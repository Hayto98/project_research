@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
start
:Assign Route;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Update Inventory;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Load Package;
:Schedule Pickup;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Report Issue;
:Track Shipment;
:Fuel Vehicle;
:Deliver Package;
stop
@enduml