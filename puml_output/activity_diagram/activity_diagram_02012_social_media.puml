@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
start
:Create Post;
:Report Content;
:Like Post;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Comment;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Send Message;
stop
@enduml