@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
start
:Borrow Book;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Register Member;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Add New Book;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Reserve Book;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Return Book;
:Renew Loan;
:Search Catalog;
stop
@enduml