@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
start
:Manage Inventory;
fork
:notify user;
fork again
:log action;
end fork
:Write Review;
:Checkout;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Add To Cart;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Make Payment;
:Browse Products;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Track Order;
:Apply Coupon;
stop
@enduml