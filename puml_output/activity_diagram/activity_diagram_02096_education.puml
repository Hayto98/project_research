@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
start
:Enroll Course;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log action;
end fork
:Submit Assignment;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Take Attendance;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log event;
end fork
:Register Student;
:Grade Exam;
:Issue Certificate;
stop
@enduml