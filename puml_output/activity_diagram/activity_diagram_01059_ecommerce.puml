@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
start
:Add To Cart;
:Checkout;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log event;
end fork
:Write Review;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Cancel Order;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Make Payment;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log change;
end fork
:Apply Coupon;
stop
@enduml