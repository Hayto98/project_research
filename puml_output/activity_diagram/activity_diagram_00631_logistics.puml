@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
start
:Schedule Pickup;
:Track Shipment;
:Load Package;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Assign Route;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Deliver Package;
:Fuel Vehicle;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Update Inventory;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Report Issue;
fork
:notify user;
fork again
:log event;
end fork
stop
@enduml