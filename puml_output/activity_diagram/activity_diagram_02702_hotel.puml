@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
start
:Request Service;
fork
:notify system;
fork again
:log event;
end fork
:Check In;
:Order Room Service;
fork
:notify admin;
fork again
:log change;
end fork
:Book Room;
:Check Out;
:Clean Room;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Process Payment;
stop
@enduml