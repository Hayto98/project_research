@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
start
:Cancel Reservation;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Request Service;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Order Room Service;
:Check Out;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Book Room;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log change;
end fork
:Process Payment;
stop
@enduml