@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
start
:Return Book;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Renew Loan;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log action;
end fork
:Borrow Book;
:Pay Fine;
:Add New Book;
:Reserve Book;
stop
@enduml