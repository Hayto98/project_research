@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
start
:Examine Patient;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Book Appointment;
:Issue Prescription;
:Process Insurance Claim;
:Run Lab Test;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log action;
end fork
:Discharge Patient;
:Update Medical Record;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Admit Patient;
stop
@enduml