@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
start
:Open Account;
:Apply For Loan;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log action;
end fork
:Block Card;
:View Statement;
fork
:notify user;
fork again
:log event;
end fork
:Deposit Money;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Withdraw Cash;
fork
:notify admin;
fork again
:log event;
end fork
:Transfer Funds;
stop
@enduml