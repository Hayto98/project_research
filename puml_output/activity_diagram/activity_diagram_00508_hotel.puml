@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
start
:Process Payment;
:Clean Room;
:Book Room;
:Order Room Service;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Check In;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Cancel Reservation;
fork
:notify system;
fork again
:log action;
end fork
:Request Service;
:Check Out;
stop
@enduml