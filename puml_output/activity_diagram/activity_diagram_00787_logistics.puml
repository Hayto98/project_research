@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
start
:Deliver Package;
:Schedule Pickup;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log action;
end fork
:Report Issue;
:Track Shipment;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Assign Route;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log event;
end fork
:Fuel Vehicle;
:Load Package;
stop
@enduml