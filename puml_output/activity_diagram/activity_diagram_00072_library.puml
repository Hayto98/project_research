@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
start
:Return Book;
:Search Catalog;
fork
:notify admin;
fork again
:log action;
end fork
:Reserve Book;
fork
:notify user;
fork again
:log event;
end fork
:Register Member;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Renew Loan;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log action;
end fork
:Add New Book;
stop
@enduml