@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
start
:Book Appointment;
:Examine Patient;
:Issue Prescription;
fork
:notify admin;
fork again
:log change;
end fork
:Discharge Patient;
:Update Medical Record;
:Process Insurance Claim;
fork
:notify admin;
fork again
:log change;
end fork
:Admit Patient;
stop
@enduml