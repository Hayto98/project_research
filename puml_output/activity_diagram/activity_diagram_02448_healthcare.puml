@startuml
skinparam monochrome true
skinparam defaultFontSize 11
start
:Admit Patient;
:Update Medical Record;
:Book Appointment;
fork
:notify system;
fork again
:log event;
end fork
:Run Lab Test;
fork
:notify system;
fork again
:log action;
end fork
:Examine Patient;
:Issue Prescription;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Discharge Patient;
stop
@enduml