@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
start
:Book Appointment;
fork
:notify admin;
fork again
:log event;
end fork
:Update Medical Record;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Examine Patient;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log action;
end fork
:Issue Prescription;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Admit Patient;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Run Lab Test;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Discharge Patient;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Process Insurance Claim;
stop
@enduml