@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
start
:Assign Route;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Deliver Package;
:Schedule Pickup;
:Update Inventory;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Fuel Vehicle;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Load Package;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Track Shipment;
:Report Issue;
stop
@enduml