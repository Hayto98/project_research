@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
start
:Load Package;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log action;
end fork
:Report Issue;
:Fuel Vehicle;
:Assign Route;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Deliver Package;
:Track Shipment;
:Update Inventory;
:Schedule Pickup;
fork
:notify admin;
fork again
:log event;
end fork
stop
@enduml