@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
start
:Discharge Patient;
fork
:notify system;
fork again
:log change;
end fork
:Book Appointment;
:Admit Patient;
:Update Medical Record;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Issue Prescription;
:Run Lab Test;
:Process Insurance Claim;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Examine Patient;
stop
@enduml