@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
start
:View Schedule;
fork
:notify admin;
fork again
:log change;
end fork
:Submit Assignment;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Grade Exam;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Borrow Book;
fork
:notify admin;
fork again
:log change;
end fork
:Register Student;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Take Attendance;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log action;
end fork
:Enroll Course;
:Issue Certificate;
stop
@enduml