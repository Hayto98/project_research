@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
start
:Add New Book;
fork
:notify user;
fork again
:log action;
end fork
:Search Catalog;
:Renew Loan;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Borrow Book;
:Reserve Book;
fork
:notify user;
fork again
:log action;
end fork
:Register Member;
stop
@enduml