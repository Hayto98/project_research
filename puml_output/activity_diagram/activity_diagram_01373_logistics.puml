@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
start
:Fuel Vehicle;
:Update Inventory;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Report Issue;
:Deliver Package;
:Assign Route;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Track Shipment;
fork
:notify admin;
fork again
:log action;
end fork
:Load Package;
stop
@enduml