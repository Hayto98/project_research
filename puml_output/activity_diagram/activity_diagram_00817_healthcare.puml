@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
start
:Examine Patient;
:Issue Prescription;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log change;
end fork
:Book Appointment;
:Discharge Patient;
fork
:notify admin;
fork again
:log action;
end fork
:Process Insurance Claim;
:Run Lab Test;
:Update Medical Record;
stop
@enduml