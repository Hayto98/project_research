@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
start
:Register Student;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Take Attendance;
:View Schedule;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Submit Assignment;
fork
:notify user;
fork again
:log action;
end fork
:Enroll Course;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Issue Certificate;
stop
@enduml