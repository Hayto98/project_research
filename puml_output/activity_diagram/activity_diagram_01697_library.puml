@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
start
:Borrow Book;
:Add New Book;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log action;
end fork
:Register Member;
fork
:notify system;
fork again
:log change;
end fork
:Reserve Book;
:Renew Loan;
fork
:notify system;
fork again
:log action;
end fork
:Pay Fine;
fork
:notify user;
fork again
:log action;
end fork
:Search Catalog;
:Return Book;
stop
@enduml