@startuml
skinparam monochrome true
skinparam defaultFontSize 13
start
:Checkout;
:Make Payment;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log change;
end fork
:Browse Products;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Write Review;
:Cancel Order;
fork
:notify system;
fork again
:log change;
end fork
:Track Order;
:Apply Coupon;
stop
@enduml