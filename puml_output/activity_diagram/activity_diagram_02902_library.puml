@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
start
:Renew Loan;
:Add New Book;
:Reserve Book;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log event;
end fork
:Return Book;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Register Member;
:Search Catalog;
:Borrow Book;
:Pay Fine;
fork
:notify user;
fork again
:log action;
end fork
stop
@enduml