@startuml
skinparam monochrome true
skinparam ArrowColor #555555
start
:Track Shipment;
:Assign Route;
:Report Issue;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log event;
end fork
:Schedule Pickup;
:Load Package;
fork
:notify system;
fork again
:log event;
end fork
:Fuel Vehicle;
:Update Inventory;
fork
:notify user;
fork again
:log change;
end fork
stop
@enduml