@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
start
:Renew Loan;
:Search Catalog;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Reserve Book;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log change;
end fork
:Borrow Book;
:Add New Book;
fork
:notify admin;
fork again
:log event;
end fork
:Register Member;
stop
@enduml