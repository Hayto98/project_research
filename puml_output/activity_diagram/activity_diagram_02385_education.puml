@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
start
:Register Student;
:Grade Exam;
:View Schedule;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Take Attendance;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Submit Assignment;
:Enroll Course;
:Borrow Book;
:Issue Certificate;
fork
:notify user;
fork again
:log action;
end fork
stop
@enduml