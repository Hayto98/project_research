@startuml
skinparam shadowing true
start
:Block Card;
:Apply For Loan;
:Open Account;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Pay Bill;
:View Statement;
fork
:notify admin;
fork again
:log event;
end fork
:Deposit Money;
:Withdraw Cash;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Transfer Funds;
stop
@enduml