@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
start
:View Statement;
:Deposit Money;
:Apply For Loan;
if (valid?) then (yes)
:continue process;
