@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
start
:Block Card;
fork
:notify system;
fork again
:log change;
end fork
:Withdraw Cash;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log event;
end fork
:Transfer Funds;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Deposit Money;
:View Statement;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log event;
end fork
:Pay Bill;
:Open Account;
:Apply For Loan;
stop
@enduml