@startuml
skinparam shadowing true
start
:Create Post;
:Comment;
:Edit Profile;
:Share Post;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Send Message;
:Like Post;
:Report Content;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Follow User;
stop
@enduml