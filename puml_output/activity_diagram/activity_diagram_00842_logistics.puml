@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
start
:Assign Route;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log change;
end fork
:Schedule Pickup;
:Update Inventory;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Track Shipment;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Fuel Vehicle;
fork
:notify admin;
fork again
:log event;
end fork
:Load Package;
:Report Issue;
:Deliver Package;
stop
@enduml