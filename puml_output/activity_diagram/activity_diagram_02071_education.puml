@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
start
:Register Student;
:Take Attendance;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:View Schedule;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log action;
end fork
:Issue Certificate;
:Grade Exam;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log change;
end fork
:Submit Assignment;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Borrow Book;
:Enroll Course;
fork
:notify system;
fork again
:log action;
end fork
stop
@enduml