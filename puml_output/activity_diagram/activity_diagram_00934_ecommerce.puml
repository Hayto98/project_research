@startuml
skinparam defaultFontSize 13
start
:Make Payment;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Add To Cart;
:Browse Products;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Write Review;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Manage Inventory;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log action;
end fork
:Apply Coupon;
:Track Order;
:Cancel Order;
stop
@enduml