@startuml

start
:Apply For Loan;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:View Statement;
:Transfer Funds;
:Open Account;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Block Card;
:Pay Bill;
:Deposit Money;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log event;
end fork
:Withdraw Cash;
stop
@enduml