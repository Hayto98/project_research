@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
start
:Request Service;
fork
:notify admin;
fork again
:log action;
end fork
:Check Out;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Order Room Service;
:Clean Room;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Check In;
fork
:notify system;
fork again
:log change;
end fork
:Cancel Reservation;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Process Payment;
stop
@enduml