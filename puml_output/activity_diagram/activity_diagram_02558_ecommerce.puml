@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
start
:Cancel Order;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Track Order;
:Manage Inventory;
:Add To Cart;
:Write Review;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
