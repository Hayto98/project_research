@startuml
skinparam monochrome true
skinparam defaultFontSize 13
start
:Register Student;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log change;
end fork
:View Schedule;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Borrow Book;
:Submit Assignment;
:Grade Exam;
:Issue Certificate;
stop
@enduml