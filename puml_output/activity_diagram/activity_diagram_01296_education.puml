@startuml
skinparam monochrome true
skinparam defaultFontSize 13
start
:Submit Assignment;
:Take Attendance;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Issue Certificate;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
