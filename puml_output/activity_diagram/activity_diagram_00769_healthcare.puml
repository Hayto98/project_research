@startuml
skinparam monochrome true
skinparam defaultFontSize 11
start
:Book Appointment;
:Discharge Patient;
fork
:notify admin;
fork again
:log change;
end fork
:Run Lab Test;
:Admit Patient;
:Issue Prescription;
fork
:notify admin;
fork again
:log change;
end fork
:Examine Patient;
fork
:notify admin;
fork again
:log change;
end fork
:Update Medical Record;
fork
:notify system;
fork again
:log change;
end fork
stop
@enduml