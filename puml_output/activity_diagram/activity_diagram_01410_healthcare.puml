@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
start
:Examine Patient;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log change;
end fork
:Update Medical Record;
:Process Insurance Claim;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Issue Prescription;
fork
:notify system;
fork again
:log change;
end fork
:Run Lab Test;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Discharge Patient;
stop
@enduml