@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
start
:Examine Patient;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Book Appointment;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log event;
end fork
:Process Insurance Claim;
:Admit Patient;
:Update Medical Record;
:Run Lab Test;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Issue Prescription;
stop
@enduml