@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
start
:Transfer Funds;
fork
:notify system;
fork again
:log event;
end fork
:View Statement;
:Withdraw Cash;
:Apply For Loan;
:Open Account;
:Deposit Money;
:Block Card;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Pay Bill;
fork
:notify system;
fork again
:log change;
end fork
stop
@enduml