@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
start
:Register Member;
:Reserve Book;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Pay Fine;
:Return Book;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Add New Book;
:Renew Loan;
fork
:notify system;
fork again
:log action;
end fork
stop
@enduml