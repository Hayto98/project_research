@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
start
:Borrow Book;
:Search Catalog;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log action;
end fork
:Renew Loan;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Pay Fine;
:Register Member;
:Add New Book;
fork
:notify admin;
fork again
:log change;
end fork
stop
@enduml