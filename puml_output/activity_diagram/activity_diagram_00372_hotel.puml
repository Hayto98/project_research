@startuml
skinparam defaultFontSize 13
start
:Book Room;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Check Out;
fork
:notify system;
fork again
:log event;
end fork
:Check In;
fork
:notify user;
fork again
:log event;
end fork
:Request Service;
:Cancel Reservation;
fork
:notify system;
fork again
:log action;
end fork
:Order Room Service;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Process Payment;
fork
:notify admin;
fork again
:log event;
end fork
stop
@enduml