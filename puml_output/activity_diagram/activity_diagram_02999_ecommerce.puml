@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
start
:Write Review;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log action;
end fork
:Add To Cart;
:Track Order;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Make Payment;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Checkout;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Manage Inventory;
:Apply Coupon;
:Browse Products;
stop
@enduml