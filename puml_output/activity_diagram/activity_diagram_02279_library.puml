@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
start
:Renew Loan;
:Register Member;
:Reserve Book;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Search Catalog;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Return Book;
:Add New Book;
stop
@enduml