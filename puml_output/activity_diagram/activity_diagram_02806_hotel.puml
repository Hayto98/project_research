@startuml
skinparam monochrome true
skinparam shadowing true
start
:Book Room;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Order Room Service;
:Check In;
:Check Out;
:Cancel Reservation;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log action;
end fork
:Request Service;
:Clean Room;
stop
@enduml