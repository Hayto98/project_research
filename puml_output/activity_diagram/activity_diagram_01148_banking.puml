@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
start
:Apply For Loan;
:Pay Bill;
fork
:notify system;
fork again
:log action;
end fork
:View Statement;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Open Account;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Deposit Money;
stop
@enduml