@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
start
:Process Payment;
:Check In;
:Cancel Reservation;
:Order Room Service;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Check Out;
:Clean Room;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Request Service;
fork
:notify system;
fork again
:log change;
end fork
stop
@enduml