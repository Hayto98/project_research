@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
start
:Order Room Service;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Check In;
fork
:notify system;
fork again
:log action;
end fork
:Cancel Reservation;
:Request Service;
:Clean Room;
:Process Payment;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Book Room;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Check Out;
stop
@enduml