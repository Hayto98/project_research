@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
start
:Grade Exam;
:Borrow Book;
:Submit Assignment;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:View Schedule;
fork
:notify admin;
fork again
:log event;
end fork
:Enroll Course;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log event;
end fork
:Issue Certificate;
stop
@enduml