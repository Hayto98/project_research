@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
start
:Reserve Book;
:Search Catalog;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Add New Book;
:Renew Loan;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log event;
end fork
:Register Member;
:Borrow Book;
fork
:notify user;
fork again
:log event;
end fork
stop
@enduml