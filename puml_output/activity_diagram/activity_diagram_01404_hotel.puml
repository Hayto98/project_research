@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
start
:Check Out;
fork
:notify admin;
fork again
:log change;
end fork
:Book Room;
:Check In;
:Order Room Service;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Request Service;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log event;
end fork
:Clean Room;
:Cancel Reservation;
stop
@enduml