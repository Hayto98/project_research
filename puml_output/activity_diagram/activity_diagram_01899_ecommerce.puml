@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
start
:Add To Cart;
:Make Payment;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Write Review;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Apply Coupon;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Manage Inventory;
:Cancel Order;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log event;
end fork
:Track Order;
fork
:notify system;
fork again
:log event;
end fork
stop
@enduml