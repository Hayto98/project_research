@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
start
:Deposit Money;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Open Account;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Block Card;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:View Statement;
fork
:notify user;
fork again
:log action;
end fork
:Withdraw Cash;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Transfer Funds;
fork
:notify system;
fork again
:log event;
end fork
:Pay Bill;
:Apply For Loan;
stop
@enduml