@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
start
:Check In;
:Request Service;
:Cancel Reservation;
:Order Room Service;
:Check Out;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Book Room;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Process Payment;
fork
:notify admin;
fork again
:log action;
end fork
stop
@enduml