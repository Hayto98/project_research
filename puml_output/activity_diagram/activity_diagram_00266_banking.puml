@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
start
:Apply For Loan;
fork
:notify admin;
fork again
:log action;
end fork
:Deposit Money;
:View Statement;
:Withdraw Cash;
:Open Account;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Pay Bill;
:Block Card;
fork
:notify system;
fork again
:log action;
end fork
stop
@enduml