@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
start
:Check In;
:Order Room Service;
:Check Out;
:Process Payment;
fork
:notify system;
fork again
:log change;
end fork
:Clean Room;
:Cancel Reservation;
fork
:notify user;
fork again
:log action;
end fork
:Request Service;
stop
@enduml