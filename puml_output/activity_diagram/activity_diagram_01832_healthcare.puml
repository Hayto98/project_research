@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
start
:Run Lab Test;
:Discharge Patient;
:Issue Prescription;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Examine Patient;
fork
:notify system;
fork again
:log event;
end fork
:Book Appointment;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Update Medical Record;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Admit Patient;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Process Insurance Claim;
stop
@enduml