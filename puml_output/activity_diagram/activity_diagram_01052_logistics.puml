@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
start
:Assign Route;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log change;
end fork
:Deliver Package;
:Report Issue;
fork
:notify user;
fork again
:log change;
end fork
:Track Shipment;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Load Package;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Schedule Pickup;
stop
@enduml