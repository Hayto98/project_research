@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
start
:Reserve Book;
fork
:notify system;
fork again
:log action;
end fork
:Search Catalog;
:Register Member;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Borrow Book;
:Renew Loan;
stop
@enduml