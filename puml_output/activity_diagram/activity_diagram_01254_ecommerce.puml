@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
start
:Browse Products;
:Track Order;
fork
:notify system;
fork again
:log change;
end fork
:Manage Inventory;
:Cancel Order;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Write Review;
:Make Payment;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Add To Cart;
:Checkout;
stop
@enduml