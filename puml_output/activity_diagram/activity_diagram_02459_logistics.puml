@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
start
:Update Inventory;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Fuel Vehicle;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Load Package;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Deliver Package;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log action;
end fork
:Schedule Pickup;
:Report Issue;
:Track Shipment;
:Assign Route;
stop
@enduml