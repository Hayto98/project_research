@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
start
:Issue Certificate;
fork
:notify user;
fork again
:log change;
end fork
:Borrow Book;
:Take Attendance;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Register Student;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Submit Assignment;
:Grade Exam;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:View Schedule;
:Enroll Course;
stop
@enduml