@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
start
:Check Out;
:Order Room Service;
fork
:notify system;
fork again
:log action;
end fork
:Book Room;
:Check In;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Cancel Reservation;
:Clean Room;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Process Payment;
:Request Service;
stop
@enduml