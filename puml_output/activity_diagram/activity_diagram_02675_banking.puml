@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
start
:Open Account;
:Pay Bill;
:View Statement;
fork
:notify user;
fork again
:log action;
end fork
:Withdraw Cash;
:Apply For Loan;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Transfer Funds;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Block Card;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Deposit Money;
stop
@enduml