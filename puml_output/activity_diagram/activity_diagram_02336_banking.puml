@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
start
:Apply For Loan;
:Deposit Money;
:View Statement;
:Block Card;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Pay Bill;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Withdraw Cash;
fork
:notify admin;
fork again
:log event;
end fork
stop
@enduml