@startuml
skinparam monochrome true
skinparam shadowing true
start
:Request Service;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Cancel Reservation;
:Book Room;
:Process Payment;
:Order Room Service;
fork
:notify user;
fork again
:log action;
end fork
:Clean Room;
stop
@enduml