@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
start
:Withdraw Cash;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log action;
end fork
:Open Account;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Deposit Money;
:Pay Bill;
:View Statement;
stop
@enduml