@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
start
:Follow User;
:Edit Profile;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Comment;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Share Post;
:Report Content;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Like Post;
stop
@enduml