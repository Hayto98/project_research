@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
start
:Make Payment;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log event;
end fork
:Add To Cart;
:Apply Coupon;
:Track Order;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Write Review;
:Checkout;
stop
@enduml