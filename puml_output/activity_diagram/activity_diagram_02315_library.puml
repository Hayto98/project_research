@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
start
:Search Catalog;
:Add New Book;
fork
:notify user;
fork again
:log action;
end fork
:Reserve Book;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Register Member;
fork
:notify user;
fork again
:log change;
end fork
:Renew Loan;
:Pay Fine;
stop
@enduml