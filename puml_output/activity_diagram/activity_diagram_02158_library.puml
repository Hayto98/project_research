@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
start
:Pay Fine;
:Renew Loan;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Search Catalog;
fork
:notify system;
fork again
:log event;
end fork
:Borrow Book;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Return Book;
stop
@enduml