@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
start
:Cancel Order;
fork
:notify user;
fork again
:log event;
end fork
:Checkout;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Manage Inventory;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Write Review;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Apply Coupon;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Browse Products;
fork
:notify user;
fork again
:log change;
end fork
:Make Payment;
stop
@enduml