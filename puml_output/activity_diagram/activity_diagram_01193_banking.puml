@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
start
:Transfer Funds;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Open Account;
:Block Card;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Pay Bill;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:View Statement;
fork
:notify user;
fork again
:log action;
end fork
stop
@enduml