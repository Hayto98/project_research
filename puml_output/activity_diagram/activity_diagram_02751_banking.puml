@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
start
:View Statement;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Deposit Money;
fork
:notify system;
fork again
:log change;
end fork
:Withdraw Cash;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Pay Bill;
:Open Account;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Block Card;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log action;
end fork
:Transfer Funds;
fork
:notify admin;
fork again
:log change;
end fork
stop
@enduml