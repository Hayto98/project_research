@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
start
:Follow User;
:Comment;
:Report Content;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Share Post;
:Create Post;
:Like Post;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Edit Profile;
fork
:notify system;
fork again
:log event;
end fork
stop
@enduml