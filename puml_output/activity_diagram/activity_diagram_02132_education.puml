@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
start
:Enroll Course;
fork
:notify user;
fork again
:log action;
end fork
:Grade Exam;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Submit Assignment;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Issue Certificate;
:Borrow Book;
stop
@enduml