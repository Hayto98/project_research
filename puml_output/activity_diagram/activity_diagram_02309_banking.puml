@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
start
:Pay Bill;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Apply For Loan;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log event;
end fork
:Withdraw Cash;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Deposit Money;
fork
:notify system;
fork again
:log change;
end fork
:Block Card;
:Open Account;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Transfer Funds;
stop
@enduml