@startuml
skinparam monochrome true
skinparam defaultFontSize 13
start
:Comment;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Send Message;
:Like Post;
:Edit Profile;
:Share Post;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Follow User;
:Report Content;
stop
@enduml