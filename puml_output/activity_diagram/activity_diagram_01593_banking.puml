@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
start
:Pay Bill;
:Deposit Money;
fork
:notify system;
fork again
:log event;
end fork
:Withdraw Cash;
:Open Account;
:Transfer Funds;
fork
:notify user;
fork again
:log change;
end fork
:View Statement;
:Block Card;
fork
:notify system;
fork again
:log change;
end fork
stop
@enduml