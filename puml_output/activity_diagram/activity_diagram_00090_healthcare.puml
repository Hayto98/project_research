@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
start
:Discharge Patient;
:Book Appointment;
:Examine Patient;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Issue Prescription;
:Update Medical Record;
:Run Lab Test;
fork
:notify user;
fork again
:log change;
end fork
:Admit Patient;
fork
:notify admin;
fork again
:log change;
end fork
stop
@enduml