@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
start
:Assign Route;
:Load Package;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log change;
end fork
:Schedule Pickup;
fork
:notify system;
fork again
:log action;
end fork
:Track Shipment;
fork
:notify user;
fork again
:log event;
end fork
:Update Inventory;
:Fuel Vehicle;
:Report Issue;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Deliver Package;
stop
@enduml