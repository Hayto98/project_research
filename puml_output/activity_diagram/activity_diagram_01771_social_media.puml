@startuml
skinparam monochrome true
skinparam defaultFontSize 11
start
:Share Post;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Follow User;
:Comment;
:Send Message;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Create Post;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Report Content;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Edit Profile;
:Like Post;
stop
@enduml