@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
start
:Cancel Reservation;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Order Room Service;
fork
:notify admin;
fork again
:log action;
end fork
:Request Service;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Process Payment;
:Clean Room;
:Check In;
fork
:notify user;
fork again
:log event;
end fork
:Book Room;
stop
@enduml