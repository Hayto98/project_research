@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
start
:Request Service;
fork
:notify user;
fork again
:log event;
end fork
:Check In;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Book Room;
fork
:notify admin;
fork again
:log event;
end fork
:Order Room Service;
:Clean Room;
:Check Out;
:Cancel Reservation;
fork
:notify user;
fork again
:log event;
end fork
stop
@enduml