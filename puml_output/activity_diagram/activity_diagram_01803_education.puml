@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
start
:Grade Exam;
:Borrow Book;
fork
:notify system;
fork again
:log event;
end fork
:Take Attendance;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Register Student;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Enroll Course;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:View Schedule;
:Submit Assignment;
stop
@enduml