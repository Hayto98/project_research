@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
start
:Update Medical Record;
:Admit Patient;
:Discharge Patient;
:Run Lab Test;
fork
:notify admin;
fork again
:log action;
end fork
:Examine Patient;
:Process Insurance Claim;
:Book Appointment;
stop
@enduml