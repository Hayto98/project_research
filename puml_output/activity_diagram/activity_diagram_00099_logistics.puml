:continue process;
else (no)
:handle error;
stop
endif
:Update Inventory;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Deliver Package;
fork
:notify user;
fork again
:log action;
end fork
stop
