@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
start
:Schedule Pickup;
:Track Shipment;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Assign Route;
:Load Package;
:Fuel Vehicle;
