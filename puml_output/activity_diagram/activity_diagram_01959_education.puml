@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
start
:Issue Certificate;
fork
:notify system;
fork again
:log event;
end fork
:Grade Exam;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Take Attendance;
:Register Student;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Submit Assignment;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Enroll Course;
:View Schedule;
:Borrow Book;
stop
@enduml