@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
start
:Borrow Book;
fork
:notify system;
fork again
:log change;
end fork
:Register Member;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Search Catalog;
:Reserve Book;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Pay Fine;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Renew Loan;
:Add New Book;
stop
@enduml