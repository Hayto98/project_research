@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
start
:Send Message;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Like Post;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log change;
end fork
:Share Post;
:Follow User;
:Report Content;
stop
@enduml