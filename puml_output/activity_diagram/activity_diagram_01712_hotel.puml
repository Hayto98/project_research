@startuml
skinparam monochrome true
skinparam defaultFontSize 13
start
:Cancel Reservation;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Check In;
:Check Out;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Book Room;
:Process Payment;
:Request Service;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Order Room Service;
:Clean Room;
fork
:notify user;
fork again
:log event;
end fork
stop
@enduml