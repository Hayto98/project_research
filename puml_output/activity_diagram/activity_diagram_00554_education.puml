@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
start
:View Schedule;
:Enroll Course;
:Submit Assignment;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Register Student;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log change;
end fork
:Grade Exam;
:Borrow Book;
stop
@enduml