@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
start
:Make Payment;
:Browse Products;
:Manage Inventory;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log change;
end fork
:Write Review;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Track Order;
stop
@enduml