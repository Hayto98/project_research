@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
start
:Discharge Patient;
:Process Insurance Claim;
fork
:notify system;
fork again
:log change;
end fork
:Admit Patient;
fork
:notify system;
fork again
:log event;
end fork
:Run Lab Test;
:Update Medical Record;
fork
:notify system;
fork again
:log change;
end fork
:Issue Prescription;
:Book Appointment;
stop
@enduml