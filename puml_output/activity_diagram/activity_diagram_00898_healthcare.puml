@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
start
:Admit Patient;
:Book Appointment;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Discharge Patient;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Process Insurance Claim;
fork
:notify admin;
fork again
:log event;
end fork
:Issue Prescription;
stop
@enduml