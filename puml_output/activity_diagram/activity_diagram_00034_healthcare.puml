@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
start
:Discharge Patient;
:Run Lab Test;
fork
:notify admin;
fork again
:log event;
end fork
:Examine Patient;
:Admit Patient;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log change;
end fork
:Book Appointment;
:Process Insurance Claim;
stop
@enduml