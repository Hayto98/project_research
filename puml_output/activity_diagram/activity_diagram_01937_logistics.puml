@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
start
:Schedule Pickup;
:Track Shipment;
:Load Package;
fork
:notify admin;
fork again
:log change;
end fork
:Report Issue;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log action;
end fork
:Deliver Package;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Fuel Vehicle;
:Update Inventory;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Assign Route;
stop
@enduml