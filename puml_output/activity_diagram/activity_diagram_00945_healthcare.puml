@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
start
:Discharge Patient;
:Update Medical Record;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Run Lab Test;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Issue Prescription;
fork
:notify system;
fork again
:log action;
end fork
:Examine Patient;
:Process Insurance Claim;
fork
:notify user;
fork again
:log event;
end fork
:Admit Patient;
:Book Appointment;
stop
@enduml