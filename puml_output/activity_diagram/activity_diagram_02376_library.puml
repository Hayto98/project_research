@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
start
:Add New Book;
:Renew Loan;
fork
:notify user;
fork again
:log event;
end fork
:Register Member;
:Return Book;
:Reserve Book;
:Borrow Book;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Search Catalog;
fork
:notify user;
fork again
:log event;
end fork
:Pay Fine;
stop
@enduml