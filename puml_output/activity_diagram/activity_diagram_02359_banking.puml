@startuml
skinparam monochrome true
start
:Block Card;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log change;
end fork
:Deposit Money;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Open Account;
:Pay Bill;
:Transfer Funds;
:Withdraw Cash;
stop
@enduml