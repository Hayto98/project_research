@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
start
:Apply For Loan;
fork
:notify admin;
fork again
:log change;
end fork
:Withdraw Cash;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:View Statement;
:Transfer Funds;
:Deposit Money;
:Pay Bill;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log action;
end fork
:Open Account;
stop
@enduml