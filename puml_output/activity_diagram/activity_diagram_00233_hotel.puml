@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
start
:Request Service;
:Check Out;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Process Payment;
:Check In;
:Clean Room;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Book Room;
stop
@enduml