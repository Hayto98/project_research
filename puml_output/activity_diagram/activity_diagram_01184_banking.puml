@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
start
:Block Card;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Open Account;
:Withdraw Cash;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Transfer Funds;
:View Statement;
:Apply For Loan;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log change;
end fork
:Deposit Money;
fork
:notify user;
fork again
:log change;
end fork
:Pay Bill;
stop
@enduml