@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
start
:Cancel Reservation;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Clean Room;
:Book Room;
:Check Out;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Request Service;
:Check In;
fork
:notify admin;
fork again
:log action;
end fork
:Process Payment;
fork
:notify user;
fork again
:log event;
end fork
stop
@enduml