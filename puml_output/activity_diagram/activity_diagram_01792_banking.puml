@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
start
:Transfer Funds;
:Pay Bill;
:Open Account;
fork
:notify system;
fork again
:log action;
end fork
:Apply For Loan;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:View Statement;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log event;
end fork
:Deposit Money;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Block Card;
stop
@enduml