@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
start
:View Statement;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Block Card;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Apply For Loan;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Open Account;
:Transfer Funds;
:Withdraw Cash;
:Deposit Money;
stop
@enduml