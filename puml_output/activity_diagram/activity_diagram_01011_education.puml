@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
start
:Enroll Course;
fork
:notify user;
fork again
:log action;
end fork
:Issue Certificate;
:Submit Assignment;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Borrow Book;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Register Student;
:View Schedule;
:Take Attendance;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Grade Exam;
fork
:notify admin;
fork again
:log event;
end fork
stop
@enduml