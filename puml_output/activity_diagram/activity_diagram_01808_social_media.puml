@startuml
skinparam monochrome true
skinparam ArrowColor #555555
start
:Send Message;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log action;
end fork
:Report Content;
:Edit Profile;
fork
:notify admin;
fork again
:log event;
end fork
:Comment;
:Share Post;
:Create Post;
:Follow User;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Like Post;
stop
@enduml