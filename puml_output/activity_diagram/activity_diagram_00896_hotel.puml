@startuml
skinparam monochrome true
skinparam defaultFontSize 11
start
:Book Room;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Order Room Service;
:Clean Room;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Process Payment;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Check In;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Request Service;
:Cancel Reservation;
:Check Out;
fork
:notify user;
fork again
:log event;
end fork
stop
@enduml