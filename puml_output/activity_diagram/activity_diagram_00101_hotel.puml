@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
start
:Check In;
:Request Service;
:Process Payment;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log event;
end fork
:Check Out;
fork
:notify user;
fork again
:log action;
end fork
:Cancel Reservation;
fork
:notify admin;
fork again
:log change;
end fork
:Book Room;
stop
@enduml