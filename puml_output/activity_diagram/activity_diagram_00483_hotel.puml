@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
start
:Check Out;
fork
:notify system;
fork again
:log change;
end fork
:Clean Room;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Book Room;
fork
:notify user;
fork again
:log change;
end fork
:Order Room Service;
:Cancel Reservation;
:Process Payment;
:Request Service;
:Check In;
stop
@enduml