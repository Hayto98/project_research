@startuml
skinparam monochrome true
skinparam defaultFontSize 13
start
:Comment;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Report Content;
:Create Post;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Follow User;
:Send Message;
:Like Post;
stop
@enduml