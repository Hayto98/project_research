@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
start
:Enroll Course;
fork
:notify system;
fork again
:log change;
end fork
:Submit Assignment;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Register Student;
:Take Attendance;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Grade Exam;
:Borrow Book;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:View Schedule;
stop
@enduml