@startuml
skinparam monochrome true
skinparam defaultFontSize 11
start
:Check In;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Clean Room;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Process Payment;
:Request Service;
:Order Room Service;
fork
:notify system;
fork again
:log action;
end fork
:Book Room;
:Cancel Reservation;
:Check Out;
stop
@enduml