@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
start
:Clean Room;
:Book Room;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Order Room Service;
fork
:notify system;
fork again
:log change;
end fork
:Cancel Reservation;
:Check Out;
fork
:notify user;
fork again
:log change;
end fork
:Process Payment;
:Request Service;
stop
@enduml