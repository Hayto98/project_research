@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
start
:Track Order;
:Make Payment;
:Cancel Order;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Browse Products;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log action;
end fork
:Checkout;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Add To Cart;
:Apply Coupon;
stop
@enduml