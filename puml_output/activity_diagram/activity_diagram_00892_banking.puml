@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
start
:Deposit Money;
fork
:notify user;
fork again
:log action;
end fork
:Open Account;
:Transfer Funds;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log event;
end fork
:Pay Bill;
:View Statement;
stop
@enduml