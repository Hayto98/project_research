@startuml
skinparam monochrome true
skinparam shadowing true
start
:Clean Room;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log event;
end fork
:Process Payment;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Request Service;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Check In;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Cancel Reservation;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Order Room Service;
fork
:notify system;
fork again
:log action;
end fork
:Check Out;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Book Room;
stop
@enduml