@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
start
:Book Room;
:Check Out;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Cancel Reservation;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Check In;
:Order Room Service;
fork
:notify admin;
fork again
:log change;
end fork
:Request Service;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Clean Room;
:Process Payment;
fork
:notify admin;
fork again
:log action;
end fork
stop
@enduml