@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
start
:Follow User;
fork
:notify admin;
fork again
:log event;
end fork
:Create Post;
:Like Post;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Comment;
:Report Content;
:Send Message;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Edit Profile;
fork
:notify user;
fork again
:log event;
end fork
stop
@enduml