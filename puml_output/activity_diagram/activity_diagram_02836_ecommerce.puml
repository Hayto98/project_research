@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
start
:Cancel Order;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Checkout;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Track Order;
:Apply Coupon;
:Browse Products;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Write Review;
:Make Payment;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Add To Cart;
fork
:notify user;
fork again
:log change;
end fork
stop
@enduml