@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
start
:Pay Fine;
:Renew Loan;
:Borrow Book;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Return Book;
:Reserve Book;
:Search Catalog;
:Register Member;
:Add New Book;
fork
:notify system;
fork again
:log action;
end fork
stop
@enduml