@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
start
:Like Post;
:Send Message;
:Share Post;
fork
:notify system;
fork again
:log change;
end fork
:Report Content;
:Create Post;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log action;
end fork
:Edit Profile;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Comment;
:Follow User;
stop
@enduml