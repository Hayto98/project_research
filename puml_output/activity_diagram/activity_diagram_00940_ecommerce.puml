@startuml
skinparam monochrome true
skinparam shadowing true
start
:Write Review;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log event;
end fork
:Manage Inventory;
:Track Order;
:Apply Coupon;
:Browse Products;
fork
:notify admin;
fork again
:log change;
end fork
:Cancel Order;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Checkout;
stop
@enduml