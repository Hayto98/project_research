@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
start
:Add To Cart;
fork
:notify user;
fork again
:log event;
end fork
:Checkout;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log change;
end fork
:Apply Coupon;
fork
:notify user;
fork again
:log action;
end fork
:Track Order;
:Manage Inventory;
:Make Payment;
:Browse Products;
:Cancel Order;
fork
:notify user;
fork again
:log change;
end fork
stop
@enduml