@startuml
skinparam monochrome true
skinparam shadowing true
start
:Report Content;
:Share Post;
:Send Message;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Follow User;
:Create Post;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log event;
end fork
:Like Post;
:Edit Profile;
fork
:notify admin;
fork again
:log action;
end fork
:Comment;
stop
@enduml