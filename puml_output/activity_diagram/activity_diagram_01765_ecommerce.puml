@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
start
:Manage Inventory;
fork
:notify user;
fork again
:log action;
end fork
:Cancel Order;
if (approved?) then (yes)
:continue process;
