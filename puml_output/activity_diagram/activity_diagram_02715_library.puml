@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
start
:Renew Loan;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Register Member;
:Pay Fine;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log event;
end fork
:Borrow Book;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Search Catalog;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Return Book;
fork
:notify system;
fork again
:log action;
end fork
stop
@enduml