@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
start
:Report Issue;
:Schedule Pickup;
:Load Package;
fork
:notify user;
fork again
:log event;
end fork
:Deliver Package;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
