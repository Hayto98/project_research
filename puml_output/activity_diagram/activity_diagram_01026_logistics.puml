@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
start
:Deliver Package;
:Fuel Vehicle;
:Load Package;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Update Inventory;
:Assign Route;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Track Shipment;
:Schedule Pickup;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Report Issue;
stop
@enduml