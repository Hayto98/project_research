@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
start
:Renew Loan;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Reserve Book;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Borrow Book;
:Pay Fine;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Return Book;
:Search Catalog;
stop
@enduml