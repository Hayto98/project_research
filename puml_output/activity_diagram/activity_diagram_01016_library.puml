@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
start
:Return Book;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Pay Fine;
:Reserve Book;
:Borrow Book;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Add New Book;
:Search Catalog;
:Renew Loan;
:Register Member;
fork
:notify user;
fork again
:log event;
end fork
stop
@enduml