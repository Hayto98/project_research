@startuml
skinparam monochrome true
start
:Check In;
:Request Service;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Check Out;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Order Room Service;
:Process Payment;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Clean Room;
stop
@enduml