@startuml
skinparam monochrome true
skinparam ArrowColor #555555
start
:Add To Cart;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Track Order;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Manage Inventory;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Apply Coupon;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Cancel Order;
fork
:notify system;
fork again
:log event;
end fork
stop
@enduml