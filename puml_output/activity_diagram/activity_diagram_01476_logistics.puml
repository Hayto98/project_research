@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
start
:Schedule Pickup;
:Deliver Package;
fork
:notify system;
fork again
:log event;
end fork
:Report Issue;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Track Shipment;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Assign Route;
:Fuel Vehicle;
fork
:notify user;
fork again
:log change;
end fork
:Update Inventory;
stop
@enduml