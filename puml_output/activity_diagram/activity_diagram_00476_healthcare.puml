@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
start
:Process Insurance Claim;
:Update Medical Record;
:Run Lab Test;
:Book Appointment;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Discharge Patient;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Examine Patient;
fork
:notify user;
fork again
:log change;
end fork
stop
@enduml