@startuml
skinparam monochrome true
skinparam ArrowColor #555555
start
:Track Shipment;
:Fuel Vehicle;
:Load Package;
:Assign Route;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log event;
end fork
:Update Inventory;
fork
:notify user;
fork again
:log event;
end fork
:Deliver Package;
:Report Issue;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Schedule Pickup;
stop
@enduml