@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
start
:Process Insurance Claim;
:Run Lab Test;
:Update Medical Record;
:Book Appointment;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Discharge Patient;
:Admit Patient;
:Issue Prescription;
:Examine Patient;
fork
:notify admin;
fork again
:log action;
end fork
stop
@enduml