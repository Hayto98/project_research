@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
start
:Apply For Loan;
:Block Card;
fork
:notify user;
fork again
:log change;
end fork
:Transfer Funds;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Withdraw Cash;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Open Account;
fork
:notify system;
fork again
:log action;
end fork
:View Statement;
stop
@enduml