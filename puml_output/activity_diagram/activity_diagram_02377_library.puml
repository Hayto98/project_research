@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
start
:Borrow Book;
:Reserve Book;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log action;
end fork
:Register Member;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Return Book;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Renew Loan;
fork
:notify user;
fork again
:log action;
end fork
:Search Catalog;
:Add New Book;
:Pay Fine;
stop
@enduml