@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
start
:Browse Products;
:Apply Coupon;
:Add To Cart;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Track Order;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Cancel Order;
fork
:notify system;
fork again
:log change;
end fork
:Write Review;
fork
:notify user;
fork again
:log event;
end fork
:Checkout;
:Make Payment;
stop
@enduml