@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
start
:Report Content;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Follow User;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Send Message;
:Like Post;
:Comment;
:Create Post;
:Edit Profile;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log event;
end fork
:Share Post;
stop
@enduml