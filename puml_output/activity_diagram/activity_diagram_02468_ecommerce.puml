@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
start
:Make Payment;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Browse Products;
:Track Order;
fork
:notify system;
fork again
:log change;
end fork
:Add To Cart;
:Checkout;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Apply Coupon;
:Manage Inventory;
:Write Review;
stop
@enduml