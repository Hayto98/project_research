@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
start
:Apply Coupon;
:Browse Products;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Manage Inventory;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Cancel Order;
:Checkout;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Make Payment;
fork
:notify admin;
fork again
:log event;
end fork
stop
@enduml