@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
start
:Book Room;
:Clean Room;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Process Payment;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Check In;
fork
:notify admin;
fork again
:log action;
end fork
:Cancel Reservation;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Check Out;
:Order Room Service;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Request Service;
stop
@enduml