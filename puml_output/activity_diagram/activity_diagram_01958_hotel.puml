@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
start
:Clean Room;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log action;
end fork
:Cancel Reservation;
:Request Service;
:Check In;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Book Room;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Order Room Service;
fork
:notify admin;
fork again
:log action;
end fork
:Check Out;
:Process Payment;
stop
@enduml