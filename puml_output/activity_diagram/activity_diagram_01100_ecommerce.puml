@startuml
skinparam shadowing true
start
:Manage Inventory;
fork
:notify system;
fork again
:log event;
end fork
:Track Order;
:Cancel Order;
:Add To Cart;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Browse Products;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Make Payment;
:Write Review;
:Apply Coupon;
fork
:notify system;
fork again
:log change;
end fork
stop
@enduml