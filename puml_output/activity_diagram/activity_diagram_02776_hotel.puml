@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
start
:Cancel Reservation;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Process Payment;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Clean Room;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Book Room;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Request Service;
:Order Room Service;
:Check In;
:Check Out;
stop
@enduml