@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
start
:Comment;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Follow User;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Report Content;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log change;
end fork
:Share Post;
:Like Post;
:Edit Profile;
fork
:notify admin;
fork again
:log event;
end fork
stop
@enduml