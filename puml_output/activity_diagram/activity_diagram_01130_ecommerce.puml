@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
start
:Browse Products;
fork
:notify user;
fork again
:log change;
end fork
:Cancel Order;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Track Order;
:Apply Coupon;
:Write Review;
fork
:notify user;
fork again
:log action;
end fork
:Make Payment;
stop
@enduml