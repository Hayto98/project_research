@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
start
:Track Order;
fork
:notify user;
fork again
:log event;
end fork
:Checkout;
fork
:notify system;
fork again
:log action;
end fork
:Apply Coupon;
:Manage Inventory;
:Add To Cart;
:Write Review;
:Browse Products;
fork
:notify admin;
fork again
:log event;
end fork
:Cancel Order;
stop
@enduml