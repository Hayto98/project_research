@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
start
:Return Book;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log change;
end fork
:Reserve Book;
:Register Member;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Renew Loan;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Borrow Book;
:Pay Fine;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log action;
end fork
:Search Catalog;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Add New Book;
stop
@enduml