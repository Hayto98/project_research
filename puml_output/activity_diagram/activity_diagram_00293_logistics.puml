@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
start
:Report Issue;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Track Shipment;
:Fuel Vehicle;
:Deliver Package;
