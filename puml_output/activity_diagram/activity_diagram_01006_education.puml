:continue process;
else (no)
:handle error;
stop
endif
:Issue Certificate;
:View Schedule;
:Register Student;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Submit Assignment;
stop
@enduml