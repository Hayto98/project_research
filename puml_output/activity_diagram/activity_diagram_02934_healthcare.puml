@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
start
:Update Medical Record;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Book Appointment;
:Run Lab Test;
:Discharge Patient;
