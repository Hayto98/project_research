@startuml
skinparam monochrome true
skinparam shadowing true
start
:Book Room;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Check Out;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Cancel Reservation;
:Process Payment;
:Check In;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log action;
end fork
:Request Service;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Order Room Service;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Clean Room;
stop
@enduml