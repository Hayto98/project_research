@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
start
:Request Service;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Check Out;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log change;
end fork
:Process Payment;
fork
:notify user;
fork again
:log action;
end fork
:Clean Room;
:Cancel Reservation;
fork
:notify admin;
fork again
:log action;
end fork
:Book Room;
stop
@enduml