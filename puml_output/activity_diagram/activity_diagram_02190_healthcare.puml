@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
start
:Process Insurance Claim;
:Examine Patient;
:Admit Patient;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Run Lab Test;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Update Medical Record;
fork
:notify admin;
fork again
:log action;
end fork
:Book Appointment;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Discharge Patient;
stop
@enduml