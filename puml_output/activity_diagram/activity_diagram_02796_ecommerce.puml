@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
start
:Track Order;
fork
:notify user;
fork again
:log event;
end fork
:Make Payment;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log action;
end fork
:Browse Products;
:Write Review;
:Checkout;
stop
@enduml