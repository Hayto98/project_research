@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
start
:Search Catalog;
:Renew Loan;
fork
:notify system;
fork again
:log change;
end fork
:Reserve Book;
:Add New Book;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Return Book;
fork
:notify admin;
fork again
:log action;
end fork
:Pay Fine;
:Borrow Book;
fork
:notify system;
fork again
:log action;
end fork
stop
@enduml