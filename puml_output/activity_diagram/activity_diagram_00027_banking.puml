@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
start
:Deposit Money;
:Block Card;
:Open Account;
:Pay Bill;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:View Statement;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Withdraw Cash;
:Transfer Funds;
fork
:notify user;
fork again
:log event;
end fork
:Apply For Loan;
stop
@enduml