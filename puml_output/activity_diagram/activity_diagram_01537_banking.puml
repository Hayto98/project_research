@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
start
:View Statement;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Transfer Funds;
:Withdraw Cash;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Apply For Loan;
fork
:notify admin;
fork again
:log change;
end fork
:Deposit Money;
stop
@enduml