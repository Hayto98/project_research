@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
start
:Open Account;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:View Statement;
:Apply For Loan;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Deposit Money;
:Withdraw Cash;
:Transfer Funds;
stop
@enduml