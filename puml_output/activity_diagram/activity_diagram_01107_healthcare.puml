@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
start
:Examine Patient;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log event;
end fork
:Update Medical Record;
:Discharge Patient;
fork
:notify system;
fork again
:log change;
end fork
:Run Lab Test;
fork
:notify admin;
fork again
:log action;
end fork
:Admit Patient;
fork
:notify user;
fork again
:log event;
end fork
:Process Insurance Claim;
fork
:notify system;
fork again
:log change;
end fork
stop
@enduml