@startuml
skinparam defaultFontSize 11
start
:Apply For Loan;
:Deposit Money;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:View Statement;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Pay Bill;
:Withdraw Cash;
fork
:notify user;
fork again
:log change;
end fork
stop
@enduml