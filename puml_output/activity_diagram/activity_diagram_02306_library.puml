@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
start
:Pay Fine;
fork
:notify system;
fork again
:log change;
end fork
:Register Member;
fork
:notify user;
fork again
:log action;
end fork
:Return Book;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Add New Book;
:Borrow Book;
fork
:notify user;
fork again
:log change;
end fork
:Reserve Book;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log event;
end fork
:Search Catalog;
stop
@enduml