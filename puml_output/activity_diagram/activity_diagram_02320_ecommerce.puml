@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
start
:Make Payment;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Browse Products;
:Apply Coupon;
:Track Order;
:Checkout;
fork
:notify system;
fork again
:log action;
end fork
:Write Review;
fork
:notify admin;
fork again
:log change;
end fork
:Cancel Order;
stop
@enduml