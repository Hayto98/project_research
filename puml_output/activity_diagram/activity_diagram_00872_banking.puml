@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
start
:Open Account;
:Block Card;
:View Statement;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Withdraw Cash;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Apply For Loan;
:Pay Bill;
:Deposit Money;
fork
:notify system;
fork again
:log action;
end fork
:Transfer Funds;
stop
@enduml