@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
start
:Apply For Loan;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Open Account;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Transfer Funds;
:Pay Bill;
:Withdraw Cash;
:Block Card;
:Deposit Money;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:View Statement;
stop
@enduml