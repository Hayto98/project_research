@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
start
:Apply For Loan;
:Block Card;
:Pay Bill;
fork
:notify user;
fork again
:log event;
end fork
:Transfer Funds;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Deposit Money;
:View Statement;
fork
:notify admin;
fork again
:log action;
end fork
:Withdraw Cash;
stop
@enduml