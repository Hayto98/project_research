@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
start
:Cancel Reservation;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Check Out;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Clean Room;
:Book Room;
:Check In;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Request Service;
stop
@enduml