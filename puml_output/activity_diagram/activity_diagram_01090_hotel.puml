@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
start
:Process Payment;
:Clean Room;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Order Room Service;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Book Room;
:Cancel Reservation;
fork
:notify system;
fork again
:log event;
end fork
:Request Service;
:Check In;
stop
@enduml