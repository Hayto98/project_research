@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
start
:Take Attendance;
fork
:notify admin;
fork again
:log event;
end fork
:Register Student;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Submit Assignment;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log event;
end fork
:Issue Certificate;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Grade Exam;
:Enroll Course;
fork
:notify admin;
fork again
:log change;
end fork
:Borrow Book;
stop
@enduml