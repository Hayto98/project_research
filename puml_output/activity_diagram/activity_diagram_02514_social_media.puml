@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
start
:Edit Profile;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Report Content;
:Comment;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Share Post;
:Send Message;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Follow User;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Like Post;
:Create Post;
fork
:notify system;
fork again
:log event;
end fork
stop
@enduml