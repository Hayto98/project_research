@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
start
:Report Content;
fork
:notify admin;
fork again
:log change;
end fork
:Follow User;
:Like Post;
fork
:notify system;
fork again
:log action;
end fork
:Edit Profile;
:Share Post;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Comment;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Create Post;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log action;
end fork
:Send Message;
stop
@enduml