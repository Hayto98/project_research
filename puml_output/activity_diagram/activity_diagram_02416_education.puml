@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
start
:Grade Exam;
fork
:notify system;
fork again
:log change;
end fork
:Register Student;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Issue Certificate;
:Take Attendance;
:Submit Assignment;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Enroll Course;
:View Schedule;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Borrow Book;
stop
@enduml