@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
start
:Book Appointment;
:Examine Patient;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Update Medical Record;
:Run Lab Test;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Issue Prescription;
fork
:notify user;
fork again
:log event;
end fork
:Admit Patient;
stop
@enduml