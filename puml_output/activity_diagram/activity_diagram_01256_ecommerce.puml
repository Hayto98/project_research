@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
start
:Make Payment;
fork
:notify system;
fork again
:log change;
end fork
:Manage Inventory;
fork
:notify admin;
fork again
:log action;
end fork
:Browse Products;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Apply Coupon;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Write Review;
:Track Order;
:Checkout;
stop
@enduml