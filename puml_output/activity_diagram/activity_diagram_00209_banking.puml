@startuml
skinparam defaultFontSize 13
start
:Open Account;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log event;
end fork
:Deposit Money;
:Pay Bill;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Apply For Loan;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Transfer Funds;
stop
@enduml