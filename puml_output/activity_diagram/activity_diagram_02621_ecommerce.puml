@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
start
:Track Order;
fork
:notify user;
fork again
:log event;
end fork
:Checkout;
:Browse Products;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Make Payment;
:Add To Cart;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Cancel Order;
:Write Review;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Manage Inventory;
stop
@enduml