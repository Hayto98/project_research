@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
start
:Checkout;
:Browse Products;
:Cancel Order;
fork
:notify user;
fork again
:log change;
end fork
:Track Order;
:Manage Inventory;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Write Review;
fork
:notify system;
fork again
:log action;
end fork
stop
@enduml