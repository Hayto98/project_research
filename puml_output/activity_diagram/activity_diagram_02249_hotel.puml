@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
start
:Check Out;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Process Payment;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Book Room;
fork
:notify admin;
fork again
:log change;
end fork
:Order Room Service;
:Check In;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Clean Room;
stop
@enduml