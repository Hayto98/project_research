@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
start
:Write Review;
fork
:notify user;
fork again
:log event;
end fork
:Cancel Order;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log action;
end fork
:Browse Products;
:Add To Cart;
fork
:notify admin;
fork again
:log change;
end fork
:Manage Inventory;
stop
@enduml