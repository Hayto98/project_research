@startuml

start
:Open Account;
:View Statement;
:Apply For Loan;
:Deposit Money;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log event;
end fork
:Withdraw Cash;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Block Card;
fork
:notify admin;
fork again
:log event;
end fork
stop
@enduml