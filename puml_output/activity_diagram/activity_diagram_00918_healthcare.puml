@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
start
:Book Appointment;
:Discharge Patient;
:Run Lab Test;
fork
:notify admin;
fork again
:log action;
end fork
:Update Medical Record;
:Issue Prescription;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Admit Patient;
:Process Insurance Claim;
:Examine Patient;
fork
:notify user;
fork again
:log change;
end fork
stop
@enduml