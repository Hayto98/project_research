@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
start
:Pay Bill;
:Apply For Loan;
fork
:notify system;
fork again
:log event;
end fork
:Open Account;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:View Statement;
:Transfer Funds;
:Block Card;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Withdraw Cash;
stop
@enduml