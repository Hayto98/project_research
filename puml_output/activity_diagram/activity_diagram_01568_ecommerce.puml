@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
start
:Cancel Order;
:Checkout;
:Track Order;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log event;
end fork
:Browse Products;
:Make Payment;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Write Review;
:Add To Cart;
fork
:notify admin;
fork again
:log action;
end fork
stop
@enduml