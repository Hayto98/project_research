@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
start
:Register Member;
:Return Book;
:Reserve Book;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log action;
end fork
:Pay Fine;
:Add New Book;
:Renew Loan;
fork
:notify user;
fork again
:log event;
end fork
:Borrow Book;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Search Catalog;
stop
@enduml