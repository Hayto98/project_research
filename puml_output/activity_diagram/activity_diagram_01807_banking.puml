@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
start
:Pay Bill;
:Withdraw Cash;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Block Card;
:View Statement;
:Transfer Funds;
