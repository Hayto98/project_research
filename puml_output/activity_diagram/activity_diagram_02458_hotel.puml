@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
start
:Process Payment;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log action;
end fork
:Order Room Service;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Clean Room;
:Check In;
:Cancel Reservation;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Request Service;
stop
@enduml