@startuml
skinparam monochrome true
skinparam defaultFontSize 11
start
:Grade Exam;
:Take Attendance;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Register Student;
:Enroll Course;
:View Schedule;
