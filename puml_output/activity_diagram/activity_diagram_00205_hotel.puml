@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
start
:Check Out;
fork
:notify system;
fork again
:log event;
end fork
:Request Service;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Book Room;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Process Payment;
fork
:notify user;
fork again
:log change;
end fork
:Check In;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Clean Room;
:Cancel Reservation;
fork
:notify user;
fork again
:log change;
end fork
:Order Room Service;
stop
@enduml