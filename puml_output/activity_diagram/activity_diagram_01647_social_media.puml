@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
start
:Create Post;
:Edit Profile;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Report Content;
:Comment;
