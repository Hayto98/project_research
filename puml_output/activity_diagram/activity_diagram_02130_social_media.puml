@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
start
:Comment;
:Share Post;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Report Content;
:Follow User;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Create Post;
:Edit Profile;
fork
:notify user;
fork again
:log event;
end fork
:Like Post;
stop
@enduml