@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
start
:Open Account;
:Withdraw Cash;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log event;
end fork
:Deposit Money;
:Pay Bill;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log action;
end fork
:View Statement;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Block Card;
stop
@enduml