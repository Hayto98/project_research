@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
start
:Apply For Loan;
:Open Account;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Block Card;
:View Statement;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Pay Bill;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log event;
end fork
:Transfer Funds;
:Withdraw Cash;
:Deposit Money;
stop
@enduml