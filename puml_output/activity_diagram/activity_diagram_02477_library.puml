@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
start
:Return Book;
fork
:notify user;
fork again
:log event;
end fork
:Add New Book;
:Renew Loan;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Reserve Book;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Pay Fine;
:Search Catalog;
:Register Member;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Borrow Book;
stop
@enduml