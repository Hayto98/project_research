@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
start
:Comment;
fork
:notify user;
fork again
:log action;
end fork
:Share Post;
:Edit Profile;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Like Post;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Report Content;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Send Message;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log change;
end fork
:Follow User;
fork
:notify system;
fork again
:log event;
end fork
stop
@enduml