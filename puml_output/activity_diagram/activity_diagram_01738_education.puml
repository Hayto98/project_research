@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
start
:Register Student;
:Borrow Book;
:Take Attendance;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log event;
end fork
:Grade Exam;
fork
:notify admin;
fork again
:log action;
end fork
:Issue Certificate;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Enroll Course;
:View Schedule;
fork
:notify admin;
fork again
:log event;
end fork
stop
@enduml