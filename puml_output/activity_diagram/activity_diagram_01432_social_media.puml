@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
start
:Share Post;
:Comment;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Edit Profile;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Like Post;
:Report Content;
:Create Post;
:Follow User;
stop
@enduml