@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
start
:Create Post;
:Report Content;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Edit Profile;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Like Post;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Comment;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Send Message;
stop
@enduml