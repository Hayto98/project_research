@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
start
:Checkout;
:Browse Products;
:Make Payment;
:Track Order;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Add To Cart;
:Write Review;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log action;
end fork
:Cancel Order;
fork
:notify admin;
fork again
:log action;
end fork
:Apply Coupon;
fork
:notify user;
fork again
:log event;
end fork
stop
@enduml