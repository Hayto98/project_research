@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
start
:Withdraw Cash;
fork
:notify system;
fork again
:log action;
end fork
:Pay Bill;
:Apply For Loan;
fork
:notify system;
fork again
:log change;
end fork
:Transfer Funds;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log change;
end fork
:View Statement;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Block Card;
stop
@enduml