@startuml
skinparam monochrome true
start
:Edit Profile;
:Share Post;
:Create Post;
:Send Message;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log action;
end fork
:Comment;
:Report Content;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Like Post;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Follow User;
fork
:notify admin;
fork again
:log action;
end fork
stop
@enduml