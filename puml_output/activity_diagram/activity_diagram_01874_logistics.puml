@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
start
:Update Inventory;
fork
:notify system;
fork again
:log change;
end fork
:Load Package;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Schedule Pickup;
:Report Issue;
:Track Shipment;
:Assign Route;
stop
@enduml