@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
start
:Run Lab Test;
fork
:notify admin;
fork again
:log action;
end fork
:Discharge Patient;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log action;
end fork
:Issue Prescription;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Admit Patient;
:Process Insurance Claim;
:Book Appointment;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Update Medical Record;
:Examine Patient;
stop
@enduml