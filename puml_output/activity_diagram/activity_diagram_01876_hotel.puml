@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
start
:Cancel Reservation;
:Check In;
:Order Room Service;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Request Service;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Book Room;
fork
:notify user;
fork again
:log action;
end fork
stop
@enduml