@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
start
:Take Attendance;
fork
:notify admin;
fork again
:log change;
end fork
:Register Student;
:Issue Certificate;
:Enroll Course;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Borrow Book;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Grade Exam;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Submit Assignment;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log event;
end fork
:View Schedule;
fork
:notify admin;
fork again
:log event;
end fork
stop
@enduml