@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
start
:Issue Prescription;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log change;
end fork
:Discharge Patient;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Process Insurance Claim;
fork
:notify admin;
fork again
:log change;
end fork
:Admit Patient;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log action;
end fork
:Run Lab Test;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Examine Patient;
fork
:notify user;
fork again
:log change;
end fork
:Update Medical Record;
:Book Appointment;
fork
:notify admin;
fork again
:log event;
end fork
stop
@enduml