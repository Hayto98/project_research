@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
start
:Track Order;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Make Payment;
:Cancel Order;
:Checkout;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log action;
end fork
:Apply Coupon;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Browse Products;
fork
:notify system;
fork again
:log action;
end fork
:Manage Inventory;
stop
@enduml