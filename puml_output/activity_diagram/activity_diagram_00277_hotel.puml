@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
start
:Check In;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log event;
end fork
:Cancel Reservation;
:Book Room;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Clean Room;
:Check Out;
:Request Service;
:Order Room Service;
:Process Payment;
fork
:notify admin;
fork again
:log change;
end fork
stop
@enduml