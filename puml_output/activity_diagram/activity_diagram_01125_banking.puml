@startuml
skinparam monochrome true
skinparam defaultFontSize 11
start
:View Statement;
:Deposit Money;
:Withdraw Cash;
:Pay Bill;
:Apply For Loan;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
