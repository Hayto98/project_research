@startuml
skinparam monochrome true
skinparam shadowing true
start
:Issue Prescription;
:Admit Patient;
:Book Appointment;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log change;
end fork
:Update Medical Record;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Run Lab Test;
:Examine Patient;
fork
:notify user;
fork again
:log action;
end fork
stop
@enduml