@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
start
:Check In;
fork
:notify admin;
fork again
:log change;
end fork
:Cancel Reservation;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Book Room;
:Clean Room;
fork
:notify user;
fork again
:log action;
end fork
:Process Payment;
stop
@enduml