@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
start
:Discharge Patient;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Update Medical Record;
:Process Insurance Claim;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Book Appointment;
:Admit Patient;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Issue Prescription;
stop
@enduml