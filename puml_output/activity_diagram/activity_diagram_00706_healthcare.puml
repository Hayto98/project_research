@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
start
:Run Lab Test;
:Admit Patient;
:Update Medical Record;
:Examine Patient;
:Book Appointment;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Discharge Patient;
fork
:notify admin;
fork again
:log event;
end fork
stop
@enduml