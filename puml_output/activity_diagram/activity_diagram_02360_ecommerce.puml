@startuml
skinparam monochrome true
skinparam shadowing true
start
:Browse Products;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Track Order;
:Add To Cart;
fork
:notify admin;
fork again
:log event;
end fork
:Checkout;
:Make Payment;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Apply Coupon;
:Manage Inventory;
stop
@enduml