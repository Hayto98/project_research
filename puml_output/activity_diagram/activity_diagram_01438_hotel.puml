@startuml
skinparam monochrome true
skinparam defaultFontSize 11
start
:Cancel Reservation;
:Clean Room;
:Check In;
:Order Room Service;
:Request Service;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Check Out;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Book Room;
stop
@enduml