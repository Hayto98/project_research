@startuml
skinparam monochrome true
skinparam defaultFontSize 13
start
:Transfer Funds;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log event;
end fork
:Apply For Loan;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Withdraw Cash;
:Deposit Money;
:Open Account;
stop
