@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
start
:Cancel Reservation;
:Check In;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Process Payment;
:Clean Room;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log action;
end fork
:Order Room Service;
stop
@enduml