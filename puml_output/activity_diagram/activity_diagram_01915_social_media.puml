@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
start
:Create Post;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Comment;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log event;
end fork
:Edit Profile;
:Send Message;
fork
:notify user;
fork again
:log event;
end fork
:Share Post;
stop
@enduml