@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
start
:View Statement;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Block Card;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Transfer Funds;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log change;
end fork
:Open Account;
:Withdraw Cash;
fork
:notify user;
fork again
:log event;
end fork
:Pay Bill;
:Deposit Money;
fork
:notify user;
fork again
:log event;
end fork
stop
@enduml