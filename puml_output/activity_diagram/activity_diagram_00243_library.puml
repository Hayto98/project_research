@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
start
:Return Book;
:Renew Loan;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Search Catalog;
:Add New Book;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Pay Fine;
:Register Member;
:Borrow Book;
stop
@enduml