@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
start
:Update Medical Record;
fork
:notify system;
fork again
:log event;
end fork
:Examine Patient;
:Issue Prescription;
:Discharge Patient;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Book Appointment;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log event;
end fork
:Process Insurance Claim;
:Run Lab Test;
stop
@enduml