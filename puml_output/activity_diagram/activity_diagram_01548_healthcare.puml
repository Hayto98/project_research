@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
start
:Update Medical Record;
:Run Lab Test;
:Admit Patient;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Examine Patient;
:Discharge Patient;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Process Insurance Claim;
fork
:notify user;
fork again
:log action;
end fork
stop
@enduml