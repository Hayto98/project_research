@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
start
:Pay Bill;
:Withdraw Cash;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Transfer Funds;
fork
:notify user;
fork again
:log event;
end fork
:Open Account;
:Deposit Money;
:Apply For Loan;
:Block Card;
:View Statement;
fork
:notify system;
fork again
:log action;
end fork
stop
@enduml