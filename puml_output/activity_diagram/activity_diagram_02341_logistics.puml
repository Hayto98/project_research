@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
start
:Assign Route;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Deliver Package;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Update Inventory;
:Track Shipment;
:Report Issue;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Schedule Pickup;
stop
@enduml