@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
start
:Add New Book;
:Register Member;
:Pay Fine;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Search Catalog;
:Renew Loan;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Return Book;
:Reserve Book;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log event;
end fork
:Borrow Book;
stop
@enduml