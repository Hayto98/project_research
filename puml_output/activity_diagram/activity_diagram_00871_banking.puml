@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
start
:Pay Bill;
:Open Account;
:Block Card;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log change;
end fork
:Transfer Funds;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Deposit Money;
:Withdraw Cash;
fork
:notify system;
fork again
:log change;
end fork
stop
@enduml