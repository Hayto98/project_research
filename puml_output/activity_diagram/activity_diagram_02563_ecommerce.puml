@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
start
:Write Review;
:Track Order;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Checkout;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Cancel Order;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Manage Inventory;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Add To Cart;
stop
@enduml