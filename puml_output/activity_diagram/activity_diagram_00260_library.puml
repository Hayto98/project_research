@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
start
:Return Book;
fork
:notify system;
fork again
:log event;
end fork
:Borrow Book;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Add New Book;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log change;
end fork
:Pay Fine;
:Reserve Book;
:Search Catalog;
:Renew Loan;
fork
:notify admin;
fork again
:log event;
end fork
stop
@enduml