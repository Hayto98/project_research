@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
start
:View Schedule;
:Register Student;
:Grade Exam;
:Issue Certificate;
:Submit Assignment;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Enroll Course;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log event;
end fork
:Take Attendance;
:Borrow Book;
stop
@enduml