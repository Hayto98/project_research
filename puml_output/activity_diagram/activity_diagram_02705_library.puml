@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
start
:Reserve Book;
:Search Catalog;
fork
:notify user;
fork again
:log change;
end fork
:Renew Loan;
fork
:notify admin;
fork again
:log change;
end fork
:Register Member;
:Add New Book;
fork
:notify user;
fork again
:log action;
end fork
:Borrow Book;
:Pay Fine;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Return Book;
stop
@enduml