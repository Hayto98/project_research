@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
start
:Apply Coupon;
:Track Order;
:Add To Cart;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Write Review;
:Manage Inventory;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Checkout;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Browse Products;
:Make Payment;
fork
:notify system;
fork again
:log change;
end fork
stop
@enduml