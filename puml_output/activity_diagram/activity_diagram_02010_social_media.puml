@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
start
:Comment;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Report Content;
:Create Post;
:Follow User;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Share Post;
:Like Post;
stop
@enduml