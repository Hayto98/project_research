@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
start
:Checkout;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log action;
end fork
:Cancel Order;
fork
:notify admin;
fork again
:log event;
end fork
:Apply Coupon;
:Make Payment;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Track Order;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Add To Cart;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Manage Inventory;
fork
:notify user;
fork again
:log event;
end fork
stop
@enduml