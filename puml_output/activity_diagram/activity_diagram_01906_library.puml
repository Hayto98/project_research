@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
start
:Register Member;
fork
:notify system;
fork again
:log change;
end fork
:Borrow Book;
:Reserve Book;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Return Book;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Search Catalog;
:Pay Fine;
:Renew Loan;
:Add New Book;
stop
@enduml