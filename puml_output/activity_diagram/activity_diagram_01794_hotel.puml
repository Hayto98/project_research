@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
start
:Check Out;
:Book Room;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Request Service;
:Process Payment;
:Cancel Reservation;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Clean Room;
:Check In;
:Order Room Service;
stop
@enduml