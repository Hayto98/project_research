@startuml
skinparam monochrome true
skinparam shadowing true
start
:Edit Profile;
fork
:notify user;
fork again
:log action;
end fork
:Report Content;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Comment;
:Create Post;
:Like Post;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log action;
end fork
:Share Post;
stop
@enduml