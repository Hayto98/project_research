@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
start
:Withdraw Cash;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Apply For Loan;
:Transfer Funds;
:View Statement;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Pay Bill;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log action;
end fork
:Block Card;
fork
:notify system;
fork again
:log action;
end fork
stop
@enduml