@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
start
:Discharge Patient;
:Examine Patient;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Admit Patient;
fork
:notify admin;
fork again
:log action;
end fork
:Process Insurance Claim;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Run Lab Test;
fork
:notify admin;
fork again
:log event;
end fork
stop
@enduml