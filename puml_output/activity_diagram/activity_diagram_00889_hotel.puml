@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
start
:Clean Room;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Cancel Reservation;
:Order Room Service;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log action;
end fork
:Request Service;
fork
:notify system;
fork again
:log event;
end fork
:Check Out;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Check In;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Book Room;
:Process Payment;
stop
@enduml