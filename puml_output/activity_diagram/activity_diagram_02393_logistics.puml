@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
start
:Report Issue;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Track Shipment;
:Deliver Package;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Fuel Vehicle;
:Update Inventory;
:Assign Route;
fork
:notify admin;
fork again
:log change;
end fork
:Schedule Pickup;
stop
@enduml