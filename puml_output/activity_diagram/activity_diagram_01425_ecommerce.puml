@startuml
skinparam ArrowColor #555555
start
:Checkout;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Manage Inventory;
:Make Payment;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
