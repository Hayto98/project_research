@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
start
:Examine Patient;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Update Medical Record;
:Discharge Patient;
:Issue Prescription;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Admit Patient;
stop
@enduml