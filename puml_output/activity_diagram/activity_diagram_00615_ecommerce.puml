@startuml
skinparam monochrome true
skinparam defaultFontSize 13
start
:Write Review;
:Browse Products;
:Add To Cart;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Checkout;
:Cancel Order;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log event;
end fork
:Track Order;
stop
@enduml