@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
start
:Issue Certificate;
fork
:notify admin;
fork again
:log event;
end fork
:Grade Exam;
:Take Attendance;
:Submit Assignment;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:View Schedule;
fork
:notify user;
fork again
:log action;
end fork
:Enroll Course;
:Register Student;
:Borrow Book;
stop
@enduml