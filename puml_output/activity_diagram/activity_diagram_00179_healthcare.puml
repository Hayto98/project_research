@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
start
:Discharge Patient;
:Book Appointment;
:Process Insurance Claim;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Admit Patient;
fork
:notify system;
fork again
:log action;
end fork
:Examine Patient;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Issue Prescription;
:Update Medical Record;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Run Lab Test;
stop
@enduml