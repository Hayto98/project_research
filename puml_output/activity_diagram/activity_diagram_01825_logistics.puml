@startuml
skinparam monochrome true
skinparam defaultFontSize 11
start
:Fuel Vehicle;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log event;
end fork
:Schedule Pickup;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Update Inventory;
:Report Issue;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Deliver Package;
:Load Package;
:Assign Route;
stop
@enduml