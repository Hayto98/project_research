@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
start
:Write Review;
:Make Payment;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Browse Products;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log change;
end fork
:Add To Cart;
:Cancel Order;
stop
@enduml