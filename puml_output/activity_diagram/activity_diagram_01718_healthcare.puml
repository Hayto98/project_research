@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
start
:Book Appointment;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Run Lab Test;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Examine Patient;
:Issue Prescription;
:Process Insurance Claim;
:Admit Patient;
:Discharge Patient;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Update Medical Record;
fork
:notify admin;
fork again
:log event;
end fork
stop
@enduml