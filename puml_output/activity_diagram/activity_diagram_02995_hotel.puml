@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
start
:Check Out;
fork
:notify system;
fork again
:log event;
end fork
:Cancel Reservation;
fork
:notify user;
fork again
:log action;
end fork
:Book Room;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Check In;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Request Service;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Process Payment;
:Order Room Service;
stop
@enduml