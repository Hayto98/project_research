@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
start
:Update Medical Record;
:Book Appointment;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Process Insurance Claim;
:Issue Prescription;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Admit Patient;
fork
:notify admin;
fork again
:log action;
end fork
stop
@enduml