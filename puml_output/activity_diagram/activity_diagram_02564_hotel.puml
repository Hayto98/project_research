@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
start
:Clean Room;
:Order Room Service;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Book Room;
:Cancel Reservation;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Request Service;
fork
:notify user;
fork again
:log action;
end fork
:Check Out;
:Process Payment;
stop
@enduml