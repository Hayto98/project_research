@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
start
:Add New Book;
:Reserve Book;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Borrow Book;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Return Book;
:Renew Loan;
stop
@enduml