@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
start
:Track Order;
:Add To Cart;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Make Payment;
:Apply Coupon;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Write Review;
:Manage Inventory;
:Cancel Order;
:Checkout;
stop
@enduml