@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
start
:Deposit Money;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Apply For Loan;
:View Statement;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Open Account;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Transfer Funds;
stop
@enduml