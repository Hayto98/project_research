@startuml
skinparam monochrome true
skinparam shadowing true
start
:Add To Cart;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Apply Coupon;
:Browse Products;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Cancel Order;
:Manage Inventory;
:Write Review;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Checkout;
stop
@enduml