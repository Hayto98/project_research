@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
start
:Manage Inventory;
:Checkout;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Make Payment;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Add To Cart;
fork
:notify admin;
fork again
:log event;
end fork
:Track Order;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log action;
end fork
:Write Review;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Cancel Order;
fork
:notify system;
fork again
:log change;
end fork
stop
@enduml