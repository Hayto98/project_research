@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
start
:Admit Patient;
fork
:notify user;
fork again
:log change;
end fork
:Run Lab Test;
:Update Medical Record;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Book Appointment;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Discharge Patient;
:Process Insurance Claim;
fork
:notify admin;
fork again
:log event;
end fork
:Examine Patient;
stop
@enduml