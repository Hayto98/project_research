@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
start
:Register Student;
fork
:notify system;
fork again
:log change;
end fork
:Take Attendance;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Enroll Course;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Submit Assignment;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Borrow Book;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Issue Certificate;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Grade Exam;
fork
:notify system;
fork again
:log change;
end fork
stop
@enduml