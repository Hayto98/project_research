@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
start
:Reserve Book;
:Pay Fine;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Search Catalog;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Return Book;
:Renew Loan;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log action;
end fork
:Register Member;
:Borrow Book;
:Add New Book;
stop
@enduml