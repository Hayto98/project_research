@startuml
skinparam shadowing true
start
:Load Package;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Deliver Package;
fork
:notify admin;
fork again
:log change;
end fork
:Track Shipment;
:Schedule Pickup;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Report Issue;
fork
:notify system;
fork again
:log event;
end fork
:Assign Route;
:Fuel Vehicle;
fork
:notify system;
fork again
:log event;
end fork
stop
@enduml