@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
start
:Make Payment;
:Browse Products;
:Track Order;
:Add To Cart;
:Write Review;
fork
:notify system;
fork again
:log change;
end fork
:Checkout;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Cancel Order;
stop
