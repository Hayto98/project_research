@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
start
:Withdraw Cash;
:Pay Bill;
fork
:notify system;
fork again
:log change;
end fork
:View Statement;
:Block Card;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Deposit Money;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Apply For Loan;
:Open Account;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log event;
end fork
:Transfer Funds;
stop
@enduml