@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
start
:Write Review;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Make Payment;
:Browse Products;
fork
:notify system;
fork again
:log event;
end fork
:Cancel Order;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Track Order;
fork
:notify system;
fork again
:log action;
end fork
stop
@enduml