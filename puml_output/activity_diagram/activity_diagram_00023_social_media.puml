@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
start
:Report Content;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Like Post;
:Create Post;
:Send Message;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log change;
end fork
:Follow User;
:Share Post;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Comment;
stop
@enduml