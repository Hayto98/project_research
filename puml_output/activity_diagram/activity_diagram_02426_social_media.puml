@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
start
:Edit Profile;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Report Content;
:Comment;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Share Post;
:Create Post;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Follow User;
fork
:notify admin;
fork again
:log change;
end fork
stop
@enduml