@startuml
skinparam monochrome true
skinparam defaultFontSize 11
start
:Create Post;
:Edit Profile;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log event;
end fork
:Follow User;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Comment;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Like Post;
stop
@enduml