@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
start
:Book Appointment;
:Process Insurance Claim;
:Admit Patient;
fork
:notify user;
fork again
:log event;
end fork
:Discharge Patient;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Run Lab Test;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log change;
end fork
:Examine Patient;
stop
@enduml