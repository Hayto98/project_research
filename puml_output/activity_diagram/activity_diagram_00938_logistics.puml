@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
start
:Report Issue;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Update Inventory;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log action;
end fork
:Deliver Package;
:Track Shipment;
:Assign Route;
fork
:notify system;
fork again
:log event;
end fork
stop
@enduml