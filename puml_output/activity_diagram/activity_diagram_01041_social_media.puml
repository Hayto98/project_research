@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
start
:Create Post;
:Comment;
:Send Message;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Like Post;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Edit Profile;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Follow User;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Report Content;
fork
:notify system;
fork again
:log event;
end fork
stop
@enduml