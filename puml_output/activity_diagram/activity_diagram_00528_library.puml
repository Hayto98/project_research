@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
start
:Renew Loan;
:Borrow Book;
:Search Catalog;
fork
:notify system;
fork again
:log change;
end fork
:Add New Book;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Register Member;
:Reserve Book;
fork
:notify system;
fork again
:log action;
end fork
stop
@enduml