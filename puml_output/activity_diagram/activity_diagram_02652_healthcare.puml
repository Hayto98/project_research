@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
start
:Discharge Patient;
fork
:notify admin;
fork again
:log action;
end fork
:Issue Prescription;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Admit Patient;
:Examine Patient;
:Book Appointment;
stop
@enduml