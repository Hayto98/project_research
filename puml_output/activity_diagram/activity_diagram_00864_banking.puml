@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
start
:Pay Bill;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Open Account;
:Block Card;
:Deposit Money;
:Transfer Funds;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Apply For Loan;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:View Statement;
stop
@enduml