@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
start
:Enroll Course;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log change;
end fork
:Issue Certificate;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Submit Assignment;
:Register Student;
fork
:notify admin;
fork again
:log event;
end fork
:Take Attendance;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:View Schedule;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Grade Exam;
fork
:notify admin;
fork again
:log action;
end fork
stop
@enduml