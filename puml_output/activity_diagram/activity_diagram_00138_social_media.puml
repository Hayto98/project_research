@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
start
:Share Post;
:Report Content;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Edit Profile;
:Send Message;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Comment;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log change;
end fork
:Like Post;
stop
@enduml