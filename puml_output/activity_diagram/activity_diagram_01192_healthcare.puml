@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
start
:Book Appointment;
:Process Insurance Claim;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Examine Patient;
fork
:notify admin;
fork again
:log action;
end fork
:Issue Prescription;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Admit Patient;
:Run Lab Test;
:Discharge Patient;
:Update Medical Record;
stop
@enduml