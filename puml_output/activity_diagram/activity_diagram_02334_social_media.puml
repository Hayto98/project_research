@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
start
:Create Post;
:Send Message;
:Report Content;
:Comment;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Edit Profile;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log event;
end fork
:Like Post;
stop
@enduml