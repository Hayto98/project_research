@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
start
:Manage Inventory;
fork
:notify system;
fork again
:log change;
end fork
:Browse Products;
:Apply Coupon;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
