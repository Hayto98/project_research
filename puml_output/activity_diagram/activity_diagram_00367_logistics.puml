@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
start
:Update Inventory;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Load Package;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log event;
end fork
:Track Shipment;
:Deliver Package;
fork
:notify user;
fork again
:log event;
end fork
:Fuel Vehicle;
:Schedule Pickup;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Report Issue;
:Assign Route;
fork
:notify user;
fork again
:log change;
end fork
stop
@enduml