@startuml
skinparam defaultFontSize 11
start
:Comment;
:Follow User;
:Report Content;
:Edit Profile;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log event;
end fork
:Share Post;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Send Message;
:Like Post;
:Create Post;
fork
:notify admin;
fork again
:log change;
end fork
stop
@enduml