@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
start
:Clean Room;
fork
:notify system;
fork again
:log event;
end fork
:Request Service;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log event;
end fork
:Order Room Service;
:Check In;
fork
:notify user;
fork again
:log event;
end fork
:Book Room;
:Check Out;
:Cancel Reservation;
:Process Payment;
stop
@enduml