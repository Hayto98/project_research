@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
start
:Manage Inventory;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Apply Coupon;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Checkout;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Add To Cart;
fork
:notify system;
fork again
:log event;
end fork
:Track Order;
stop
@enduml