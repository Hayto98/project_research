@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
start
:Add To Cart;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Checkout;
:Write Review;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Apply Coupon;
:Cancel Order;
:Make Payment;
fork
:notify system;
fork again
:log action;
end fork
:Browse Products;
stop
@enduml