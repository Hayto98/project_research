@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
start
:Withdraw Cash;
:View Statement;
:Apply For Loan;
fork
:notify user;
fork again
:log change;
end fork
:Open Account;
:Block Card;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Deposit Money;
:Transfer Funds;
:Pay Bill;
stop
@enduml