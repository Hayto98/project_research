@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
start
:Assign Route;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log event;
end fork
:Track Shipment;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Update Inventory;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Deliver Package;
:Report Issue;
stop
@enduml