@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
start
:Open Account;
fork
:notify user;
fork again
:log change;
end fork
:Block Card;
fork
:notify admin;
fork again
:log event;
end fork
:Transfer Funds;
:View Statement;
:Withdraw Cash;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Apply For Loan;
stop
@enduml