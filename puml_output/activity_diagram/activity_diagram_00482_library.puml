@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
start
:Reserve Book;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log action;
end fork
:Pay Fine;
:Search Catalog;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Borrow Book;
fork
:notify system;
fork again
:log event;
end fork
:Register Member;
fork
:notify user;
fork again
:log event;
end fork
:Return Book;
stop
@enduml