@startuml
skinparam defaultFontSize 11
start
:Edit Profile;
:Share Post;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Follow User;
:Report Content;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Comment;
fork
:notify system;
fork again
:log change;
end fork
stop
@enduml