@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
start
:Send Message;
fork
:notify system;
fork again
:log action;
end fork
:Create Post;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log action;
end fork
:Like Post;
:Share Post;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Follow User;
fork
:notify user;
fork again
:log event;
end fork
stop
@enduml