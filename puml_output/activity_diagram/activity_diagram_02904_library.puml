@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
start
:Return Book;
:Renew Loan;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Reserve Book;
:Borrow Book;
:Register Member;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Pay Fine;
:Search Catalog;
:Add New Book;
stop
@enduml