@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
start
:Send Message;
:Comment;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Share Post;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Like Post;
fork
:notify user;
fork again
:log event;
end fork
:Follow User;
fork
:notify admin;
fork again
:log change;
end fork
stop
@enduml