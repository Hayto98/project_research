@startuml
skinparam monochrome true
skinparam ArrowColor #555555
start
:Search Catalog;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log change;
end fork
:Reserve Book;
:Borrow Book;
:Renew Loan;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Pay Fine;
:Return Book;
fork
:notify system;
fork again
:log action;
end fork
:Add New Book;
stop
@enduml