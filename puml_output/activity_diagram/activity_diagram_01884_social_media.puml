@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
start
:Create Post;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Send Message;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Report Content;
fork
:notify system;
fork again
:log change;
end fork
:Edit Profile;
:Share Post;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log change;
end fork
:Like Post;
stop
@enduml