@startuml
skinparam ArrowColor #555555
start
:Edit Profile;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Comment;
:Follow User;
:Share Post;
:Like Post;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Send Message;
:Report Content;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Create Post;
stop
@enduml