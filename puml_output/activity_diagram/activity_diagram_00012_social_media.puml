@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
start
:Like Post;
:Follow User;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Share Post;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log change;
end fork
:Report Content;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Edit Profile;
:Send Message;
:Comment;
stop
@enduml