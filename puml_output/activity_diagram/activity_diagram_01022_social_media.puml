@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
start
:Send Message;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Share Post;
:Comment;
