@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
start
:Register Student;
:Submit Assignment;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Issue Certificate;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Enroll Course;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:View Schedule;
:Borrow Book;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Take Attendance;
fork
:notify system;
fork again
:log event;
end fork
:Grade Exam;
stop
@enduml