@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
start
:Apply Coupon;
:Checkout;
fork
:notify system;
fork again
:log action;
end fork
:Write Review;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log event;
end fork
:Manage Inventory;
:Cancel Order;
fork
:notify user;
fork again
:log change;
end fork
stop
@enduml