@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
start
:Add To Cart;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Write Review;
fork
:notify admin;
fork again
:log event;
end fork
:Checkout;
:Apply Coupon;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Cancel Order;
fork
:notify user;
fork again
:log action;
end fork
stop
@enduml