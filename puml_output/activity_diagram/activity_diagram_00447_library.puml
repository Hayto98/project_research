@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
start
:Return Book;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Borrow Book;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Renew Loan;
fork
:notify admin;
fork again
:log change;
end fork
:Pay Fine;
:Register Member;
fork
:notify admin;
fork again
:log event;
end fork
:Reserve Book;
:Search Catalog;
stop
@enduml