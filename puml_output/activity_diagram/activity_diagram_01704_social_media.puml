@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
start
:Comment;
:Create Post;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Report Content;
:Send Message;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Share Post;
:Like Post;
stop
@enduml