@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
start
:Transfer Funds;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log action;
end fork
:Open Account;
:Deposit Money;
:Block Card;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:View Statement;
fork
:notify admin;
fork again
:log action;
end fork
stop
@enduml