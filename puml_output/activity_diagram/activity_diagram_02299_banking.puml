@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
start
:Pay Bill;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Transfer Funds;
fork
:notify system;
fork again
:log action;
end fork
:Block Card;
:View Statement;
fork
:notify user;
fork again
:log event;
end fork
:Withdraw Cash;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Apply For Loan;
:Open Account;
stop
@enduml