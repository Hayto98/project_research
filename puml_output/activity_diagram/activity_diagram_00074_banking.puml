@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
start
:Pay Bill;
fork
:notify admin;
fork again
:log action;
end fork
:Block Card;
fork
:notify user;
fork again
:log event;
end fork
:Withdraw Cash;
fork
:notify admin;
fork again
:log change;
end fork
:Apply For Loan;
fork
:notify user;
fork again
:log event;
end fork
:View Statement;
stop
@enduml