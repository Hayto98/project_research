@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
start
:Transfer Funds;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:View Statement;
:Deposit Money;
:Apply For Loan;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Pay Bill;
fork
:notify system;
fork again
:log change;
end fork
stop
@enduml