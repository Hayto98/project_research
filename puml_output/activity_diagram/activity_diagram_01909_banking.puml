@startuml
skinparam shadowing true
start
:Block Card;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Withdraw Cash;
:Apply For Loan;
fork
:notify system;
fork again
:log change;
end fork
:Deposit Money;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log change;
end fork
:Open Account;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:View Statement;
stop
@enduml