@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
start
:Borrow Book;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Search Catalog;
fork
:notify admin;
fork again
:log event;
end fork
:Return Book;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log change;
end fork
:Add New Book;
fork
:notify user;
fork again
:log event;
end fork
:Reserve Book;
:Renew Loan;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Register Member;
:Pay Fine;
fork
:notify admin;
fork again
:log change;
end fork
stop
@enduml