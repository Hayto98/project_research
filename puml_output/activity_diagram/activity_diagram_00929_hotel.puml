@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
start
:Check In;
:Process Payment;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Clean Room;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Cancel Reservation;
:Check Out;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Order Room Service;
fork
:notify user;
fork again
:log event;
end fork
stop
@enduml