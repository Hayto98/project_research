:continue process;
else (no)
:handle error;
stop
endif
:Issue Certificate;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log action;
end fork
:View Schedule;
stop
