@startuml
skinparam ArrowColor #555555
start
:Reserve Book;
fork
:notify system;
fork again
:log action;
end fork
:Register Member;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Borrow Book;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log event;
end fork
:Return Book;
:Pay Fine;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Add New Book;
fork
:notify admin;
fork again
:log action;
end fork
stop
@enduml