@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
start
:Withdraw Cash;
:Open Account;
fork
:notify user;
fork again
:log event;
end fork
:Apply For Loan;
:Deposit Money;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:View Statement;
fork
:notify user;
fork again
:log event;
end fork
:Transfer Funds;
fork
:notify admin;
fork again
:log event;
end fork
stop
@enduml