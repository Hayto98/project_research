@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
start
:Pay Fine;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Add New Book;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log action;
end fork
:Return Book;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Search Catalog;
:Reserve Book;
fork
:notify user;
fork again
:log action;
end fork
stop
@enduml