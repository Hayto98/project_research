@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
start
:Create Post;
:Share Post;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Send Message;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Report Content;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Like Post;
stop
@enduml