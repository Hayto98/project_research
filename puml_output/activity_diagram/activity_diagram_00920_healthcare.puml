@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
start
:Discharge Patient;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Book Appointment;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Run Lab Test;
:Update Medical Record;
fork
:notify user;
fork again
:log action;
end fork
:Process Insurance Claim;
:Issue Prescription;
:Examine Patient;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log event;
end fork
:Admit Patient;
stop
@enduml