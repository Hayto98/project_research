@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
start
:Take Attendance;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Enroll Course;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Grade Exam;
fork
:notify system;
fork again
:log change;
end fork
:View Schedule;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log action;
end fork
:Register Student;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Issue Certificate;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Submit Assignment;
:Borrow Book;
stop
@enduml