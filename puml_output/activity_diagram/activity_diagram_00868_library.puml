@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
start
:Reserve Book;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Borrow Book;
:Add New Book;
:Register Member;
:Search Catalog;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Return Book;
:Renew Loan;
stop
@enduml