@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
start
:View Statement;
fork
:notify user;
fork again
:log event;
end fork
:Open Account;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Apply For Loan;
:Pay Bill;
:Block Card;
fork
:notify system;
fork again
:log event;
end fork
stop
@enduml