@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
start
:Book Appointment;
:Admit Patient;
fork
:notify system;
fork again
:log change;
end fork
:Examine Patient;
:Update Medical Record;
fork
:notify admin;
fork again
:log action;
end fork
:Discharge Patient;
:Issue Prescription;
stop
@enduml