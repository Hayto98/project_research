@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
start
:View Statement;
:Pay Bill;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Open Account;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Withdraw Cash;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Transfer Funds;
:Apply For Loan;
:Block Card;
fork
:notify admin;
fork again
:log action;
end fork
stop
@enduml