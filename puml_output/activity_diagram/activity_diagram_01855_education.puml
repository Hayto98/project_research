@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
start
:Take Attendance;
fork
:notify system;
fork again
:log action;
end fork
:Enroll Course;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Grade Exam;
:Register Student;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Borrow Book;
:Submit Assignment;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:View Schedule;
stop
@enduml