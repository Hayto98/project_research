@startuml
skinparam monochrome true
skinparam defaultFontSize 13
start
:Run Lab Test;
fork
:notify user;
fork again
:log event;
end fork
:Admit Patient;
:Discharge Patient;
:Book Appointment;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Examine Patient;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log change;
end fork
:Update Medical Record;
:Process Insurance Claim;
:Issue Prescription;
stop
@enduml