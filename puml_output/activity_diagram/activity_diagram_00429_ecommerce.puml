@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
start
:Browse Products;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Checkout;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Track Order;
fork
:notify user;
fork again
:log change;
end fork
:Apply Coupon;
:Write Review;
:Manage Inventory;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Make Payment;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Cancel Order;
fork
:notify user;
fork again
:log change;
end fork
stop
@enduml