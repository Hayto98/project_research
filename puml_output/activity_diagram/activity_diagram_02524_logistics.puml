@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
start
:Track Shipment;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Deliver Package;
:Assign Route;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log event;
end fork
:Load Package;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Update Inventory;
fork
:notify admin;
fork again
:log change;
end fork
:Fuel Vehicle;
fork
:notify system;
fork again
:log change;
end fork
:Report Issue;
:Schedule Pickup;
stop
@enduml