@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
start
:Manage Inventory;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Write Review;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Add To Cart;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Checkout;
:Browse Products;
:Make Payment;
fork
:notify admin;
fork again
:log change;
end fork
stop
@enduml