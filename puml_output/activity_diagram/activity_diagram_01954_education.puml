@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
start
:View Schedule;
:Issue Certificate;
fork
:notify user;
fork again
:log action;
end fork
:Register Student;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Enroll Course;
:Submit Assignment;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Grade Exam;
:Borrow Book;
stop
@enduml