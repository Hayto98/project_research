@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
start
:Send Message;
:Create Post;
:Edit Profile;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Comment;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Follow User;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Report Content;
:Share Post;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Like Post;
fork
:notify user;
fork again
:log action;
end fork
stop
@enduml