@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
start
:Comment;
:Follow User;
fork
:notify admin;
fork again
:log action;
end fork
:Share Post;
:Create Post;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Send Message;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Like Post;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Report Content;
fork
:notify system;
fork again
:log change;
end fork
stop
@enduml