@startuml
skinparam monochrome true
skinparam defaultFontSize 11
start
:Discharge Patient;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Process Insurance Claim;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Admit Patient;
:Examine Patient;
:Issue Prescription;
fork
:notify system;
fork again
:log event;
end fork
stop
@enduml