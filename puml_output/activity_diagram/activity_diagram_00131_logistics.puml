@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
start
:Track Shipment;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Report Issue;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Deliver Package;
fork
:notify admin;
fork again
:log event;
end fork
:Fuel Vehicle;
:Load Package;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Schedule Pickup;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log change;
end fork
:Assign Route;
fork
:notify system;
fork again
:log action;
end fork
stop
@enduml