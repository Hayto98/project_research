@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
start
:Cancel Order;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Apply Coupon;
:Checkout;
:Add To Cart;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Browse Products;
fork
:notify user;
fork again
:log action;
end fork
:Make Payment;
:Write Review;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log event;
end fork
:Track Order;
stop
@enduml