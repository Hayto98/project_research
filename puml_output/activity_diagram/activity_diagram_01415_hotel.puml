@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
start
:Check Out;
:Cancel Reservation;
:Order Room Service;
fork
:notify user;
fork again
:log event;
end fork
:Clean Room;
:Request Service;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log change;
end fork
:Process Payment;
:Check In;
:Book Room;
stop
@enduml