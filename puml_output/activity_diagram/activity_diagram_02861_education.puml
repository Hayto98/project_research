@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
start
:View Schedule;
:Take Attendance;
:Grade Exam;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Register Student;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Borrow Book;
:Submit Assignment;
:Issue Certificate;
stop
@enduml