@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
start
:Clean Room;
:Request Service;
:Order Room Service;
:Process Payment;
:Book Room;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log event;
end fork
:Check In;
fork
:notify user;
fork again
:log action;
end fork
:Check Out;
stop
@enduml