@startuml
skinparam defaultFontSize 11
start
:Comment;
:Like Post;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Create Post;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Edit Profile;
:Report Content;
fork
:notify system;
fork again
:log change;
end fork
