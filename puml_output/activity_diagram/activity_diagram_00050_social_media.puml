@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
start
:Create Post;
:Edit Profile;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Like Post;
fork
:notify admin;
fork again
:log event;
end fork
:Comment;
fork
:notify user;
fork again
:log event;
end fork
:Share Post;
fork
:notify system;
fork again
:log change;
end fork
stop
@enduml