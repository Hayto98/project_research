@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
start
:Browse Products;
fork
:notify user;
fork again
:log action;
end fork
:Write Review;
:Manage Inventory;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log event;
end fork
:Checkout;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Cancel Order;
:Apply Coupon;
stop
@enduml