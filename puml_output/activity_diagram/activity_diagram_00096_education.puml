@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
start
:Grade Exam;
fork
:notify admin;
fork again
:log action;
end fork
:Register Student;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Submit Assignment;
:Issue Certificate;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Borrow Book;
:Enroll Course;
:Take Attendance;
:View Schedule;
stop
@enduml