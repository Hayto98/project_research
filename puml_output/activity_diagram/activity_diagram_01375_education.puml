@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
start
:Register Student;
:Take Attendance;
:Enroll Course;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Issue Certificate;
:Borrow Book;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Submit Assignment;
fork
:notify admin;
fork again
:log event;
end fork
stop
@enduml