@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
start
:Schedule Pickup;
:Deliver Package;
:Update Inventory;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Assign Route;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Track Shipment;
fork
:notify system;
fork again
:log change;
end fork
stop
@enduml