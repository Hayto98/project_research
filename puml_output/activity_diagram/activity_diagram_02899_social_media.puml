@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
start
:Comment;
:Report Content;
:Create Post;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log event;
end fork
:Edit Profile;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Like Post;
fork
:notify user;
fork again
:log event;
end fork
:Share Post;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Send Message;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Follow User;
stop
@enduml