@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
start
:Make Payment;
:Cancel Order;
:Manage Inventory;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Write Review;
fork
:notify system;
fork again
:log event;
end fork
:Checkout;
stop
@enduml