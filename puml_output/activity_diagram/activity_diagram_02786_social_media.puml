@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
start
:Comment;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log event;
end fork
:Follow User;
:Share Post;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log event;
end fork
:Send Message;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Report Content;
:Create Post;
:Edit Profile;
:Like Post;
stop
@enduml