@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
start
:Load Package;
:Fuel Vehicle;
:Schedule Pickup;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Assign Route;
:Update Inventory;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Report Issue;
:Deliver Package;
:Track Shipment;
stop
@enduml