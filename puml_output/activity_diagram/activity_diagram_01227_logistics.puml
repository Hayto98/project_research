@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
start
:Track Shipment;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log change;
end fork
:Schedule Pickup;
:Update Inventory;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Assign Route;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Deliver Package;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log action;
end fork
:Report Issue;
:Load Package;
:Fuel Vehicle;
fork
:notify admin;
fork again
:log change;
end fork
stop
@enduml