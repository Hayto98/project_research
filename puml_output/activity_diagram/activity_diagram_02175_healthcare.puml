@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
start
:Run Lab Test;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Update Medical Record;
:Process Insurance Claim;
fork
:notify user;
fork again
:log action;
end fork
:Issue Prescription;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Book Appointment;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Discharge Patient;
:Admit Patient;
:Examine Patient;
stop
@enduml