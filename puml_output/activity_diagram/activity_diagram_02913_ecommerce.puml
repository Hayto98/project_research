@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
start
:Write Review;
fork
:notify user;
fork again
:log change;
end fork
:Track Order;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Cancel Order;
:Make Payment;
:Apply Coupon;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Checkout;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Browse Products;
stop
@enduml