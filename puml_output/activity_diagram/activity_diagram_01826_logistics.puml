@startuml
skinparam monochrome true
start
:Track Shipment;
:Assign Route;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log event;
end fork
:Fuel Vehicle;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log action;
end fork
:Schedule Pickup;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Load Package;
:Update Inventory;
:Deliver Package;
:Report Issue;
stop
@enduml