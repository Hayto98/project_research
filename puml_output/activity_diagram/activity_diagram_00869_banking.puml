@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
start
:Pay Bill;
:Transfer Funds;
:Block Card;
:Withdraw Cash;
:Apply For Loan;
:Open Account;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:View Statement;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log event;
end fork
:Deposit Money;
stop
@enduml