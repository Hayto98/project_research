@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
start
:Order Room Service;
:Book Room;
:Check In;
:Clean Room;
fork
:notify system;
fork again
:log event;
end fork
:Process Payment;
fork
:notify system;
fork again
:log action;
end fork
:Cancel Reservation;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Request Service;
:Check Out;
stop
@enduml