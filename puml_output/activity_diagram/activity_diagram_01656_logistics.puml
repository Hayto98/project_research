@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
start
:Assign Route;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Update Inventory;
:Deliver Package;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Fuel Vehicle;
fork
:notify admin;
fork again
:log action;
end fork
:Load Package;
:Track Shipment;
:Schedule Pickup;
stop
@enduml