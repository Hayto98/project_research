@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
start
:Write Review;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Manage Inventory;
:Apply Coupon;
:Track Order;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Add To Cart;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Checkout;
:Make Payment;
stop
@enduml