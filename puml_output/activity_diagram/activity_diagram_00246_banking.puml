@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
start
:Pay Bill;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log change;
end fork
:Withdraw Cash;
:Transfer Funds;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Deposit Money;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:View Statement;
:Apply For Loan;
:Open Account;
:Block Card;
stop
@enduml