@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
start
:Renew Loan;
:Borrow Book;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log action;
end fork
:Search Catalog;
:Register Member;
