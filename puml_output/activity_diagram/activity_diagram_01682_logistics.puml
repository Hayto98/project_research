@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
start
:Deliver Package;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Assign Route;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Update Inventory;
:Fuel Vehicle;
:Load Package;
:Schedule Pickup;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Report Issue;
stop
@enduml