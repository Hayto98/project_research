@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
start
:Clean Room;
:Order Room Service;
fork
:notify admin;
fork again
:log event;
end fork
:Check Out;
:Book Room;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Request Service;
:Cancel Reservation;
fork
:notify system;
fork again
:log event;
end fork
:Check In;
stop
@enduml