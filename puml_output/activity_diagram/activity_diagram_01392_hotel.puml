@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
start
:Check Out;
:Book Room;
fork
:notify user;
fork again
:log change;
end fork
:Clean Room;
:Process Payment;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Order Room Service;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Request Service;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log change;
end fork
:Cancel Reservation;
stop
@enduml