@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
start
:Transfer Funds;
:Deposit Money;
:Withdraw Cash;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log action;
end fork
:Open Account;
:Block Card;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:View Statement;
:Apply For Loan;
fork
:notify user;
fork again
:log event;
end fork
stop
@enduml