@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
start
:Register Member;
fork
:notify system;
fork again
:log action;
end fork
:Return Book;
:Search Catalog;
:Borrow Book;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Renew Loan;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Reserve Book;
stop
@enduml