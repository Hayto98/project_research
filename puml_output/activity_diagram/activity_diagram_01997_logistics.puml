@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
start
:Report Issue;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Deliver Package;
:Track Shipment;
:Schedule Pickup;
:Load Package;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Assign Route;
stop
@enduml