@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
start
:Follow User;
fork
:notify system;
fork again
:log event;
end fork
:Like Post;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Report Content;
:Edit Profile;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Create Post;
fork
:notify user;
fork again
:log action;
end fork
:Comment;
stop
@enduml