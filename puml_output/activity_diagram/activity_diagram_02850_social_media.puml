@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
start
:Edit Profile;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Follow User;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Like Post;
:Report Content;
