@startuml
skinparam monochrome true
skinparam shadowing true
start
:Examine Patient;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Process Insurance Claim;
:Book Appointment;
:Update Medical Record;
fork
:notify system;
fork again
:log event;
end fork
:Issue Prescription;
:Discharge Patient;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Run Lab Test;
stop
@enduml