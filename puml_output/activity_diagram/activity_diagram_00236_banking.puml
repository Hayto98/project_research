@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
start
:View Statement;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log action;
end fork
:Apply For Loan;
:Deposit Money;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Pay Bill;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Transfer Funds;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Open Account;
fork
:notify system;
fork again
:log change;
end fork
:Block Card;
stop
@enduml