@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
start
:Update Medical Record;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Issue Prescription;
:Admit Patient;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Examine Patient;
:Process Insurance Claim;
:Discharge Patient;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Run Lab Test;
:Book Appointment;
stop
@enduml