@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
start
:Check Out;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log change;
end fork
:Process Payment;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Order Room Service;
:Book Room;
fork
:notify user;
fork again
:log change;
end fork
:Clean Room;
stop
@enduml