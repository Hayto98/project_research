@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
start
:Report Content;
fork
:notify user;
fork again
:log change;
end fork
:Follow User;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Share Post;
:Send Message;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Edit Profile;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Comment;
:Like Post;
stop
@enduml