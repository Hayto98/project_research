@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
start
:Cancel Reservation;
:Request Service;
:Clean Room;
:Book Room;
:Process Payment;
:Order Room Service;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Check In;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Check Out;
stop
@enduml