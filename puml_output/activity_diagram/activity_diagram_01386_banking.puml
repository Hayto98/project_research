@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
start
:Transfer Funds;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Pay Bill;
:Apply For Loan;
:Withdraw Cash;
:Open Account;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Block Card;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:View Statement;
stop
@enduml