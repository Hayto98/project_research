@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
start
:Send Message;
fork
:notify user;
fork again
:log event;
end fork
:Like Post;
:Comment;
:Follow User;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Share Post;
:Report Content;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Create Post;
fork
:notify user;
fork again
:log action;
end fork
:Edit Profile;
stop
@enduml