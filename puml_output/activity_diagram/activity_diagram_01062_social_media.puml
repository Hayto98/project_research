@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
start
:Follow User;
:Share Post;
:Report Content;
:Like Post;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Send Message;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Create Post;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Comment;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Edit Profile;
stop
@enduml