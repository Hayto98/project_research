@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
start
:Track Order;
:Write Review;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log event;
end fork
:Apply Coupon;
fork
:notify system;
fork again
:log action;
end fork
:Checkout;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Add To Cart;
stop
@enduml