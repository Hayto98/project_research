@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
start
:Make Payment;
:Track Order;
fork
:notify user;
fork again
:log change;
end fork
:Browse Products;
:Write Review;
fork
:notify admin;
fork again
:log event;
end fork
:Checkout;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Apply Coupon;
fork
:notify system;
fork again
:log action;
end fork
stop
@enduml