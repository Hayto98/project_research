@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
start
:Enroll Course;
:Register Student;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Take Attendance;
:View Schedule;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Grade Exam;
fork
:notify user;
fork again
:log action;
end fork
:Borrow Book;
stop
@enduml