@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
start
:Check In;
:Book Room;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Cancel Reservation;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log change;
end fork
:Clean Room;
:Check Out;
:Order Room Service;
:Process Payment;
stop
@enduml