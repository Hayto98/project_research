@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
start
:Track Shipment;
:Assign Route;
fork
:notify admin;
fork again
:log event;
end fork
:Load Package;
:Report Issue;
:Fuel Vehicle;
:Deliver Package;
