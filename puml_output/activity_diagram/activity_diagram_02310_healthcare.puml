@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
start
:Update Medical Record;
:Admit Patient;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Issue Prescription;
:Book Appointment;
:Process Insurance Claim;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Discharge Patient;
:Examine Patient;
fork
:notify system;
fork again
:log change;
end fork
stop
@enduml