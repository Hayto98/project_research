@startuml
skinparam monochrome true
skinparam shadowing true
start
:Deposit Money;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Open Account;
:Apply For Loan;
:Block Card;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Pay Bill;
fork
:notify system;
fork again
:log change;
end fork
stop
@enduml