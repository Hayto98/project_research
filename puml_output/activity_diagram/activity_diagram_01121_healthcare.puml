@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
start
:Examine Patient;
:Run Lab Test;
:Discharge Patient;
:Process Insurance Claim;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Book Appointment;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Update Medical Record;
fork
:notify admin;
fork again
:log event;
end fork
:Admit Patient;
:Issue Prescription;
stop
@enduml