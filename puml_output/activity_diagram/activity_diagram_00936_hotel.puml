@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
start
:Process Payment;
:Check Out;
:Check In;
fork
:notify user;
fork again
:log action;
end fork
:Order Room Service;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Request Service;
:Cancel Reservation;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Book Room;
:Clean Room;
stop
@enduml