@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
start
:Clean Room;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log change;
end fork
:Book Room;
:Cancel Reservation;
fork
:notify system;
fork again
:log event;
end fork
:Process Payment;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log change;
end fork
:Order Room Service;
stop
@enduml