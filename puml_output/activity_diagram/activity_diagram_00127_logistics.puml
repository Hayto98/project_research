@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
start
:Deliver Package;
fork
:notify admin;
fork again
:log event;
end fork
:Load Package;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Report Issue;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log action;
end fork
:Schedule Pickup;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Fuel Vehicle;
:Assign Route;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Update Inventory;
:Track Shipment;
stop
@enduml