@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
start
:Cancel Reservation;
:Check Out;
:Book Room;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Order Room Service;
fork
:notify admin;
fork again
:log change;
end fork
:Clean Room;
fork
:notify system;
fork again
:log action;
end fork
:Request Service;
:Check In;
stop
@enduml