@startuml
skinparam monochrome true
skinparam shadowing true
start
:Edit Profile;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Share Post;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log action;
end fork
:Report Content;
:Comment;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Create Post;
stop
@enduml