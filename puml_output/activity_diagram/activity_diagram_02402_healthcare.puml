@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
start
:Examine Patient;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Run Lab Test;
:Book Appointment;
:Admit Patient;
:Discharge Patient;
