@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
start
:Discharge Patient;
fork
:notify user;
fork again
:log action;
end fork
:Examine Patient;
:Admit Patient;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Book Appointment;
:Update Medical Record;
:Run Lab Test;
:Issue Prescription;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log action;
end fork
:Process Insurance Claim;
stop
@enduml