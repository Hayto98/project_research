@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
start
:Update Inventory;
fork
:notify admin;
fork again
:log action;
end fork
:Schedule Pickup;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Fuel Vehicle;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Report Issue;
:Assign Route;
:Deliver Package;
stop
@enduml