@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
start
:Like Post;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Create Post;
:Send Message;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Share Post;
:Comment;
stop
@enduml