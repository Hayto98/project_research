@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
start
:Track Order;
:Checkout;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Browse Products;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Apply Coupon;
:Manage Inventory;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Write Review;
fork
:notify system;
fork again
:log event;
end fork
:Make Payment;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify admin;
fork again
:log change;
end fork
:Cancel Order;
stop
@enduml