@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
start
:Assign Route;
fork
:notify user;
fork again
:log action;
end fork
:Schedule Pickup;
:Load Package;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Report Issue;
:Deliver Package;
fork
:notify system;
fork again
:log change;
end fork
stop
@enduml