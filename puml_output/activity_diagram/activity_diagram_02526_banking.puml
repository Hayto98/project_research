@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
start
:Apply For Loan;
:Open Account;
:Transfer Funds;
if (approved?) then (yes)
:continue process;
else (no)
