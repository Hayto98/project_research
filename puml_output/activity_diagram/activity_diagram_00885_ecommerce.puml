@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
start
:Cancel Order;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Checkout;
:Write Review;
:Manage Inventory;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log change;
end fork
:Add To Cart;
:Make Payment;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Browse Products;
fork
:notify admin;
fork again
:log event;
end fork
:Apply Coupon;
fork
:notify system;
fork again
:log change;
end fork
stop
@enduml