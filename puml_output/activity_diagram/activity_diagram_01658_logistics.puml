@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
start
:Load Package;
fork
:notify system;
fork again
:log event;
end fork
:Schedule Pickup;
:Track Shipment;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Fuel Vehicle;
fork
:notify admin;
fork again
:log event;
end fork
:Assign Route;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Update Inventory;
fork
:notify system;
fork again
:log event;
end fork
stop
@enduml