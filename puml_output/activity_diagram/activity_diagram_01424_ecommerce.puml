@startuml
skinparam monochrome true
start
:Checkout;
fork
:notify user;
fork again
:log change;
end fork
:Apply Coupon;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Track Order;
:Manage Inventory;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify system;
fork again
:log event;
end fork
:Write Review;
stop
@enduml