@startuml
skinparam monochrome true
skinparam defaultFontSize 11
start
:Report Issue;
if (success?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Update Inventory;
:Assign Route;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log action;
end fork
:Schedule Pickup;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Load Package;
:Deliver Package;
:Track Shipment;
stop
@enduml