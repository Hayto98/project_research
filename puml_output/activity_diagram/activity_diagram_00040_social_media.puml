@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
start
:Like Post;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
fork
:notify user;
fork again
:log action;
end fork
:Share Post;
:Send Message;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Comment;
if (approved?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Create Post;
fork
:notify system;
fork again
:log action;
end fork
:Edit Profile;
fork
:notify admin;
fork again
:log event;
end fork
stop
@enduml