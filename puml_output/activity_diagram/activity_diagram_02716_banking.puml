@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
start
:Deposit Money;
fork
:notify admin;
fork again
:log event;
end fork
:Apply For Loan;
if (valid?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Withdraw Cash;
:Open Account;
if (available?) then (yes)
:continue process;
else (no)
:handle error;
stop
endif
:Pay Bill;
:Block Card;
stop
@enduml