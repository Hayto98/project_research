@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
[*] --> Archived
Archived --> Delivered : confirm
Delivered --> Closed : reject
Closed --> Reviewed : review
Reviewed --> OnHold : reject
Reviewed --> Archived : revert
OnHold --> [*]
@enduml