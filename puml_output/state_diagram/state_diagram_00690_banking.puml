@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
[*] --> Cancelled
Cancelled --> Processing : update
Processing --> Rejected : cancel
Rejected --> Created : approve
Rejected : entry / log loan
Created --> Cancelled : revert
Created --> [*]
@enduml