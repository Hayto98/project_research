@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
[*] --> Pending
Pending --> Shipped : approve
Shipped --> Rejected : review
Rejected --> Completed : confirm
Rejected : entry / log package
Completed --> Closed : review
Closed --> [*]
@enduml