@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
[*] --> Reviewed
Reviewed --> Created : submit
Created --> Active : process
Active --> Pending : reject
Active : entry / log statement
Pending --> OnHold : approve
Pending : entry / log statement
OnHold --> Cancelled : cancel
Created --> Reviewed : revert
Cancelled --> [*]
@enduml