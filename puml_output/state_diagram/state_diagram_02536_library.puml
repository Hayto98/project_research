@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
[*] --> Cancelled
Cancelled --> Completed : confirm
Completed --> OnHold : review
OnHold --> Active : review
Active --> Created : review
Created --> Approved : update
Active --> Cancelled : revert
Approved --> [*]
@enduml