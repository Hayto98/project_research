@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
[*] --> Created
Created --> Pending : update
Pending --> OnHold : submit
OnHold --> Reviewed : confirm
OnHold : entry / log shelf
Reviewed --> Delivered : review
Delivered --> [*]
@enduml