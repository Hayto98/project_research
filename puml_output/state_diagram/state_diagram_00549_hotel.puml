@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
[*] --> Approved
Approved --> Rejected : review
Rejected --> Draft : approve
Draft --> OnHold : reject
OnHold --> Closed : review
Rejected --> Approved : revert
Closed --> [*]
@enduml