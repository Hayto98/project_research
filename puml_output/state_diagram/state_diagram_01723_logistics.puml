@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
[*] --> OnHold
OnHold --> Rejected : review
Rejected --> Pending : update
Pending --> Delivered : update
Delivered --> Archived : cancel
Archived --> Reviewed : submit
Reviewed --> [*]
@enduml