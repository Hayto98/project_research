@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
[*] --> Cancelled
Cancelled --> Reviewed : review
Reviewed --> Shipped : update
Shipped --> Processing : process
Processing --> Approved : process
Approved --> OnHold : cancel
Processing --> Cancelled : revert
OnHold --> [*]
@enduml