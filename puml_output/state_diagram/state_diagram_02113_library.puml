@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
[*] --> Cancelled
Cancelled --> Draft : review
Draft --> Delivered : review
Delivered --> Closed : cancel
Delivered : entry / log librarian
Closed --> Created : confirm
Created --> OnHold : review
OnHold --> [*]
@enduml