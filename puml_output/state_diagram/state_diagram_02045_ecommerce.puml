@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
[*] --> Shipped
Shipped --> Reviewed : approve
Reviewed --> Rejected : update
Rejected --> Processing : confirm
Processing --> Completed : process
Processing : entry / log customer
Completed --> Cancelled : confirm
Cancelled --> [*]
@enduml