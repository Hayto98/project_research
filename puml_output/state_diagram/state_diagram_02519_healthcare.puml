@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
[*] --> Shipped
Shipped --> Cancelled : confirm
Cancelled --> Closed : process
Closed --> Processing : reject
Processing --> Active : review
Active --> Approved : submit
Active : entry / log medicalrecord
Active --> Shipped : revert
Approved --> [*]
@enduml