@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
[*] --> Rejected
Rejected --> Created : approve
Rejected : entry / log treatment
Created --> Cancelled : update
Cancelled --> Delivered : review
Cancelled --> Delivered : revert
Delivered --> [*]
@enduml