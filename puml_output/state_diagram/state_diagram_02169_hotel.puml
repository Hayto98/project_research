@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
[*] --> Approved
Approved --> Shipped : approve
Shipped --> OnHold : approve
OnHold --> Rejected : cancel
Rejected --> Reviewed : reject
Reviewed --> Approved : revert
Reviewed --> [*]
@enduml