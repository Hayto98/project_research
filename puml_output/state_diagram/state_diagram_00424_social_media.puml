@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
[*] --> Pending
Pending --> Archived : approve
Pending : entry / log message
Archived --> Completed : cancel
Completed --> Rejected : process
Rejected --> Approved : reject
Approved --> Reviewed : review
Reviewed --> Pending : revert
Reviewed --> [*]
@enduml