@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
[*] --> Pending
Pending --> Cancelled : submit
Cancelled --> Created : cancel
Created --> Approved : confirm
Approved --> Active : approve
Active --> Delivered : submit
Active : entry / log route
Delivered --> Cancelled : revert
Delivered --> [*]
@enduml