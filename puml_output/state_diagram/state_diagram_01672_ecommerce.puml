@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
[*] --> Active
Active --> Rejected : review
Rejected --> Completed : approve
Completed --> Approved : confirm
Completed : entry / log warehouse
Approved --> Shipped : approve
Shipped --> Draft : process
Draft --> [*]
@enduml