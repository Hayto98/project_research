@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
[*] --> Processing
Processing --> Delivered : process
Delivered --> Approved : process
Approved --> Archived : submit
Archived --> Closed : approve
Closed --> Completed : cancel
Completed --> [*]
@enduml