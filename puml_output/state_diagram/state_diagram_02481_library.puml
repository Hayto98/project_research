@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
[*] --> Reviewed
Reviewed --> Draft : confirm
Draft --> Cancelled : reject
Cancelled --> Pending : update
Cancelled : entry / log publisher
Pending --> Archived : confirm
Archived --> Delivered : reject
Delivered --> [*]
@enduml