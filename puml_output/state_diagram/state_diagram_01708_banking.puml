@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
[*] --> Processing
Processing --> Shipped : approve
Shipped --> Pending : reject
Pending --> Created : cancel
Created --> Cancelled : submit
Cancelled --> Reviewed : submit
Shipped --> Processing : revert
Reviewed --> [*]
@enduml