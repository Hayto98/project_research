@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
[*] --> Processing
Processing --> Draft : reject
Draft --> Active : cancel
Active --> Delivered : review
Delivered --> Archived : approve
Delivered : entry / log wishlist
Archived --> Cancelled : update
Active --> Archived : revert
Cancelled --> [*]
@enduml