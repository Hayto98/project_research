@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
[*] --> Processing
Processing --> Reviewed : approve
Reviewed --> Delivered : cancel
Reviewed : entry / log report
Delivered --> Pending : approve
Reviewed --> Processing : revert
Pending --> [*]
@enduml