@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
[*] --> Reviewed
Reviewed --> Closed : update
Closed --> Rejected : approve
Rejected --> OnHold : confirm
OnHold --> Draft : submit
Draft --> Active : cancel
Draft : entry / log grade
Active --> [*]
@enduml