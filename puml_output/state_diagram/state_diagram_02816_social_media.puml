@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
[*] --> Closed
Closed --> Active : cancel
Active --> Draft : submit
Draft --> Pending : process
Draft : entry / log group
Pending --> Approved : update
Approved --> Archived : update
Archived --> [*]
@enduml