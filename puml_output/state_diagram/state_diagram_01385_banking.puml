@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
[*] --> Draft
Draft --> Pending : cancel
Pending --> Delivered : submit
Pending : entry / log teller
Delivered --> Cancelled : process
Cancelled --> Shipped : cancel
Shipped --> Draft : revert
Shipped --> [*]
@enduml