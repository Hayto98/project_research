@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
[*] --> Completed
Completed --> Closed : cancel
Closed --> Cancelled : process
Closed : entry / log branch
Cancelled --> Pending : update
Pending --> Rejected : reject
Rejected --> Completed : revert
Rejected --> [*]
@enduml