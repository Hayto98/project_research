@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
[*] --> Archived
Archived --> Delivered : reject
Delivered --> Rejected : reject
Rejected --> Completed : reject
Completed --> Cancelled : review
Cancelled --> Reviewed : confirm
Rejected --> Archived : revert
Reviewed --> [*]
@enduml