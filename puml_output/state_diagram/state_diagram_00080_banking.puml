@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
[*] --> Delivered
Delivered --> Closed : submit
Closed --> Cancelled : process
Cancelled --> Created : confirm
Created --> Pending : confirm
Created : entry / log account
Pending --> Reviewed : approve
Reviewed --> [*]
@enduml