@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
[*] --> Approved
Approved --> OnHold : confirm
OnHold --> Created : cancel
OnHold : entry / log customer
Created --> Completed : update
Completed --> Delivered : cancel
Delivered --> [*]
