@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
[*] --> Closed
Closed --> Active : cancel
Active --> Completed : reject
Completed --> Processing : approve
Processing --> Cancelled : approve
Cancelled --> Shipped : cancel
Shipped --> Completed : revert
Shipped --> [*]
@enduml