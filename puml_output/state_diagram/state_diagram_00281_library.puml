@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
[*] --> Created
Created --> Completed : update
Completed --> Active : cancel
Active --> Cancelled : reject
Active : entry / log branch
Cancelled --> Rejected : update
Rejected --> Processing : update
Completed --> Created : revert
Processing --> [*]
@enduml