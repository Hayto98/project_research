@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
[*] --> Created
Created --> Archived : update
Archived --> Closed : reject
Closed --> Delivered : update
Closed : entry / log amenity
Closed --> Created : revert
Delivered --> [*]
@enduml