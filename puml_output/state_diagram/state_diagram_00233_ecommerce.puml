@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
[*] --> Reviewed
Reviewed --> Cancelled : approve
Cancelled --> Shipped : approve
Shipped --> OnHold : cancel
OnHold --> Rejected : confirm
Rejected --> Active : approve
OnHold --> Shipped : revert
Active --> [*]
@enduml