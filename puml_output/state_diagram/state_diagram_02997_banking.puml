@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
[*] --> Created
Created --> Approved : review
Approved --> Reviewed : review
Reviewed --> Cancelled : submit
Cancelled --> Draft : process
Draft --> Closed : confirm
Closed --> [*]
@enduml