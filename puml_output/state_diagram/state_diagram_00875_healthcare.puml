@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
[*] --> OnHold
OnHold --> Delivered : update
Delivered --> Rejected : approve
Rejected --> Completed : review
Completed --> Processing : confirm
Completed : entry / log treatment
Processing --> [*]
@enduml