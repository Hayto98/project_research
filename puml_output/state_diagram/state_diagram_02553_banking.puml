@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
[*] --> Pending
Pending --> Reviewed : process
Pending : entry / log beneficiary
Reviewed --> Draft : review
Draft --> Delivered : approve
Reviewed --> Delivered : revert
Delivered --> [*]
@enduml