@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
[*] --> Pending
Pending --> Processing : review
Processing --> Created : confirm
Created --> Closed : submit
Closed --> Rejected : update
Created --> Processing : revert
Rejected --> [*]
@enduml