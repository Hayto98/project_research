@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
[*] --> Archived
Archived --> Active : reject
Archived : entry / log checkout
Active --> Pending : confirm
Pending --> Rejected : update
Rejected --> Closed : confirm
Rejected : entry / log checkout
Closed --> Reviewed : cancel
Reviewed --> [*]
@enduml