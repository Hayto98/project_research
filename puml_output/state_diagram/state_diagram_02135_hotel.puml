@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
[*] --> Draft
Draft --> Rejected : confirm
Rejected --> Shipped : update
Shipped --> Archived : approve
Shipped : entry / log amenity
Archived --> OnHold : process
OnHold --> Delivered : confirm
Delivered --> Shipped : revert
Delivered --> [*]
@enduml