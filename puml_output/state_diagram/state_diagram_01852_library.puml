@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
[*] --> Pending
Pending --> Reviewed : submit
Reviewed --> Closed : submit
Closed --> Rejected : process
Rejected --> Approved : submit
Rejected : entry / log shelf
Approved --> Archived : review
Rejected --> Approved : revert
Archived --> [*]
@enduml