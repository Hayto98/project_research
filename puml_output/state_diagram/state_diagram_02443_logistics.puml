@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
[*] --> Pending
Pending --> Shipped : reject
Shipped --> Cancelled : confirm
Cancelled --> Processing : update
Processing --> Archived : submit
Archived --> Created : approve
Created --> [*]
@enduml