@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
[*] --> Reviewed
Reviewed --> Archived : approve
Archived --> Pending : submit
Pending --> Draft : reject
Pending : entry / log tracking
Draft --> Delivered : cancel
Delivered --> Completed : cancel
Delivered : entry / log tracking
Completed --> [*]
@enduml