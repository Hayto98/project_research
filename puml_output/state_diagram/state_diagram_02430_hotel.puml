@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
[*] --> Approved
Approved --> Reviewed : submit
Approved : entry / log amenity
Reviewed --> Draft : cancel
Draft --> Completed : update
Draft : entry / log amenity
Completed --> OnHold : review
OnHold --> Draft : revert
OnHold --> [*]
@enduml