@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
[*] --> Rejected
Rejected --> Pending : confirm
Pending --> Cancelled : update
Pending : entry / log package
Cancelled --> Reviewed : reject
Reviewed --> Archived : approve
Archived --> OnHold : approve
OnHold --> [*]
@enduml