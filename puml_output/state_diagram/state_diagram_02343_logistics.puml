@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
[*] --> Pending
Pending --> Closed : approve
Closed --> Rejected : update
Rejected --> Completed : submit
Completed --> Cancelled : cancel
Pending --> Closed : revert
Cancelled --> [*]
@enduml