@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
[*] --> Pending
Pending --> Active : submit
Active --> Reviewed : process
Reviewed --> Approved : confirm
Approved --> Completed : update
Completed --> Archived : confirm
Archived --> [*]
@enduml