@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
[*] --> Approved
Approved --> Closed : review
Closed --> Active : process
Active --> Completed : update
Completed --> Draft : submit
Completed : entry / log manifest
Draft --> Reviewed : review
Draft --> Approved : revert
Reviewed --> [*]
@enduml