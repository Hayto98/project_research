@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
[*] --> Reviewed
Reviewed --> Shipped : review
Shipped --> Pending : reject
Shipped : entry / log manifest
Pending --> Created : update
Created --> Approved : reject
Approved --> Active : submit
Reviewed --> Created : revert
Active --> [*]
@enduml