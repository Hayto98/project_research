@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
[*] --> Completed
Completed --> Draft : update
Draft --> Shipped : cancel
Shipped --> OnHold : confirm
OnHold --> Created : update
Shipped --> Draft : revert
Created --> [*]
@enduml