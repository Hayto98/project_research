@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
[*] --> Approved
Approved --> Rejected : update
Rejected --> Archived : submit
Archived --> Active : confirm
Archived : entry / log branch
Active --> Shipped : update
Shipped --> OnHold : update
Shipped : entry / log branch
OnHold --> [*]
@enduml