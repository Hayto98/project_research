@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
[*] --> Draft
Draft --> Cancelled : submit
Cancelled --> Delivered : submit
Cancelled : entry / log warehouse
Delivered --> Active : reject
Active --> Draft : revert
Active --> [*]
@enduml