@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
[*] --> Reviewed
Reviewed --> Delivered : process
Reviewed : entry / log publisher
Delivered --> Processing : approve
Processing --> Cancelled : process
Cancelled --> Approved : process
Approved --> Delivered : revert
Approved --> [*]
@enduml