@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
[*] --> Closed
Closed --> Active : submit
Active --> Processing : update
Processing --> Approved : process
Approved --> Archived : process
Approved : entry / log classroom
Archived --> [*]
@enduml