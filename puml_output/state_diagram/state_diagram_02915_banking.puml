@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
[*] --> Cancelled
Cancelled --> Active : reject
Active --> OnHold : process
Active : entry / log teller
OnHold --> Delivered : cancel
Active --> Cancelled : revert
Delivered --> [*]
@enduml