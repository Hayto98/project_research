@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
[*] --> Processing
Processing --> OnHold : confirm
OnHold --> Rejected : cancel
Rejected --> Pending : review
Rejected : entry / log fuellog
Pending --> Created : approve
Created --> Archived : cancel
Rejected --> OnHold : revert
Archived --> [*]
@enduml