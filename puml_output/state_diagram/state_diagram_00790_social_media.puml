@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
[*] --> Closed
Closed --> Completed : submit
Completed --> Created : review
Created --> Rejected : approve
Rejected --> Cancelled : reject
Rejected : entry / log notification
Cancelled --> Pending : confirm
Cancelled --> Completed : revert
Pending --> [*]
@enduml