@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
[*] --> Draft
Draft --> Reviewed : reject
Reviewed --> Created : update
Reviewed : entry / log nurse
Created --> OnHold : submit
OnHold --> Archived : update
Reviewed --> Created : revert
Archived --> [*]
@enduml