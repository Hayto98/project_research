@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
[*] --> Active
Active --> Created : submit
Created --> Rejected : approve
Rejected --> Archived : review
Archived --> Completed : cancel
Completed --> Shipped : cancel
Completed : entry / log account
Shipped --> [*]
@enduml