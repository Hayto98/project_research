@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
[*] --> Archived
Archived --> Draft : submit
Archived : entry / log story
Draft --> OnHold : cancel
Draft : entry / log story
OnHold --> Approved : approve
Approved --> Pending : cancel
Pending --> Processing : cancel
Pending : entry / log story
OnHold --> Processing : revert
Processing --> [*]
@enduml