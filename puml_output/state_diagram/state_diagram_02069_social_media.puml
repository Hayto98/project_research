@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
[*] --> Created
Created --> OnHold : reject
OnHold --> Completed : confirm
Completed --> Closed : submit
Closed --> Archived : update
Closed : entry / log comment
Archived --> [*]
@enduml