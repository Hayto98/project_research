@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
[*] --> Created
Created --> Closed : approve
Closed --> Approved : reject
Approved --> Shipped : cancel
Shipped --> Active : cancel
Shipped : entry / log card
Closed --> Active : revert
Active --> [*]
@enduml