@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
[*] --> Reviewed
Reviewed --> Completed : review
Reviewed : entry / log depot
Completed --> Shipped : submit
Shipped --> OnHold : confirm
OnHold --> Cancelled : submit
Cancelled --> Active : process
Active --> [*]
@enduml