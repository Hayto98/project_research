@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
[*] --> Active
Active --> Created : update
Created --> Completed : update
Completed --> Approved : submit
Approved --> OnHold : submit
OnHold --> Rejected : submit
Created --> Rejected : revert
Rejected --> [*]
@enduml