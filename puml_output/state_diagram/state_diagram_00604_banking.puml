@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
[*] --> Cancelled
Cancelled --> Reviewed : confirm
Reviewed --> Pending : cancel
Reviewed : entry / log deposit
Pending --> Draft : approve
Cancelled --> Pending : revert
Draft --> [*]
@enduml