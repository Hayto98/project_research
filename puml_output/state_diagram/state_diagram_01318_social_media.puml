@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
[*] --> Processing
Processing --> Draft : approve
Draft --> Delivered : cancel
Delivered --> Rejected : update
Delivered : entry / log comment
Rejected --> Reviewed : reject
Reviewed --> Archived : update
Archived --> Delivered : revert
Archived --> [*]
@enduml