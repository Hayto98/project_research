@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
[*] --> Pending
Pending --> Delivered : submit
Delivered --> Cancelled : reject
Delivered : entry / log attendance
Cancelled --> Shipped : update
Cancelled : entry / log attendance
Shipped --> Approved : process
Approved --> Rejected : process
Approved : entry / log attendance
Rejected --> [*]
@enduml