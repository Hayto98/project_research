@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
[*] --> Approved
Approved --> Draft : update
Draft --> Created : update
Created --> Closed : approve
Closed --> Cancelled : update
Cancelled --> Reviewed : cancel
Cancelled : entry / log catalog
Reviewed --> [*]
@enduml