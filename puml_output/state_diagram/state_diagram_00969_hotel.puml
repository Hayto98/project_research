@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
[*] --> Closed
Closed --> Reviewed : approve
Closed : entry / log checkin
Reviewed --> Approved : review
Approved --> Pending : submit
Pending --> Shipped : review
Shipped --> Cancelled : update
Closed --> Shipped : revert
Cancelled --> [*]
@enduml