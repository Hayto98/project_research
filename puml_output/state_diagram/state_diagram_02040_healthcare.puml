@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
[*] --> Draft
Draft --> Archived : process
Archived --> Reviewed : update
Reviewed --> Created : review
Created --> Completed : submit
Created : entry / log nurse
Reviewed --> Completed : revert
Completed --> [*]
@enduml