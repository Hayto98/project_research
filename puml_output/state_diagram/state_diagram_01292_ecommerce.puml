@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
[*] --> Created
Created --> Draft : review
Draft --> Shipped : cancel
Shipped --> Reviewed : confirm
Shipped : entry / log return
Reviewed --> Approved : submit
Approved --> [*]
@enduml