@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
[*] --> Cancelled
Cancelled --> Approved : review
Approved --> Rejected : submit
Approved : entry / log billing
Rejected --> Pending : update
Pending --> Processing : reject
Processing --> Cancelled : revert
Processing --> [*]
@enduml