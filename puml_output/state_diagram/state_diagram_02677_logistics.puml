@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
[*] --> Shipped
Shipped --> Delivered : process
Delivered --> Processing : review
Processing --> Completed : cancel
Completed --> Pending : review
Pending --> Closed : confirm
Pending : entry / log warehouse
Closed --> [*]
@enduml