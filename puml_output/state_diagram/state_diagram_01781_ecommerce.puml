@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
[*] --> Created
Created --> Archived : reject
Archived --> Approved : confirm
Approved --> Delivered : review
Delivered --> Active : process
Active --> Pending : process
Pending --> [*]
@enduml