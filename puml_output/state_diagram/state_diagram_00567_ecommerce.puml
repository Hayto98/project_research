@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
[*] --> Draft
Draft --> Archived : process
Draft : entry / log payment
Archived --> Created : review
Created --> Shipped : submit
Shipped --> Pending : cancel
Pending --> Cancelled : reject
Shipped --> Pending : revert
Cancelled --> [*]
@enduml