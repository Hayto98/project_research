@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
[*] --> Created
Created --> Archived : submit
Created : entry / log checkin
Archived --> Rejected : cancel
Rejected --> Processing : submit
Rejected --> Archived : revert
Processing --> [*]
@enduml