@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
[*] --> Draft
Draft --> Closed : process
Draft : entry / log account
Closed --> Rejected : review
Rejected --> Active : update
Active --> Processing : approve
Processing --> Created : reject
Created --> [*]
@enduml