@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
[*] --> Completed
Completed --> Processing : update
Processing --> Cancelled : update
Cancelled --> Shipped : cancel
Shipped --> Closed : confirm
Closed --> Approved : reject
Approved --> [*]
@enduml