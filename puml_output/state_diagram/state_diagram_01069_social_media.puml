@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
[*] --> Archived
Archived --> Approved : cancel
Approved --> Closed : update
Closed --> Shipped : process
Shipped --> Draft : process
Shipped : entry / log album
Draft --> Pending : process
Draft : entry / log album
Pending --> [*]
@enduml