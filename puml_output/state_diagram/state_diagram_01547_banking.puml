@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
[*] --> Created
Created --> OnHold : process
OnHold --> Archived : process
Archived --> Approved : submit
Approved --> Processing : process
Processing --> Shipped : review
Shipped --> [*]
@enduml