@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
[*] --> Rejected
Rejected --> Shipped : confirm
Shipped --> OnHold : cancel
Shipped : entry / log warehouse
OnHold --> Closed : review
Closed --> Archived : cancel
Archived --> Cancelled : submit
Cancelled --> [*]
@enduml