@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
[*] --> Reviewed
Reviewed --> Pending : submit
Pending --> Processing : process
Processing --> Approved : confirm
Approved --> OnHold : reject
Approved : entry / log tracking
Pending --> Reviewed : revert
OnHold --> [*]
@enduml