@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
[*] --> Archived
Archived --> Draft : update
Archived : entry / log fine
Draft --> Shipped : approve
Shipped --> OnHold : update
OnHold --> Processing : submit
Processing --> Shipped : revert
Processing --> [*]
@enduml