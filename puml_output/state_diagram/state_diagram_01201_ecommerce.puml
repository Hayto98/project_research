@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
[*] --> OnHold
OnHold --> Delivered : update
Delivered --> Reviewed : reject
Reviewed --> Archived : submit
Reviewed : entry / log return
Archived --> Cancelled : confirm
Archived --> Delivered : revert
Cancelled --> [*]
@enduml