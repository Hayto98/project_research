@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
[*] --> Cancelled
Cancelled --> Reviewed : approve
Reviewed --> Completed : cancel
Completed --> Closed : update
Closed --> Approved : approve
Approved --> Shipped : approve
Approved : entry / log loan
Shipped --> Cancelled : revert
Shipped --> [*]
@enduml