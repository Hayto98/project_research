@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
[*] --> Active
Active --> Cancelled : cancel
Cancelled --> Archived : update
Archived --> Rejected : approve
Rejected --> Reviewed : review
Reviewed --> Draft : review
Draft --> [*]
@enduml