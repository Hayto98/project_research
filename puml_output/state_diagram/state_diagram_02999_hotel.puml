@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
[*] --> Created
Created --> Pending : confirm
Pending --> Processing : submit
Processing --> Archived : review
Processing : entry / log housekeeping
Archived --> Completed : update
Pending --> Completed : revert
Completed --> [*]
@enduml