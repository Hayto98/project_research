@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
[*] --> Archived
Archived --> Pending : review
Pending --> OnHold : process
OnHold --> Processing : submit
Processing --> Rejected : update
Processing : entry / log route
Rejected --> Draft : cancel
Processing --> Archived : revert
Draft --> [*]
@enduml