@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
[*] --> Shipped
Shipped --> Pending : submit
Pending --> OnHold : submit
OnHold --> Approved : reject
OnHold : entry / log assignment
Approved --> Active : reject
Pending --> Active : revert
Active --> [*]
@enduml