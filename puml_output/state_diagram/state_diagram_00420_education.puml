@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
[*] --> Pending
Pending --> Processing : approve
Pending : entry / log attendance
Processing --> Closed : process
Closed --> Active : cancel
Active --> Reviewed : submit
Active : entry / log attendance
Reviewed --> Rejected : approve
Rejected --> Processing : revert
Rejected --> [*]
@enduml