@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
[*] --> Closed
Closed --> Created : cancel
Created --> Reviewed : process
Reviewed --> Archived : review
Archived --> Approved : submit
Approved --> Delivered : confirm
Approved : entry / log medicalrecord
Delivered --> [*]
@enduml