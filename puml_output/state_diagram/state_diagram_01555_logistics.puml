@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
[*] --> Archived
Archived --> Approved : reject
Approved --> Cancelled : confirm
Cancelled --> OnHold : approve
Cancelled : entry / log driver
OnHold --> Reviewed : submit
Reviewed --> Processing : update
Reviewed : entry / log driver
Cancelled --> Approved : revert
Processing --> [*]
@enduml