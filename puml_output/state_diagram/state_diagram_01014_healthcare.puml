@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
[*] --> Draft
Draft --> Delivered : submit
Delivered --> Shipped : cancel
Shipped --> Completed : review
Completed --> Cancelled : process
Completed : entry / log doctor
Cancelled --> [*]
