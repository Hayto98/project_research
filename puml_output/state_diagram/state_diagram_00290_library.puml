@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
[*] --> Delivered
Delivered --> Reviewed : approve
Reviewed --> Rejected : approve
Rejected --> Active : approve
Rejected : entry / log renewal
Active --> OnHold : approve
Active --> Delivered : revert
OnHold --> [*]
@enduml