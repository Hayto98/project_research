@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
[*] --> Closed
Closed --> Rejected : review
Rejected --> Pending : cancel
Pending --> Created : update
Created --> Approved : process
Created --> Closed : revert
Approved --> [*]
@enduml