@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
[*] --> Closed
Closed --> Completed : cancel
Completed --> Rejected : confirm
Rejected --> Processing : reject
Rejected : entry / log hashtag
Closed --> Processing : revert
Processing --> [*]
@enduml