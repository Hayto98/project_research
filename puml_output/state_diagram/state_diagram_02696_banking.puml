@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
[*] --> Reviewed
Reviewed --> Created : reject
Created --> Draft : approve
Draft --> Approved : cancel
Draft : entry / log card
Approved --> Delivered : review
Delivered --> [*]
@enduml