@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
[*] --> Delivered
Delivered --> OnHold : confirm
OnHold --> Completed : review
Completed --> Reviewed : process
Reviewed --> Rejected : review
Rejected --> Processing : submit
Processing --> [*]
@enduml