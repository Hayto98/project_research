@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
[*] --> Rejected
Rejected --> Completed : submit
Completed --> Cancelled : approve
Completed : entry / log room
Cancelled --> Pending : submit
Pending --> OnHold : cancel
OnHold --> [*]
@enduml