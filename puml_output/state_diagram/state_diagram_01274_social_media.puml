@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
[*] --> Pending
Pending --> Rejected : submit
Pending : entry / log comment
Rejected --> Created : confirm
Created --> Processing : update
Processing --> OnHold : submit
OnHold --> Active : update
Created --> Active : revert
Active --> [*]
@enduml