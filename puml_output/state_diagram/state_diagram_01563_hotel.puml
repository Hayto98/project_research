@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
[*] --> Closed
Closed --> Cancelled : submit
Cancelled --> Active : confirm
Active --> Delivered : confirm
Delivered --> Draft : cancel
Draft --> Active : revert
Draft --> [*]
@enduml