@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
[*] --> Draft
Draft --> Delivered : confirm
Draft : entry / log supplier
Delivered --> Reviewed : submit
Reviewed --> Created : cancel
Created --> Reviewed : revert
Created --> [*]
@enduml