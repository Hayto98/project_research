@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
[*] --> OnHold
OnHold --> Completed : process
Completed --> Rejected : reject
Rejected --> Active : process
Active --> Closed : approve
Active : entry / log billing
Active --> OnHold : revert
Closed --> [*]
@enduml