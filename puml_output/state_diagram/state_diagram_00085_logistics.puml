@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
[*] --> Completed
Completed --> Processing : process
Processing --> Cancelled : approve
Cancelled --> Archived : submit
Archived --> Draft : update
Draft --> Reviewed : approve
Draft : entry / log depot
Completed --> Cancelled : revert
Reviewed --> [*]
@enduml