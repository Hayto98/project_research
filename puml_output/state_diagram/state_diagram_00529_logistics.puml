@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
[*] --> Completed
Completed --> Active : process
Active --> Rejected : reject
Rejected --> Approved : approve
Approved --> Shipped : process
Shipped --> Closed : process
Closed --> [*]
@enduml