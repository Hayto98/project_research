@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
[*] --> Reviewed
Reviewed --> Active : confirm
Active --> Completed : cancel
Completed --> Closed : approve
Closed --> Draft : update
Draft --> Archived : confirm
Completed --> Reviewed : revert
Archived --> [*]
@enduml