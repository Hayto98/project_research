@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
[*] --> Delivered
Delivered --> Processing : submit
Processing --> Archived : reject
Archived --> OnHold : cancel
OnHold --> Created : cancel
OnHold : entry / log department
Created --> Pending : reject
Pending --> [*]
@enduml