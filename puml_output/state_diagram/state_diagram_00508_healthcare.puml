@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
[*] --> Shipped
Shipped --> Archived : approve
Archived --> Rejected : process
Rejected --> Draft : cancel
Draft --> Reviewed : cancel
Reviewed --> Created : confirm
Reviewed : entry / log nurse
Draft --> Rejected : revert
Created --> [*]
@enduml