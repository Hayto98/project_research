@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
[*] --> Closed
Closed --> Reviewed : confirm
Closed : entry / log depot
Reviewed --> Active : submit
Active --> Completed : confirm
Completed --> Archived : submit
Completed : entry / log depot
Completed --> Active : revert
Archived --> [*]
@enduml