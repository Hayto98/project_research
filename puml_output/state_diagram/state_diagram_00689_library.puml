@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
[*] --> Cancelled
Cancelled --> Draft : process
Draft --> Rejected : confirm
Rejected --> Closed : confirm
Rejected : entry / log catalog
Rejected --> Draft : revert
Closed --> [*]
@enduml