@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
[*] --> Rejected
Rejected --> Approved : approve
Rejected : entry / log review
Approved --> Processing : submit
Processing --> Delivered : process
Delivered --> Cancelled : confirm
Cancelled --> [*]
@enduml