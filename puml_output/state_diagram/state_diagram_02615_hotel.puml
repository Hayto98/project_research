@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
[*] --> Archived
Archived --> Processing : process
Archived : entry / log reservation
Processing --> Shipped : reject
Shipped --> Cancelled : approve
Cancelled --> Completed : confirm
Processing --> Archived : revert
Completed --> [*]
@enduml