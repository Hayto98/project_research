@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
[*] --> Closed
Closed --> Processing : approve
Processing --> Reviewed : cancel
Reviewed --> Created : review
Reviewed : entry / log warehouse
Created --> Cancelled : confirm
Cancelled --> [*]
@enduml