@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
[*] --> Pending
Pending --> Processing : reject
Processing --> Created : reject
Created --> Shipped : review
Shipped --> Active : approve
Active --> Archived : update
Archived --> [*]
@enduml