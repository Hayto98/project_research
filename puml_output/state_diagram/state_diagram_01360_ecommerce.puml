@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
[*] --> Pending
Pending --> Approved : submit
Approved --> Closed : submit
Closed --> Created : review
Created --> Archived : review
Pending --> Created : revert
Archived --> [*]
@enduml