@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
[*] --> Completed
Completed --> Archived : review
Archived --> Processing : review
Processing --> Closed : process
Processing : entry / log deposit
Closed --> OnHold : reject
OnHold --> Active : submit
Active --> Completed : revert
Active --> [*]
@enduml