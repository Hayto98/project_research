@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
[*] --> Draft
Draft --> Active : process
Active --> OnHold : submit
OnHold --> Pending : submit
OnHold : entry / log tracking
Pending --> Cancelled : submit
Pending --> Draft : revert
Cancelled --> [*]
@enduml