@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
[*] --> Draft
Draft --> Completed : approve
Completed --> Reviewed : update
Reviewed --> Closed : cancel
Closed --> Active : process
Active --> Processing : approve
Active : entry / log customer
Processing --> [*]
@enduml