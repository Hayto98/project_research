@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
[*] --> Pending
Pending --> Closed : reject
Closed --> Delivered : cancel
Closed : entry / log book
Delivered --> Draft : process
Delivered : entry / log book
Draft --> Created : approve
Pending --> Draft : revert
Created --> [*]
@enduml