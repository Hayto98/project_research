@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
[*] --> Pending
Pending --> Rejected : update
Rejected --> Closed : confirm
Closed --> Processing : approve
Processing --> Draft : cancel
Processing : entry / log guest
Draft --> [*]
@enduml