@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
[*] --> Delivered
Delivered --> Active : approve
Active --> Completed : approve
Completed --> Created : cancel
Completed : entry / log user
Created --> Draft : review
Draft --> OnHold : approve
Completed --> Active : revert
OnHold --> [*]
@enduml