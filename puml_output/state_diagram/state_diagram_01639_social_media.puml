@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
[*] --> Active
Active --> Closed : update
Closed --> Rejected : update
Rejected --> Shipped : approve
Shipped --> Processing : submit
Processing --> Completed : reject
Processing : entry / log story
Completed --> [*]
@enduml