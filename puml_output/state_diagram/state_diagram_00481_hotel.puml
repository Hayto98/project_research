@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
[*] --> Active
Active --> Approved : confirm
Active : entry / log checkin
Approved --> Draft : cancel
Draft --> Cancelled : reject
Cancelled --> Archived : update
Archived --> OnHold : submit
Archived : entry / log checkin
Active --> OnHold : revert
OnHold --> [*]
@enduml