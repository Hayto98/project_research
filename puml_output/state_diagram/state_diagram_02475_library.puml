@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
[*] --> Processing
Processing --> Rejected : submit
Rejected --> Active : approve
Active --> Closed : update
Closed --> Draft : cancel
Draft --> Approved : confirm
Approved --> [*]
@enduml