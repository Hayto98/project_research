@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
[*] --> Rejected
Rejected --> Created : reject
Created --> Draft : approve
Draft --> Pending : reject
Draft : entry / log return
Pending --> Approved : process
Pending : entry / log return
Approved --> Rejected : revert
Approved --> [*]
@enduml