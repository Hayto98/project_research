@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
[*] --> Completed
Completed --> Rejected : review
Rejected --> Archived : reject
Archived --> Approved : review
Approved --> Active : process
Approved : entry / log route
Active --> Closed : confirm
Completed --> Archived : revert
Closed --> [*]
@enduml