@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
[*] --> OnHold
OnHold --> Active : approve
Active --> Approved : reject
Approved --> Created : process
Created --> Cancelled : approve
Cancelled --> Completed : submit
Completed --> [*]
@enduml