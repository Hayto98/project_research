@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
[*] --> Created
Created --> Cancelled : review
Cancelled --> Completed : confirm
Cancelled : entry / log category
Completed --> Pending : submit
Pending --> Processing : approve
Pending : entry / log category
Processing --> OnHold : process
Processing : entry / log category
OnHold --> [*]
@enduml