@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
[*] --> Closed
Closed --> Delivered : review
Delivered --> Completed : confirm
Delivered : entry / log student
Completed --> Rejected : reject
Rejected --> Cancelled : reject
Cancelled --> Created : approve
Created --> Completed : revert
Created --> [*]
@enduml