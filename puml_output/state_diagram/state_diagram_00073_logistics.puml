@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
[*] --> Closed
Closed --> Shipped : cancel
Shipped --> OnHold : cancel
OnHold --> Cancelled : approve
Cancelled --> Reviewed : update
Reviewed --> Pending : confirm
Shipped --> Closed : revert
Pending --> [*]
@enduml