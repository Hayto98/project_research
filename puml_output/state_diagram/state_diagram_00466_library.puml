@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
[*] --> Shipped
Shipped --> Rejected : cancel
Rejected --> Draft : confirm
Draft --> Closed : cancel
Closed --> Completed : review
Shipped --> Closed : revert
Completed --> [*]
@enduml