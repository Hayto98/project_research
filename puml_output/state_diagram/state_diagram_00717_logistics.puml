@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
[*] --> Closed
Closed --> Processing : update
Processing --> Shipped : submit
Shipped --> Cancelled : submit
Shipped : entry / log warehouse
Cancelled --> Reviewed : approve
Reviewed --> Created : submit
Shipped --> Closed : revert
Created --> [*]
@enduml