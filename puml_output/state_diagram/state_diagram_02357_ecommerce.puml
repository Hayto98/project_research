@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
[*] --> Rejected
Rejected --> Archived : submit
Archived --> Processing : approve
Archived : entry / log wishlist
Processing --> Active : confirm
Active --> Processing : revert
Active --> [*]
@enduml