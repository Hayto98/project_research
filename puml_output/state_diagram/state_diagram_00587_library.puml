@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
[*] --> OnHold
OnHold --> Pending : confirm
Pending --> Closed : reject
Closed --> Delivered : approve
Closed : entry / log librarian
Delivered --> Active : submit
Active --> Shipped : update
Active --> Delivered : revert
Shipped --> [*]
@enduml