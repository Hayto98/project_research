@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
[*] --> Shipped
Shipped --> Pending : confirm
Shipped : entry / log message
Pending --> Rejected : submit
Rejected --> Delivered : confirm
Rejected : entry / log message
Delivered --> Draft : review
Delivered : entry / log message
Draft --> Archived : cancel
Archived --> [*]
@enduml