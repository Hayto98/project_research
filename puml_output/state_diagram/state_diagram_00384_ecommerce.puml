@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
[*] --> Draft
Draft --> Approved : reject
Draft : entry / log category
Approved --> Pending : update
Pending --> Rejected : review
Rejected --> Archived : approve
Archived --> OnHold : process
Archived : entry / log category
OnHold --> Draft : revert
OnHold --> [*]
@enduml