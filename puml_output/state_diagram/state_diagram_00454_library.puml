@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
[*] --> OnHold
OnHold --> Draft : submit
Draft --> Archived : process
Archived --> Processing : submit
Processing --> Active : confirm
Active --> Shipped : confirm
Active : entry / log renewal
Shipped --> Active : revert
Shipped --> [*]
@enduml