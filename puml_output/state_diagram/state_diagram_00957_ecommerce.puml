@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
[*] --> Pending
Pending --> Rejected : approve
Rejected --> Reviewed : cancel
Reviewed --> Shipped : cancel
Shipped --> Created : submit
Reviewed --> Created : revert
Created --> [*]
@enduml