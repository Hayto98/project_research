@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
[*] --> Approved
Approved --> Archived : submit
Approved : entry / log branch
Archived --> Shipped : process
Shipped --> Active : approve
Active --> Delivered : review
Delivered --> Rejected : process
Shipped --> Active : revert
Rejected --> [*]
@enduml