@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
[*] --> Approved
Approved --> Reviewed : approve
Reviewed --> Closed : confirm
Closed --> Delivered : reject
Delivered --> OnHold : confirm
OnHold --> Completed : confirm
OnHold : entry / log package
OnHold --> Closed : revert
Completed --> [*]
@enduml