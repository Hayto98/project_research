@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
[*] --> Pending
Pending --> Created : cancel
Created --> Closed : review
Closed --> Processing : review
Closed : entry / log like
Processing --> Completed : process
Completed --> Delivered : cancel
Delivered --> [*]
@enduml