@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
[*] --> Shipped
Shipped --> Approved : cancel
Approved --> Draft : review
Draft --> Closed : update
Closed --> Reviewed : approve
Approved --> Draft : revert
Reviewed --> [*]
@enduml