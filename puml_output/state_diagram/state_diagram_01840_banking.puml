@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
[*] --> Reviewed
Reviewed --> Draft : confirm
Reviewed : entry / log transfer
Draft --> Cancelled : confirm
Cancelled --> Processing : submit
Processing --> Reviewed : revert
Processing --> [*]
