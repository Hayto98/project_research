@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
[*] --> Approved
Approved --> Closed : update
Closed --> Processing : submit
Processing --> OnHold : confirm
OnHold --> Created : submit
OnHold : entry / log manifest
Created --> Approved : revert
Created --> [*]
@enduml