@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
[*] --> Reviewed
Reviewed --> Delivered : review
Delivered --> Active : submit
Active --> Draft : update
Draft --> Created : submit
Created --> Cancelled : update
Created : entry / log inventory
Reviewed --> Cancelled : revert
Cancelled --> [*]
@enduml