@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
[*] --> Pending
Pending --> OnHold : submit
Pending : entry / log report
OnHold --> Closed : confirm
Closed --> Created : cancel
Created --> Reviewed : approve
Reviewed --> Processing : submit
Reviewed : entry / log report
Processing --> [*]
@enduml