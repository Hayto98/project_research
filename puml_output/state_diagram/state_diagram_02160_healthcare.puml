@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
[*] --> Pending
Pending --> Cancelled : approve
Cancelled --> Delivered : confirm
Delivered --> Processing : approve
Processing --> Closed : update
Processing : entry / log medicalrecord
Closed --> Rejected : reject
Processing --> Cancelled : revert
Rejected --> [*]
@enduml