@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
[*] --> Archived
Archived --> Draft : confirm
Draft --> Reviewed : reject
Reviewed --> Cancelled : review
Cancelled --> OnHold : cancel
Cancelled : entry / log guest
OnHold --> [*]
@enduml