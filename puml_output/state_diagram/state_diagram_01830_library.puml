@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
[*] --> OnHold
OnHold --> Rejected : cancel
Rejected --> Delivered : review
Delivered --> Processing : review
Processing --> Completed : approve
Processing : entry / log branch
Completed --> [*]
@enduml