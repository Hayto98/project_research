@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
[*] --> Pending
Pending --> Cancelled : review
Pending : entry / log treatment
Cancelled --> Reviewed : submit
Reviewed --> Archived : reject
Archived --> Draft : submit
Draft --> [*]
@enduml