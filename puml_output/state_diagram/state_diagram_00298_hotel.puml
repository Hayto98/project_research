@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
[*] --> OnHold
OnHold --> Processing : submit
Processing --> Draft : review
Draft --> Reviewed : reject
Reviewed --> Created : reject
Created --> Cancelled : approve
Reviewed --> Cancelled : revert
Cancelled --> [*]
@enduml