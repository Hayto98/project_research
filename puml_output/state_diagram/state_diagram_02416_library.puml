@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
[*] --> Pending
Pending --> Active : submit
Active --> OnHold : cancel
OnHold --> Reviewed : submit
Reviewed --> Closed : submit
Reviewed : entry / log member
Closed --> Rejected : confirm
Rejected --> [*]
@enduml