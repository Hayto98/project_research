@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
[*] --> Reviewed
Reviewed --> OnHold : approve
OnHold --> Processing : cancel
Processing --> Rejected : reject
Rejected --> Archived : approve
Processing --> Rejected : revert
Archived --> [*]
@enduml