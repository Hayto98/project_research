@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
[*] --> Shipped
Shipped --> Reviewed : review
Reviewed --> Completed : submit
Completed --> Closed : approve
Closed --> Draft : cancel
Completed --> Reviewed : revert
Draft --> [*]
@enduml