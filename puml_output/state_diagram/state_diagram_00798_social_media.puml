@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
[*] --> Shipped
Shipped --> OnHold : update
OnHold --> Archived : submit
Archived --> Pending : cancel
Pending --> Created : submit
Pending : entry / log message
Created --> Shipped : revert
Created --> [*]
@enduml