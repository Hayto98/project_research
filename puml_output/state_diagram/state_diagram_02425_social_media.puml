@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
[*] --> Shipped
Shipped --> Rejected : cancel
Rejected --> Processing : submit
Rejected : entry / log notification
Processing --> Draft : approve
Draft --> Created : approve
Created --> Shipped : revert
Created --> [*]
@enduml