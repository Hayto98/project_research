@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
[*] --> Shipped
Shipped --> Pending : approve
Shipped : entry / log department
Pending --> OnHold : update
OnHold --> Draft : submit
OnHold : entry / log department
Draft --> Approved : cancel
Draft : entry / log department
Approved --> Delivered : cancel
Approved : entry / log department
Pending --> Delivered : revert
Delivered --> [*]
@enduml