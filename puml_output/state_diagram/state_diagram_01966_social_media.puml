@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
[*] --> Active
Active --> Processing : process
Processing --> Created : submit
Created --> Completed : cancel
Created : entry / log comment
Completed --> Approved : process
Approved --> Closed : review
Closed --> [*]
@enduml