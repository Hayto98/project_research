@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
[*] --> Cancelled
Cancelled --> Processing : update
Processing --> Pending : cancel
Pending --> Rejected : submit
Rejected --> Delivered : confirm
Delivered --> Shipped : reject
Shipped --> [*]
@enduml