@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
[*] --> Cancelled
Cancelled --> Draft : update
Draft --> Completed : submit
Completed --> Pending : reject
Pending --> Reviewed : confirm
Reviewed --> Created : submit
Reviewed : entry / log student
Completed --> Draft : revert
Created --> [*]
@enduml