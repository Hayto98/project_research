@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
[*] --> Draft
Draft --> Reviewed : confirm
Reviewed --> Processing : process
Reviewed : entry / log publisher
Processing --> Created : confirm
Processing --> Draft : revert
Created --> [*]
@enduml