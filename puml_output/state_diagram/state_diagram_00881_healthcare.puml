@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
[*] --> Draft
Draft --> Processing : submit
Draft : entry / log insurance
Processing --> Approved : submit
Approved --> Closed : reject
Closed --> Active : submit
Active --> Reviewed : approve
Draft --> Reviewed : revert
Reviewed --> [*]
@enduml