@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
[*] --> Cancelled
Cancelled --> Reviewed : reject
Reviewed --> Pending : process
Reviewed : entry / log cart
Pending --> Approved : cancel
Approved --> Rejected : process
Approved : entry / log cart
Cancelled --> Reviewed : revert
Rejected --> [*]
@enduml