@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
[*] --> OnHold
OnHold --> Rejected : reject
Rejected --> Reviewed : cancel
Reviewed --> Completed : confirm
Reviewed : entry / log treatment
Completed --> Shipped : reject
Shipped --> Created : update
Created --> [*]
@enduml