@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
[*] --> Approved
Approved --> Cancelled : review
Cancelled --> Archived : update
Archived --> Created : confirm
Archived : entry / log inventory
Created --> Reviewed : process
Reviewed --> Closed : review
Reviewed --> Approved : revert
Closed --> [*]
@enduml