@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
[*] --> Rejected
Rejected --> Cancelled : approve
Cancelled --> Reviewed : confirm
Cancelled : entry / log post
Reviewed --> Processing : confirm
Processing --> Approved : submit
Approved --> Created : approve
Created --> Cancelled : revert
Created --> [*]
@enduml