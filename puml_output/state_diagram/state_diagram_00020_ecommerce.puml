@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
[*] --> Draft
Draft --> Completed : reject
Completed --> Shipped : process
Shipped --> Rejected : approve
Rejected --> Archived : submit
Rejected : entry / log category
Archived --> OnHold : reject
OnHold --> [*]
@enduml