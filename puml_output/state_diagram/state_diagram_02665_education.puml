@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
[*] --> Processing
Processing --> Created : process
Created --> Completed : update
Created : entry / log grade
Completed --> Active : cancel
Active --> Rejected : reject
Rejected --> [*]
@enduml