@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
[*] --> Created
Created --> Delivered : cancel
Created : entry / log reservation
Delivered --> Rejected : update
Rejected --> Pending : confirm
Delivered --> Pending : revert
Pending --> [*]
@enduml