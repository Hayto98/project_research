@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
[*] --> Processing
Processing --> Pending : confirm
Pending --> Reviewed : cancel
Reviewed --> Rejected : review
Rejected --> Completed : process
Completed --> [*]
@enduml