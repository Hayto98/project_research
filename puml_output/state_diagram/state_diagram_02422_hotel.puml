@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
[*] --> Rejected
Rejected --> Pending : submit
Pending --> Cancelled : confirm
Cancelled --> Archived : submit
Archived --> Shipped : update
Archived : entry / log checkout
Archived --> Rejected : revert
Shipped --> [*]
@enduml