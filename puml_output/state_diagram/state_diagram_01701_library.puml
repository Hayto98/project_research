@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
[*] --> Cancelled
Cancelled --> Shipped : confirm
Shipped --> OnHold : process
OnHold --> Completed : submit
OnHold : entry / log renewal
Completed --> Closed : cancel
Closed --> Reviewed : cancel
Reviewed --> [*]
@enduml