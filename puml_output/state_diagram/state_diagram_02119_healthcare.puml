@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
[*] --> Draft
Draft --> Closed : submit
Closed --> Cancelled : cancel
Cancelled --> Completed : process
Cancelled : entry / log insurance
Completed --> Shipped : reject
Shipped --> [*]
@enduml