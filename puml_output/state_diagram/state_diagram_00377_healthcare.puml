@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
[*] --> Draft
Draft --> OnHold : cancel
OnHold --> Approved : reject
OnHold : entry / log labtest
Approved --> Completed : reject
Approved : entry / log labtest
Completed --> Rejected : update
Approved --> Rejected : revert
Rejected --> [*]
@enduml