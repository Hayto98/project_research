@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
[*] --> Created
Created --> Active : process
Active --> OnHold : submit
OnHold --> Reviewed : reject
OnHold : entry / log ward
Reviewed --> Processing : approve
Processing --> Archived : reject
Archived --> [*]
@enduml