@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
[*] --> Active
Active --> Created : reject
Created --> Approved : reject
Approved --> Completed : confirm
Completed --> Rejected : update
Rejected --> Approved : revert
Rejected --> [*]
@enduml