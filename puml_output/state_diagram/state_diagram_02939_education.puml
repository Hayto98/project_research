@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
[*] --> Rejected
Rejected --> Draft : review
Draft --> Created : submit
Draft : entry / log book
Created --> Pending : confirm
Pending --> Cancelled : review
Cancelled --> Closed : cancel
Pending --> Cancelled : revert
Closed --> [*]
@enduml