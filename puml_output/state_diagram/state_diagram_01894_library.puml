@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
[*] --> Delivered
Delivered --> Active : update
Active --> Draft : review
Draft --> Created : cancel
Created --> Rejected : approve
Rejected --> Processing : process
Rejected : entry / log branch
Active --> Delivered : revert
Processing --> [*]
@enduml