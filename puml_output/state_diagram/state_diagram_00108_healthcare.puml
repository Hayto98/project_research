@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
[*] --> Delivered
Delivered --> OnHold : review
OnHold --> Approved : review
OnHold : entry / log labtest
Approved --> Archived : reject
Archived --> Closed : reject
Approved --> OnHold : revert
Closed --> [*]
@enduml