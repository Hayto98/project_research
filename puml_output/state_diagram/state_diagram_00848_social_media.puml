@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
[*] --> Reviewed
Reviewed --> Created : submit
Reviewed : entry / log story
Created --> Rejected : reject
Rejected --> Shipped : update
Shipped --> Draft : update
Draft --> Approved : review
Draft : entry / log story
Rejected --> Reviewed : revert
Approved --> [*]
@enduml