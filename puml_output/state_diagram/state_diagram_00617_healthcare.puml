@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
[*] --> Closed
Closed --> Delivered : update
Delivered --> Archived : cancel
Archived --> Cancelled : approve
Cancelled --> Created : reject
Created --> Pending : review
Pending --> [*]
@enduml