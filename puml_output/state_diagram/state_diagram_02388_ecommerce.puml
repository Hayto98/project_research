@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
[*] --> Cancelled
Cancelled --> Archived : review
Archived --> Completed : reject
Completed --> Active : approve
Active --> Draft : reject
Draft --> Shipped : cancel
Cancelled --> Draft : revert
Shipped --> [*]
@enduml