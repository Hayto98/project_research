@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
[*] --> Completed
Completed --> Pending : cancel
Pending --> Rejected : cancel
Rejected --> Delivered : process
Delivered --> Draft : reject
Delivered : entry / log exam
Draft --> Completed : revert
Draft --> [*]
@enduml