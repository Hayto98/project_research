@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
[*] --> Cancelled
Cancelled --> Closed : submit
Cancelled : entry / log treatment
Closed --> OnHold : reject
OnHold --> Archived : review
Archived --> Reviewed : process
Closed --> Reviewed : revert
Reviewed --> [*]
@enduml