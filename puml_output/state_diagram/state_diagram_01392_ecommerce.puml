@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
[*] --> Created
Created --> Active : submit
Active --> Reviewed : review
Reviewed --> Delivered : review
Reviewed : entry / log invoice
Delivered --> Draft : review
Draft --> Closed : submit
Closed --> Created : revert
Closed --> [*]
@enduml