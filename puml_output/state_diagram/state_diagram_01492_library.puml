@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
[*] --> Reviewed
Reviewed --> Created : cancel
Created --> Draft : review
Draft --> Rejected : submit
Draft : entry / log fine
Rejected --> Pending : confirm
Pending --> Shipped : review
Shipped --> [*]
@enduml