@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
[*] --> Rejected
Rejected --> Active : update
Active --> Draft : reject
Draft --> OnHold : update
OnHold --> Delivered : update
Active --> Rejected : revert
Delivered --> [*]
@enduml