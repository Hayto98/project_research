@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
[*] --> Completed
Completed --> Archived : process
Completed : entry / log notification
Archived --> Pending : approve
Archived : entry / log notification
Pending --> Delivered : update
Delivered --> Cancelled : confirm
Delivered : entry / log notification
Cancelled --> Reviewed : submit
Cancelled --> Delivered : revert
Reviewed --> [*]
@enduml