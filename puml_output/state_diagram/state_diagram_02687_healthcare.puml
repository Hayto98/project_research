@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
[*] --> Closed
Closed --> Rejected : reject
Rejected --> Created : review
Created --> Shipped : process
Shipped --> Reviewed : cancel
Reviewed --> Completed : reject
Closed --> Completed : revert
Completed --> [*]
@enduml