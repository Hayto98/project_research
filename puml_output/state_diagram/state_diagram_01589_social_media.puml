@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
[*] --> Archived
Archived --> Active : confirm
Active --> Approved : approve
Approved --> Created : reject
Created --> Rejected : update
Rejected --> Cancelled : review
Cancelled --> [*]
@enduml