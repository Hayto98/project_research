@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
[*] --> Rejected
Rejected --> OnHold : review
Rejected : entry / log album
OnHold --> Created : cancel
Created --> Delivered : approve
Delivered --> Active : confirm
Created --> Active : revert
Active --> [*]
@enduml