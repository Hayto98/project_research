@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
[*] --> Processing
Processing --> Closed : cancel
Closed --> Archived : confirm
Archived --> Reviewed : approve
Reviewed --> Completed : submit
Reviewed : entry / log fuellog
Completed --> Shipped : update
Archived --> Processing : revert
Shipped --> [*]
@enduml