@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
[*] --> Pending
Pending --> Closed : update
Closed --> Approved : update
Approved --> Reviewed : submit
Reviewed --> Shipped : confirm
Reviewed : entry / log member
Shipped --> [*]
@enduml