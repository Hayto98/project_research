@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
[*] --> Reviewed
Reviewed --> Rejected : update
Reviewed : entry / log transaction
Rejected --> Pending : cancel
Pending --> Draft : approve
Draft --> Completed : submit
Draft --> Reviewed : revert
Completed --> [*]
@enduml