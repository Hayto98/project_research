@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
[*] --> Rejected
Rejected --> Completed : submit
Completed --> Processing : process
Processing --> Delivered : process
Processing : entry / log invoice
Delivered --> Shipped : process
Shipped --> Rejected : revert
Shipped --> [*]
@enduml