@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
[*] --> Cancelled
Cancelled --> Rejected : reject
Rejected --> Draft : approve
Draft --> Reviewed : confirm
Reviewed --> Closed : submit
Closed --> Approved : process
Closed : entry / log payment
Cancelled --> Approved : revert
Approved --> [*]
@enduml