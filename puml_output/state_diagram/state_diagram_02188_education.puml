@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
[*] --> Reviewed
Reviewed --> Rejected : submit
Rejected --> Processing : approve
Processing --> Pending : review
Pending --> OnHold : confirm
Rejected --> OnHold : revert
OnHold --> [*]
@enduml