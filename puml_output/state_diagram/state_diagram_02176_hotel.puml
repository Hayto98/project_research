@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
[*] --> Reviewed
Reviewed --> Active : submit
Active --> Archived : submit
Archived --> Draft : approve
Archived : entry / log booking
Draft --> Delivered : reject
Delivered --> OnHold : approve
Active --> Reviewed : revert
OnHold --> [*]
@enduml