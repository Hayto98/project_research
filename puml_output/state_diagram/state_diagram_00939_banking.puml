@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
[*] --> Completed
Completed --> Shipped : review
Shipped --> Created : update
Created --> OnHold : confirm
OnHold --> Reviewed : confirm
Reviewed --> Cancelled : reject
Shipped --> Reviewed : revert
Cancelled --> [*]
@enduml