@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
[*] --> Completed
Completed --> Shipped : reject
Shipped --> Cancelled : cancel
Cancelled --> Approved : submit
Approved --> Pending : submit
Cancelled --> Approved : revert
Pending --> [*]
@enduml