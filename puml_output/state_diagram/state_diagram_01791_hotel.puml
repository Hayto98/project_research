@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
[*] --> Rejected
Rejected --> Draft : cancel
Draft --> Processing : process
Processing --> Closed : reject
Closed --> Delivered : review
Delivered --> Shipped : update
Draft --> Delivered : revert
Shipped --> [*]
@enduml