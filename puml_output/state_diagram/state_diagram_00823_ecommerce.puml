@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
[*] --> Cancelled
Cancelled --> Draft : cancel
Draft --> Processing : review
Draft : entry / log supplier
Processing --> Completed : review
Completed --> Active : process
Active --> Closed : submit
Closed --> [*]
@enduml