@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
[*] --> Draft
Draft --> Rejected : update
Rejected --> Approved : cancel
Rejected : entry / log account
Approved --> Delivered : approve
Approved --> Draft : revert
Delivered --> [*]
@enduml