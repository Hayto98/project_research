@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
[*] --> Reviewed
Reviewed --> Delivered : approve
Reviewed : entry / log depot
Delivered --> Pending : update
Pending --> Completed : reject
Completed --> Rejected : confirm
Reviewed --> Rejected : revert
Rejected --> [*]
@enduml