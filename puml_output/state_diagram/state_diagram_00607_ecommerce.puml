@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
[*] --> Delivered
Delivered --> Reviewed : reject
Reviewed --> Closed : submit
Closed --> Approved : submit
Approved --> Shipped : confirm
Delivered --> Reviewed : revert
Shipped --> [*]
@enduml