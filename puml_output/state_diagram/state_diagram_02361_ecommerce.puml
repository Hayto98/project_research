@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
[*] --> Approved
Approved --> Archived : confirm
Archived --> Reviewed : cancel
Reviewed --> Delivered : reject
Delivered --> Rejected : approve
Rejected --> Pending : submit
Pending --> [*]
@enduml