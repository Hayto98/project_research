@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
[*] --> Completed
Completed --> Delivered : submit
Delivered --> Shipped : update
Shipped --> Draft : reject
Shipped : entry / log report
Completed --> Delivered : revert
Draft --> [*]
@enduml