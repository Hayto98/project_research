@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
[*] --> Processing
Processing --> Approved : update
Approved --> Pending : process
Approved : entry / log attendance
Pending --> Delivered : submit
Delivered --> Closed : cancel
Closed --> Active : review
Active --> Pending : revert
Active --> [*]
@enduml