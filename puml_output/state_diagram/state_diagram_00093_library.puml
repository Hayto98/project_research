@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
[*] --> Active
Active --> Approved : submit
Approved --> Processing : submit
Processing --> Rejected : cancel
Rejected --> Reviewed : process
Reviewed --> Closed : confirm
Closed --> [*]
@enduml