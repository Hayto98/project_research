@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
[*] --> Closed
Closed --> Delivered : update
Delivered --> Shipped : confirm
Shipped --> Pending : process
Pending --> Created : cancel
Pending --> Closed : revert
Created --> [*]
@enduml