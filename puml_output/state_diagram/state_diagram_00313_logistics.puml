@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
[*] --> Created
Created --> Draft : approve
Draft --> Approved : submit
Approved --> Rejected : cancel
Rejected --> Delivered : review
Rejected --> Draft : revert
Delivered --> [*]
@enduml