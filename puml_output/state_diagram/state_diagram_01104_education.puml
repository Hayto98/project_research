@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
[*] --> Reviewed
Reviewed --> Cancelled : cancel
Cancelled --> Completed : cancel
Completed --> Pending : submit
Reviewed --> Pending : revert
Pending --> [*]
@enduml