@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
[*] --> OnHold
OnHold --> Approved : review
Approved --> Rejected : submit
Rejected --> Delivered : confirm
Rejected : entry / log manifest
Delivered --> Archived : submit
Delivered : entry / log manifest
Archived --> Completed : process
Completed --> [*]
@enduml