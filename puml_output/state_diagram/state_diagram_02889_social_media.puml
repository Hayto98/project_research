@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
[*] --> Shipped
Shipped --> Cancelled : approve
Cancelled --> OnHold : reject
OnHold --> Delivered : confirm
Delivered --> Rejected : reject
Cancelled --> Rejected : revert
Rejected --> [*]
@enduml