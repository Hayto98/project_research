@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
[*] --> Rejected
Rejected --> Created : update
Created --> Draft : process
Draft --> Pending : cancel
Draft : entry / log invoice
Pending --> Cancelled : approve
Cancelled --> Approved : approve
Approved --> [*]
@enduml