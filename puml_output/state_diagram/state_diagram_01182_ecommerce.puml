@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
[*] --> Created
Created --> Completed : reject
Created : entry / log payment
Completed --> Pending : confirm
Pending --> Reviewed : submit
Reviewed --> Delivered : reject
Delivered --> Draft : cancel
Draft --> [*]
@enduml