@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
[*] --> Active
Active --> Rejected : process
Rejected --> Shipped : process
Shipped --> OnHold : confirm
OnHold --> Pending : reject
OnHold : entry / log review
Active --> Rejected : revert
Pending --> [*]
@enduml