@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
[*] --> Reviewed
Reviewed --> Rejected : approve
Rejected --> Active : review
Active --> Cancelled : confirm
Cancelled --> Approved : update
Approved --> Pending : cancel
Approved : entry / log hashtag
Rejected --> Approved : revert
Pending --> [*]
@enduml