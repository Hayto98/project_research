@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
[*] --> Cancelled
Cancelled --> Active : reject
Active --> Archived : reject
Archived --> Closed : approve
Archived : entry / log labtest
Closed --> OnHold : confirm
OnHold --> Delivered : review
Cancelled --> Archived : revert
Delivered --> [*]
@enduml