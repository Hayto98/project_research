@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
[*] --> Reviewed
Reviewed --> Active : cancel
Active --> Shipped : approve
Shipped --> Pending : reject
Pending --> Rejected : process
Reviewed --> Pending : revert
Rejected --> [*]
@enduml