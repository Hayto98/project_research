@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
[*] --> Archived
Archived --> Completed : cancel
Completed --> Processing : cancel
Processing --> Shipped : review
Shipped --> Reviewed : submit
Reviewed --> Shipped : revert
Reviewed --> [*]
