@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
[*] --> Created
Created --> Draft : confirm
Draft --> Closed : submit
Closed --> Processing : reject
Closed : entry / log follower
Processing --> OnHold : process
Processing : entry / log follower
OnHold --> [*]
@enduml