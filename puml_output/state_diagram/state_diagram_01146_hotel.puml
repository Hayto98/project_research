@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
[*] --> Closed
Closed --> Processing : reject
Processing --> Reviewed : submit
Reviewed --> Archived : cancel
Reviewed : entry / log restaurant
Archived --> Completed : cancel
Reviewed --> Completed : revert
Completed --> [*]
@enduml