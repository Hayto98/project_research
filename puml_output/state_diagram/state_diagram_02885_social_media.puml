@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
[*] --> Shipped
Shipped --> Draft : cancel
Draft --> Created : confirm
Created --> Processing : confirm
Created : entry / log like
Processing --> Approved : submit
Approved --> Processing : revert
Approved --> [*]
@enduml