@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
[*] --> Active
Active --> Shipped : update
Shipped --> Closed : confirm
Closed --> OnHold : confirm
OnHold --> Draft : cancel
OnHold --> Shipped : revert
Draft --> [*]
@enduml