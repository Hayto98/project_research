@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
[*] --> Rejected
Rejected --> OnHold : confirm
OnHold --> Active : approve
Active --> Shipped : review
Shipped --> Closed : reject
Closed --> Pending : submit
Pending --> Shipped : revert
Pending --> [*]
@enduml