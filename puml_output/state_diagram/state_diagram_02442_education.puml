@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
[*] --> Approved
Approved --> OnHold : review
Approved : entry / log grade
OnHold --> Archived : submit
Archived --> Cancelled : review
Cancelled --> Delivered : submit
Approved --> Delivered : revert
Delivered --> [*]
@enduml