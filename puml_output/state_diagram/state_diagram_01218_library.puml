@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
[*] --> Created
Created --> Reviewed : cancel
Created : entry / log member
Reviewed --> Cancelled : reject
Cancelled --> Archived : cancel
Created --> Cancelled : revert
Archived --> [*]
@enduml