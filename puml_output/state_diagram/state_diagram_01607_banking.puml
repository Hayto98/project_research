@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
[*] --> Delivered
Delivered --> Pending : submit
Pending --> Completed : update
Completed --> Reviewed : reject
Reviewed --> Active : submit
Active --> OnHold : cancel
Delivered --> Active : revert
OnHold --> [*]
@enduml