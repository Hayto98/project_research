@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
[*] --> Reviewed
Reviewed --> Draft : update
Draft --> Archived : review
Draft : entry / log beneficiary
Archived --> Processing : cancel
Processing --> Pending : confirm
Pending --> OnHold : reject
Reviewed --> Draft : revert
OnHold --> [*]
@enduml