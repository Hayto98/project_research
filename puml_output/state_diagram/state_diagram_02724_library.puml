@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
[*] --> Delivered
Delivered --> OnHold : review
OnHold --> Reviewed : approve
OnHold : entry / log shelf
Reviewed --> Cancelled : cancel
Cancelled --> Draft : process
Cancelled : entry / log shelf
Draft --> Processing : cancel
Processing --> [*]
@enduml