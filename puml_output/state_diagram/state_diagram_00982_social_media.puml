@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
[*] --> Draft
Draft --> Processing : cancel
Processing --> Rejected : review
Rejected --> Completed : review
Completed --> Approved : submit
Completed --> Approved : revert
Approved --> [*]
@enduml