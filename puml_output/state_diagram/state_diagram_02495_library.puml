@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
[*] --> Reviewed
Reviewed --> Pending : submit
Pending --> Archived : process
Archived --> Processing : approve
Processing --> Active : reject
Active --> Rejected : submit
Active : entry / log shelf
Reviewed --> Active : revert
Rejected --> [*]
@enduml