@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
[*] --> Active
Active --> Completed : process
Completed --> Cancelled : confirm
Cancelled --> OnHold : cancel
OnHold --> Reviewed : confirm
Reviewed --> Pending : confirm
OnHold --> Pending : revert
Pending --> [*]
@enduml