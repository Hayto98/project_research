@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
[*] --> Approved
Approved --> Draft : reject
Draft --> Closed : process
Closed --> Reviewed : confirm
Reviewed --> Pending : reject
Pending --> Active : review
Pending : entry / log guest
Closed --> Active : revert
Active --> [*]
@enduml