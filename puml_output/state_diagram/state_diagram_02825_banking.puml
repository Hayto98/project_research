@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
[*] --> Active
Active --> Draft : approve
Active : entry / log transfer
Draft --> Rejected : submit
Rejected --> Pending : confirm
Pending --> Created : process
Created --> Completed : cancel
Created --> Pending : revert
Completed --> [*]
@enduml