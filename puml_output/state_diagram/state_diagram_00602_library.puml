@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
[*] --> OnHold
OnHold --> Pending : approve
Pending --> Reviewed : process
Reviewed --> Active : review
Reviewed : entry / log author
Active --> Processing : confirm
Processing --> Cancelled : process
Cancelled --> [*]
@enduml