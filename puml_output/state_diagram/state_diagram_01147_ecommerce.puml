@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
[*] --> Completed
Completed --> Draft : approve
Draft --> Processing : reject
Draft : entry / log shipment
Processing --> Pending : update
Draft --> Completed : revert
Pending --> [*]
@enduml