@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
[*] --> Cancelled
Cancelled --> Approved : submit
Approved --> OnHold : process
Approved : entry / log route
OnHold --> Active : submit
Active --> Created : cancel
Created --> OnHold : revert
Created --> [*]
@enduml