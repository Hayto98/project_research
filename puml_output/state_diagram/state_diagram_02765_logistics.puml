@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
[*] --> Approved
Approved --> OnHold : confirm
OnHold --> Closed : submit
Closed --> Pending : reject
Pending --> Cancelled : cancel
Cancelled --> Archived : reject
Archived --> [*]
@enduml