@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
[*] --> Pending
Pending --> Closed : submit
Closed --> Archived : process
Archived --> Rejected : approve
Rejected --> Cancelled : review
Rejected : entry / log customer
Cancelled --> Draft : approve
Draft --> [*]
@enduml