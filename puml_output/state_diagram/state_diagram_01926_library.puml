@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
[*] --> Reviewed
Reviewed --> Cancelled : review
Cancelled --> Approved : process
Approved --> Draft : cancel
Approved : entry / log loan
Draft --> Pending : confirm
Pending --> [*]
@enduml