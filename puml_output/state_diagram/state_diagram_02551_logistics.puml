@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
[*] --> Delivered
Delivered --> Approved : confirm
Approved --> Cancelled : approve
Cancelled --> Reviewed : process
Reviewed --> Active : reject
Active --> Closed : submit
Closed --> [*]
@enduml