@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
[*] --> Closed
Closed --> Approved : update
Approved --> Completed : review
Completed --> Pending : process
Pending --> Reviewed : review
Pending : entry / log librarian
Reviewed --> Draft : submit
Completed --> Reviewed : revert
Draft --> [*]
@enduml