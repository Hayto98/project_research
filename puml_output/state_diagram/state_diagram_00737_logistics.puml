@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
[*] --> Reviewed
Reviewed --> Pending : update
Pending --> Created : process
Created --> Delivered : reject
Delivered --> Completed : confirm
Completed --> Closed : reject
Completed : entry / log fuellog
Delivered --> Closed : revert
Closed --> [*]
@enduml