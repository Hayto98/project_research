@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
[*] --> Archived
Archived --> Approved : submit
Approved --> Shipped : submit
Shipped --> Processing : approve
Shipped : entry / log billing
Processing --> Rejected : process
Rejected --> Created : cancel
Created --> Processing : revert
Created --> [*]
@enduml