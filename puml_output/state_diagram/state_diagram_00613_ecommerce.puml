@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
[*] --> Completed
Completed --> Pending : reject
Pending --> Shipped : process
Shipped --> Rejected : cancel
Shipped : entry / log supplier
Rejected --> Archived : reject
Archived --> Created : submit
Rejected --> Shipped : revert
Created --> [*]
@enduml