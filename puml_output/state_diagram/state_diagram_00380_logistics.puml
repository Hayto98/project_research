@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
[*] --> Shipped
Shipped --> Completed : cancel
Shipped : entry / log depot
Completed --> OnHold : review
OnHold --> Rejected : review
Rejected --> Processing : submit
Processing --> Closed : approve
Closed --> [*]
@enduml