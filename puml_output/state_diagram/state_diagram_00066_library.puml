@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
[*] --> Draft
Draft --> Created : approve
Draft : entry / log branch
Created --> Processing : process
Processing --> Completed : update
Completed --> Rejected : review
Completed : entry / log branch
Rejected --> Reviewed : update
Rejected : entry / log branch
Reviewed --> [*]
@enduml