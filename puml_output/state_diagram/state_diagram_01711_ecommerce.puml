@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
[*] --> Draft
Draft --> Closed : review
Closed --> Rejected : review
Rejected --> Approved : process
Approved --> Completed : submit
Completed --> Cancelled : submit
Cancelled --> [*]
@enduml