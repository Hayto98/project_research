@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
[*] --> Created
Created --> Closed : reject
Created : entry / log shipment
Closed --> Reviewed : process
Reviewed --> Completed : update
Completed --> Active : reject
Active --> [*]
@enduml