@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
[*] --> Closed
Closed --> Created : update
Created --> Cancelled : confirm
Cancelled --> Processing : process
Cancelled : entry / log ward
Processing --> Rejected : process
Rejected --> Reviewed : process
Reviewed --> [*]
@enduml