@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
[*] --> Reviewed
Reviewed --> Active : confirm
Active --> Approved : approve
Active : entry / log attendance
Approved --> Rejected : cancel
Rejected --> Archived : reject
Archived --> [*]
@enduml