@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
[*] --> Delivered
Delivered --> Created : approve
Created --> Rejected : update
Rejected --> Processing : review
Processing --> Active : cancel
Active --> Pending : submit
Rejected --> Processing : revert
Pending --> [*]
@enduml