@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
[*] --> Completed
Completed --> Approved : review
Approved --> Rejected : update
Rejected --> Cancelled : cancel
Cancelled --> Processing : reject
Processing --> Pending : cancel
Rejected --> Cancelled : revert
Pending --> [*]
@enduml