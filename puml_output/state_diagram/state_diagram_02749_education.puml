@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
[*] --> Created
Created --> OnHold : reject
OnHold --> Delivered : process
OnHold : entry / log grade
Delivered --> Processing : submit
Delivered --> Created : revert
Processing --> [*]
@enduml