@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
[*] --> Rejected
Rejected --> Closed : cancel
Closed --> Delivered : submit
Closed : entry / log student
Delivered --> Processing : approve
Processing --> Archived : process
Processing : entry / log student
Processing --> Rejected : revert
Archived --> [*]
@enduml