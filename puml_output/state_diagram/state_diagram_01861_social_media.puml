@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
[*] --> Reviewed
Reviewed --> OnHold : review
OnHold --> Cancelled : cancel
OnHold : entry / log post
Cancelled --> Rejected : confirm
Rejected --> Processing : approve
Processing --> Approved : review
Processing : entry / log post
Approved --> [*]
@enduml