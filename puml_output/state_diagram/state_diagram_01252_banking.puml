@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
[*] --> Shipped
Shipped --> Pending : cancel
Pending --> Closed : submit
Closed --> Active : approve
Active --> Created : review
Created --> Completed : update
Closed --> Completed : revert
Completed --> [*]
@enduml