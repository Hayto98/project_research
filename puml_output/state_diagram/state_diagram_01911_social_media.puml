@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
[*] --> Completed
Completed --> Processing : approve
Processing --> Delivered : approve
Delivered --> Pending : submit
Pending --> Shipped : process
Shipped --> Rejected : update
Shipped --> Processing : revert
Rejected --> [*]
@enduml