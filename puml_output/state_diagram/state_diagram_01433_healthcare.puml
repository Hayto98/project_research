@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
[*] --> Draft
Draft --> Cancelled : cancel
Cancelled --> Rejected : cancel
Rejected --> Reviewed : process
Reviewed --> Completed : process
Completed --> Created : review
Created --> [*]
@enduml