@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
[*] --> Processing
Processing --> Active : submit
Active --> Draft : approve
Draft --> Delivered : review
Delivered --> Created : review
Delivered : entry / log attendance
Created --> Archived : reject
Created : entry / log attendance
Archived --> Active : revert
Archived --> [*]
@enduml