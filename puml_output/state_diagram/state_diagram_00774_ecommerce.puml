@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
[*] --> Shipped
Shipped --> Reviewed : approve
Reviewed --> Draft : confirm
Reviewed : entry / log wishlist
Draft --> OnHold : confirm
OnHold --> Approved : update
Approved --> Rejected : process
Approved : entry / log wishlist
Rejected --> [*]
@enduml