@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
[*] --> Pending
Pending --> Approved : reject
Approved --> Draft : review
Draft --> Active : confirm
Draft : entry / log driver
Active --> Archived : process
Archived --> Shipped : review
Shipped --> [*]
@enduml