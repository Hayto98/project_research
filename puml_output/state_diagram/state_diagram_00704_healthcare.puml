@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
[*] --> Completed
Completed --> Reviewed : confirm
Completed : entry / log appointment
Reviewed --> Rejected : cancel
Rejected --> Delivered : submit
Delivered --> Cancelled : approve
Cancelled --> [*]
@enduml