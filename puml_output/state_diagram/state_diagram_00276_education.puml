@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
[*] --> Closed
Closed --> Reviewed : confirm
Reviewed --> Active : review
Active --> Delivered : approve
Delivered --> Cancelled : reject
Cancelled --> Archived : submit
Reviewed --> Delivered : revert
Archived --> [*]
@enduml