@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
[*] --> Reviewed
Reviewed --> Closed : confirm
Closed --> Completed : reject
Completed --> Approved : update
Approved --> Pending : approve
Approved : entry / log ward
Pending --> OnHold : update
Approved --> Completed : revert
OnHold --> [*]
@enduml