@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
[*] --> Cancelled
Cancelled --> Completed : process
Completed --> Reviewed : review
Reviewed --> Shipped : update
Shipped --> Rejected : process
Shipped : entry / log warehouse
Rejected --> OnHold : confirm
Reviewed --> OnHold : revert
OnHold --> [*]
@enduml