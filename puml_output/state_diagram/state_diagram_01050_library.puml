@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
[*] --> Draft
Draft --> Shipped : review
Draft : entry / log catalog
Shipped --> Pending : cancel
Pending --> Delivered : process
Delivered --> Active : reject
Delivered : entry / log catalog
Active --> Approved : approve
Active : entry / log catalog
Approved --> [*]
@enduml