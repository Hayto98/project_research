@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
[*] --> Approved
Approved --> Pending : reject
Pending --> Draft : update
Draft --> Active : reject
Active --> Completed : update
Active : entry / log category
Completed --> Archived : cancel
Completed : entry / log category
Archived --> [*]
@enduml