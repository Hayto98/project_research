@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
[*] --> OnHold
OnHold --> Delivered : reject
Delivered --> Closed : confirm
Closed --> Draft : confirm
Closed : entry / log customer
Draft --> Cancelled : confirm
Cancelled --> [*]
@enduml