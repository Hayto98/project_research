@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
[*] --> Processing
Processing --> Shipped : review
Shipped --> Reviewed : update
Reviewed --> Draft : approve
Reviewed : entry / log category
Draft --> Created : approve
Created --> Approved : reject
Created --> Reviewed : revert
Approved --> [*]
@enduml