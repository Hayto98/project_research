@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
[*] --> Shipped
Shipped --> Closed : cancel
Closed --> Archived : process
Archived --> Approved : reject
Approved --> Cancelled : reject
Cancelled --> Completed : cancel
Completed --> [*]
@enduml