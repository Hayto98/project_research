@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
[*] --> Archived
Archived --> Approved : reject
Archived : entry / log payment
Approved --> Closed : cancel
Closed --> Processing : process
Closed --> Processing : revert
Processing --> [*]
@enduml