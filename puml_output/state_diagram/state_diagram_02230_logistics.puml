@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
[*] --> Approved
Approved --> Closed : confirm
Approved : entry / log driver
Closed --> Cancelled : cancel
Closed : entry / log driver
Cancelled --> Delivered : reject
Delivered --> Processing : update
Processing --> Completed : submit
Delivered --> Closed : revert
Completed --> [*]
