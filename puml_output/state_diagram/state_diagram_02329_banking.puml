@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
[*] --> Active
Active --> Draft : reject
Draft --> Processing : review
Draft : entry / log customer
Processing --> Shipped : review
Shipped --> Rejected : update
Rejected --> Pending : submit
Pending --> [*]
@enduml