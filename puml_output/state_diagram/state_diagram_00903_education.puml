@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
[*] --> Draft
Draft --> Created : submit
Created --> OnHold : submit
Created : entry / log library
OnHold --> Approved : update
Approved --> Rejected : approve
Approved : entry / log library
Rejected --> OnHold : revert
Rejected --> [*]
@enduml