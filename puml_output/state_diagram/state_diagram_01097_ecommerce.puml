@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
[*] --> OnHold
OnHold --> Reviewed : update
Reviewed --> Shipped : update
Shipped --> Approved : update
Approved --> Active : update
Active --> Draft : update
Draft --> OnHold : revert
Draft --> [*]
@enduml