@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
[*] --> Created
Created --> Draft : submit
Draft --> Active : cancel
Active --> Delivered : update
Delivered --> Reviewed : reject
Delivered --> Active : revert
Reviewed --> [*]
@enduml