@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
[*] --> Active
Active --> Cancelled : reject
Cancelled --> Processing : cancel
Processing --> Shipped : approve
Processing : entry / log beneficiary
Shipped --> Pending : approve
Pending --> Closed : cancel
Cancelled --> Pending : revert
Closed --> [*]
@enduml