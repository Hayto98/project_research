@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
[*] --> Cancelled
Cancelled --> Reviewed : process
Reviewed --> Completed : process
Completed --> Shipped : update
Completed : entry / log restaurant
Shipped --> Rejected : review
Rejected --> Closed : update
Reviewed --> Rejected : revert
Closed --> [*]
@enduml