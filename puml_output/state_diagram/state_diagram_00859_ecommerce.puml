@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
[*] --> Completed
Completed --> OnHold : approve
OnHold --> Created : submit
Created --> Active : cancel
Created : entry / log supplier
OnHold --> Active : revert
Active --> [*]
@enduml