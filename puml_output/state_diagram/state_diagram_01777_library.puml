@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
[*] --> Shipped
Shipped --> Delivered : approve
Delivered --> Draft : submit
Draft --> Approved : reject
Approved --> Completed : process
Completed --> Created : approve
Created --> [*]
@enduml