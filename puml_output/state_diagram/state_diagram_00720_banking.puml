@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
[*] --> Reviewed
Reviewed --> Cancelled : approve
Reviewed : entry / log loan
Cancelled --> Approved : confirm
Approved --> Delivered : process
Delivered --> Shipped : update
Shipped --> Closed : reject
Approved --> Closed : revert
Closed --> [*]
@enduml