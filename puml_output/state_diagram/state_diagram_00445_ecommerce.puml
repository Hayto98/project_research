@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
[*] --> Closed
Closed --> Completed : process
Completed --> Created : cancel
Created --> Rejected : reject
Created : entry / log coupon
Rejected --> Shipped : submit
Shipped --> Processing : approve
Closed --> Shipped : revert
Processing --> [*]
@enduml