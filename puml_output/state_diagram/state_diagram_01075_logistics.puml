@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
[*] --> Completed
Completed --> Reviewed : process
Completed : entry / log tracking
Reviewed --> Closed : confirm
Closed --> Shipped : submit
Shipped --> OnHold : reject
OnHold --> Processing : confirm
OnHold --> Reviewed : revert
Processing --> [*]
@enduml