@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
[*] --> Draft
Draft --> OnHold : update
Draft : entry / log room
OnHold --> Reviewed : cancel
Reviewed --> Archived : approve
Archived --> Closed : cancel
Closed --> Pending : approve
Closed --> OnHold : revert
Pending --> [*]
@enduml