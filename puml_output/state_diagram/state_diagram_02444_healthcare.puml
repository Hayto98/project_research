@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
[*] --> Completed
Completed --> Shipped : review
Shipped --> Rejected : update
Rejected --> Draft : confirm
Draft --> Archived : review
Draft : entry / log medicalrecord
Archived --> [*]
@enduml