@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
[*] --> Created
Created --> Closed : update
Closed --> Active : reject
Active --> OnHold : reject
OnHold --> Approved : cancel
OnHold : entry / log book
Approved --> Delivered : confirm
Approved : entry / log book
Delivered --> [*]
@enduml