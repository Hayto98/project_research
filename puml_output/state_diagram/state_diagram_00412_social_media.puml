@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
[*] --> Completed
Completed --> Delivered : process
Delivered --> Processing : process
Delivered : entry / log report
Processing --> Active : reject
Active --> Pending : approve
Pending --> Draft : confirm
Draft --> [*]
@enduml