@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
[*] --> Approved
Approved --> Rejected : reject
Approved : entry / log guest
Rejected --> Shipped : confirm
Shipped --> OnHold : approve
OnHold --> Completed : submit
Completed --> Reviewed : confirm
Shipped --> Rejected : revert
Reviewed --> [*]
@enduml