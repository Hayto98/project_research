@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
[*] --> Approved
Approved --> Delivered : submit
Delivered --> Pending : update
Pending --> Completed : approve
Completed --> Processing : reject
Completed : entry / log ward
Processing --> Rejected : cancel
Processing --> Pending : revert
Rejected --> [*]
@enduml