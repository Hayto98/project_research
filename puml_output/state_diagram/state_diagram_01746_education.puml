@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
[*] --> Active
Active --> Cancelled : review
Cancelled --> Completed : update
Completed --> Delivered : update
Completed : entry / log grade
Delivered --> Pending : reject
Pending --> Reviewed : confirm
Pending : entry / log grade
Active --> Cancelled : revert
Reviewed --> [*]
@enduml