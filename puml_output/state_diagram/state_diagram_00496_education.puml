@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
[*] --> Closed
Closed --> OnHold : reject
OnHold --> Delivered : update
Delivered --> Active : approve
Active --> Shipped : approve
Shipped --> Draft : reject
OnHold --> Draft : revert
Draft --> [*]
@enduml