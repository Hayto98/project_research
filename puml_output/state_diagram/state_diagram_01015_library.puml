@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
[*] --> Approved
Approved --> Closed : approve
Closed --> Rejected : process
Rejected --> Draft : review
Rejected : entry / log shelf
Draft --> Delivered : confirm
Delivered --> Archived : process
Delivered : entry / log shelf
Archived --> [*]
@enduml