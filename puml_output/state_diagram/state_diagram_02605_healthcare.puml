@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
[*] --> Pending
Pending --> Shipped : review
Shipped --> Created : cancel
Shipped : entry / log diagnosis
Created --> Processing : review
Created : entry / log diagnosis
Processing --> Closed : cancel
Closed --> Delivered : review
Closed : entry / log diagnosis
Delivered --> Pending : revert
Delivered --> [*]
@enduml