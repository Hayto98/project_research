@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
[*] --> Shipped
Shipped --> Draft : update
Shipped : entry / log diagnosis
Draft --> Cancelled : update
Cancelled --> Archived : reject
Archived --> Created : update
Created --> Reviewed : submit
Draft --> Shipped : revert
Reviewed --> [*]
@enduml