@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
[*] --> Completed
Completed --> Draft : cancel
Draft --> Created : reject
Created --> OnHold : review
OnHold --> Closed : reject
Closed --> Pending : update
Pending --> [*]
@enduml