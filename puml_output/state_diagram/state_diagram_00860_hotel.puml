@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
[*] --> Draft
Draft --> Created : process
Created --> Delivered : reject
Delivered --> Active : confirm
Active --> Rejected : reject
Rejected --> Reviewed : approve
Draft --> Delivered : revert
Reviewed --> [*]
@enduml