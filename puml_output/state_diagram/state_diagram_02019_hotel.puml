@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
[*] --> Rejected
Rejected --> Processing : approve
Processing --> Approved : process
Approved --> Completed : approve
Completed --> Shipped : confirm
Shipped --> Archived : cancel
Processing --> Archived : revert
Archived --> [*]
@enduml