@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
[*] --> Rejected
Rejected --> Active : approve
Active --> Approved : reject
Active : entry / log statement
Approved --> Draft : reject
Draft --> Delivered : approve
Delivered --> Created : approve
Rejected --> Draft : revert
Created --> [*]
@enduml