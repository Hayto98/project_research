@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
[*] --> Rejected
Rejected --> Completed : approve
Completed --> Created : confirm
Created --> Shipped : approve
Shipped --> Cancelled : submit
Shipped : entry / log attendance
Cancelled --> Active : confirm
Rejected --> Created : revert
Active --> [*]
@enduml