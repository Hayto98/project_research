@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
[*] --> Archived
Archived --> OnHold : confirm
OnHold --> Delivered : submit
OnHold : entry / log hashtag
Delivered --> Shipped : cancel
Shipped --> Reviewed : reject
Shipped --> Delivered : revert
Reviewed --> [*]
@enduml