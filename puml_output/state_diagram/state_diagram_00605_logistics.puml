@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
[*] --> Pending
Pending --> Cancelled : confirm
Pending : entry / log route
Cancelled --> Delivered : update
Delivered --> Completed : cancel
Completed --> Reviewed : review
Pending --> Reviewed : revert
Reviewed --> [*]
@enduml