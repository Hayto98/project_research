@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
[*] --> Active
Active --> Archived : reject
Archived --> Reviewed : update
Archived : entry / log assignment
Reviewed --> Cancelled : reject
Reviewed : entry / log assignment
Cancelled --> Pending : approve
Reviewed --> Archived : revert
Pending --> [*]
@enduml