@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
[*] --> Draft
Draft --> Shipped : approve
Shipped --> Completed : approve
Completed --> Active : review
Completed : entry / log shipment
Active --> Approved : submit
Approved --> Processing : cancel
Processing --> Approved : revert
Processing --> [*]
@enduml