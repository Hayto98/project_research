@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
[*] --> Approved
Approved --> Reviewed : confirm
Reviewed --> OnHold : update
OnHold --> Archived : approve
Archived --> Draft : reject
Reviewed --> Approved : revert
Draft --> [*]
@enduml