@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
[*] --> Created
Created --> Draft : submit
Created : entry / log route
Draft --> Archived : review
Archived --> Reviewed : approve
Archived : entry / log route
Reviewed --> Closed : cancel
Reviewed : entry / log route
Reviewed --> Closed : revert
Closed --> [*]
@enduml