@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
[*] --> Rejected
Rejected --> Approved : cancel
Approved --> Delivered : process
Approved : entry / log customer
Delivered --> Closed : update
Closed --> Shipped : reject
Shipped --> Reviewed : cancel
Shipped --> Delivered : revert
Reviewed --> [*]
@enduml