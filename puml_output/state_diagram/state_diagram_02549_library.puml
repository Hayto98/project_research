@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
[*] --> Closed
Closed --> Draft : review
Draft --> Created : cancel
Created --> OnHold : reject
OnHold --> Archived : process
Archived --> Cancelled : process
Archived : entry / log loan
Cancelled --> [*]
@enduml