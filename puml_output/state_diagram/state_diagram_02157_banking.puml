@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
[*] --> Cancelled
Cancelled --> Delivered : approve
Cancelled : entry / log transfer
Delivered --> Processing : submit
Processing --> Draft : cancel
Draft --> Reviewed : update
Reviewed --> Shipped : review
Shipped --> [*]
@enduml