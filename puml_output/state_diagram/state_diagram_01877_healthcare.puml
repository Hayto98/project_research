@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
[*] --> Rejected
Rejected --> Active : review
Active --> Shipped : submit
Active : entry / log labtest
Shipped --> Draft : process
Draft --> Completed : approve
Completed --> Reviewed : update
Completed --> Reviewed : revert
Reviewed --> [*]
@enduml