@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
[*] --> Closed
Closed --> Delivered : submit
Delivered --> Pending : cancel
Pending --> Processing : update
Processing --> Completed : confirm
Delivered --> Closed : revert
Completed --> [*]
@enduml