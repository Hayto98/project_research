@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
[*] --> Draft
Draft --> Approved : approve
Approved --> Pending : confirm
Approved : entry / log publisher
Pending --> Rejected : cancel
Rejected --> Completed : reject
Completed --> Rejected : revert
Completed --> [*]
@enduml