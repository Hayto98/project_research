@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
[*] --> Closed
Closed --> Processing : process
Closed : entry / log patient
Processing --> Archived : cancel
Archived --> Completed : confirm
Archived : entry / log patient
Completed --> Delivered : update
Delivered --> [*]
@enduml