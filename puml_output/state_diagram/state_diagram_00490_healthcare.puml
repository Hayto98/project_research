@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
[*] --> Shipped
Shipped --> Closed : reject
Closed --> Approved : cancel
Approved --> Reviewed : cancel
Reviewed --> Completed : review
Shipped --> Approved : revert
Completed --> [*]
@enduml