@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
[*] --> Completed
Completed --> Delivered : cancel
Delivered --> Rejected : update
Delivered : entry / log transaction
Rejected --> Active : approve
Active --> Cancelled : cancel
Cancelled --> Reviewed : cancel
Reviewed --> [*]
@enduml