@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
[*] --> Active
Active --> Completed : cancel
Active : entry / log diagnosis
Completed --> Closed : update
Closed --> Reviewed : review
Reviewed --> OnHold : submit
OnHold --> Shipped : approve
Shipped --> [*]
@enduml