@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
[*] --> Archived
Archived --> Active : review
Active --> Reviewed : submit
Reviewed --> Shipped : confirm
Reviewed : entry / log patient
Shipped --> Processing : submit
Processing --> Approved : approve
Reviewed --> Archived : revert
Approved --> [*]
@enduml