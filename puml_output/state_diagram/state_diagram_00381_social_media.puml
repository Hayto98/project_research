@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
[*] --> OnHold
OnHold --> Processing : update
Processing --> Delivered : confirm
Delivered --> Shipped : submit
Shipped --> Completed : submit
Completed --> Archived : approve
Completed : entry / log like
Processing --> Archived : revert
Archived --> [*]
@enduml