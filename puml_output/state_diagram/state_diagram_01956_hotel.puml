@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
[*] --> Processing
Processing --> Closed : reject
Closed --> Draft : cancel
Draft --> Pending : approve
Pending --> Cancelled : process
Pending : entry / log service
Cancelled --> Completed : process
Completed --> [*]
@enduml