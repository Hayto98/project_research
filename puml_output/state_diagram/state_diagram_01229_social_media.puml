@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
[*] --> Archived
Archived --> Delivered : submit
Delivered --> Active : approve
Active --> Processing : update
Processing --> Pending : confirm
Pending --> Completed : confirm
Processing --> Pending : revert
Completed --> [*]
@enduml