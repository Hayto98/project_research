@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
[*] --> Rejected
Rejected --> Cancelled : approve
Cancelled --> Pending : submit
Cancelled : entry / log like
Pending --> Reviewed : update
Reviewed --> Archived : reject
Archived --> [*]
@enduml