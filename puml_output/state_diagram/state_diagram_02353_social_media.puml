@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
[*] --> Cancelled
Cancelled --> Completed : approve
Completed --> Active : process
Active --> Processing : process
Processing --> OnHold : submit
OnHold --> Processing : revert
OnHold --> [*]
@enduml