@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
[*] --> Reviewed
Reviewed --> Rejected : confirm
Rejected --> Archived : approve
Archived --> Approved : cancel
Archived : entry / log deliverynote
Approved --> Reviewed : revert
Approved --> [*]
@enduml