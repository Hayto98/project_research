@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
[*] --> OnHold
OnHold --> Reviewed : cancel
Reviewed --> Shipped : review
Shipped --> Cancelled : submit
Cancelled --> Active : cancel
Cancelled : entry / log billing
Active --> [*]
