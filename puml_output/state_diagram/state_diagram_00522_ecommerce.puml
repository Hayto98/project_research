@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
[*] --> Draft
Draft --> Created : update
Created --> Delivered : cancel
Created : entry / log product
Delivered --> Cancelled : confirm
Cancelled --> OnHold : review
OnHold --> Shipped : submit
Shipped --> [*]
@enduml