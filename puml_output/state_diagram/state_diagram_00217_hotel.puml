@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
[*] --> Approved
Approved --> Rejected : reject
Rejected --> Pending : cancel
Rejected : entry / log restaurant
Pending --> OnHold : confirm
OnHold --> Shipped : process
Shipped --> [*]
@enduml