@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
[*] --> Approved
Approved --> Processing : cancel
Processing --> Completed : process
Completed --> Shipped : reject
Shipped --> Rejected : update
Approved --> Rejected : revert
Rejected --> [*]
@enduml