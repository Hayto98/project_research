@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
[*] --> Reviewed
Reviewed --> Draft : confirm
Draft --> Approved : cancel
Approved --> Created : reject
Created --> Delivered : approve
Created : entry / log hashtag
Delivered --> Cancelled : submit
Cancelled --> [*]
@enduml