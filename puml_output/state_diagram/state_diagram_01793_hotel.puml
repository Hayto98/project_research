@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
[*] --> Created
Created --> Approved : confirm
Approved --> Closed : approve
Closed --> Draft : review
Draft --> OnHold : process
Closed --> OnHold : revert
OnHold --> [*]
@enduml