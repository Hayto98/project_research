@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
[*] --> Shipped
Shipped --> Approved : update
Shipped : entry / log group
Approved --> Draft : approve
Draft --> Active : process
Active --> Rejected : approve
Rejected --> Approved : revert
Rejected --> [*]
@enduml