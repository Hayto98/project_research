@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
[*] --> Cancelled
Cancelled --> Pending : cancel
Pending --> Completed : confirm
Pending : entry / log member
Completed --> Shipped : confirm
Shipped --> Closed : confirm
Closed --> Rejected : approve
Rejected --> [*]
@enduml