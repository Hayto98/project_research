@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
[*] --> Approved
Approved --> Cancelled : update
Cancelled --> OnHold : confirm
OnHold --> Created : submit
OnHold : entry / log deposit
Created --> Delivered : reject
Delivered --> Closed : review
Closed --> [*]
@enduml