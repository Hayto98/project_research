@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
[*] --> Draft
Draft --> Approved : cancel
Approved --> Created : review
Created --> Closed : update
Closed --> Delivered : update
Created --> Draft : revert
Delivered --> [*]
@enduml