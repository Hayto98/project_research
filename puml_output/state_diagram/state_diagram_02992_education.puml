@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
[*] --> Completed
Completed --> Rejected : submit
Rejected --> Active : approve
Rejected : entry / log grade
Active --> Approved : confirm
Approved --> Pending : review
Pending --> Reviewed : approve
Pending --> Approved : revert
Reviewed --> [*]
@enduml