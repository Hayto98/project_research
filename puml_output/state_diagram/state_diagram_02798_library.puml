@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
[*] --> Delivered
Delivered --> Closed : confirm
Closed --> Cancelled : process
Cancelled --> Active : reject
Active --> Reviewed : submit
Delivered --> Cancelled : revert
Reviewed --> [*]
@enduml