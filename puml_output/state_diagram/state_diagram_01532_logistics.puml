@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
[*] --> Pending
Pending --> Rejected : approve
Pending : entry / log route
Rejected --> Processing : cancel
Processing --> Reviewed : process
Reviewed --> Approved : process
Approved --> Archived : update
Approved --> Rejected : revert
Archived --> [*]
@enduml