@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
[*] --> Draft
Draft --> Completed : approve
Draft : entry / log assignment
Completed --> Rejected : update
Rejected --> Closed : submit
Closed --> OnHold : reject
OnHold --> Reviewed : cancel
Closed --> Completed : revert
Reviewed --> [*]
@enduml