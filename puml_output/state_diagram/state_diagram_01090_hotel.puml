@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
[*] --> OnHold
OnHold --> Active : confirm
Active --> Delivered : process
Active : entry / log guest
Delivered --> Approved : review
Approved --> Cancelled : cancel
Cancelled --> [*]
@enduml