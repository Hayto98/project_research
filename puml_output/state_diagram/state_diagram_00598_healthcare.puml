@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
[*] --> Rejected
Rejected --> Closed : approve
Closed --> Reviewed : process
Reviewed --> Active : submit
Active --> Draft : review
Active : entry / log treatment
Draft --> Approved : cancel
Draft : entry / log treatment
Draft --> Closed : revert
Approved --> [*]
@enduml