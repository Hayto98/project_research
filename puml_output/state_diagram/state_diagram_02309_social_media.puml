@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
[*] --> Completed
Completed --> Delivered : process
Delivered --> Archived : cancel
Delivered : entry / log report
Archived --> Created : update
Created --> Draft : reject
Created : entry / log report
Draft --> Rejected : confirm
Rejected --> [*]
@enduml