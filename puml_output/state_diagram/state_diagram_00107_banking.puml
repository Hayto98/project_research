@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
[*] --> Approved
Approved --> Pending : cancel
Approved : entry / log card
Pending --> Rejected : review
Rejected --> Active : approve
Active --> Archived : update
Archived --> Created : reject
Created --> [*]
@enduml