@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
[*] --> Closed
Closed --> Archived : submit
Closed : entry / log course
Archived --> Created : confirm
Created --> Processing : process
Processing --> Shipped : cancel
Shipped --> Approved : reject
Approved --> [*]
@enduml