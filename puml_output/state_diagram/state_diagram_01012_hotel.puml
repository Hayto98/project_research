@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
[*] --> Rejected
Rejected --> Active : confirm
Rejected : entry / log housekeeping
Active --> Cancelled : submit
Cancelled --> Delivered : cancel
Delivered --> Pending : submit
Delivered : entry / log housekeeping
Pending --> Closed : reject
Closed --> [*]
@enduml