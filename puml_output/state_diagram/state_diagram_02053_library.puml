@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
[*] --> OnHold
OnHold --> Active : cancel
Active --> Rejected : reject
Active : entry / log renewal
Rejected --> Archived : submit
Archived --> Completed : confirm
Completed --> OnHold : revert
Completed --> [*]
@enduml