@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
[*] --> Draft
Draft --> Rejected : confirm
Rejected --> Created : approve
Created --> Archived : approve
Archived --> Reviewed : approve
Reviewed --> Approved : confirm
Reviewed : entry / log booking
Rejected --> Draft : revert
Approved --> [*]
@enduml