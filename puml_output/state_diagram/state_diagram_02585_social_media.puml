@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
[*] --> Draft
Draft --> Rejected : review
Draft : entry / log album
Rejected --> Archived : update
Archived --> Created : review
Created --> Shipped : update
Shipped --> Active : reject
Shipped : entry / log album
Active --> [*]
@enduml