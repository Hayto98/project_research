@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
[*] --> Approved
Approved --> Active : confirm
Active --> Closed : cancel
Active : entry / log like
Closed --> Pending : update
Pending --> Delivered : submit
Active --> Pending : revert
Delivered --> [*]
@enduml