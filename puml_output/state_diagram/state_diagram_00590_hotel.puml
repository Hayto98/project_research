@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
[*] --> Shipped
Shipped --> Closed : submit
Closed --> Cancelled : confirm
Cancelled --> Pending : reject
Pending --> Reviewed : approve
Pending : entry / log amenity
Reviewed --> OnHold : confirm
Closed --> Cancelled : revert
OnHold --> [*]
@enduml