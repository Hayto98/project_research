@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
[*] --> Pending
Pending --> Archived : review
Archived --> Reviewed : reject
Reviewed --> Processing : cancel
Processing --> OnHold : submit
OnHold --> Approved : reject
OnHold : entry / log renewal
Approved --> [*]
@enduml