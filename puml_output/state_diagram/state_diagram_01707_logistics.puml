@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
[*] --> Approved
Approved --> Draft : approve
Approved : entry / log fuellog
Draft --> Closed : confirm
Closed --> OnHold : cancel
OnHold --> Completed : cancel
Draft --> Completed : revert
Completed --> [*]
@enduml