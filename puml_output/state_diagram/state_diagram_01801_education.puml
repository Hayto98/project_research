@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
[*] --> Shipped
Shipped --> Reviewed : submit
Reviewed --> Archived : confirm
Archived --> OnHold : cancel
OnHold --> Cancelled : submit
Cancelled --> Completed : reject
Cancelled : entry / log classroom
Shipped --> OnHold : revert
Completed --> [*]
@enduml