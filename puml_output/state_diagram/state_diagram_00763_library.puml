@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
[*] --> Created
Created --> Active : update
Active --> Closed : update
Active : entry / log catalog
Closed --> Completed : approve
Completed --> Draft : submit
Draft --> Delivered : approve
Draft : entry / log catalog
Delivered --> Completed : revert
Delivered --> [*]
@enduml