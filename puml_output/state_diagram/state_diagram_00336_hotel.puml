@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
[*] --> Shipped
Shipped --> Delivered : cancel
Delivered --> Closed : update
Closed --> Draft : process
Draft --> Pending : confirm
Pending --> Archived : submit
Pending : entry / log room
Archived --> [*]
@enduml