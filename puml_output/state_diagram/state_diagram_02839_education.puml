@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
[*] --> Created
Created --> Active : review
Active --> Closed : reject
Closed --> Archived : review
Archived --> Rejected : process
Rejected --> Cancelled : review
Cancelled --> [*]
@enduml