@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
[*] --> OnHold
OnHold --> Active : reject
Active --> Completed : approve
Completed --> Archived : update
Completed : entry / log restaurant
Archived --> Approved : submit
Approved --> Closed : cancel
Closed --> [*]
@enduml