@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
[*] --> Draft
Draft --> Created : process
Created --> Cancelled : cancel
Created : entry / log service
Cancelled --> Reviewed : process
Reviewed --> Active : review
Reviewed --> Active : revert
Active --> [*]
@enduml