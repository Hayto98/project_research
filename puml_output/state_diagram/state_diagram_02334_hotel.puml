@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
[*] --> Rejected
Rejected --> Active : update
Rejected : entry / log room
Active --> Draft : submit
Draft --> Reviewed : update
Reviewed --> Processing : confirm
Processing --> Rejected : revert
Processing --> [*]
@enduml