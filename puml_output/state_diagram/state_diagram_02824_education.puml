@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
[*] --> OnHold
OnHold --> Reviewed : update
OnHold : entry / log enrollment
Reviewed --> Pending : confirm
Pending --> Completed : review
Completed --> Draft : reject
Completed : entry / log enrollment
Draft --> [*]
@enduml