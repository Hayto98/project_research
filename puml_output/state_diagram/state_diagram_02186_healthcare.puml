@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
[*] --> Pending
Pending --> Approved : cancel
Approved --> Rejected : update
Rejected --> Delivered : confirm
Delivered --> Draft : review
Draft --> Reviewed : submit
Draft : entry / log billing
Delivered --> Rejected : revert
Reviewed --> [*]
@enduml