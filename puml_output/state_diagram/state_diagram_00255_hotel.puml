@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
[*] --> OnHold
OnHold --> Reviewed : update
Reviewed --> Archived : confirm
Archived --> Shipped : update
Shipped --> Active : reject
Shipped : entry / log restaurant
Active --> OnHold : revert
Active --> [*]
@enduml