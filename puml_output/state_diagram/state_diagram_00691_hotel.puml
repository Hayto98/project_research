@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
[*] --> Draft
Draft --> Closed : review
Draft : entry / log staff
Closed --> Pending : reject
Pending --> Completed : cancel
Completed --> Archived : process
Archived --> Closed : revert
Archived --> [*]
@enduml