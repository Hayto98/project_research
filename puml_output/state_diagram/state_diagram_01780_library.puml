@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
[*] --> Draft
Draft --> OnHold : update
OnHold --> Reviewed : cancel
OnHold : entry / log shelf
Reviewed --> Processing : process
Processing --> Closed : submit
Reviewed --> Draft : revert
Closed --> [*]
@enduml