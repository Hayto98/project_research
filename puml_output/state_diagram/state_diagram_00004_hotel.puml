@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
[*] --> Approved
Approved --> Cancelled : update
Cancelled --> Rejected : approve
Cancelled : entry / log reservation
Rejected --> Pending : cancel
Pending --> Shipped : confirm
Pending : entry / log reservation
Shipped --> Approved : revert
Shipped --> [*]
@enduml