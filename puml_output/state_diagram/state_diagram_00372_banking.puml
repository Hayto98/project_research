@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
[*] --> Rejected
Rejected --> Draft : reject
Rejected : entry / log deposit
Draft --> Archived : confirm
Archived --> Completed : submit
Rejected --> Completed : revert
Completed --> [*]
@enduml