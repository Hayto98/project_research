@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
[*] --> Archived
Archived --> Rejected : approve
Rejected --> Processing : process
Processing --> Reviewed : confirm
Reviewed --> Completed : submit
Completed --> Active : confirm
Active --> Rejected : revert
Active --> [*]
@enduml