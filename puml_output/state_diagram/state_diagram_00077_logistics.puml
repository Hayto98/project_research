@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
[*] --> Pending
Pending --> Delivered : update
Delivered --> OnHold : submit
OnHold --> Draft : submit
OnHold : entry / log customer
OnHold --> Draft : revert
Draft --> [*]
@enduml