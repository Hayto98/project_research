@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
[*] --> Closed
Closed --> Draft : confirm
Draft --> Processing : review
Processing --> Rejected : process
Processing : entry / log book
Rejected --> Reviewed : update
Reviewed --> [*]
@enduml