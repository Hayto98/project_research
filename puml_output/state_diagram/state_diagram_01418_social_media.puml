@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
[*] --> Draft
Draft --> Active : process
Active --> Delivered : cancel
Delivered --> Archived : process
Archived --> Processing : reject
Archived : entry / log hashtag
Processing --> Active : revert
Processing --> [*]
@enduml