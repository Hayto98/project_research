@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
[*] --> Shipped
Shipped --> Approved : process
Approved --> Created : submit
Approved : entry / log deposit
Created --> Archived : submit
Archived --> Reviewed : approve
Reviewed --> Rejected : reject
Rejected --> Shipped : revert
Rejected --> [*]
@enduml