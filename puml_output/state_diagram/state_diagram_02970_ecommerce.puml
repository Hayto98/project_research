@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
[*] --> Closed
Closed --> Created : approve
Created --> Archived : approve
Created : entry / log invoice
Archived --> Approved : review
Approved --> Draft : cancel
Approved : entry / log invoice
Draft --> Pending : approve
Closed --> Pending : revert
Pending --> [*]
@enduml