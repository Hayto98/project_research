@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
[*] --> Delivered
Delivered --> Approved : update
Approved --> Rejected : update
Rejected --> OnHold : approve
OnHold --> Active : approve
Rejected --> Active : revert
Active --> [*]
@enduml