@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
[*] --> Created
Created --> Reviewed : submit
Reviewed --> Draft : review
Reviewed : entry / log invoice
Draft --> Approved : review
Approved --> Closed : reject
Closed --> Rejected : confirm
Rejected --> [*]
@enduml