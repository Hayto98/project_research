@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
[*] --> Active
Active --> Processing : update
Processing --> Archived : submit
Processing : entry / log user
Archived --> Reviewed : confirm
Reviewed --> Cancelled : reject
Cancelled --> [*]
@enduml