@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
[*] --> Reviewed
Reviewed --> Completed : review
Completed --> OnHold : update
OnHold --> Approved : reject
OnHold : entry / log post
Approved --> Archived : update
Approved : entry / log post
Archived --> Processing : approve
Archived : entry / log post
Processing --> [*]
@enduml