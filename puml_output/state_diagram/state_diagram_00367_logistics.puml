@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
[*] --> Cancelled
Cancelled --> Archived : review
Archived --> Pending : approve
Archived : entry / log tracking
Pending --> Delivered : submit
Delivered --> Rejected : update
Archived --> Pending : revert
Rejected --> [*]
@enduml