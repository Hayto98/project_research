@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
[*] --> OnHold
OnHold --> Rejected : update
OnHold : entry / log statement
Rejected --> Approved : confirm
Approved --> Reviewed : reject
Reviewed --> Completed : submit
Completed --> Closed : cancel
Closed --> [*]
@enduml