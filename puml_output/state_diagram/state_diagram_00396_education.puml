@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
[*] --> Completed
Completed --> Draft : process
Draft --> Cancelled : cancel
Draft : entry / log enrollment
Cancelled --> Shipped : cancel
Shipped --> Active : approve
Active --> OnHold : approve
OnHold --> [*]
@enduml