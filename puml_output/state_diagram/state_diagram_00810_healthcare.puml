@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
[*] --> Archived
Archived --> Shipped : approve
Archived : entry / log nurse
Shipped --> OnHold : update
OnHold --> Rejected : reject
Rejected --> Created : confirm
Created --> Closed : confirm
Rejected --> Closed : revert
Closed --> [*]
@enduml