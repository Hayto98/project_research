@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
[*] --> Pending
Pending --> Approved : process
Approved --> Processing : reject
Processing --> Shipped : review
Shipped --> Completed : update
Shipped : entry / log booking
Completed --> Rejected : update
Rejected --> [*]
@enduml