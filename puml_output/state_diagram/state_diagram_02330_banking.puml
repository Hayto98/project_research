@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
[*] --> Approved
Approved --> Archived : confirm
Archived --> Delivered : confirm
Archived : entry / log branch
Delivered --> Draft : process
Delivered : entry / log branch
Draft --> Created : cancel
Created --> Active : cancel
Created : entry / log branch
Delivered --> Approved : revert
Active --> [*]
@enduml