@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
[*] --> Completed
Completed --> Reviewed : reject
Reviewed --> Closed : submit
Closed --> Created : approve
Closed : entry / log notification
Created --> Active : confirm
Active --> Shipped : update
Shipped --> [*]
@enduml