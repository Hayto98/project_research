@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
[*] --> Archived
Archived --> Rejected : review
Rejected --> Created : update
Created --> Completed : submit
Completed --> Active : review
Active --> Approved : approve
Approved --> [*]
@enduml