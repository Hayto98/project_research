@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
[*] --> Pending
Pending --> Completed : update
Completed --> Reviewed : process
Completed : entry / log book
Reviewed --> Delivered : update
Delivered --> Draft : approve
Delivered : entry / log book
Draft --> Cancelled : review
Cancelled --> [*]
@enduml