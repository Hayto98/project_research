@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
[*] --> Pending
Pending --> Shipped : approve
Pending : entry / log profile
Shipped --> Closed : submit
Closed --> Cancelled : confirm
Cancelled --> OnHold : process
OnHold --> Active : approve
Active --> [*]
@enduml