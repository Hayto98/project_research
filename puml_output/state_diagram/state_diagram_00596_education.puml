@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
[*] --> Delivered
Delivered --> Cancelled : process
Cancelled --> Shipped : approve
Shipped --> OnHold : confirm
OnHold --> Rejected : update
Rejected --> Completed : process
Rejected : entry / log classroom
Completed --> [*]
@enduml