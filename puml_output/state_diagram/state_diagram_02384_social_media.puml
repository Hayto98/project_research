@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
[*] --> Active
Active --> Rejected : reject
Rejected --> Cancelled : confirm
Cancelled --> Created : review
Created --> Shipped : reject
Created : entry / log comment
Shipped --> Archived : reject
Active --> Cancelled : revert
Archived --> [*]
@enduml