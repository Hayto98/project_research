@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
[*] --> Rejected
Rejected --> Cancelled : submit
Cancelled --> Reviewed : confirm
Cancelled : entry / log statement
Reviewed --> Closed : reject
Closed --> Approved : process
Rejected --> Approved : revert
Approved --> [*]
@enduml