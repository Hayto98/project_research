@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
[*] --> Created
Created --> Cancelled : review
Created : entry / log prescription
Cancelled --> Draft : process
Draft --> OnHold : cancel
OnHold --> Delivered : submit
Delivered --> Approved : cancel
Approved --> [*]
@enduml