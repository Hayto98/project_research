@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
[*] --> Completed
Completed --> Closed : cancel
Closed --> Archived : cancel
Closed : entry / log supplier
Archived --> OnHold : approve
OnHold --> Delivered : cancel
Delivered --> Approved : submit
Delivered : entry / log supplier
Approved --> [*]
@enduml