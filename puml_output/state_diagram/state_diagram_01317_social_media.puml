@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
[*] --> Active
Active --> Reviewed : update
Reviewed --> Rejected : reject
Rejected --> Processing : review
Rejected : entry / log profile
Processing --> Delivered : review
Processing --> Reviewed : revert
Delivered --> [*]
@enduml