@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
[*] --> Pending
Pending --> Delivered : reject
Delivered --> Draft : submit
Draft --> Approved : confirm
Approved --> Archived : submit
Approved : entry / log catalog
Archived --> OnHold : approve
OnHold --> [*]
@enduml