@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
[*] --> Reviewed
Reviewed --> Pending : submit
Reviewed : entry / log shipment
Pending --> Approved : confirm
Approved --> OnHold : review
OnHold --> Closed : cancel
Pending --> Reviewed : revert
Closed --> [*]
@enduml