@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
[*] --> Approved
Approved --> Closed : cancel
Closed --> Draft : reject
Draft --> Completed : review
Completed --> Delivered : process
Closed --> Approved : revert
Delivered --> [*]
@enduml