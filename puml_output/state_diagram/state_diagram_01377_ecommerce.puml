@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
[*] --> OnHold
OnHold --> Cancelled : confirm
Cancelled --> Closed : review
Closed --> Rejected : update
Rejected --> Active : reject
Active --> Draft : reject
Draft --> [*]
@enduml