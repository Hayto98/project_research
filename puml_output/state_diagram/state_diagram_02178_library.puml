@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
[*] --> Created
Created --> Pending : cancel
Pending --> Reviewed : submit
Reviewed --> Closed : process
Reviewed : entry / log member
Closed --> Archived : approve
Archived --> Draft : confirm
Pending --> Draft : revert
Draft --> [*]
@enduml