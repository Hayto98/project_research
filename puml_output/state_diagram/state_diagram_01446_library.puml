@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
[*] --> Reviewed
Reviewed --> Draft : update
Draft --> Active : reject
Draft : entry / log book
Active --> Rejected : approve
Active : entry / log book
Rejected --> Cancelled : process
Cancelled --> OnHold : cancel
OnHold --> Reviewed : revert
OnHold --> [*]
@enduml