@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
[*] --> Processing
Processing --> Created : cancel
Created --> Rejected : update
Rejected --> Draft : submit
Draft --> Approved : submit
Draft : entry / log enrollment
Approved --> Active : confirm
Draft --> Processing : revert
Active --> [*]
@enduml