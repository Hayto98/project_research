@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
[*] --> Created
Created --> Closed : review
Closed --> Pending : submit
Pending --> Shipped : confirm
Shipped --> Active : review
Shipped : entry / log warehouse
Active --> Approved : submit
Created --> Pending : revert
Approved --> [*]
@enduml