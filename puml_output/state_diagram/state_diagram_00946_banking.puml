@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
[*] --> Created
Created --> Active : submit
Active --> Draft : process
Draft --> Processing : confirm
Draft : entry / log interest
Processing --> Reviewed : cancel
Reviewed --> Cancelled : confirm
Draft --> Active : revert
Cancelled --> [*]
@enduml