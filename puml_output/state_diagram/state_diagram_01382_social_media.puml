@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
[*] --> Closed
Closed --> Rejected : approve
Rejected --> Cancelled : approve
Rejected : entry / log message
Cancelled --> Completed : cancel
Completed --> Draft : review
Draft --> Archived : approve
Draft : entry / log message
Archived --> Rejected : revert
Archived --> [*]
@enduml