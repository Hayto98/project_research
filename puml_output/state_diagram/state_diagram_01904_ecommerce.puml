@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
[*] --> Created
Created --> OnHold : reject
Created : entry / log customer
OnHold --> Processing : review
Processing --> Draft : update
Draft --> Pending : review
Draft : entry / log customer
Pending --> Closed : cancel
Draft --> Processing : revert
Closed --> [*]
@enduml