@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
[*] --> Cancelled
Cancelled --> Completed : update
Completed --> Rejected : process
Completed : entry / log diagnosis
Rejected --> Reviewed : reject
Reviewed --> Delivered : update
Delivered --> Pending : confirm
Pending --> [*]
@enduml