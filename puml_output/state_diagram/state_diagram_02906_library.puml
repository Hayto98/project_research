@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
[*] --> Archived
Archived --> Shipped : cancel
Shipped --> Created : reject
Created --> Rejected : submit
Rejected --> Pending : process
Pending --> Approved : submit
Shipped --> Pending : revert
Approved --> [*]
@enduml