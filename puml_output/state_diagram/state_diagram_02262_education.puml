@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
[*] --> Pending
Pending --> OnHold : process
OnHold --> Approved : confirm
Approved --> Reviewed : update
Approved : entry / log classroom
Reviewed --> Processing : reject
Approved --> Pending : revert
Processing --> [*]
@enduml