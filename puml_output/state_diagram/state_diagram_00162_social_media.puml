@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
[*] --> Active
Active --> Closed : review
Active : entry / log message
Closed --> Rejected : approve
Rejected --> Created : submit
Created --> Completed : confirm
Completed --> Created : revert
Completed --> [*]
@enduml