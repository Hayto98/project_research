@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
[*] --> Delivered
Delivered --> Active : confirm
Active --> Approved : reject
Active : entry / log post
Approved --> Closed : submit
Closed --> Delivered : revert
Closed --> [*]
@enduml