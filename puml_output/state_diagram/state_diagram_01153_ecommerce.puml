@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
[*] --> Archived
Archived --> OnHold : update
OnHold --> Created : submit
Created --> Completed : confirm
Created : entry / log cart
Completed --> Processing : approve
Archived --> Processing : revert
Processing --> [*]
@enduml