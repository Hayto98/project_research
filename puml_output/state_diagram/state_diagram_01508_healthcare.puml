@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
[*] --> Rejected
Rejected --> Closed : submit
Closed --> Cancelled : review
Closed : entry / log patient
Cancelled --> Pending : reject
Pending --> Approved : process
Pending : entry / log patient
Approved --> Reviewed : update
Approved : entry / log patient
Approved --> Pending : revert
Reviewed --> [*]
@enduml