@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
[*] --> Cancelled
Cancelled --> Approved : review
Approved --> Active : submit
Active --> Archived : process
Archived --> Reviewed : confirm
Active --> Approved : revert
Reviewed --> [*]
@enduml