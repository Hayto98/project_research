@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
[*] --> Cancelled
Cancelled --> Completed : confirm
Completed --> Shipped : update
Shipped --> Created : reject
Created --> Reviewed : confirm
Created : entry / log reservation
Completed --> Created : revert
Reviewed --> [*]
@enduml