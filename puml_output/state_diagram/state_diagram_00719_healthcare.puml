@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
[*] --> Rejected
Rejected --> Active : reject
Active --> Reviewed : cancel
Active : entry / log hospital
Reviewed --> OnHold : cancel
OnHold --> Cancelled : reject
Active --> Rejected : revert
Cancelled --> [*]
@enduml