@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
[*] --> Rejected
Rejected --> Pending : reject
Pending --> Approved : submit
Approved --> Archived : update
Approved : entry / log hospital
Archived --> Draft : submit
Draft --> Pending : revert
Draft --> [*]
@enduml