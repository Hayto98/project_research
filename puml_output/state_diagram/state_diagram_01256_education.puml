@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
[*] --> Archived
Archived --> Rejected : cancel
Rejected --> Created : submit
Created --> Delivered : confirm
Created : entry / log attendance
Delivered --> Processing : approve
Archived --> Created : revert
Processing --> [*]
@enduml