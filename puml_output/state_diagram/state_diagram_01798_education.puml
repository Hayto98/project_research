@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
[*] --> Approved
Approved --> Reviewed : confirm
Reviewed --> Rejected : confirm
Rejected --> Closed : submit
Closed --> Active : reject
Closed : entry / log schedule
Approved --> Active : revert
Active --> [*]
@enduml