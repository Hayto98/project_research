@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
[*] --> Cancelled
Cancelled --> Shipped : update
Shipped --> Approved : update
Shipped : entry / log return
Approved --> Completed : approve
Completed --> Draft : cancel
Draft --> Processing : update
Processing --> Draft : revert
Processing --> [*]
@enduml