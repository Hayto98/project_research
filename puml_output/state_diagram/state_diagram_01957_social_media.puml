@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
[*] --> Rejected
Rejected --> Archived : reject
Archived --> Reviewed : process
Reviewed --> Approved : reject
Approved --> Completed : process
Completed --> Rejected : revert
Completed --> [*]
@enduml