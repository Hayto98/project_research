@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
[*] --> Cancelled
Cancelled --> Completed : submit
Completed --> Active : cancel
Active --> Closed : process
Closed --> Rejected : submit
Rejected --> Created : process
Created --> [*]
@enduml