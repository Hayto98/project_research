@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
[*] --> Draft
Draft --> Processing : confirm
Processing --> Pending : reject
Pending --> Completed : approve
Completed --> Delivered : process
Delivered --> Cancelled : cancel
Delivered : entry / log exam
Pending --> Cancelled : revert
Cancelled --> [*]
@enduml