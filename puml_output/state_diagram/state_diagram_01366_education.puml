@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
[*] --> Active
Active --> Rejected : confirm
Active : entry / log course
Rejected --> Processing : submit
Processing --> Closed : submit
Closed --> Cancelled : confirm
Cancelled --> [*]
