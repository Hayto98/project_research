@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
[*] --> Archived
Archived --> Cancelled : cancel
Archived : entry / log like
Cancelled --> Created : update
Cancelled : entry / log like
Created --> Reviewed : update
Reviewed --> Delivered : update
Reviewed --> Delivered : revert
Delivered --> [*]
@enduml