@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
[*] --> Draft
Draft --> Cancelled : review
Cancelled --> Shipped : cancel
Cancelled : entry / log course
Shipped --> Delivered : process
Shipped : entry / log course
Delivered --> OnHold : reject
Delivered : entry / log course
OnHold --> Completed : reject
Completed --> [*]
@enduml