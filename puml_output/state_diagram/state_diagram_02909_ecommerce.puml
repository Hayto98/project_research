@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
[*] --> Closed
Closed --> Created : cancel
Created --> Pending : approve
Pending --> Cancelled : submit
Cancelled --> Shipped : confirm
Shipped --> Delivered : cancel
Pending --> Delivered : revert
Delivered --> [*]
@enduml