@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
[*] --> Delivered
Delivered --> Reviewed : process
Reviewed --> Pending : submit
Pending --> Completed : approve
Pending : entry / log cart
Completed --> Archived : reject
Completed : entry / log cart
Archived --> Closed : cancel
Closed --> [*]
@enduml