@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
[*] --> Draft
Draft --> Approved : process
Draft : entry / log depot
Approved --> Reviewed : confirm
Reviewed --> Completed : process
Completed --> Processing : update
Processing --> Pending : review
Processing --> Approved : revert
Pending --> [*]
@enduml