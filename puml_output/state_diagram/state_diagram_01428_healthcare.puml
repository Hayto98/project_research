@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
[*] --> Archived
Archived --> Active : process
Active --> Pending : confirm
Pending --> Closed : review
Closed --> OnHold : review
Closed : entry / log nurse
OnHold --> Processing : process
OnHold --> Closed : revert
Processing --> [*]
@enduml