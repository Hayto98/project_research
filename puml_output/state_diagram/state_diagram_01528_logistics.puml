@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
[*] --> Archived
Archived --> Delivered : approve
Delivered --> Completed : submit
Completed --> Closed : review
Closed --> Cancelled : reject
Closed : entry / log warehouse
Cancelled --> [*]
@enduml