@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
[*] --> Closed
Closed --> Rejected : confirm
Rejected --> Archived : cancel
Rejected : entry / log customer
Archived --> Shipped : cancel
Shipped --> Processing : confirm
Processing --> Active : cancel
Processing : entry / log customer
Active --> [*]
@enduml