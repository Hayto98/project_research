@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
[*] --> Approved
Approved --> Created : review
Created --> Pending : confirm
Pending --> OnHold : update
OnHold --> Completed : update
OnHold : entry / log treatment
Completed --> Rejected : update
Rejected --> [*]
@enduml