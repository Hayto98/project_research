@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
[*] --> Closed
Closed --> Created : approve
Created --> Rejected : review
Rejected --> Reviewed : submit
Rejected : entry / log checkout
Reviewed --> Pending : review
Pending --> Cancelled : update
Cancelled --> [*]
@enduml