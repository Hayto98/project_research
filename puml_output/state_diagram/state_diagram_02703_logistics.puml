@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
[*] --> Processing
Processing --> Delivered : reject
Delivered --> Shipped : process
Shipped --> OnHold : submit
OnHold --> Reviewed : submit
Reviewed --> Draft : approve
Reviewed : entry / log fuellog
Draft --> [*]
@enduml