@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
[*] --> OnHold
OnHold --> Rejected : process
Rejected --> Shipped : confirm
Rejected : entry / log amenity
Shipped --> Created : cancel
Created --> Archived : process
Archived --> [*]
@enduml