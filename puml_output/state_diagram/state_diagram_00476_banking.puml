@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
[*] --> Cancelled
Cancelled --> Draft : approve
Cancelled : entry / log branch
Draft --> Approved : review
Approved --> Created : reject
Created --> Delivered : process
Delivered --> Pending : cancel
Delivered : entry / log branch
Draft --> Pending : revert
Pending --> [*]
@enduml