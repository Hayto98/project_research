@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
[*] --> Reviewed
Reviewed --> OnHold : approve
OnHold --> Closed : update
Closed --> Created : update
Created --> Rejected : confirm
Created : entry / log depot
Created --> OnHold : revert
Rejected --> [*]
@enduml