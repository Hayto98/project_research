@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
[*] --> Pending
Pending --> Active : confirm
Active --> Closed : cancel
Closed --> Rejected : update
Closed : entry / log deposit
Rejected --> OnHold : reject
OnHold --> [*]
@enduml