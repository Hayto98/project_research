@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
[*] --> Completed
Completed --> Cancelled : submit
Completed : entry / log order
Cancelled --> Reviewed : cancel
Reviewed --> Processing : update
Processing --> Archived : update
Archived --> Shipped : review
Cancelled --> Completed : revert
Shipped --> [*]
@enduml