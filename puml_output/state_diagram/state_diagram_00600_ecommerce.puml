@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
[*] --> Active
Active --> Closed : process
Closed --> Draft : submit
Draft --> Pending : submit
Draft : entry / log coupon
Pending --> Completed : confirm
Completed --> Shipped : review
Shipped --> [*]
