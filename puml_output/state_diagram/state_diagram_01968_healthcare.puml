@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
[*] --> Cancelled
Cancelled --> Approved : process
Approved --> Draft : approve
Draft --> Completed : approve
Completed --> Reviewed : review
Completed : entry / log doctor
Reviewed --> Closed : reject
Completed --> Draft : revert
Closed --> [*]
@enduml