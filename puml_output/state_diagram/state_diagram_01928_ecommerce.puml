@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
[*] --> OnHold
OnHold --> Completed : review
Completed --> Created : approve
Created --> Reviewed : cancel
Created : entry / log product
Reviewed --> Delivered : cancel
Delivered --> OnHold : revert
Delivered --> [*]
@enduml