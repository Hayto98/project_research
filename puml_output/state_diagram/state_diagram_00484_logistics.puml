@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
[*] --> Active
Active --> Shipped : update
Shipped --> Approved : approve
Approved --> Created : submit
Created --> Archived : confirm
Archived --> Reviewed : update
Archived : entry / log tracking
Active --> Shipped : revert
Reviewed --> [*]
@enduml