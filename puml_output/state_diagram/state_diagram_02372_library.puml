@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
[*] --> Draft
Draft --> Processing : update
Draft : entry / log member
Processing --> Approved : approve
Approved --> Completed : submit
Approved : entry / log member
Completed --> Cancelled : cancel
Cancelled --> Delivered : review
Delivered --> Completed : revert
Delivered --> [*]
@enduml