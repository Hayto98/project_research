@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
[*] --> Delivered
Delivered --> Rejected : submit
Rejected --> Created : submit
Created --> Completed : process
Completed --> Closed : confirm
Completed --> Created : revert
Closed --> [*]
@enduml