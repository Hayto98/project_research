@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
[*] --> Cancelled
Cancelled --> Rejected : update
Rejected --> Active : submit
Active --> Completed : approve
Completed --> Approved : submit
Completed : entry / log account
Cancelled --> Approved : revert
Approved --> [*]
@enduml