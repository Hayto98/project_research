@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
[*] --> Pending
Pending --> Processing : reject
Processing --> Completed : submit
Completed --> Rejected : submit
Completed : entry / log comment
Pending --> Rejected : revert
Rejected --> [*]
@enduml