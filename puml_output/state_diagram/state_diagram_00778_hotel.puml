@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
[*] --> Cancelled
Cancelled --> Delivered : review
Delivered --> Draft : submit
Draft --> Shipped : review
Draft : entry / log booking
Shipped --> Approved : update
Approved --> Archived : submit
Archived --> [*]
@enduml