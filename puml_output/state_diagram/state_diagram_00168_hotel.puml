@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
[*] --> Rejected
Rejected --> OnHold : confirm
OnHold --> Created : update
Created --> Delivered : reject
Created : entry / log invoice
Created --> Delivered : revert
Delivered --> [*]
@enduml