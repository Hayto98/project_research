@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
[*] --> Draft
Draft --> Pending : review
Draft : entry / log room
Pending --> Active : confirm
Active --> Closed : process
Closed --> Rejected : submit
Rejected --> Completed : update
Rejected : entry / log room
Completed --> [*]
@enduml