@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
[*] --> Draft
Draft --> Cancelled : confirm
Cancelled --> Pending : update
Cancelled : entry / log hospital
Pending --> Approved : submit
Approved --> Completed : cancel
Completed --> Active : approve
Active --> [*]
@enduml