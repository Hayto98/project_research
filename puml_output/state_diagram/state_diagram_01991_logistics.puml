@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
[*] --> Archived
Archived --> Reviewed : approve
Reviewed --> Pending : process
Pending --> Closed : confirm
Closed --> Draft : confirm
Draft --> Active : confirm
Draft : entry / log fuellog
Archived --> Pending : revert
Active --> [*]
@enduml