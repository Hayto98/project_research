@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
[*] --> OnHold
OnHold --> Reviewed : confirm
Reviewed --> Completed : process
Completed --> Pending : confirm
Pending --> Shipped : confirm
OnHold --> Shipped : revert
Shipped --> [*]
@enduml