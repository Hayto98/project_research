@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
[*] --> Completed
Completed --> Archived : process
Archived --> Active : confirm
Active --> Created : process
Created --> Rejected : approve
Completed --> Archived : revert
Rejected --> [*]
@enduml