@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
[*] --> OnHold
OnHold --> Rejected : process
Rejected --> Created : cancel
Created --> Cancelled : approve
Cancelled --> Pending : confirm
Pending --> Active : update
Pending : entry / log prescription
OnHold --> Rejected : revert
Active --> [*]
@enduml