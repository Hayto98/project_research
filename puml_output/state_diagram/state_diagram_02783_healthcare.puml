@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
[*] --> Rejected
Rejected --> Processing : update
Processing --> Pending : submit
Processing : entry / log treatment
Pending --> Reviewed : review
Reviewed --> Cancelled : review
Cancelled --> Active : cancel
Active --> [*]
@enduml