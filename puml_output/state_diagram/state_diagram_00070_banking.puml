@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
[*] --> Draft
Draft --> Archived : review
Archived --> Rejected : approve
Rejected --> Approved : submit
Approved --> Closed : approve
Approved : entry / log beneficiary
Closed --> Pending : reject
Pending --> Approved : revert
Pending --> [*]
@enduml