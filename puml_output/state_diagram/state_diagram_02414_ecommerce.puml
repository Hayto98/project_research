@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
[*] --> Active
Active --> Processing : submit
Processing --> Shipped : cancel
Shipped --> Created : cancel
Created --> Approved : reject
Approved --> Rejected : confirm
Active --> Shipped : revert
Rejected --> [*]
@enduml