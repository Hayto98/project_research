@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
[*] --> Created
Created --> Reviewed : approve
Reviewed --> Approved : cancel
Approved --> OnHold : approve
OnHold --> Completed : update
Completed --> Shipped : cancel
Shipped --> [*]
@enduml