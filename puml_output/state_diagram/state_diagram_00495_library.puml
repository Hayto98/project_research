@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
[*] --> Cancelled
Cancelled --> Processing : reject
Processing --> Reviewed : approve
Reviewed --> Draft : update
Reviewed : entry / log branch
Draft --> Completed : update
Draft : entry / log branch
Completed --> Delivered : review
Delivered --> [*]
@enduml