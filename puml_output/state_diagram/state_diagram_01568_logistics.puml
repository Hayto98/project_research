@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
[*] --> Active
Active --> Closed : review
Closed --> Rejected : submit
Rejected --> Shipped : cancel
Shipped --> Approved : confirm
Approved --> Delivered : submit
Approved : entry / log driver
Delivered --> [*]
@enduml