@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
[*] --> Closed
Closed --> Rejected : process
Rejected --> Delivered : confirm
Delivered --> Completed : process
Completed --> Reviewed : cancel
Completed : entry / log insurance
Reviewed --> Cancelled : update
Cancelled --> [*]
@enduml