@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
[*] --> Pending
Pending --> Processing : update
Processing --> Completed : confirm
Completed --> Approved : submit
Completed : entry / log department
Approved --> Closed : update
Closed --> OnHold : cancel
Closed --> Approved : revert
OnHold --> [*]
@enduml