@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
[*] --> Closed
Closed --> Draft : confirm
Draft --> Archived : review
Archived --> Active : process
Active --> Reviewed : update
Closed --> Active : revert
Reviewed --> [*]
@enduml