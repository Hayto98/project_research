@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
[*] --> Archived
Archived --> Created : process
Created --> Closed : approve
Closed --> Draft : review
Draft --> Pending : confirm
Pending --> Shipped : process
Pending : entry / log room
Shipped --> Created : revert
Shipped --> [*]
@enduml