@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
[*] --> Draft
Draft --> Completed : update
Completed --> Cancelled : submit
Cancelled --> Active : process
Active --> Shipped : review
Shipped --> Pending : process
Active --> Pending : revert
Pending --> [*]
@enduml