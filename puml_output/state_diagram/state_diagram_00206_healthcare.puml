@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
[*] --> Created
Created --> Shipped : update
Shipped --> Processing : confirm
Shipped : entry / log doctor
Processing --> Approved : submit
Approved --> Rejected : approve
Approved : entry / log doctor
Rejected --> Completed : cancel
Completed --> [*]
@enduml