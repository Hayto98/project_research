@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
[*] --> Active
Active --> Draft : confirm
Draft --> OnHold : cancel
OnHold --> Closed : approve
Closed --> Rejected : update
Closed : entry / log tracking
OnHold --> Draft : revert
Rejected --> [*]
@enduml