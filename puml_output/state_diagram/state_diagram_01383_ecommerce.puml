@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
[*] --> Archived
Archived --> Draft : update
Draft --> Reviewed : update
Reviewed --> Completed : reject
Completed --> Pending : submit
Pending --> Processing : reject
Pending : entry / log return
Processing --> [*]
@enduml