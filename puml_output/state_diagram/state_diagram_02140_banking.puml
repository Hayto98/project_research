@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
[*] --> Shipped
Shipped --> OnHold : confirm
OnHold --> Closed : submit
Closed --> Rejected : approve
Rejected --> Pending : approve
Rejected : entry / log transfer
Pending --> Shipped : revert
Pending --> [*]
@enduml