@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
[*] --> Approved
Approved --> OnHold : cancel
OnHold --> Created : update
Created --> Completed : review
Completed --> Rejected : update
Rejected --> Draft : confirm
Draft --> [*]
@enduml