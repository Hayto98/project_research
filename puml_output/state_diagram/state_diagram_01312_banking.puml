@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
[*] --> Draft
Draft --> Active : confirm
Active --> OnHold : reject
OnHold --> Rejected : cancel
Rejected --> Archived : process
Rejected --> Draft : revert
Archived --> [*]
@enduml