@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
[*] --> Pending
Pending --> Reviewed : submit
Reviewed --> Active : approve
Reviewed : entry / log depot
Active --> Created : approve
Created --> Cancelled : cancel
Cancelled --> OnHold : confirm
Cancelled --> Reviewed : revert
OnHold --> [*]
@enduml