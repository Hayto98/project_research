@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
[*] --> Closed
Closed --> Created : review
Closed : entry / log account
Created --> Pending : approve
Pending --> Delivered : submit
Pending --> Closed : revert
Delivered --> [*]
@enduml