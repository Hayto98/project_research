@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
[*] --> Shipped
Shipped --> Reviewed : reject
Reviewed --> Rejected : approve
Reviewed : entry / log patient
Rejected --> Completed : process
Completed --> Processing : review
Processing --> Completed : revert
Processing --> [*]
@enduml