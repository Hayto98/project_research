@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
[*] --> Closed
Closed --> Delivered : cancel
Delivered --> Pending : submit
Pending --> Approved : approve
Approved --> Created : submit
Approved : entry / log warehouse
Created --> Active : reject
Created : entry / log warehouse
Active --> [*]
