@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
[*] --> Pending
Pending --> Completed : reject
Completed --> Closed : cancel
Completed : entry / log department
Closed --> Rejected : process
Rejected --> OnHold : cancel
OnHold --> [*]
@enduml