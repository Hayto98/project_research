@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
[*] --> OnHold
OnHold --> Reviewed : submit
Reviewed --> Processing : review
Processing --> Created : process
Created --> Shipped : confirm
Shipped --> Draft : submit
Draft --> [*]
@enduml