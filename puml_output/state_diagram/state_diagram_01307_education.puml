@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
[*] --> Approved
Approved --> Draft : review
Draft --> Processing : reject
Processing --> Rejected : review
Rejected --> Closed : update
Closed --> Shipped : submit
Shipped --> Processing : revert
Shipped --> [*]
@enduml