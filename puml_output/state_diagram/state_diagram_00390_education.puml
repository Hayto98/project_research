@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
[*] --> OnHold
OnHold --> Shipped : update
OnHold : entry / log schedule
Shipped --> Rejected : submit
Rejected --> Draft : reject
Draft --> Reviewed : process
Reviewed --> [*]
@enduml