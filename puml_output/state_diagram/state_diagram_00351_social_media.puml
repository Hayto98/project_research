@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
[*] --> Pending
Pending --> Draft : review
Draft --> Created : review
Created --> OnHold : update
OnHold --> Approved : reject
Approved --> Pending : revert
Approved --> [*]
@enduml