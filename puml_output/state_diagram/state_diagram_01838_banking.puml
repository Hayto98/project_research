@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
[*] --> Archived
Archived --> Shipped : approve
Archived : entry / log withdrawal
Shipped --> Pending : confirm
Pending --> Completed : review
Completed --> Archived : revert
Completed --> [*]
@enduml