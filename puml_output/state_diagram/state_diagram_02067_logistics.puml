@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
[*] --> Active
Active --> Rejected : update
Rejected --> Archived : confirm
Archived --> Pending : process
Archived : entry / log tracking
Pending --> Rejected : revert
Pending --> [*]
@enduml