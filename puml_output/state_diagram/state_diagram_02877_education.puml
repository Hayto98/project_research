@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
[*] --> Shipped
Shipped --> Processing : review
Processing --> Reviewed : submit
Reviewed --> Approved : process
Reviewed : entry / log department
Approved --> Draft : reject
Draft --> Closed : confirm
Closed --> Processing : revert
Closed --> [*]
@enduml