@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
[*] --> Delivered
Delivered --> Completed : update
Completed --> Active : reject
Active --> Processing : cancel
Processing --> Rejected : cancel
Rejected --> Closed : reject
Rejected : entry / log reservation
Completed --> Closed : revert
Closed --> [*]
@enduml