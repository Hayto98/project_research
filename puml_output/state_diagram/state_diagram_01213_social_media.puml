@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
[*] --> Pending
Pending --> Created : confirm
Pending : entry / log profile
Created --> Rejected : approve
Rejected --> Reviewed : update
Reviewed --> Cancelled : confirm
Cancelled --> [*]
@enduml