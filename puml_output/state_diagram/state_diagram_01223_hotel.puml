@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
[*] --> Shipped
Shipped --> Created : process
Created --> Draft : submit
Draft --> Delivered : update
Draft : entry / log restaurant
Delivered --> Closed : approve
Closed --> Reviewed : cancel
Reviewed --> [*]
@enduml