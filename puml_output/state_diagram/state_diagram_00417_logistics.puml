@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
[*] --> Completed
Completed --> Reviewed : submit
Completed : entry / log deliverynote
Reviewed --> Shipped : cancel
Shipped --> Closed : process
Closed --> OnHold : cancel
Shipped --> Completed : revert
OnHold --> [*]
@enduml