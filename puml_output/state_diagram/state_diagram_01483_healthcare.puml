@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
[*] --> Delivered
Delivered --> Processing : reject
Processing --> Created : approve
Created --> Draft : process
Draft --> Pending : update
Pending --> Reviewed : reject
Draft --> Reviewed : revert
Reviewed --> [*]
@enduml