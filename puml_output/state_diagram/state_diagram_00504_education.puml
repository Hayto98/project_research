@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
[*] --> Active
Active --> OnHold : cancel
OnHold --> Approved : approve
Approved --> Closed : submit
Closed --> Pending : update
Closed --> Pending : revert
Pending --> [*]
@enduml