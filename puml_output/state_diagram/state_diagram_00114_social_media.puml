@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
[*] --> Shipped
Shipped --> Archived : submit
Shipped : entry / log hashtag
Archived --> Draft : approve
Draft --> Completed : review
Completed --> Cancelled : review
Cancelled --> Closed : reject
Closed --> [*]
@enduml