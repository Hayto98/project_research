@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
[*] --> Completed
Completed --> Active : process
Active --> Cancelled : review
Cancelled --> Rejected : process
Rejected --> Approved : cancel
Approved --> Closed : cancel
Closed --> Approved : revert
Closed --> [*]
@enduml