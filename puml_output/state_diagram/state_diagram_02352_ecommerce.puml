@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
[*] --> OnHold
OnHold --> Rejected : submit
OnHold : entry / log invoice
Rejected --> Created : submit
Created --> Archived : review
Archived --> Approved : cancel
Approved --> Reviewed : process
Reviewed --> [*]
@enduml