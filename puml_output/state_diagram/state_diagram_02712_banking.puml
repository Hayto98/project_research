@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
[*] --> Archived
Archived --> Reviewed : review
Reviewed --> Draft : reject
Draft --> Completed : reject
Completed --> Rejected : confirm
Completed : entry / log withdrawal
Rejected --> Active : cancel
Rejected : entry / log withdrawal
Active --> Draft : revert
Active --> [*]
@enduml