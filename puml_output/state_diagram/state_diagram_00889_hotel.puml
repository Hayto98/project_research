@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
[*] --> Closed
Closed --> Processing : approve
Closed : entry / log guest
Processing --> Pending : process
Pending --> OnHold : approve
OnHold --> Completed : cancel
OnHold --> Pending : revert
Completed --> [*]
@enduml