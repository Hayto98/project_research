@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
[*] --> Archived
Archived --> Created : update
Created --> Approved : submit
Approved --> Delivered : review
Delivered --> Completed : review
Completed --> Processing : process
Completed : entry / log manifest
Created --> Processing : revert
Processing --> [*]
@enduml