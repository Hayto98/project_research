@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
[*] --> Pending
Pending --> Completed : approve
Completed --> Cancelled : review
Completed : entry / log checkin
Cancelled --> Processing : confirm
Processing --> OnHold : reject
OnHold --> [*]
@enduml