@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
[*] --> Cancelled
Cancelled --> Completed : review
Completed --> Processing : approve
Completed : entry / log profile
Processing --> Draft : process
Draft --> Archived : cancel
Archived --> Closed : process
Closed --> [*]
@enduml