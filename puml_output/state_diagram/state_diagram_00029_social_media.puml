@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
[*] --> OnHold
OnHold --> Rejected : cancel
Rejected --> Created : update
Created --> Reviewed : submit
Reviewed --> Closed : reject
Reviewed : entry / log notification
OnHold --> Created : revert
Closed --> [*]
@enduml