@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
[*] --> Delivered
Delivered --> Created : cancel
Created --> Pending : confirm
Created : entry / log amenity
Pending --> Archived : reject
Archived --> Approved : approve
Archived : entry / log amenity
Approved --> [*]
@enduml