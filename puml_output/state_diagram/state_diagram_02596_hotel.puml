@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
[*] --> Closed
Closed --> Reviewed : process
Reviewed --> Approved : reject
Approved --> Active : process
Active --> Created : submit
Created --> Shipped : cancel
Created : entry / log checkout
Active --> Approved : revert
Shipped --> [*]
@enduml