@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
[*] --> Created
Created --> Shipped : reject
Created : entry / log checkin
Shipped --> Closed : approve
Closed --> Draft : approve
Draft --> Reviewed : submit
Reviewed --> Completed : cancel
Completed --> [*]
@enduml