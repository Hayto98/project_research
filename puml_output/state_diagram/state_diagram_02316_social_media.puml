@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
[*] --> Cancelled
Cancelled --> Pending : confirm
Pending --> Reviewed : process
Reviewed --> Active : approve
Reviewed : entry / log user
Active --> Closed : reject
Closed --> [*]
@enduml