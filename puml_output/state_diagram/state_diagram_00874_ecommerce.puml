@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
[*] --> Delivered
Delivered --> Reviewed : submit
Reviewed --> Closed : update
Closed --> Approved : submit
Closed : entry / log shipment
Approved --> Active : submit
Active --> Processing : process
Processing --> [*]
@enduml