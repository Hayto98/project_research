@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
[*] --> Closed
Closed --> Cancelled : approve
Cancelled --> Created : process
Created --> Completed : process
Completed --> Processing : reject
Completed : entry / log user
Processing --> Pending : update
Pending --> [*]
@enduml