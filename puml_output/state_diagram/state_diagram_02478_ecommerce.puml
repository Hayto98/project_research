@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
[*] --> Reviewed
Reviewed --> OnHold : confirm
OnHold --> Processing : process
OnHold : entry / log payment
Processing --> Active : update
Active --> Cancelled : submit
Cancelled --> Closed : reject
Closed --> [*]
@enduml