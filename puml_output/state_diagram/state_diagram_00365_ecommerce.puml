@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
[*] --> Archived
Archived --> Delivered : cancel
Delivered --> Completed : update
Delivered : entry / log order
Completed --> Closed : reject
Closed --> Draft : confirm
Draft --> Processing : process
Processing --> [*]
@enduml