@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
[*] --> Created
Created --> Closed : confirm
Closed --> Completed : submit
Completed --> Draft : update
Completed : entry / log reservation
Draft --> Reviewed : reject
Reviewed --> [*]
@enduml