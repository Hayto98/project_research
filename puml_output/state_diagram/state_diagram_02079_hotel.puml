@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
[*] --> Cancelled
Cancelled --> Active : confirm
Cancelled : entry / log amenity
Active --> Rejected : confirm
Rejected --> Delivered : submit
Delivered --> Pending : process
Delivered --> Cancelled : revert
Pending --> [*]
@enduml