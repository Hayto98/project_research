@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
participant "Chef" as C
control "Receptionist" as R
participant "Guest" as G
R --> G : Cancel Reservation
C ->> R : Order Room Service
C -> G : Check In
activate G
G --> C : ACK
deactivate G
C -> G : Clean Room
note over G : processing clean room
R ->> G : Process Payment
R --> G : Request Service
@enduml