@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
entity "Moderator" as M
actor "Admin" as A
boundary "User" as U
M --> A : Edit Profile
A ->> M : Report Content
note over M : processing report content
U ->> M : Follow User
U --> A : Like Post
activate A
A --> U : ACK
deactivate A
U --> A : Share Post
note over A : processing share post
U -> M : Create Post
@enduml