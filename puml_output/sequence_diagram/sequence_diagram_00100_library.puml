@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
actor "Admin" as A
actor "Member" as M
participant "Librarian" as L
A -> L : Search Catalog
A -> L : Return Book
note over L : processing return book
M --> L : Add New Book
A ->> L : Borrow Book
@enduml