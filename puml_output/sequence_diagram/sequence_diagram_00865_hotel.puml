@startuml
skinparam shadowing true
entity "Chef" as C
entity "Guest" as G
boundary "Housekeeper" as H
entity "Receptionist" as R
control "Manager" as M
G ->> H : Clean Room
activate H
H --> G : ACK
deactivate H
G --> H : Order Room Service
activate H
H --> G : ACK
deactivate H
C --> H : Check In
note over H : processing check in
R -> H : Request Service
H ->> M : Book Room
activate M
M --> H : ACK
deactivate M
R ->> H : Cancel Reservation
@enduml