@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
actor "Student" as S
boundary "Admin" as A
participant "Registrar" as R
R --> A : Grade Exam
activate A
A --> R : ACK
deactivate A
R ->> S : Submit Assignment
S -> A : Take Attendance
note over A : processing take attendance
S --> A : Enroll Course
S ->> A : Borrow Book
S --> A : Issue Certificate
note over A : processing issue certificate
@enduml