@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
control "Driver" as D
participant "Warehouse Staff" as WS
entity "Dispatcher" as D2
WS --> D2 : Update Inventory
WS --> D2 : Schedule Pickup
WS ->> D2 : Assign Route
WS -> D : Deliver Package
note over D : processing deliver package
D --> WS : Load Package
D2 ->> D : Track Shipment
@enduml