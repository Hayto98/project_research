@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
entity "Fleet Manager" as FM
participant "Dispatcher" as D
participant "Customer" as C
FM ->> C : Track Shipment
D -> C : Deliver Package
C -> D : Fuel Vehicle
FM -> C : Load Package
note over C : processing load package
FM --> D : Report Issue
@enduml