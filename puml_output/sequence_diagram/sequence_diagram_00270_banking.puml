@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
actor "Account Holder" as AH
entity "ATM" as A
actor "Branch Manager" as BM
participant "Bank Teller" as BT
actor "Auditor" as A2
BT -> A2 : Pay Bill
activate A2
A2 --> BT : ACK
deactivate A2
A2 --> BM : Deposit Money
activate BM
BM --> A2 : ACK
deactivate BM
AH --> A : View Statement
A --> AH : Open Account
activate AH
AH --> A : ACK
deactivate AH
@enduml