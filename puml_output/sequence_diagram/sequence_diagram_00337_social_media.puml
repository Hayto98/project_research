@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
actor "Admin" as A
actor "Moderator" as M
actor "Advertiser" as A2
A2 -> M : Follow User
A -> A2 : Share Post
activate A2
A2 --> A : ACK
deactivate A2
A -> M : Report Content
A2 ->> A : Comment
A2 ->> A : Create Post
activate A
A --> A2 : ACK
deactivate A
A2 --> M : Send Message
activate M
M --> A2 : ACK
deactivate M
@enduml