@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
entity "Moderator" as M
control "User" as U
participant "Advertiser" as A
control "Admin" as A2
A2 --> U : Follow User
M --> A : Edit Profile
note over A : processing edit profile
A --> M : Share Post
note over M : processing share post
A -> M : Create Post
note over M : processing create post
U --> A : Like Post
note over A : processing like post
A -> U : Send Message
note over U : processing send message
A -> U : Comment
note over U : processing comment
@enduml