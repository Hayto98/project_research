@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
actor "Receptionist" as R
control "Housekeeper" as H
control "Chef" as C
C --> R : Check Out
activate R
R --> C : ACK
deactivate R
C -> H : Cancel Reservation
C ->> H : Process Payment
H ->> R : Check In
H ->> R : Clean Room
R -> C : Order Room Service
activate C
C --> R : ACK
deactivate C
C --> R : Request Service
@enduml