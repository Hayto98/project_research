@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
entity "Warehouse Staff" as WS
entity "Fleet Manager" as FM
participant "Customer" as C
WS ->> C : Assign Route
activate C
C --> WS : ACK
deactivate C
FM ->> C : Deliver Package
activate C
C --> FM : ACK
deactivate C
FM ->> WS : Report Issue
C ->> WS : Fuel Vehicle
@enduml