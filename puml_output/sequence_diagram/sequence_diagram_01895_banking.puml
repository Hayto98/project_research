@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
boundary "Account Holder" as AH
boundary "ATM" as A
participant "Auditor" as A2
boundary "Bank Teller" as BT
participant "Branch Manager" as BM
BT --> BM : Pay Bill
note over BM : processing pay bill
A2 ->> BM : Deposit Money
activate BM
BM --> A2 : ACK
deactivate BM
A -> BM : Transfer Funds
activate BM
BM --> A : ACK
deactivate BM
AH --> A2 : Withdraw Cash
AH --> BM : Open Account
AH ->> A : Block Card
@enduml