@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
control "User" as U
boundary "Admin" as A
entity "Advertiser" as A2
participant "Moderator" as M
M -> U : Share Post
note over U : processing share post
M --> A : Comment
note over A : processing comment
A2 -> A : Follow User
activate A
A --> A2 : ACK
deactivate A
M ->> U : Edit Profile
activate U
U --> M : ACK
deactivate U
U ->> A : Like Post
A --> A2 : Report Content
activate A2
A2 --> A : ACK
deactivate A2
@enduml