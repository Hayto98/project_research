@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
entity "User" as U
boundary "Advertiser" as A
boundary "Moderator" as M
M -> A : Edit Profile
A ->> M : Send Message
activate M
M --> A : ACK
deactivate M
M -> U : Report Content
M -> A : Follow User
activate A
A --> M : ACK
deactivate A
U ->> A : Share Post
activate A
A --> U : ACK
deactivate A
U --> A : Comment
activate A
A --> U : ACK
deactivate A
@enduml