@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
control "Admin" as A
participant "User" as U
participant "Advertiser" as A2
participant "Moderator" as M
U -> A2 : Like Post
activate A2
A2 --> U : ACK
deactivate A2
M --> A : Edit Profile
A --> M : Share Post
U ->> A2 : Comment
note over A2 : processing comment
@enduml