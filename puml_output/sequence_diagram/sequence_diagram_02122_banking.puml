@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
control "ATM" as A
boundary "Auditor" as A2
actor "Bank Teller" as BT
actor "Branch Manager" as BM
control "Account Holder" as AH
AH --> BT : View Statement
activate BT
BT --> AH : ACK
deactivate BT
BM --> AH : Open Account
activate AH
AH --> BM : ACK
deactivate AH
BT ->> AH : Transfer Funds
activate AH
AH --> BT : ACK
deactivate AH
A --> BM : Deposit Money
activate BM
BM --> A : ACK
deactivate BM
BM ->> BT : Block Card
@enduml