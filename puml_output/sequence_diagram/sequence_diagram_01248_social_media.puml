@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
participant "Advertiser" as A
control "User" as U
control "Admin" as A2
actor "Moderator" as M
A2 -> M : Share Post
M ->> U : Comment
activate U
U --> M : ACK
deactivate U
U -> M : Send Message
A2 ->> U : Report Content
A2 -> A : Create Post
activate A
A --> A2 : ACK
deactivate A
@enduml