@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
actor "Warehouse Staff" as WS
participant "Dispatcher" as D
actor "Driver" as D2
actor "Fleet Manager" as FM
WS ->> D2 : Track Shipment
FM ->> D : Deliver Package
D2 -> D : Fuel Vehicle
activate D
D --> D2 : ACK
deactivate D
D2 ->> FM : Load Package
activate FM
FM --> D2 : ACK
deactivate FM
WS ->> D : Schedule Pickup
D2 ->> D : Report Issue
note over D : processing report issue
@enduml