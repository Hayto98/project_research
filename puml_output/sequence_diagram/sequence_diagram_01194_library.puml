@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
boundary "Librarian" as L
actor "Admin" as A
actor "Member" as M
L ->> A : Pay Fine
activate A
A --> L : ACK
deactivate A
M --> L : Renew Loan
note over L : processing renew loan
M --> L : Reserve Book
A ->> L : Add New Book
L ->> M : Return Book
note over M : processing return book
@enduml