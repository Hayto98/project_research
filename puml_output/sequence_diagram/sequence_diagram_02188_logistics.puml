@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
participant "Driver" as D
control "Fleet Manager" as FM
participant "Warehouse Staff" as WS
actor "Customer" as C
FM --> D : Update Inventory
note over D : processing update inventory
C ->> FM : Assign Route
activate FM
FM --> C : ACK
deactivate FM
D ->> FM : Report Issue
note over FM : processing report issue
C -> D : Track Shipment
D --> C : Deliver Package
@enduml