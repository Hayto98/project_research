@startuml
skinparam monochrome true
skinparam shadowing true
entity "Warehouse Staff" as WS
entity "Fleet Manager" as FM
participant "Customer" as C
boundary "Driver" as D
C --> WS : Update Inventory
activate WS
WS --> C : ACK
deactivate WS
C --> FM : Fuel Vehicle
D ->> C : Assign Route
FM ->> C : Schedule Pickup
@enduml