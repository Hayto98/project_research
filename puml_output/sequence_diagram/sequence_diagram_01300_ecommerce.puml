@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
boundary "Customer" as C
entity "Admin" as A
participant "Seller" as S
S ->> A : Track Order
note over A : processing track order
S ->> C : Cancel Order
S ->> C : Write Review
A ->> C : Browse Products
S --> A : Checkout
activate A
A --> S : ACK
deactivate A
note over A : processing checkout
@enduml