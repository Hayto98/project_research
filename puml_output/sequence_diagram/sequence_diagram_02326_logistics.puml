@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
entity "Warehouse Staff" as WS
entity "Dispatcher" as D
control "Driver" as D2
actor "Fleet Manager" as FM
control "Customer" as C
D2 ->> WS : Report Issue
D2 --> C : Load Package
activate C
C --> D2 : ACK
deactivate C
note over C : processing load package
D2 ->> D : Update Inventory
note over D : processing update inventory
C -> D : Deliver Package
activate D
D --> C : ACK
deactivate D
FM ->> D : Fuel Vehicle
activate D
D --> FM : ACK
deactivate D
WS --> D2 : Assign Route
activate D2
D2 --> WS : ACK
deactivate D2
FM ->> D2 : Schedule Pickup
activate D2
D2 --> FM : ACK
deactivate D2
@enduml