@startuml
skinparam shadowing true
control "Advertiser" as A
participant "User" as U
boundary "Admin" as A2
entity "Moderator" as M
U -> A : Share Post
U ->> M : Create Post
U ->> M : Send Message
activate M
M --> U : ACK
deactivate M
A2 -> A : Comment
M ->> A2 : Report Content
A ->> M : Like Post
A -> M : Edit Profile
@enduml