@startuml
skinparam shadowing true
entity "Admin" as A
actor "Librarian" as L
entity "Member" as M
M --> A : Reserve Book
activate A
A --> M : ACK
deactivate A
A --> L : Pay Fine
note over L : processing pay fine
M --> L : Return Book
A --> L : Borrow Book
activate L
L --> A : ACK
deactivate L
@enduml