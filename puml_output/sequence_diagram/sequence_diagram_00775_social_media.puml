@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
actor "Admin" as A
boundary "User" as U
control "Advertiser" as A2
A2 ->> U : Report Content
U --> A2 : Send Message
A2 -> U : Edit Profile
activate U
U --> A2 : ACK
deactivate U
A2 ->> U : Share Post
A2 ->> A : Like Post
@enduml