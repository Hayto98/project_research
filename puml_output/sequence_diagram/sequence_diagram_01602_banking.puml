@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
control "Branch Manager" as BM
control "ATM" as A
control "Account Holder" as AH
entity "Auditor" as A2
BM ->> AH : Withdraw Cash
A -> AH : Deposit Money
activate AH
AH --> A : ACK
deactivate AH
AH ->> BM : Transfer Funds
activate BM
BM --> AH : ACK
deactivate BM
AH ->> A2 : View Statement
BM -> A2 : Pay Bill
@enduml