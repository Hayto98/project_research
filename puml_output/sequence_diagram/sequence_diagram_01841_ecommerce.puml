@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
control "Customer" as C
control "Seller" as S
entity "Delivery Service" as DS
boundary "Payment Gateway" as PG
C ->> DS : Cancel Order
S -> DS : Manage Inventory
activate DS
DS --> S : ACK
deactivate DS
DS --> C : Apply Coupon
activate C
C --> DS : ACK
deactivate C
note over C : processing apply coupon
C ->> PG : Write Review
activate PG
PG --> C : ACK
deactivate PG
@enduml