@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
entity "Admin" as A
control "Member" as M
control "Librarian" as L
L --> A : Reserve Book
activate A
A --> L : ACK
deactivate A
M -> L : Borrow Book
A --> L : Pay Fine
activate L
L --> A : ACK
deactivate L
M ->> A : Register Member
L ->> M : Search Catalog
activate M
M --> L : ACK
deactivate M
note over M : processing search catalog
L ->> M : Renew Loan
A ->> M : Add New Book
activate M
M --> A : ACK
deactivate M
@enduml