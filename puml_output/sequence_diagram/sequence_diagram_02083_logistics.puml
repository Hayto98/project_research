@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
participant "Driver" as D
boundary "Customer" as C
entity "Fleet Manager" as FM
actor "Warehouse Staff" as WS
boundary "Dispatcher" as D2
D ->> WS : Assign Route
note over WS : processing assign route
D2 -> D : Fuel Vehicle
note over D : processing fuel vehicle
D --> FM : Update Inventory
FM --> WS : Report Issue
note over WS : processing report issue
C ->> FM : Schedule Pickup
@enduml