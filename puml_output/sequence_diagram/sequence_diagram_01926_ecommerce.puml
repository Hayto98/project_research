@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
participant "Delivery Service" as DS
actor "Seller" as S
entity "Customer" as C
entity "Payment Gateway" as PG
actor "Admin" as A
DS -> C : Checkout
note over C : processing checkout
C ->> S : Add To Cart
DS ->> PG : Browse Products
PG --> S : Make Payment
A ->> DS : Apply Coupon
activate DS
DS --> A : ACK
deactivate DS
A -> S : Track Order
note over S : processing track order
@enduml