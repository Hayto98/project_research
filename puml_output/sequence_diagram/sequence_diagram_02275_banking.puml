@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
entity "Auditor" as A
entity "ATM" as A2
entity "Branch Manager" as BM
entity "Bank Teller" as BT
A2 ->> A : View Statement
A ->> A2 : Pay Bill
BM ->> A : Open Account
BM -> A2 : Apply For Loan
A --> A2 : Transfer Funds
note over A2 : processing transfer funds
BM ->> BT : Deposit Money
note over BT : processing deposit money
@enduml