@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
boundary "Student" as S
participant "Registrar" as R
entity "Librarian" as L
S --> R : Enroll Course
activate R
R --> S : ACK
deactivate R
R -> S : Register Student
note over S : processing register student
R ->> S : View Schedule
note over S : processing view schedule
R --> S : Issue Certificate
S -> L : Take Attendance
@enduml