@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
actor "ATM" as A
actor "Account Holder" as AH
participant "Branch Manager" as BM
entity "Bank Teller" as BT
actor "Auditor" as A2
AH -> BT : Apply For Loan
activate BT
BT --> AH : ACK
deactivate BT
A2 --> BT : Withdraw Cash
BM -> AH : Pay Bill
A2 -> AH : Open Account
activate AH
AH --> A2 : ACK
deactivate AH
A2 -> AH : Transfer Funds
@enduml