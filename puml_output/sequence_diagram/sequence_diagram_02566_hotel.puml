@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
control "Housekeeper" as H
actor "Receptionist" as R
control "Manager" as M
H ->> M : Request Service
activate M
M --> H : ACK
deactivate M
M -> R : Order Room Service
activate R
R --> M : ACK
deactivate R
H --> R : Process Payment
H -> M : Book Room
M -> R : Clean Room
activate R
R --> M : ACK
deactivate R
@enduml