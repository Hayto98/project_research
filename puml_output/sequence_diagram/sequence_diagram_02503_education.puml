@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
actor "Student" as S
actor "Librarian" as L
participant "Admin" as A
control "Teacher" as T
A --> L : Submit Assignment
S ->> A : Issue Certificate
A -> L : Register Student
activate L
L --> A : ACK
deactivate L
S --> L : Take Attendance
note over L : processing take attendance
L -> S : Enroll Course
@enduml