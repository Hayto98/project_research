@startuml
skinparam monochrome true
actor "Chef" as C
boundary "Manager" as M
actor "Receptionist" as R
control "Housekeeper" as H
R --> H : Request Service
activate H
H --> R : ACK
deactivate H
M -> C : Clean Room
activate C
C --> M : ACK
deactivate C
note over C : processing clean room
H ->> M : Process Payment
C --> H : Check In
@enduml