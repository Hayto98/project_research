@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
entity "Member" as M
entity "Admin" as A
boundary "Librarian" as L
M ->> A : Return Book
activate A
A --> M : ACK
deactivate A
M ->> L : Register Member
activate L
L --> M : ACK
deactivate L
A ->> M : Search Catalog
note over M : processing search catalog
A --> M : Add New Book
note over M : processing add new book
@enduml