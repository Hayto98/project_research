@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
actor "Receptionist" as R
participant "Manager" as M
boundary "Housekeeper" as H
boundary "Guest" as G
boundary "Chef" as C
R --> G : Book Room
activate G
G --> R : ACK
deactivate G
G -> M : Order Room Service
R ->> H : Clean Room
note over H : processing clean room
C -> G : Check Out
activate G
G --> C : ACK
deactivate G
C --> G : Process Payment
M -> G : Check In
@enduml