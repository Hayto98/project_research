@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
entity "Receptionist" as R
actor "Chef" as C
boundary "Manager" as M
boundary "Guest" as G
G --> R : Cancel Reservation
R --> G : Check In
C ->> G : Request Service
activate G
G --> C : ACK
deactivate G
M --> R : Clean Room
M -> R : Check Out
G -> R : Process Payment
@enduml