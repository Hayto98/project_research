@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
actor "Seller" as S
entity "Customer" as C
entity "Payment Gateway" as PG
entity "Admin" as A
PG -> A : Track Order
activate A
A --> PG : ACK
deactivate A
PG -> C : Browse Products
activate C
C --> PG : ACK
deactivate C
S --> C : Write Review
activate C
C --> S : ACK
deactivate C
A ->> C : Apply Coupon
activate C
C --> A : ACK
deactivate C
@enduml