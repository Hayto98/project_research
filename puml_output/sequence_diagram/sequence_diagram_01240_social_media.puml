@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
boundary "Advertiser" as A
actor "Moderator" as M
actor "Admin" as A2
actor "User" as U
A2 ->> M : Share Post
M --> U : Comment
note over U : processing comment
A2 -> M : Follow User
A2 -> A : Create Post
activate A
A --> A2 : ACK
deactivate A
note over A : processing create post
@enduml