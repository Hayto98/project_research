@startuml
skinparam monochrome true
skinparam defaultFontSize 13
actor "Housekeeper" as H
participant "Receptionist" as R
participant "Guest" as G
control "Chef" as C
G ->> H : Clean Room
R ->> G : Order Room Service
C --> R : Check Out
activate R
R --> C : ACK
deactivate R
H ->> R : Process Payment
C -> R : Request Service
activate R
R --> C : ACK
deactivate R
@enduml