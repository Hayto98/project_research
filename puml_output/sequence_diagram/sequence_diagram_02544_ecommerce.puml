@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
participant "Admin" as A
entity "Customer" as C
control "Payment Gateway" as PG
control "Delivery Service" as DS
participant "Seller" as S
S -> DS : Write Review
note over DS : processing write review
DS --> A : Apply Coupon
activate A
A --> DS : ACK
deactivate A
DS --> A : Add To Cart
A -> S : Manage Inventory
activate S
S --> A : ACK
deactivate S
S --> C : Browse Products
DS ->> PG : Checkout
activate PG
PG --> DS : ACK
deactivate PG
@enduml