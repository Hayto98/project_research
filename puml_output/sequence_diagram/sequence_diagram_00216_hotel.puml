@startuml
skinparam defaultFontSize 11
control "Guest" as G
entity "Manager" as M
control "Housekeeper" as H
control "Receptionist" as R
participant "Chef" as C
C -> G : Process Payment
R --> G : Cancel Reservation
note over G : processing cancel reservation
R --> H : Book Room
G --> H : Order Room Service
activate H
H --> G : ACK
deactivate H
@enduml