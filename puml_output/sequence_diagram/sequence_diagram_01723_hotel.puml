@startuml
skinparam monochrome true
skinparam ArrowColor #555555
control "Guest" as G
boundary "Receptionist" as R
participant "Chef" as C
G ->> R : Request Service
activate R
R --> G : ACK
deactivate R
note over R : processing request service
G -> C : Check In
note over C : processing check in
C --> R : Process Payment
activate R
R --> C : ACK
deactivate R
G ->> C : Cancel Reservation
activate C
C --> G : ACK
deactivate C
R ->> C : Book Room
R -> G : Check Out
@enduml