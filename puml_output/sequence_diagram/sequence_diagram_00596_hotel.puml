@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
actor "Chef" as C
actor "Manager" as M
entity "Guest" as G
boundary "Housekeeper" as H
actor "Receptionist" as R
M --> G : Order Room Service
note over G : processing order room service
R ->> M : Check In
R -> G : Check Out
G -> C : Clean Room
C -> R : Process Payment
activate R
R --> C : ACK
deactivate R
note over R : processing process payment
@enduml