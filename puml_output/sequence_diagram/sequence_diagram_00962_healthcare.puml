@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
participant "Patient" as P
control "Lab Technician" as LT
entity "Receptionist" as R
P --> LT : Discharge Patient
P -> R : Book Appointment
note over R : processing book appointment
R ->> P : Issue Prescription
P --> R : Process Insurance Claim
activate R
R --> P : ACK
deactivate R
@enduml