@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
participant "Librarian" as L
actor "Registrar" as R
participant "Parent" as P
control "Admin" as A
control "Teacher" as T
T ->> A : Grade Exam
L --> A : View Schedule
A ->> L : Enroll Course
A --> T : Borrow Book
R -> P : Register Student
activate P
P --> R : ACK
deactivate P
T -> L : Submit Assignment
note over L : processing submit assignment
L ->> T : Issue Certificate
@enduml