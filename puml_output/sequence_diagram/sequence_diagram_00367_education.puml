@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
actor "Teacher" as T
participant "Admin" as A
participant "Librarian" as L
participant "Parent" as P
A -> T : Submit Assignment
P --> A : Grade Exam
activate A
A --> P : ACK
deactivate A
T --> A : Take Attendance
L --> T : View Schedule
@enduml