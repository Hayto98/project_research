@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
actor "Teacher" as T
actor "Parent" as P
entity "Admin" as A
entity "Registrar" as R
participant "Student" as S
S --> R : Register Student
activate R
R --> S : ACK
deactivate R
