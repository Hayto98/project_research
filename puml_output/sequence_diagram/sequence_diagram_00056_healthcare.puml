@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
control "Receptionist" as R
entity "Lab Technician" as LT
control "Nurse" as N
actor "Doctor" as D
LT -> R : Book Appointment
D -> LT : Process Insurance Claim
N --> LT : Update Medical Record
R --> D : Issue Prescription
D --> R : Examine Patient
N --> LT : Run Lab Test
@enduml