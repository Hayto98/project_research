@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
control "ATM" as A
participant "Bank Teller" as BT
control "Auditor" as A2
BT -> A : Withdraw Cash
note over A : processing withdraw cash
A --> A2 : Apply For Loan
note over A2 : processing apply for loan
A ->> A2 : Open Account
BT --> A2 : Transfer Funds
@enduml