@startuml
skinparam monochrome true
skinparam ArrowColor #555555
entity "Lab Technician" as LT
entity "Patient" as P
entity "Doctor" as D
D --> P : Run Lab Test
activate P
P --> D : ACK
deactivate P
P -> D : Book Appointment
activate D
D --> P : ACK
deactivate D
P ->> LT : Process Insurance Claim
note over LT : processing process insurance claim
LT --> P : Discharge Patient
D --> LT : Examine Patient
@enduml