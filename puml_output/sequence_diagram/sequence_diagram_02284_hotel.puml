@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
control "Guest" as G
actor "Housekeeper" as H
actor "Manager" as M
control "Receptionist" as R
H --> G : Book Room
note over G : processing book room
R -> M : Process Payment
H --> M : Order Room Service
note over M : processing order room service
M --> G : Check Out
H -> M : Clean Room
activate M
M --> H : ACK
deactivate M
note over M : processing clean room
M --> H : Cancel Reservation
@enduml