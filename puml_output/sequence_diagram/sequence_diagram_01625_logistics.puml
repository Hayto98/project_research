@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
participant "Fleet Manager" as FM
participant "Warehouse Staff" as WS
entity "Customer" as C
FM -> WS : Report Issue
C ->> FM : Update Inventory
note over FM : processing update inventory
FM -> C : Track Shipment
activate C
C --> FM : ACK
deactivate C
note over C : processing track shipment
C --> WS : Load Package
FM ->> C : Deliver Package
WS ->> C : Schedule Pickup
activate C
C --> WS : ACK
deactivate C
@enduml