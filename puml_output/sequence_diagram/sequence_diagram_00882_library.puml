@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
boundary "Admin" as A
boundary "Librarian" as L
participant "Member" as M
M -> L : Borrow Book
note over L : processing borrow book
A -> L : Reserve Book
M --> L : Register Member
note over L : processing register member
M --> L : Add New Book
activate L
L --> M : ACK
deactivate L
note over L : processing add new book
@enduml