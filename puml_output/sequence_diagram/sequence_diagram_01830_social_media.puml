@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
participant "User" as U
actor "Advertiser" as A
boundary "Admin" as A2
participant "Moderator" as M
U ->> A : Comment
activate A
A --> U : ACK
deactivate A
U --> A2 : Send Message
U ->> M : Follow User
note over M : processing follow user
M ->> A2 : Create Post
@enduml