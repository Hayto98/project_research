@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
control "Housekeeper" as H
actor "Guest" as G
entity "Chef" as C
H --> G : Clean Room
H ->> C : Check Out
activate C
C --> H : ACK
deactivate C
C ->> H : Check In
G --> C : Cancel Reservation
G -> H : Order Room Service
note over H : processing order room service
H --> C : Request Service
@enduml