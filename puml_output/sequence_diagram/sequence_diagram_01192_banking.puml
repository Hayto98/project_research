@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
control "Auditor" as A
participant "Account Holder" as AH
actor "ATM" as A2
AH --> A : Transfer Funds
activate A
A --> AH : ACK
deactivate A
note over A : processing transfer funds
A -> AH : Block Card
note over AH : processing block card
AH --> A : View Statement
note over A : processing view statement
A --> AH : Open Account
A --> AH : Deposit Money
@enduml