@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
actor "Admin" as A
entity "Member" as M
participant "Librarian" as L
A -> M : Renew Loan
activate M
M --> A : ACK
deactivate M
L ->> M : Register Member
activate M
M --> L : ACK
deactivate M
L --> A : Reserve Book
A -> M : Search Catalog
L -> M : Add New Book
activate M
M --> L : ACK
deactivate M
L --> M : Pay Fine
@enduml