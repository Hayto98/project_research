@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
boundary "Admin" as A
actor "Member" as M
participant "Librarian" as L
A -> L : Search Catalog
note over L : processing search catalog
M --> A : Return Book
A --> M : Borrow Book
activate M
M --> A : ACK
deactivate M
L -> M : Register Member
L --> A : Pay Fine
@enduml