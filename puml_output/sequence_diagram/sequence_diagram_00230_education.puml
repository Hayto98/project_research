@startuml
skinparam shadowing true
actor "Parent" as P
entity "Teacher" as T
boundary "Registrar" as R
control "Admin" as A
control "Librarian" as L
T ->> P : Register Student
activate P
P --> T : ACK
deactivate P
R ->> T : Issue Certificate
note over T : processing issue certificate
P ->> R : Borrow Book
A ->> T : Enroll Course
@enduml