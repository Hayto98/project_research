@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
control "Customer" as C
participant "Payment Gateway" as PG
entity "Admin" as A
entity "Seller" as S
participant "Delivery Service" as DS
A ->> C : Apply Coupon
A --> DS : Track Order
activate DS
DS --> A : ACK
deactivate DS
note over DS : processing track order
A --> DS : Browse Products
note over DS : processing browse products
A ->> S : Cancel Order
activate S
S --> A : ACK
deactivate S
note over S : processing cancel order
C -> S : Add To Cart
C --> PG : Write Review
activate PG
PG --> C : ACK
deactivate PG
DS ->> C : Make Payment
note over C : processing make payment
@enduml