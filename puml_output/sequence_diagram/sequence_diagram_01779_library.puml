@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
actor "Member" as M
participant "Librarian" as L
boundary "Admin" as A
A -> M : Borrow Book
activate M
M --> A : ACK
deactivate M
L --> M : Reserve Book
L ->> A : Renew Loan
note over A : processing renew loan
M -> L : Register Member
@enduml