@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
participant "User" as U
actor "Admin" as A
boundary "Advertiser" as A2
participant "Moderator" as M
A ->> M : Comment
M --> A2 : Share Post
activate A2
A2 --> M : ACK
deactivate A2
A2 ->> M : Follow User
U ->> A : Send Message
@enduml