@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
boundary "Bank Teller" as BT
boundary "Account Holder" as AH
entity "Auditor" as A
AH --> A : Transfer Funds
activate A
A --> AH : ACK
deactivate A
A --> AH : View Statement
A --> BT : Open Account
BT -> AH : Deposit Money
activate AH
AH --> BT : ACK
deactivate AH
@enduml