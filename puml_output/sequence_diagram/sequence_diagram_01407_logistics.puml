@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
boundary "Fleet Manager" as FM
actor "Customer" as C
boundary "Driver" as D
actor "Dispatcher" as D2
D2 ->> D : Update Inventory
D2 --> D : Assign Route
D -> C : Schedule Pickup
D --> D2 : Track Shipment
@enduml