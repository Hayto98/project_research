@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
control "Manager" as M
control "Housekeeper" as H
entity "Guest" as G
H --> G : Cancel Reservation
activate G
G --> H : ACK
deactivate G
G -> M : Order Room Service
H --> G : Clean Room
activate G
G --> H : ACK
deactivate G
G ->> M : Request Service
activate M
M --> G : ACK
deactivate M
M ->> G : Process Payment
H ->> M : Book Room
M -> G : Check In
@enduml