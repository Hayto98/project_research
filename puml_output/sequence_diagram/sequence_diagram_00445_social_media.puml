@startuml
skinparam defaultFontSize 11
boundary "Admin" as A
entity "Advertiser" as A2
boundary "Moderator" as M
boundary "User" as U
M -> U : Share Post
A ->> U : Create Post
activate U
U --> A : ACK
deactivate U
A2 --> U : Comment
activate U
U --> A2 : ACK
deactivate U
note over U : processing comment
A ->> A2 : Send Message
activate A2
A2 --> A : ACK
deactivate A2
A2 -> U : Like Post
A --> A2 : Report Content
activate A2
A2 --> A : ACK
deactivate A2
note over A2 : processing report content
@enduml