@startuml
skinparam monochrome true
skinparam defaultFontSize 11
control "Admin" as A
entity "Moderator" as M
participant "Advertiser" as A2
M -> A2 : Comment
A -> A2 : Share Post
A --> M : Follow User
activate M
M --> A : ACK
deactivate M
A2 --> A : Send Message
note over A : processing send message
@enduml