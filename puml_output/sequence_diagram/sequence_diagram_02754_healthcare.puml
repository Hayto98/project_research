@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
actor "Insurance Provider" as IP
boundary "Patient" as P
control "Receptionist" as R
entity "Nurse" as N
IP ->> R : Issue Prescription
activate R
R --> IP : ACK
deactivate R
N -> P : Process Insurance Claim
N --> R : Update Medical Record
P --> N : Discharge Patient
@enduml