@startuml
skinparam monochrome true
skinparam defaultFontSize 13
entity "Customer" as C
participant "Warehouse Staff" as WS
control "Fleet Manager" as FM
WS ->> FM : Load Package
activate FM
FM --> WS : ACK
deactivate FM
WS --> FM : Deliver Package
note over FM : processing deliver package
C --> WS : Update Inventory
activate WS
WS --> C : ACK
deactivate WS
WS -> FM : Schedule Pickup
activate FM
FM --> WS : ACK
deactivate FM
FM --> WS : Track Shipment
@enduml