@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
control "Librarian" as L
actor "Admin" as A
control "Member" as M
L -> A : Renew Loan
note over A : processing renew loan
M -> A : Pay Fine
note over A : processing pay fine
M -> A : Search Catalog
A ->> L : Return Book
activate L
L --> A : ACK
deactivate L
note over L : processing return book
M --> A : Add New Book
activate A
A --> M : ACK
deactivate A
A -> L : Reserve Book
activate L
L --> A : ACK
deactivate L
L --> A : Register Member
@enduml