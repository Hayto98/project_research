@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
entity "Admin" as A
participant "Moderator" as M
control "User" as U
U -> M : Create Post
U ->> M : Edit Profile
M -> U : Share Post
A -> U : Comment
activate U
U --> A : ACK
deactivate U
@enduml