@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
boundary "Housekeeper" as H
actor "Guest" as G
actor "Receptionist" as R
H ->> G : Request Service
R -> H : Check Out
activate H
H --> R : ACK
deactivate H
H ->> R : Cancel Reservation
R -> H : Book Room
R --> G : Check In
@enduml