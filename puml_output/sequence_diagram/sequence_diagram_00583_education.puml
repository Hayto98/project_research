@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
boundary "Parent" as P
entity "Student" as S
control "Teacher" as T
participant "Registrar" as R
T -> S : Grade Exam
T -> P : Submit Assignment
P --> R : View Schedule
activate R
R --> P : ACK
deactivate R
P ->> S : Borrow Book
S -> T : Issue Certificate
@enduml