@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
boundary "Housekeeper" as H
control "Chef" as C
control "Guest" as G
actor "Receptionist" as R
control "Manager" as M
H -> C : Book Room
G --> C : Order Room Service
C ->> R : Check Out
activate R
R --> C : ACK
deactivate R
G ->> R : Clean Room
G --> M : Request Service
M -> G : Check In
@enduml