@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
entity "Customer" as C
boundary "Fleet Manager" as FM
control "Dispatcher" as D
actor "Warehouse Staff" as WS
FM ->> D : Schedule Pickup
D --> FM : Report Issue
WS ->> D : Deliver Package
FM ->> WS : Update Inventory
note over WS : processing update inventory
D ->> FM : Load Package
@enduml