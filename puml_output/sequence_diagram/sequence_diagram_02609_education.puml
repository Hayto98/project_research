@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
control "Parent" as P
actor "Admin" as A
actor "Librarian" as L
boundary "Teacher" as T
A --> T : View Schedule
P -> L : Borrow Book
T -> A : Submit Assignment
T ->> A : Grade Exam
note over A : processing grade exam
P ->> A : Take Attendance
activate A
A --> P : ACK
deactivate A
L ->> T : Enroll Course
note over T : processing enroll course
@enduml