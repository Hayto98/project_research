@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
boundary "Delivery Service" as DS
entity "Customer" as C
actor "Admin" as A
C --> DS : Track Order
activate DS
DS --> C : ACK
deactivate DS
C --> A : Make Payment
C -> DS : Cancel Order
DS -> C : Write Review
A -> C : Manage Inventory
C ->> DS : Browse Products
@enduml