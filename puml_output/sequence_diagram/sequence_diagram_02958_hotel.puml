@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
participant "Manager" as M
boundary "Guest" as G
entity "Receptionist" as R
participant "Chef" as C
C -> G : Clean Room
activate G
G --> C : ACK
deactivate G
G --> R : Process Payment
M -> G : Request Service
activate G
G --> M : ACK
deactivate G
R ->> G : Check In
G ->> C : Cancel Reservation
@enduml