@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
control "Chef" as C
boundary "Guest" as G
boundary "Housekeeper" as H
entity "Manager" as M
boundary "Receptionist" as R
M ->> C : Check Out
activate C
C --> M : ACK
deactivate C
G ->> M : Order Room Service
G ->> R : Clean Room
note over R : processing clean room
C --> R : Process Payment
note over R : processing process payment
@enduml