@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
actor "Customer" as C
control "Driver" as D
control "Warehouse Staff" as WS
C --> D : Assign Route
D --> WS : Deliver Package
D ->> WS : Load Package
C ->> WS : Schedule Pickup
@enduml