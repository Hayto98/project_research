@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
boundary "Advertiser" as A
participant "Admin" as A2
control "User" as U
A -> U : Create Post
activate U
U --> A : ACK
deactivate U
U --> A : Share Post
activate A
A --> U : ACK
deactivate A
A --> A2 : Like Post
activate A2
A2 --> A : ACK
deactivate A2
U ->> A2 : Comment
note over A2 : processing comment
U -> A : Edit Profile
A2 ->> A : Send Message
activate A
A --> A2 : ACK
deactivate A
@enduml