@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
entity "Admin" as A
entity "Librarian" as L
boundary "Student" as S
control "Teacher" as T
actor "Registrar" as R
A --> S : Issue Certificate
R ->> S : Take Attendance
activate S
S --> R : ACK
deactivate S
note over S : processing take attendance
R --> S : Borrow Book
S --> T : Grade Exam
@enduml