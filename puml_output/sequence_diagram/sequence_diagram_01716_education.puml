@startuml
skinparam ArrowColor #555555
control "Admin" as A
actor "Librarian" as L
entity "Student" as S
entity "Registrar" as R
entity "Teacher" as T
T -> S : Grade Exam
activate S
S --> T : ACK
deactivate S
note over S : processing grade exam
A ->> S : Borrow Book
L ->> A : View Schedule
S --> L : Enroll Course
L -> R : Submit Assignment
activate R
R --> L : ACK
deactivate R
A -> T : Issue Certificate
note over T : processing issue certificate
L -> T : Register Student
activate T
T --> L : ACK
deactivate T
@enduml