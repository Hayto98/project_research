@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
actor "Librarian" as L
boundary "Member" as M
entity "Admin" as A
M --> L : Borrow Book
activate L
L --> M : ACK
deactivate L
L --> M : Reserve Book
L -> A : Pay Fine
M -> L : Return Book
activate L
L --> M : ACK
deactivate L
@enduml