@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
control "Receptionist" as R
boundary "Nurse" as N
boundary "Lab Technician" as LT
participant "Patient" as P
boundary "Doctor" as D
D --> N : Book Appointment
D -> LT : Process Insurance Claim
note over LT : processing process insurance claim
N -> P : Run Lab Test
LT -> R : Admit Patient
N ->> D : Examine Patient
note over D : processing examine patient
@enduml