@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
entity "Admin" as A
boundary "Member" as M
actor "Librarian" as L
M -> L : Search Catalog
L --> M : Pay Fine
M ->> A : Register Member
note over A : processing register member
A ->> M : Renew Loan
L ->> M : Add New Book
M -> A : Reserve Book
activate A
A --> M : ACK
deactivate A
@enduml