@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
entity "Manager" as M
participant "Chef" as C
boundary "Guest" as G
entity "Receptionist" as R
G -> R : Book Room
note over R : processing book room
M ->> R : Clean Room
C ->> M : Check Out
M ->> G : Order Room Service
note over G : processing order room service
@enduml