@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
actor "Housekeeper" as H
entity "Receptionist" as R
actor "Guest" as G
boundary "Chef" as C
boundary "Manager" as M
G -> H : Order Room Service
activate H
H --> G : ACK
deactivate H
C ->> H : Book Room
R --> H : Process Payment
H -> R : Clean Room
@enduml