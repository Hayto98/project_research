@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
actor "Receptionist" as R
participant "Chef" as C
boundary "Manager" as M
C --> M : Clean Room
R -> C : Order Room Service
M ->> C : Request Service
R --> C : Process Payment
M -> C : Book Room
M --> R : Check Out
activate R
R --> M : ACK
deactivate R
M -> R : Cancel Reservation
activate R
R --> M : ACK
deactivate R
@enduml