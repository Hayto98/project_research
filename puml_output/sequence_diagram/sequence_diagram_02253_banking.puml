@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
control "Branch Manager" as BM
control "Auditor" as A
entity "Account Holder" as AH
control "ATM" as A2
entity "Bank Teller" as BT
AH ->> BT : Deposit Money
activate BT
BT --> AH : ACK
deactivate BT
A -> BT : Transfer Funds
note over BT : processing transfer funds
AH --> A2 : Open Account
activate A2
A2 --> AH : ACK
deactivate A2
note over A2 : processing open account
BM --> A2 : Pay Bill
@enduml