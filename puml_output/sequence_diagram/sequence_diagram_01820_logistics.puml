@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
actor "Warehouse Staff" as WS
entity "Fleet Manager" as FM
control "Driver" as D
control "Dispatcher" as D2
FM --> D : Fuel Vehicle
D2 ->> D : Update Inventory
activate D
D --> D2 : ACK
deactivate D
FM --> D2 : Report Issue
D2 --> WS : Deliver Package
D2 --> WS : Track Shipment
note over WS : processing track shipment
D ->> FM : Load Package
WS -> D : Assign Route
note over D : processing assign route
@enduml