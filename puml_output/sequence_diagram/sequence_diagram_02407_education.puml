@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
control "Teacher" as T
participant "Registrar" as R
actor "Librarian" as L
T ->> L : Grade Exam
L --> T : Enroll Course
activate T
T --> L : ACK
deactivate T
T --> R : Issue Certificate
note over R : processing issue certificate
L --> T : Borrow Book
note over T : processing borrow book
T -> R : Register Student
L ->> T : View Schedule
activate T
T --> L : ACK
deactivate T
@enduml