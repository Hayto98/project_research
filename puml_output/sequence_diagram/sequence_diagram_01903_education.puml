@startuml

control "Teacher" as T
actor "Librarian" as L
boundary "Parent" as P
actor "Registrar" as R
actor "Admin" as A
A -> T : View Schedule
activate T
T --> A : ACK
deactivate T
T --> L : Take Attendance
T ->> L : Register Student
activate L
L --> T : ACK
deactivate L
T ->> L : Submit Assignment
activate L
L --> T : ACK
deactivate L
@enduml