@startuml
skinparam monochrome true
skinparam defaultFontSize 13
boundary "Registrar" as R
boundary "Admin" as A
boundary "Teacher" as T
control "Librarian" as L
R ->> A : Enroll Course
A --> L : Submit Assignment
activate L
L --> A : ACK
deactivate L
T ->> A : Borrow Book
activate A
A --> T : ACK
deactivate A
L ->> A : Register Student
L ->> T : Grade Exam
@enduml