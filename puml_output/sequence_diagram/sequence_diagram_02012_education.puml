@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
boundary "Student" as S
entity "Parent" as P
actor "Registrar" as R
P -> S : Grade Exam
P ->> R : Register Student
activate R
R --> P : ACK
deactivate R
R --> P : View Schedule
R -> P : Enroll Course
R -> P : Borrow Book
P -> S : Issue Certificate
activate S
S --> P : ACK
deactivate S
S ->> P : Submit Assignment
note over P : processing submit assignment
@enduml