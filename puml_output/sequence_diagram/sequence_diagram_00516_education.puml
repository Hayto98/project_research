@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
boundary "Teacher" as T
entity "Admin" as A
boundary "Parent" as P
participant "Registrar" as R
boundary "Student" as S
R ->> S : Submit Assignment
S --> R : Issue Certificate
R -> P : Grade Exam
activate P
P --> R : ACK
deactivate P
note over P : processing grade exam
S ->> T : Enroll Course
@enduml