@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
control "Parent" as P
entity "Librarian" as L
control "Registrar" as R
control "Teacher" as T
control "Admin" as A
P -> T : Borrow Book
activate T
T --> P : ACK
deactivate T
A ->> T : Take Attendance
T ->> R : View Schedule
activate R
R --> T : ACK
deactivate R
P ->> T : Enroll Course
activate T
T --> P : ACK
deactivate T
A ->> L : Submit Assignment
@enduml