@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
participant "Parent" as P
control "Admin" as A
entity "Registrar" as R
entity "Librarian" as L
entity "Student" as S
P ->> R : Borrow Book
S -> L : Grade Exam
S --> L : Enroll Course
note over L : processing enroll course
P -> A : Take Attendance
L --> R : Issue Certificate
@enduml