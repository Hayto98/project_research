@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
actor "Member" as M
participant "Admin" as A
entity "Librarian" as L
M -> L : Add New Book
A ->> M : Pay Fine
L ->> A : Return Book
L ->> M : Borrow Book
M ->> A : Renew Loan
note over A : processing renew loan
@enduml