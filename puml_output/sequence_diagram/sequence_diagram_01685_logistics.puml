@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
actor "Driver" as D
entity "Warehouse Staff" as WS
boundary "Dispatcher" as D2
D2 -> WS : Track Shipment
activate WS
WS --> D2 : ACK
deactivate WS
note over WS : processing track shipment
D ->> D2 : Assign Route
D2 -> WS : Deliver Package
WS --> D : Load Package
WS ->> D2 : Update Inventory
activate D2
D2 --> WS : ACK
deactivate D2
@enduml