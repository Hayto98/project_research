@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
entity "Account Holder" as AH
participant "Branch Manager" as BM
entity "Auditor" as A
entity "ATM" as A2
actor "Bank Teller" as BT
A --> BT : Apply For Loan
activate BT
BT --> A : ACK
deactivate BT
A2 --> BM : Transfer Funds
AH -> A2 : Block Card
AH --> A2 : Pay Bill
BT ->> A : Deposit Money
@enduml