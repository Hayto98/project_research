@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
actor "Advertiser" as A
entity "Admin" as A2
control "Moderator" as M
control "User" as U
A -> M : Comment
activate M
M --> A : ACK
deactivate M
M --> A2 : Follow User
activate A2
A2 --> M : ACK
deactivate A2
A ->> U : Create Post
A --> U : Send Message
M -> A : Like Post
@enduml