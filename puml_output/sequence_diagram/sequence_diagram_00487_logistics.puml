@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
participant "Driver" as D
actor "Customer" as C
participant "Fleet Manager" as FM
participant "Warehouse Staff" as WS
D ->> FM : Fuel Vehicle
activate FM
FM --> D : ACK
deactivate FM
D -> WS : Assign Route
WS -> C : Load Package
note over C : processing load package
FM --> WS : Update Inventory
@enduml