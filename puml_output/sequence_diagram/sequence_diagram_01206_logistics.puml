@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
actor "Warehouse Staff" as WS
boundary "Customer" as C
entity "Driver" as D
control "Fleet Manager" as FM
control "Dispatcher" as D2
D2 ->> D : Load Package
WS -> FM : Track Shipment
FM ->> D : Fuel Vehicle
WS --> D2 : Assign Route
@enduml