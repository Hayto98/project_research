@startuml
skinparam monochrome true
skinparam defaultFontSize 13
entity "Chef" as C
entity "Manager" as M
participant "Guest" as G
G --> M : Process Payment
M ->> G : Order Room Service
G -> M : Check In
activate M
M --> G : ACK
deactivate M
G -> M : Check Out
activate M
M --> G : ACK
deactivate M
@enduml