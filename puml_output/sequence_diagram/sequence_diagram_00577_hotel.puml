@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
control "Receptionist" as R
actor "Housekeeper" as H
entity "Chef" as C
entity "Manager" as M
C ->> M : Process Payment
note over M : processing process payment
R ->> H : Check Out
activate H
H --> R : ACK
deactivate H
M --> H : Clean Room
R --> M : Request Service
activate M
M --> R : ACK
deactivate M
M ->> H : Book Room
M --> C : Cancel Reservation
activate C
C --> M : ACK
deactivate C
C --> H : Check In
@enduml