@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
boundary "Insurance Provider" as IP
boundary "Doctor" as D
boundary "Nurse" as N
boundary "Patient" as P
entity "Lab Technician" as LT
D -> P : Book Appointment
IP ->> D : Admit Patient
note over D : processing admit patient
IP ->> LT : Update Medical Record
P --> D : Issue Prescription
@enduml