@startuml
skinparam ArrowColor #555555
entity "Librarian" as L
entity "Member" as M
entity "Admin" as A
L -> A : Search Catalog
L ->> A : Return Book
L ->> A : Reserve Book
A -> L : Borrow Book
activate L
L --> A : ACK
deactivate L
A --> M : Pay Fine
activate M
M --> A : ACK
deactivate M
M --> L : Add New Book
activate L
L --> M : ACK
deactivate L
M --> L : Renew Loan
@enduml