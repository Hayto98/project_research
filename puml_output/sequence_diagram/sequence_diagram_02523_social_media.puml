@startuml
skinparam shadowing true
control "Moderator" as M
boundary "User" as U
participant "Advertiser" as A
entity "Admin" as A2
A2 -> A : Share Post
A ->> A2 : Like Post
activate A2
A2 --> A : ACK
deactivate A2
U ->> A2 : Report Content
M ->> A2 : Edit Profile
activate A2
A2 --> M : ACK
deactivate A2
note over A2 : processing edit profile
M --> U : Send Message
A2 -> U : Follow User
activate U
U --> A2 : ACK
deactivate U
note over U : processing follow user
A2 --> A : Create Post
@enduml