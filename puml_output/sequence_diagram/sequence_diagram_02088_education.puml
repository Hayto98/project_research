@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
participant "Teacher" as T
participant "Student" as S
actor "Librarian" as L
L --> S : View Schedule
activate S
S --> L : ACK
deactivate S
T -> S : Issue Certificate
L -> S : Submit Assignment
activate S
S --> L : ACK
deactivate S
T --> S : Enroll Course
L ->> S : Borrow Book
note over S : processing borrow book
T -> L : Register Student
activate L
L --> T : ACK
deactivate L
note over L : processing register student
T ->> L : Take Attendance
@enduml