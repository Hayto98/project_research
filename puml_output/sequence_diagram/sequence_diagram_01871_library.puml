@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
control "Admin" as A
boundary "Librarian" as L
participant "Member" as M
M -> A : Pay Fine
L -> A : Reserve Book
activate A
A --> L : ACK
deactivate A
A ->> M : Search Catalog
L -> M : Return Book
A --> M : Borrow Book
M --> L : Register Member
@enduml