@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
actor "Member" as M
participant "Librarian" as L
actor "Admin" as A
L -> A : Return Book
activate A
A --> L : ACK
deactivate A
note over A : processing return book
M --> A : Search Catalog
A -> M : Add New Book
M --> L : Renew Loan
activate L
L --> M : ACK
deactivate L
@enduml