@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
control "Lab Technician" as LT
boundary "Insurance Provider" as IP
participant "Patient" as P
P -> IP : Update Medical Record
IP ->> LT : Examine Patient
IP -> LT : Process Insurance Claim
activate LT
LT --> IP : ACK
deactivate LT
IP --> LT : Discharge Patient
LT ->> IP : Issue Prescription
activate IP
IP --> LT : ACK
deactivate IP
note over IP : processing issue prescription
IP -> P : Book Appointment
@enduml