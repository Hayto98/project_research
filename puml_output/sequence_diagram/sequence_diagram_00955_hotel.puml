@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
control "Guest" as G
boundary "Housekeeper" as H
boundary "Chef" as C
C --> H : Check Out
activate H
H --> C : ACK
deactivate H
C ->> G : Request Service
H ->> G : Book Room
G -> C : Check In
@enduml