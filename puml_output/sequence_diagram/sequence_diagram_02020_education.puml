@startuml
skinparam shadowing true
control "Registrar" as R
participant "Student" as S
entity "Teacher" as T
entity "Admin" as A
entity "Librarian" as L
R --> T : Grade Exam
note over T : processing grade exam
A -> S : Issue Certificate
S ->> R : Borrow Book
note over R : processing borrow book
T -> S : Take Attendance
note over S : processing take attendance
A --> R : Submit Assignment
activate R
R --> A : ACK
deactivate R
note over R : processing submit assignment
S --> R : Register Student
activate R
R --> S : ACK
deactivate R
S -> A : Enroll Course
activate A
A --> S : ACK
deactivate A
@enduml