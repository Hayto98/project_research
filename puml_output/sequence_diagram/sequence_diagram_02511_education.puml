@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
control "Student" as S
control "Teacher" as T
entity "Registrar" as R
R -> T : Borrow Book
R ->> S : Grade Exam
activate S
S --> R : ACK
deactivate S
note over S : processing grade exam
S -> T : Register Student
T -> S : Issue Certificate
R -> S : View Schedule
activate S
S --> R : ACK
deactivate S
R ->> S : Enroll Course
note over S : processing enroll course
T -> S : Submit Assignment
@enduml