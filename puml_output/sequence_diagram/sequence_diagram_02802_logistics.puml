@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
actor "Fleet Manager" as FM
control "Customer" as C
participant "Driver" as D
actor "Dispatcher" as D2
participant "Warehouse Staff" as WS
WS ->> D : Load Package
D2 ->> C : Report Issue
activate C
C --> D2 : ACK
deactivate C
C --> D : Fuel Vehicle
note over D : processing fuel vehicle
D --> C : Track Shipment
@enduml