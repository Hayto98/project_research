@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
entity "Teacher" as T
boundary "Student" as S
actor "Registrar" as R
T -> R : Grade Exam
T --> S : View Schedule
T ->> R : Take Attendance
note over R : processing take attendance
T -> S : Borrow Book
note over S : processing borrow book
R -> T : Submit Assignment
note over T : processing submit assignment
R ->> T : Issue Certificate
note over T : processing issue certificate
T -> R : Register Student
note over R : processing register student
@enduml