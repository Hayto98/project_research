@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
participant "Insurance Provider" as IP
entity "Nurse" as N
control "Lab Technician" as LT
LT ->> N : Discharge Patient
note over N : processing discharge patient
LT ->> IP : Examine Patient
N ->> LT : Book Appointment
N -> LT : Admit Patient
LT ->> IP : Issue Prescription
N --> IP : Process Insurance Claim
note over IP : processing process insurance claim
N --> IP : Update Medical Record
@enduml