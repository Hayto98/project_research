@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
participant "Advertiser" as A
boundary "Admin" as A2
entity "Moderator" as M
entity "User" as U
M -> A : Edit Profile
M --> A : Create Post
activate A
A --> M : ACK
deactivate A
U -> M : Like Post
note over M : processing like post
A --> M : Follow User
M -> U : Share Post
activate U
U --> M : ACK
deactivate U
@enduml