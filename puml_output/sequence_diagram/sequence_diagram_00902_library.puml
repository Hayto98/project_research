@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
entity "Member" as M
entity "Admin" as A
participant "Librarian" as L
A --> M : Renew Loan
activate M
M --> A : ACK
deactivate M
L ->> A : Search Catalog
M --> A : Add New Book
A ->> M : Return Book
activate M
M --> A : ACK
deactivate M
@enduml