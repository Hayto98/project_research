@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
boundary "Seller" as S
actor "Payment Gateway" as PG
entity "Customer" as C
PG --> C : Manage Inventory
S --> C : Checkout
PG --> C : Track Order
note over C : processing track order
PG ->> S : Make Payment
S ->> PG : Apply Coupon
note over PG : processing apply coupon
@enduml