@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
boundary "Nurse" as N
boundary "Lab Technician" as LT
control "Receptionist" as R
R --> LT : Run Lab Test
activate LT
LT --> R : ACK
deactivate LT
R -> LT : Discharge Patient
LT -> R : Book Appointment
LT -> R : Update Medical Record
N ->> LT : Process Insurance Claim
note over LT : processing process insurance claim
R -> LT : Admit Patient
activate LT
LT --> R : ACK
deactivate LT
@enduml