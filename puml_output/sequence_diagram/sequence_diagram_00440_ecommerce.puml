@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
participant "Payment Gateway" as PG
actor "Seller" as S
control "Admin" as A
PG ->> A : Apply Coupon
PG -> A : Track Order
activate A
A --> PG : ACK
deactivate A
A ->> PG : Browse Products
activate PG
PG --> A : ACK
deactivate PG
A --> S : Make Payment
activate S
S --> A : ACK
deactivate S
@enduml