@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
boundary "Lab Technician" as LT
entity "Insurance Provider" as IP
boundary "Nurse" as N
control "Doctor" as D
D ->> IP : Admit Patient
activate IP
IP --> D : ACK
deactivate IP
D --> IP : Examine Patient
LT -> N : Process Insurance Claim
note over N : processing process insurance claim
N ->> D : Run Lab Test
N ->> IP : Discharge Patient
activate IP
IP --> N : ACK
deactivate IP
D --> N : Issue Prescription
N --> IP : Update Medical Record
@enduml