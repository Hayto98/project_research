@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
participant "Student" as S
actor "Parent" as P
actor "Registrar" as R
participant "Librarian" as L
L --> S : Grade Exam
activate S
S --> L : ACK
deactivate S
L --> S : Enroll Course
note over S : processing enroll course
P ->> R : Register Student
P --> S : Take Attendance
L --> S : Submit Assignment
@enduml