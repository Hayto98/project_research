@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
actor "Receptionist" as R
entity "Chef" as C
boundary "Manager" as M
actor "Guest" as G
G --> C : Process Payment
activate C
C --> G : ACK
deactivate C
R -> M : Book Room
activate M
M --> R : ACK
deactivate M
G -> M : Request Service
activate M
M --> G : ACK
deactivate M
C --> R : Check Out
note over R : processing check out
R -> G : Cancel Reservation
activate G
G --> R : ACK
deactivate G
M --> C : Clean Room
activate C
C --> M : ACK
deactivate C
G --> M : Order Room Service
note over M : processing order room service
@enduml