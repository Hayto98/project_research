@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
boundary "Librarian" as L
control "Teacher" as T
control "Student" as S
T ->> S : Issue Certificate
activate S
S --> T : ACK
deactivate S
S ->> T : Submit Assignment
note over T : processing submit assignment
L ->> S : Grade Exam
T -> S : Register Student
note over S : processing register student
@enduml