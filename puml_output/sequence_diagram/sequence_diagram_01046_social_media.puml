@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
control "User" as U
entity "Admin" as A
entity "Advertiser" as A2
U ->> A2 : Edit Profile
activate A2
A2 --> U : ACK
deactivate A2
U -> A2 : Like Post
A -> A2 : Share Post
A ->> U : Report Content
U ->> A2 : Create Post
activate A2
A2 --> U : ACK
deactivate A2
A2 ->> U : Follow User
A -> A2 : Send Message
@enduml