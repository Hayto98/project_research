@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
actor "Patient" as P
entity "Insurance Provider" as IP
actor "Doctor" as D
D ->> P : Book Appointment
activate P
P --> D : ACK
deactivate P
D ->> P : Examine Patient
P --> IP : Run Lab Test
P -> D : Discharge Patient
activate D
D --> P : ACK
deactivate D
@enduml