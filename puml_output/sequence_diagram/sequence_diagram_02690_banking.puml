@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
control "Auditor" as A
entity "Bank Teller" as BT
entity "ATM" as A2
A -> A2 : Apply For Loan
BT --> A2 : View Statement
A ->> A2 : Withdraw Cash
BT -> A : Deposit Money
activate A
A --> BT : ACK
deactivate A
@enduml