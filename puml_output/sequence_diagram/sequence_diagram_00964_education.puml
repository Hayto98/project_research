@startuml
skinparam monochrome true
skinparam defaultFontSize 13
control "Student" as S
control "Parent" as P
actor "Librarian" as L
actor "Teacher" as T
P ->> L : Register Student
activate L
L --> P : ACK
deactivate L
P -> T : Submit Assignment
P --> L : Take Attendance
note over L : processing take attendance
T -> P : View Schedule
T ->> P : Borrow Book
S -> T : Issue Certificate
@enduml