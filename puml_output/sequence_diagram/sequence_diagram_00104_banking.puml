@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
actor "Account Holder" as AH
participant "ATM" as A
control "Bank Teller" as BT
AH -> BT : Apply For Loan
note over BT : processing apply for loan
A -> BT : Block Card
BT ->> AH : View Statement
AH --> A : Deposit Money
activate A
A --> AH : ACK
deactivate A
A -> AH : Pay Bill
BT ->> A : Open Account
@enduml