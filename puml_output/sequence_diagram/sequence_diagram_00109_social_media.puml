@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
boundary "Moderator" as M
boundary "User" as U
participant "Admin" as A
participant "Advertiser" as A2
U ->> A : Like Post
activate A
A --> U : ACK
deactivate A
note over A : processing like post
U -> A2 : Report Content
activate A2
A2 --> U : ACK
deactivate A2
M --> U : Send Message
activate U
U --> M : ACK
deactivate U
U ->> A2 : Share Post
U -> A : Follow User
A2 --> A : Edit Profile
@enduml