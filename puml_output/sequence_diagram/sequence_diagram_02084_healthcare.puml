@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
participant "Doctor" as D
boundary "Insurance Provider" as IP
actor "Patient" as P
actor "Receptionist" as R
control "Nurse" as N
P ->> N : Process Insurance Claim
note over N : processing process insurance claim
D ->> N : Examine Patient
activate N
N --> D : ACK
deactivate N
P --> D : Run Lab Test
activate D
D --> P : ACK
deactivate D
R --> IP : Discharge Patient
activate IP
IP --> R : ACK
deactivate IP
D ->> N : Book Appointment
R -> D : Issue Prescription
@enduml