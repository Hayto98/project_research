@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
control "Parent" as P
actor "Registrar" as R
actor "Student" as S
boundary "Teacher" as T
S -> P : Enroll Course
activate P
P --> S : ACK
deactivate P
note over P : processing enroll course
P ->> R : Submit Assignment
P --> T : Take Attendance
P -> T : View Schedule
R ->> T : Register Student
S -> R : Grade Exam
@enduml