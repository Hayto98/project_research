@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
actor "Customer" as C
participant "Driver" as D
control "Warehouse Staff" as WS
participant "Dispatcher" as D2
actor "Fleet Manager" as FM
WS -> C : Deliver Package
FM -> D2 : Load Package
C -> D : Report Issue
activate D
D --> C : ACK
deactivate D
D ->> WS : Schedule Pickup
@enduml