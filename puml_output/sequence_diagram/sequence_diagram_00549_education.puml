@startuml
skinparam monochrome true
skinparam defaultFontSize 11
actor "Teacher" as T
control "Registrar" as R
actor "Librarian" as L
L -> R : Enroll Course
R ->> T : Submit Assignment
R --> T : View Schedule
activate T
T --> R : ACK
deactivate T
R ->> T : Register Student
activate T
T --> R : ACK
deactivate T
note over T : processing register student
@enduml