@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
entity "Parent" as P
control "Librarian" as L
actor "Student" as S
entity "Teacher" as T
L ->> T : Submit Assignment
note over T : processing submit assignment
L --> P : Take Attendance
S --> T : Borrow Book
L ->> T : View Schedule
note over T : processing view schedule
L --> S : Register Student
@enduml