@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
entity "Fleet Manager" as FM
actor "Customer" as C
actor "Driver" as D
C --> FM : Load Package
note over FM : processing load package
C -> D : Schedule Pickup
D --> FM : Track Shipment
note over FM : processing track shipment
C -> D : Report Issue
@enduml