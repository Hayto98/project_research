@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
actor "Doctor" as D
participant "Insurance Provider" as IP
actor "Patient" as P
control "Nurse" as N
IP -> P : Book Appointment
N -> P : Discharge Patient
D ->> N : Admit Patient
activate N
N --> D : ACK
deactivate N
D --> P : Update Medical Record
note over P : processing update medical record
@enduml