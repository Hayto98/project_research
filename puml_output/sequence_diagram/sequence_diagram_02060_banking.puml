@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
participant "ATM" as A
control "Branch Manager" as BM
participant "Account Holder" as AH
control "Bank Teller" as BT
entity "Auditor" as A2
A2 --> AH : Apply For Loan
A -> BT : View Statement
note over BT : processing view statement
A2 -> BM : Deposit Money
A2 -> BM : Transfer Funds
BM ->> A2 : Block Card
@enduml