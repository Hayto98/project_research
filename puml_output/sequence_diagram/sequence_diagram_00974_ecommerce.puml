@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
control "Delivery Service" as DS
entity "Payment Gateway" as PG
entity "Admin" as A
participant "Customer" as C
DS ->> C : Checkout
activate C
C --> DS : ACK
deactivate C
note over C : processing checkout
A --> DS : Add To Cart
activate DS
DS --> A : ACK
deactivate DS
A ->> C : Track Order
note over C : processing track order
A --> PG : Browse Products
DS ->> PG : Apply Coupon
activate PG
PG --> DS : ACK
deactivate PG
@enduml