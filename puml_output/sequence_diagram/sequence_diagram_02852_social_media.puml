@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
actor "Admin" as A
participant "User" as U
control "Moderator" as M
actor "Advertiser" as A2
A --> A2 : Comment
A2 -> U : Create Post
activate U
U --> A2 : ACK
deactivate U
A -> U : Report Content
M --> A2 : Like Post
activate A2
A2 --> M : ACK
deactivate A2
@enduml