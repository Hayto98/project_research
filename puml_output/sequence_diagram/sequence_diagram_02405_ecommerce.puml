@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
control "Admin" as A
control "Delivery Service" as DS
control "Customer" as C
participant "Payment Gateway" as PG
actor "Seller" as S
S --> DS : Apply Coupon
S -> DS : Add To Cart
activate DS
DS --> S : ACK
deactivate DS
PG --> DS : Browse Products
S ->> A : Write Review
S --> DS : Make Payment
@enduml