@startuml
skinparam defaultFontSize 11
entity "Insurance Provider" as IP
boundary "Nurse" as N
entity "Lab Technician" as LT
participant "Patient" as P
N ->> IP : Book Appointment
note over IP : processing book appointment
LT -> IP : Discharge Patient
LT -> IP : Admit Patient
LT --> IP : Update Medical Record
note over IP : processing update medical record
@enduml