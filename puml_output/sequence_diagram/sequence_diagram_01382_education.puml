@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
actor "Student" as S
control "Parent" as P
control "Teacher" as T
T ->> P : Borrow Book
activate P
P --> T : ACK
deactivate P
T ->> S : Take Attendance
activate S
S --> T : ACK
deactivate S
P -> T : Issue Certificate
P --> T : Register Student
P -> S : Grade Exam
note over S : processing grade exam
@enduml