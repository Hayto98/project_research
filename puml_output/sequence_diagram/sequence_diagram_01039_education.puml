@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
participant "Librarian" as L
control "Teacher" as T
participant "Admin" as A
control "Registrar" as R
R --> T : Take Attendance
A -> T : View Schedule
L ->> T : Borrow Book
R -> T : Issue Certificate
activate T
T --> R : ACK
deactivate T
A -> R : Submit Assignment
@enduml