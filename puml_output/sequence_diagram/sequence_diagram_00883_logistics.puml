@startuml

participant "Driver" as D
entity "Customer" as C
control "Warehouse Staff" as WS
actor "Fleet Manager" as FM
FM --> WS : Deliver Package
FM -> WS : Fuel Vehicle
activate WS
WS --> FM : ACK
deactivate WS
WS -> FM : Schedule Pickup
note over FM : processing schedule pickup
FM ->> D : Report Issue
@enduml