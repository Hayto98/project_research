@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
entity "Delivery Service" as DS
actor "Admin" as A
boundary "Customer" as C
participant "Seller" as S
A ->> C : Write Review
activate C
C --> A : ACK
deactivate C
C -> A : Checkout
activate A
A --> C : ACK
deactivate A
A ->> DS : Browse Products
A --> S : Manage Inventory
DS ->> C : Cancel Order
activate C
C --> DS : ACK
deactivate C
C --> S : Apply Coupon
@enduml