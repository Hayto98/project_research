@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
participant "Teacher" as T
actor "Student" as S
boundary "Admin" as A
control "Parent" as P
A --> T : Borrow Book
activate T
T --> A : ACK
deactivate T
A -> T : Submit Assignment
T ->> P : Issue Certificate
activate P
P --> T : ACK
deactivate P
T --> P : View Schedule
T --> A : Grade Exam
@enduml