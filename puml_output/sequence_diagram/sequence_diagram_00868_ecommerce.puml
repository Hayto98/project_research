@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
participant "Seller" as S
boundary "Delivery Service" as DS
participant "Payment Gateway" as PG
PG --> DS : Cancel Order
activate DS
DS --> PG : ACK
deactivate DS
note over DS : processing cancel order
S --> DS : Apply Coupon
activate DS
DS --> S : ACK
deactivate DS
S --> DS : Checkout
S --> DS : Manage Inventory
note over DS : processing manage inventory
@enduml