@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
actor "Admin" as A
participant "Librarian" as L
boundary "Teacher" as T
L -> T : Take Attendance
activate T
T --> L : ACK
deactivate T
L -> T : Submit Assignment
A ->> L : Borrow Book
T --> L : View Schedule
activate L
L --> T : ACK
deactivate L
L --> A : Grade Exam
T ->> L : Enroll Course
@enduml