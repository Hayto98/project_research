@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
participant "Housekeeper" as H
participant "Manager" as M
participant "Guest" as G
participant "Receptionist" as R
actor "Chef" as C
G -> H : Request Service
H ->> R : Check Out
R --> H : Cancel Reservation
note over H : processing cancel reservation
M --> C : Process Payment
M -> H : Book Room
@enduml