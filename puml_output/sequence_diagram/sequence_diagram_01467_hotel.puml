@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
control "Guest" as G
boundary "Receptionist" as R
entity "Housekeeper" as H
actor "Chef" as C
actor "Manager" as M
R ->> H : Check In
C -> H : Book Room
M --> G : Check Out
activate G
G --> M : ACK
deactivate G
G ->> M : Request Service
C ->> M : Cancel Reservation
@enduml