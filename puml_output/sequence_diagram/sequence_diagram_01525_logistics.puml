@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
control "Warehouse Staff" as WS
actor "Dispatcher" as D
actor "Driver" as D2
entity "Fleet Manager" as FM
participant "Customer" as C
WS ->> D : Deliver Package
note over D : processing deliver package
WS --> FM : Fuel Vehicle
D --> C : Assign Route
activate C
C --> D : ACK
deactivate C
WS ->> C : Update Inventory
@enduml