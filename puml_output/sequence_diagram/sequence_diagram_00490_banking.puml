@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
boundary "ATM" as A
participant "Bank Teller" as BT
control "Account Holder" as AH
entity "Auditor" as A2
participant "Branch Manager" as BM
A2 ->> BT : Apply For Loan
A2 --> A : Pay Bill
A2 ->> BT : Deposit Money
note over BT : processing deposit money
A2 --> A : Withdraw Cash
activate A
A --> A2 : ACK
deactivate A
@enduml