@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
entity "Parent" as P
control "Registrar" as R
actor "Teacher" as T
control "Admin" as A
R --> T : Register Student
R -> P : View Schedule
P -> A : Take Attendance
activate A
A --> P : ACK
deactivate A
R --> P : Borrow Book
A --> P : Grade Exam
A -> R : Submit Assignment
activate R
R --> A : ACK
deactivate R
@enduml