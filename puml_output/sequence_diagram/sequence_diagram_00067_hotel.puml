@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
entity "Manager" as M
entity "Receptionist" as R
participant "Chef" as C
actor "Guest" as G
C --> M : Check Out
R -> C : Order Room Service
note over C : processing order room service
C --> G : Clean Room
G -> R : Book Room
R ->> M : Process Payment
@enduml