@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
participant "Admin" as A
entity "Moderator" as M
boundary "Advertiser" as A2
A2 -> A : Share Post
A2 --> M : Edit Profile
activate M
M --> A2 : ACK
deactivate M
A2 ->> M : Create Post
activate M
M --> A2 : ACK
deactivate M
note over M : processing create post
A -> A2 : Like Post
activate A2
A2 --> A : ACK
deactivate A2
note over A2 : processing like post
M --> A2 : Report Content
activate A2
A2 --> M : ACK
deactivate A2
note over A2 : processing report content
@enduml