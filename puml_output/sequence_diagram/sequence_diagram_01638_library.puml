@startuml
skinparam defaultFontSize 11
boundary "Member" as M
boundary "Librarian" as L
control "Admin" as A
L ->> A : Search Catalog
activate A
A --> L : ACK
deactivate A
M -> L : Renew Loan
note over L : processing renew loan
L ->> A : Reserve Book
L -> A : Return Book
M ->> L : Add New Book
@enduml