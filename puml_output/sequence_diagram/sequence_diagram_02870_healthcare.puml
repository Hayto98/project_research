@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
actor "Nurse" as N
participant "Patient" as P
control "Insurance Provider" as IP
entity "Lab Technician" as LT
IP ->> N : Examine Patient
P -> N : Discharge Patient
note over N : processing discharge patient
IP -> LT : Update Medical Record
activate LT
LT --> IP : ACK
deactivate LT
note over LT : processing update medical record
LT --> P : Book Appointment
activate P
P --> LT : ACK
deactivate P
N ->> LT : Issue Prescription
P ->> LT : Admit Patient
note over LT : processing admit patient
IP -> LT : Run Lab Test
activate LT
LT --> IP : ACK
deactivate LT
note over LT : processing run lab test
@enduml