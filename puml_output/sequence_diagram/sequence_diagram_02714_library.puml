@startuml
skinparam monochrome true
skinparam shadowing true
actor "Member" as M
actor "Admin" as A
control "Librarian" as L
A --> L : Pay Fine
activate L
L --> A : ACK
deactivate L
M ->> L : Search Catalog
activate L
L --> M : ACK
deactivate L
A -> M : Reserve Book
note over M : processing reserve book
L --> M : Add New Book
A --> M : Register Member
@enduml