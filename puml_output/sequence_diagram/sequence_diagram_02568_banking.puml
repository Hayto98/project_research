@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
control "Account Holder" as AH
participant "Bank Teller" as BT
participant "Branch Manager" as BM
entity "Auditor" as A
A --> BM : Deposit Money
activate BM
BM --> A : ACK
deactivate BM
AH -> BM : Apply For Loan
BM --> AH : Open Account
note over AH : processing open account
BM --> AH : Pay Bill
note over AH : processing pay bill
@enduml