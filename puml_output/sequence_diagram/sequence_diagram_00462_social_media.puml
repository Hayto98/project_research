@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
boundary "User" as U
entity "Admin" as A
entity "Moderator" as M
control "Advertiser" as A2
A2 --> A : Create Post
M ->> A : Report Content
note over A : processing report content
U ->> A : Comment
activate A
A --> U : ACK
deactivate A
note over A : processing comment
A ->> A2 : Share Post
note over A2 : processing share post
M -> U : Like Post
M ->> A2 : Send Message
@enduml