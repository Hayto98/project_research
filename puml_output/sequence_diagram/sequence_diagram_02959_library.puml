@startuml
skinparam monochrome true
skinparam shadowing true
participant "Admin" as A
participant "Librarian" as L
entity "Member" as M
M -> L : Renew Loan
note over L : processing renew loan
M --> L : Borrow Book
activate L
L --> M : ACK
deactivate L
L -> M : Pay Fine
activate M
M --> L : ACK
deactivate M
M ->> A : Return Book
A -> M : Search Catalog
activate M
M --> A : ACK
deactivate M
@enduml