@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
boundary "Registrar" as R
participant "Student" as S
actor "Parent" as P
participant "Admin" as A
P ->> R : Issue Certificate
note over R : processing issue certificate
A --> P : Submit Assignment
activate P
P --> A : ACK
deactivate P
S -> P : Take Attendance
S --> P : View Schedule
R --> A : Register Student
@enduml