@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
boundary "Admin" as A
control "Member" as M
boundary "Librarian" as L
L -> A : Add New Book
M ->> A : Pay Fine
A --> L : Register Member
A -> L : Renew Loan
L ->> A : Search Catalog
activate A
A --> L : ACK
deactivate A
M -> A : Reserve Book
activate A
A --> M : ACK
deactivate A
@enduml