@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
entity "Moderator" as M
control "Advertiser" as A
entity "Admin" as A2
M ->> A : Report Content
A2 ->> M : Share Post
activate M
M --> A2 : ACK
deactivate M
M ->> A2 : Create Post
M --> A2 : Follow User
activate A2
A2 --> M : ACK
deactivate A2
A2 -> A : Comment
note over A : processing comment
A --> A2 : Send Message
@enduml