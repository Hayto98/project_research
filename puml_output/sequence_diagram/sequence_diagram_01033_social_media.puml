@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
actor "User" as U
entity "Admin" as A
control "Advertiser" as A2
boundary "Moderator" as M
M -> A : Share Post
activate A
A --> M : ACK
deactivate A
A2 -> M : Edit Profile
A2 --> M : Create Post
A -> M : Like Post
A ->> M : Report Content
@enduml