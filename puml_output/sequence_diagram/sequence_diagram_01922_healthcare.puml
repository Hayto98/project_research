@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
actor "Insurance Provider" as IP
boundary "Receptionist" as R
actor "Patient" as P
boundary "Nurse" as N
IP -> N : Admit Patient
IP -> P : Discharge Patient
N ->> P : Book Appointment
R -> P : Issue Prescription
N -> R : Update Medical Record
activate R
R --> N : ACK
deactivate R
@enduml