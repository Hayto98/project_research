@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
boundary "Librarian" as L
entity "Member" as M
participant "Admin" as A
L ->> M : Return Book
note over M : processing return book
A ->> L : Add New Book
M ->> A : Renew Loan
activate A
A --> M : ACK
deactivate A
L --> M : Pay Fine
note over M : processing pay fine
L --> M : Borrow Book
activate M
M --> L : ACK
deactivate M
note over M : processing borrow book
M --> L : Register Member
activate L
L --> M : ACK
deactivate L
note over L : processing register member
A --> L : Search Catalog
note over L : processing search catalog
@enduml