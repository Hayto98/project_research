@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
actor "Librarian" as L
participant "Admin" as A
control "Member" as M
L --> M : Return Book
activate M
M --> L : ACK
deactivate M
M ->> A : Reserve Book
M --> A : Renew Loan
A --> M : Borrow Book
L -> M : Add New Book
@enduml