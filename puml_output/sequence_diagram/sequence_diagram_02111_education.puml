@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
participant "Admin" as A
participant "Librarian" as L
participant "Student" as S
L -> A : Borrow Book
activate A
A --> L : ACK
deactivate A
L --> S : Submit Assignment
S --> A : Issue Certificate
S -> A : Grade Exam
@enduml