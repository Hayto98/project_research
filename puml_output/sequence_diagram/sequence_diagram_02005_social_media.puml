@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
participant "Moderator" as M
entity "Advertiser" as A
entity "Admin" as A2
boundary "User" as U
A2 --> A : Like Post
U ->> A : Comment
M -> A : Follow User
M ->> A2 : Report Content
activate A2
A2 --> M : ACK
deactivate A2
@enduml