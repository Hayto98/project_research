@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
participant "Housekeeper" as H
actor "Receptionist" as R
actor "Chef" as C
H --> R : Order Room Service
activate R
R --> H : ACK
deactivate R
C --> R : Book Room
H -> C : Check Out
C ->> H : Clean Room
activate H
H --> C : ACK
deactivate H
C ->> H : Check In
activate H
H --> C : ACK
deactivate H
@enduml