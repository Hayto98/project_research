@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
boundary "Admin" as A
boundary "Member" as M
boundary "Librarian" as L
A ->> M : Renew Loan
L --> M : Register Member
activate M
M --> L : ACK
deactivate M
L --> M : Borrow Book
activate M
M --> L : ACK
deactivate M
note over M : processing borrow book
M --> A : Reserve Book
note over A : processing reserve book
L -> M : Pay Fine
M -> L : Return Book
activate L
L --> M : ACK
deactivate L
A ->> M : Search Catalog
activate M
M --> A : ACK
deactivate M
note over M : processing search catalog
@enduml