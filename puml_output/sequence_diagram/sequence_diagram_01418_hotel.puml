@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
participant "Chef" as C
control "Manager" as M
control "Receptionist" as R
R -> C : Book Room
activate C
C --> R : ACK
deactivate C
note over C : processing book room
R --> M : Cancel Reservation
C -> R : Request Service
R -> C : Clean Room
C -> M : Check In
activate M
M --> C : ACK
deactivate M
@enduml