@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
control "Fleet Manager" as FM
control "Customer" as C
boundary "Warehouse Staff" as WS
actor "Driver" as D
FM -> WS : Report Issue
WS -> FM : Fuel Vehicle
C -> FM : Update Inventory
activate FM
FM --> C : ACK
deactivate FM
note over FM : processing update inventory
FM ->> C : Load Package
@enduml