@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
boundary "Housekeeper" as H
participant "Manager" as M
entity "Receptionist" as R
participant "Chef" as C
R ->> M : Clean Room
activate M
M --> R : ACK
deactivate M
note over M : processing clean room
H --> C : Request Service
activate C
C --> H : ACK
deactivate C
H --> M : Process Payment
R -> C : Check In
@enduml