@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
participant "Advertiser" as A
actor "Admin" as A2
control "Moderator" as M
A2 ->> M : Report Content
activate M
M --> A2 : ACK
deactivate M
note over M : processing report content
A2 --> A : Follow User
M -> A2 : Send Message
A2 --> M : Share Post
note over M : processing share post
A -> A2 : Edit Profile
activate A2
A2 --> A : ACK
deactivate A2
note over A2 : processing edit profile
M -> A2 : Create Post
A ->> M : Comment
note over M : processing comment
@enduml