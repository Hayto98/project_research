@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
boundary "Student" as S
actor "Librarian" as L
entity "Registrar" as R
participant "Parent" as P
L -> P : Grade Exam
activate P
P --> L : ACK
deactivate P
L --> R : Submit Assignment
activate R
R --> L : ACK
deactivate R
S -> R : Issue Certificate
activate R
R --> S : ACK
deactivate R
L -> R : Borrow Book
activate R
R --> L : ACK
deactivate R
@enduml