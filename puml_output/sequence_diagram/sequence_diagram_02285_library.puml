@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
boundary "Member" as M
actor "Librarian" as L
actor "Admin" as A
A --> M : Search Catalog
L -> M : Renew Loan
activate M
M --> L : ACK
deactivate M
L -> M : Pay Fine
note over M : processing pay fine
A -> L : Reserve Book
@enduml