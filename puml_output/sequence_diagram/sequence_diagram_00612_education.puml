@startuml
skinparam shadowing true
entity "Parent" as P
control "Teacher" as T
entity "Librarian" as L
boundary "Admin" as A
participant "Registrar" as R
P -> R : Take Attendance
R -> T : Grade Exam
P ->> L : Submit Assignment
R --> A : View Schedule
activate A
A --> R : ACK
deactivate A
note over A : processing view schedule
@enduml