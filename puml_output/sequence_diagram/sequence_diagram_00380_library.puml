@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
actor "Admin" as A
entity "Librarian" as L
participant "Member" as M
M -> A : Reserve Book
activate A
A --> M : ACK
deactivate A
L --> A : Borrow Book
M ->> L : Search Catalog
L --> M : Pay Fine
activate M
M --> L : ACK
deactivate M
L ->> M : Add New Book
activate M
M --> L : ACK
deactivate M
M ->> L : Renew Loan
@enduml