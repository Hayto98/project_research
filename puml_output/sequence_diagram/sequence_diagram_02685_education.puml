@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
control "Student" as S
actor "Registrar" as R
actor "Teacher" as T
actor "Librarian" as L
L ->> T : Submit Assignment
R --> T : Borrow Book
note over T : processing borrow book
L ->> R : Issue Certificate
T --> R : Take Attendance
@enduml