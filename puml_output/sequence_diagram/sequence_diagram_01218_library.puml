@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
actor "Admin" as A
actor "Member" as M
actor "Librarian" as L
M -> A : Pay Fine
note over A : processing pay fine
A -> L : Return Book
L -> M : Renew Loan
L -> M : Register Member
A --> L : Borrow Book
note over L : processing borrow book
L ->> M : Search Catalog
activate M
M --> L : ACK
deactivate M
@enduml