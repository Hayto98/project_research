@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
boundary "Customer" as C
entity "Delivery Service" as DS
actor "Admin" as A
actor "Payment Gateway" as PG
boundary "Seller" as S
C ->> A : Cancel Order
activate A
A --> C : ACK
deactivate A
DS -> S : Checkout
C ->> DS : Write Review
S --> PG : Make Payment
activate PG
PG --> S : ACK
deactivate PG
C --> S : Track Order
activate S
S --> C : ACK
deactivate S
A --> PG : Browse Products
activate PG
PG --> A : ACK
deactivate PG
note over PG : processing browse products
@enduml