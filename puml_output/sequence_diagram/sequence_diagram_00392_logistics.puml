@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
participant "Warehouse Staff" as WS
actor "Customer" as C
boundary "Fleet Manager" as FM
entity "Dispatcher" as D
FM -> WS : Track Shipment
WS ->> FM : Load Package
FM -> C : Schedule Pickup
D -> FM : Update Inventory
@enduml