@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
actor "Receptionist" as R
control "Guest" as G
participant "Manager" as M
participant "Chef" as C
M -> G : Clean Room
C --> G : Book Room
note over G : processing book room
M -> G : Cancel Reservation
activate G
G --> M : ACK
deactivate G
M --> R : Check Out
activate R
R --> M : ACK
deactivate R
note over R : processing check out
C ->> M : Check In
activate M
M --> C : ACK
deactivate M
@enduml