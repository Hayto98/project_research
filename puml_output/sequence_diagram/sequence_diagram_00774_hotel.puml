@startuml

boundary "Receptionist" as R
entity "Guest" as G
boundary "Housekeeper" as H
control "Chef" as C
actor "Manager" as M
G -> M : Request Service
note over M : processing request service
H ->> R : Check Out
activate R
R --> H : ACK
deactivate R
note over R : processing check out
C --> G : Process Payment
activate G
G --> C : ACK
deactivate G
G -> H : Order Room Service
activate H
H --> G : ACK
deactivate H
M ->> C : Book Room
M -> C : Cancel Reservation
M -> G : Clean Room
@enduml