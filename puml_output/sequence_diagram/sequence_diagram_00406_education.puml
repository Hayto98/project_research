@startuml
skinparam monochrome true
skinparam ArrowColor #555555
boundary "Librarian" as L
boundary "Student" as S
entity "Teacher" as T
S -> L : Enroll Course
S -> T : View Schedule
S --> L : Borrow Book
activate L
L --> S : ACK
deactivate L
L -> T : Take Attendance
S ->> L : Register Student
T -> S : Grade Exam
activate S
S --> T : ACK
deactivate S
@enduml