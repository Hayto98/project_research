@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
boundary "Payment Gateway" as PG
control "Admin" as A
boundary "Seller" as S
boundary "Customer" as C
actor "Delivery Service" as DS
S --> PG : Track Order
DS --> C : Apply Coupon
note over C : processing apply coupon
A -> PG : Write Review
PG ->> S : Add To Cart
activate S
S --> PG : ACK
deactivate S
A --> S : Cancel Order
activate S
S --> A : ACK
deactivate S
C ->> DS : Browse Products
note over DS : processing browse products
@enduml