@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
boundary "Admin" as A
actor "Librarian" as L
control "Teacher" as T
actor "Student" as S
A --> S : Take Attendance
activate S
S --> A : ACK
deactivate S
L ->> A : Enroll Course
S ->> L : Submit Assignment
activate L
L --> S : ACK
deactivate L
S ->> L : Grade Exam
activate L
L --> S : ACK
deactivate L
note over L : processing grade exam
S -> T : View Schedule
activate T
T --> S : ACK
deactivate T
note over T : processing view schedule
T ->> S : Register Student
@enduml