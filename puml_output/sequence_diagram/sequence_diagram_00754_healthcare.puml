@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
boundary "Lab Technician" as LT
actor "Receptionist" as R
control "Doctor" as D
participant "Insurance Provider" as IP
entity "Patient" as P
D --> R : Discharge Patient
activate R
R --> D : ACK
deactivate R
P --> D : Run Lab Test
D -> LT : Book Appointment
activate LT
LT --> D : ACK
deactivate LT
P ->> R : Update Medical Record
IP --> LT : Process Insurance Claim
activate LT
LT --> IP : ACK
deactivate LT
R ->> D : Issue Prescription
P -> R : Admit Patient
activate R
R --> P : ACK
deactivate R
@enduml