@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
entity "Nurse" as N
participant "Lab Technician" as LT
boundary "Insurance Provider" as IP
boundary "Doctor" as D
IP --> LT : Book Appointment
D ->> N : Discharge Patient
N -> D : Admit Patient
LT -> IP : Examine Patient
note over IP : processing examine patient
@enduml