@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
participant "Chef" as C
participant "Receptionist" as R
participant "Guest" as G
entity "Manager" as M
R --> C : Process Payment
R ->> G : Clean Room
C -> M : Check Out
note over M : processing check out
R ->> C : Order Room Service
note over C : processing order room service
C --> R : Cancel Reservation
@enduml