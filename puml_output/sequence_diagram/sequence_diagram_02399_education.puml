@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
entity "Teacher" as T
entity "Parent" as P
participant "Registrar" as R
actor "Student" as S
control "Admin" as A
R -> S : Borrow Book
R --> P : Enroll Course
T ->> A : Issue Certificate
S -> P : Take Attendance
A -> T : Grade Exam
@enduml