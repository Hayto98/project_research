@startuml
skinparam monochrome true
boundary "Housekeeper" as H
actor "Receptionist" as R
participant "Manager" as M
R --> M : Check In
R ->> H : Check Out
R -> H : Order Room Service
H ->> M : Request Service
activate M
M --> H : ACK
deactivate M
R ->> M : Clean Room
activate M
M --> R : ACK
deactivate M
@enduml