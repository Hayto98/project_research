@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
control "Customer" as C
entity "Warehouse Staff" as WS
actor "Driver" as D
control "Dispatcher" as D2
boundary "Fleet Manager" as FM
WS ->> C : Update Inventory
activate C
C --> WS : ACK
deactivate C
note over C : processing update inventory
C ->> WS : Deliver Package
activate WS
WS --> C : ACK
deactivate WS
note over WS : processing deliver package
C --> D : Fuel Vehicle
activate D
D --> C : ACK
deactivate D
note over D : processing fuel vehicle
WS ->> FM : Load Package
activate FM
FM --> WS : ACK
deactivate FM
FM --> WS : Track Shipment
activate WS
WS --> FM : ACK
deactivate WS
@enduml