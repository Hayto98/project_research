@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
actor "Moderator" as M
actor "User" as U
control "Admin" as A
entity "Advertiser" as A2
U ->> A2 : Create Post
note over A2 : processing create post
A --> U : Send Message
note over U : processing send message
A2 --> U : Share Post
note over U : processing share post
U -> A2 : Report Content
note over A2 : processing report content
U ->> A : Comment
@enduml