@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
actor "Moderator" as M
control "User" as U
boundary "Advertiser" as A
boundary "Admin" as A2
M --> A : Share Post
note over A : processing share post
A --> A2 : Edit Profile
U -> M : Send Message
A -> U : Comment
note over U : processing comment
@enduml