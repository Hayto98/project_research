@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
entity "Parent" as P
control "Student" as S
participant "Teacher" as T
S --> T : Take Attendance
activate T
T --> S : ACK
deactivate T
P -> T : View Schedule
activate T
T --> P : ACK
deactivate T
P -> T : Submit Assignment
P --> S : Register Student
note over S : processing register student
T ->> S : Enroll Course
@enduml