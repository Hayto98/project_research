@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
actor "Account Holder" as AH
actor "Branch Manager" as BM
boundary "Bank Teller" as BT
actor "Auditor" as A
entity "ATM" as A2
BT ->> AH : Withdraw Cash
activate AH
AH --> BT : ACK
deactivate AH
BT -> BM : Open Account
AH -> A2 : Apply For Loan
activate A2
A2 --> AH : ACK
deactivate A2
note over A2 : processing apply for loan
A2 ->> BT : View Statement
A2 ->> A : Deposit Money
A -> BT : Pay Bill
@enduml