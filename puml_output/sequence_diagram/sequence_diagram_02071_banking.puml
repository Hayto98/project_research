@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
actor "Auditor" as A
boundary "Bank Teller" as BT
control "Branch Manager" as BM
actor "ATM" as A2
boundary "Account Holder" as AH
BM --> A : Pay Bill
activate A
A --> BM : ACK
deactivate A
AH -> A2 : Withdraw Cash
BT --> BM : Apply For Loan
activate BM
BM --> BT : ACK
deactivate BM
note over BM : processing apply for loan
BM ->> A : Open Account
activate A
A --> BM : ACK
deactivate A
BM --> A2 : Block Card
activate A2
A2 --> BM : ACK
deactivate A2
@enduml