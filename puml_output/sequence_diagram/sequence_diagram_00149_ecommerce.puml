@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
control "Delivery Service" as DS
participant "Admin" as A
entity "Customer" as C
C ->> DS : Apply Coupon
note over DS : processing apply coupon
C --> A : Write Review
C -> DS : Track Order
DS --> A : Browse Products
A --> C : Manage Inventory
note over C : processing manage inventory
@enduml