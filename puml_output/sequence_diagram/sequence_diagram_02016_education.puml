@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
control "Student" as S
entity "Librarian" as L
entity "Teacher" as T
S --> L : Take Attendance
activate L
L --> S : ACK
deactivate L
T --> S : Issue Certificate
activate S
S --> T : ACK
deactivate S
note over S : processing issue certificate
S -> T : Grade Exam
activate T
T --> S : ACK
deactivate T
S -> L : Submit Assignment
activate L
L --> S : ACK
deactivate L
@enduml