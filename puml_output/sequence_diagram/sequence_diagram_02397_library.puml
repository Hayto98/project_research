@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
boundary "Librarian" as L
participant "Admin" as A
boundary "Member" as M
M -> L : Return Book
M ->> A : Renew Loan
M ->> L : Borrow Book
activate L
L --> M : ACK
deactivate L
note over L : processing borrow book
A -> L : Add New Book
activate L
L --> A : ACK
deactivate L
M --> L : Pay Fine
activate L
L --> M : ACK
deactivate L
A --> M : Search Catalog
@enduml