@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
participant "Insurance Provider" as IP
entity "Lab Technician" as LT
participant "Nurse" as N
N ->> LT : Update Medical Record
note over LT : processing update medical record
IP -> LT : Discharge Patient
N -> LT : Examine Patient
N -> LT : Admit Patient
activate LT
LT --> N : ACK
deactivate LT
note over LT : processing admit patient
LT ->> N : Book Appointment
note over N : processing book appointment
LT --> N : Run Lab Test
note over N : processing run lab test
@enduml