@startuml

boundary "Housekeeper" as H
control "Guest" as G
entity "Receptionist" as R
R ->> G : Check In
activate G
G --> R : ACK
deactivate G
note over G : processing check in
G -> H : Cancel Reservation
note over H : processing cancel reservation
G --> H : Clean Room
G -> H : Request Service
G --> H : Order Room Service
@enduml