@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
entity "Guest" as G
actor "Chef" as C
participant "Receptionist" as R
actor "Housekeeper" as H
entity "Manager" as M
G --> H : Request Service
note over H : processing request service
C ->> M : Process Payment
C -> M : Book Room
C ->> H : Check In
note over H : processing check in
@enduml