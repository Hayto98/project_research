@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
actor "Moderator" as M
control "User" as U
boundary "Admin" as A
M -> A : Report Content
U -> A : Comment
A --> M : Share Post
M --> A : Create Post
note over A : processing create post
A -> M : Send Message
U ->> M : Like Post
A ->> M : Follow User
@enduml