@startuml
skinparam monochrome true
skinparam shadowing true
boundary "Account Holder" as AH
actor "Auditor" as A
control "ATM" as A2
boundary "Branch Manager" as BM
AH ->> A2 : Block Card
activate A2
A2 --> AH : ACK
deactivate A2
A ->> BM : Pay Bill
A ->> A2 : Deposit Money
AH --> BM : Apply For Loan
activate BM
BM --> AH : ACK
deactivate BM
AH -> BM : Open Account
note over BM : processing open account
AH -> BM : Transfer Funds
note over BM : processing transfer funds
@enduml