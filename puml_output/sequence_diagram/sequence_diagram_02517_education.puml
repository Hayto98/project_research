@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
actor "Teacher" as T
actor "Student" as S
boundary "Registrar" as R
actor "Admin" as A
boundary "Parent" as P
R -> T : Grade Exam
activate T
T --> R : ACK
deactivate T
T --> R : Borrow Book
R ->> P : Take Attendance
note over P : processing take attendance
P ->> S : Issue Certificate
activate S
S --> P : ACK
deactivate S
S -> P : Register Student
R ->> P : View Schedule
@enduml