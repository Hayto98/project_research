@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
entity "Patient" as P
control "Receptionist" as R
control "Lab Technician" as LT
R --> P : Run Lab Test
activate P
P --> R : ACK
deactivate P
LT --> P : Process Insurance Claim
P -> R : Update Medical Record
LT --> P : Discharge Patient
@enduml