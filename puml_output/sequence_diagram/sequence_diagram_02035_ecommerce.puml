@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
boundary "Admin" as A
control "Seller" as S
participant "Customer" as C
control "Payment Gateway" as PG
C ->> A : Apply Coupon
PG ->> A : Make Payment
activate A
A --> PG : ACK
deactivate A
A -> S : Track Order
A --> S : Cancel Order
activate S
S --> A : ACK
deactivate S
PG ->> A : Browse Products
@enduml