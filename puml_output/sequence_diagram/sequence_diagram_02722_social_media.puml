@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
boundary "Moderator" as M
control "Admin" as A
boundary "User" as U
control "Advertiser" as A2
A --> M : Report Content
note over M : processing report content
M ->> A : Edit Profile
U -> A2 : Comment
activate A2
A2 --> U : ACK
deactivate A2
U ->> M : Create Post
activate M
M --> U : ACK
deactivate M
@enduml