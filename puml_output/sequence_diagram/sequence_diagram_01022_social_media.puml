@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
control "Advertiser" as A
entity "Admin" as A2
entity "Moderator" as M
entity "User" as U
M ->> U : Follow User
U ->> M : Share Post
activate M
M --> U : ACK
deactivate M
note over M : processing share post
A2 --> A : Send Message
U --> A : Like Post
note over A : processing like post
A2 ->> A : Create Post
@enduml