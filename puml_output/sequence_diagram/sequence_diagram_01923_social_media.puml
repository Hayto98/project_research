@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
control "Moderator" as M
participant "User" as U
actor "Advertiser" as A
actor "Admin" as A2
A -> U : Comment
M ->> A2 : Like Post
U -> A2 : Send Message
activate A2
A2 --> U : ACK
deactivate A2
A2 ->> A : Edit Profile
A -> U : Create Post
@enduml