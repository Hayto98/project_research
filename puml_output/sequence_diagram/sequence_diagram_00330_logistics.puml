@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
participant "Fleet Manager" as FM
control "Warehouse Staff" as WS
participant "Dispatcher" as D
FM ->> WS : Load Package
note over WS : processing load package
FM ->> D : Deliver Package
D ->> WS : Schedule Pickup
FM ->> D : Assign Route
@enduml