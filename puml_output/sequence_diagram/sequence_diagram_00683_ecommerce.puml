@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
boundary "Customer" as C
control "Admin" as A
participant "Delivery Service" as DS
DS ->> C : Track Order
activate C
C --> DS : ACK
deactivate C
note over C : processing track order
C --> DS : Make Payment
activate DS
DS --> C : ACK
deactivate DS
DS --> C : Write Review
activate C
C --> DS : ACK
deactivate C
DS -> A : Browse Products
activate A
A --> DS : ACK
deactivate A
DS -> A : Apply Coupon
@enduml