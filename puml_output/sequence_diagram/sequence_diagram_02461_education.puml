@startuml
skinparam monochrome true
skinparam defaultFontSize 13
actor "Teacher" as T
boundary "Admin" as A
control "Student" as S
entity "Librarian" as L
A --> T : Register Student
S -> L : Take Attendance
activate L
L --> S : ACK
deactivate L
T --> L : View Schedule
activate L
L --> T : ACK
deactivate L
A -> L : Enroll Course
S -> A : Submit Assignment
S -> A : Grade Exam
@enduml