@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
control "Receptionist" as R
boundary "Housekeeper" as H
boundary "Manager" as M
actor "Chef" as C
C ->> H : Order Room Service
note over H : processing order room service
C -> H : Request Service
note over H : processing request service
H --> C : Check In
activate C
C --> H : ACK
deactivate C
H -> M : Clean Room
@enduml