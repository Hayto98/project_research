@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
entity "Admin" as A
actor "Student" as S
control "Librarian" as L
S ->> L : Register Student
activate L
L --> S : ACK
deactivate L
note over L : processing register student
A --> S : Enroll Course
L ->> A : Issue Certificate
note over A : processing issue certificate
A ->> L : Submit Assignment
activate L
L --> A : ACK
deactivate L
@enduml