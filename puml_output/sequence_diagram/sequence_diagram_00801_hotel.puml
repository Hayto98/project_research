@startuml
skinparam monochrome true
skinparam defaultFontSize 13
entity "Housekeeper" as H
control "Manager" as M
actor "Receptionist" as R
R -> H : Book Room
activate H
H --> R : ACK
deactivate H
M ->> R : Check Out
activate R
R --> M : ACK
deactivate R
M ->> R : Process Payment
note over R : processing process payment
M -> R : Cancel Reservation
note over R : processing cancel reservation
@enduml