@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
participant "Delivery Service" as DS
control "Admin" as A
actor "Customer" as C
control "Payment Gateway" as PG
entity "Seller" as S
PG --> C : Track Order
activate C
C --> PG : ACK
deactivate C
C -> PG : Write Review
A ->> C : Cancel Order
A -> C : Apply Coupon
PG -> C : Browse Products
@enduml