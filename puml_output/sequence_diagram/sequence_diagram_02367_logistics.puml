@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
control "Fleet Manager" as FM
control "Dispatcher" as D
control "Warehouse Staff" as WS
D -> FM : Report Issue
activate FM
FM --> D : ACK
deactivate FM
FM --> D : Schedule Pickup
FM ->> D : Update Inventory
activate D
D --> FM : ACK
deactivate D
D -> FM : Deliver Package
activate FM
FM --> D : ACK
deactivate FM
@enduml