@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
control "Receptionist" as R
entity "Insurance Provider" as IP
boundary "Doctor" as D
participant "Patient" as P
actor "Nurse" as N
P ->> N : Discharge Patient
IP -> N : Issue Prescription
activate N
N --> IP : ACK
deactivate N
P -> IP : Examine Patient
activate IP
IP --> P : ACK
deactivate IP
D ->> R : Update Medical Record
N ->> P : Book Appointment
@enduml