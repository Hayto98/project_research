@startuml

participant "Auditor" as A
participant "Account Holder" as AH
actor "Branch Manager" as BM
A ->> AH : Apply For Loan
note over AH : processing apply for loan
AH ->> BM : Block Card
A --> BM : Pay Bill
note over BM : processing pay bill
AH -> BM : View Statement
activate BM
BM --> AH : ACK
deactivate BM
note over BM : processing view statement
A ->> BM : Open Account
@enduml