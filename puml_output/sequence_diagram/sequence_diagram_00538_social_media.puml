@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
actor "Admin" as A
control "Moderator" as M
actor "Advertiser" as A2
actor "User" as U
A ->> A2 : Edit Profile
A ->> U : Send Message
activate U
U --> A : ACK
deactivate U
A2 -> A : Follow User
activate A
A --> A2 : ACK
deactivate A
A --> U : Share Post
U -> A2 : Comment
U -> A : Like Post
activate A
A --> U : ACK
deactivate A
@enduml