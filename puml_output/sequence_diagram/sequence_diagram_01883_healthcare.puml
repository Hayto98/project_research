@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
actor "Insurance Provider" as IP
control "Lab Technician" as LT
participant "Receptionist" as R
actor "Doctor" as D
participant "Nurse" as N
N --> LT : Run Lab Test
activate LT
LT --> N : ACK
deactivate LT
note over LT : processing run lab test
N -> IP : Book Appointment
note over IP : processing book appointment
IP -> D : Examine Patient
IP --> N : Issue Prescription
IP ->> D : Process Insurance Claim
note over D : processing process insurance claim
R ->> D : Admit Patient
activate D
D --> R : ACK
deactivate D
note over D : processing admit patient
IP -> N : Update Medical Record
@enduml