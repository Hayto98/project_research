@startuml
skinparam ArrowColor #555555
actor "Bank Teller" as BT
participant "Account Holder" as AH
participant "Branch Manager" as BM
BT ->> AH : Apply For Loan
AH ->> BT : Pay Bill
AH ->> BM : Block Card
activate BM
BM --> AH : ACK
deactivate BM
AH -> BT : Withdraw Cash
note over BT : processing withdraw cash
AH --> BM : Transfer Funds
activate BM
BM --> AH : ACK
deactivate BM
BM --> BT : Open Account
activate BT
BT --> BM : ACK
deactivate BT
BT --> BM : Deposit Money
note over BM : processing deposit money
@enduml