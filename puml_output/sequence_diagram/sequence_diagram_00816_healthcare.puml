@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
participant "Patient" as P
entity "Receptionist" as R
participant "Doctor" as D
R -> P : Process Insurance Claim
activate P
P --> R : ACK
deactivate P
R ->> D : Discharge Patient
note over D : processing discharge patient
D ->> P : Admit Patient
R ->> D : Run Lab Test
note over D : processing run lab test
D ->> R : Update Medical Record
activate R
R --> D : ACK
deactivate R
note over R : processing update medical record
P ->> D : Book Appointment
activate D
D --> P : ACK
deactivate D
R --> P : Issue Prescription
@enduml