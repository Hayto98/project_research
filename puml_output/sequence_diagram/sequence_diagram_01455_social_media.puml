@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
control "User" as U
control "Advertiser" as A
boundary "Moderator" as M
U ->> M : Like Post
note over M : processing like post
M --> U : Share Post
note over U : processing share post
M --> U : Send Message
U ->> A : Create Post
activate A
A --> U : ACK
deactivate A
A --> M : Comment
activate M
M --> A : ACK
deactivate M
M --> U : Follow User
@enduml