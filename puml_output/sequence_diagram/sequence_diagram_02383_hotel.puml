@startuml
skinparam monochrome true
entity "Manager" as M
boundary "Housekeeper" as H
actor "Guest" as G
actor "Chef" as C
C -> M : Check In
note over M : processing check in
M ->> C : Cancel Reservation
note over C : processing cancel reservation
G -> C : Process Payment
C ->> G : Check Out
H --> M : Request Service
G ->> C : Clean Room
@enduml