@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
actor "Receptionist" as R
entity "Guest" as G
control "Housekeeper" as H
participant "Chef" as C
G -> R : Clean Room
C -> G : Request Service
activate G
G --> C : ACK
deactivate G
R -> C : Process Payment
C --> H : Cancel Reservation
G ->> H : Check In
C --> G : Order Room Service
activate G
G --> C : ACK
deactivate G
@enduml