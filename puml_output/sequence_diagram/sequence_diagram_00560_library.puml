@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
participant "Admin" as A
entity "Member" as M
actor "Librarian" as L
M ->> L : Register Member
activate L
L --> M : ACK
deactivate L
A --> M : Add New Book
activate M
M --> A : ACK
deactivate M
M --> L : Pay Fine
activate L
L --> M : ACK
deactivate L
A --> M : Return Book
activate M
M --> A : ACK
deactivate M
A --> M : Reserve Book
@enduml