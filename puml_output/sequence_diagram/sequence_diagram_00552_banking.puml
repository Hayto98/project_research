@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
actor "Auditor" as A
entity "ATM" as A2
control "Branch Manager" as BM
participant "Account Holder" as AH
entity "Bank Teller" as BT
BT -> A : Block Card
note over A : processing block card
AH -> BT : Open Account
A2 --> BM : Pay Bill
activate BM
BM --> A2 : ACK
deactivate BM
note over BM : processing pay bill
BM ->> AH : Transfer Funds
activate AH
AH --> BM : ACK
deactivate AH
BT -> A : Deposit Money
@enduml