@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
control "Customer" as C
control "Warehouse Staff" as WS
entity "Fleet Manager" as FM
C -> WS : Fuel Vehicle
FM ->> C : Deliver Package
note over C : processing deliver package
WS -> FM : Update Inventory
activate FM
FM --> WS : ACK
deactivate FM
note over FM : processing update inventory
C -> FM : Load Package
activate FM
FM --> C : ACK
deactivate FM
FM -> WS : Track Shipment
note over WS : processing track shipment
@enduml