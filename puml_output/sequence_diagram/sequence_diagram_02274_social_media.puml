@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
control "Moderator" as M
actor "Advertiser" as A
boundary "Admin" as A2
participant "User" as U
U ->> A2 : Create Post
M --> A : Edit Profile
M -> A : Send Message
activate A
A --> M : ACK
deactivate A
A2 ->> U : Report Content
activate U
U --> A2 : ACK
deactivate U
note over U : processing report content
A2 ->> M : Like Post
@enduml