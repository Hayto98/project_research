@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
actor "Advertiser" as A
entity "Moderator" as M
control "Admin" as A2
control "User" as U
M --> A : Report Content
U -> A : Send Message
note over A : processing send message
A --> U : Share Post
M -> U : Edit Profile
A2 -> M : Create Post
U -> A : Like Post
@enduml