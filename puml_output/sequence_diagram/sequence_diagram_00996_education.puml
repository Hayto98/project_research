@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
boundary "Teacher" as T
boundary "Registrar" as R
actor "Parent" as P
R -> P : Submit Assignment
activate P
P --> R : ACK
deactivate P
P ->> R : Grade Exam
P ->> R : Borrow Book
activate R
R --> P : ACK
deactivate R
R ->> T : Enroll Course
activate T
T --> R : ACK
deactivate T
@enduml