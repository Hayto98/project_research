@startuml
skinparam monochrome true
skinparam shadowing true
actor "Member" as M
control "Librarian" as L
actor "Admin" as A
L ->> A : Add New Book
L -> M : Search Catalog
activate M
M --> L : ACK
deactivate M
note over M : processing search catalog
L --> A : Register Member
M -> L : Renew Loan
note over L : processing renew loan
@enduml