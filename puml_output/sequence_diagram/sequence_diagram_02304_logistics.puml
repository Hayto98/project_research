@startuml
skinparam shadowing true
entity "Fleet Manager" as FM
participant "Warehouse Staff" as WS
control "Dispatcher" as D
actor "Customer" as C
WS --> FM : Fuel Vehicle
D --> C : Track Shipment
activate C
C --> D : ACK
deactivate C
D --> C : Report Issue
FM --> D : Schedule Pickup
activate D
D --> FM : ACK
deactivate D
C --> D : Load Package
@enduml