@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
control "Fleet Manager" as FM
control "Driver" as D
participant "Customer" as C
participant "Dispatcher" as D2
entity "Warehouse Staff" as WS
D ->> FM : Schedule Pickup
note over FM : processing schedule pickup
FM ->> D : Track Shipment
activate D
D --> FM : ACK
deactivate D
D2 -> D : Fuel Vehicle
WS ->> FM : Load Package
activate FM
FM --> WS : ACK
deactivate FM
C ->> FM : Deliver Package
WS --> C : Update Inventory
activate C
C --> WS : ACK
deactivate C
FM --> D : Assign Route
@enduml