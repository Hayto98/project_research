@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
boundary "Admin" as A
entity "Advertiser" as A2
control "Moderator" as M
M -> A2 : Follow User
activate A2
A2 --> M : ACK
deactivate A2
M --> A2 : Like Post
activate A2
A2 --> M : ACK
deactivate A2
M --> A2 : Comment
A2 --> M : Send Message
@enduml