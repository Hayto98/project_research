@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
control "Librarian" as L
actor "Member" as M
control "Admin" as A
A --> L : Reserve Book
M --> L : Return Book
A -> M : Search Catalog
activate M
M --> A : ACK
deactivate M
M ->> A : Renew Loan
L -> M : Pay Fine
activate M
M --> L : ACK
deactivate M
note over M : processing pay fine
@enduml