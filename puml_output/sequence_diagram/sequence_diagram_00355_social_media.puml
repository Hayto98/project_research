@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
actor "Moderator" as M
actor "Admin" as A
control "User" as U
actor "Advertiser" as A2
U -> M : Share Post
M ->> U : Comment
U ->> A2 : Send Message
U --> A : Create Post
activate A
A --> U : ACK
deactivate A
A2 -> M : Like Post
A2 -> M : Edit Profile
activate M
M --> A2 : ACK
deactivate M
@enduml