@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
boundary "Member" as M
entity "Admin" as A
boundary "Librarian" as L
M --> A : Pay Fine
note over A : processing pay fine
M -> L : Register Member
L --> A : Reserve Book
A ->> M : Borrow Book
note over M : processing borrow book
@enduml