@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
boundary "Admin" as A
boundary "Member" as M
participant "Librarian" as L
M -> L : Return Book
activate L
L --> M : ACK
deactivate L
M ->> A : Renew Loan
L --> M : Pay Fine
A -> M : Add New Book
L --> M : Reserve Book
activate M
M --> L : ACK
deactivate M
@enduml