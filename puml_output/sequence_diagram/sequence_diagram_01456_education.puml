@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
entity "Parent" as P
boundary "Student" as S
boundary "Registrar" as R
participant "Admin" as A
entity "Librarian" as L
S --> R : Take Attendance
activate R
R --> S : ACK
deactivate R
L ->> R : Enroll Course
activate R
R --> L : ACK
deactivate R
note over R : processing enroll course
P -> R : Grade Exam
R ->> P : Borrow Book
A ->> R : Submit Assignment
note over R : processing submit assignment
R --> P : Issue Certificate
@enduml