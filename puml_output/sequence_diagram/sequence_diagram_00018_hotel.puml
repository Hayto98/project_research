@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
control "Housekeeper" as H
actor "Receptionist" as R
control "Manager" as M
participant "Chef" as C
H --> M : Check In
activate M
M --> H : ACK
deactivate M
note over M : processing check in
H --> M : Order Room Service
note over M : processing order room service
C --> R : Book Room
H --> R : Request Service
R -> H : Check Out
H -> R : Clean Room
note over R : processing clean room
@enduml