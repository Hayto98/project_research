@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
boundary "User" as U
participant "Admin" as A
actor "Advertiser" as A2
A2 ->> U : Send Message
A2 --> A : Comment
activate A
A --> A2 : ACK
deactivate A
A2 --> A : Edit Profile
activate A
A --> A2 : ACK
deactivate A
U -> A2 : Like Post
activate A2
A2 --> U : ACK
deactivate A2
@enduml