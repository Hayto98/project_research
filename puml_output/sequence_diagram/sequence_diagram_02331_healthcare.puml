@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
boundary "Patient" as P
actor "Nurse" as N
entity "Lab Technician" as LT
control "Doctor" as D
boundary "Receptionist" as R
N ->> P : Discharge Patient
N ->> P : Issue Prescription
note over P : processing issue prescription
LT -> N : Admit Patient
activate N
N --> LT : ACK
deactivate N
R --> P : Examine Patient
note over P : processing examine patient
@enduml