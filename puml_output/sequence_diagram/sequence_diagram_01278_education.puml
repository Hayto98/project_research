@startuml
skinparam defaultFontSize 11
control "Registrar" as R
actor "Librarian" as L
boundary "Parent" as P
actor "Student" as S
S --> L : Issue Certificate
P ->> S : Register Student
R -> P : Take Attendance
activate P
P --> R : ACK
deactivate P
L ->> S : View Schedule
activate S
S --> L : ACK
deactivate S
R -> P : Borrow Book
L --> S : Enroll Course
@enduml