@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
participant "Moderator" as M
control "Admin" as A
control "Advertiser" as A2
control "User" as U
A2 ->> U : Like Post
M --> A2 : Share Post
activate A2
A2 --> M : ACK
deactivate A2
A ->> M : Comment
activate M
M --> A : ACK
deactivate M
M -> U : Send Message
activate U
U --> M : ACK
deactivate U
M ->> A : Report Content
note over A : processing report content
M --> A2 : Create Post
@enduml