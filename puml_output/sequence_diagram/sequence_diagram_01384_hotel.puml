@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
participant "Chef" as C
entity "Manager" as M
participant "Receptionist" as R
participant "Guest" as G
boundary "Housekeeper" as H
M --> C : Clean Room
H --> R : Order Room Service
G ->> H : Book Room
M ->> C : Process Payment
activate C
C --> M : ACK
deactivate C
H -> R : Check Out
activate R
R --> H : ACK
deactivate R
note over R : processing check out
G ->> M : Cancel Reservation
G --> R : Check In
activate R
R --> G : ACK
deactivate R
@enduml