@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
participant "Librarian" as L
control "Registrar" as R
entity "Student" as S
S -> L : Take Attendance
S --> L : Submit Assignment
L ->> R : Register Student
activate R
R --> L : ACK
deactivate R
L --> S : Enroll Course
S ->> L : Grade Exam
L --> R : View Schedule
note over R : processing view schedule
@enduml