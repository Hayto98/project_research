@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
entity "Driver" as D
entity "Dispatcher" as D2
actor "Warehouse Staff" as WS
participant "Fleet Manager" as FM
entity "Customer" as C
FM --> WS : Deliver Package
WS -> FM : Assign Route
activate FM
FM --> WS : ACK
deactivate FM
C ->> WS : Track Shipment
D2 --> D : Report Issue
C ->> FM : Schedule Pickup
WS ->> D2 : Load Package
@enduml