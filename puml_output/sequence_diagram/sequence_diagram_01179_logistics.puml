@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
control "Driver" as D
participant "Fleet Manager" as FM
actor "Dispatcher" as D2
actor "Customer" as C
D ->> FM : Update Inventory
C ->> FM : Track Shipment
D -> FM : Report Issue
FM -> C : Schedule Pickup
C -> D : Deliver Package
activate D
D --> C : ACK
deactivate D
@enduml