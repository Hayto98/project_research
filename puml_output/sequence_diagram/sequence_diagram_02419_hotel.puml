@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
boundary "Receptionist" as R
boundary "Housekeeper" as H
control "Chef" as C
C -> H : Clean Room
H ->> R : Request Service
C ->> H : Check Out
R -> H : Order Room Service
activate H
H --> R : ACK
deactivate H
note over H : processing order room service
C -> R : Cancel Reservation
R -> C : Process Payment
activate C
C --> R : ACK
deactivate C
C ->> H : Book Room
activate H
H --> C : ACK
deactivate H
@enduml