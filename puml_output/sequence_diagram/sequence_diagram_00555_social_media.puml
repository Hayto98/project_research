@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
actor "User" as U
actor "Advertiser" as A
boundary "Moderator" as M
actor "Admin" as A2
M --> A : Follow User
activate A
A --> M : ACK
deactivate A
U -> A2 : Report Content
activate A2
A2 --> U : ACK
deactivate A2
note over A2 : processing report content
U ->> A2 : Share Post
activate A2
A2 --> U : ACK
deactivate A2
U -> A : Send Message
@enduml