@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
control "Admin" as A
actor "Payment Gateway" as PG
entity "Delivery Service" as DS
actor "Seller" as S
boundary "Customer" as C
S --> PG : Add To Cart
A -> S : Apply Coupon
PG --> A : Write Review
activate A
A --> PG : ACK
deactivate A
note over A : processing write review
C ->> S : Cancel Order
S -> C : Checkout
activate C
C --> S : ACK
deactivate C
S ->> C : Make Payment
@enduml