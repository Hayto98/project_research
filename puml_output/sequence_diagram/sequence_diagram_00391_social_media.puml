@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
boundary "Advertiser" as A
control "User" as U
participant "Admin" as A2
A2 ->> A : Share Post
A2 ->> U : Create Post
A --> A2 : Report Content
A2 -> U : Like Post
activate U
U --> A2 : ACK
deactivate U
A ->> A2 : Follow User
@enduml