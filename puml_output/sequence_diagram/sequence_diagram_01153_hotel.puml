@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
entity "Receptionist" as R
entity "Guest" as G
participant "Chef" as C
R --> G : Book Room
note over G : processing book room
R -> C : Process Payment
G --> C : Check Out
activate C
C --> G : ACK
deactivate C
C ->> R : Cancel Reservation
@enduml