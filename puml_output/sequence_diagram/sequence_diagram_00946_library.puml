@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
control "Librarian" as L
participant "Member" as M
entity "Admin" as A
A -> L : Reserve Book
L --> A : Search Catalog
activate A
A --> L : ACK
deactivate A
L ->> A : Borrow Book
activate A
A --> L : ACK
deactivate A
M ->> A : Renew Loan
@enduml