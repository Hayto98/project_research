@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
control "Branch Manager" as BM
boundary "Account Holder" as AH
entity "Bank Teller" as BT
AH ->> BT : Open Account
BM --> BT : Pay Bill
AH --> BT : Apply For Loan
note over BT : processing apply for loan
BT ->> AH : Block Card
@enduml