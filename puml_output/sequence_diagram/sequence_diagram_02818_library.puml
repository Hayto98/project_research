@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
control "Librarian" as L
actor "Admin" as A
actor "Member" as M
L ->> A : Borrow Book
activate A
A --> L : ACK
deactivate A
A ->> L : Search Catalog
M --> L : Renew Loan
L --> A : Reserve Book
@enduml