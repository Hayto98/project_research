@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
entity "Teacher" as T
participant "Student" as S
entity "Librarian" as L
entity "Registrar" as R
entity "Admin" as A
R ->> T : Grade Exam
S ->> L : Issue Certificate
A -> T : Enroll Course
L --> T : Register Student
A ->> L : Submit Assignment
activate L
L --> A : ACK
deactivate L
@enduml