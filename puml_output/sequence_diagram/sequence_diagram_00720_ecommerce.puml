@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
control "Admin" as A
boundary "Seller" as S
actor "Customer" as C
participant "Payment Gateway" as PG
S --> C : Checkout
A --> C : Make Payment
activate C
C --> A : ACK
deactivate C
note over C : processing make payment
PG -> C : Browse Products
PG -> A : Apply Coupon
S ->> A : Track Order
@enduml