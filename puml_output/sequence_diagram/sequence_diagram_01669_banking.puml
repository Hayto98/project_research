@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
boundary "Branch Manager" as BM
control "Auditor" as A
participant "Account Holder" as AH
actor "ATM" as A2
A2 ->> BM : Block Card
AH -> A2 : Apply For Loan
activate A2
A2 --> AH : ACK
deactivate A2
BM ->> AH : Withdraw Cash
A -> AH : View Statement
activate AH
AH --> A : ACK
deactivate AH
AH -> BM : Pay Bill
A --> A2 : Deposit Money
@enduml