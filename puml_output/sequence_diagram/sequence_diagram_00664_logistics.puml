@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
control "Warehouse Staff" as WS
actor "Fleet Manager" as FM
control "Driver" as D
D --> WS : Fuel Vehicle
WS --> D : Assign Route
D ->> FM : Deliver Package
FM ->> WS : Track Shipment
activate WS
WS --> FM : ACK
deactivate WS
note over WS : processing track shipment
FM ->> D : Schedule Pickup
note over D : processing schedule pickup
@enduml