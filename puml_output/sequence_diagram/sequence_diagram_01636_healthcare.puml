@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
participant "Patient" as P
boundary "Receptionist" as R
boundary "Doctor" as D
boundary "Lab Technician" as LT
LT -> P : Update Medical Record
D --> P : Issue Prescription
D -> R : Examine Patient
D -> LT : Book Appointment
note over LT : processing book appointment
R ->> LT : Admit Patient
@enduml