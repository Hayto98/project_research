@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
entity "Librarian" as L
participant "Parent" as P
boundary "Registrar" as R
control "Student" as S
R -> S : Take Attendance
activate S
S --> R : ACK
deactivate S
note over S : processing take attendance
L --> P : Borrow Book
R ->> L : Enroll Course
R ->> L : View Schedule
@enduml