@startuml
skinparam monochrome true
control "Dispatcher" as D
boundary "Warehouse Staff" as WS
boundary "Driver" as D2
control "Fleet Manager" as FM
WS ->> FM : Assign Route
activate FM
FM --> WS : ACK
deactivate FM
note over FM : processing assign route
FM --> WS : Schedule Pickup
FM ->> WS : Fuel Vehicle
D2 ->> WS : Report Issue
WS ->> D : Update Inventory
activate D
D --> WS : ACK
deactivate D
D -> D2 : Load Package
note over D2 : processing load package
FM --> D2 : Deliver Package
@enduml