@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
actor "Fleet Manager" as FM
control "Customer" as C
actor "Warehouse Staff" as WS
C -> WS : Schedule Pickup
activate WS
WS --> C : ACK
deactivate WS
FM --> WS : Assign Route
activate WS
WS --> FM : ACK
deactivate WS
FM ->> WS : Fuel Vehicle
FM --> WS : Track Shipment
activate WS
WS --> FM : ACK
deactivate WS
@enduml