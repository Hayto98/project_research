@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
actor "Doctor" as D
actor "Patient" as P
participant "Receptionist" as R
control "Insurance Provider" as IP
control "Nurse" as N
IP --> N : Discharge Patient
IP --> D : Update Medical Record
N -> R : Examine Patient
P -> N : Book Appointment
D -> R : Process Insurance Claim
activate R
R --> D : ACK
deactivate R
@enduml