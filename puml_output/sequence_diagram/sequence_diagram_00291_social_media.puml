@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
actor "Moderator" as M
entity "User" as U
control "Admin" as A
participant "Advertiser" as A2
M --> A : Edit Profile
activate A
A --> M : ACK
deactivate A
M ->> A : Like Post
activate A
A --> M : ACK
deactivate A
A ->> A2 : Report Content
A --> A2 : Share Post
activate A2
A2 --> A : ACK
deactivate A2
M -> A2 : Comment
M ->> A2 : Follow User
activate A2
A2 --> M : ACK
deactivate A2
note over A2 : processing follow user
@enduml