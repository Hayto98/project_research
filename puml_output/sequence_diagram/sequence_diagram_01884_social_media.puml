@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
participant "Advertiser" as A
participant "Moderator" as M
entity "Admin" as A2
entity "User" as U
A -> U : Follow User
A2 ->> M : Like Post
note over M : processing like post
U -> A : Create Post
M -> U : Report Content
A ->> A2 : Share Post
A2 ->> M : Send Message
note over M : processing send message
M -> A : Edit Profile
@enduml