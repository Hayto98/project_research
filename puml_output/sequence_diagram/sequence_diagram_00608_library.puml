@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
boundary "Member" as M
actor "Admin" as A
actor "Librarian" as L
M ->> L : Borrow Book
activate L
L --> M : ACK
deactivate L
M --> L : Register Member
A --> M : Add New Book
note over M : processing add new book
A --> M : Return Book
M ->> A : Reserve Book
@enduml