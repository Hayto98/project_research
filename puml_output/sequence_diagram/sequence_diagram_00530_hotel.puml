@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
actor "Housekeeper" as H
actor "Chef" as C
entity "Guest" as G
actor "Receptionist" as R
H --> G : Check Out
H --> C : Clean Room
G --> H : Process Payment
R --> C : Order Room Service
note over C : processing order room service
@enduml