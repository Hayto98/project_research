@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
participant "Moderator" as M
actor "Admin" as A
actor "User" as U
actor "Advertiser" as A2
U --> M : Follow User
note over M : processing follow user
M ->> A2 : Create Post
note over A2 : processing create post
A2 --> M : Share Post
U ->> M : Like Post
M --> A : Report Content
@enduml