@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
boundary "Patient" as P
control "Lab Technician" as LT
boundary "Nurse" as N
participant "Receptionist" as R
control "Doctor" as D
LT --> R : Book Appointment
activate R
R --> LT : ACK
deactivate R
note over R : processing book appointment
R --> LT : Admit Patient
activate LT
LT --> R : ACK
deactivate LT
P -> R : Update Medical Record
note over R : processing update medical record
LT --> D : Issue Prescription
@enduml