@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
boundary "Chef" as C
control "Housekeeper" as H
entity "Manager" as M
control "Guest" as G
H -> M : Request Service
activate M
M --> H : ACK
deactivate M
M --> H : Check Out
activate H
H --> M : ACK
deactivate H
M ->> G : Clean Room
note over G : processing clean room
H ->> C : Book Room
activate C
C --> H : ACK
deactivate C
@enduml