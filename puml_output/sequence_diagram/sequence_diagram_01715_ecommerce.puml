@startuml
skinparam monochrome true
skinparam defaultFontSize 13
actor "Delivery Service" as DS
actor "Customer" as C
actor "Seller" as S
C -> S : Checkout
C -> DS : Browse Products
DS -> S : Cancel Order
DS ->> S : Add To Cart
S -> DS : Manage Inventory
activate DS
DS --> S : ACK
deactivate DS
@enduml