@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
entity "Librarian" as L
entity "Teacher" as T
control "Parent" as P
entity "Admin" as A
actor "Student" as S
T ->> A : View Schedule
activate A
A --> T : ACK
deactivate A
T ->> L : Grade Exam
T --> S : Submit Assignment
S --> P : Borrow Book
activate P
P --> S : ACK
deactivate P
T --> L : Register Student
@enduml