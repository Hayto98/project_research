@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
boundary "Advertiser" as A
actor "Moderator" as M
entity "User" as U
participant "Admin" as A2
M -> A : Comment
A --> M : Send Message
A2 -> A : Follow User
M ->> A : Create Post
note over A : processing create post
U -> M : Share Post
M -> U : Edit Profile
activate U
U --> M : ACK
deactivate U
@enduml