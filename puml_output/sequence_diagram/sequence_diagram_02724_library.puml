@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
boundary "Librarian" as L
boundary "Admin" as A
actor "Member" as M
L --> A : Renew Loan
activate A
A --> L : ACK
deactivate A
L --> M : Pay Fine
activate M
M --> L : ACK
deactivate M
A -> M : Borrow Book
activate M
M --> A : ACK
deactivate M
A ->> L : Search Catalog
M ->> L : Register Member
activate L
L --> M : ACK
deactivate L
L ->> A : Reserve Book
activate A
A --> L : ACK
deactivate A
note over A : processing reserve book
M ->> A : Return Book
note over A : processing return book
@enduml