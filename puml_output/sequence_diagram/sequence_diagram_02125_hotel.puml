@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
boundary "Chef" as C
control "Housekeeper" as H
control "Guest" as G
boundary "Receptionist" as R
C --> R : Process Payment
R --> H : Order Room Service
activate H
H --> R : ACK
deactivate H
C --> H : Clean Room
note over H : processing clean room
G ->> H : Request Service
note over H : processing request service
G --> H : Check In
@enduml