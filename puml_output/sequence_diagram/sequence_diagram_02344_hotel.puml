@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
participant "Chef" as C
participant "Guest" as G
boundary "Housekeeper" as H
control "Manager" as M
G --> C : Check Out
note over C : processing check out
M ->> C : Process Payment
G ->> M : Book Room
H ->> C : Clean Room
activate C
C --> H : ACK
deactivate C
note over C : processing clean room
H ->> C : Order Room Service
@enduml