@startuml
skinparam monochrome true
skinparam defaultFontSize 13
control "Member" as M
actor "Librarian" as L
entity "Admin" as A
A -> L : Add New Book
note over L : processing add new book
A -> M : Return Book
A -> L : Borrow Book
activate L
L --> A : ACK
deactivate L
A -> M : Reserve Book
activate M
M --> A : ACK
deactivate M
@enduml