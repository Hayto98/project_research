@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
actor "Member" as M
actor "Admin" as A
actor "Librarian" as L
A --> M : Borrow Book
activate M
M --> A : ACK
deactivate M
A ->> M : Add New Book
A --> L : Register Member
activate L
L --> A : ACK
deactivate L
M --> A : Pay Fine
activate A
A --> M : ACK
deactivate A
L ->> A : Reserve Book
activate A
A --> L : ACK
deactivate A
@enduml