@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
control "Lab Technician" as LT
control "Nurse" as N
actor "Insurance Provider" as IP
LT --> N : Update Medical Record
IP --> LT : Examine Patient
LT --> IP : Admit Patient
LT --> N : Book Appointment
N ->> IP : Discharge Patient
activate IP
IP --> N : ACK
deactivate IP
IP --> LT : Run Lab Test
@enduml