@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
entity "Delivery Service" as DS
entity "Customer" as C
entity "Seller" as S
control "Admin" as A
entity "Payment Gateway" as PG
C -> PG : Checkout
activate PG
PG --> C : ACK
deactivate PG
DS --> A : Write Review
note over A : processing write review
A ->> C : Add To Cart
DS --> S : Track Order
PG -> C : Cancel Order
activate C
C --> PG : ACK
deactivate C
DS ->> S : Make Payment
S -> PG : Manage Inventory
@enduml