@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
entity "Librarian" as L
entity "Admin" as A
boundary "Member" as M
L -> A : Add New Book
L --> A : Reserve Book
activate A
A --> L : ACK
deactivate A
A -> L : Register Member
activate L
L --> A : ACK
deactivate L
note over L : processing register member
L --> A : Renew Loan
A ->> L : Return Book
note over L : processing return book
@enduml