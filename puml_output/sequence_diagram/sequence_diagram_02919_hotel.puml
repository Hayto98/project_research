@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
entity "Guest" as G
boundary "Housekeeper" as H
entity "Receptionist" as R
entity "Manager" as M
H -> R : Check In
M -> G : Book Room
activate G
G --> M : ACK
deactivate G
note over G : processing book room
M ->> H : Cancel Reservation
G ->> H : Order Room Service
activate H
H --> G : ACK
deactivate H
R -> M : Check Out
activate M
M --> R : ACK
deactivate M
@enduml