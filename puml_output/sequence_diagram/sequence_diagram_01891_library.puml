@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
boundary "Librarian" as L
entity "Admin" as A
entity "Member" as M
A --> M : Register Member
activate M
M --> A : ACK
deactivate M
L --> A : Renew Loan
A --> L : Pay Fine
L ->> A : Borrow Book
A --> M : Search Catalog
M -> A : Reserve Book
note over A : processing reserve book
@enduml