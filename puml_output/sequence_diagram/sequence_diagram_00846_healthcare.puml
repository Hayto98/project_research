@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
entity "Nurse" as N
control "Receptionist" as R
actor "Lab Technician" as LT
boundary "Insurance Provider" as IP
R -> IP : Discharge Patient
activate IP
IP --> R : ACK
deactivate IP
R ->> IP : Issue Prescription
IP -> R : Book Appointment
R --> LT : Process Insurance Claim
@enduml