@startuml
skinparam monochrome true
skinparam defaultFontSize 11
participant "Librarian" as L
actor "Member" as M
participant "Admin" as A
L ->> A : Borrow Book
activate A
A --> L : ACK
deactivate A
M -> A : Search Catalog
activate A
A --> M : ACK
deactivate A
note over A : processing search catalog
M --> L : Renew Loan
activate L
L --> M : ACK
deactivate L
M ->> L : Pay Fine
A -> L : Return Book
@enduml