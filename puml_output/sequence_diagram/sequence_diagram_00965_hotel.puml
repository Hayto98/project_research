@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
participant "Receptionist" as R
participant "Housekeeper" as H
participant "Chef" as C
C ->> R : Cancel Reservation
C -> H : Request Service
activate H
H --> C : ACK
deactivate H
C -> H : Order Room Service
R -> H : Check Out
note over H : processing check out
R --> H : Check In
C ->> R : Process Payment
@enduml