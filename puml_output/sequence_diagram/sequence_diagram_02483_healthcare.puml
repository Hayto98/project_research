@startuml
skinparam defaultFontSize 11
participant "Doctor" as D
boundary "Lab Technician" as LT
control "Receptionist" as R
entity "Patient" as P
participant "Nurse" as N
N --> D : Discharge Patient
activate D
D --> N : ACK
deactivate D
N ->> P : Process Insurance Claim
R --> N : Admit Patient
R -> LT : Examine Patient
note over LT : processing examine patient
@enduml