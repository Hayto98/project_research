@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
boundary "Receptionist" as R
participant "Housekeeper" as H
participant "Guest" as G
H --> G : Process Payment
R ->> H : Cancel Reservation
activate H
H --> R : ACK
deactivate H
H ->> G : Clean Room
R -> H : Check In
H ->> G : Check Out
R -> G : Book Room
R --> H : Order Room Service
@enduml