@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
control "ATM" as A
participant "Branch Manager" as BM
control "Bank Teller" as BT
entity "Account Holder" as AH
actor "Auditor" as A2
AH -> BM : View Statement
BT -> A2 : Pay Bill
activate A2
A2 --> BT : ACK
deactivate A2
A2 ->> BT : Apply For Loan
BM -> A : Transfer Funds
@enduml