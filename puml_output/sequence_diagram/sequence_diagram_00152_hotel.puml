@startuml
skinparam ArrowColor #555555
boundary "Receptionist" as R
control "Guest" as G
boundary "Manager" as M
participant "Housekeeper" as H
participant "Chef" as C
G ->> R : Book Room
G -> C : Clean Room
G ->> R : Request Service
R -> H : Process Payment
activate H
H --> R : ACK
deactivate H
@enduml