@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
control "Receptionist" as R
control "Housekeeper" as H
boundary "Manager" as M
entity "Guest" as G
entity "Chef" as C
G ->> H : Order Room Service
activate H
H --> G : ACK
deactivate H
note over H : processing order room service
H --> R : Book Room
H ->> G : Request Service
note over G : processing request service
M -> R : Clean Room
H ->> C : Process Payment
H -> M : Cancel Reservation
activate M
M --> H : ACK
deactivate M
@enduml