@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
control "ATM" as A
control "Bank Teller" as BT
actor "Account Holder" as AH
AH ->> BT : Transfer Funds
BT -> A : Deposit Money
AH -> BT : Withdraw Cash
note over BT : processing withdraw cash
A -> BT : View Statement
BT --> AH : Open Account
note over AH : processing open account
AH -> A : Block Card
@enduml