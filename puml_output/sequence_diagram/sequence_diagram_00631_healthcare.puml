@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
control "Lab Technician" as LT
boundary "Insurance Provider" as IP
entity "Nurse" as N
control "Receptionist" as R
entity "Doctor" as D
R --> IP : Book Appointment
activate IP
IP --> R : ACK
deactivate IP
R ->> D : Examine Patient
D -> N : Issue Prescription
LT -> R : Admit Patient
@enduml