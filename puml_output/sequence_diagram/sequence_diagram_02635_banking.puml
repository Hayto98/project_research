@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
entity "Auditor" as A
control "Account Holder" as AH
actor "Branch Manager" as BM
actor "ATM" as A2
BM --> AH : Deposit Money
A2 ->> AH : Apply For Loan
AH --> A : Pay Bill
activate A
A --> AH : ACK
deactivate A
A2 --> AH : Open Account
A -> BM : View Statement
activate BM
BM --> A : ACK
deactivate BM
@enduml