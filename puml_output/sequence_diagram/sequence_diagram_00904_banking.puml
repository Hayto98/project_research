@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
participant "Auditor" as A
actor "Bank Teller" as BT
entity "Account Holder" as AH
boundary "Branch Manager" as BM
BM -> A : Pay Bill
A --> AH : Withdraw Cash
note over AH : processing withdraw cash
AH -> BM : Open Account
A ->> BM : Deposit Money
@enduml