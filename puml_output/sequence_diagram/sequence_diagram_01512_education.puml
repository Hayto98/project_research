@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
entity "Librarian" as L
actor "Student" as S
boundary "Parent" as P
boundary "Registrar" as R
L -> R : Grade Exam
L --> S : Register Student
note over S : processing register student
P --> S : View Schedule
S ->> R : Issue Certificate
activate R
R --> S : ACK
deactivate R
R -> P : Submit Assignment
activate P
P --> R : ACK
deactivate P
R --> L : Enroll Course
activate L
L --> R : ACK
deactivate L
P -> L : Borrow Book
activate L
L --> P : ACK
deactivate L
@enduml