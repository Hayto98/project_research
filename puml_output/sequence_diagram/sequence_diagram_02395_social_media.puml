@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
boundary "Advertiser" as A
actor "Moderator" as M
boundary "Admin" as A2
A --> M : Create Post
activate M
M --> A : ACK
deactivate M
A2 -> M : Share Post
A --> M : Edit Profile
activate M
M --> A : ACK
deactivate M
M -> A : Send Message
activate A
A --> M : ACK
deactivate A
@enduml