@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
control "Housekeeper" as H
control "Guest" as G
entity "Manager" as M
participant "Receptionist" as R
entity "Chef" as C
C -> H : Clean Room
M --> R : Request Service
activate R
R --> M : ACK
deactivate R
C ->> H : Process Payment
activate H
H --> C : ACK
deactivate H
note over H : processing process payment
R -> C : Check Out
note over C : processing check out
M ->> R : Cancel Reservation
note over R : processing cancel reservation
@enduml