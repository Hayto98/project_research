@startuml

actor "Student" as S
actor "Librarian" as L
participant "Teacher" as T
actor "Parent" as P
control "Admin" as A
P --> S : Borrow Book
activate S
S --> P : ACK
deactivate S
T -> P : Issue Certificate
activate P
P --> T : ACK
deactivate P
T -> L : Take Attendance
L ->> P : View Schedule
A ->> L : Grade Exam
activate L
L --> A : ACK
deactivate L
@enduml