@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
entity "Registrar" as R
entity "Parent" as P
actor "Student" as S
S -> R : Grade Exam
note over R : processing grade exam
P -> S : Take Attendance
activate S
S --> P : ACK
deactivate S
P --> R : Submit Assignment
activate R
R --> P : ACK
deactivate R
note over R : processing submit assignment
P -> S : View Schedule
activate S
S --> P : ACK
deactivate S
@enduml