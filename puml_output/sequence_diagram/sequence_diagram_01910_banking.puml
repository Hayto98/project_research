@startuml
skinparam ArrowColor #555555
actor "Branch Manager" as BM
entity "ATM" as A
actor "Auditor" as A2
participant "Account Holder" as AH
control "Bank Teller" as BT
BM -> AH : Deposit Money
BT -> AH : View Statement
activate AH
AH --> BT : ACK
deactivate AH
note over AH : processing view statement
BT --> A2 : Block Card
AH ->> BT : Transfer Funds
@enduml