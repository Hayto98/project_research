@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
participant "Admin" as A
boundary "Advertiser" as A2
entity "Moderator" as M
control "User" as U
M -> A : Like Post
activate A
A --> M : ACK
deactivate A
note over A : processing like post
M -> A2 : Send Message
M --> A2 : Edit Profile
A ->> U : Create Post
activate U
U --> A : ACK
deactivate U
@enduml