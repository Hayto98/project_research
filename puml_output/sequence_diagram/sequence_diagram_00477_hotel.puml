@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
participant "Housekeeper" as H
participant "Guest" as G
control "Manager" as M
H -> G : Check Out
note over G : processing check out
H --> G : Process Payment
note over G : processing process payment
M --> H : Check In
H --> M : Clean Room
M --> G : Cancel Reservation
activate G
G --> M : ACK
deactivate G
G --> H : Request Service
H -> G : Book Room
activate G
G --> H : ACK
deactivate G
@enduml