@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
actor "Account Holder" as AH
boundary "ATM" as A
actor "Auditor" as A2
entity "Branch Manager" as BM
control "Bank Teller" as BT
A ->> A2 : Deposit Money
A --> AH : Pay Bill
note over AH : processing pay bill
A2 --> A : View Statement
A -> AH : Withdraw Cash
note over AH : processing withdraw cash
BT -> A : Apply For Loan
A2 ->> BT : Open Account
BT --> A : Transfer Funds
note over A : processing transfer funds
@enduml