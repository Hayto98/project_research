@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
entity "Member" as M
actor "Librarian" as L
boundary "Admin" as A
L --> M : Reserve Book
A -> M : Register Member
activate M
M --> A : ACK
deactivate M
A --> L : Borrow Book
A ->> M : Pay Fine
activate M
M --> A : ACK
deactivate M
@enduml