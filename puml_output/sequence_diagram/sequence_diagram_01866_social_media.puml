@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
control "Moderator" as M
entity "Admin" as A
entity "User" as U
U -> M : Edit Profile
activate M
M --> U : ACK
deactivate M
U -> M : Follow User
activate M
M --> U : ACK
deactivate M
A -> M : Report Content
A ->> M : Like Post
note over M : processing like post
U --> A : Share Post
activate A
A --> U : ACK
deactivate A
@enduml