@startuml
skinparam shadowing true
control "Chef" as C
actor "Receptionist" as R
control "Manager" as M
R --> C : Cancel Reservation
M ->> C : Check Out
R ->> C : Clean Room
note over C : processing clean room
R ->> C : Request Service
R ->> M : Book Room
M ->> C : Order Room Service
activate C
C --> M : ACK
deactivate C
note over C : processing order room service
@enduml