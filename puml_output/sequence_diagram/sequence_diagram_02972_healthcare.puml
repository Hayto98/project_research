@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
boundary "Insurance Provider" as IP
control "Nurse" as N
control "Receptionist" as R
control "Doctor" as D
IP ->> R : Update Medical Record
N --> D : Book Appointment
activate D
D --> N : ACK
deactivate D
note over D : processing book appointment
R -> N : Run Lab Test
note over N : processing run lab test
R -> IP : Process Insurance Claim
IP ->> R : Examine Patient
IP -> N : Discharge Patient
@enduml