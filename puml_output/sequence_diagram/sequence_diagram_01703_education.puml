@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
control "Teacher" as T
entity "Librarian" as L
actor "Registrar" as R
control "Parent" as P
control "Student" as S
R ->> P : View Schedule
R ->> T : Borrow Book
T -> L : Submit Assignment
activate L
L --> T : ACK
deactivate L
note over L : processing submit assignment
T ->> L : Take Attendance
T --> R : Register Student
@enduml