@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
participant "Admin" as A
boundary "Advertiser" as A2
entity "User" as U
participant "Moderator" as M
A2 --> A : Like Post
M --> U : Report Content
note over U : processing report content
A ->> M : Comment
activate M
M --> A : ACK
deactivate M
A2 -> M : Share Post
activate M
M --> A2 : ACK
deactivate M
note over M : processing share post
U -> A : Create Post
activate A
A --> U : ACK
deactivate A
M ->> A : Send Message
note over A : processing send message
M ->> A2 : Follow User
activate A2
A2 --> M : ACK
deactivate A2
@enduml