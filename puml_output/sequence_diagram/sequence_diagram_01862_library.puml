@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
boundary "Member" as M
boundary "Admin" as A
control "Librarian" as L
M -> A : Renew Loan
L ->> M : Add New Book
L --> M : Borrow Book
A --> M : Search Catalog
note over M : processing search catalog
@enduml