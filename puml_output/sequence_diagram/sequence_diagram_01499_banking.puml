@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
boundary "Branch Manager" as BM
participant "ATM" as A
actor "Bank Teller" as BT
boundary "Account Holder" as AH
A ->> BT : Block Card
A --> AH : Withdraw Cash
BM -> A : Transfer Funds
note over A : processing transfer funds
AH -> BM : Pay Bill
BT --> BM : View Statement
@enduml