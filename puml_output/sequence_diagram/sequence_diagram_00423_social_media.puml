@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
control "Moderator" as M
entity "Admin" as A
boundary "User" as U
participant "Advertiser" as A2
A -> U : Follow User
A ->> M : Send Message
activate M
M --> A : ACK
deactivate M
U ->> A2 : Create Post
M -> A : Share Post
@enduml