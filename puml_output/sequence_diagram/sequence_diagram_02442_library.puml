@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
control "Member" as M
actor "Librarian" as L
entity "Admin" as A
A --> M : Add New Book
M -> A : Search Catalog
activate A
A --> M : ACK
deactivate A
A --> L : Renew Loan
M ->> A : Reserve Book
L -> A : Pay Fine
note over A : processing pay fine
@enduml