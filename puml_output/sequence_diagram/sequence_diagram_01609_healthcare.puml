@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
entity "Doctor" as D
boundary "Lab Technician" as LT
participant "Nurse" as N
LT -> N : Issue Prescription
N ->> LT : Update Medical Record
activate LT
LT --> N : ACK
deactivate LT
LT --> D : Admit Patient
N ->> D : Book Appointment
note over D : processing book appointment
D -> LT : Run Lab Test
activate LT
LT --> D : ACK
deactivate LT
note over LT : processing run lab test
D --> N : Examine Patient
activate N
N --> D : ACK
deactivate N
@enduml