@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
control "Payment Gateway" as PG
participant "Admin" as A
control "Customer" as C
participant "Seller" as S
PG ->> S : Checkout
activate S
S --> PG : ACK
deactivate S
C --> PG : Manage Inventory
activate PG
PG --> C : ACK
deactivate PG
PG ->> S : Track Order
A --> PG : Add To Cart
C --> PG : Cancel Order
C --> S : Write Review
activate S
S --> C : ACK
deactivate S
A --> PG : Browse Products
activate PG
PG --> A : ACK
deactivate PG
@enduml