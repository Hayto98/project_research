@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
boundary "User" as U
actor "Admin" as A
boundary "Advertiser" as A2
U -> A2 : Send Message
U -> A2 : Report Content
A2 --> A : Follow User
note over A : processing follow user
A ->> A2 : Share Post
activate A2
A2 --> A : ACK
deactivate A2
A --> U : Comment
note over U : processing comment
U ->> A : Edit Profile
activate A
A --> U : ACK
deactivate A
A2 --> A : Like Post
@enduml