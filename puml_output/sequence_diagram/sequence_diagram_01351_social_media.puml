@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
actor "User" as U
entity "Admin" as A
entity "Moderator" as M
control "Advertiser" as A2
U -> M : Share Post
A --> M : Comment
A2 -> U : Send Message
U --> M : Follow User
note over M : processing follow user
A -> U : Report Content
activate U
U --> A : ACK
deactivate U
@enduml