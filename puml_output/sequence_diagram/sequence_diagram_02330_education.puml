@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
actor "Student" as S
boundary "Teacher" as T
control "Librarian" as L
control "Registrar" as R
participant "Admin" as A
R ->> S : Grade Exam
activate S
S --> R : ACK
deactivate S
A --> R : Submit Assignment
L -> A : Register Student
note over A : processing register student
S ->> R : Borrow Book
@enduml