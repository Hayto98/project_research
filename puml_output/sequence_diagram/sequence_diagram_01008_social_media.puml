@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
entity "Admin" as A
control "User" as U
control "Advertiser" as A2
entity "Moderator" as M
A2 -> A : Report Content
U --> A : Follow User
U --> A : Edit Profile
activate A
A --> U : ACK
deactivate A
A -> M : Like Post
U -> A2 : Create Post
A -> U : Share Post
note over U : processing share post
U --> M : Send Message
@enduml