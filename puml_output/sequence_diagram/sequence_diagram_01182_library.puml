@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
actor "Member" as M
boundary "Admin" as A
actor "Librarian" as L
M ->> L : Add New Book
L --> M : Pay Fine
activate M
M --> L : ACK
deactivate M
A ->> M : Return Book
L --> M : Reserve Book
activate M
M --> L : ACK
deactivate M
L --> A : Renew Loan
@enduml