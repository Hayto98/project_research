@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
actor "Moderator" as M
participant "Advertiser" as A
boundary "Admin" as A2
actor "User" as U
A ->> M : Send Message
activate M
M --> A : ACK
deactivate M
note over M : processing send message
M ->> A : Like Post
U --> A2 : Share Post
U --> A2 : Comment
@enduml