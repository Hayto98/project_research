@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
boundary "ATM" as A
participant "Bank Teller" as BT
boundary "Auditor" as A2
entity "Account Holder" as AH
control "Branch Manager" as BM
AH --> BM : Block Card
A2 ->> BT : Withdraw Cash
BM -> A : Transfer Funds
activate A
A --> BM : ACK
deactivate A
note over A : processing transfer funds
AH ->> BT : View Statement
@enduml