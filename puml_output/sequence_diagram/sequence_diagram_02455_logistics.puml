@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
actor "Customer" as C
control "Fleet Manager" as FM
control "Warehouse Staff" as WS
boundary "Dispatcher" as D
FM --> C : Fuel Vehicle
activate C
C --> FM : ACK
deactivate C
D ->> C : Assign Route
activate C
C --> D : ACK
deactivate C
FM -> D : Load Package
activate D
D --> FM : ACK
deactivate D
D --> C : Track Shipment
note over C : processing track shipment
C ->> D : Report Issue
C --> FM : Deliver Package
activate FM
FM --> C : ACK
deactivate FM
note over FM : processing deliver package
@enduml