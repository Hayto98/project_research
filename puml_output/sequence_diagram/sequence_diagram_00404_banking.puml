@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
control "Branch Manager" as BM
participant "Account Holder" as AH
entity "ATM" as A
actor "Bank Teller" as BT
actor "Auditor" as A2
A ->> BT : Withdraw Cash
A2 -> A : Deposit Money
BM ->> A : Transfer Funds
note over A : processing transfer funds
BT --> BM : Apply For Loan
BT ->> A : Pay Bill
activate A
A --> BT : ACK
deactivate A
AH --> A2 : View Statement
BM --> A2 : Block Card
activate A2
A2 --> BM : ACK
deactivate A2
@enduml