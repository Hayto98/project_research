@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
entity "Moderator" as M
entity "Admin" as A
participant "Advertiser" as A2
A2 ->> M : Follow User
activate M
M --> A2 : ACK
deactivate M
A --> M : Send Message
M ->> A2 : Report Content
activate A2
A2 --> M : ACK
deactivate A2
M --> A2 : Create Post
M --> A : Like Post
M ->> A2 : Edit Profile
activate A2
A2 --> M : ACK
deactivate A2
M -> A : Share Post
@enduml