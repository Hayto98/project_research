@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
boundary "Registrar" as R
actor "Student" as S
actor "Teacher" as T
T -> S : Issue Certificate
R ->> T : Take Attendance
note over T : processing take attendance
S --> T : View Schedule
T -> R : Borrow Book
note over R : processing borrow book
@enduml