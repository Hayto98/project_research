@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
participant "Admin" as A
entity "Member" as M
boundary "Librarian" as L
A --> M : Pay Fine
activate M
M --> A : ACK
deactivate M
L --> A : Register Member
M --> L : Reserve Book
M --> A : Search Catalog
A --> L : Borrow Book
A --> L : Return Book
@enduml