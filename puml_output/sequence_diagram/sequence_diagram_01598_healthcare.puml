@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
control "Receptionist" as R
participant "Doctor" as D
boundary "Insurance Provider" as IP
entity "Nurse" as N
D --> N : Examine Patient
D --> N : Process Insurance Claim
IP ->> D : Admit Patient
note over D : processing admit patient
R --> IP : Book Appointment
