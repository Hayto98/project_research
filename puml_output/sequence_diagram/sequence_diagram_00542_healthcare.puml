@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
boundary "Patient" as P
boundary "Lab Technician" as LT
participant "Receptionist" as R
boundary "Doctor" as D
actor "Insurance Provider" as IP
R ->> D : Discharge Patient
LT ->> D : Issue Prescription
IP --> LT : Book Appointment
activate LT
LT --> IP : ACK
deactivate LT
note over LT : processing book appointment
D ->> LT : Admit Patient
activate LT
LT --> D : ACK
deactivate LT
R -> P : Process Insurance Claim
P -> IP : Run Lab Test
note over IP : processing run lab test
IP -> D : Examine Patient
activate D
D --> IP : ACK
deactivate D
@enduml