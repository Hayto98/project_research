@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
boundary "Teacher" as T
entity "Registrar" as R
boundary "Librarian" as L
T -> R : Submit Assignment
R -> L : Issue Certificate
R ->> L : View Schedule
T --> R : Register Student
L ->> R : Take Attendance
L -> R : Grade Exam
L --> R : Enroll Course
activate R
R --> L : ACK
deactivate R
@enduml