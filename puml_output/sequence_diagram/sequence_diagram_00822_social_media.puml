@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
entity "Admin" as A
participant "Moderator" as M
actor "User" as U
M ->> A : Send Message
activate A
A --> M : ACK
deactivate A
U ->> M : Create Post
activate M
M --> U : ACK
deactivate M
M -> A : Like Post
M --> A : Follow User
A ->> U : Comment
A --> U : Share Post
@enduml