@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
actor "Member" as M
entity "Librarian" as L
actor "Admin" as A
M --> L : Register Member
activate L
L --> M : ACK
deactivate L
note over L : processing register member
A ->> M : Renew Loan
activate M
M --> A : ACK
deactivate M
note over M : processing renew loan
L -> M : Pay Fine
A -> L : Add New Book
note over L : processing add new book
M -> L : Borrow Book
@enduml