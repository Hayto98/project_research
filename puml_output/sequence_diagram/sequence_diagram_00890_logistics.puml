@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
boundary "Driver" as D
participant "Dispatcher" as D2
entity "Fleet Manager" as FM
D2 -> D : Load Package
activate D
D --> D2 : ACK
deactivate D
D2 -> D : Assign Route
activate D
D --> D2 : ACK
deactivate D
FM ->> D : Fuel Vehicle
activate D
D --> FM : ACK
deactivate D
FM -> D : Deliver Package
activate D
D --> FM : ACK
deactivate D
D2 ->> FM : Schedule Pickup
activate FM
FM --> D2 : ACK
deactivate FM
D ->> FM : Track Shipment
@enduml