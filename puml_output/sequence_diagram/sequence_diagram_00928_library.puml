@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
entity "Librarian" as L
control "Admin" as A
participant "Member" as M
M -> L : Add New Book
L -> A : Reserve Book
M ->> A : Pay Fine
M --> L : Borrow Book
activate L
L --> M : ACK
deactivate L
note over L : processing borrow book
L --> A : Renew Loan
@enduml