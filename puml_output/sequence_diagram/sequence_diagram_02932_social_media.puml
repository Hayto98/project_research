@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
participant "Moderator" as M
actor "Admin" as A
participant "User" as U
control "Advertiser" as A2
A2 ->> A : Like Post
activate A
A --> A2 : ACK
deactivate A
M -> U : Send Message
activate U
U --> M : ACK
deactivate U
A -> M : Create Post
A2 --> M : Report Content
note over M : processing report content
@enduml