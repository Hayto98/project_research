@startuml
skinparam defaultFontSize 13
boundary "Auditor" as A
control "ATM" as A2
participant "Account Holder" as AH
participant "Bank Teller" as BT
control "Branch Manager" as BM
BT -> AH : Apply For Loan
AH ->> BT : Deposit Money
A2 ->> BM : Withdraw Cash
note over BM : processing withdraw cash
A ->> BT : Pay Bill
@enduml