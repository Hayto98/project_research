@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
boundary "Chef" as C
actor "Guest" as G
actor "Manager" as M
G --> M : Cancel Reservation
activate M
M --> G : ACK
deactivate M
M -> G : Check Out
activate G
G --> M : ACK
deactivate G
C --> G : Clean Room
activate G
G --> C : ACK
deactivate G
G --> M : Order Room Service
activate M
M --> G : ACK
deactivate M
note over M : processing order room service
M -> G : Process Payment
activate G
G --> M : ACK
deactivate G
M -> C : Check In
G --> M : Book Room
activate M
M --> G : ACK
deactivate M
note over M : processing book room
@enduml