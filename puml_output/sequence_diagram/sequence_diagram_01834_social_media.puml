@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
boundary "Admin" as A
actor "Moderator" as M
boundary "Advertiser" as A2
entity "User" as U
A --> M : Report Content
A ->> A2 : Create Post
A2 -> U : Edit Profile
A2 --> M : Follow User
A --> M : Send Message
U -> A2 : Comment
activate A2
A2 --> U : ACK
deactivate A2
A2 -> M : Share Post
activate M
M --> A2 : ACK
deactivate M
@enduml