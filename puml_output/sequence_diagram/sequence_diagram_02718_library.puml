@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
boundary "Admin" as A
boundary "Librarian" as L
control "Member" as M
M -> L : Reserve Book
note over L : processing reserve book
L ->> M : Register Member
note over M : processing register member
L -> A : Renew Loan
M ->> L : Return Book
@enduml