@startuml
skinparam monochrome true
skinparam ArrowColor #555555
actor "Registrar" as R
participant "Admin" as A
control "Librarian" as L
A ->> L : Grade Exam
note over L : processing grade exam
R ->> A : Submit Assignment
L ->> R : Borrow Book
note over R : processing borrow book
L -> A : View Schedule
@enduml