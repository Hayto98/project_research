@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
boundary "Moderator" as M
participant "User" as U
participant "Advertiser" as A
entity "Admin" as A2
A2 --> U : Like Post
note over U : processing like post
U --> M : Edit Profile
note over M : processing edit profile
M -> A2 : Share Post
A2 --> A : Follow User
note over A : processing follow user
U ->> M : Send Message
A ->> U : Create Post
A --> A2 : Comment
note over A2 : processing comment
@enduml