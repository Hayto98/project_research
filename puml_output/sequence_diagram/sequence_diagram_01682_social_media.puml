@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
participant "Admin" as A
participant "Advertiser" as A2
participant "Moderator" as M
A2 --> A : Create Post
A2 ->> A : Send Message
A ->> A2 : Report Content
note over A2 : processing report content
A --> A2 : Comment
activate A2
A2 --> A : ACK
deactivate A2
@enduml