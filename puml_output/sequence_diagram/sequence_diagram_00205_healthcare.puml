@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
entity "Patient" as P
control "Receptionist" as R
boundary "Nurse" as N
boundary "Lab Technician" as LT
N ->> P : Process Insurance Claim
R ->> P : Discharge Patient
note over P : processing discharge patient
R ->> P : Admit Patient
P --> LT : Book Appointment
activate LT
LT --> P : ACK
deactivate LT
LT --> N : Update Medical Record
activate N
N --> LT : ACK
deactivate N
@enduml