@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
entity "Housekeeper" as H
participant "Receptionist" as R
actor "Chef" as C
control "Manager" as M
H ->> M : Request Service
activate M
M --> H : ACK
deactivate M
H --> C : Process Payment
M ->> C : Order Room Service
H ->> R : Check In
H --> C : Clean Room
@enduml