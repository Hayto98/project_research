@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
participant "Admin" as A
entity "Member" as M
boundary "Librarian" as L
A --> M : Register Member
L ->> M : Pay Fine
activate M
M --> L : ACK
deactivate M
L ->> M : Return Book
A --> L : Renew Loan
M ->> A : Add New Book
L ->> M : Borrow Book
@enduml