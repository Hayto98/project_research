@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
entity "Warehouse Staff" as WS
boundary "Fleet Manager" as FM
participant "Customer" as C
control "Driver" as D
boundary "Dispatcher" as D2
FM ->> C : Deliver Package
note over C : processing deliver package
C --> WS : Fuel Vehicle
FM -> D2 : Update Inventory
activate D2
D2 --> FM : ACK
deactivate D2
FM --> D : Assign Route
FM --> C : Track Shipment
note over C : processing track shipment
WS -> D : Report Issue
activate D
D --> WS : ACK
deactivate D
FM -> D2 : Load Package
note over D2 : processing load package
@enduml