@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
actor "Member" as M
entity "Admin" as A
boundary "Librarian" as L
M ->> L : Add New Book
A ->> M : Search Catalog
L -> A : Renew Loan
M -> L : Borrow Book
note over L : processing borrow book
A --> L : Register Member
@enduml