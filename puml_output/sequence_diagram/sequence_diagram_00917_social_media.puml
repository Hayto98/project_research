@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
entity "Admin" as A
boundary "Advertiser" as A2
control "User" as U
control "Moderator" as M
M --> A2 : Edit Profile
activate A2
A2 --> M : ACK
deactivate A2
M -> A : Report Content
note over A : processing report content
A ->> A2 : Send Message
activate A2
A2 --> A : ACK
deactivate A2
M -> A2 : Create Post
M ->> U : Comment
U ->> A : Share Post
activate A
A --> U : ACK
deactivate A
M -> A2 : Follow User
note over A2 : processing follow user
@enduml