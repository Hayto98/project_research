@startuml
skinparam monochrome true
skinparam defaultFontSize 13
control "Housekeeper" as H
actor "Receptionist" as R
entity "Manager" as M
M -> R : Clean Room
activate R
R --> M : ACK
deactivate R
M --> H : Process Payment
note over H : processing process payment
R --> M : Request Service
H -> M : Check In
H --> R : Order Room Service
H --> R : Cancel Reservation
H ->> R : Check Out
@enduml