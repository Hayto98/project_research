@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
actor "Teacher" as T
participant "Admin" as A
entity "Parent" as P
T --> P : Register Student
T --> A : Submit Assignment
P -> A : Grade Exam
P ->> T : Borrow Book
note over T : processing borrow book
P --> T : View Schedule
activate T
T --> P : ACK
deactivate T
note over T : processing view schedule
@enduml