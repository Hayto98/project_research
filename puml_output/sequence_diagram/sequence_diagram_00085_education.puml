@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
control "Librarian" as L
actor "Registrar" as R
entity "Parent" as P
L --> P : Register Student
L ->> P : Submit Assignment
activate P
P --> L : ACK
deactivate P
note over P : processing submit assignment
P --> L : View Schedule
L -> R : Grade Exam
R -> L : Take Attendance
@enduml