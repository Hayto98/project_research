@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
participant "Registrar" as R
actor "Student" as S
control "Parent" as P
S ->> R : Borrow Book
R -> P : Submit Assignment
P --> R : View Schedule
P -> S : Issue Certificate
activate S
S --> P : ACK
deactivate S
P --> S : Enroll Course
activate S
S --> P : ACK
deactivate S
S -> P : Register Student
@enduml