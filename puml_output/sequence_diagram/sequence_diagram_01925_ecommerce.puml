@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
participant "Delivery Service" as DS
participant "Seller" as S
boundary "Admin" as A
S ->> DS : Apply Coupon
DS -> A : Track Order
S -> DS : Add To Cart
DS -> S : Browse Products
activate S
S --> DS : ACK
deactivate S
@enduml