@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
boundary "Member" as M
participant "Admin" as A
participant "Librarian" as L
M --> L : Borrow Book
A --> M : Renew Loan
A -> L : Search Catalog
L ->> M : Return Book
activate M
M --> L : ACK
deactivate M
note over M : processing return book
L -> A : Reserve Book
@enduml