@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
participant "Customer" as C
entity "Driver" as D
control "Fleet Manager" as FM
actor "Dispatcher" as D2
D --> D2 : Update Inventory
activate D2
D2 --> D : ACK
deactivate D2
C --> FM : Report Issue
activate FM
FM --> C : ACK
deactivate FM
D2 --> C : Deliver Package
FM -> C : Fuel Vehicle
activate C
C --> FM : ACK
deactivate C
D2 --> FM : Track Shipment
activate FM
FM --> D2 : ACK
deactivate FM
@enduml