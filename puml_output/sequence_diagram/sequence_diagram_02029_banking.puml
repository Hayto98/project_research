@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
participant "Branch Manager" as BM
control "ATM" as A
control "Account Holder" as AH
AH ->> BM : Pay Bill
BM ->> AH : Deposit Money
AH ->> BM : Withdraw Cash
AH --> BM : Transfer Funds
note over BM : processing transfer funds
BM ->> A : View Statement
@enduml