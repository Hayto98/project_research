@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
control "Bank Teller" as BT
participant "Account Holder" as AH
participant "ATM" as A
participant "Branch Manager" as BM
BT ->> A : Deposit Money
BT -> A : Open Account
BT -> A : Withdraw Cash
AH --> BM : View Statement
activate BM
BM --> AH : ACK
deactivate BM
BT ->> AH : Transfer Funds
note over AH : processing transfer funds
AH --> BM : Apply For Loan
activate BM
BM --> AH : ACK
deactivate BM
BT ->> A : Pay Bill
@enduml