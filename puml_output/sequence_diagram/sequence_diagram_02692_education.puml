@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
actor "Registrar" as R
entity "Admin" as A
control "Librarian" as L
entity "Student" as S
actor "Parent" as P
P --> A : View Schedule
S --> R : Grade Exam
A --> L : Register Student
P ->> S : Issue Certificate
S -> A : Borrow Book
P ->> S : Enroll Course
activate S
S --> P : ACK
deactivate S
note over S : processing enroll course
@enduml