@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
control "Admin" as A
actor "Librarian" as L
control "Teacher" as T
participant "Student" as S
L --> A : Register Student
activate A
A --> L : ACK
deactivate A
S --> L : Borrow Book
T ->> L : Issue Certificate
note over L : processing issue certificate
S -> L : Enroll Course
S -> A : Take Attendance
activate A
A --> S : ACK
deactivate A
S -> L : Submit Assignment
@enduml