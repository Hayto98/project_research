@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
actor "Dispatcher" as D
actor "Fleet Manager" as FM
actor "Driver" as D2
D -> D2 : Assign Route
D ->> D2 : Deliver Package
note over D2 : processing deliver package
D --> D2 : Update Inventory
D -> D2 : Fuel Vehicle
activate D2
D2 --> D : ACK
deactivate D2
@enduml