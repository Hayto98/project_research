@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
participant "Manager" as M
participant "Receptionist" as R
participant "Housekeeper" as H
control "Chef" as C
boundary "Guest" as G
R -> H : Check In
C -> M : Request Service
R -> C : Cancel Reservation
activate C
C --> R : ACK
deactivate C
note over C : processing cancel reservation
M --> G : Clean Room
activate G
G --> M : ACK
deactivate G
note over G : processing clean room
M -> H : Book Room
activate H
H --> M : ACK
deactivate H
note over H : processing book room
G ->> R : Order Room Service
activate R
R --> G : ACK
deactivate R
G ->> C : Check Out
activate C
C --> G : ACK
deactivate C
@enduml