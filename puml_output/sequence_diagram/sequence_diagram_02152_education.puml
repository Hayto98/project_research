@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
boundary "Student" as S
actor "Registrar" as R
control "Teacher" as T
control "Parent" as P
boundary "Admin" as A
R ->> T : Submit Assignment
P --> A : Issue Certificate
A --> P : Enroll Course
A --> P : View Schedule
P -> T : Take Attendance
T -> R : Register Student
@enduml