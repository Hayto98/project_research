@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
boundary "Member" as M
actor "Librarian" as L
control "Admin" as A
L ->> M : Borrow Book
activate M
M --> L : ACK
deactivate M
M -> A : Pay Fine
activate A
A --> M : ACK
deactivate A
A ->> L : Register Member
note over L : processing register member
M -> L : Add New Book
A -> L : Reserve Book
L -> A : Search Catalog
activate A
A --> L : ACK
deactivate A
note over A : processing search catalog
@enduml