@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
entity "Admin" as A
actor "Seller" as S
boundary "Payment Gateway" as PG
boundary "Customer" as C
A -> S : Cancel Order
activate S
S --> A : ACK
deactivate S
note over S : processing cancel order
PG -> C : Manage Inventory
PG --> C : Apply Coupon
S --> C : Add To Cart
activate C
C --> S : ACK
deactivate C
S -> PG : Checkout
activate PG
PG --> S : ACK
deactivate PG
A -> PG : Make Payment
note over PG : processing make payment
PG --> S : Browse Products
@enduml