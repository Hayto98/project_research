@startuml
skinparam monochrome true
skinparam defaultFontSize 11
actor "User" as U
boundary "Admin" as A
actor "Moderator" as M
boundary "Advertiser" as A2
A2 -> U : Send Message
A2 -> U : Report Content
activate U
U --> A2 : ACK
deactivate U
A ->> U : Edit Profile
activate U
U --> A : ACK
deactivate U
note over U : processing edit profile
U -> A : Follow User
activate A
A --> U : ACK
deactivate A
@enduml