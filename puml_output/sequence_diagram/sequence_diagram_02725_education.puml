@startuml
skinparam defaultFontSize 13
participant "Parent" as P
actor "Teacher" as T
control "Student" as S
actor "Librarian" as L
participant "Admin" as A
S --> T : Take Attendance
activate T
T --> S : ACK
deactivate T
S -> P : Borrow Book
S --> P : Grade Exam
S -> A : View Schedule
T ->> A : Register Student
activate A
A --> T : ACK
deactivate A
@enduml