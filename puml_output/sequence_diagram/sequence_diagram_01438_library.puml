@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
control "Member" as M
participant "Librarian" as L
participant "Admin" as A
M --> L : Register Member
L -> A : Add New Book
activate A
A --> L : ACK
deactivate A
A ->> M : Pay Fine
activate M
M --> A : ACK
deactivate M
M -> A : Renew Loan
M -> A : Reserve Book
activate A
A --> M : ACK
deactivate A
@enduml