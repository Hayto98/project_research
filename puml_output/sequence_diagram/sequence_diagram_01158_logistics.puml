@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
actor "Customer" as C
control "Dispatcher" as D
participant "Warehouse Staff" as WS
participant "Fleet Manager" as FM
actor "Driver" as D2
D2 -> FM : Fuel Vehicle
activate FM
FM --> D2 : ACK
deactivate FM
note over FM : processing fuel vehicle
C --> WS : Schedule Pickup
activate WS
WS --> C : ACK
deactivate WS
note over WS : processing schedule pickup
D -> D2 : Track Shipment
FM -> WS : Report Issue
activate WS
WS --> FM : ACK
deactivate WS
@enduml