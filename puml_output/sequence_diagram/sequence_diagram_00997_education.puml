@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
participant "Parent" as P
participant "Teacher" as T
actor "Registrar" as R
T --> R : Borrow Book
note over R : processing borrow book
R ->> T : Register Student
activate T
T --> R : ACK
deactivate T
T ->> R : Submit Assignment
note over R : processing submit assignment
T --> R : View Schedule
note over R : processing view schedule
R ->> T : Enroll Course
T ->> R : Grade Exam
activate R
R --> T : ACK
deactivate R
P --> R : Issue Certificate
note over R : processing issue certificate
@enduml