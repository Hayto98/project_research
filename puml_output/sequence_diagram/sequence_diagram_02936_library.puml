@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
actor "Librarian" as L
boundary "Admin" as A
boundary "Member" as M
L ->> M : Register Member
L --> M : Search Catalog
activate M
M --> L : ACK
deactivate M
L ->> M : Reserve Book
activate M
M --> L : ACK
deactivate M
A --> M : Renew Loan
L ->> M : Borrow Book
activate M
M --> L : ACK
deactivate M
@enduml