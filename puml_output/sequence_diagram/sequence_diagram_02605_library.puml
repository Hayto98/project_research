@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
control "Librarian" as L
participant "Member" as M
boundary "Admin" as A
A ->> L : Add New Book
note over L : processing add new book
A -> L : Reserve Book
L -> M : Pay Fine
L --> M : Renew Loan
M --> A : Return Book
note over A : processing return book
L --> A : Borrow Book
@enduml