@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
participant "Admin" as A
entity "Student" as S
actor "Librarian" as L
actor "Teacher" as T
T ->> A : Issue Certificate
L -> S : Enroll Course
S -> L : View Schedule
S --> L : Grade Exam
activate L
L --> S : ACK
deactivate L
note over L : processing grade exam
A -> S : Take Attendance
@enduml