@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
boundary "Advertiser" as A
control "User" as U
participant "Admin" as A2
entity "Moderator" as M
A2 -> U : Report Content
activate U
U --> A2 : ACK
deactivate U
A ->> U : Comment
note over U : processing comment
U ->> A : Follow User
A2 --> U : Edit Profile
M -> U : Create Post
@enduml