@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
boundary "Librarian" as L
actor "Member" as M
control "Admin" as A
M ->> A : Register Member
activate A
A --> M : ACK
deactivate A
L -> A : Add New Book
note over A : processing add new book
M -> A : Renew Loan
activate A
A --> M : ACK
deactivate A
M --> A : Search Catalog
L ->> A : Return Book
@enduml