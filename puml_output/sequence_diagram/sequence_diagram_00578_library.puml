@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
control "Member" as M
participant "Admin" as A
entity "Librarian" as L
A ->> L : Return Book
activate L
L --> A : ACK
deactivate L
A -> L : Register Member
L -> A : Renew Loan
M -> A : Borrow Book
note over A : processing borrow book
@enduml