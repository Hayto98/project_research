@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
actor "Member" as M
actor "Librarian" as L
entity "Admin" as A
M ->> A : Register Member
activate A
A --> M : ACK
deactivate A
L ->> A : Search Catalog
activate A
A --> L : ACK
deactivate A
M ->> A : Renew Loan
M ->> A : Borrow Book
note over A : processing borrow book
M ->> A : Return Book
activate A
A --> M : ACK
deactivate A
@enduml