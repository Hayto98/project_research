@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
actor "Chef" as C
entity "Manager" as M
boundary "Guest" as G
M --> G : Check Out
activate G
G --> M : ACK
deactivate G
note over G : processing check out
G -> M : Process Payment
note over M : processing process payment
G ->> C : Request Service
C -> M : Book Room
note over M : processing book room
C -> G : Clean Room
note over G : processing clean room
@enduml