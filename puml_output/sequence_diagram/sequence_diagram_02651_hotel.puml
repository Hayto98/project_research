@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
control "Receptionist" as R
control "Guest" as G
entity "Chef" as C
entity "Housekeeper" as H
boundary "Manager" as M
G --> R : Cancel Reservation
M ->> C : Check Out
G ->> H : Process Payment
G --> R : Book Room
H -> R : Check In
note over R : processing check in
C -> M : Clean Room
@enduml