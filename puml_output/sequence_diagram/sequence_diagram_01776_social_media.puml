@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
control "Moderator" as M
boundary "Admin" as A
actor "User" as U
participant "Advertiser" as A2
U -> M : Comment
U ->> A : Edit Profile
A2 ->> A : Send Message
A2 --> M : Follow User
@enduml