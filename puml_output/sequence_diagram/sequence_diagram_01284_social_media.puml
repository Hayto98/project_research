@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
participant "Admin" as A
actor "User" as U
actor "Moderator" as M
A ->> U : Edit Profile
activate U
U --> A : ACK
deactivate U
M ->> U : Report Content
activate U
U --> M : ACK
deactivate U
U -> M : Like Post
U --> M : Create Post
activate M
M --> U : ACK
deactivate M
U -> A : Share Post
activate A
A --> U : ACK
deactivate A
note over A : processing share post
@enduml