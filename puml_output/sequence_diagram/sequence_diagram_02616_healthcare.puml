@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
control "Insurance Provider" as IP
control "Patient" as P
entity "Lab Technician" as LT
LT --> IP : Issue Prescription
activate IP
IP --> LT : ACK
deactivate IP
P -> LT : Run Lab Test
P ->> LT : Admit Patient
activate LT
LT --> P : ACK
deactivate LT
P -> LT : Process Insurance Claim
@enduml