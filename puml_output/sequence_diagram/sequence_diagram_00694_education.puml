@startuml

participant "Registrar" as R
control "Librarian" as L
control "Teacher" as T
participant "Admin" as A
R -> A : Enroll Course
activate A
A --> R : ACK
deactivate A
note over A : processing enroll course
L -> T : Borrow Book
activate T
T --> L : ACK
deactivate T
note over T : processing borrow book
A --> L : Grade Exam
L ->> A : Register Student
R --> L : Issue Certificate
note over L : processing issue certificate
@enduml