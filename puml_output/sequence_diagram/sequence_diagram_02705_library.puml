@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
control "Admin" as A
entity "Librarian" as L
control "Member" as M
A ->> M : Add New Book
activate M
M --> A : ACK
deactivate M
M ->> A : Reserve Book
M ->> A : Register Member
note over A : processing register member
M -> L : Search Catalog
A -> L : Pay Fine
@enduml