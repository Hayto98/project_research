@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
entity "Registrar" as R
actor "Student" as S
entity "Admin" as A
participant "Librarian" as L
control "Parent" as P
A -> P : Issue Certificate
P --> L : Grade Exam
note over L : processing grade exam
S -> L : Take Attendance
L --> A : Register Student
activate A
A --> L : ACK
deactivate A
@enduml