@startuml
skinparam monochrome true
boundary "Admin" as A
actor "Student" as S
participant "Librarian" as L
control "Teacher" as T
T ->> L : View Schedule
S --> T : Register Student
A -> S : Issue Certificate
activate S
S --> A : ACK
deactivate S
S -> T : Take Attendance
activate T
T --> S : ACK
deactivate T
T -> S : Enroll Course
@enduml