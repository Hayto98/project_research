@startuml
skinparam defaultFontSize 11
entity "Seller" as S
boundary "Customer" as C
actor "Admin" as A
actor "Payment Gateway" as PG
A ->> C : Apply Coupon
activate C
C --> A : ACK
deactivate C
C -> PG : Cancel Order
activate PG
PG --> C : ACK
deactivate PG
note over PG : processing cancel order
PG ->> A : Checkout
PG -> C : Add To Cart
activate C
C --> PG : ACK
deactivate C
@enduml