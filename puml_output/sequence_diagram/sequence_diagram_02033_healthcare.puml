@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
entity "Patient" as P
participant "Lab Technician" as LT
entity "Doctor" as D
control "Receptionist" as R
LT ->> P : Process Insurance Claim
R -> LT : Update Medical Record
D ->> P : Issue Prescription
R ->> D : Discharge Patient
note over D : processing discharge patient
LT -> P : Book Appointment
P -> LT : Run Lab Test
@enduml