@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
control "Chef" as C
entity "Manager" as M
participant "Receptionist" as R
actor "Housekeeper" as H
C -> R : Cancel Reservation
C -> M : Process Payment
M ->> C : Order Room Service
activate C
C --> M : ACK
deactivate C
M -> R : Request Service
@enduml