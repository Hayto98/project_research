@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
boundary "Driver" as D
boundary "Fleet Manager" as FM
participant "Dispatcher" as D2
D2 ->> FM : Schedule Pickup
D ->> FM : Load Package
D2 -> FM : Fuel Vehicle
D ->> FM : Update Inventory
note over FM : processing update inventory
@enduml