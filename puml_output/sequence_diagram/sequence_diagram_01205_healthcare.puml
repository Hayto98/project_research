@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
boundary "Insurance Provider" as IP
control "Patient" as P
participant "Nurse" as N
actor "Lab Technician" as LT
entity "Receptionist" as R
LT -> P : Admit Patient
N ->> LT : Issue Prescription
IP --> N : Book Appointment
note over N : processing book appointment
R ->> IP : Discharge Patient
P --> N : Examine Patient
LT ->> P : Process Insurance Claim
note over P : processing process insurance claim
@enduml