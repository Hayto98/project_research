@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
entity "Admin" as A
actor "Member" as M
participant "Librarian" as L
M -> L : Register Member
L --> M : Return Book
A -> M : Pay Fine
L ->> A : Borrow Book
A -> M : Add New Book
A -> L : Reserve Book
activate L
L --> A : ACK
deactivate L
M ->> A : Search Catalog
activate A
A --> M : ACK
deactivate A
@enduml