@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
boundary "Teacher" as T
participant "Parent" as P
participant "Admin" as A
A -> P : View Schedule
activate P
P --> A : ACK
deactivate P
T -> P : Register Student
activate P
P --> T : ACK
deactivate P
A ->> P : Enroll Course
activate P
P --> A : ACK
deactivate P
P ->> T : Borrow Book
note over T : processing borrow book
A -> P : Issue Certificate
@enduml