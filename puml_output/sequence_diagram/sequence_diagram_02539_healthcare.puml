@startuml
skinparam monochrome true
skinparam defaultFontSize 11
participant "Doctor" as D
entity "Lab Technician" as LT
entity "Nurse" as N
N -> D : Process Insurance Claim
LT --> N : Book Appointment
note over N : processing book appointment
D -> LT : Run Lab Test
D ->> N : Admit Patient
activate N
N --> D : ACK
deactivate N
@enduml