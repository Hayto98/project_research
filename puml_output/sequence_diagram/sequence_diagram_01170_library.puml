@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
actor "Librarian" as L
control "Member" as M
entity "Admin" as A
L -> M : Register Member
M ->> L : Reserve Book
activate L
L --> M : ACK
deactivate L
note over L : processing reserve book
L ->> M : Add New Book
activate M
M --> L : ACK
deactivate M
note over M : processing add new book
L --> A : Return Book
L --> M : Renew Loan
@enduml