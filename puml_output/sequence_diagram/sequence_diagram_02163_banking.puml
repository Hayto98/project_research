@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
control "Account Holder" as AH
entity "Auditor" as A
control "ATM" as A2
control "Branch Manager" as BM
A -> A2 : Apply For Loan
AH ->> A : View Statement
AH ->> A : Deposit Money
activate A
A --> AH : ACK
deactivate A
A --> BM : Open Account
activate BM
BM --> A : ACK
deactivate BM
A --> A2 : Withdraw Cash
activate A2
A2 --> A : ACK
deactivate A2
@enduml