@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
entity "Customer" as C
participant "Payment Gateway" as PG
actor "Admin" as A
participant "Delivery Service" as DS
control "Seller" as S
PG --> DS : Cancel Order
activate DS
DS --> PG : ACK
deactivate DS
note over DS : processing cancel order
S -> PG : Write Review
activate PG
PG --> S : ACK
deactivate PG
DS --> C : Make Payment
activate C
C --> DS : ACK
deactivate C
A ->> DS : Manage Inventory
@enduml