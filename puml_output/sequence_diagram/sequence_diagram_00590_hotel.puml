@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
entity "Guest" as G
entity "Manager" as M
entity "Housekeeper" as H
control "Receptionist" as R
M -> R : Clean Room
G ->> H : Book Room
H ->> M : Check Out
H -> M : Request Service
activate M
M --> H : ACK
deactivate M
@enduml