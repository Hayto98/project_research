@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
actor "Warehouse Staff" as WS
control "Customer" as C
entity "Dispatcher" as D
D --> C : Assign Route
activate C
C --> D : ACK
deactivate C
WS -> D : Track Shipment
D ->> WS : Fuel Vehicle
D ->> C : Load Package
C -> D : Report Issue
@enduml