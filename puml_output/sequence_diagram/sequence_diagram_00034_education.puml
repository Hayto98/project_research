@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
boundary "Student" as S
participant "Registrar" as R
actor "Parent" as P
R ->> P : Issue Certificate
S ->> P : Take Attendance
P ->> S : Enroll Course
P --> R : Borrow Book
note over R : processing borrow book
S --> P : Submit Assignment
P ->> R : Register Student
activate R
R --> P : ACK
deactivate R
@enduml