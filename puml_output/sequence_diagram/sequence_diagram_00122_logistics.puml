@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
boundary "Warehouse Staff" as WS
actor "Customer" as C
actor "Driver" as D
boundary "Dispatcher" as D2
actor "Fleet Manager" as FM
D2 -> C : Schedule Pickup
note over C : processing schedule pickup
D2 -> D : Report Issue
WS ->> C : Fuel Vehicle
C --> D : Assign Route
note over D : processing assign route
D2 -> WS : Track Shipment
activate WS
WS --> D2 : ACK
deactivate WS
@enduml