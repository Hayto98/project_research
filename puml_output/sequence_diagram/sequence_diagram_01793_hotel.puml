@startuml
skinparam monochrome true
skinparam ArrowColor #555555
boundary "Manager" as M
participant "Receptionist" as R
control "Guest" as G
entity "Chef" as C
G -> R : Order Room Service
activate R
R --> G : ACK
deactivate R
G ->> M : Book Room
M --> C : Check Out
M -> G : Clean Room
activate G
G --> M : ACK
deactivate G
note over G : processing clean room
@enduml