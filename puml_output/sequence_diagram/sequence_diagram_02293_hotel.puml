@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
actor "Manager" as M
actor "Guest" as G
participant "Receptionist" as R
entity "Chef" as C
G --> M : Order Room Service
activate M
M --> G : ACK
deactivate M
G --> M : Check Out
activate M
M --> G : ACK
deactivate M
note over M : processing check out
C --> G : Check In
note over G : processing check in
M ->> C : Clean Room
G -> R : Request Service
G ->> M : Cancel Reservation
M --> C : Process Payment
@enduml