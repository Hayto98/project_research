@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
actor "Librarian" as L
participant "Parent" as P
boundary "Registrar" as R
participant "Admin" as A
participant "Student" as S
R ->> A : View Schedule
note over A : processing view schedule
P ->> A : Grade Exam
activate A
A --> P : ACK
deactivate A
L ->> A : Submit Assignment
R -> P : Borrow Book
L -> R : Register Student
S ->> L : Issue Certificate
@enduml