@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
boundary "Driver" as D
actor "Customer" as C
actor "Warehouse Staff" as WS
control "Dispatcher" as D2
D -> D2 : Assign Route
D2 -> WS : Load Package
activate WS
WS --> D2 : ACK
deactivate WS
D2 --> WS : Track Shipment
D ->> C : Deliver Package
@enduml