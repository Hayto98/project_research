@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
control "Lab Technician" as LT
actor "Patient" as P
control "Receptionist" as R
control "Insurance Provider" as IP
IP -> R : Update Medical Record
activate R
R --> IP : ACK
deactivate R
P ->> IP : Run Lab Test
P --> IP : Book Appointment
P --> IP : Examine Patient
R --> IP : Discharge Patient
@enduml