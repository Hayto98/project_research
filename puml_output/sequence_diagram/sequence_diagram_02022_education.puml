@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
boundary "Parent" as P
actor "Teacher" as T
participant "Student" as S
control "Registrar" as R
control "Admin" as A
P -> R : Borrow Book
T --> R : Issue Certificate
A -> R : Register Student
activate R
R --> A : ACK
deactivate R
S -> A : Grade Exam
T ->> P : Submit Assignment
R --> S : Enroll Course
A ->> P : View Schedule
@enduml