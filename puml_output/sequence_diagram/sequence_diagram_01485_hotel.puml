@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
participant "Guest" as G
boundary "Chef" as C
actor "Receptionist" as R
entity "Housekeeper" as H
R --> C : Check In
R --> H : Order Room Service
note over H : processing order room service
C ->> R : Request Service
activate R
R --> C : ACK
deactivate R
H -> C : Book Room
@enduml