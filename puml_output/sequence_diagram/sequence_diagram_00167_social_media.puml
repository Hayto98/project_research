@startuml
skinparam ArrowColor #555555
participant "Advertiser" as A
participant "User" as U
participant "Admin" as A2
participant "Moderator" as M
U -> M : Report Content
A -> A2 : Create Post
M -> A2 : Edit Profile
note over A2 : processing edit profile
M --> A : Follow User
A2 ->> A : Share Post
activate A
A --> A2 : ACK
deactivate A
@enduml