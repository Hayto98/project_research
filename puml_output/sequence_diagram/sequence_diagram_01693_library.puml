@startuml
skinparam monochrome true
skinparam defaultFontSize 11
boundary "Librarian" as L
entity "Admin" as A
control "Member" as M
A ->> L : Borrow Book
activate L
L --> A : ACK
deactivate L
A -> L : Renew Loan
activate L
L --> A : ACK
deactivate L
M -> L : Add New Book
L --> A : Reserve Book
activate A
A --> L : ACK
deactivate A
@enduml