@startuml
skinparam defaultFontSize 13
boundary "Admin" as A
actor "Advertiser" as A2
actor "User" as U
boundary "Moderator" as M
A2 -> M : Create Post
activate M
M --> A2 : ACK
deactivate M
A -> M : Comment
U ->> A2 : Like Post
activate A2
A2 --> U : ACK
deactivate A2
M ->> A : Share Post
note over A : processing share post
A2 ->> M : Send Message
note over M : processing send message
@enduml