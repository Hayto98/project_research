@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
participant "Warehouse Staff" as WS
control "Driver" as D
actor "Customer" as C
D -> WS : Deliver Package
note over WS : processing deliver package
C -> WS : Report Issue
C -> WS : Schedule Pickup
D -> WS : Track Shipment
C -> WS : Assign Route
activate WS
WS --> C : ACK
deactivate WS
@enduml