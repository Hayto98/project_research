@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
actor "Admin" as A
boundary "Customer" as C
control "Seller" as S
control "Payment Gateway" as PG
PG --> C : Cancel Order
A --> PG : Track Order
PG ->> S : Checkout
S ->> A : Manage Inventory
note over A : processing manage inventory
C -> A : Make Payment
S ->> C : Write Review
activate C
C --> S : ACK
deactivate C
S --> C : Apply Coupon
activate C
C --> S : ACK
deactivate C
note over C : processing apply coupon
@enduml