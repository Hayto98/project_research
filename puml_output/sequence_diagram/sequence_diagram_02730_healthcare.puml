@startuml
skinparam defaultFontSize 11
boundary "Insurance Provider" as IP
boundary "Doctor" as D
boundary "Nurse" as N
participant "Patient" as P
entity "Lab Technician" as LT
N ->> LT : Update Medical Record
D -> IP : Discharge Patient
N --> IP : Examine Patient
activate IP
IP --> N : ACK
deactivate IP
LT ->> N : Process Insurance Claim
IP -> D : Book Appointment
P --> IP : Admit Patient
activate IP
IP --> P : ACK
deactivate IP
@enduml