@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
boundary "Admin" as A
entity "Librarian" as L
participant "Teacher" as T
entity "Registrar" as R
T -> R : Submit Assignment
note over R : processing submit assignment
L ->> T : View Schedule
A --> L : Grade Exam
L -> A : Borrow Book
activate A
A --> L : ACK
deactivate A
@enduml