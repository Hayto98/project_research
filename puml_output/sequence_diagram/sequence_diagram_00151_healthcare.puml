@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
control "Nurse" as N
entity "Insurance Provider" as IP
entity "Doctor" as D
actor "Receptionist" as R
N -> R : Process Insurance Claim
D ->> R : Update Medical Record
note over R : processing update medical record
R ->> IP : Issue Prescription
D ->> R : Admit Patient
@enduml