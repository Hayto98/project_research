@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
entity "Manager" as M
boundary "Housekeeper" as H
entity "Chef" as C
C --> M : Request Service
activate M
M --> C : ACK
deactivate M
M ->> C : Process Payment
C --> H : Check Out
activate H
H --> C : ACK
deactivate H
note over H : processing check out
M -> C : Book Room
@enduml