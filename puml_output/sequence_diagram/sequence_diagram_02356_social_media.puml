@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
actor "Admin" as A
entity "Advertiser" as A2
actor "Moderator" as M
A -> A2 : Follow User
A ->> A2 : Share Post
activate A2
A2 --> A : ACK
deactivate A2
M -> A2 : Create Post
note over A2 : processing create post
A2 --> M : Comment
A2 --> A : Like Post
activate A
A --> A2 : ACK
deactivate A
@enduml