@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
control "Librarian" as L
entity "Admin" as A
entity "Member" as M
A -> M : Pay Fine
L --> M : Add New Book
L --> M : Register Member
A ->> M : Search Catalog
M -> A : Return Book
activate A
A --> M : ACK
deactivate A
note over A : processing return book
M --> A : Borrow Book
@enduml