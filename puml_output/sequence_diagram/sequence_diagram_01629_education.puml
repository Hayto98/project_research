@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
entity "Admin" as A
entity "Teacher" as T
entity "Parent" as P
entity "Student" as S
A --> S : Register Student
A ->> S : View Schedule
activate S
S --> A : ACK
deactivate S
S ->> A : Issue Certificate
activate A
A --> S : ACK
deactivate A
S ->> A : Enroll Course
activate A
A --> S : ACK
deactivate A
T ->> P : Grade Exam
A --> T : Submit Assignment
note over T : processing submit assignment
A --> P : Take Attendance
@enduml