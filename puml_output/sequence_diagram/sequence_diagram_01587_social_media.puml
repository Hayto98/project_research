@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
control "Advertiser" as A
participant "Moderator" as M
actor "User" as U
M -> U : Share Post
M -> U : Like Post
activate U
U --> M : ACK
deactivate U
M -> A : Edit Profile
U ->> M : Create Post
M -> A : Comment
@enduml