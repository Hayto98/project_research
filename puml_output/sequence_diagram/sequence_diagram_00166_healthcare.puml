@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
entity "Doctor" as D
entity "Patient" as P
participant "Lab Technician" as LT
LT -> P : Admit Patient
D --> P : Run Lab Test
P -> D : Book Appointment
P --> D : Discharge Patient
activate D
D --> P : ACK
deactivate D
note over D : processing discharge patient
@enduml