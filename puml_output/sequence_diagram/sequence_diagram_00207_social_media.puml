@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
boundary "Moderator" as M
control "Admin" as A
control "User" as U
actor "Advertiser" as A2
A2 ->> A : Send Message
A2 --> A : Comment
activate A
A --> A2 : ACK
deactivate A
U -> A2 : Like Post
A2 -> A : Create Post
activate A
A --> A2 : ACK
deactivate A
@enduml