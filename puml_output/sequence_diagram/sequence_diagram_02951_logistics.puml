@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
control "Driver" as D
entity "Dispatcher" as D2
control "Customer" as C
entity "Fleet Manager" as FM
actor "Warehouse Staff" as WS
WS --> D : Load Package
D --> WS : Report Issue
note over WS : processing report issue
D2 -> D : Update Inventory
WS --> FM : Track Shipment
note over FM : processing track shipment
C --> D : Assign Route
@enduml