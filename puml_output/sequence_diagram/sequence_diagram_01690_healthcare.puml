@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
actor "Receptionist" as R
actor "Patient" as P
actor "Lab Technician" as LT
P ->> LT : Examine Patient
P --> R : Run Lab Test
activate R
R --> P : ACK
deactivate R
R ->> P : Process Insurance Claim
R --> LT : Book Appointment
P ->> LT : Discharge Patient
@enduml