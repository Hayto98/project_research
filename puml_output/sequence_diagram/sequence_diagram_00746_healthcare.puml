@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
control "Lab Technician" as LT
participant "Receptionist" as R
boundary "Insurance Provider" as IP
participant "Nurse" as N
actor "Doctor" as D
LT -> N : Examine Patient
activate N
N --> LT : ACK
deactivate N
IP -> N : Book Appointment
R ->> LT : Admit Patient
IP --> N : Issue Prescription
@enduml