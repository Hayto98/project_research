@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
participant "Lab Technician" as LT
participant "Nurse" as N
actor "Doctor" as D
entity "Insurance Provider" as IP
LT ->> N : Discharge Patient
LT --> D : Update Medical Record
activate D
D --> LT : ACK
deactivate D
LT --> N : Run Lab Test
D --> LT : Admit Patient
note over LT : processing admit patient
D --> IP : Process Insurance Claim
LT ->> D : Book Appointment
activate D
D --> LT : ACK
deactivate D
IP -> D : Examine Patient
activate D
D --> IP : ACK
deactivate D
@enduml