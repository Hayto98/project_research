@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
boundary "Moderator" as M
participant "Admin" as A
control "Advertiser" as A2
A -> M : Like Post
activate M
M --> A : ACK
deactivate M
A2 ->> M : Create Post
A --> M : Follow User
activate M
M --> A : ACK
deactivate M
A2 ->> M : Report Content
activate M
M --> A2 : ACK
deactivate M
A2 --> M : Share Post
M -> A2 : Edit Profile
note over A2 : processing edit profile
A2 --> M : Comment
@enduml