@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
control "Dispatcher" as D
entity "Fleet Manager" as FM
control "Driver" as D2
control "Customer" as C
actor "Warehouse Staff" as WS
FM --> D : Fuel Vehicle
C ->> WS : Assign Route
D2 ->> WS : Report Issue
C ->> D2 : Track Shipment
activate D2
D2 --> C : ACK
deactivate D2
D -> D2 : Schedule Pickup
@enduml