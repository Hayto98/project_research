@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
entity "Registrar" as R
actor "Parent" as P
entity "Admin" as A
P --> R : Take Attendance
activate R
R --> P : ACK
deactivate R
R -> P : Enroll Course
activate P
P --> R : ACK
deactivate P
P -> A : Submit Assignment
A -> R : Grade Exam
A ->> P : Borrow Book
note over P : processing borrow book
@enduml