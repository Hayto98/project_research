@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
control "Advertiser" as A
participant "Admin" as A2
actor "User" as U
A -> A2 : Comment
U ->> A : Report Content
U --> A2 : Like Post
activate A2
A2 --> U : ACK
deactivate A2
note over A2 : processing like post
A ->> U : Send Message
A2 ->> U : Follow User
U --> A2 : Create Post
activate A2
A2 --> U : ACK
deactivate A2
@enduml