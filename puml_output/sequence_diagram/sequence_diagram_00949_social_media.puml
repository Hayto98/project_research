@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
boundary "Admin" as A
control "User" as U
control "Advertiser" as A2
actor "Moderator" as M
A -> A2 : Comment
activate A2
A2 --> A : ACK
deactivate A2
note over A2 : processing comment
M -> U : Follow User
A -> U : Edit Profile
A -> U : Share Post
A ->> U : Like Post
A --> U : Report Content
@enduml