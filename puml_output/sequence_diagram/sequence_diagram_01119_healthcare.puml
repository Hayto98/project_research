@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
entity "Nurse" as N
actor "Receptionist" as R
participant "Doctor" as D
R ->> N : Discharge Patient
D ->> N : Book Appointment
D ->> R : Update Medical Record
activate R
R --> D : ACK
deactivate R
R --> D : Admit Patient
@enduml