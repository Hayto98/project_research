@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
control "Branch Manager" as BM
control "Auditor" as A
entity "ATM" as A2
A2 ->> A : Pay Bill
activate A
A --> A2 : ACK
deactivate A
BM ->> A2 : Open Account
activate A2
A2 --> BM : ACK
deactivate A2
note over A2 : processing open account
A -> BM : Transfer Funds
activate BM
BM --> A : ACK
deactivate BM
A2 ->> BM : View Statement
activate BM
BM --> A2 : ACK
deactivate BM
note over BM : processing view statement
BM --> A : Withdraw Cash
activate A
A --> BM : ACK
deactivate A
A ->> A2 : Deposit Money
@enduml