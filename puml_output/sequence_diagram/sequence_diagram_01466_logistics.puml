@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
entity "Fleet Manager" as FM
participant "Customer" as C
entity "Dispatcher" as D
FM --> D : Load Package
C ->> FM : Track Shipment
C ->> D : Fuel Vehicle
D ->> FM : Assign Route
activate FM
FM --> D : ACK
deactivate FM
D --> C : Schedule Pickup
activate C
C --> D : ACK
deactivate C
C ->> D : Deliver Package
D ->> FM : Report Issue
activate FM
FM --> D : ACK
deactivate FM
@enduml