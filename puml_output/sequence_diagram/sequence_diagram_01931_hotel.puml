@startuml
skinparam defaultFontSize 11
participant "Manager" as M
boundary "Receptionist" as R
entity "Housekeeper" as H
R --> M : Check Out
note over M : processing check out
R -> M : Process Payment
activate M
M --> R : ACK
deactivate M
M -> R : Cancel Reservation
M ->> R : Order Room Service
note over R : processing order room service
M --> R : Book Room
@enduml