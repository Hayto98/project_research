@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
participant "Insurance Provider" as IP
actor "Doctor" as D
entity "Lab Technician" as LT
IP -> LT : Examine Patient
LT -> D : Run Lab Test
IP --> LT : Issue Prescription
note over LT : processing issue prescription
D --> LT : Process Insurance Claim
IP --> LT : Admit Patient
@enduml