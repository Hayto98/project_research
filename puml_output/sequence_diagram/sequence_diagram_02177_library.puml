@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
control "Librarian" as L
participant "Admin" as A
entity "Member" as M
A -> M : Register Member
M ->> L : Return Book
activate L
L --> M : ACK
deactivate L
note over L : processing return book
L --> M : Reserve Book
M --> L : Renew Loan
@enduml