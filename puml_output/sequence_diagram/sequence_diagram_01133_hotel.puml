@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
boundary "Chef" as C
participant "Guest" as G
actor "Manager" as M
G ->> C : Check Out
activate C
C --> G : ACK
deactivate C
C --> M : Request Service
activate M
M --> C : ACK
deactivate M
G --> C : Clean Room
M -> C : Cancel Reservation
G --> M : Book Room
note over M : processing book room
G ->> M : Order Room Service
activate M
M --> G : ACK
deactivate M
note over M : processing order room service
G ->> C : Check In
@enduml