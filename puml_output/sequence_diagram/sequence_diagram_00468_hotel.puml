@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
boundary "Receptionist" as R
participant "Manager" as M
boundary "Housekeeper" as H
boundary "Guest" as G
M --> R : Cancel Reservation
G --> R : Clean Room
note over R : processing clean room
G ->> M : Book Room
note over M : processing book room
M --> G : Check In
note over G : processing check in
G -> M : Process Payment
activate M
M --> G : ACK
deactivate M
M ->> R : Check Out
activate R
R --> M : ACK
deactivate R
@enduml