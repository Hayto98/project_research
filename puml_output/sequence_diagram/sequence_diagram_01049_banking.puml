@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
control "ATM" as A
actor "Bank Teller" as BT
entity "Account Holder" as AH
participant "Auditor" as A2
actor "Branch Manager" as BM
A ->> BM : Pay Bill
note over BM : processing pay bill
BT ->> AH : Open Account
note over AH : processing open account
BT ->> BM : Transfer Funds
AH ->> A : Block Card
BT -> BM : View Statement
activate BM
BM --> BT : ACK
deactivate BM
note over BM : processing view statement
@enduml