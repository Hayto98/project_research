@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
actor "Teacher" as T
boundary "Registrar" as R
boundary "Student" as S
entity "Parent" as P
R --> P : Issue Certificate
P -> T : Borrow Book
activate T
T --> P : ACK
deactivate T
S --> T : Take Attendance
T --> R : Submit Assignment
activate R
R --> T : ACK
deactivate R
P -> T : Register Student
activate T
T --> P : ACK
deactivate T
@enduml