@startuml
skinparam defaultFontSize 13
actor "Warehouse Staff" as WS
participant "Driver" as D
actor "Dispatcher" as D2
boundary "Customer" as C
C -> WS : Track Shipment
WS --> D : Fuel Vehicle
WS ->> D : Report Issue
D2 --> D : Update Inventory
WS ->> D : Deliver Package
D --> WS : Load Package
D ->> WS : Assign Route
@enduml