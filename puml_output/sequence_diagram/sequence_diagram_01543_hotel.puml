@startuml
skinparam ArrowColor #555555
participant "Receptionist" as R
entity "Guest" as G
participant "Housekeeper" as H
entity "Manager" as M
M --> G : Cancel Reservation
activate G
G --> M : ACK
deactivate G
note over G : processing cancel reservation
H --> G : Book Room
R --> M : Process Payment
H ->> R : Request Service
note over R : processing request service
@enduml