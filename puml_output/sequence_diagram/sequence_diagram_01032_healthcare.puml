@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
entity "Nurse" as N
boundary "Patient" as P
entity "Insurance Provider" as IP
IP ->> N : Update Medical Record
N --> P : Admit Patient
note over P : processing admit patient
IP ->> N : Discharge Patient
activate N
N --> IP : ACK
deactivate N
note over N : processing discharge patient
IP -> N : Examine Patient
IP --> P : Run Lab Test
note over P : processing run lab test
@enduml