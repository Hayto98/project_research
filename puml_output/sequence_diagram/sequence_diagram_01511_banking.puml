@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
actor "Account Holder" as AH
actor "Auditor" as A
entity "ATM" as A2
entity "Bank Teller" as BT
A -> A2 : Deposit Money
activate A2
A2 --> A : ACK
deactivate A2
A -> AH : View Statement
note over AH : processing view statement
AH -> BT : Open Account
A2 -> BT : Block Card
note over BT : processing block card
@enduml