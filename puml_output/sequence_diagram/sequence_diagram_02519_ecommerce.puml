@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
participant "Customer" as C
entity "Seller" as S
participant "Payment Gateway" as PG
C ->> S : Write Review
C --> S : Apply Coupon
note over S : processing apply coupon
S ->> PG : Track Order
PG -> S : Manage Inventory
S --> C : Add To Cart
@enduml