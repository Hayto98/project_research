@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
control "Chef" as C
entity "Manager" as M
control "Receptionist" as R
entity "Housekeeper" as H
R ->> H : Check In
M --> H : Request Service
activate H
H --> M : ACK
deactivate H
R --> M : Order Room Service
H -> M : Clean Room
M --> C : Book Room
C --> M : Process Payment
activate M
M --> C : ACK
deactivate M
note over M : processing process payment
M --> C : Check Out
note over C : processing check out
@enduml