@startuml
skinparam monochrome true
participant "Dispatcher" as D
boundary "Customer" as C
entity "Warehouse Staff" as WS
control "Driver" as D2
boundary "Fleet Manager" as FM
FM -> WS : Report Issue
C ->> D2 : Load Package
C ->> D : Assign Route
activate D
D --> C : ACK
deactivate D
note over D : processing assign route
FM -> D : Deliver Package
D2 -> D : Update Inventory
FM --> D2 : Schedule Pickup
activate D2
D2 --> FM : ACK
deactivate D2
FM --> D : Track Shipment
activate D
D --> FM : ACK
deactivate D
note over D : processing track shipment
@enduml