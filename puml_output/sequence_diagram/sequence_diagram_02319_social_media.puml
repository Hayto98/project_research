@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
control "User" as U
control "Moderator" as M
control "Advertiser" as A
control "Admin" as A2
U --> M : Like Post
M --> U : Create Post
activate U
U --> M : ACK
deactivate U
A2 ->> A : Edit Profile
activate A
A --> A2 : ACK
deactivate A
A2 ->> A : Share Post
activate A
A --> A2 : ACK
deactivate A
M ->> A2 : Comment
@enduml