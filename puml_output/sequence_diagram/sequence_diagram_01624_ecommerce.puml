@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
entity "Payment Gateway" as PG
entity "Admin" as A
entity "Customer" as C
participant "Seller" as S
entity "Delivery Service" as DS
A ->> S : Browse Products
DS -> S : Write Review
activate S
S --> DS : ACK
deactivate S
A -> S : Cancel Order
note over S : processing cancel order
C --> PG : Apply Coupon
activate PG
PG --> C : ACK
deactivate PG
@enduml