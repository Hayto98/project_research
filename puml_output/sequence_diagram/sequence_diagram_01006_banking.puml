@startuml
skinparam monochrome true
skinparam ArrowColor #555555
participant "Bank Teller" as BT
boundary "Auditor" as A
boundary "ATM" as A2
boundary "Account Holder" as AH
boundary "Branch Manager" as BM
BM --> AH : Transfer Funds
AH -> BM : View Statement
AH --> BT : Deposit Money
AH --> BT : Open Account
activate BT
BT --> AH : ACK
deactivate BT
AH -> BT : Withdraw Cash
@enduml