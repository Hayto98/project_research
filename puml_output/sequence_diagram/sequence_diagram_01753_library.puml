@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
control "Member" as M
boundary "Admin" as A
actor "Librarian" as L
A --> L : Renew Loan
M --> A : Register Member
M -> L : Add New Book
activate L
L --> M : ACK
deactivate L
M -> A : Return Book
L -> A : Pay Fine
@enduml