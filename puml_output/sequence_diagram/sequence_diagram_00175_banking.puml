@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
actor "Bank Teller" as BT
entity "Account Holder" as AH
control "Auditor" as A
BT --> AH : Transfer Funds
note over AH : processing transfer funds
A ->> BT : Pay Bill
AH --> BT : Deposit Money
activate BT
BT --> AH : ACK
deactivate BT
AH -> A : Apply For Loan
@enduml