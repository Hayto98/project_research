@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
boundary "Teacher" as T
entity "Librarian" as L
control "Parent" as P
T --> L : View Schedule
P -> L : Grade Exam
P ->> L : Enroll Course
T ->> L : Borrow Book
activate L
L --> T : ACK
deactivate L
note over L : processing borrow book
P ->> L : Take Attendance
L ->> T : Register Student
@enduml