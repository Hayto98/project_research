@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
boundary "Member" as M
participant "Librarian" as L
entity "Admin" as A
M -> L : Search Catalog
note over L : processing search catalog
L ->> M : Pay Fine
L ->> A : Add New Book
M -> A : Return Book
note over A : processing return book
@enduml