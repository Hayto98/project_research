@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
actor "Doctor" as D
actor "Lab Technician" as LT
participant "Nurse" as N
D --> N : Update Medical Record
D -> LT : Discharge Patient
activate LT
LT --> D : ACK
deactivate LT
note over LT : processing discharge patient
D -> LT : Process Insurance Claim
N --> D : Run Lab Test
@enduml