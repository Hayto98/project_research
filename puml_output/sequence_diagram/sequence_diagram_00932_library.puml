@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
participant "Member" as M
entity "Librarian" as L
actor "Admin" as A
M --> A : Reserve Book
A --> M : Add New Book
L --> M : Borrow Book
L -> M : Search Catalog
activate M
M --> L : ACK
deactivate M
A ->> M : Renew Loan
activate M
M --> A : ACK
deactivate M
@enduml