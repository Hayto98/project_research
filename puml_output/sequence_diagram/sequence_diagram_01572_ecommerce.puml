@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
control "Seller" as S
boundary "Delivery Service" as DS
boundary "Customer" as C
entity "Admin" as A
control "Payment Gateway" as PG
C -> A : Manage Inventory
C -> DS : Apply Coupon
activate DS
DS --> C : ACK
deactivate DS
A -> PG : Track Order
PG ->> DS : Add To Cart
note over DS : processing add to cart
@enduml