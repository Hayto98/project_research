@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
participant "Admin" as A
boundary "User" as U
participant "Moderator" as M
boundary "Advertiser" as A2
A2 -> A : Like Post
activate A
A --> A2 : ACK
deactivate A
A2 ->> A : Comment
activate A
A --> A2 : ACK
deactivate A
A --> A2 : Create Post
A --> A2 : Send Message
M -> A2 : Follow User
activate A2
A2 --> M : ACK
deactivate A2
@enduml