@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
boundary "Teacher" as T
participant "Parent" as P
actor "Registrar" as R
control "Student" as S
P --> S : Submit Assignment
activate S
S --> P : ACK
deactivate S
S --> R : Take Attendance
note over R : processing take attendance
T ->> S : View Schedule
R --> P : Issue Certificate
@enduml