@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
entity "Doctor" as D
entity "Insurance Provider" as IP
control "Nurse" as N
N -> D : Examine Patient
D -> N : Book Appointment
N --> IP : Update Medical Record
note over IP : processing update medical record
D --> N : Admit Patient
IP --> N : Process Insurance Claim
IP -> D : Run Lab Test
@enduml