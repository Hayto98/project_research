@startuml
skinparam monochrome true
skinparam defaultFontSize 11
actor "Housekeeper" as H
control "Chef" as C
entity "Manager" as M
participant "Guest" as G
H --> C : Book Room
note over C : processing book room
G ->> M : Cancel Reservation
note over M : processing cancel reservation
M --> C : Check In
activate C
C --> M : ACK
deactivate C
M ->> G : Clean Room
M -> G : Request Service
note over G : processing request service
M -> C : Order Room Service
@enduml