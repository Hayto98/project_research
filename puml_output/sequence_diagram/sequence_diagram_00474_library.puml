@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
participant "Member" as M
participant "Librarian" as L
control "Admin" as A
M ->> L : Search Catalog
L --> M : Register Member
note over M : processing register member
A -> M : Renew Loan
A -> L : Add New Book
@enduml