@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
participant "Chef" as C
boundary "Manager" as M
boundary "Receptionist" as R
entity "Housekeeper" as H
M ->> H : Check In
R ->> C : Process Payment
activate C
C --> R : ACK
deactivate C
H -> M : Order Room Service
C --> H : Clean Room
C ->> H : Book Room
R ->> H : Cancel Reservation
@enduml