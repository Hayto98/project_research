@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
control "User" as U
boundary "Advertiser" as A
boundary "Moderator" as M
entity "Admin" as A2
M -> A2 : Send Message
activate A2
A2 --> M : ACK
deactivate A2
U -> A : Edit Profile
U --> M : Create Post
M ->> A2 : Share Post
U -> M : Follow User
A -> M : Like Post
@enduml