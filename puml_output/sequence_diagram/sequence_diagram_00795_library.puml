@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
entity "Member" as M
control "Admin" as A
actor "Librarian" as L
L ->> M : Renew Loan
activate M
M --> L : ACK
deactivate M
L --> M : Pay Fine
activate M
M --> L : ACK
deactivate M
L --> A : Search Catalog
L ->> M : Reserve Book
@enduml