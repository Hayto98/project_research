@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
participant "Patient" as P
actor "Nurse" as N
entity "Insurance Provider" as IP
N ->> IP : Process Insurance Claim
N ->> P : Admit Patient
P ->> IP : Book Appointment
note over IP : processing book appointment
P -> N : Issue Prescription
P -> N : Discharge Patient
@enduml