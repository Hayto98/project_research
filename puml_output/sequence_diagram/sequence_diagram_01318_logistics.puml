@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
actor "Warehouse Staff" as WS
boundary "Driver" as D
actor "Dispatcher" as D2
entity "Fleet Manager" as FM
FM ->> D : Track Shipment
WS --> D2 : Assign Route
D2 -> D : Report Issue
activate D
D --> D2 : ACK
deactivate D
D2 --> WS : Load Package
activate WS
WS --> D2 : ACK
deactivate WS
WS ->> FM : Fuel Vehicle
note over FM : processing fuel vehicle
@enduml