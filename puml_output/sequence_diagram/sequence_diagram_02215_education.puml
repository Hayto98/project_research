@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
participant "Librarian" as L
actor "Registrar" as R
actor "Student" as S
actor "Parent" as P
R ->> S : View Schedule
activate S
S --> R : ACK
deactivate S
S --> R : Register Student
L ->> S : Take Attendance
note over S : processing take attendance
P -> R : Submit Assignment
activate R
R --> P : ACK
deactivate R
@enduml