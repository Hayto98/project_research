@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
control "Auditor" as A
actor "Bank Teller" as BT
participant "Account Holder" as AH
A -> AH : Apply For Loan
activate AH
AH --> A : ACK
deactivate AH
A --> BT : Transfer Funds
BT -> A : View Statement
note over A : processing view statement
BT -> AH : Open Account
A --> AH : Pay Bill
activate AH
AH --> A : ACK
deactivate AH
@enduml