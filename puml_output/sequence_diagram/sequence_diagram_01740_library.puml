@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
entity "Librarian" as L
actor "Member" as M
entity "Admin" as A
L ->> A : Return Book
A ->> M : Pay Fine
L --> M : Borrow Book
L --> A : Renew Loan
note over A : processing renew loan
A --> L : Add New Book
L ->> M : Register Member
activate M
M --> L : ACK
deactivate M
@enduml