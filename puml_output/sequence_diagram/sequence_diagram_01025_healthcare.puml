@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
entity "Patient" as P
boundary "Doctor" as D
control "Lab Technician" as LT
entity "Nurse" as N
P -> D : Admit Patient
P -> N : Run Lab Test
N --> D : Book Appointment
LT ->> P : Update Medical Record
LT -> P : Examine Patient
@enduml