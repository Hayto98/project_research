@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
entity "Admin" as A
participant "User" as U
actor "Advertiser" as A2
A2 ->> U : Send Message
A ->> A2 : Follow User
activate A2
A2 --> A : ACK
deactivate A2
U -> A2 : Edit Profile
activate A2
A2 --> U : ACK
deactivate A2
note over A2 : processing edit profile
U ->> A2 : Create Post
activate A2
A2 --> U : ACK
deactivate A2
note over A2 : processing create post
@enduml