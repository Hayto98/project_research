@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
participant "Dispatcher" as D
participant "Customer" as C
participant "Fleet Manager" as FM
C ->> FM : Fuel Vehicle
activate FM
FM --> C : ACK
deactivate FM
D ->> FM : Deliver Package
D --> FM : Assign Route
activate FM
FM --> D : ACK
deactivate FM
C ->> FM : Schedule Pickup
@enduml