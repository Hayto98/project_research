@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
actor "Warehouse Staff" as WS
actor "Dispatcher" as D
boundary "Customer" as C
actor "Fleet Manager" as FM
D ->> WS : Assign Route
note over WS : processing assign route
D ->> FM : Schedule Pickup
activate FM
FM --> D : ACK
deactivate FM
C --> FM : Deliver Package
WS ->> C : Fuel Vehicle
activate C
C --> WS : ACK
deactivate C
note over C : processing fuel vehicle
FM ->> D : Track Shipment
activate D
D --> FM : ACK
deactivate D
WS ->> FM : Update Inventory
activate FM
FM --> WS : ACK
deactivate FM
D ->> FM : Report Issue
@enduml