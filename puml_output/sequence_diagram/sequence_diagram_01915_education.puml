@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
actor "Student" as S
entity "Parent" as P
actor "Registrar" as R
R --> S : Grade Exam
R -> S : Borrow Book
S -> R : Enroll Course
R -> P : View Schedule
note over P : processing view schedule
R ->> P : Take Attendance
S -> P : Register Student
R -> S : Submit Assignment
activate S
S --> R : ACK
deactivate S
note over S : processing submit assignment
@enduml