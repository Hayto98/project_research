@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
entity "Account Holder" as AH
control "Bank Teller" as BT
entity "ATM" as A
participant "Auditor" as A2
A -> BT : Apply For Loan
activate BT
BT --> A : ACK
deactivate BT
A2 -> A : Pay Bill
activate A
A --> A2 : ACK
deactivate A
A2 -> AH : Transfer Funds
A -> A2 : Deposit Money
@enduml