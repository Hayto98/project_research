@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
actor "Branch Manager" as BM
control "Auditor" as A
boundary "ATM" as A2
A2 ->> A : Open Account
BM --> A2 : Transfer Funds
note over A2 : processing transfer funds
BM -> A2 : Deposit Money
note over A2 : processing deposit money
A --> A2 : Block Card
note over A2 : processing block card
@enduml