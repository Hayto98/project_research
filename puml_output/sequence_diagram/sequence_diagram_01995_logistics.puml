@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
participant "Customer" as C
boundary "Warehouse Staff" as WS
control "Fleet Manager" as FM
participant "Driver" as D
boundary "Dispatcher" as D2
D --> D2 : Load Package
FM ->> WS : Schedule Pickup
D ->> D2 : Deliver Package
D ->> C : Report Issue
D ->> FM : Assign Route
D2 -> C : Track Shipment
@enduml