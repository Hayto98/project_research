@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
participant "Driver" as D
participant "Fleet Manager" as FM
actor "Warehouse Staff" as WS
WS ->> D : Load Package
activate D
D --> WS : ACK
deactivate D
WS -> FM : Schedule Pickup
note over FM : processing schedule pickup
FM ->> WS : Track Shipment
D ->> FM : Report Issue
activate FM
FM --> D : ACK
deactivate FM
WS -> FM : Fuel Vehicle
WS -> D : Deliver Package
activate D
D --> WS : ACK
deactivate D
FM -> WS : Assign Route
note over WS : processing assign route
@enduml