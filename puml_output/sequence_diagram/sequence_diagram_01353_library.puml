@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
control "Member" as M
control "Admin" as A
participant "Librarian" as L
M ->> A : Pay Fine
activate A
A --> M : ACK
deactivate A
L -> A : Reserve Book
activate A
A --> L : ACK
deactivate A
A ->> L : Borrow Book
L --> A : Add New Book
M -> A : Renew Loan
activate A
A --> M : ACK
deactivate A
@enduml