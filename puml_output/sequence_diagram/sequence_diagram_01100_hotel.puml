@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
boundary "Manager" as M
participant "Chef" as C
boundary "Guest" as G
M -> G : Check Out
G -> C : Request Service
note over C : processing request service
M -> C : Cancel Reservation
note over C : processing cancel reservation
G ->> M : Clean Room
@enduml