@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
entity "Librarian" as L
actor "Teacher" as T
boundary "Student" as S
L ->> T : View Schedule
T ->> L : Grade Exam
activate L
L --> T : ACK
deactivate L
T --> L : Take Attendance
note over L : processing take attendance
T --> L : Borrow Book
S -> T : Enroll Course
@enduml