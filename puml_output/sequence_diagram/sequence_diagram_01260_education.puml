@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
actor "Parent" as P
actor "Teacher" as T
actor "Admin" as A
A -> T : Take Attendance
T ->> A : Submit Assignment
note over A : processing submit assignment
A --> T : Issue Certificate
T ->> A : Grade Exam
T --> A : Borrow Book
A --> T : View Schedule
activate T
T --> A : ACK
deactivate T
note over T : processing view schedule
P ->> A : Register Student
activate A
A --> P : ACK
deactivate A
@enduml