@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
entity "Auditor" as A
control "ATM" as A2
boundary "Account Holder" as AH
actor "Bank Teller" as BT
A2 --> A : Apply For Loan
A -> AH : Open Account
BT --> A : Block Card
A -> A2 : Transfer Funds
activate A2
A2 --> A : ACK
deactivate A2
AH ->> A2 : View Statement
activate A2
A2 --> AH : ACK
deactivate A2
A ->> AH : Withdraw Cash
activate AH
AH --> A : ACK
deactivate AH
note over AH : processing withdraw cash
A2 -> AH : Deposit Money
activate AH
AH --> A2 : ACK
deactivate AH
@enduml