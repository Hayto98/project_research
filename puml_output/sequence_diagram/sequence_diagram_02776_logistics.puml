@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
entity "Driver" as D
boundary "Warehouse Staff" as WS
actor "Customer" as C
control "Dispatcher" as D2
control "Fleet Manager" as FM
WS -> D2 : Schedule Pickup
note over D2 : processing schedule pickup
D2 ->> C : Deliver Package
activate C
C --> D2 : ACK
deactivate C
C -> D : Update Inventory
C ->> D : Load Package
@enduml