@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
entity "Fleet Manager" as FM
participant "Driver" as D
actor "Dispatcher" as D2
actor "Customer" as C
participant "Warehouse Staff" as WS
WS ->> C : Track Shipment
D2 --> C : Load Package
activate C
C --> D2 : ACK
deactivate C
D2 --> WS : Deliver Package
FM -> D2 : Update Inventory
C --> D2 : Fuel Vehicle
note over D2 : processing fuel vehicle
@enduml