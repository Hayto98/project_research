@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
actor "Librarian" as L
control "Admin" as A
actor "Member" as M
A --> M : Borrow Book
A -> L : Add New Book
M ->> A : Pay Fine
activate A
A --> M : ACK
deactivate A
A -> M : Reserve Book
activate M
M --> A : ACK
deactivate M
note over M : processing reserve book
@enduml