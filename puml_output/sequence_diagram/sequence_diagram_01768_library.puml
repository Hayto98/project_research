@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
control "Member" as M
entity "Librarian" as L
actor "Admin" as A
L --> M : Renew Loan
L ->> A : Reserve Book
L ->> M : Register Member
A --> L : Return Book
L ->> M : Borrow Book
A ->> M : Pay Fine
@enduml