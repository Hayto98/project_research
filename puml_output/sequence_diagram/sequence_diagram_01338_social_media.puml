@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
participant "Admin" as A
control "Advertiser" as A2
entity "User" as U
participant "Moderator" as M
M ->> A : Comment
note over A : processing comment
M -> A2 : Edit Profile
A --> U : Create Post
note over U : processing create post
A2 -> M : Report Content
M --> U : Share Post
activate U
U --> M : ACK
deactivate U
note over U : processing share post
U ->> A : Send Message
activate A
A --> U : ACK
deactivate A
note over A : processing send message
A2 --> A : Follow User
note over A : processing follow user
@enduml