@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
actor "Housekeeper" as H
boundary "Chef" as C
boundary "Guest" as G
actor "Manager" as M
control "Receptionist" as R
C --> H : Cancel Reservation
R -> H : Check In
note over H : processing check in
C ->> G : Order Room Service
C --> R : Clean Room
R -> M : Request Service
G ->> R : Book Room
C --> H : Check Out
@enduml