@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
participant "Chef" as C
participant "Manager" as M
boundary "Guest" as G
actor "Receptionist" as R
M ->> G : Cancel Reservation
G ->> C : Check In
note over C : processing check in
C ->> R : Clean Room
note over R : processing clean room
M -> G : Process Payment
R --> C : Request Service
note over C : processing request service
@enduml