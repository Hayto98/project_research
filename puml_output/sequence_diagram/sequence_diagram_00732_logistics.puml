@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
entity "Fleet Manager" as FM
participant "Customer" as C
participant "Dispatcher" as D
boundary "Driver" as D2
D2 -> FM : Update Inventory
activate FM
FM --> D2 : ACK
deactivate FM
C -> D2 : Deliver Package
D --> FM : Fuel Vehicle
activate FM
FM --> D : ACK
deactivate FM
D -> FM : Assign Route
@enduml