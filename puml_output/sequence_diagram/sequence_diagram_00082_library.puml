@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
boundary "Librarian" as L
participant "Admin" as A
control "Member" as M
M -> L : Search Catalog
A ->> L : Renew Loan
activate L
L --> A : ACK
deactivate L
L -> M : Register Member
note over M : processing register member
L -> A : Return Book
activate A
A --> L : ACK
deactivate A
note over A : processing return book
L ->> A : Add New Book
L -> A : Pay Fine
@enduml