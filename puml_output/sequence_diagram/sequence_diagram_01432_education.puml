@startuml
skinparam defaultFontSize 13
entity "Registrar" as R
entity "Admin" as A
participant "Parent" as P
participant "Librarian" as L
participant "Student" as S
L ->> P : Grade Exam
activate P
P --> L : ACK
deactivate P
note over P : processing grade exam
P --> R : Register Student
S --> P : Submit Assignment
A -> R : Borrow Book
R --> A : View Schedule
note over A : processing view schedule
P --> R : Issue Certificate
@enduml