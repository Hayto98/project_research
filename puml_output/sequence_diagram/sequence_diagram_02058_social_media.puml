@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
actor "Admin" as A
control "Moderator" as M
participant "Advertiser" as A2
A ->> M : Share Post
activate M
M --> A : ACK
deactivate M
M ->> A2 : Like Post
activate A2
A2 --> M : ACK
deactivate A2
note over A2 : processing like post
A2 -> A : Report Content
A2 -> M : Send Message
@enduml