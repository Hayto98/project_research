@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
entity "Advertiser" as A
actor "Moderator" as M
participant "Admin" as A2
control "User" as U
U ->> A2 : Comment
U -> M : Create Post
A ->> U : Report Content
note over U : processing report content
U --> A : Send Message
@enduml