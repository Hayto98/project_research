@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
actor "Librarian" as L
actor "Registrar" as R
control "Teacher" as T
R ->> L : Grade Exam
activate L
L --> R : ACK
deactivate L
T ->> R : Register Student
R ->> T : Enroll Course
L --> R : Submit Assignment
activate R
R --> L : ACK
deactivate R
L --> T : Borrow Book
T --> R : Take Attendance
activate R
R --> T : ACK
deactivate R
@enduml