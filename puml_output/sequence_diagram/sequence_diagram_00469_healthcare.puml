@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
participant "Nurse" as N
entity "Insurance Provider" as IP
control "Doctor" as D
D ->> N : Update Medical Record
N --> IP : Discharge Patient
note over IP : processing discharge patient
D ->> IP : Examine Patient
activate IP
IP --> D : ACK
deactivate IP
IP -> D : Process Insurance Claim
note over D : processing process insurance claim
D -> IP : Run Lab Test
activate IP
IP --> D : ACK
deactivate IP
note over IP : processing run lab test
D --> IP : Admit Patient
@enduml