@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
control "Admin" as A
entity "Registrar" as R
participant "Student" as S
actor "Librarian" as L
participant "Parent" as P
S -> L : Register Student
P -> A : Grade Exam
S --> P : Enroll Course
R ->> S : Issue Certificate
note over S : processing issue certificate
@enduml