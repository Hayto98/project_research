@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
actor "Teacher" as T
boundary "Student" as S
actor "Admin" as A
S ->> T : Register Student
T --> A : Issue Certificate
activate A
A --> T : ACK
deactivate A
note over A : processing issue certificate
A ->> T : Take Attendance
note over T : processing take attendance
A ->> T : Grade Exam
@enduml