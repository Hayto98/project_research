@startuml
skinparam defaultFontSize 11
actor "Branch Manager" as BM
control "Auditor" as A
participant "Bank Teller" as BT
A --> BM : Transfer Funds
activate BM
BM --> A : ACK
deactivate BM
A --> BM : Apply For Loan
note over BM : processing apply for loan
A -> BM : Withdraw Cash
BM -> BT : Pay Bill
activate BT
BT --> BM : ACK
deactivate BT
note over BT : processing pay bill
@enduml