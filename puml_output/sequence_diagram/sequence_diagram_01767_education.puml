@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
actor "Parent" as P
entity "Student" as S
participant "Librarian" as L
actor "Admin" as A
actor "Registrar" as R
P -> R : Issue Certificate
L ->> P : Enroll Course
R --> A : Take Attendance
R -> P : View Schedule
note over P : processing view schedule
L ->> S : Borrow Book
@enduml