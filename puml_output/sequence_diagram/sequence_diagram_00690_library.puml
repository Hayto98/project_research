@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
participant "Admin" as A
control "Member" as M
participant "Librarian" as L
L --> M : Register Member
L ->> M : Renew Loan
activate M
M --> L : ACK
deactivate M
L ->> M : Add New Book
M --> A : Return Book
A --> M : Pay Fine
@enduml