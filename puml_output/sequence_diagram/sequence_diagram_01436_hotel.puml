@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
boundary "Housekeeper" as H
boundary "Guest" as G
entity "Receptionist" as R
R -> G : Clean Room
R -> G : Request Service
R ->> H : Check Out
H -> G : Book Room
R -> G : Process Payment
H --> G : Cancel Reservation
note over G : processing cancel reservation
@enduml