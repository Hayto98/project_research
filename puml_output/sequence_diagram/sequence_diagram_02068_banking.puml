@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
actor "Auditor" as A
participant "Account Holder" as AH
entity "ATM" as A2
A ->> A2 : Open Account
AH --> A2 : Block Card
activate A2
A2 --> AH : ACK
deactivate A2
A ->> AH : Deposit Money
note over AH : processing deposit money
A ->> AH : Apply For Loan
note over AH : processing apply for loan
@enduml