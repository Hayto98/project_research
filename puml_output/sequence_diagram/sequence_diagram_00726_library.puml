@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
participant "Member" as M
entity "Admin" as A
participant "Librarian" as L
A ->> M : Register Member
A ->> M : Pay Fine
L --> M : Reserve Book
note over M : processing reserve book
L --> M : Renew Loan
note over M : processing renew loan
@enduml