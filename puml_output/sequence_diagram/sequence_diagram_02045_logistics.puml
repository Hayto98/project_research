@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
entity "Driver" as D
entity "Customer" as C
entity "Fleet Manager" as FM
C --> D : Assign Route
activate D
D --> C : ACK
deactivate D
D ->> FM : Load Package
activate FM
FM --> D : ACK
deactivate FM
C --> D : Track Shipment
activate D
D --> C : ACK
deactivate D
C -> D : Fuel Vehicle
D ->> FM : Report Issue
D ->> C : Schedule Pickup
activate C
C --> D : ACK
deactivate C
note over C : processing schedule pickup
FM -> C : Update Inventory
activate C
C --> FM : ACK
deactivate C
@enduml