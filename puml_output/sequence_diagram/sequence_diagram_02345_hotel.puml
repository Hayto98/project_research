@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
boundary "Housekeeper" as H
control "Guest" as G
entity "Manager" as M
actor "Receptionist" as R
entity "Chef" as C
H ->> C : Cancel Reservation
C --> H : Check In
M ->> G : Process Payment
C --> R : Book Room
@enduml