@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
participant "Warehouse Staff" as WS
control "Dispatcher" as D
participant "Fleet Manager" as FM
WS ->> FM : Deliver Package
D ->> WS : Track Shipment
FM --> WS : Update Inventory
D -> FM : Assign Route
activate FM
FM --> D : ACK
deactivate FM
WS -> D : Load Package
activate D
D --> WS : ACK
deactivate D
note over D : processing load package
WS ->> D : Fuel Vehicle
note over D : processing fuel vehicle
D --> WS : Report Issue
@enduml