@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
control "Receptionist" as R
participant "Doctor" as D
actor "Nurse" as N
R -> N : Issue Prescription
activate N
N --> R : ACK
deactivate N
N -> R : Process Insurance Claim
R ->> D : Update Medical Record
activate D
D --> R : ACK
deactivate D
N --> R : Admit Patient
activate R
R --> N : ACK
deactivate R
@enduml