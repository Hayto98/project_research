@startuml
skinparam monochrome true
actor "Member" as M
actor "Librarian" as L
control "Admin" as A
M -> L : Borrow Book
activate L
L --> M : ACK
deactivate L
M ->> L : Pay Fine
L --> M : Renew Loan
L ->> A : Add New Book
activate A
A --> L : ACK
deactivate A
L -> M : Register Member
activate M
M --> L : ACK
deactivate M
L --> M : Reserve Book
activate M
M --> L : ACK
deactivate M
@enduml