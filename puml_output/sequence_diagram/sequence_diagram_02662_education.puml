@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
boundary "Student" as S
control "Librarian" as L
boundary "Registrar" as R
participant "Admin" as A
control "Parent" as P
A ->> P : Borrow Book
A -> R : Grade Exam
S --> R : Register Student
A -> R : Enroll Course
R -> A : Take Attendance
note over A : processing take attendance
L ->> P : Submit Assignment
note over P : processing submit assignment
@enduml