@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
control "User" as U
participant "Admin" as A
control "Moderator" as M
U --> M : Comment
U -> A : Follow User
activate A
A --> U : ACK
deactivate A
M --> A : Like Post
U --> A : Share Post
@enduml