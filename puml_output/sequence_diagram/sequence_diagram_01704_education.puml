@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
participant "Registrar" as R
boundary "Librarian" as L
participant "Admin" as A
entity "Student" as S
R --> S : Submit Assignment
activate S
S --> R : ACK
deactivate S
R ->> S : Enroll Course
activate S
S --> R : ACK
deactivate S
L -> S : Register Student
R --> S : Borrow Book
activate S
S --> R : ACK
deactivate S
A -> R : View Schedule
@enduml