@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
actor "Delivery Service" as DS
participant "Payment Gateway" as PG
boundary "Admin" as A
boundary "Customer" as C
PG -> C : Cancel Order
note over C : processing cancel order
A --> DS : Make Payment
C --> PG : Add To Cart
DS -> A : Write Review
PG ->> A : Browse Products
C ->> DS : Checkout
@enduml