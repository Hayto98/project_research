@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
entity "ATM" as A
control "Account Holder" as AH
actor "Bank Teller" as BT
entity "Auditor" as A2
actor "Branch Manager" as BM
BT -> A2 : Apply For Loan
activate A2
A2 --> BT : ACK
deactivate A2
A --> BM : Transfer Funds
activate BM
BM --> A : ACK
deactivate BM
BT ->> A : Open Account
activate A
A --> BT : ACK
deactivate A
A2 ->> BT : Pay Bill
activate BT
BT --> A2 : ACK
deactivate BT
A ->> BM : View Statement
AH ->> A2 : Withdraw Cash
A --> AH : Deposit Money
activate AH
AH --> A : ACK
deactivate AH
@enduml