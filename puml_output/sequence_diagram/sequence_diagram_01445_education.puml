@startuml
skinparam monochrome true
boundary "Student" as S
entity "Teacher" as T
boundary "Admin" as A
boundary "Registrar" as R
participant "Librarian" as L
T ->> S : View Schedule
activate S
S --> T : ACK
deactivate S
T --> L : Issue Certificate
A -> R : Take Attendance
note over R : processing take attendance
R --> T : Register Student
note over T : processing register student
@enduml