@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
participant "Nurse" as N
actor "Insurance Provider" as IP
participant "Doctor" as D
IP --> D : Run Lab Test
D -> N : Issue Prescription
N ->> D : Admit Patient
note over D : processing admit patient
D -> IP : Discharge Patient
activate IP
IP --> D : ACK
deactivate IP
@enduml