@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
actor "Guest" as G
participant "Manager" as M
boundary "Housekeeper" as H
control "Chef" as C
control "Receptionist" as R
C --> M : Clean Room
G --> R : Cancel Reservation
G --> C : Order Room Service
activate C
C --> G : ACK
deactivate C
C -> G : Process Payment
activate G
G --> C : ACK
deactivate G
@enduml