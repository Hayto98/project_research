@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
actor "Registrar" as R
entity "Librarian" as L
actor "Parent" as P
actor "Student" as S
R --> P : Enroll Course
R --> L : Issue Certificate
S -> P : Register Student
activate P
P --> S : ACK
deactivate P
L -> P : View Schedule
activate P
P --> L : ACK
deactivate P
note over P : processing view schedule
@enduml