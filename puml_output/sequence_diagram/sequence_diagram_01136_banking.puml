@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
control "Auditor" as A
participant "Branch Manager" as BM
control "Account Holder" as AH
boundary "Bank Teller" as BT
actor "ATM" as A2
A2 -> AH : Transfer Funds
BT --> A2 : Block Card
BT --> BM : Open Account
BM -> A2 : Apply For Loan
activate A2
A2 --> BM : ACK
deactivate A2
@enduml