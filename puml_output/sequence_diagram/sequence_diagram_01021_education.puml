@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
boundary "Librarian" as L
entity "Parent" as P
boundary "Teacher" as T
T ->> L : View Schedule
T --> L : Borrow Book
P --> L : Submit Assignment
activate L
L --> P : ACK
deactivate L
T ->> L : Enroll Course
note over L : processing enroll course
@enduml