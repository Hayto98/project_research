@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
actor "Fleet Manager" as FM
participant "Driver" as D
entity "Customer" as C
control "Warehouse Staff" as WS
C ->> D : Update Inventory
note over D : processing update inventory
D ->> WS : Schedule Pickup
C -> D : Deliver Package
C -> D : Load Package
D -> FM : Fuel Vehicle
activate FM
FM --> D : ACK
deactivate FM
@enduml