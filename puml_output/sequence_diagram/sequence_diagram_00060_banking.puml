@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
entity "Auditor" as A
actor "Bank Teller" as BT
boundary "ATM" as A2
A --> A2 : Open Account
A2 ->> A : Apply For Loan
BT ->> A : Block Card
activate A
A --> BT : ACK
deactivate A
BT --> A : Deposit Money
activate A
A --> BT : ACK
deactivate A
A ->> BT : Transfer Funds
@enduml