@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
participant "Admin" as A
actor "Registrar" as R
boundary "Student" as S
participant "Parent" as P
A --> P : Take Attendance
activate P
P --> A : ACK
deactivate P
note over P : processing take attendance
A --> S : Submit Assignment
note over S : processing submit assignment
R ->> A : Borrow Book
note over A : processing borrow book
A -> S : Enroll Course
@enduml