@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
participant "Chef" as C
entity "Housekeeper" as H
control "Manager" as M
C ->> M : Process Payment
H --> C : Cancel Reservation
activate C
C --> H : ACK
deactivate C
M ->> C : Clean Room
M -> C : Book Room
activate C
C --> M : ACK
deactivate C
M --> H : Check Out
@enduml