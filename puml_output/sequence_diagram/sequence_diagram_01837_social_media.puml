@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
entity "User" as U
participant "Admin" as A
boundary "Advertiser" as A2
actor "Moderator" as M
U ->> M : Comment
activate M
M --> U : ACK
deactivate M
M -> A2 : Edit Profile
A -> U : Follow User
note over U : processing follow user
M -> A2 : Share Post
U -> A2 : Create Post
activate A2
A2 --> U : ACK
deactivate A2
@enduml