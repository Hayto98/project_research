@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
control "Guest" as G
entity "Manager" as M
actor "Receptionist" as R
entity "Chef" as C
M ->> R : Book Room
R ->> C : Process Payment
R --> C : Check Out
note over C : processing check out
M --> R : Check In
activate R
R --> M : ACK
deactivate R
R --> G : Request Service
@enduml