@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
entity "Librarian" as L
actor "Student" as S
actor "Parent" as P
P -> L : Borrow Book
L -> P : View Schedule
note over P : processing view schedule
S -> L : Issue Certificate
P -> L : Enroll Course
note over L : processing enroll course
P ->> L : Register Student
activate L
L --> P : ACK
deactivate L
@enduml