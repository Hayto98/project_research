@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
control "Delivery Service" as DS
actor "Payment Gateway" as PG
actor "Seller" as S
actor "Admin" as A
S --> PG : Apply Coupon
PG --> DS : Track Order
note over DS : processing track order
PG ->> A : Add To Cart
PG ->> S : Manage Inventory
@enduml