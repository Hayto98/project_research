@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
control "Doctor" as D
boundary "Nurse" as N
entity "Receptionist" as R
actor "Insurance Provider" as IP
D -> IP : Process Insurance Claim
N -> R : Book Appointment
R --> IP : Run Lab Test
N -> IP : Discharge Patient
D -> N : Examine Patient
@enduml