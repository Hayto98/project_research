@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
control "ATM" as A
control "Branch Manager" as BM
participant "Account Holder" as AH
entity "Bank Teller" as BT
entity "Auditor" as A2
A2 --> BM : Apply For Loan
activate BM
BM --> A2 : ACK
deactivate BM
AH ->> A2 : Transfer Funds
activate A2
A2 --> AH : ACK
deactivate A2
A2 ->> AH : Deposit Money
BM -> BT : View Statement
@enduml