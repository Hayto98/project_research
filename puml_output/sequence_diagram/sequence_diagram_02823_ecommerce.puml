@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
entity "Customer" as C
entity "Seller" as S
actor "Payment Gateway" as PG
actor "Delivery Service" as DS
control "Admin" as A
DS --> C : Manage Inventory
S --> DS : Browse Products
note over DS : processing browse products
A -> S : Cancel Order
S ->> PG : Make Payment
activate PG
PG --> S : ACK
deactivate PG
C --> PG : Add To Cart
activate PG
PG --> C : ACK
deactivate PG
note over PG : processing add to cart
@enduml