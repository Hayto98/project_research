@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
entity "Librarian" as L
control "Member" as M
actor "Admin" as A
L --> A : Pay Fine
M -> A : Search Catalog
activate A
A --> M : ACK
deactivate A
L ->> A : Reserve Book
A ->> M : Return Book
M -> L : Borrow Book
note over L : processing borrow book
@enduml