@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
actor "User" as U
entity "Advertiser" as A
control "Admin" as A2
A2 ->> U : Edit Profile
A --> U : Comment
note over U : processing comment
A2 -> U : Like Post
activate U
U --> A2 : ACK
deactivate U
note over U : processing like post
A2 --> U : Create Post
U ->> A : Share Post
activate A
A --> U : ACK
deactivate A
A2 --> A : Send Message
activate A
A --> A2 : ACK
deactivate A
A2 --> U : Report Content
@enduml