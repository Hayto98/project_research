@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
entity "Admin" as A
control "Student" as S
entity "Teacher" as T
A --> T : Grade Exam
note over T : processing grade exam
S -> T : Issue Certificate
T -> S : Take Attendance
note over S : processing take attendance
A --> S : View Schedule
T --> S : Borrow Book
@enduml