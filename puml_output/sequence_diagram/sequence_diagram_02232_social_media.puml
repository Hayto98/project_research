@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
boundary "User" as U
actor "Advertiser" as A
control "Admin" as A2
control "Moderator" as M
U -> M : Create Post
activate M
M --> U : ACK
deactivate M
U --> M : Send Message
activate M
M --> U : ACK
deactivate M
U --> M : Like Post
A --> A2 : Report Content
note over A2 : processing report content
@enduml