@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
participant "Teacher" as T
entity "Registrar" as R
control "Parent" as P
P --> T : Borrow Book
P -> R : View Schedule
activate R
R --> P : ACK
deactivate R
P -> R : Issue Certificate
activate R
R --> P : ACK
deactivate R
R --> T : Register Student
P -> T : Take Attendance
@enduml