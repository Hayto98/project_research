@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
control "Teacher" as T
actor "Student" as S
control "Parent" as P
S -> P : Borrow Book
P ->> T : Take Attendance
activate T
T --> P : ACK
deactivate T
T -> P : Grade Exam
activate P
P --> T : ACK
deactivate P
T --> P : Submit Assignment
note over P : processing submit assignment
P --> T : Enroll Course
P ->> T : Register Student
activate T
T --> P : ACK
deactivate T
note over T : processing register student
P --> T : View Schedule
activate T
T --> P : ACK
deactivate T
@enduml