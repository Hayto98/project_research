@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
control "Member" as M
control "Librarian" as L
control "Admin" as A
L --> M : Renew Loan
activate M
M --> L : ACK
deactivate M
A -> L : Reserve Book
M ->> A : Pay Fine
activate A
A --> M : ACK
deactivate A
A --> L : Register Member
note over L : processing register member
L -> A : Search Catalog
activate A
A --> L : ACK
deactivate A
@enduml