@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
participant "Doctor" as D
entity "Patient" as P
entity "Receptionist" as R
participant "Lab Technician" as LT
participant "Insurance Provider" as IP
R --> LT : Run Lab Test
R ->> LT : Process Insurance Claim
P -> R : Issue Prescription
activate R
R --> P : ACK
deactivate R
LT ->> D : Discharge Patient
note over D : processing discharge patient
@enduml