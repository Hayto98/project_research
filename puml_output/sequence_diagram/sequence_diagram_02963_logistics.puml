@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
actor "Driver" as D
participant "Warehouse Staff" as WS
participant "Customer" as C
boundary "Dispatcher" as D2
boundary "Fleet Manager" as FM
D ->> FM : Load Package
FM --> D : Assign Route
C ->> FM : Update Inventory
FM -> C : Deliver Package
@enduml