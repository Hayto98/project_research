@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
control "Student" as S
actor "Parent" as P
entity "Librarian" as L
control "Registrar" as R
S --> R : Issue Certificate
activate R
R --> S : ACK
deactivate R
R ->> S : Register Student
note over S : processing register student
L -> S : Take Attendance
note over S : processing take attendance
L --> S : Enroll Course
activate S
S --> L : ACK
deactivate S
P --> L : Borrow Book
activate L
L --> P : ACK
deactivate L
@enduml