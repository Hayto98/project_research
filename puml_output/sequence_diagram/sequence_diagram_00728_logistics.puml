@startuml
skinparam monochrome true
boundary "Driver" as D
control "Fleet Manager" as FM
participant "Warehouse Staff" as WS
WS ->> FM : Update Inventory
D -> FM : Assign Route
note over FM : processing assign route
D --> WS : Load Package
D --> FM : Fuel Vehicle
D --> FM : Deliver Package
activate FM
FM --> D : ACK
deactivate FM
FM ->> D : Report Issue
activate D
D --> FM : ACK
deactivate D
note over D : processing report issue
@enduml