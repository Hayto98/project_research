@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
control "Admin" as A
actor "Advertiser" as A2
control "Moderator" as M
control "User" as U
U -> A2 : Send Message
note over A2 : processing send message
A2 -> A : Report Content
activate A
A --> A2 : ACK
deactivate A
A2 -> U : Share Post
activate U
U --> A2 : ACK
deactivate U
A2 --> A : Like Post
activate A
A --> A2 : ACK
deactivate A
note over A : processing like post
A ->> U : Follow User
U -> A2 : Edit Profile
@enduml