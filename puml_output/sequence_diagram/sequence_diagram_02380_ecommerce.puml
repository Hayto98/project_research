@startuml
skinparam monochrome true
skinparam defaultFontSize 13
boundary "Customer" as C
boundary "Seller" as S
actor "Delivery Service" as DS
participant "Payment Gateway" as PG
PG --> C : Browse Products
DS --> PG : Track Order
DS --> S : Write Review
PG ->> C : Cancel Order
activate C
C --> PG : ACK
deactivate C
DS --> PG : Apply Coupon
DS --> PG : Add To Cart
S -> C : Manage Inventory
activate C
C --> S : ACK
deactivate C
@enduml