@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
participant "User" as U
boundary "Advertiser" as A
participant "Moderator" as M
U ->> A : Edit Profile
A --> M : Like Post
M ->> A : Share Post
activate A
A --> M : ACK
deactivate A
note over A : processing share post
A ->> U : Send Message
note over U : processing send message
@enduml