@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
participant "Advertiser" as A
participant "User" as U
entity "Moderator" as M
A --> U : Report Content
U --> A : Comment
A -> M : Edit Profile
M ->> U : Send Message
activate U
U --> M : ACK
deactivate U
M -> A : Create Post
U ->> A : Like Post
note over A : processing like post
@enduml