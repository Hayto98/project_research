@startuml
skinparam monochrome true
skinparam shadowing true
actor "Guest" as G
participant "Manager" as M
boundary "Receptionist" as R
control "Housekeeper" as H
boundary "Chef" as C
G ->> M : Order Room Service
activate M
M --> G : ACK
deactivate M
note over M : processing order room service
M --> R : Check In
activate R
R --> M : ACK
deactivate R
note over R : processing check in
C ->> M : Clean Room
M ->> H : Cancel Reservation
C --> M : Check Out
G --> M : Process Payment
activate M
M --> G : ACK
deactivate M
@enduml