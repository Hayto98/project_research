@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
control "Advertiser" as A
entity "Moderator" as M
actor "User" as U
participant "Admin" as A2
U --> M : Send Message
A -> A2 : Follow User
A2 -> A : Share Post
U -> A : Comment
note over A : processing comment
M ->> U : Like Post
@enduml