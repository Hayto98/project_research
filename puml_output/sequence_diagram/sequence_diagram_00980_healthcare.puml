@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
boundary "Insurance Provider" as IP
boundary "Doctor" as D
actor "Receptionist" as R
actor "Lab Technician" as LT
participant "Nurse" as N
IP --> LT : Process Insurance Claim
LT ->> IP : Admit Patient
activate IP
IP --> LT : ACK
deactivate IP
N --> R : Update Medical Record
R ->> D : Book Appointment
activate D
D --> R : ACK
deactivate D
note over D : processing book appointment
LT -> R : Examine Patient
note over R : processing examine patient
@enduml