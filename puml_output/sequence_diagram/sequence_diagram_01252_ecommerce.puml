@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
control "Seller" as S
control "Admin" as A
control "Delivery Service" as DS
boundary "Customer" as C
control "Payment Gateway" as PG
A ->> DS : Manage Inventory
note over DS : processing manage inventory
A -> PG : Make Payment
PG ->> A : Cancel Order
activate A
A --> PG : ACK
deactivate A
C ->> A : Apply Coupon
activate A
A --> C : ACK
deactivate A
PG ->> C : Add To Cart
note over C : processing add to cart
@enduml