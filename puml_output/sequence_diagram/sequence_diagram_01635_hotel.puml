@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
participant "Receptionist" as R
control "Housekeeper" as H
participant "Chef" as C
C -> H : Cancel Reservation
C --> H : Process Payment
C -> H : Clean Room
R --> C : Order Room Service
C --> H : Book Room
activate H
H --> C : ACK
deactivate H
C -> H : Request Service
note over H : processing request service
@enduml