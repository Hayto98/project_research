@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
actor "Moderator" as M
control "Advertiser" as A
participant "User" as U
control "Admin" as A2
U --> A2 : Follow User
U ->> A2 : Send Message
M -> A : Report Content
A2 -> M : Like Post
U -> M : Comment
activate M
M --> U : ACK
deactivate M
M ->> U : Edit Profile
A2 --> A : Create Post
note over A : processing create post
@enduml