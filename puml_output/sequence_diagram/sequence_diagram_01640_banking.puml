@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
control "ATM" as A
boundary "Bank Teller" as BT
participant "Auditor" as A2
A ->> BT : Withdraw Cash
activate BT
BT --> A : ACK
deactivate BT
note over BT : processing withdraw cash
A2 -> BT : View Statement
A --> BT : Block Card
A2 ->> A : Deposit Money
A2 ->> BT : Pay Bill
@enduml