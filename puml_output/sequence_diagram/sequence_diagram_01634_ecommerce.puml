@startuml
skinparam monochrome true
skinparam shadowing true
control "Payment Gateway" as PG
participant "Seller" as S
participant "Admin" as A
entity "Customer" as C
PG ->> C : Track Order
activate C
C --> PG : ACK
deactivate C
A ->> S : Cancel Order
S --> C : Checkout
activate C
C --> S : ACK
deactivate C
A ->> PG : Write Review
PG --> S : Apply Coupon
@enduml