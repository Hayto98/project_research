@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
entity "Lab Technician" as LT
control "Patient" as P
participant "Insurance Provider" as IP
actor "Receptionist" as R
boundary "Doctor" as D
P ->> IP : Update Medical Record
D ->> R : Run Lab Test
activate R
R --> D : ACK
deactivate R
IP --> P : Process Insurance Claim
activate P
P --> IP : ACK
deactivate P
D --> R : Issue Prescription
P -> R : Admit Patient
note over R : processing admit patient
LT -> R : Discharge Patient
IP ->> D : Book Appointment
@enduml