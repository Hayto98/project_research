@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
boundary "Teacher" as T
participant "Librarian" as L
control "Student" as S
participant "Admin" as A
L ->> S : Register Student
activate S
S --> L : ACK
deactivate S
S ->> L : Submit Assignment
activate L
L --> S : ACK
deactivate L
L -> S : Issue Certificate
A ->> L : Grade Exam
activate L
L --> A : ACK
deactivate L
T ->> A : View Schedule
note over A : processing view schedule
L --> T : Borrow Book
@enduml