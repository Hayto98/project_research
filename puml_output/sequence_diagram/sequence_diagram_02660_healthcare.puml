@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
entity "Patient" as P
actor "Lab Technician" as LT
actor "Insurance Provider" as IP
LT -> IP : Examine Patient
activate IP
IP --> LT : ACK
deactivate IP
P --> LT : Discharge Patient
activate LT
LT --> P : ACK
deactivate LT
LT ->> IP : Admit Patient
IP -> LT : Book Appointment
activate LT
LT --> IP : ACK
deactivate LT
note over LT : processing book appointment
LT ->> P : Issue Prescription
activate P
P --> LT : ACK
deactivate P
IP -> P : Run Lab Test
activate P
P --> IP : ACK
deactivate P
IP -> P : Update Medical Record
note over P : processing update medical record
@enduml