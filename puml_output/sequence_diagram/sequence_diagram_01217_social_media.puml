@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
actor "Admin" as A
actor "Moderator" as M
actor "Advertiser" as A2
boundary "User" as U
A ->> M : Like Post
note over M : processing like post
A ->> U : Follow User
activate U
U --> A : ACK
deactivate U
U -> A : Comment
M ->> A2 : Create Post
@enduml