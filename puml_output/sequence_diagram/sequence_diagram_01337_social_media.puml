@startuml

entity "Advertiser" as A
actor "User" as U
actor "Moderator" as M
boundary "Admin" as A2
A2 ->> U : Like Post
M -> A2 : Share Post
activate A2
A2 --> M : ACK
deactivate A2
A2 --> A : Edit Profile
activate A
A --> A2 : ACK
deactivate A
U ->> M : Report Content
activate M
M --> U : ACK
deactivate M
A --> U : Follow User
@enduml