@startuml
skinparam ArrowColor #555555
participant "Advertiser" as A
participant "User" as U
participant "Moderator" as M
M ->> U : Share Post
A --> U : Comment
note over U : processing comment
A ->> U : Edit Profile
activate U
U --> A : ACK
deactivate U
note over U : processing edit profile
A -> M : Report Content
note over M : processing report content
U ->> M : Create Post
activate M
M --> U : ACK
deactivate M
note over M : processing create post
M ->> A : Follow User
activate A
A --> M : ACK
deactivate A
note over A : processing follow user
@enduml