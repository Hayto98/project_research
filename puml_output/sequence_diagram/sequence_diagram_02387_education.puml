@startuml
skinparam monochrome true
skinparam shadowing true
actor "Librarian" as L
boundary "Student" as S
boundary "Admin" as A
participant "Parent" as P
S --> A : Borrow Book
note over A : processing borrow book
P ->> A : Submit Assignment
L --> P : Register Student
L --> A : View Schedule
note over A : processing view schedule
A ->> P : Take Attendance
note over P : processing take attendance
A -> S : Grade Exam
A --> L : Enroll Course
@enduml