@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
actor "Admin" as A
boundary "Librarian" as L
boundary "Member" as M
L -> M : Borrow Book
L -> M : Pay Fine
activate M
M --> L : ACK
deactivate M
M ->> A : Add New Book
M -> A : Register Member
activate A
A --> M : ACK
deactivate A
note over A : processing register member
@enduml