@startuml
skinparam monochrome true
skinparam shadowing true
participant "Fleet Manager" as FM
participant "Driver" as D
boundary "Warehouse Staff" as WS
boundary "Customer" as C
boundary "Dispatcher" as D2
C ->> D2 : Deliver Package
WS ->> D2 : Report Issue
WS --> D : Load Package
D ->> C : Schedule Pickup
activate C
C --> D : ACK
deactivate C
@enduml