@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
control "Moderator" as M
boundary "Admin" as A
entity "User" as U
boundary "Advertiser" as A2
U ->> M : Report Content
activate M
M --> U : ACK
deactivate M
A2 ->> M : Create Post
A2 --> M : Follow User
U --> M : Like Post
A --> M : Share Post
A ->> M : Edit Profile
A2 --> U : Send Message
@enduml