@startuml
skinparam monochrome true
skinparam ArrowColor #555555
boundary "ATM" as A
entity "Branch Manager" as BM
control "Account Holder" as AH
actor "Bank Teller" as BT
actor "Auditor" as A2
BM --> A2 : Deposit Money
BM ->> BT : Block Card
activate BT
BT --> BM : ACK
deactivate BT
AH --> A : Open Account
AH ->> BM : Transfer Funds
activate BM
BM --> AH : ACK
deactivate BM
note over BM : processing transfer funds
AH ->> A : Pay Bill
activate A
A --> AH : ACK
deactivate A
BM ->> BT : View Statement
A2 --> A : Withdraw Cash
@enduml