@startuml
skinparam monochrome true
skinparam defaultFontSize 13
control "Chef" as C
boundary "Receptionist" as R
entity "Manager" as M
C -> M : Check In
R -> C : Clean Room
activate C
C --> R : ACK
deactivate C
M --> C : Request Service
R -> C : Check Out
activate C
C --> R : ACK
deactivate C
R -> C : Book Room
M ->> C : Process Payment
@enduml