@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
control "Teacher" as T
entity "Parent" as P
boundary "Student" as S
participant "Librarian" as L
participant "Registrar" as R
T -> R : Take Attendance
activate R
R --> T : ACK
deactivate R
T ->> L : Issue Certificate
activate L
L --> T : ACK
deactivate L
R -> T : Grade Exam
activate T
T --> R : ACK
deactivate T
T ->> R : Borrow Book
@enduml