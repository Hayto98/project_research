@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
participant "Warehouse Staff" as WS
participant "Fleet Manager" as FM
boundary "Driver" as D
D ->> WS : Report Issue
activate WS
WS --> D : ACK
deactivate WS
D -> WS : Assign Route
activate WS
WS --> D : ACK
deactivate WS
WS --> FM : Update Inventory
activate FM
FM --> WS : ACK
deactivate FM
FM --> WS : Schedule Pickup
FM ->> WS : Load Package
@enduml