@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
control "Admin" as A
participant "Librarian" as L
participant "Registrar" as R
A -> L : Enroll Course
L ->> R : Borrow Book
L ->> R : Issue Certificate
note over R : processing issue certificate
L --> R : View Schedule
activate R
R --> L : ACK
deactivate R
A ->> R : Grade Exam
@enduml