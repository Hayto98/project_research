@startuml
skinparam monochrome true
skinparam defaultFontSize 11
control "Librarian" as L
participant "Member" as M
entity "Admin" as A
L -> A : Borrow Book
note over A : processing borrow book
M -> L : Renew Loan
note over L : processing renew loan
L -> A : Register Member
A ->> L : Add New Book
L --> M : Return Book
activate M
M --> L : ACK
deactivate M
A ->> M : Reserve Book
@enduml