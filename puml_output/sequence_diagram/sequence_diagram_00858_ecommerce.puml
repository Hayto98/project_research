@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
entity "Delivery Service" as DS
actor "Payment Gateway" as PG
actor "Admin" as A
DS --> PG : Manage Inventory
note over PG : processing manage inventory
A --> PG : Browse Products
PG --> A : Write Review
note over A : processing write review
PG --> A : Add To Cart
activate A
A --> PG : ACK
deactivate A
@enduml