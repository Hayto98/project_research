@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
boundary "Parent" as P
participant "Registrar" as R
participant "Teacher" as T
control "Student" as S
actor "Librarian" as L
T -> L : Submit Assignment
activate L
L --> T : ACK
deactivate L
L -> P : View Schedule
activate P
P --> L : ACK
deactivate P
R -> T : Borrow Book
note over T : processing borrow book
S --> L : Issue Certificate
R -> T : Grade Exam
activate T
T --> R : ACK
deactivate T
L ->> R : Register Student
activate R
R --> L : ACK
deactivate R
R -> L : Enroll Course
@enduml