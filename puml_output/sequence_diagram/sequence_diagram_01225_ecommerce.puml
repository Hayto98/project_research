@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
entity "Customer" as C
control "Seller" as S
participant "Delivery Service" as DS
actor "Payment Gateway" as PG
S --> DS : Browse Products
note over DS : processing browse products
DS --> S : Cancel Order
activate S
S --> DS : ACK
deactivate S
DS -> S : Write Review
C --> DS : Add To Cart
@enduml