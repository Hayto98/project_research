@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
entity "Teacher" as T
control "Registrar" as R
control "Admin" as A
actor "Parent" as P
T ->> A : Take Attendance
activate A
A --> T : ACK
deactivate A
T -> R : Issue Certificate
A -> P : Borrow Book
activate P
P --> A : ACK
deactivate P
A -> T : Enroll Course
A --> R : Register Student
P -> A : View Schedule
activate A
A --> P : ACK
deactivate A
@enduml