@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
participant "Admin" as A
entity "Seller" as S
participant "Payment Gateway" as PG
control "Delivery Service" as DS
PG --> A : Cancel Order
S ->> DS : Browse Products
DS --> PG : Checkout
A -> DS : Make Payment
DS --> S : Manage Inventory
note over S : processing manage inventory
PG --> S : Write Review
note over S : processing write review
@enduml