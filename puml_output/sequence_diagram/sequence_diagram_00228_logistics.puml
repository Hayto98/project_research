@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
entity "Driver" as D
boundary "Dispatcher" as D2
control "Warehouse Staff" as WS
WS -> D2 : Deliver Package
WS ->> D : Report Issue
WS ->> D2 : Assign Route
WS --> D2 : Update Inventory
WS --> D2 : Track Shipment
activate D2
D2 --> WS : ACK
deactivate D2
@enduml