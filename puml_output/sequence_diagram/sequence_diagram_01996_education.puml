@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
boundary "Librarian" as L
participant "Teacher" as T
participant "Student" as S
entity "Parent" as P
entity "Registrar" as R
P -> L : Submit Assignment
T -> R : Enroll Course
T -> P : View Schedule
activate P
P --> T : ACK
deactivate P
R --> S : Borrow Book
activate S
S --> R : ACK
deactivate S
T -> L : Take Attendance
@enduml