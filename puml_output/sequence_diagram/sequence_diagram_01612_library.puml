@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
boundary "Member" as M
participant "Librarian" as L
control "Admin" as A
M --> A : Borrow Book
M -> A : Search Catalog
activate A
A --> M : ACK
deactivate A
L --> M : Pay Fine
A --> M : Renew Loan
A --> M : Reserve Book
activate M
M --> A : ACK
deactivate M
@enduml