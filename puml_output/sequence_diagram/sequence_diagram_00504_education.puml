@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
boundary "Librarian" as L
entity "Student" as S
boundary "Teacher" as T
control "Parent" as P
S --> L : Enroll Course
activate L
L --> S : ACK
deactivate L
S -> L : Register Student
note over L : processing register student
T --> L : Submit Assignment
note over L : processing submit assignment
S ->> T : Borrow Book
S -> L : Issue Certificate
L -> T : Grade Exam
note over T : processing grade exam
@enduml