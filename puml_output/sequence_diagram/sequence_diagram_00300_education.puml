@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
actor "Librarian" as L
entity "Admin" as A
participant "Registrar" as R
control "Teacher" as T
participant "Parent" as P
R --> P : Borrow Book
A -> P : Grade Exam
activate P
P --> A : ACK
deactivate P
A ->> L : Enroll Course
R --> L : View Schedule
activate L
L --> R : ACK
deactivate L
L --> R : Register Student
note over R : processing register student
@enduml