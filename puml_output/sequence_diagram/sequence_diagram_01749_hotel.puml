@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
control "Receptionist" as R
participant "Manager" as M
actor "Guest" as G
R -> M : Clean Room
activate M
M --> R : ACK
deactivate M
M --> R : Book Room
R --> M : Request Service
activate M
M --> R : ACK
deactivate M
G ->> M : Process Payment
activate M
M --> G : ACK
deactivate M
note over M : processing process payment
R -> G : Check In
R ->> M : Order Room Service
@enduml