@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
participant "Driver" as D
entity "Customer" as C
actor "Warehouse Staff" as WS
actor "Fleet Manager" as FM
WS ->> FM : Fuel Vehicle
WS -> FM : Deliver Package
activate FM
FM --> WS : ACK
deactivate FM
D ->> FM : Load Package
C ->> D : Schedule Pickup
@enduml