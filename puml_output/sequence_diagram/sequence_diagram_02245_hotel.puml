@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
control "Housekeeper" as H
actor "Guest" as G
entity "Manager" as M
entity "Chef" as C
entity "Receptionist" as R
G --> M : Check In
activate M
M --> G : ACK
deactivate M
C -> R : Book Room
H -> R : Cancel Reservation
M --> G : Order Room Service
@enduml