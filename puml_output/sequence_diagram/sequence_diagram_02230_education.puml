@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
entity "Registrar" as R
actor "Parent" as P
control "Student" as S
P --> S : Register Student
S -> R : Submit Assignment
S ->> P : Borrow Book
note over P : processing borrow book
S ->> P : Take Attendance
activate P
P --> S : ACK
deactivate P
R -> S : Grade Exam
@enduml