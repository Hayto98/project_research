@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
control "Admin" as A
entity "Student" as S
entity "Parent" as P
boundary "Teacher" as T
boundary "Registrar" as R
A ->> P : Submit Assignment
activate P
P --> A : ACK
deactivate P
R ->> T : Enroll Course
A ->> S : Issue Certificate
P -> A : Borrow Book
@enduml