@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
boundary "Librarian" as L
actor "Member" as M
control "Admin" as A
A ->> L : Register Member
A ->> L : Borrow Book
activate L
L --> A : ACK
deactivate L
L -> A : Reserve Book
L ->> A : Renew Loan
M --> L : Add New Book
@enduml