@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
boundary "Delivery Service" as DS
participant "Admin" as A
boundary "Customer" as C
boundary "Seller" as S
entity "Payment Gateway" as PG
DS ->> S : Apply Coupon
PG -> S : Track Order
DS ->> S : Checkout
activate S
S --> DS : ACK
deactivate S
C --> S : Browse Products
DS --> C : Manage Inventory
activate C
C --> DS : ACK
deactivate C
@enduml