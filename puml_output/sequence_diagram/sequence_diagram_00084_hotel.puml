@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
entity "Manager" as M
entity "Guest" as G
control "Receptionist" as R
boundary "Chef" as C
participant "Housekeeper" as H
R -> C : Request Service
C ->> G : Book Room
note over G : processing book room
H -> R : Check Out
G --> R : Check In
C --> M : Process Payment
G --> M : Clean Room
@enduml