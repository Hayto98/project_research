@startuml

boundary "Librarian" as L
control "Admin" as A
participant "Teacher" as T
actor "Registrar" as R
A ->> T : View Schedule
note over T : processing view schedule
R -> A : Borrow Book
L --> A : Grade Exam
note over A : processing grade exam
L -> T : Issue Certificate
A ->> T : Submit Assignment
activate T
T --> A : ACK
deactivate T
@enduml