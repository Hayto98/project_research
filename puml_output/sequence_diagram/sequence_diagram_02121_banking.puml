@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
control "Branch Manager" as BM
entity "Auditor" as A
actor "Account Holder" as AH
entity "ATM" as A2
A2 -> AH : Transfer Funds
BM --> AH : Pay Bill
A --> AH : Deposit Money
A2 ->> BM : View Statement
activate BM
BM --> A2 : ACK
deactivate BM
BM --> A2 : Withdraw Cash
@enduml