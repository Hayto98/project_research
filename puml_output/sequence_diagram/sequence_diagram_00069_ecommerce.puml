@startuml
skinparam monochrome true
skinparam shadowing true
entity "Seller" as S
participant "Delivery Service" as DS
actor "Payment Gateway" as PG
participant "Customer" as C
DS -> PG : Write Review
PG -> S : Make Payment
PG -> DS : Add To Cart
C ->> S : Cancel Order
C ->> PG : Manage Inventory
@enduml