@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
entity "Student" as S
entity "Teacher" as T
control "Admin" as A
S -> T : View Schedule
activate T
T --> S : ACK
deactivate T
S ->> A : Submit Assignment
A --> S : Borrow Book
activate S
S --> A : ACK
deactivate S
S -> A : Take Attendance
activate A
A --> S : ACK
deactivate A
A ->> S : Grade Exam
note over S : processing grade exam
@enduml