@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
participant "User" as U
control "Moderator" as M
participant "Advertiser" as A
control "Admin" as A2
A -> M : Comment
U -> A : Create Post
A ->> M : Share Post
activate M
M --> A : ACK
deactivate M
note over M : processing share post
M ->> U : Follow User
U ->> A : Like Post
activate A
A --> U : ACK
deactivate A
A ->> M : Send Message
@enduml