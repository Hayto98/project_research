@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
actor "Student" as S
control "Registrar" as R
entity "Librarian" as L
actor "Admin" as A
participant "Teacher" as T
T ->> S : Take Attendance
activate S
S --> T : ACK
deactivate S
L --> R : Submit Assignment
A ->> T : Grade Exam
L ->> A : Enroll Course
activate A
A --> L : ACK
deactivate A
R ->> S : View Schedule
activate S
S --> R : ACK
deactivate S
R ->> L : Issue Certificate
activate L
L --> R : ACK
deactivate L
@enduml