@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
boundary "Manager" as M
entity "Housekeeper" as H
entity "Chef" as C
entity "Receptionist" as R
H --> M : Order Room Service
note over M : processing order room service
M --> R : Process Payment
note over R : processing process payment
M -> C : Book Room
activate C
C --> M : ACK
deactivate C
H -> C : Check Out
@enduml