@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
boundary "Librarian" as L
participant "Member" as M
actor "Admin" as A
A -> M : Add New Book
activate M
M --> A : ACK
deactivate M
L -> M : Renew Loan
A ->> L : Return Book
activate L
L --> A : ACK
deactivate L
M -> A : Search Catalog
@enduml