@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
entity "User" as U
participant "Advertiser" as A
actor "Admin" as A2
A -> A2 : Comment
U -> A : Follow User
note over A : processing follow user
A2 --> U : Like Post
A2 --> A : Report Content
activate A
A --> A2 : ACK
deactivate A
A --> A2 : Send Message
A ->> A2 : Edit Profile
@enduml