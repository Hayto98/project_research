@startuml
skinparam monochrome true
skinparam defaultFontSize 13
boundary "User" as U
participant "Admin" as A
participant "Moderator" as M
boundary "Advertiser" as A2
M -> A2 : Follow User
M ->> U : Comment
activate U
U --> M : ACK
deactivate U
M --> A2 : Edit Profile
activate A2
A2 --> M : ACK
deactivate A2
note over A2 : processing edit profile
M -> A2 : Share Post
activate A2
A2 --> M : ACK
deactivate A2
A -> U : Report Content
activate U
U --> A : ACK
deactivate U
U ->> A : Send Message
U --> M : Like Post
note over M : processing like post
@enduml