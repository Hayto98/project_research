@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
actor "Chef" as C
control "Manager" as M
boundary "Receptionist" as R
C --> M : Order Room Service
C --> M : Book Room
activate M
M --> C : ACK
deactivate M
R --> M : Check In
activate M
M --> R : ACK
deactivate M
C --> R : Check Out
note over R : processing check out
@enduml