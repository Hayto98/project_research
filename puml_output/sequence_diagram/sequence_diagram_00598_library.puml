@startuml
skinparam monochrome true
skinparam shadowing true
entity "Admin" as A
control "Librarian" as L
entity "Member" as M
A --> L : Pay Fine
note over L : processing pay fine
L --> A : Reserve Book
activate A
A --> L : ACK
deactivate A
A -> M : Search Catalog
note over M : processing search catalog
M --> L : Renew Loan
activate L
L --> M : ACK
deactivate L
@enduml