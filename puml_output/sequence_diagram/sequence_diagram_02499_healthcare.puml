@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
actor "Lab Technician" as LT
boundary "Patient" as P
actor "Insurance Provider" as IP
P --> IP : Book Appointment
IP --> LT : Examine Patient
note over LT : processing examine patient
LT ->> IP : Update Medical Record
activate IP
IP --> LT : ACK
deactivate IP
P ->> IP : Process Insurance Claim
LT --> P : Discharge Patient
note over P : processing discharge patient
IP --> P : Run Lab Test
LT ->> IP : Admit Patient
@enduml