@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
boundary "Delivery Service" as DS
actor "Admin" as A
entity "Customer" as C
participant "Seller" as S
S -> DS : Track Order
note over DS : processing track order
DS --> S : Add To Cart
note over S : processing add to cart
C --> DS : Browse Products
S ->> A : Write Review
activate A
A --> S : ACK
deactivate A
note over A : processing write review
C ->> DS : Cancel Order
DS --> S : Checkout
activate S
S --> DS : ACK
deactivate S
@enduml