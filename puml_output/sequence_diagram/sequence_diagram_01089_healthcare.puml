@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
control "Nurse" as N
boundary "Patient" as P
boundary "Insurance Provider" as IP
IP -> P : Discharge Patient
P --> IP : Issue Prescription
activate IP
IP --> P : ACK
deactivate IP
P -> IP : Examine Patient
P -> N : Run Lab Test
P -> N : Admit Patient
P --> N : Book Appointment
@enduml