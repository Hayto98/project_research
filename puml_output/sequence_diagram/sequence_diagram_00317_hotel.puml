@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
participant "Manager" as M
participant "Receptionist" as R
control "Chef" as C
participant "Guest" as G
participant "Housekeeper" as H
C -> R : Request Service
activate R
R --> C : ACK
deactivate R
C --> M : Book Room
H --> M : Order Room Service
activate M
M --> H : ACK
deactivate M
R ->> C : Cancel Reservation
activate C
C --> R : ACK
deactivate C
note over C : processing cancel reservation
M ->> G : Clean Room
@enduml