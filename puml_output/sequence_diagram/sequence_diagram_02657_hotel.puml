@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
entity "Receptionist" as R
participant "Housekeeper" as H
actor "Chef" as C
C -> H : Request Service
C --> R : Cancel Reservation
R -> H : Book Room
note over H : processing book room
C --> H : Process Payment
@enduml