@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
actor "Guest" as G
entity "Manager" as M
control "Receptionist" as R
actor "Chef" as C
entity "Housekeeper" as H
R -> G : Request Service
activate G
G --> R : ACK
deactivate G
R ->> C : Check In
R -> G : Order Room Service
activate G
G --> R : ACK
deactivate G
H --> G : Clean Room
note over G : processing clean room
@enduml