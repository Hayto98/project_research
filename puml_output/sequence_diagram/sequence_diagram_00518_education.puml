@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
entity "Parent" as P
participant "Admin" as A
actor "Teacher" as T
P --> A : Register Student
activate A
A --> P : ACK
deactivate A
A -> T : Take Attendance
T -> P : Issue Certificate
A ->> P : View Schedule
@enduml