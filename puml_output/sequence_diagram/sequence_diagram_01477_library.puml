@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
participant "Librarian" as L
control "Member" as M
participant "Admin" as A
L ->> A : Renew Loan
L -> A : Add New Book
note over A : processing add new book
M -> A : Borrow Book
L -> A : Pay Fine
activate A
A --> L : ACK
deactivate A
L -> A : Return Book
@enduml