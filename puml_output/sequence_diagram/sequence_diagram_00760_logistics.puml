@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
control "Dispatcher" as D
participant "Driver" as D2
participant "Fleet Manager" as FM
control "Warehouse Staff" as WS
entity "Customer" as C
D2 --> WS : Load Package
WS --> D : Deliver Package
WS ->> C : Assign Route
WS -> FM : Update Inventory
@enduml