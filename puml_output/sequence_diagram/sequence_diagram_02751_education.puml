@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
entity "Teacher" as T
entity "Student" as S
boundary "Admin" as A
participant "Registrar" as R
participant "Librarian" as L
R --> A : Enroll Course
S --> A : Register Student
activate A
A --> S : ACK
deactivate A
A -> S : Grade Exam
note over S : processing grade exam
R --> A : Take Attendance
@enduml