@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
control "Housekeeper" as H
entity "Chef" as C
control "Guest" as G
G ->> C : Request Service
G --> C : Order Room Service
C --> H : Process Payment
activate H
H --> C : ACK
deactivate H
H -> G : Check In
note over G : processing check in
G ->> H : Check Out
activate H
H --> G : ACK
deactivate H
C -> G : Cancel Reservation
H -> G : Book Room
@enduml