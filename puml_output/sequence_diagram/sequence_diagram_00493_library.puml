@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
participant "Librarian" as L
entity "Admin" as A
actor "Member" as M
M --> L : Renew Loan
note over L : processing renew loan
M ->> A : Pay Fine
M --> L : Search Catalog
note over L : processing search catalog
A ->> L : Borrow Book
activate L
L --> A : ACK
deactivate L
@enduml