@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
actor "Member" as M
actor "Librarian" as L
entity "Admin" as A
M -> L : Reserve Book
A -> M : Borrow Book
L ->> M : Add New Book
activate M
M --> L : ACK
deactivate M
note over M : processing add new book
L -> A : Search Catalog
activate A
A --> L : ACK
deactivate A
L ->> A : Return Book
A --> L : Register Member
activate L
L --> A : ACK
deactivate L
@enduml