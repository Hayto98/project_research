@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
participant "Account Holder" as AH
boundary "Bank Teller" as BT
entity "Branch Manager" as BM
boundary "Auditor" as A
BM --> AH : Apply For Loan
AH ->> BT : Block Card
BM -> A : Withdraw Cash
A --> BT : Open Account
activate BT
BT --> A : ACK
deactivate BT
AH --> BM : Deposit Money
BM -> A : View Statement
@enduml