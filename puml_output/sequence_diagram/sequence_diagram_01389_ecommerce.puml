@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
boundary "Payment Gateway" as PG
entity "Seller" as S
control "Delivery Service" as DS
participant "Customer" as C
boundary "Admin" as A
S --> A : Add To Cart
S -> PG : Track Order
note over PG : processing track order
C ->> PG : Cancel Order
A --> PG : Manage Inventory
@enduml