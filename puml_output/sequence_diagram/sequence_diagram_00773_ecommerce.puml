@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
participant "Admin" as A
actor "Customer" as C
participant "Delivery Service" as DS
participant "Payment Gateway" as PG
participant "Seller" as S
A ->> PG : Manage Inventory
activate PG
PG --> A : ACK
deactivate PG
note over PG : processing manage inventory
PG ->> A : Make Payment
PG --> DS : Checkout
C -> DS : Add To Cart
@enduml