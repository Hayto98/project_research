@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
actor "User" as U
participant "Moderator" as M
control "Admin" as A
entity "Advertiser" as A2
A ->> A2 : Comment
U --> A : Send Message
activate A
A --> U : ACK
deactivate A
M ->> U : Follow User
activate U
U --> M : ACK
deactivate U
M ->> A : Share Post
activate A
A --> M : ACK
deactivate A
@enduml