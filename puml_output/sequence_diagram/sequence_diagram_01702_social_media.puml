@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
boundary "Advertiser" as A
participant "User" as U
control "Admin" as A2
A ->> A2 : Edit Profile
U -> A2 : Send Message
U --> A : Follow User
A2 --> A : Share Post
note over A : processing share post
A2 -> A : Create Post
activate A
A --> A2 : ACK
deactivate A
note over A : processing create post
@enduml