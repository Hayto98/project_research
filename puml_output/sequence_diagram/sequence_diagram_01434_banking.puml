@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
participant "Account Holder" as AH
actor "Bank Teller" as BT
actor "Branch Manager" as BM
boundary "Auditor" as A
AH -> BM : Deposit Money
A -> AH : Withdraw Cash
activate AH
AH --> A : ACK
deactivate AH
A ->> AH : View Statement
A ->> BT : Open Account
activate BT
BT --> A : ACK
deactivate BT
A ->> BM : Pay Bill
@enduml