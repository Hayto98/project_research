@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
control "Bank Teller" as BT
actor "ATM" as A
entity "Account Holder" as AH
participant "Branch Manager" as BM
actor "Auditor" as A2
BM ->> A2 : Pay Bill
AH -> A2 : Open Account
A2 -> BT : Deposit Money
note over BT : processing deposit money
BM --> A2 : Apply For Loan
note over A2 : processing apply for loan
@enduml