@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
entity "Moderator" as M
boundary "User" as U
actor "Advertiser" as A
A -> U : Send Message
activate U
U --> A : ACK
deactivate U
A -> U : Create Post
U ->> A : Comment
activate A
A --> U : ACK
deactivate A
M ->> U : Follow User
@enduml