@startuml
skinparam defaultFontSize 11
control "Lab Technician" as LT
control "Patient" as P
control "Receptionist" as R
LT -> R : Run Lab Test
R -> LT : Issue Prescription
activate LT
LT --> R : ACK
deactivate LT
note over LT : processing issue prescription
P --> R : Discharge Patient
activate R
R --> P : ACK
deactivate R
R --> P : Examine Patient
@enduml