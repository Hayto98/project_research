@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
participant "Librarian" as L
participant "Member" as M
control "Admin" as A
L -> M : Pay Fine
activate M
M --> L : ACK
deactivate M
note over M : processing pay fine
M -> L : Reserve Book
activate L
L --> M : ACK
deactivate L
note over L : processing reserve book
L --> M : Add New Book
A --> L : Register Member
@enduml