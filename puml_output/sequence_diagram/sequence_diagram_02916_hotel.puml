@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
actor "Receptionist" as R
actor "Guest" as G
boundary "Housekeeper" as H
entity "Manager" as M
G --> H : Check In
note over H : processing check in
H --> M : Order Room Service
activate M
M --> H : ACK
deactivate M
R ->> H : Request Service
M --> R : Process Payment
@enduml