@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
control "Librarian" as L
control "Admin" as A
actor "Member" as M
M ->> L : Register Member
A ->> L : Return Book
activate L
L --> A : ACK
deactivate L
M ->> A : Search Catalog
A -> L : Renew Loan
M -> L : Pay Fine
@enduml