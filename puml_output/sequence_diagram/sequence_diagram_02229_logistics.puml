@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
participant "Customer" as C
participant "Dispatcher" as D
participant "Driver" as D2
D2 --> C : Report Issue
activate C
C --> D2 : ACK
deactivate C
C ->> D : Track Shipment
D2 -> D : Schedule Pickup
activate D
D --> D2 : ACK
deactivate D
note over D : processing schedule pickup
C --> D2 : Deliver Package
C --> D : Load Package
@enduml