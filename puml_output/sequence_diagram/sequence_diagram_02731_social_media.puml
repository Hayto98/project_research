@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
actor "Advertiser" as A
boundary "User" as U
actor "Moderator" as M
entity "Admin" as A2
M --> A : Like Post
note over A : processing like post
A --> U : Edit Profile
A --> U : Comment
activate U
U --> A : ACK
deactivate U
U --> A2 : Follow User
U -> A2 : Send Message
@enduml