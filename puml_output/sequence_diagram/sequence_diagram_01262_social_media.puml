@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
control "User" as U
control "Admin" as A
participant "Moderator" as M
entity "Advertiser" as A2
A --> M : Report Content
note over M : processing report content
M ->> A2 : Follow User
A -> U : Edit Profile
M --> U : Like Post
A2 --> A : Send Message
M --> A : Share Post
U -> A : Comment
@enduml