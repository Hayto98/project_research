@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
entity "Auditor" as A
actor "Account Holder" as AH
control "ATM" as A2
A2 ->> AH : Deposit Money
activate AH
AH --> A2 : ACK
deactivate AH
A2 -> A : View Statement
A2 -> A : Withdraw Cash
A -> AH : Block Card
activate AH
AH --> A : ACK
deactivate AH
@enduml