@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
participant "Parent" as P
participant "Registrar" as R
control "Librarian" as L
L ->> P : Borrow Book
note over P : processing borrow book
P ->> R : Submit Assignment
activate R
R --> P : ACK
deactivate R
P ->> L : Grade Exam
activate L
L --> P : ACK
deactivate L
L ->> P : Register Student
@enduml