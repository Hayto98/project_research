@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
actor "Manager" as M
actor "Chef" as C
entity "Receptionist" as R
boundary "Guest" as G
control "Housekeeper" as H
C ->> M : Check In
R --> G : Request Service
note over G : processing request service
R -> H : Cancel Reservation
R --> G : Order Room Service
H -> G : Check Out
@enduml