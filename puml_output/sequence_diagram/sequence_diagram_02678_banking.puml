@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
control "Auditor" as A
actor "Bank Teller" as BT
control "ATM" as A2
control "Branch Manager" as BM
A ->> BT : View Statement
BT ->> A2 : Pay Bill
A2 ->> BM : Apply For Loan
activate BM
BM --> A2 : ACK
deactivate BM
BT -> A : Deposit Money
@enduml