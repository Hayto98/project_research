@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
control "Patient" as P
control "Insurance Provider" as IP
control "Lab Technician" as LT
entity "Receptionist" as R
LT ->> P : Run Lab Test
note over P : processing run lab test
R ->> P : Process Insurance Claim
IP --> R : Examine Patient
note over R : processing examine patient
LT -> R : Update Medical Record
R -> LT : Issue Prescription
IP --> P : Book Appointment
LT -> IP : Discharge Patient
@enduml