@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
boundary "User" as U
control "Advertiser" as A
participant "Admin" as A2
A2 --> U : Comment
U --> A2 : Share Post
activate A2
A2 --> U : ACK
deactivate A2
A -> A2 : Send Message
activate A2
A2 --> A : ACK
deactivate A2
A --> A2 : Follow User
A ->> A2 : Like Post
activate A2
A2 --> A : ACK
deactivate A2
A2 --> A : Edit Profile
note over A : processing edit profile
@enduml