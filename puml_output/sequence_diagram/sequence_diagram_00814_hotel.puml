@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
actor "Housekeeper" as H
participant "Manager" as M
control "Guest" as G
boundary "Chef" as C
H ->> M : Clean Room
note over M : processing clean room
H ->> M : Cancel Reservation
note over M : processing cancel reservation
G ->> M : Check Out
M ->> G : Book Room
@enduml