@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
participant "Member" as M
control "Librarian" as L
participant "Admin" as A
M -> A : Renew Loan
activate A
A --> M : ACK
deactivate A
M --> L : Pay Fine
activate L
L --> M : ACK
deactivate L
A -> L : Register Member
activate L
L --> A : ACK
deactivate L
note over L : processing register member
A -> L : Return Book
activate L
L --> A : ACK
deactivate L
A --> M : Search Catalog
@enduml