@startuml
skinparam monochrome true
skinparam ArrowColor #555555
entity "Nurse" as N
boundary "Lab Technician" as LT
actor "Doctor" as D
N -> D : Discharge Patient
LT -> D : Issue Prescription
note over D : processing issue prescription
D ->> N : Examine Patient
note over N : processing examine patient
LT ->> N : Admit Patient
LT -> D : Book Appointment
note over D : processing book appointment
N ->> LT : Run Lab Test
@enduml