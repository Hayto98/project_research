@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
control "Student" as S
control "Librarian" as L
entity "Admin" as A
L -> A : Borrow Book
activate A
A --> L : ACK
deactivate A
L --> A : Enroll Course
activate A
A --> L : ACK
deactivate A
A ->> L : Register Student
A ->> S : Take Attendance
note over S : processing take attendance
@enduml