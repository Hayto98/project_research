@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
participant "Seller" as S
control "Customer" as C
actor "Admin" as A
actor "Delivery Service" as DS
DS ->> A : Make Payment
activate A
A --> DS : ACK
deactivate A
S -> DS : Add To Cart
activate DS
DS --> S : ACK
deactivate DS
note over DS : processing add to cart
A -> C : Cancel Order
A ->> DS : Apply Coupon
activate DS
DS --> A : ACK
deactivate DS
C --> A : Checkout
activate A
A --> C : ACK
deactivate A
note over A : processing checkout
S ->> DS : Manage Inventory
@enduml