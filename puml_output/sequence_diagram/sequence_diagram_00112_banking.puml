@startuml
skinparam ArrowColor #555555
participant "Branch Manager" as BM
actor "Auditor" as A
participant "Bank Teller" as BT
entity "ATM" as A2
A --> BM : Transfer Funds
activate BM
BM --> A : ACK
deactivate BM
A2 --> A : Block Card
BT --> A : Deposit Money
A ->> A2 : View Statement
note over A2 : processing view statement
BT ->> A : Withdraw Cash
@enduml