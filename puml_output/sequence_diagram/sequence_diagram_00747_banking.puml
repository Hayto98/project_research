@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
control "Branch Manager" as BM
participant "Account Holder" as AH
participant "ATM" as A
boundary "Auditor" as A2
AH -> A : View Statement
note over A : processing view statement
A2 -> AH : Deposit Money
BM -> AH : Transfer Funds
activate AH
AH --> BM : ACK
deactivate AH
A -> BM : Block Card
A2 -> BM : Open Account
activate BM
BM --> A2 : ACK
deactivate BM
@enduml