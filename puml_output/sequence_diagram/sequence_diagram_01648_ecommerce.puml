@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
control "Customer" as C
boundary "Admin" as A
control "Seller" as S
A ->> S : Add To Cart
C --> S : Make Payment
activate S
S --> C : ACK
deactivate S
A -> C : Browse Products
activate C
C --> A : ACK
deactivate C
S --> A : Cancel Order
@enduml