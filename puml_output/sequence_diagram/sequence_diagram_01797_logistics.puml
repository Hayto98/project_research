@startuml
skinparam ArrowColor #555555
boundary "Fleet Manager" as FM
participant "Customer" as C
entity "Dispatcher" as D
control "Warehouse Staff" as WS
entity "Driver" as D2
D2 --> D : Update Inventory
D2 --> C : Report Issue
activate C
C --> D2 : ACK
deactivate C
WS ->> D : Schedule Pickup
note over D : processing schedule pickup
FM -> D : Fuel Vehicle
WS --> D : Deliver Package
activate D
D --> WS : ACK
deactivate D
note over D : processing deliver package
WS ->> C : Load Package
@enduml