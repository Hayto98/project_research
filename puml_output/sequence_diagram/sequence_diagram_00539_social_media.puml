@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
boundary "Advertiser" as A
entity "Admin" as A2
entity "User" as U
A ->> A2 : Comment
A --> A2 : Share Post
activate A2
A2 --> A : ACK
deactivate A2
U -> A : Create Post
A2 ->> A : Edit Profile
activate A
A --> A2 : ACK
deactivate A
note over A : processing edit profile
@enduml