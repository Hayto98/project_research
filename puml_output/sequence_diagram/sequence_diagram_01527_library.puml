@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
participant "Admin" as A
control "Librarian" as L
actor "Member" as M
L -> M : Search Catalog
M --> L : Return Book
note over L : processing return book
L -> M : Register Member
activate M
M --> L : ACK
deactivate M
note over M : processing register member
M --> L : Pay Fine
M -> A : Add New Book
activate A
A --> M : ACK
deactivate A
M ->> A : Renew Loan
activate A
A --> M : ACK
deactivate A
@enduml