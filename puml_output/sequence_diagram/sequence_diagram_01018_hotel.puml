@startuml
skinparam monochrome true
skinparam defaultFontSize 11
actor "Guest" as G
control "Chef" as C
entity "Manager" as M
C -> M : Clean Room
G -> M : Book Room
M -> G : Cancel Reservation
note over G : processing cancel reservation
G ->> M : Check In
activate M
M --> G : ACK
deactivate M
C -> G : Process Payment
activate G
G --> C : ACK
deactivate G
@enduml