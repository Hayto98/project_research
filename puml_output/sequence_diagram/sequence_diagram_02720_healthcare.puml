@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
actor "Patient" as P
control "Doctor" as D
entity "Insurance Provider" as IP
IP ->> P : Run Lab Test
activate P
P --> IP : ACK
deactivate P
P --> D : Examine Patient
activate D
D --> P : ACK
deactivate D
IP --> P : Update Medical Record
activate P
P --> IP : ACK
deactivate P
P ->> IP : Process Insurance Claim
note over IP : processing process insurance claim
D ->> IP : Admit Patient
@enduml