@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
control "Librarian" as L
participant "Admin" as A
participant "Member" as M
A ->> L : Register Member
activate L
L --> A : ACK
deactivate L
L -> A : Pay Fine
M -> L : Borrow Book
activate L
L --> M : ACK
deactivate L
M --> L : Reserve Book
M --> L : Add New Book
activate L
L --> M : ACK
deactivate L
@enduml