@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
participant "Advertiser" as A
control "Admin" as A2
actor "User" as U
participant "Moderator" as M
A2 ->> U : Report Content
A -> U : Follow User
A --> U : Comment
A --> M : Create Post
activate M
M --> A : ACK
deactivate M
@enduml