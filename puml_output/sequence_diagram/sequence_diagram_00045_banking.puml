@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
participant "Account Holder" as AH
control "Bank Teller" as BT
participant "Branch Manager" as BM
boundary "ATM" as A
AH --> BT : Apply For Loan
A -> AH : Pay Bill
BM -> AH : Transfer Funds
note over AH : processing transfer funds
AH --> BT : Block Card
BT ->> BM : Deposit Money
@enduml