@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
boundary "Warehouse Staff" as WS
entity "Dispatcher" as D
control "Fleet Manager" as FM
entity "Customer" as C
entity "Driver" as D2
WS -> D2 : Load Package
activate D2
D2 --> WS : ACK
deactivate D2
WS -> D : Report Issue
D2 --> FM : Schedule Pickup
activate FM
FM --> D2 : ACK
deactivate FM
FM -> D2 : Fuel Vehicle
activate D2
D2 --> FM : ACK
deactivate D2
D ->> D2 : Track Shipment
FM -> WS : Assign Route
activate WS
WS --> FM : ACK
deactivate WS
@enduml