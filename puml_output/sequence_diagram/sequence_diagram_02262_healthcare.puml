@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
participant "Lab Technician" as LT
boundary "Insurance Provider" as IP
participant "Doctor" as D
actor "Receptionist" as R
LT ->> R : Discharge Patient
R -> IP : Admit Patient
D --> IP : Process Insurance Claim
activate IP
IP --> D : ACK
deactivate IP
IP -> LT : Update Medical Record
R --> LT : Issue Prescription
activate LT
LT --> R : ACK
deactivate LT
note over LT : processing issue prescription
IP ->> R : Book Appointment
@enduml