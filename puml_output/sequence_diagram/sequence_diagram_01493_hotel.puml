@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
entity "Receptionist" as R
control "Manager" as M
entity "Housekeeper" as H
entity "Guest" as G
R -> G : Clean Room
H --> M : Book Room
note over M : processing book room
G ->> M : Request Service
activate M
M --> G : ACK
deactivate M
G ->> M : Cancel Reservation
note over M : processing cancel reservation
@enduml