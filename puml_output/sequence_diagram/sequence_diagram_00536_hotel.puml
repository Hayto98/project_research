@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
participant "Guest" as G
participant "Receptionist" as R
participant "Manager" as M
actor "Housekeeper" as H
H ->> R : Book Room
H --> R : Order Room Service
activate R
R --> H : ACK
deactivate R
G ->> H : Check In
activate H
H --> G : ACK
deactivate H
R --> H : Request Service
note over H : processing request service
M --> G : Cancel Reservation
@enduml