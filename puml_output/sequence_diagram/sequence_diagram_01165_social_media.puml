@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
control "User" as U
participant "Admin" as A
participant "Moderator" as M
participant "Advertiser" as A2
A -> A2 : Like Post
activate A2
A2 --> A : ACK
deactivate A2
note over A2 : processing like post
M -> A : Share Post
activate A
A --> M : ACK
deactivate A
note over A : processing share post
A2 --> U : Create Post
M ->> A2 : Follow User
@enduml