@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
actor "Admin" as A
entity "Seller" as S
boundary "Payment Gateway" as PG
participant "Delivery Service" as DS
control "Customer" as C
C -> DS : Make Payment
activate DS
DS --> C : ACK
deactivate DS
S -> C : Manage Inventory
PG ->> S : Browse Products
S ->> C : Checkout
activate C
C --> S : ACK
deactivate C
S ->> A : Cancel Order
S ->> PG : Track Order
activate PG
PG --> S : ACK
deactivate PG
note over PG : processing track order
@enduml