@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
control "Patient" as P
entity "Doctor" as D
entity "Nurse" as N
P ->> N : Admit Patient
P -> N : Process Insurance Claim
N ->> P : Book Appointment
P --> D : Issue Prescription
activate D
D --> P : ACK
deactivate D
P ->> D : Run Lab Test
@enduml