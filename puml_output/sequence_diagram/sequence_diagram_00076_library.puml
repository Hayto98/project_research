@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
boundary "Librarian" as L
entity "Member" as M
entity "Admin" as A
A -> L : Renew Loan
activate L
L --> A : ACK
deactivate L
M ->> L : Add New Book
L --> A : Register Member
activate A
A --> L : ACK
deactivate A
A ->> L : Search Catalog
activate L
L --> A : ACK
deactivate L
@enduml