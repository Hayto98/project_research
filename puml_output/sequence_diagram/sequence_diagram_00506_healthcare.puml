@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
participant "Lab Technician" as LT
control "Insurance Provider" as IP
participant "Doctor" as D
actor "Nurse" as N
control "Receptionist" as R
D --> LT : Book Appointment
D ->> R : Update Medical Record
LT ->> D : Run Lab Test
IP --> N : Issue Prescription
activate N
N --> IP : ACK
deactivate N
@enduml