@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
entity "Dispatcher" as D
boundary "Fleet Manager" as FM
participant "Customer" as C
control "Driver" as D2
D2 --> FM : Fuel Vehicle
activate FM
FM --> D2 : ACK
deactivate FM
FM --> D : Update Inventory
activate D
D --> FM : ACK
deactivate D
note over D : processing update inventory
C -> D : Schedule Pickup
note over D : processing schedule pickup
FM --> D : Load Package
activate D
D --> FM : ACK
deactivate D
note over D : processing load package
C ->> D : Track Shipment
activate D
D --> C : ACK
deactivate D
D ->> D2 : Assign Route
C ->> FM : Report Issue
note over FM : processing report issue
@enduml