@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
actor "Housekeeper" as H
actor "Receptionist" as R
actor "Guest" as G
entity "Chef" as C
boundary "Manager" as M
G -> M : Clean Room
H -> G : Book Room
C -> M : Check Out
activate M
M --> C : ACK
deactivate M
C --> M : Process Payment
M --> G : Request Service
G ->> C : Order Room Service
@enduml