@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
boundary "Payment Gateway" as PG
participant "Seller" as S
entity "Customer" as C
PG --> C : Track Order
PG ->> S : Checkout
note over S : processing checkout
PG -> S : Browse Products
C ->> S : Write Review
S ->> PG : Apply Coupon
@enduml