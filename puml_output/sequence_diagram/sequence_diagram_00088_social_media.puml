@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
control "User" as U
participant "Moderator" as M
actor "Advertiser" as A
M ->> U : Share Post
A --> M : Create Post
activate M
M --> A : ACK
deactivate M
A -> M : Send Message
M ->> A : Edit Profile
activate A
A --> M : ACK
deactivate A
U -> A : Comment
note over A : processing comment
@enduml