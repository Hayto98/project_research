@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
participant "Advertiser" as A
entity "User" as U
participant "Admin" as A2
A -> U : Edit Profile
A2 ->> A : Comment
A ->> A2 : Report Content
A2 ->> U : Share Post
activate U
U --> A2 : ACK
deactivate U
A -> A2 : Create Post
U ->> A : Like Post
activate A
A --> U : ACK
deactivate A
note over A : processing like post
@enduml