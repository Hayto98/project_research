@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
participant "Receptionist" as R
entity "Guest" as G
participant "Housekeeper" as H
actor "Manager" as M
M ->> R : Check In
G ->> H : Order Room Service
activate H
H --> G : ACK
deactivate H
G ->> R : Cancel Reservation
note over R : processing cancel reservation
R --> H : Book Room
M ->> R : Request Service
@enduml