@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
actor "Admin" as A
participant "Librarian" as L
actor "Member" as M
L -> A : Return Book
A --> L : Add New Book
L -> M : Register Member
L ->> M : Renew Loan
activate M
M --> L : ACK
deactivate M
note over M : processing renew loan
@enduml