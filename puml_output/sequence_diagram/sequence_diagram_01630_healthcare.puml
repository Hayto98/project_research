@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
boundary "Doctor" as D
entity "Lab Technician" as LT
entity "Patient" as P
control "Nurse" as N
actor "Receptionist" as R
N ->> P : Issue Prescription
N ->> P : Discharge Patient
activate P
P --> N : ACK
deactivate P
LT --> P : Process Insurance Claim
LT --> N : Update Medical Record
N ->> P : Admit Patient
@enduml