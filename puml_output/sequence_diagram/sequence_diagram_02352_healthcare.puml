@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
actor "Insurance Provider" as IP
actor "Lab Technician" as LT
participant "Receptionist" as R
R --> IP : Discharge Patient
IP ->> LT : Book Appointment
R ->> LT : Issue Prescription
LT -> R : Process Insurance Claim
activate R
R --> LT : ACK
deactivate R
LT --> IP : Run Lab Test
@enduml