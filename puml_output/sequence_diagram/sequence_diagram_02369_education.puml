@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
entity "Student" as S
control "Registrar" as R
participant "Admin" as A
A ->> R : Grade Exam
note over R : processing grade exam
R ->> S : Submit Assignment
activate S
S --> R : ACK
deactivate S
R ->> A : Borrow Book
R -> A : Register Student
note over A : processing register student
A ->> R : Issue Certificate
A --> R : Enroll Course
R --> S : View Schedule
@enduml