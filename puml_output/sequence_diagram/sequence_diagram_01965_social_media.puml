@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
boundary "User" as U
entity "Advertiser" as A
participant "Moderator" as M
boundary "Admin" as A2
A --> U : Share Post
U --> A2 : Comment
activate A2
A2 --> U : ACK
deactivate A2
note over A2 : processing comment
M -> A2 : Like Post
activate A2
A2 --> M : ACK
deactivate A2
A2 -> A : Report Content
@enduml