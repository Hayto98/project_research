@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
control "ATM" as A
entity "Account Holder" as AH
participant "Auditor" as A2
entity "Bank Teller" as BT
A ->> A2 : View Statement
A2 --> AH : Deposit Money
A -> AH : Withdraw Cash
AH --> BT : Block Card
@enduml