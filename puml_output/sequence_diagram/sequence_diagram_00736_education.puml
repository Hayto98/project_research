@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
actor "Registrar" as R
control "Student" as S
entity "Librarian" as L
S ->> R : View Schedule
S -> L : Issue Certificate
R --> S : Enroll Course
activate S
S --> R : ACK
deactivate S
L -> R : Take Attendance
activate R
R --> L : ACK
deactivate R
S ->> R : Submit Assignment
R ->> L : Register Student
note over L : processing register student
R ->> L : Borrow Book
@enduml