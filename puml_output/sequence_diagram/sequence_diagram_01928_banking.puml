@startuml
skinparam monochrome true
skinparam ArrowColor #555555
participant "Branch Manager" as BM
control "Bank Teller" as BT
entity "ATM" as A
A -> BM : Open Account
A --> BT : Pay Bill
BT -> BM : Apply For Loan
activate BM
BM --> BT : ACK
deactivate BM
BM --> A : Transfer Funds
note over A : processing transfer funds
A ->> BT : Deposit Money
@enduml