@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
participant "ATM" as A
control "Branch Manager" as BM
control "Bank Teller" as BT
entity "Account Holder" as AH
control "Auditor" as A2
BM ->> A2 : Withdraw Cash
note over A2 : processing withdraw cash
BT --> AH : Deposit Money
A ->> AH : Transfer Funds
note over AH : processing transfer funds
A -> BT : Open Account
note over BT : processing open account
@enduml