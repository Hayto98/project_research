@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
actor "Guest" as G
control "Housekeeper" as H
control "Chef" as C
C -> H : Check In
activate H
H --> C : ACK
deactivate H
note over H : processing check in
G ->> H : Clean Room
H --> C : Process Payment
C -> H : Order Room Service
H ->> G : Check Out
activate G
G --> H : ACK
deactivate G
@enduml