@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
control "Parent" as P
actor "Student" as S
participant "Admin" as A
entity "Librarian" as L
entity "Teacher" as T
P --> T : Grade Exam
note over T : processing grade exam
P -> S : Register Student
T --> A : Take Attendance
T ->> S : Borrow Book
@enduml