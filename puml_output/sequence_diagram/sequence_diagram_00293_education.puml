@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
actor "Parent" as P
control "Student" as S
control "Admin" as A
S --> A : Grade Exam
P -> S : Issue Certificate
activate S
S --> P : ACK
deactivate S
P ->> A : View Schedule
A -> P : Borrow Book
activate P
P --> A : ACK
deactivate P
@enduml