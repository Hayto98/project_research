@startuml
skinparam monochrome true
actor "Seller" as S
entity "Payment Gateway" as PG
entity "Admin" as A
S -> A : Write Review
PG ->> S : Manage Inventory
PG -> A : Cancel Order
PG -> A : Apply Coupon
activate A
A --> PG : ACK
deactivate A
note over A : processing apply coupon
PG ->> S : Browse Products
@enduml