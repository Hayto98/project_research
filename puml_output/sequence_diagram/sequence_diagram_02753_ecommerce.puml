@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
entity "Payment Gateway" as PG
actor "Seller" as S
control "Delivery Service" as DS
DS -> S : Write Review
DS -> S : Manage Inventory
activate S
S --> DS : ACK
deactivate S
DS --> S : Checkout
DS --> S : Browse Products
S ->> DS : Apply Coupon
DS ->> S : Add To Cart
@enduml