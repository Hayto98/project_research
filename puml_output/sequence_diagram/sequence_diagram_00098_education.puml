@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
actor "Student" as S
actor "Registrar" as R
participant "Librarian" as L
boundary "Admin" as A
participant "Parent" as P
R --> L : Take Attendance
activate L
L --> R : ACK
deactivate L
R --> L : Issue Certificate
activate L
L --> R : ACK
deactivate L
R ->> A : Grade Exam
activate A
A --> R : ACK
deactivate A
A -> R : Register Student
@enduml