@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
boundary "Lab Technician" as LT
boundary "Nurse" as N
entity "Insurance Provider" as IP
participant "Doctor" as D
boundary "Patient" as P
LT -> D : Issue Prescription
P --> N : Book Appointment
IP --> LT : Discharge Patient
IP --> P : Run Lab Test
LT --> IP : Process Insurance Claim
note over IP : processing process insurance claim
IP ->> P : Examine Patient
IP --> P : Admit Patient
note over P : processing admit patient
@enduml