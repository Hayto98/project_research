@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
control "Driver" as D
participant "Fleet Manager" as FM
participant "Customer" as C
D ->> C : Fuel Vehicle
C -> D : Schedule Pickup
C --> D : Assign Route
FM -> D : Report Issue
activate D
D --> FM : ACK
deactivate D
note over D : processing report issue
D ->> FM : Deliver Package
D --> FM : Load Package
@enduml