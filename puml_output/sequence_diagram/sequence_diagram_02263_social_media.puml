@startuml
skinparam defaultFontSize 11
boundary "Moderator" as M
entity "User" as U
actor "Admin" as A
U ->> M : Report Content
activate M
M --> U : ACK
deactivate M
A --> M : Follow User
note over M : processing follow user
U ->> A : Like Post
A --> U : Comment
note over U : processing comment
A ->> M : Share Post
note over M : processing share post
@enduml