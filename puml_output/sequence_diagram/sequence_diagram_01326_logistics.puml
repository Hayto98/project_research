@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
participant "Customer" as C
actor "Fleet Manager" as FM
control "Dispatcher" as D
control "Driver" as D2
D2 ->> D : Load Package
activate D
D --> D2 : ACK
deactivate D
C -> FM : Fuel Vehicle
FM --> D : Assign Route
activate D
D --> FM : ACK
deactivate D
D ->> D2 : Track Shipment
@enduml