@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
boundary "ATM" as A
entity "Branch Manager" as BM
participant "Account Holder" as AH
boundary "Auditor" as A2
control "Bank Teller" as BT
A ->> A2 : Block Card
BT ->> A : View Statement
BM --> AH : Open Account
note over AH : processing open account
BT --> AH : Transfer Funds
note over AH : processing transfer funds
@enduml