@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
participant "Fleet Manager" as FM
boundary "Dispatcher" as D
control "Driver" as D2
participant "Customer" as C
D --> FM : Report Issue
D2 ->> FM : Fuel Vehicle
D2 --> C : Deliver Package
C --> D2 : Track Shipment
activate D2
D2 --> C : ACK
deactivate D2
@enduml