@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
boundary "Driver" as D
entity "Fleet Manager" as FM
participant "Warehouse Staff" as WS
actor "Dispatcher" as D2
actor "Customer" as C
D2 -> D : Report Issue
activate D
D --> D2 : ACK
deactivate D
WS ->> D2 : Deliver Package
note over D2 : processing deliver package
FM --> C : Track Shipment
D2 --> FM : Update Inventory
activate FM
FM --> D2 : ACK
deactivate FM
WS --> D2 : Assign Route
activate D2
D2 --> WS : ACK
deactivate D2
D ->> WS : Fuel Vehicle
activate WS
WS --> D : ACK
deactivate WS
WS --> FM : Load Package
activate FM
FM --> WS : ACK
deactivate FM
note over FM : processing load package
@enduml