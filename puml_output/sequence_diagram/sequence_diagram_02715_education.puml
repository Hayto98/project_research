@startuml
skinparam monochrome true
skinparam defaultFontSize 13
boundary "Registrar" as R
boundary "Student" as S
participant "Librarian" as L
participant "Teacher" as T
T ->> L : Borrow Book
note over L : processing borrow book
R -> S : Issue Certificate
note over S : processing issue certificate
T -> S : Register Student
L -> R : View Schedule
R --> L : Enroll Course
activate L
L --> R : ACK
deactivate L
@enduml