@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
participant "Branch Manager" as BM
control "ATM" as A
actor "Bank Teller" as BT
BT -> A : Deposit Money
BT -> A : Withdraw Cash
activate A
A --> BT : ACK
deactivate A
A ->> BM : Open Account
A ->> BM : Apply For Loan
BM --> A : Block Card
@enduml