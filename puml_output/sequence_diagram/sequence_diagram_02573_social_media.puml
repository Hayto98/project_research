@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
actor "User" as U
boundary "Moderator" as M
participant "Admin" as A
A -> M : Follow User
activate M
M --> A : ACK
deactivate M
A ->> U : Report Content
A --> U : Create Post
M ->> U : Comment
activate U
U --> M : ACK
deactivate U
@enduml