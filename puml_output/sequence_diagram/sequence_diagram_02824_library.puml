@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
participant "Member" as M
boundary "Admin" as A
control "Librarian" as L
A -> L : Return Book
A -> L : Renew Loan
note over L : processing renew loan
A --> L : Borrow Book
L -> M : Add New Book
activate M
M --> L : ACK
deactivate M
L ->> A : Register Member
note over A : processing register member
M ->> L : Search Catalog
note over L : processing search catalog
@enduml