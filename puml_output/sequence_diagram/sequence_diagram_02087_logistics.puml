@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
boundary "Driver" as D
boundary "Customer" as C
entity "Fleet Manager" as FM
actor "Dispatcher" as D2
control "Warehouse Staff" as WS
D -> C : Assign Route
C ->> D2 : Report Issue
WS ->> D2 : Track Shipment
D2 ->> C : Load Package
FM ->> D : Schedule Pickup
@enduml