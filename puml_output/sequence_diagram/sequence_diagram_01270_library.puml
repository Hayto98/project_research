@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
boundary "Librarian" as L
boundary "Member" as M
control "Admin" as A
L -> A : Reserve Book
activate A
A --> L : ACK
deactivate A
M -> L : Search Catalog
note over L : processing search catalog
M ->> L : Borrow Book
activate L
L --> M : ACK
deactivate L
note over L : processing borrow book
A ->> M : Add New Book
activate M
M --> A : ACK
deactivate M
M --> A : Pay Fine
activate A
A --> M : ACK
deactivate A
@enduml