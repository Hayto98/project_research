@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
participant "Admin" as A
control "Advertiser" as A2
boundary "User" as U
participant "Moderator" as M
A2 ->> A : Share Post
note over A : processing share post
M --> A2 : Comment
A2 --> A : Follow User
activate A
A --> A2 : ACK
deactivate A
note over A : processing follow user
A -> U : Like Post
note over U : processing like post
@enduml