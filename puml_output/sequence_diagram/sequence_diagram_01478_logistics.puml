@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
actor "Customer" as C
participant "Driver" as D
control "Warehouse Staff" as WS
WS -> D : Deliver Package
activate D
D --> WS : ACK
deactivate D
WS ->> C : Track Shipment
D ->> WS : Schedule Pickup
activate WS
WS --> D : ACK
deactivate WS
D --> C : Fuel Vehicle
activate C
C --> D : ACK
deactivate C
@enduml