@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
actor "Patient" as P
entity "Receptionist" as R
entity "Insurance Provider" as IP
R -> IP : Examine Patient
R ->> IP : Book Appointment
activate IP
IP --> R : ACK
deactivate IP
P --> R : Admit Patient
activate R
R --> P : ACK
deactivate R
P -> R : Issue Prescription
P -> R : Run Lab Test
activate R
R --> P : ACK
deactivate R
@enduml