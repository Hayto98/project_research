@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
participant "Advertiser" as A
boundary "User" as U
participant "Admin" as A2
participant "Moderator" as M
A --> M : Comment
U ->> A : Create Post
note over A : processing create post
U ->> A2 : Share Post
A2 ->> M : Like Post
note over M : processing like post
M -> A : Follow User
activate A
A --> M : ACK
deactivate A
@enduml