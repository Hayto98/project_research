@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
boundary "Patient" as P
entity "Lab Technician" as LT
control "Insurance Provider" as IP
boundary "Nurse" as N
entity "Doctor" as D
N -> D : Examine Patient
N ->> LT : Book Appointment
LT -> N : Admit Patient
N -> P : Issue Prescription
D ->> LT : Discharge Patient
@enduml