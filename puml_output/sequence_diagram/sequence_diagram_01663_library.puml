@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
boundary "Admin" as A
actor "Librarian" as L
control "Member" as M
L --> A : Borrow Book
activate A
A --> L : ACK
deactivate A
A -> M : Add New Book
activate M
M --> A : ACK
deactivate M
L ->> A : Reserve Book
activate A
A --> L : ACK
deactivate A
note over A : processing reserve book
A --> M : Register Member
activate M
M --> A : ACK
deactivate M
@enduml