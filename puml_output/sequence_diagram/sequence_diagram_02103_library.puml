@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
participant "Librarian" as L
entity "Member" as M
actor "Admin" as A
M -> A : Borrow Book
A --> M : Renew Loan
A -> M : Search Catalog
A -> L : Pay Fine
activate L
L --> A : ACK
deactivate L
A -> M : Reserve Book
activate M
M --> A : ACK
deactivate M
M -> L : Register Member
M ->> L : Return Book
note over L : processing return book
@enduml