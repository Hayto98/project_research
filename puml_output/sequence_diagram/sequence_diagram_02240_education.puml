@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
control "Parent" as P
participant "Student" as S
entity "Registrar" as R
P ->> R : Borrow Book
activate R
R --> P : ACK
deactivate R
note over R : processing borrow book
R ->> P : Grade Exam
activate P
P --> R : ACK
deactivate P
P ->> S : Issue Certificate
S --> P : Take Attendance
activate P
P --> S : ACK
deactivate P
@enduml