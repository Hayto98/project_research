@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
boundary "Lab Technician" as LT
participant "Patient" as P
control "Insurance Provider" as IP
LT ->> IP : Discharge Patient
P --> LT : Update Medical Record
IP ->> LT : Book Appointment
activate LT
LT --> IP : ACK
deactivate LT
note over LT : processing book appointment
P -> LT : Examine Patient
LT ->> P : Issue Prescription
note over P : processing issue prescription
IP --> LT : Admit Patient
@enduml