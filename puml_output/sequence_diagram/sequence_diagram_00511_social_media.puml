@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
control "Moderator" as M
boundary "Admin" as A
participant "User" as U
actor "Advertiser" as A2
M -> U : Send Message
activate U
U --> M : ACK
deactivate U
U ->> A2 : Edit Profile
activate A2
A2 --> U : ACK
deactivate A2
U -> A : Create Post
note over A : processing create post
U -> A2 : Share Post
M ->> A : Follow User
note over A : processing follow user
M --> A : Comment
note over A : processing comment
@enduml