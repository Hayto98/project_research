@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
participant "Receptionist" as R
actor "Doctor" as D
actor "Lab Technician" as LT
D --> LT : Discharge Patient
R -> LT : Run Lab Test
note over LT : processing run lab test
D --> R : Book Appointment
D --> R : Examine Patient
note over R : processing examine patient
@enduml