@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
control "Teacher" as T
boundary "Admin" as A
actor "Student" as S
S ->> A : View Schedule
note over A : processing view schedule
A ->> T : Issue Certificate
S -> T : Submit Assignment
note over T : processing submit assignment
A -> T : Take Attendance
activate T
T --> A : ACK
deactivate T
T ->> A : Borrow Book
note over A : processing borrow book
@enduml