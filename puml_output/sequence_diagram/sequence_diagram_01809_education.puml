@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
control "Admin" as A
actor "Registrar" as R
participant "Parent" as P
participant "Librarian" as L
R ->> P : Issue Certificate
R ->> L : Submit Assignment
R -> A : Register Student
activate A
A --> R : ACK
deactivate A
L --> P : Grade Exam
activate P
P --> L : ACK
deactivate P
R -> A : View Schedule
R ->> A : Enroll Course
activate A
A --> R : ACK
deactivate A
L --> P : Borrow Book
@enduml