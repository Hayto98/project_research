@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
actor "Moderator" as M
control "Advertiser" as A
control "Admin" as A2
actor "User" as U
A -> M : Like Post
A -> A2 : Report Content
activate A2
A2 --> A : ACK
deactivate A2
U ->> M : Create Post
U ->> A : Edit Profile
note over A : processing edit profile
A2 ->> M : Comment
note over M : processing comment
@enduml