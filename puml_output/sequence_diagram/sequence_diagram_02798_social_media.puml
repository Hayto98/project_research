@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
entity "User" as U
control "Admin" as A
entity "Advertiser" as A2
participant "Moderator" as M
U --> A2 : Report Content
activate A2
A2 --> U : ACK
deactivate A2
A2 ->> M : Create Post
A2 --> U : Follow User
activate U
U --> A2 : ACK
deactivate U
note over U : processing follow user
M ->> A : Comment
note over A : processing comment
U -> A : Share Post
activate A
A --> U : ACK
deactivate A
U -> A : Edit Profile
M ->> A : Send Message
@enduml