@startuml
skinparam defaultFontSize 11
control "Patient" as P
control "Receptionist" as R
control "Lab Technician" as LT
participant "Nurse" as N
entity "Doctor" as D
D -> LT : Run Lab Test
activate LT
LT --> D : ACK
deactivate LT
note over LT : processing run lab test
LT --> N : Issue Prescription
activate N
N --> LT : ACK
deactivate N
note over N : processing issue prescription
N ->> R : Book Appointment
D ->> R : Update Medical Record
activate R
R --> D : ACK
deactivate R
@enduml