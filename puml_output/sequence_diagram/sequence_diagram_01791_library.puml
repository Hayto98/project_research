@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
actor "Librarian" as L
participant "Member" as M
control "Admin" as A
L -> M : Reserve Book
activate M
M --> L : ACK
deactivate M
L --> M : Search Catalog
activate M
M --> L : ACK
deactivate M
A -> M : Pay Fine
activate M
M --> A : ACK
deactivate M
M -> A : Add New Book
activate A
A --> M : ACK
deactivate A
note over A : processing add new book
@enduml