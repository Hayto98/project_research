@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
actor "Admin" as A
boundary "Librarian" as L
entity "Member" as M
A -> L : Return Book
activate L
L --> A : ACK
deactivate L
M -> A : Reserve Book
activate A
A --> M : ACK
deactivate A
A -> L : Add New Book
L ->> A : Register Member
L -> A : Borrow Book
note over A : processing borrow book
A --> M : Pay Fine
@enduml