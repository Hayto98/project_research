@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
participant "Insurance Provider" as IP
participant "Nurse" as N
participant "Lab Technician" as LT
N --> IP : Issue Prescription
note over IP : processing issue prescription
LT ->> N : Process Insurance Claim
LT -> IP : Discharge Patient
IP ->> N : Examine Patient
@enduml