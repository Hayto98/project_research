@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
participant "Registrar" as R
actor "Parent" as P
participant "Teacher" as T
P ->> T : Take Attendance
R -> T : Borrow Book
note over T : processing borrow book
T -> R : Enroll Course
note over R : processing enroll course
P -> R : Submit Assignment
activate R
R --> P : ACK
deactivate R
@enduml