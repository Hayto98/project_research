@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
entity "Member" as M
boundary "Librarian" as L
actor "Admin" as A
M ->> L : Return Book
L --> M : Search Catalog
activate M
M --> L : ACK
deactivate M
L --> A : Reserve Book
activate A
A --> L : ACK
deactivate A
A ->> L : Pay Fine
activate L
L --> A : ACK
deactivate L
L -> A : Renew Loan
M --> L : Add New Book
@enduml