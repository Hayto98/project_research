@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
actor "Guest" as G
boundary "Chef" as C
control "Housekeeper" as H
entity "Receptionist" as R
boundary "Manager" as M
G -> H : Process Payment
R --> M : Check Out
M --> C : Request Service
activate C
C --> M : ACK
deactivate C
note over C : processing request service
H -> M : Cancel Reservation
G --> R : Order Room Service
@enduml