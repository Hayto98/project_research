@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
entity "Chef" as C
entity "Guest" as G
actor "Housekeeper" as H
control "Receptionist" as R
H -> G : Cancel Reservation
H ->> C : Book Room
note over C : processing book room
G -> R : Order Room Service
note over R : processing order room service
R -> C : Clean Room
R -> G : Check Out
note over G : processing check out
@enduml