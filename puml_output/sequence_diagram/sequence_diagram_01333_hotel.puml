@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
control "Chef" as C
boundary "Guest" as G
participant "Manager" as M
M -> C : Order Room Service
activate C
C --> M : ACK
deactivate C
G --> C : Clean Room
C --> M : Process Payment
G ->> M : Book Room
C -> G : Check Out
G -> M : Check In
activate M
M --> G : ACK
deactivate M
@enduml