@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
actor "User" as U
control "Admin" as A
entity "Advertiser" as A2
U -> A : Report Content
U -> A2 : Create Post
activate A2
A2 --> U : ACK
deactivate A2
A ->> A2 : Share Post
activate A2
A2 --> A : ACK
deactivate A2
U ->> A : Edit Profile
activate A
A --> U : ACK
deactivate A
A -> A2 : Follow User
@enduml