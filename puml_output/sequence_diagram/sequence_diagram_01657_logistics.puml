@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
participant "Fleet Manager" as FM
boundary "Warehouse Staff" as WS
participant "Customer" as C
boundary "Driver" as D
actor "Dispatcher" as D2
C -> WS : Update Inventory
D ->> FM : Fuel Vehicle
C --> D : Load Package
C --> D2 : Assign Route
D2 --> C : Report Issue
D -> C : Track Shipment
@enduml