@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
boundary "Admin" as A
actor "Librarian" as L
control "Member" as M
A --> L : Borrow Book
A --> M : Register Member
L ->> M : Reserve Book
note over M : processing reserve book
L ->> A : Search Catalog
note over A : processing search catalog
M -> L : Pay Fine
M -> A : Renew Loan
@enduml