@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
actor "Receptionist" as R
participant "Chef" as C
control "Housekeeper" as H
participant "Manager" as M
participant "Guest" as G
C --> M : Clean Room
M --> C : Request Service
activate C
C --> M : ACK
deactivate C
C ->> G : Cancel Reservation
H ->> R : Process Payment
note over R : processing process payment
@enduml