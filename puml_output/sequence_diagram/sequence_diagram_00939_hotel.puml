@startuml
skinparam monochrome true
control "Guest" as G
control "Chef" as C
actor "Manager" as M
entity "Receptionist" as R
C --> R : Cancel Reservation
activate R
R --> C : ACK
deactivate R
R --> C : Request Service
G ->> R : Book Room
note over R : processing book room
R --> C : Clean Room
@enduml