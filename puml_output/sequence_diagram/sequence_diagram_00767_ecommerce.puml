@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
participant "Delivery Service" as DS
actor "Payment Gateway" as PG
boundary "Customer" as C
entity "Seller" as S
actor "Admin" as A
DS ->> A : Add To Cart
A ->> S : Checkout
DS --> A : Manage Inventory
DS --> S : Apply Coupon
activate S
S --> DS : ACK
deactivate S
PG --> DS : Make Payment
activate DS
DS --> PG : ACK
deactivate DS
note over DS : processing make payment
@enduml