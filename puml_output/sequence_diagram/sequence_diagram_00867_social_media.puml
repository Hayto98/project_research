@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
boundary "Moderator" as M
boundary "Advertiser" as A
participant "User" as U
participant "Admin" as A2
U -> M : Send Message
M ->> U : Share Post
activate U
U --> M : ACK
deactivate U
note over U : processing share post
U --> A : Edit Profile
U -> A : Report Content
A --> M : Create Post
@enduml