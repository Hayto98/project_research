@startuml
skinparam defaultFontSize 11
entity "Librarian" as L
control "Admin" as A
boundary "Member" as M
M -> L : Search Catalog
L ->> M : Reserve Book
activate M
M --> L : ACK
deactivate M
M --> L : Pay Fine
activate L
L --> M : ACK
deactivate L
L --> A : Register Member
activate A
A --> L : ACK
deactivate A
A ->> M : Borrow Book
note over M : processing borrow book
A --> L : Add New Book
L -> M : Renew Loan
activate M
M --> L : ACK
deactivate M
@enduml