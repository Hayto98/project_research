@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
participant "Librarian" as L
entity "Member" as M
entity "Admin" as A
M --> A : Reserve Book
activate A
A --> M : ACK
deactivate A
L -> M : Add New Book
note over M : processing add new book
L ->> A : Pay Fine
activate A
A --> L : ACK
deactivate A
M ->> L : Borrow Book
activate L
L --> M : ACK
deactivate L
M -> L : Search Catalog
note over L : processing search catalog
@enduml