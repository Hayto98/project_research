@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
boundary "Receptionist" as R
participant "Guest" as G
control "Manager" as M
entity "Housekeeper" as H
entity "Chef" as C
R ->> M : Cancel Reservation
G -> R : Check In
activate R
R --> G : ACK
deactivate R
H -> M : Book Room
C --> G : Check Out
@enduml