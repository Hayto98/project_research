@startuml
skinparam defaultFontSize 11
actor "Receptionist" as R
actor "Manager" as M
entity "Chef" as C
entity "Housekeeper" as H
boundary "Guest" as G
G -> H : Cancel Reservation
C -> H : Check Out
activate H
H --> C : ACK
deactivate H
H -> G : Book Room
H --> G : Order Room Service
activate G
G --> H : ACK
deactivate G
@enduml