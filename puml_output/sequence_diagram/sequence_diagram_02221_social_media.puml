@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
actor "Advertiser" as A
boundary "Admin" as A2
control "User" as U
A2 -> A : Edit Profile
activate A
A --> A2 : ACK
deactivate A
A2 ->> U : Like Post
activate U
U --> A2 : ACK
deactivate U
U ->> A : Comment
U ->> A : Report Content
activate A
A --> U : ACK
deactivate A
note over A : processing report content
A2 ->> A : Follow User
activate A
A --> A2 : ACK
deactivate A
note over A : processing follow user
@enduml