@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
actor "User" as U
actor "Advertiser" as A
boundary "Admin" as A2
participant "Moderator" as M
A2 ->> A : Share Post
activate A
A --> A2 : ACK
deactivate A
U --> M : Report Content
M -> A2 : Comment
M --> A : Send Message
@enduml