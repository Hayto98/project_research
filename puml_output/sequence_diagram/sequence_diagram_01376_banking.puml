@startuml
skinparam monochrome true
participant "Branch Manager" as BM
participant "Account Holder" as AH
boundary "Bank Teller" as BT
participant "Auditor" as A
AH -> BM : Withdraw Cash
note over BM : processing withdraw cash
A ->> BM : Apply For Loan
BM -> A : Open Account
BT -> BM : Pay Bill
activate BM
BM --> BT : ACK
deactivate BM
A --> BM : Deposit Money
@enduml