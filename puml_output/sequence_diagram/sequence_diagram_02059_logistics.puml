@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
participant "Dispatcher" as D
entity "Driver" as D2
entity "Warehouse Staff" as WS
actor "Fleet Manager" as FM
FM -> WS : Schedule Pickup
note over WS : processing schedule pickup
D2 -> D : Report Issue
FM --> D : Deliver Package
note over D : processing deliver package
D2 -> FM : Load Package
@enduml