@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
entity "Teacher" as T
actor "Parent" as P
boundary "Admin" as A
A ->> T : Take Attendance
note over T : processing take attendance
A -> P : Grade Exam
A ->> P : Register Student
note over P : processing register student
P --> T : Issue Certificate
activate T
T --> P : ACK
deactivate T
note over T : processing issue certificate
P -> T : View Schedule
note over T : processing view schedule
@enduml