@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
participant "Teacher" as T
participant "Parent" as P
participant "Admin" as A
entity "Student" as S
entity "Registrar" as R
R ->> T : Grade Exam
A ->> T : View Schedule
activate T
T --> A : ACK
deactivate T
S --> R : Take Attendance
A ->> P : Issue Certificate
A ->> R : Register Student
P --> R : Submit Assignment
@enduml