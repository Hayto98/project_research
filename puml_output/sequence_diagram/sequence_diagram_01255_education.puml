@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
entity "Teacher" as T
participant "Parent" as P
control "Admin" as A
actor "Librarian" as L
T ->> A : Enroll Course
activate A
A --> T : ACK
deactivate A
P -> A : Issue Certificate
note over A : processing issue certificate
T --> L : Borrow Book
activate L
L --> T : ACK
deactivate L
note over L : processing borrow book
T --> L : View Schedule
note over L : processing view schedule
@enduml