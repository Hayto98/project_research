@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
entity "Account Holder" as AH
participant "Bank Teller" as BT
control "ATM" as A
participant "Auditor" as A2
actor "Branch Manager" as BM
BT --> BM : Open Account
activate BM
BM --> BT : ACK
deactivate BM
BT -> A : Deposit Money
activate A
A --> BT : ACK
deactivate A
note over A : processing deposit money
A --> AH : Block Card
activate AH
AH --> A : ACK
deactivate AH
BM -> A : View Statement
A ->> BT : Pay Bill
A2 ->> BT : Apply For Loan
BT --> BM : Transfer Funds
note over BM : processing transfer funds
@enduml