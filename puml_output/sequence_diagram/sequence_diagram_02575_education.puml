@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
participant "Registrar" as R
actor "Student" as S
control "Librarian" as L
participant "Parent" as P
L -> R : Issue Certificate
activate R
R --> L : ACK
deactivate R
P --> R : Borrow Book
note over R : processing borrow book
L --> P : Enroll Course
L --> P : Grade Exam
S -> P : Register Student
activate P
P --> S : ACK
deactivate P
@enduml