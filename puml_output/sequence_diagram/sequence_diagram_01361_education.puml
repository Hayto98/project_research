@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
actor "Teacher" as T
entity "Student" as S
control "Parent" as P
S -> P : Grade Exam
T -> P : Enroll Course
T -> S : View Schedule
activate S
S --> T : ACK
deactivate S
note over S : processing view schedule
T --> S : Borrow Book
note over S : processing borrow book
@enduml