@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
control "Member" as M
control "Admin" as A
control "Librarian" as L
M --> L : Return Book
L --> M : Reserve Book
M -> A : Register Member
activate A
A --> M : ACK
deactivate A
L ->> A : Search Catalog
A --> L : Borrow Book
@enduml