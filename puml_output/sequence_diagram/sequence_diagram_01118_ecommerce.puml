@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
boundary "Admin" as A
control "Customer" as C
control "Delivery Service" as DS
control "Seller" as S
S ->> A : Checkout
DS -> C : Track Order
C ->> S : Browse Products
note over S : processing browse products
S --> DS : Add To Cart
S ->> DS : Cancel Order
@enduml