@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
actor "Librarian" as L
boundary "Student" as S
boundary "Parent" as P
entity "Admin" as A
P --> S : Submit Assignment
L --> A : View Schedule
activate A
A --> L : ACK
deactivate A
S --> L : Register Student
note over L : processing register student
L -> S : Take Attendance
S -> P : Borrow Book
L --> P : Enroll Course
note over P : processing enroll course
@enduml