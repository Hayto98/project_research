@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
boundary "Admin" as A
control "User" as U
entity "Advertiser" as A2
participant "Moderator" as M
U -> A2 : Report Content
A2 -> A : Send Message
activate A
A --> A2 : ACK
deactivate A
A2 -> M : Create Post
A -> U : Follow User
@enduml