@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
boundary "Insurance Provider" as IP
control "Doctor" as D
entity "Nurse" as N
actor "Receptionist" as R
D ->> IP : Issue Prescription
N -> D : Examine Patient
IP ->> D : Run Lab Test
D ->> R : Admit Patient
N ->> R : Book Appointment
@enduml