@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
entity "Chef" as C
actor "Receptionist" as R
control "Manager" as M
entity "Guest" as G
boundary "Housekeeper" as H
H ->> M : Process Payment
R ->> M : Check Out
M ->> C : Check In
C --> H : Request Service
G ->> M : Book Room
note over M : processing book room
R ->> G : Clean Room
R ->> H : Order Room Service
activate H
H --> R : ACK
deactivate H
@enduml