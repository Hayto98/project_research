@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
entity "Warehouse Staff" as WS
entity "Fleet Manager" as FM
entity "Customer" as C
FM ->> C : Report Issue
C ->> WS : Deliver Package
note over WS : processing deliver package
C --> WS : Track Shipment
FM --> WS : Assign Route
note over WS : processing assign route
@enduml