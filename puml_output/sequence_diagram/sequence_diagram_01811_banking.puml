@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
entity "Bank Teller" as BT
control "Account Holder" as AH
control "Auditor" as A
control "ATM" as A2
control "Branch Manager" as BM
BM -> BT : Pay Bill
A2 --> BM : Block Card
A2 ->> AH : Deposit Money
note over AH : processing deposit money
A2 ->> BT : Apply For Loan
A ->> AH : Transfer Funds
BT ->> A2 : Open Account
@enduml