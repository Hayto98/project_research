@startuml
skinparam monochrome true
skinparam defaultFontSize 11
actor "Nurse" as N
control "Insurance Provider" as IP
actor "Lab Technician" as LT
control "Doctor" as D
N ->> IP : Update Medical Record
IP --> LT : Admit Patient
N ->> LT : Issue Prescription
note over LT : processing issue prescription
LT --> D : Book Appointment
D --> IP : Process Insurance Claim
activate IP
IP --> D : ACK
deactivate IP
note over IP : processing process insurance claim
@enduml