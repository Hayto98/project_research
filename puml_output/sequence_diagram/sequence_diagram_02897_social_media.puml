@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
control "Advertiser" as A
control "Admin" as A2
actor "User" as U
A2 -> A : Follow User
U ->> A : Send Message
activate A
A --> U : ACK
deactivate A
A2 ->> U : Report Content
activate U
U --> A2 : ACK
deactivate U
U --> A2 : Share Post
activate A2
A2 --> U : ACK
deactivate A2
@enduml