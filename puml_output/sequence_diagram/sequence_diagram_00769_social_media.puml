@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
control "Advertiser" as A
control "User" as U
participant "Moderator" as M
U --> M : Send Message
A -> M : Like Post
U --> A : Report Content
A ->> U : Share Post
activate U
U --> A : ACK
deactivate U
U ->> A : Edit Profile
activate A
A --> U : ACK
deactivate A
M --> A : Create Post
activate A
A --> M : ACK
deactivate A
M ->> U : Comment
@enduml