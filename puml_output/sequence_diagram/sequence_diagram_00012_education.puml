@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
actor "Student" as S
participant "Teacher" as T
control "Parent" as P
entity "Librarian" as L
P --> T : Register Student
S --> P : Enroll Course
T --> S : View Schedule
P ->> T : Grade Exam
activate T
T --> P : ACK
deactivate T
P ->> L : Submit Assignment
activate L
L --> P : ACK
deactivate L
P -> L : Issue Certificate
@enduml