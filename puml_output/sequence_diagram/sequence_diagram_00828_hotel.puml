@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
participant "Housekeeper" as H
participant "Chef" as C
entity "Manager" as M
control "Guest" as G
C -> H : Clean Room
activate H
H --> C : ACK
deactivate H
G -> M : Book Room
H ->> G : Check Out
note over G : processing check out
G -> M : Process Payment
activate M
M --> G : ACK
deactivate M
note over M : processing process payment
G -> M : Check In
note over M : processing check in
C -> G : Cancel Reservation
H ->> G : Request Service
activate G
G --> H : ACK
deactivate G
@enduml