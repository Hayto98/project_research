@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
control "Insurance Provider" as IP
boundary "Doctor" as D
control "Patient" as P
boundary "Lab Technician" as LT
participant "Nurse" as N
N --> LT : Examine Patient
activate LT
LT --> N : ACK
deactivate LT
note over LT : processing examine patient
IP ->> N : Update Medical Record
N -> P : Book Appointment
IP -> D : Issue Prescription
activate D
D --> IP : ACK
deactivate D
D -> LT : Discharge Patient
activate LT
LT --> D : ACK
deactivate LT
N --> IP : Run Lab Test
LT -> IP : Admit Patient
@enduml