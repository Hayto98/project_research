@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
boundary "Customer" as C
boundary "Fleet Manager" as FM
participant "Driver" as D
FM -> D : Track Shipment
note over D : processing track shipment
C --> D : Deliver Package
D -> C : Assign Route
D ->> C : Load Package
FM --> C : Fuel Vehicle
note over C : processing fuel vehicle
@enduml