@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
actor "Account Holder" as AH
entity "ATM" as A
actor "Branch Manager" as BM
actor "Auditor" as A2
participant "Bank Teller" as BT
A2 --> AH : Open Account
note over AH : processing open account
A -> BM : Transfer Funds
BT ->> BM : View Statement
note over BM : processing view statement
BT --> A : Block Card
activate A
A --> BT : ACK
deactivate A
BT ->> A2 : Pay Bill
@enduml