@startuml
skinparam monochrome true
skinparam defaultFontSize 11
participant "Student" as S
actor "Teacher" as T
actor "Parent" as P
boundary "Admin" as A
A --> S : Issue Certificate
note over S : processing issue certificate
S --> T : Register Student
A --> T : Borrow Book
note over T : processing borrow book
A --> T : Enroll Course
activate T
T --> A : ACK
deactivate T
A ->> T : View Schedule
note over T : processing view schedule
@enduml