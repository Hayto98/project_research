@startuml
skinparam ArrowColor #555555
actor "Bank Teller" as BT
boundary "ATM" as A
actor "Auditor" as A2
entity "Branch Manager" as BM
A ->> BM : Open Account
activate BM
BM --> A : ACK
deactivate BM
A --> BM : View Statement
A ->> BT : Pay Bill
BT --> A2 : Transfer Funds
A2 --> BM : Apply For Loan
@enduml