@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
control "Admin" as A
entity "Librarian" as L
participant "Member" as M
M --> A : Reserve Book
activate A
A --> M : ACK
deactivate A
M ->> A : Return Book
activate A
A --> M : ACK
deactivate A
M --> L : Search Catalog
A ->> M : Register Member
L -> A : Pay Fine
M -> A : Renew Loan
L ->> M : Borrow Book
@enduml