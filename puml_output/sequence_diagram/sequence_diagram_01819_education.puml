@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
participant "Librarian" as L
participant "Admin" as A
entity "Parent" as P
entity "Student" as S
control "Teacher" as T
A --> P : Borrow Book
S -> P : Take Attendance
activate P
P --> S : ACK
deactivate P
A --> L : View Schedule
A ->> L : Enroll Course
@enduml