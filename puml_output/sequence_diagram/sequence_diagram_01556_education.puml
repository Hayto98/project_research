@startuml

actor "Student" as S
actor "Librarian" as L
actor "Teacher" as T
control "Registrar" as R
R -> T : Submit Assignment
activate T
T --> R : ACK
deactivate T
S --> L : Issue Certificate
note over L : processing issue certificate
L -> R : Grade Exam
activate R
R --> L : ACK
deactivate R
R -> T : Borrow Book
T -> R : Enroll Course
activate R
R --> T : ACK
deactivate R
note over R : processing enroll course
@enduml