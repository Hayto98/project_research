@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
participant "Member" as M
participant "Admin" as A
boundary "Librarian" as L
L --> A : Search Catalog
M --> A : Reserve Book
activate A
A --> M : ACK
deactivate A
A --> L : Add New Book
activate L
L --> A : ACK
deactivate L
M ->> A : Register Member
activate A
A --> M : ACK
deactivate A
A ->> M : Renew Loan
note over M : processing renew loan
@enduml