@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
actor "Student" as S
participant "Registrar" as R
boundary "Librarian" as L
control "Admin" as A
participant "Parent" as P
S -> P : Enroll Course
P ->> S : Submit Assignment
activate S
S --> P : ACK
deactivate S
A ->> S : Borrow Book
S --> P : Issue Certificate
@enduml