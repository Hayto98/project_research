@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
actor "Warehouse Staff" as WS
participant "Fleet Manager" as FM
entity "Dispatcher" as D
WS --> D : Schedule Pickup
D -> WS : Update Inventory
FM --> WS : Assign Route
WS -> D : Track Shipment
activate D
D --> WS : ACK
deactivate D
FM ->> WS : Load Package
activate WS
WS --> FM : ACK
deactivate WS
@enduml