@startuml
skinparam monochrome true
skinparam ArrowColor #555555
entity "Seller" as S
control "Payment Gateway" as PG
control "Delivery Service" as DS
entity "Customer" as C
boundary "Admin" as A
S ->> A : Checkout
note over A : processing checkout
DS -> A : Write Review
activate A
A --> DS : ACK
deactivate A
note over A : processing write review
PG ->> S : Add To Cart
activate S
S --> PG : ACK
deactivate S
A --> DS : Track Order
note over DS : processing track order
@enduml