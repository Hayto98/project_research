@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
participant "Insurance Provider" as IP
entity "Lab Technician" as LT
participant "Nurse" as N
participant "Patient" as P
boundary "Doctor" as D
P --> D : Book Appointment
D ->> N : Discharge Patient
P --> D : Issue Prescription
activate D
D --> P : ACK
deactivate D
P -> D : Update Medical Record
LT ->> P : Examine Patient
@enduml