@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
entity "Nurse" as N
boundary "Lab Technician" as LT
control "Doctor" as D
participant "Receptionist" as R
boundary "Insurance Provider" as IP
N ->> IP : Examine Patient
N --> IP : Discharge Patient
LT -> R : Issue Prescription
activate R
R --> LT : ACK
deactivate R
D ->> LT : Run Lab Test
activate LT
LT --> D : ACK
deactivate LT
R ->> IP : Admit Patient
activate IP
IP --> R : ACK
deactivate IP
note over IP : processing admit patient
D --> R : Process Insurance Claim
activate R
R --> D : ACK
deactivate R
D --> IP : Update Medical Record
activate IP
IP --> D : ACK
deactivate IP
@enduml