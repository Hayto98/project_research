@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
boundary "Admin" as A
actor "Registrar" as R
entity "Teacher" as T
A --> T : Borrow Book
activate T
T --> A : ACK
deactivate T
T -> A : Take Attendance
A --> T : Issue Certificate
R --> A : Submit Assignment
R ->> T : Enroll Course
A -> R : Grade Exam
A ->> T : View Schedule
@enduml