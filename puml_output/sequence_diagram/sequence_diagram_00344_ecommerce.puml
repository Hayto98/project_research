@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
boundary "Customer" as C
entity "Admin" as A
control "Delivery Service" as DS
participant "Seller" as S
participant "Payment Gateway" as PG
A --> C : Write Review
activate C
C --> A : ACK
deactivate C
S -> PG : Make Payment
S --> DS : Cancel Order
activate DS
DS --> S : ACK
deactivate DS
DS ->> A : Checkout
note over A : processing checkout
PG ->> A : Apply Coupon
activate A
A --> PG : ACK
deactivate A
@enduml