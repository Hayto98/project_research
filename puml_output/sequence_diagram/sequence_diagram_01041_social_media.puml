@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
boundary "Advertiser" as A
actor "Admin" as A2
participant "User" as U
U -> A : Follow User
note over A : processing follow user
A -> A2 : Like Post
A2 --> U : Comment
A --> A2 : Report Content
U ->> A2 : Send Message
activate A2
A2 --> U : ACK
deactivate A2
A -> A2 : Create Post
note over A2 : processing create post
@enduml