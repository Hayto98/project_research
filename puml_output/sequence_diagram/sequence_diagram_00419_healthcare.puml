@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
participant "Doctor" as D
actor "Insurance Provider" as IP
control "Lab Technician" as LT
boundary "Receptionist" as R
R -> D : Run Lab Test
note over D : processing run lab test
IP --> D : Issue Prescription
activate D
D --> IP : ACK
deactivate D
LT ->> R : Examine Patient
R ->> IP : Update Medical Record
activate IP
IP --> R : ACK
deactivate IP
note over IP : processing update medical record
LT -> IP : Process Insurance Claim
@enduml