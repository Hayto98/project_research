@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
entity "Advertiser" as A
entity "Moderator" as M
entity "Admin" as A2
actor "User" as U
M --> U : Comment
A --> A2 : Edit Profile
note over A2 : processing edit profile
A2 --> A : Follow User
note over A : processing follow user
A --> A2 : Share Post
activate A2
A2 --> A : ACK
deactivate A2
U --> M : Like Post
@enduml