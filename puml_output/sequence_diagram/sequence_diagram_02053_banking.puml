@startuml
skinparam monochrome true
skinparam defaultFontSize 13
participant "Branch Manager" as BM
control "ATM" as A
boundary "Account Holder" as AH
boundary "Bank Teller" as BT
AH -> BM : View Statement
BT ->> AH : Transfer Funds
note over AH : processing transfer funds
A ->> BM : Block Card
A ->> AH : Withdraw Cash
@enduml