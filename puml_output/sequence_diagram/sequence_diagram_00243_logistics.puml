@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
participant "Dispatcher" as D
participant "Customer" as C
boundary "Driver" as D2
D ->> C : Track Shipment
C -> D : Update Inventory
activate D
D --> C : ACK
deactivate D
D --> D2 : Deliver Package
activate D2
D2 --> D : ACK
deactivate D2
note over D2 : processing deliver package
D2 -> D : Load Package
D -> D2 : Assign Route
D2 ->> D : Schedule Pickup
C --> D2 : Report Issue
note over D2 : processing report issue
@enduml