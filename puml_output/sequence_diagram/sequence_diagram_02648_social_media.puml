@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
actor "Moderator" as M
entity "Admin" as A
actor "User" as U
entity "Advertiser" as A2
A2 --> U : Comment
M --> A : Follow User
activate A
A --> M : ACK
deactivate A
A2 ->> M : Create Post
activate M
M --> A2 : ACK
deactivate M
M ->> A2 : Report Content
@enduml