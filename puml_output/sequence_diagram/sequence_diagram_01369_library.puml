@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
actor "Librarian" as L
entity "Member" as M
actor "Admin" as A
M -> A : Return Book
A -> L : Reserve Book
activate L
L --> A : ACK
deactivate L
A ->> L : Search Catalog
activate L
L --> A : ACK
deactivate L
M -> L : Register Member
activate L
L --> M : ACK
deactivate L
note over L : processing register member
@enduml