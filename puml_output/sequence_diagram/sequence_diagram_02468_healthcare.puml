@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
control "Nurse" as N
boundary "Lab Technician" as LT
participant "Insurance Provider" as IP
N ->> IP : Issue Prescription
IP -> N : Discharge Patient
note over N : processing discharge patient
LT -> N : Admit Patient
note over N : processing admit patient
LT -> IP : Book Appointment
N ->> LT : Update Medical Record
activate LT
LT --> N : ACK
deactivate LT
IP --> LT : Examine Patient
@enduml