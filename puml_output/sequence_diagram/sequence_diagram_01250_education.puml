@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
entity "Teacher" as T
participant "Admin" as A
boundary "Registrar" as R
actor "Parent" as P
boundary "Student" as S
S --> R : View Schedule
A ->> S : Issue Certificate
S -> T : Borrow Book
activate T
T --> S : ACK
deactivate T
S ->> T : Submit Assignment
R ->> P : Grade Exam
activate P
P --> R : ACK
deactivate P
A -> T : Register Student
activate T
T --> A : ACK
deactivate T
T --> A : Enroll Course
activate A
A --> T : ACK
deactivate A
@enduml