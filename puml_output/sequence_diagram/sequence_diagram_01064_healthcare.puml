@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
actor "Receptionist" as R
entity "Insurance Provider" as IP
actor "Nurse" as N
control "Patient" as P
P --> R : Run Lab Test
activate R
R --> P : ACK
deactivate R
note over R : processing run lab test
P --> N : Update Medical Record
note over N : processing update medical record
R -> IP : Issue Prescription
IP ->> P : Examine Patient
IP -> P : Book Appointment
R --> IP : Discharge Patient
@enduml