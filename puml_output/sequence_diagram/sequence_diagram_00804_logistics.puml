@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
boundary "Dispatcher" as D
actor "Customer" as C
control "Fleet Manager" as FM
boundary "Driver" as D2
control "Warehouse Staff" as WS
C -> D : Assign Route
activate D
D --> C : ACK
deactivate D
C ->> FM : Update Inventory
activate FM
FM --> C : ACK
deactivate FM
D2 -> WS : Report Issue
activate WS
WS --> D2 : ACK
deactivate WS
WS ->> C : Schedule Pickup
note over C : processing schedule pickup
D --> FM : Load Package
note over FM : processing load package
D --> WS : Fuel Vehicle
@enduml