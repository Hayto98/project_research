@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
boundary "Admin" as A
actor "Librarian" as L
boundary "Member" as M
A ->> L : Borrow Book
L -> A : Renew Loan
activate A
A --> L : ACK
deactivate A
note over A : processing renew loan
A --> L : Search Catalog
activate L
L --> A : ACK
deactivate L
M -> A : Return Book
activate A
A --> M : ACK
deactivate A
note over A : processing return book
@enduml