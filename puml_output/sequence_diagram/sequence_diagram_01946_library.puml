@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
entity "Librarian" as L
actor "Admin" as A
actor "Member" as M
L ->> A : Return Book
M ->> A : Add New Book
M --> L : Renew Loan
activate L
L --> M : ACK
deactivate L
note over L : processing renew loan
A ->> L : Search Catalog
@enduml