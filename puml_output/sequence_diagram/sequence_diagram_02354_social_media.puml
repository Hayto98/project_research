@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
actor "Moderator" as M
entity "Admin" as A
boundary "Advertiser" as A2
A --> M : Create Post
M ->> A2 : Edit Profile
activate A2
A2 --> M : ACK
deactivate A2
A --> M : Comment
A2 ->> A : Follow User
A ->> A2 : Report Content
activate A2
A2 --> A : ACK
deactivate A2
A2 --> A : Share Post
@enduml