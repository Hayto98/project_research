@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
actor "Auditor" as A
boundary "ATM" as A2
actor "Account Holder" as AH
actor "Branch Manager" as BM
A2 ->> A : Pay Bill
note over A : processing pay bill
AH --> A2 : View Statement
A2 -> AH : Apply For Loan
AH --> BM : Withdraw Cash
note over BM : processing withdraw cash
A -> BM : Open Account
@enduml