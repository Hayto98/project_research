@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
control "Customer" as C
entity "Seller" as S
control "Admin" as A
A --> C : Track Order
note over C : processing track order
A -> S : Checkout
activate S
S --> A : ACK
deactivate S
A --> S : Cancel Order
A --> S : Manage Inventory
@enduml