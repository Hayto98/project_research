@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
participant "Member" as M
actor "Librarian" as L
participant "Admin" as A
M -> L : Pay Fine
M -> L : Search Catalog
activate L
L --> M : ACK
deactivate L
L ->> A : Return Book
activate A
A --> L : ACK
deactivate A
M ->> A : Register Member
activate A
A --> M : ACK
deactivate A
L ->> M : Add New Book
activate M
M --> L : ACK
deactivate M
note over M : processing add new book
@enduml