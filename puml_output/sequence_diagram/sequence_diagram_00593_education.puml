@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
actor "Parent" as P
entity "Librarian" as L
participant "Teacher" as T
control "Admin" as A
boundary "Student" as S
P -> L : View Schedule
note over L : processing view schedule
S --> A : Grade Exam
L -> A : Submit Assignment
activate A
A --> L : ACK
deactivate A
note over A : processing submit assignment
L --> T : Borrow Book
A -> S : Enroll Course
note over S : processing enroll course
A -> P : Register Student
activate P
P --> A : ACK
deactivate P
A --> S : Issue Certificate
@enduml