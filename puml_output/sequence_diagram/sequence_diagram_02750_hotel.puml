@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
actor "Manager" as M
actor "Receptionist" as R
actor "Chef" as C
control "Housekeeper" as H
actor "Guest" as G
H -> C : Request Service
activate C
C --> H : ACK
deactivate C
C -> R : Process Payment
activate R
R --> C : ACK
deactivate R
R --> G : Clean Room
activate G
G --> R : ACK
deactivate G
G ->> M : Order Room Service
@enduml