@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
participant "Librarian" as L
entity "Student" as S
entity "Parent" as P
control "Teacher" as T
P -> T : Enroll Course
S ->> T : Register Student
S -> P : View Schedule
S -> L : Take Attendance
activate L
L --> S : ACK
deactivate L
@enduml