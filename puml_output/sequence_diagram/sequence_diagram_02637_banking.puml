@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
boundary "Account Holder" as AH
actor "Branch Manager" as BM
actor "ATM" as A
control "Bank Teller" as BT
AH --> BT : Transfer Funds
activate BT
BT --> AH : ACK
deactivate BT
A ->> BT : Open Account
BT ->> AH : Withdraw Cash
A -> AH : Pay Bill
BM -> AH : View Statement
BT --> BM : Deposit Money
activate BM
BM --> BT : ACK
deactivate BM
@enduml