@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
entity "Librarian" as L
entity "Admin" as A
entity "Member" as M
L -> A : Reserve Book
A --> L : Pay Fine
note over L : processing pay fine
M --> A : Borrow Book
activate A
A --> M : ACK
deactivate A
A --> M : Add New Book
note over M : processing add new book
L ->> M : Return Book
activate M
M --> L : ACK
deactivate M
@enduml