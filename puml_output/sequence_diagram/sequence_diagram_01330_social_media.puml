@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
participant "Advertiser" as A
entity "User" as U
actor "Admin" as A2
A2 --> U : Comment
A2 --> U : Create Post
A -> A2 : Edit Profile
activate A2
A2 --> A : ACK
deactivate A2
U --> A2 : Follow User
activate A2
A2 --> U : ACK
deactivate A2
@enduml