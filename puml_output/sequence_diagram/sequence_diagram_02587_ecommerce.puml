@startuml
skinparam monochrome true
skinparam ArrowColor #555555
entity "Admin" as A
control "Seller" as S
entity "Delivery Service" as DS
entity "Payment Gateway" as PG
boundary "Customer" as C
C --> S : Make Payment
DS -> PG : Checkout
C -> S : Add To Cart
S --> DS : Track Order
note over DS : processing track order
@enduml