@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
boundary "Moderator" as M
entity "Admin" as A
control "User" as U
actor "Advertiser" as A2
A2 ->> M : Like Post
A --> M : Comment
A2 --> A : Edit Profile
U --> A2 : Follow User
activate A2
A2 --> U : ACK
deactivate A2
A -> A2 : Send Message
note over A2 : processing send message
@enduml