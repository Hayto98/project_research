@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
participant "Admin" as A
entity "Member" as M
actor "Librarian" as L
A ->> M : Return Book
L --> M : Pay Fine
L --> A : Add New Book
A -> L : Search Catalog
A -> L : Register Member
activate L
L --> A : ACK
deactivate L
L --> A : Reserve Book
@enduml