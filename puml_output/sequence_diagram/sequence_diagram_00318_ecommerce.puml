@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
boundary "Payment Gateway" as PG
control "Delivery Service" as DS
control "Seller" as S
PG ->> DS : Track Order
S --> PG : Browse Products
DS -> S : Apply Coupon
S -> DS : Checkout
S ->> DS : Manage Inventory
DS ->> S : Add To Cart
note over S : processing add to cart
@enduml