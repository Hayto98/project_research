@startuml
skinparam defaultFontSize 11
actor "Admin" as A
participant "Member" as M
entity "Librarian" as L
M ->> A : Register Member
activate A
A --> M : ACK
deactivate A
A ->> M : Borrow Book
note over M : processing borrow book
M -> A : Add New Book
note over A : processing add new book
M ->> A : Search Catalog
M ->> A : Return Book
A ->> L : Pay Fine
M ->> L : Renew Loan
activate L
L --> M : ACK
deactivate L
@enduml