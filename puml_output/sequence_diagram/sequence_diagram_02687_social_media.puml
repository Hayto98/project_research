@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
control "Advertiser" as A
actor "User" as U
entity "Admin" as A2
A2 -> A : Comment
U --> A2 : Edit Profile
activate A2
A2 --> U : ACK
deactivate A2
note over A2 : processing edit profile
A ->> U : Share Post
note over U : processing share post
A --> A2 : Send Message
A -> A2 : Follow User
note over A2 : processing follow user
@enduml