@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
actor "Student" as S
actor "Parent" as P
entity "Admin" as A
control "Teacher" as T
participant "Registrar" as R
R -> S : Enroll Course
T -> R : Grade Exam
note over R : processing grade exam
S -> R : Borrow Book
activate R
R --> S : ACK
deactivate R
S --> A : Register Student
activate A
A --> S : ACK
deactivate A
@enduml