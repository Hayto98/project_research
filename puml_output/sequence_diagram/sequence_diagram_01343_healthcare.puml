@startuml
skinparam defaultFontSize 13
boundary "Patient" as P
entity "Nurse" as N
actor "Doctor" as D
N -> D : Issue Prescription
N ->> D : Book Appointment
activate D
D --> N : ACK
deactivate D
note over D : processing book appointment
N -> D : Discharge Patient
note over D : processing discharge patient
P ->> N : Examine Patient
@enduml