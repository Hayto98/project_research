@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
actor "Auditor" as A
entity "Account Holder" as AH
actor "Bank Teller" as BT
entity "ATM" as A2
A -> BT : View Statement
AH --> A : Deposit Money
activate A
A --> AH : ACK
deactivate A
AH --> A2 : Withdraw Cash
BT -> A2 : Pay Bill
activate A2
A2 --> BT : ACK
deactivate A2
@enduml