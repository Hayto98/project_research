@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
boundary "Member" as M
control "Librarian" as L
participant "Admin" as A
A ->> M : Borrow Book
L ->> A : Reserve Book
activate A
A --> L : ACK
deactivate A
note over A : processing reserve book
A ->> L : Register Member
activate L
L --> A : ACK
deactivate L
note over L : processing register member
L --> M : Search Catalog
@enduml