@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
actor "Admin" as A
participant "Librarian" as L
entity "Member" as M
M --> A : Reserve Book
L --> A : Add New Book
note over A : processing add new book
M --> A : Register Member
note over A : processing register member
A --> L : Return Book
note over L : processing return book
M -> A : Renew Loan
activate A
A --> M : ACK
deactivate A
@enduml