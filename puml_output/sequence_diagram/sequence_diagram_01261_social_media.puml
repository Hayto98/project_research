@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
control "Admin" as A
actor "Moderator" as M
actor "User" as U
actor "Advertiser" as A2
A2 ->> M : Comment
activate M
M --> A2 : ACK
deactivate M
A2 --> M : Create Post
M --> A2 : Edit Profile
U -> A2 : Like Post
note over A2 : processing like post
A2 -> U : Report Content
A2 ->> M : Share Post
note over M : processing share post
@enduml