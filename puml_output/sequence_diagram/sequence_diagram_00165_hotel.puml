@startuml
skinparam monochrome true
skinparam defaultFontSize 11
participant "Receptionist" as R
participant "Manager" as M
entity "Chef" as C
actor "Guest" as G
boundary "Housekeeper" as H
H --> G : Clean Room
C ->> G : Process Payment
note over G : processing process payment
M -> G : Check In
C --> R : Cancel Reservation
activate R
R --> C : ACK
deactivate R
M -> C : Check Out
note over C : processing check out
G -> R : Request Service
note over R : processing request service
M ->> C : Book Room
note over C : processing book room
@enduml