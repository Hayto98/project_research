@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
entity "Moderator" as M
control "Advertiser" as A
participant "User" as U
participant "Admin" as A2
M -> A : Edit Profile
activate A
A --> M : ACK
deactivate A
A2 -> U : Send Message
activate U
U --> A2 : ACK
deactivate U
A2 --> U : Like Post
A -> U : Follow User
M -> A : Comment
activate A
A --> M : ACK
deactivate A
note over A : processing comment
@enduml