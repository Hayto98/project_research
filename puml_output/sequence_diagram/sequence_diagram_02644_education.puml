@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
boundary "Teacher" as T
participant "Librarian" as L
participant "Student" as S
S -> L : Enroll Course
activate L
L --> S : ACK
deactivate L
L --> S : Take Attendance
S --> L : Register Student
L --> T : Grade Exam
activate T
T --> L : ACK
deactivate T
S -> T : View Schedule
activate T
T --> S : ACK
deactivate T
S ->> T : Submit Assignment
L -> T : Borrow Book
@enduml