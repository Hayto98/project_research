@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
entity "Delivery Service" as DS
entity "Admin" as A
boundary "Seller" as S
A -> S : Cancel Order
activate S
S --> A : ACK
deactivate S
A -> S : Browse Products
activate S
S --> A : ACK
deactivate S
note over S : processing browse products
S --> A : Write Review
A ->> DS : Track Order
S ->> DS : Apply Coupon
note over DS : processing apply coupon
@enduml