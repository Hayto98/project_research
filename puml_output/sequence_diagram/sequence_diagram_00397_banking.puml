@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
actor "Auditor" as A
participant "ATM" as A2
entity "Branch Manager" as BM
control "Bank Teller" as BT
A2 -> BM : Pay Bill
A2 -> BM : View Statement
BT --> A2 : Transfer Funds
activate A2
A2 --> BT : ACK
deactivate A2
note over A2 : processing transfer funds
BM -> A : Deposit Money
@enduml