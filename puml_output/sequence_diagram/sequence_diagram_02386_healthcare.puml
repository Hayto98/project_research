@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
entity "Receptionist" as R
boundary "Insurance Provider" as IP
boundary "Doctor" as D
D -> R : Issue Prescription
note over R : processing issue prescription
D ->> R : Book Appointment
IP --> R : Admit Patient
activate R
R --> IP : ACK
deactivate R
note over R : processing admit patient
D ->> R : Examine Patient
IP --> D : Update Medical Record
@enduml