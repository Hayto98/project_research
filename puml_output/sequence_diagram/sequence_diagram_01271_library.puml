@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
boundary "Librarian" as L
entity "Member" as M
actor "Admin" as A
M ->> L : Add New Book
A ->> L : Search Catalog
activate L
L --> A : ACK
deactivate L
L -> M : Borrow Book
M --> A : Pay Fine
A --> L : Return Book
@enduml