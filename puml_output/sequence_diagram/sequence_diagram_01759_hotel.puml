@startuml
skinparam monochrome true
skinparam defaultFontSize 13
control "Guest" as G
entity "Housekeeper" as H
control "Chef" as C
participant "Receptionist" as R
G -> R : Process Payment
C ->> G : Cancel Reservation
activate G
G --> C : ACK
deactivate G
C --> H : Request Service
activate H
H --> C : ACK
deactivate H
note over H : processing request service
G -> H : Book Room
note over H : processing book room
C --> H : Clean Room
activate H
H --> C : ACK
deactivate H
note over H : processing clean room
@enduml