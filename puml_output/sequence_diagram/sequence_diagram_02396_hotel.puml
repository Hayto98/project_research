@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
actor "Housekeeper" as H
participant "Guest" as G
control "Manager" as M
control "Receptionist" as R
M -> H : Cancel Reservation
H -> G : Request Service
activate G
G --> H : ACK
deactivate G
H ->> R : Book Room
M -> R : Process Payment
M --> H : Clean Room
@enduml