@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
actor "Student" as S
boundary "Teacher" as T
participant "Registrar" as R
T --> R : Issue Certificate
S ->> R : Enroll Course
activate R
R --> S : ACK
deactivate R
R -> T : Register Student
activate T
T --> R : ACK
deactivate T
T ->> S : Submit Assignment
T ->> R : Grade Exam
@enduml