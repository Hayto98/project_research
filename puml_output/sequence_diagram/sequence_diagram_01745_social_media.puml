@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
participant "Admin" as A
participant "Moderator" as M
actor "Advertiser" as A2
M ->> A : Like Post
A2 ->> A : Send Message
activate A
A --> A2 : ACK
deactivate A
A ->> M : Edit Profile
note over M : processing edit profile
M ->> A2 : Comment
note over A2 : processing comment
@enduml