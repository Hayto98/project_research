@startuml
skinparam defaultFontSize 13
boundary "Librarian" as L
boundary "Admin" as A
entity "Member" as M
M --> A : Pay Fine
A --> M : Renew Loan
activate M
M --> A : ACK
deactivate M
L ->> M : Borrow Book
activate M
M --> L : ACK
deactivate M
M -> A : Register Member
activate A
A --> M : ACK
deactivate A
A ->> M : Search Catalog
activate M
M --> A : ACK
deactivate M
M ->> A : Reserve Book
activate A
A --> M : ACK
deactivate A
L -> A : Return Book
activate A
A --> L : ACK
deactivate A
@enduml