@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
participant "Parent" as P
actor "Admin" as A
actor "Teacher" as T
actor "Librarian" as L
L --> T : Take Attendance
L -> T : Submit Assignment
L -> T : View Schedule
T ->> P : Enroll Course
activate P
P --> T : ACK
deactivate P
L -> P : Register Student
activate P
P --> L : ACK
deactivate P
T -> P : Grade Exam
L --> A : Borrow Book
activate A
A --> L : ACK
deactivate A
@enduml