@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
actor "Advertiser" as A
control "Admin" as A2
participant "Moderator" as M
participant "User" as U
M -> A : Follow User
activate A
A --> M : ACK
deactivate A
A2 --> M : Like Post
note over M : processing like post
A2 -> A : Edit Profile
activate A
A --> A2 : ACK
deactivate A
note over A : processing edit profile
U -> M : Share Post
A --> A2 : Comment
@enduml