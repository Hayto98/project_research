@startuml
skinparam defaultFontSize 11
participant "Moderator" as M
entity "Admin" as A
actor "User" as U
actor "Advertiser" as A2
M -> U : Create Post
activate U
U --> M : ACK
deactivate U
U -> M : Like Post
activate M
M --> U : ACK
deactivate M
A2 -> U : Comment
U -> A : Share Post
activate A
A --> U : ACK
deactivate A
note over A : processing share post
A ->> M : Follow User
note over M : processing follow user
A ->> U : Edit Profile
activate U
U --> A : ACK
deactivate U
A2 ->> M : Send Message
activate M
M --> A2 : ACK
deactivate M
note over M : processing send message
@enduml