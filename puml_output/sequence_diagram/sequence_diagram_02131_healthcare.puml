@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
participant "Lab Technician" as LT
actor "Nurse" as N
actor "Patient" as P
entity "Doctor" as D
actor "Receptionist" as R
LT --> N : Examine Patient
activate N
N --> LT : ACK
deactivate N
N --> D : Issue Prescription
activate D
D --> N : ACK
deactivate D
note over D : processing issue prescription
P ->> D : Process Insurance Claim
LT ->> R : Discharge Patient
R --> N : Update Medical Record
P -> D : Run Lab Test
activate D
D --> P : ACK
deactivate D
D ->> R : Admit Patient
activate R
R --> D : ACK
deactivate R
@enduml