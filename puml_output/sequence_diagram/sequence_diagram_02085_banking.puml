@startuml
skinparam monochrome true
skinparam defaultFontSize 13
actor "Account Holder" as AH
entity "Auditor" as A
entity "Branch Manager" as BM
boundary "Bank Teller" as BT
BT --> BM : Apply For Loan
activate BM
BM --> BT : ACK
deactivate BM
A -> BM : Transfer Funds
BT --> BM : View Statement
BT ->> A : Open Account
@enduml