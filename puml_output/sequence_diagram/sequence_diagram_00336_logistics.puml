@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
entity "Warehouse Staff" as WS
control "Customer" as C
actor "Dispatcher" as D
participant "Driver" as D2
D --> D2 : Fuel Vehicle
C ->> D2 : Update Inventory
activate D2
D2 --> C : ACK
deactivate D2
C ->> D2 : Schedule Pickup
D --> WS : Track Shipment
activate WS
WS --> D : ACK
deactivate WS
note over WS : processing track shipment
@enduml