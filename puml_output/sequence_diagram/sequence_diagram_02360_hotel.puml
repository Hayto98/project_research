@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
control "Manager" as M
control "Receptionist" as R
boundary "Guest" as G
actor "Chef" as C
M --> G : Book Room
C --> G : Process Payment
activate G
G --> C : ACK
deactivate G
R -> C : Clean Room
M --> C : Order Room Service
R ->> G : Cancel Reservation
activate G
G --> R : ACK
deactivate G
R --> G : Request Service
@enduml