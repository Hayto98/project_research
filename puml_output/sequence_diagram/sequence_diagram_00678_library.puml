@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
control "Librarian" as L
boundary "Admin" as A
entity "Member" as M
M --> A : Renew Loan
note over A : processing renew loan
L -> M : Return Book
activate M
M --> L : ACK
deactivate M
L ->> M : Pay Fine
activate M
M --> L : ACK
deactivate M
A --> M : Borrow Book
activate M
M --> A : ACK
deactivate M
M -> L : Add New Book
A --> M : Register Member
M --> A : Search Catalog
activate A
A --> M : ACK
deactivate A
@enduml