@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
entity "Admin" as A
control "User" as U
boundary "Advertiser" as A2
entity "Moderator" as M
U -> M : Like Post
A2 --> A : Edit Profile
A -> M : Comment
note over M : processing comment
U -> A2 : Report Content
U -> A2 : Follow User
note over A2 : processing follow user
M --> U : Share Post
@enduml