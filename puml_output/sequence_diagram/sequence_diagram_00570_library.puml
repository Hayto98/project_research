@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
actor "Admin" as A
actor "Member" as M
boundary "Librarian" as L
L -> M : Reserve Book
A ->> M : Register Member
activate M
M --> A : ACK
deactivate M
M --> L : Add New Book
activate L
L --> M : ACK
deactivate L
L ->> A : Search Catalog
A ->> M : Borrow Book
@enduml