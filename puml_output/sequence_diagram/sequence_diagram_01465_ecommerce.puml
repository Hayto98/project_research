@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
actor "Admin" as A
control "Payment Gateway" as PG
control "Delivery Service" as DS
DS --> PG : Cancel Order
PG ->> DS : Manage Inventory
activate DS
DS --> PG : ACK
deactivate DS
PG -> A : Write Review
activate A
A --> PG : ACK
deactivate A
DS ->> PG : Add To Cart
activate PG
PG --> DS : ACK
deactivate PG
DS --> A : Checkout
PG -> A : Apply Coupon
activate A
A --> PG : ACK
deactivate A
PG ->> A : Make Payment
@enduml