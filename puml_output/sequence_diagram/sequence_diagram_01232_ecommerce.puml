@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
participant "Admin" as A
boundary "Payment Gateway" as PG
participant "Customer" as C
PG ->> A : Apply Coupon
activate A
A --> PG : ACK
deactivate A
A --> PG : Track Order
activate PG
PG --> A : ACK
deactivate PG
PG --> C : Write Review
activate C
C --> PG : ACK
deactivate C
A -> PG : Browse Products
PG --> C : Checkout
activate C
C --> PG : ACK
deactivate C
note over C : processing checkout
PG --> C : Cancel Order
C ->> PG : Make Payment
@enduml