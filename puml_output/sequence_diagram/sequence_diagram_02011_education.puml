@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
actor "Registrar" as R
participant "Student" as S
entity "Librarian" as L
boundary "Admin" as A
A ->> L : View Schedule
activate L
L --> A : ACK
deactivate L
S -> L : Submit Assignment
A ->> R : Borrow Book
A -> L : Take Attendance
activate L
L --> A : ACK
deactivate L
L ->> A : Register Student
@enduml