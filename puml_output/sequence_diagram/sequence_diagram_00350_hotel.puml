@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
participant "Guest" as G
actor "Manager" as M
control "Housekeeper" as H
boundary "Receptionist" as R
G --> R : Request Service
H --> G : Check Out
note over G : processing check out
M -> R : Book Room
M ->> H : Clean Room
@enduml