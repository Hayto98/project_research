@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
actor "Advertiser" as A
entity "Moderator" as M
control "Admin" as A2
M --> A : Edit Profile
M -> A2 : Send Message
activate A2
A2 --> M : ACK
deactivate A2
A ->> A2 : Report Content
A2 --> M : Create Post
note over M : processing create post
A2 --> A : Comment
A2 -> M : Like Post
@enduml