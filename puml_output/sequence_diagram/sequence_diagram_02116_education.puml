@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
control "Librarian" as L
participant "Teacher" as T
participant "Parent" as P
boundary "Student" as S
L ->> T : Register Student
note over T : processing register student
L ->> T : Submit Assignment
activate T
T --> L : ACK
deactivate T
L --> P : Grade Exam
activate P
P --> L : ACK
deactivate P
S ->> P : View Schedule
@enduml