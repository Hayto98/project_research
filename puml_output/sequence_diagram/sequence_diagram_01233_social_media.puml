@startuml
skinparam ArrowColor #555555
participant "Moderator" as M
entity "User" as U
entity "Admin" as A
A ->> M : Comment
activate M
M --> A : ACK
deactivate M
note over M : processing comment
A ->> U : Report Content
activate U
U --> A : ACK
deactivate U
A ->> M : Edit Profile
A --> U : Share Post
activate U
U --> A : ACK
deactivate U
@enduml