@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
actor "User" as U
participant "Advertiser" as A
entity "Moderator" as M
U -> A : Create Post
U --> A : Report Content
M -> A : Send Message
note over A : processing send message
M --> U : Follow User
@enduml