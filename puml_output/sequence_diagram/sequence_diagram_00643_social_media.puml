@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
control "Admin" as A
actor "Advertiser" as A2
control "User" as U
entity "Moderator" as M
A2 -> M : Follow User
activate M
M --> A2 : ACK
deactivate M
U --> A2 : Like Post
U ->> M : Edit Profile
activate M
M --> U : ACK
deactivate M
M ->> A : Share Post
A ->> U : Comment
activate U
U --> A : ACK
deactivate U
@enduml