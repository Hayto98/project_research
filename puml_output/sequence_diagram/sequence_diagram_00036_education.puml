@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
boundary "Registrar" as R
boundary "Student" as S
participant "Parent" as P
entity "Librarian" as L
boundary "Admin" as A
R ->> S : Submit Assignment
S -> A : Issue Certificate
activate A
A --> S : ACK
deactivate A
A -> L : View Schedule
L --> P : Grade Exam
@enduml