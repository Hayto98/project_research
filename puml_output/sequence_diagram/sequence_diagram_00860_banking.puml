@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
actor "Auditor" as A
control "Branch Manager" as BM
boundary "Account Holder" as AH
control "Bank Teller" as BT
boundary "ATM" as A2
AH -> A : Block Card
BT --> A2 : View Statement
activate A2
A2 --> BT : ACK
deactivate A2
A2 --> A : Withdraw Cash
AH --> BT : Pay Bill
@enduml