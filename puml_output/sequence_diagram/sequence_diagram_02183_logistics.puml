@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
participant "Dispatcher" as D
control "Warehouse Staff" as WS
participant "Driver" as D2
boundary "Fleet Manager" as FM
participant "Customer" as C
D2 -> D : Update Inventory
activate D
D --> D2 : ACK
deactivate D
D2 -> FM : Deliver Package
D2 ->> D : Schedule Pickup
activate D
D --> D2 : ACK
deactivate D
FM -> WS : Fuel Vehicle
activate WS
WS --> FM : ACK
deactivate WS
D2 -> FM : Report Issue
C --> FM : Load Package
@enduml