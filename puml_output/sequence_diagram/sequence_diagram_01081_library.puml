@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
boundary "Librarian" as L
actor "Admin" as A
entity "Member" as M
A --> M : Reserve Book
L --> A : Pay Fine
L --> M : Add New Book
M ->> A : Register Member
activate A
A --> M : ACK
deactivate A
L ->> M : Return Book
note over M : processing return book
@enduml