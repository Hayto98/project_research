@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
participant "Student" as S
entity "Parent" as P
entity "Registrar" as R
P -> R : Take Attendance
R -> P : View Schedule
note over P : processing view schedule
P --> R : Enroll Course
R ->> P : Register Student
note over P : processing register student
P --> S : Borrow Book
S -> P : Submit Assignment
note over P : processing submit assignment
S ->> R : Issue Certificate
note over R : processing issue certificate
@enduml