@startuml
skinparam monochrome true
skinparam defaultFontSize 13
participant "Admin" as A
boundary "Advertiser" as A2
actor "User" as U
participant "Moderator" as M
U ->> A : Report Content
activate A
A --> U : ACK
deactivate A
M ->> A2 : Share Post
activate A2
A2 --> M : ACK
deactivate A2
U ->> A2 : Edit Profile
activate A2
A2 --> U : ACK
deactivate A2
A2 ->> U : Like Post
@enduml