@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
control "User" as U
participant "Admin" as A
actor "Moderator" as M
control "Advertiser" as A2
U ->> A : Edit Profile
activate A
A --> U : ACK
deactivate A
A2 -> A : Follow User
note over A : processing follow user
M ->> A : Share Post
note over A : processing share post
U -> A : Like Post
activate A
A --> U : ACK
deactivate A
@enduml