@startuml
skinparam monochrome true
skinparam defaultFontSize 11
participant "User" as U
participant "Advertiser" as A
control "Moderator" as M
M -> U : Share Post
U --> M : Create Post
note over M : processing create post
A ->> M : Like Post
activate M
M --> A : ACK
deactivate M
A --> U : Comment
A -> M : Report Content
@enduml