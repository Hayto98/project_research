@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
participant "Student" as S
control "Parent" as P
control "Librarian" as L
S ->> P : Enroll Course
L -> S : Grade Exam
P --> L : Borrow Book
L ->> P : Submit Assignment
P -> L : View Schedule
activate L
L --> P : ACK
deactivate L
L -> P : Take Attendance
activate P
P --> L : ACK
deactivate P
note over P : processing take attendance
@enduml