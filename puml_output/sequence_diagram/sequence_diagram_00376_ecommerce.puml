@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
actor "Delivery Service" as DS
control "Admin" as A
boundary "Payment Gateway" as PG
PG --> DS : Make Payment
PG -> A : Add To Cart
DS --> A : Write Review
PG -> DS : Manage Inventory
DS -> A : Track Order
activate A
A --> DS : ACK
deactivate A
PG -> A : Browse Products
@enduml