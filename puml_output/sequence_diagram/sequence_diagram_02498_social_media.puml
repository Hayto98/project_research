@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
boundary "Admin" as A
actor "User" as U
control "Advertiser" as A2
A2 --> U : Report Content
A2 --> U : Like Post
note over U : processing like post
U -> A : Follow User
activate A
A --> U : ACK
deactivate A
A2 --> U : Create Post
A2 ->> A : Comment
activate A
A --> A2 : ACK
deactivate A
note over A : processing comment
A2 ->> A : Edit Profile
U --> A2 : Send Message
activate A2
A2 --> U : ACK
deactivate A2
@enduml