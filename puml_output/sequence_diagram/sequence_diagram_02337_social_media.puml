@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
participant "Admin" as A
boundary "Moderator" as M
boundary "User" as U
actor "Advertiser" as A2
U ->> M : Edit Profile
note over M : processing edit profile
A ->> U : Like Post
A ->> M : Create Post
activate M
M --> A : ACK
deactivate M
U ->> M : Report Content
activate M
M --> U : ACK
deactivate M
@enduml