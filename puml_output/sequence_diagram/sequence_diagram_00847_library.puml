@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
participant "Member" as M
participant "Librarian" as L
actor "Admin" as A
M -> A : Search Catalog
M ->> A : Renew Loan
A -> M : Add New Book
L -> M : Borrow Book
activate M
M --> L : ACK
deactivate M
A -> L : Pay Fine
@enduml