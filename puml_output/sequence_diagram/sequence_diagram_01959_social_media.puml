@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
participant "Advertiser" as A
entity "Moderator" as M
boundary "User" as U
actor "Admin" as A2
M --> U : Like Post
note over U : processing like post
A ->> U : Report Content
M -> U : Create Post
note over U : processing create post
A ->> M : Edit Profile
activate M
M --> A : ACK
deactivate M
U --> A : Comment
A -> A2 : Share Post
note over A2 : processing share post
A2 ->> M : Follow User
note over M : processing follow user
@enduml