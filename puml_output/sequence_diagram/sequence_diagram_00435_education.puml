@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
boundary "Student" as S
entity "Parent" as P
control "Teacher" as T
entity "Librarian" as L
actor "Admin" as A
A --> S : Issue Certificate
note over S : processing issue certificate
S --> L : Enroll Course
A -> L : Borrow Book
A ->> S : Register Student
note over S : processing register student
P ->> A : Grade Exam
activate A
A --> P : ACK
deactivate A
P -> A : Submit Assignment
@enduml