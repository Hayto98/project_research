@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
boundary "User" as U
control "Moderator" as M
participant "Advertiser" as A
entity "Admin" as A2
A -> A2 : Send Message
activate A2
A2 --> A : ACK
deactivate A2
U --> A2 : Comment
M -> A2 : Follow User
A ->> A2 : Share Post
M --> A2 : Like Post
activate A2
A2 --> M : ACK
deactivate A2
note over A2 : processing like post
@enduml