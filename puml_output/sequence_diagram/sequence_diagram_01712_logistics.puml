@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
participant "Dispatcher" as D
actor "Warehouse Staff" as WS
entity "Driver" as D2
WS -> D2 : Assign Route
D2 ->> D : Deliver Package
WS ->> D2 : Schedule Pickup
D2 -> WS : Track Shipment
WS ->> D2 : Fuel Vehicle
note over D2 : processing fuel vehicle
@enduml