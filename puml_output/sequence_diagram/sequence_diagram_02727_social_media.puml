@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
entity "Moderator" as M
participant "User" as U
entity "Advertiser" as A
U ->> M : Comment
activate M
M --> U : ACK
deactivate M
A --> M : Like Post
activate M
M --> A : ACK
deactivate M
U --> A : Edit Profile
note over A : processing edit profile
A -> U : Follow User
U -> A : Report Content
A --> M : Send Message
@enduml