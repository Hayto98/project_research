@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
participant "Teacher" as T
control "Librarian" as L
control "Parent" as P
P ->> T : Borrow Book
T --> P : Take Attendance
activate P
P --> T : ACK
deactivate P
T --> L : Register Student
activate L
L --> T : ACK
deactivate L
L ->> T : Issue Certificate
T --> P : Submit Assignment
note over P : processing submit assignment
L --> T : Enroll Course
L ->> P : View Schedule
note over P : processing view schedule
@enduml