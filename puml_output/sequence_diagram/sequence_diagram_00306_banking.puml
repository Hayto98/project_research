@startuml
skinparam monochrome true
skinparam ArrowColor #555555
control "Bank Teller" as BT
control "Auditor" as A
boundary "Account Holder" as AH
BT -> AH : Apply For Loan
AH ->> BT : Pay Bill
activate BT
BT --> AH : ACK
deactivate BT
BT --> AH : Withdraw Cash
AH --> BT : View Statement
AH --> A : Open Account
A -> BT : Deposit Money
activate BT
BT --> A : ACK
deactivate BT
@enduml