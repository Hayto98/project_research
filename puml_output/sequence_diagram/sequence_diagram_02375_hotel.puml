@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
control "Receptionist" as R
entity "Housekeeper" as H
entity "Chef" as C
C -> R : Book Room
H ->> R : Request Service
C -> R : Cancel Reservation
activate R
R --> C : ACK
deactivate R
C ->> H : Check Out
activate H
H --> C : ACK
deactivate H
@enduml