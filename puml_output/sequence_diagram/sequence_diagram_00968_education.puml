@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
participant "Teacher" as T
entity "Admin" as A
entity "Registrar" as R
control "Librarian" as L
L --> T : View Schedule
activate T
T --> L : ACK
deactivate T
A ->> R : Register Student
activate R
R --> A : ACK
deactivate R
T -> R : Take Attendance
activate R
R --> T : ACK
deactivate R
L -> T : Borrow Book
T ->> A : Grade Exam
@enduml