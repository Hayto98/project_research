@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
left to right direction
actor "Librarian" as Librarian
actor "Registrar" as Registrar
actor "Parent" as Parent
actor "Student" as Student
rectangle "Education System" {
  usecase "Take Attendance" as UC_TakeAttendance
  usecase "Submit Assignment" as UC_SubmitAssignment
  usecase "Issue Certificate" as UC_IssueCertificate
  usecase "Register Student" as UC_RegisterStudent
  usecase "Enroll Course" as UC_EnrollCourse
}
Librarian --> UC_EnrollCourse
Librarian --> UC_RegisterStudent
Librarian --> UC_IssueCertificate
Registrar --> UC_TakeAttendance
Parent --> UC_EnrollCourse
Parent --> UC_IssueCertificate
Student --> UC_EnrollCourse
Student --> UC_IssueCertificate
UC_IssueCertificate ..|> UC_EnrollCourse : <<extend>>
@enduml