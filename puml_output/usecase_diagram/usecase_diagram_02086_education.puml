@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
left to right direction
actor "Librarian" as L
actor "Registrar" as R
actor "Parent" as P
actor "Student" as S
rectangle "Education System" {
  usecase "Take Attendance" as UC_TakeAttendance
  usecase "Submit Assignment" as UC_SubmitAssignment
  usecase "Issue Certificate" as UC_IssueCertificate
  usecase "Register Student" as UC_RegisterStudent
  usecase "Enroll Course" as UC_EnrollCourse
}
L --> UC_EnrollCourse
L --> UC_RegisterStudent
L --> UC_IssueCertificate
R --> UC_TakeAttendance
P --> UC_EnrollCourse
P --> UC_IssueCertificate
S --> UC_EnrollCourse
S --> UC_IssueCertificate
UC_IssueCertificate ..|> UC_EnrollCourse : <<extend>>
@enduml