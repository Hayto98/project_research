@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
left to right direction
actor "Customer" as C
actor "Seller" as S
actor "Payment Gateway" as PG
actor "Delivery Service" as DS
rectangle "Ecommerce System" {
  usecase "Track Order" as UC_TrackOrder
  usecase "Cancel Order" as UC_CancelOrder
  usecase "Browse Products" as UC_BrowseProducts
  usecase "Write Review" as UC_WriteReview
  usecase "Add To Cart" as UC_AddToCart
  usecase "Manage Inventory" as UC_ManageInventory
}
C --> UC_WriteReview
S --> UC_TrackOrder
PG --> UC_ManageInventory
PG --> UC_AddToCart
PG --> UC_WriteReview
DS --> UC_CancelOrder
UC_WriteReview ..> UC_AddToCart : <<extend>>
@enduml