@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
left to right direction
actor "Librarian" as Librarian
actor "Member" as Member
rectangle "Library System" {
  usecase "Return Book" as UC_ReturnBook
  usecase "Borrow Book" as UC_BorrowBook
  usecase "Register Member" as UC_RegisterMember
  usecase "Pay Fine" as UC_PayFine
  usecase "Renew Loan" as UC_RenewLoan
  usecase "Reserve Book" as UC_ReserveBook
  usecase "Search Catalog" as UC_SearchCatalog
}
Librarian --> UC_PayFine
Member --> UC_RegisterMember
Member --> UC_ReturnBook
Member --> UC_ReserveBook
@enduml