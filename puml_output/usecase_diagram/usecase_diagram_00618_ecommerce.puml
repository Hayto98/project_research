@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
left to right direction
actor "Delivery Service" as DeliveryService
actor "Admin" as Admin
actor "Payment Gateway" as PaymentGateway
rectangle "Ecommerce System" {
  usecase "Checkout" as UC_Checkout
  usecase "Track Order" as UC_TrackOrder
  usecase "Write Review" as UC_WriteReview
  usecase "Cancel Order" as UC_CancelOrder
  usecase "Apply Coupon" as UC_ApplyCoupon
  usecase "Manage Inventory" as UC_ManageInventory
}
DeliveryService --> UC_ManageInventory
DeliveryService --> UC_WriteReview
DeliveryService --> UC_ApplyCoupon
Admin --> UC_Checkout
Admin --> UC_TrackOrder
Admin --> UC_ApplyCoupon
PaymentGateway --> UC_WriteReview
UC_CancelOrder ..|> UC_Checkout : <<extend>>
@enduml