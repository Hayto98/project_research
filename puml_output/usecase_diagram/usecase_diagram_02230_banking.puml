@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
left to right direction
actor "Auditor" as A
actor "ATM" as A1
actor "Branch Manager" as BM
actor "Account Holder" as AH
rectangle "Banking System" {
  usecase "Open Account" as UC_OpenAccount
  usecase "Transfer Funds" as UC_TransferFunds
  usecase "Deposit Money" as UC_DepositMoney
  usecase "Block Card" as UC_BlockCard
  usecase "Pay Bill" as UC_PayBill
}
A --> UC_OpenAccount
A --> UC_TransferFunds
A1 --> UC_PayBill
A1 --> UC_OpenAccount
BM --> UC_PayBill
BM --> UC_OpenAccount
BM --> UC_BlockCard
AH --> UC_PayBill
AH --> UC_TransferFunds
AH --> UC_OpenAccount
UC_PayBill ..|> UC_OpenAccount : <<include>>
@enduml