@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
left to right direction
actor "Branch Manager" as BM
actor "Bank Teller" as BT
actor "Auditor" as A
rectangle "Banking System" {
  usecase "Withdraw Cash" as UC_WithdrawCash
  usecase "Apply For Loan" as UC_ApplyForLoan
  usecase "Deposit Money" as UC_DepositMoney
  usecase "Block Card" as UC_BlockCard
  usecase "Pay Bill" as UC_PayBill
}
BM --> UC_WithdrawCash
BM --> UC_BlockCard
BM --> UC_ApplyForLoan
BT --> UC_DepositMoney
BT --> UC_WithdrawCash
BT --> UC_ApplyForLoan
A --> UC_PayBill
A --> UC_WithdrawCash
UC_ApplyForLoan ..|> UC_DepositMoney : <<extend>>
@enduml