@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
left to right direction
actor "Teacher" as Teacher
actor "Registrar" as Registrar
actor "Admin" as Admin
rectangle "Education System" {
  usecase "Borrow Book" as UC_BorrowBook
  usecase "Grade Exam" as UC_GradeExam
  usecase "Enroll Course" as UC_EnrollCourse
  usecase "Register Student" as UC_RegisterStudent
  usecase "View Schedule" as UC_ViewSchedule
  usecase "Submit Assignment" as UC_SubmitAssignment
  usecase "Take Attendance" as UC_TakeAttendance
}
Teacher --> UC_EnrollCourse
Teacher --> UC_TakeAttendance
Registrar --> UC_EnrollCourse
Registrar --> UC_BorrowBook
Admin --> UC_EnrollCourse
Admin --> UC_RegisterStudent
Admin --> UC_ViewSchedule
@enduml