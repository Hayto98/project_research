@startuml
skinparam monochrome true
skinparam defaultFontSize 13
left to right direction
actor "Seller" as S
actor "Delivery Service" as DS
actor "Customer" as C
actor "Payment Gateway" as PG
rectangle "Ecommerce System" {
  usecase "Cancel Order" as UC_CancelOrder
  usecase "Add To Cart" as UC_AddToCart
  usecase "Checkout" as UC_Checkout
  usecase "Track Order" as UC_TrackOrder
  usecase "Write Review" as UC_WriteReview
}
S --> UC_Checkout
S --> UC_WriteReview
DS --> UC_WriteReview
C --> UC_AddToCart
C --> UC_CancelOrder
PG --> UC_Checkout
PG --> UC_AddToCart
UC_TrackOrder ..> UC_WriteReview : <<include>>
@enduml