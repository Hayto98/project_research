@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
left to right direction
actor "Chef" as Chef
actor "Manager" as Manager
actor "Housekeeper" as Housekeeper
rectangle "Hotel System" {
  usecase "Book Room" as UC_BookRoom
  usecase "Request Service" as UC_RequestService
  usecase "Process Payment" as UC_ProcessPayment
  usecase "Clean Room" as UC_CleanRoom
  usecase "Check Out" as UC_CheckOut
  usecase "Check In" as UC_CheckIn
}
Chef --> UC_ProcessPayment
Chef --> UC_CheckOut
Manager --> UC_CheckIn
Manager --> UC_BookRoom
Manager --> UC_CheckOut
Housekeeper --> UC_ProcessPayment
UC_BookRoom ..|> UC_CheckIn : <<extend>>
@enduml