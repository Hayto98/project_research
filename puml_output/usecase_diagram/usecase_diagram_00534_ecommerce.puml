@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
left to right direction
actor "Admin" as A
actor "Customer" as C
actor "Delivery Service" as DS
actor "Payment Gateway" as PG
rectangle "Ecommerce System" {
  usecase "Checkout" as UC_Checkout
  usecase "Apply Coupon" as UC_ApplyCoupon
  usecase "Track Order" as UC_TrackOrder
  usecase "Manage Inventory" as UC_ManageInventory
  usecase "Cancel Order" as UC_CancelOrder
}
A --> UC_ManageInventory
A --> UC_CancelOrder
A --> UC_TrackOrder
C --> UC_Checkout
C --> UC_CancelOrder
C --> UC_TrackOrder
DS --> UC_ApplyCoupon
DS --> UC_Checkout
DS --> UC_CancelOrder
PG --> UC_Checkout
@enduml