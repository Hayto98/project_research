@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
left to right direction
actor "Advertiser" as A
actor "User" as U
actor "Admin" as A1
actor "Moderator" as M
rectangle "Social Media System" {
  usecase "Send Message" as UC_SendMessage
  usecase "Like Post" as UC_LikePost
  usecase "Comment" as UC_Comment
  usecase "Share Post" as UC_SharePost
  usecase "Report Content" as UC_ReportContent
  usecase "Edit Profile" as UC_EditProfile
}
A --> UC_LikePost
U --> UC_Comment
U --> UC_SendMessage
A1 --> UC_SendMessage
A1 --> UC_SharePost
M --> UC_SendMessage
M --> UC_ReportContent
M --> UC_LikePost
UC_ReportContent ..> UC_EditProfile : <<include>>
@enduml