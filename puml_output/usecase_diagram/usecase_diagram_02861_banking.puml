@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
left to right direction
actor "Account Holder" as AH
actor "Auditor" as A
actor "Branch Manager" as BM
actor "ATM" as A1
rectangle "Banking System" {
  usecase "Open Account" as UC_OpenAccount
  usecase "View Statement" as UC_ViewStatement
  usecase "Apply For Loan" as UC_ApplyForLoan
  usecase "Deposit Money" as UC_DepositMoney
  usecase "Transfer Funds" as UC_TransferFunds
}
AH --> UC_TransferFunds
AH --> UC_DepositMoney
A --> UC_DepositMoney
A --> UC_ApplyForLoan
BM --> UC_DepositMoney
A1 --> UC_DepositMoney
@enduml