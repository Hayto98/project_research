@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
left to right direction
actor "Bank Teller" as BT
actor "Account Holder" as AH
actor "Auditor" as A
actor "Branch Manager" as BM
rectangle "Banking System" {
  usecase "Open Account" as UC_OpenAccount
  usecase "Withdraw Cash" as UC_WithdrawCash
  usecase "View Statement" as UC_ViewStatement
  usecase "Transfer Funds" as UC_TransferFunds
  usecase "Block Card" as UC_BlockCard
}
BT --> UC_TransferFunds
AH --> UC_BlockCard
AH --> UC_ViewStatement
A --> UC_ViewStatement
A --> UC_OpenAccount
A --> UC_BlockCard
BM --> UC_WithdrawCash
BM --> UC_ViewStatement
BM --> UC_OpenAccount
UC_TransferFunds ..> UC_ViewStatement : <<include>>
@enduml