@startuml
skinparam monochrome true
skinparam ArrowColor #555555
left to right direction
actor "Seller" as S
actor "Payment Gateway" as PG
actor "Customer" as C
actor "Admin" as A
rectangle "Ecommerce System" {
  usecase "Add To Cart" as UC_AddToCart
  usecase "Make Payment" as UC_MakePayment
  usecase "Apply Coupon" as UC_ApplyCoupon
  usecase "Cancel Order" as UC_CancelOrder
  usecase "Manage Inventory" as UC_ManageInventory
  usecase "Write Review" as UC_WriteReview
  usecase "Track Order" as UC_TrackOrder
}
S --> UC_TrackOrder
S --> UC_ManageInventory
S --> UC_ApplyCoupon
PG --> UC_ApplyCoupon
C --> UC_CancelOrder
C --> UC_WriteReview
A --> UC_AddToCart
A --> UC_MakePayment
UC_TrackOrder ..> UC_WriteReview : <<extend>>
@enduml