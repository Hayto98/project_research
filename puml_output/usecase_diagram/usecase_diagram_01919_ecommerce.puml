@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
left to right direction
actor "Customer" as C
actor "Seller" as S
actor "Delivery Service" as DS
actor "Payment Gateway" as PG
rectangle "Ecommerce System" {
  usecase "Checkout" as UC_Checkout
  usecase "Write Review" as UC_WriteReview
  usecase "Track Order" as UC_TrackOrder
  usecase "Cancel Order" as UC_CancelOrder
  usecase "Manage Inventory" as UC_ManageInventory
}
C --> UC_TrackOrder
C --> UC_WriteReview
S --> UC_WriteReview
S --> UC_TrackOrder
DS --> UC_Checkout
DS --> UC_TrackOrder
PG --> UC_Checkout
UC_WriteReview ..|> UC_CancelOrder : <<include>>
@enduml