@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
left to right direction
actor "Receptionist" as Receptionist
actor "Guest" as Guest
actor "Housekeeper" as Housekeeper
actor "Chef" as Chef
rectangle "Hotel System" {
  usecase "Order Room Service" as UC_OrderRoomService
  usecase "Request Service" as UC_RequestService
  usecase "Check In" as UC_CheckIn
  usecase "Cancel Reservation" as UC_CancelReservation
  usecase "Process Payment" as UC_ProcessPayment
  usecase "Book Room" as UC_BookRoom
  usecase "Check Out" as UC_CheckOut
}
Receptionist --> UC_RequestService
Receptionist --> UC_CancelReservation
Guest --> UC_BookRoom
Guest --> UC_ProcessPayment
Guest --> UC_RequestService
Housekeeper --> UC_ProcessPayment
Housekeeper --> UC_CheckOut
Chef --> UC_CheckIn
Chef --> UC_OrderRoomService
Chef --> UC_RequestService
UC_CheckIn ..|> UC_BookRoom : <<include>>
@enduml