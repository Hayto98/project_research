@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
left to right direction
actor "Librarian" as L
actor "Admin" as A
actor "Member" as M
rectangle "Library System" {
  usecase "Reserve Book" as UC_ReserveBook
  usecase "Return Book" as UC_ReturnBook
  usecase "Pay Fine" as UC_PayFine
  usecase "Add New Book" as UC_AddNewBook
  usecase "Borrow Book" as UC_BorrowBook
}
L --> UC_PayFine
L --> UC_ReturnBook
L --> UC_AddNewBook
A --> UC_AddNewBook
A --> UC_ReserveBook
A --> UC_ReturnBook
M --> UC_AddNewBook
M --> UC_ReserveBook
M --> UC_BorrowBook
UC_ReserveBook ..> UC_BorrowBook : <<include>>
@enduml