@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
left to right direction
actor "Branch Manager" as BM
actor "Auditor" as A
actor "ATM" as A1
actor "Bank Teller" as BT
rectangle "Banking System" {
  usecase "Open Account" as UC_OpenAccount
  usecase "Deposit Money" as UC_DepositMoney
  usecase "Block Card" as UC_BlockCard
  usecase "View Statement" as UC_ViewStatement
  usecase "Apply For Loan" as UC_ApplyForLoan
  usecase "Pay Bill" as UC_PayBill
  usecase "Withdraw Cash" as UC_WithdrawCash
}
BM --> UC_ApplyForLoan
BM --> UC_ViewStatement
A --> UC_OpenAccount
A1 --> UC_ViewStatement
A1 --> UC_ApplyForLoan
A1 --> UC_WithdrawCash
BT --> UC_OpenAccount
BT --> UC_ViewStatement
UC_OpenAccount ..> UC_DepositMoney : <<include>>
@enduml