@startuml
skinparam monochrome true
skinparam ArrowColor #555555
left to right direction
actor "Admin" as A
actor "Customer" as C
actor "Delivery Service" as DS
actor "Seller" as S
rectangle "Ecommerce System" {
  usecase "Apply Coupon" as UC_ApplyCoupon
  usecase "Cancel Order" as UC_CancelOrder
  usecase "Add To Cart" as UC_AddToCart
  usecase "Manage Inventory" as UC_ManageInventory
  usecase "Track Order" as UC_TrackOrder
}
A --> UC_TrackOrder
A --> UC_AddToCart
C --> UC_AddToCart
C --> UC_CancelOrder
C --> UC_ApplyCoupon
DS --> UC_ManageInventory
DS --> UC_CancelOrder
S --> UC_TrackOrder
UC_CancelOrder ..> UC_AddToCart : <<include>>
@enduml