@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
left to right direction
actor "Customer" as C
actor "Delivery Service" as DS
actor "Payment Gateway" as PG
actor "Seller" as S
rectangle "Ecommerce System" {
  usecase "Checkout" as UC_Checkout
  usecase "Manage Inventory" as UC_ManageInventory
  usecase "Make Payment" as UC_MakePayment
  usecase "Track Order" as UC_TrackOrder
  usecase "Add To Cart" as UC_AddToCart
  usecase "Browse Products" as UC_BrowseProducts
}
C --> UC_AddToCart
C --> UC_BrowseProducts
DS --> UC_AddToCart
DS --> UC_BrowseProducts
DS --> UC_ManageInventory
PG --> UC_BrowseProducts
PG --> UC_ManageInventory
PG --> UC_TrackOrder
S --> UC_BrowseProducts
S --> UC_ManageInventory
S --> UC_TrackOrder
UC_BrowseProducts ..|> UC_ManageInventory : <<include>>
@enduml