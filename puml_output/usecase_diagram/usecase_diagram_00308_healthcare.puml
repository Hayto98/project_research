@startuml
skinparam monochrome true
skinparam defaultFontSize 11
left to right direction
actor "Doctor" as D
actor "Nurse" as N
actor "Receptionist" as R
actor "Patient" as P
rectangle "Healthcare System" {
  usecase "Discharge Patient" as UC_DischargePatient
  usecase "Issue Prescription" as UC_IssuePrescription
  usecase "Admit Patient" as UC_AdmitPatient
  usecase "Examine Patient" as UC_ExaminePatient
  usecase "Run Lab Test" as UC_RunLabTest
  usecase "Process Insurance Claim" as UC_ProcessInsuranceClaim
}
D --> UC_ExaminePatient
D --> UC_ProcessInsuranceClaim
N --> UC_ProcessInsuranceClaim
N --> UC_RunLabTest
R --> UC_RunLabTest
P --> UC_IssuePrescription
P --> UC_ProcessInsuranceClaim
UC_ProcessInsuranceClaim ..> UC_IssuePrescription : <<extend>>
@enduml