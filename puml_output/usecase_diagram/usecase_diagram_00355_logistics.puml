@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
left to right direction
actor "Warehouse Staff" as WS
actor "Dispatcher" as D
actor "Customer" as C
actor "Driver" as D1
rectangle "Logistics System" {
  usecase "Load Package" as UC_LoadPackage
  usecase "Report Issue" as UC_ReportIssue
  usecase "Deliver Package" as UC_DeliverPackage
  usecase "Assign Route" as UC_AssignRoute
  usecase "Fuel Vehicle" as UC_FuelVehicle
  usecase "Track Shipment" as UC_TrackShipment
}
WS --> UC_TrackShipment
WS --> UC_FuelVehicle
D --> UC_TrackShipment
D --> UC_DeliverPackage
D --> UC_AssignRoute
C --> UC_DeliverPackage
D1 --> UC_TrackShipment
D1 --> UC_ReportIssue
D1 --> UC_DeliverPackage
UC_LoadPackage ..> UC_ReportIssue : <<include>>
@enduml