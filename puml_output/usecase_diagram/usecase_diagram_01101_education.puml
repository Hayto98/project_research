@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
left to right direction
actor "Student" as S
actor "Librarian" as L
actor "Teacher" as T
actor "Parent" as P
rectangle "Education System" {
  usecase "Submit Assignment" as UC_SubmitAssignment
  usecase "Grade Exam" as UC_GradeExam
  usecase "Issue Certificate" as UC_IssueCertificate
  usecase "Enroll Course" as UC_EnrollCourse
  usecase "Register Student" as UC_RegisterStudent
  usecase "Take Attendance" as UC_TakeAttendance
  usecase "View Schedule" as UC_ViewSchedule
}
S --> UC_EnrollCourse
L --> UC_SubmitAssignment
T --> UC_GradeExam
T --> UC_RegisterStudent
T --> UC_IssueCertificate
P --> UC_ViewSchedule
P --> UC_EnrollCourse
P --> UC_RegisterStudent
UC_ViewSchedule ..> UC_EnrollCourse : <<extend>>
@enduml