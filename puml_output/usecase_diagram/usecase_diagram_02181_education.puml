@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
left to right direction
actor "Admin" as A
actor "Teacher" as T
actor "Parent" as P
rectangle "Education System" {
  usecase "View Schedule" as UC_ViewSchedule
  usecase "Take Attendance" as UC_TakeAttendance
  usecase "Issue Certificate" as UC_IssueCertificate
  usecase "Submit Assignment" as UC_SubmitAssignment
  usecase "Borrow Book" as UC_BorrowBook
}
A --> UC_SubmitAssignment
A --> UC_TakeAttendance
T --> UC_SubmitAssignment
T --> UC_IssueCertificate
P --> UC_ViewSchedule
P --> UC_SubmitAssignment
P --> UC_IssueCertificate
@enduml