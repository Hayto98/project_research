@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
left to right direction
actor "Fleet Manager" as FM
actor "Dispatcher" as D
actor "Driver" as D1
actor "Customer" as C
rectangle "Logistics System" {
  usecase "Fuel Vehicle" as UC_FuelVehicle
  usecase "Deliver Package" as UC_DeliverPackage
  usecase "Assign Route" as UC_AssignRoute
  usecase "Report Issue" as UC_ReportIssue
  usecase "Schedule Pickup" as UC_SchedulePickup
}
FM --> UC_AssignRoute
FM --> UC_ReportIssue
D --> UC_AssignRoute
D --> UC_FuelVehicle
D --> UC_ReportIssue
D1 --> UC_FuelVehicle
D1 --> UC_DeliverPackage
C --> UC_ReportIssue
C --> UC_AssignRoute
C --> UC_DeliverPackage
UC_ReportIssue ..> UC_DeliverPackage : <<include>>
@enduml