@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
left to right direction
actor "Manager" as M
actor "Guest" as G
actor "Chef" as C
actor "Housekeeper" as H
rectangle "Hotel System" {
  usecase "Check In" as UC_CheckIn
  usecase "Check Out" as UC_CheckOut
  usecase "Order Room Service" as UC_OrderRoomService
  usecase "Clean Room" as UC_CleanRoom
  usecase "Process Payment" as UC_ProcessPayment
  usecase "Cancel Reservation" as UC_CancelReservation
  usecase "Request Service" as UC_RequestService
}
M --> UC_CheckIn
M --> UC_ProcessPayment
G --> UC_ProcessPayment
G --> UC_RequestService
G --> UC_OrderRoomService
C --> UC_CancelReservation
C --> UC_CheckOut
C --> UC_ProcessPayment
H --> UC_CheckIn
H --> UC_OrderRoomService
UC_CheckIn ..> UC_ProcessPayment : <<extend>>
@enduml