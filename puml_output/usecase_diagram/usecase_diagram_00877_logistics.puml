@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
left to right direction
actor "Fleet Manager" as FM
actor "Driver" as D
actor "Dispatcher" as D1
rectangle "Logistics System" {
  usecase "Track Shipment" as UC_TrackShipment
  usecase "Report Issue" as UC_ReportIssue
  usecase "Deliver Package" as UC_DeliverPackage
  usecase "Assign Route" as UC_AssignRoute
  usecase "Fuel Vehicle" as UC_FuelVehicle
}
FM --> UC_ReportIssue
D --> UC_ReportIssue
D --> UC_DeliverPackage
D --> UC_TrackShipment
D1 --> UC_DeliverPackage
D1 --> UC_TrackShipment
D1 --> UC_FuelVehicle
@enduml