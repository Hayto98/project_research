@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
left to right direction
actor "Advertiser" as A
actor "Moderator" as M
actor "Admin" as A1
actor "User" as U
rectangle "Social Media System" {
  usecase "Edit Profile" as UC_EditProfile
  usecase "Follow User" as UC_FollowUser
  usecase "Share Post" as UC_SharePost
  usecase "Comment" as UC_Comment
  usecase "Create Post" as UC_CreatePost
}
A --> UC_SharePost
A --> UC_CreatePost
M --> UC_FollowUser
A1 --> UC_FollowUser
A1 --> UC_Comment
A1 --> UC_CreatePost
U --> UC_SharePost
U --> UC_CreatePost
U --> UC_FollowUser
@enduml