@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
left to right direction
actor "Admin" as Admin
actor "Seller" as Seller
actor "Customer" as Customer
actor "Payment Gateway" as PaymentGateway
rectangle "Ecommerce System" {
  usecase "Apply Coupon" as UC_ApplyCoupon
  usecase "Browse Products" as UC_BrowseProducts
  usecase "Write Review" as UC_WriteReview
  usecase "Track Order" as UC_TrackOrder
  usecase "Add To Cart" as UC_AddToCart
  usecase "Make Payment" as UC_MakePayment
  usecase "Cancel Order" as UC_CancelOrder
}
Admin --> UC_WriteReview
Seller --> UC_TrackOrder
Seller --> UC_ApplyCoupon
Seller --> UC_WriteReview
Customer --> UC_AddToCart
Customer --> UC_TrackOrder
PaymentGateway --> UC_CancelOrder
UC_MakePayment ..|> UC_BrowseProducts : <<extend>>
@enduml