@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
left to right direction
actor "Patient" as P
actor "Insurance Provider" as IP
actor "Doctor" as D
actor "Nurse" as N
rectangle "Healthcare System" {
  usecase "Process Insurance Claim" as UC_ProcessInsuranceClaim
  usecase "Examine Patient" as UC_ExaminePatient
  usecase "Admit Patient" as UC_AdmitPatient
  usecase "Update Medical Record" as UC_UpdateMedicalRecord
  usecase "Run Lab Test" as UC_RunLabTest
  usecase "Book Appointment" as UC_BookAppointment
}
P --> UC_AdmitPatient
P --> UC_UpdateMedicalRecord
P --> UC_RunLabTest
IP --> UC_UpdateMedicalRecord
IP --> UC_ProcessInsuranceClaim
IP --> UC_RunLabTest
D --> UC_AdmitPatient
D --> UC_ProcessInsuranceClaim
N --> UC_ExaminePatient
N --> UC_BookAppointment
N --> UC_UpdateMedicalRecord
UC_UpdateMedicalRecord ..|> UC_BookAppointment : <<extend>>
@enduml