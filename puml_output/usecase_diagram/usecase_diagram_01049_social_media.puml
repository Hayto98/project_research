@startuml
skinparam defaultFontSize 13
left to right direction
actor "Moderator" as M
actor "User" as U
actor "Advertiser" as A
actor "Admin" as A1
rectangle "Social Media System" {
  usecase "Follow User" as UC_FollowUser
  usecase "Edit Profile" as UC_EditProfile
  usecase "Comment" as UC_Comment
  usecase "Like Post" as UC_LikePost
  usecase "Send Message" as UC_SendMessage
}
M --> UC_LikePost
M --> UC_SendMessage
U --> UC_EditProfile
A --> UC_EditProfile
A --> UC_SendMessage
A1 --> UC_SendMessage
A1 --> UC_Comment
A1 --> UC_EditProfile
UC_EditProfile ..> UC_SendMessage : <<include>>
@enduml