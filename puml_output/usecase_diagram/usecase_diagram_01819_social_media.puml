@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
left to right direction
actor "Moderator" as M
actor "Advertiser" as A
actor "Admin" as A1
actor "User" as U
rectangle "Social Media System" {
  usecase "Follow User" as UC_FollowUser
  usecase "Like Post" as UC_LikePost
  usecase "Create Post" as UC_CreatePost
  usecase "Report Content" as UC_ReportContent
  usecase "Edit Profile" as UC_EditProfile
  usecase "Send Message" as UC_SendMessage
  usecase "Comment" as UC_Comment
  usecase "Share Post" as UC_SharePost
}
M --> UC_SendMessage
M --> UC_CreatePost
A --> UC_SendMessage
A --> UC_Comment
A --> UC_EditProfile
A1 --> UC_Comment
U --> UC_LikePost
U --> UC_SharePost
U --> UC_Comment
UC_LikePost ..|> UC_FollowUser : <<include>>
@enduml