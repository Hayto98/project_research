@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
left to right direction
actor "Receptionist" as Receptionist
actor "Housekeeper" as Housekeeper
actor "Manager" as Manager
actor "Chef" as Chef
rectangle "Hotel System" {
  usecase "Cancel Reservation" as UC_CancelReservation
  usecase "Process Payment" as UC_ProcessPayment
  usecase "Clean Room" as UC_CleanRoom
  usecase "Check In" as UC_CheckIn
  usecase "Book Room" as UC_BookRoom
  usecase "Request Service" as UC_RequestService
  usecase "Check Out" as UC_CheckOut
  usecase "Order Room Service" as UC_OrderRoomService
}
Receptionist --> UC_CleanRoom
Housekeeper --> UC_CancelReservation
Manager --> UC_CheckOut
Manager --> UC_BookRoom
Chef --> UC_BookRoom
Chef --> UC_OrderRoomService
UC_CancelReservation ..|> UC_CheckOut : <<extend>>
@enduml