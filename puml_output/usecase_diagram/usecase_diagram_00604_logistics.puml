@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
left to right direction
actor "Dispatcher" as D
actor "Fleet Manager" as FM
actor "Warehouse Staff" as WS
actor "Driver" as D1
rectangle "Logistics System" {
  usecase "Report Issue" as UC_ReportIssue
  usecase "Schedule Pickup" as UC_SchedulePickup
  usecase "Update Inventory" as UC_UpdateInventory
  usecase "Assign Route" as UC_AssignRoute
  usecase "Load Package" as UC_LoadPackage
}
D --> UC_UpdateInventory
D --> UC_ReportIssue
D --> UC_SchedulePickup
FM --> UC_UpdateInventory
WS --> UC_SchedulePickup
D1 --> UC_LoadPackage
D1 --> UC_ReportIssue
D1 --> UC_SchedulePickup
UC_UpdateInventory ..> UC_SchedulePickup : <<include>>
@enduml