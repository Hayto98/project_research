@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
left to right direction
actor "Chef" as Chef
actor "Guest" as Guest
actor "Receptionist" as Receptionist
actor "Manager" as Manager
rectangle "Hotel System" {
  usecase "Check Out" as UC_CheckOut
  usecase "Process Payment" as UC_ProcessPayment
  usecase "Cancel Reservation" as UC_CancelReservation
  usecase "Clean Room" as UC_CleanRoom
  usecase "Book Room" as UC_BookRoom
  usecase "Request Service" as UC_RequestService
}
Chef --> UC_CancelReservation
Chef --> UC_CleanRoom
Guest --> UC_CleanRoom
Guest --> UC_ProcessPayment
Receptionist --> UC_CheckOut
Receptionist --> UC_CancelReservation
Receptionist --> UC_BookRoom
Manager --> UC_BookRoom
Manager --> UC_CancelReservation
Manager --> UC_ProcessPayment
UC_ProcessPayment ..|> UC_CancelReservation : <<extend>>
@enduml