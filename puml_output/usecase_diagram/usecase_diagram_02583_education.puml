@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
left to right direction
actor "Teacher" as T
actor "Student" as S
actor "Registrar" as R
rectangle "Education System" {
  usecase "Take Attendance" as UC_TakeAttendance
  usecase "Submit Assignment" as UC_SubmitAssignment
  usecase "View Schedule" as UC_ViewSchedule
  usecase "Enroll Course" as UC_EnrollCourse
  usecase "Register Student" as UC_RegisterStudent
}
T --> UC_SubmitAssignment
T --> UC_RegisterStudent
S --> UC_TakeAttendance
S --> UC_EnrollCourse
R --> UC_ViewSchedule
R --> UC_TakeAttendance
R --> UC_EnrollCourse
UC_ViewSchedule ..|> UC_SubmitAssignment : <<include>>
@enduml