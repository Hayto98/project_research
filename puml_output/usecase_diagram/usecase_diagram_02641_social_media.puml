@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
left to right direction
actor "Admin" as A
actor "Moderator" as M
actor "User" as U
rectangle "Social Media System" {
  usecase "Report Content" as UC_ReportContent
  usecase "Send Message" as UC_SendMessage
  usecase "Like Post" as UC_LikePost
  usecase "Edit Profile" as UC_EditProfile
  usecase "Share Post" as UC_SharePost
}
A --> UC_LikePost
M --> UC_ReportContent
M --> UC_SendMessage
M --> UC_LikePost
U --> UC_EditProfile
U --> UC_ReportContent
@enduml