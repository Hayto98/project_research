@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
left to right direction
actor "Housekeeper" as H
actor "Manager" as M
actor "Chef" as C
actor "Receptionist" as R
rectangle "Hotel System" {
  usecase "Request Service" as UC_RequestService
  usecase "Order Room Service" as UC_OrderRoomService
  usecase "Check In" as UC_CheckIn
  usecase "Book Room" as UC_BookRoom
  usecase "Process Payment" as UC_ProcessPayment
}
H --> UC_RequestService
H --> UC_ProcessPayment
M --> UC_ProcessPayment
M --> UC_CheckIn
C --> UC_OrderRoomService
C --> UC_BookRoom
R --> UC_RequestService
R --> UC_BookRoom
R --> UC_ProcessPayment
UC_ProcessPayment ..> UC_RequestService : <<extend>>
@enduml