@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
left to right direction
actor "Registrar" as R
actor "Parent" as P
actor "Admin" as A
actor "Librarian" as L
rectangle "Education System" {
  usecase "Submit Assignment" as UC_SubmitAssignment
  usecase "Grade Exam" as UC_GradeExam
  usecase "Take Attendance" as UC_TakeAttendance
  usecase "Issue Certificate" as UC_IssueCertificate
  usecase "View Schedule" as UC_ViewSchedule
  usecase "Borrow Book" as UC_BorrowBook
}
R --> UC_ViewSchedule
P --> UC_TakeAttendance
P --> UC_GradeExam
P --> UC_BorrowBook
A --> UC_GradeExam
A --> UC_TakeAttendance
L --> UC_SubmitAssignment
L --> UC_ViewSchedule
UC_ViewSchedule ..> UC_SubmitAssignment : <<include>>
@enduml