@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
left to right direction
actor "Housekeeper" as H
actor "Chef" as C
actor "Guest" as G
actor "Manager" as M
rectangle "Hotel System" {
  usecase "Check In" as UC_CheckIn
  usecase "Order Room Service" as UC_OrderRoomService
  usecase "Request Service" as UC_RequestService
  usecase "Clean Room" as UC_CleanRoom
  usecase "Check Out" as UC_CheckOut
  usecase "Book Room" as UC_BookRoom
  usecase "Process Payment" as UC_ProcessPayment
}
H --> UC_RequestService
H --> UC_ProcessPayment
H --> UC_CleanRoom
C --> UC_CleanRoom
C --> UC_BookRoom
C --> UC_RequestService
G --> UC_ProcessPayment
G --> UC_CleanRoom
M --> UC_BookRoom
M --> UC_RequestService
M --> UC_CheckIn
UC_OrderRoomService ..> UC_CleanRoom : <<include>>
@enduml