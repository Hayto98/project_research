@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
left to right direction
actor "Librarian" as L
actor "Admin" as A
actor "Parent" as P
rectangle "Education System" {
  usecase "View Schedule" as UC_ViewSchedule
  usecase "Grade Exam" as UC_GradeExam
  usecase "Issue Certificate" as UC_IssueCertificate
  usecase "Borrow Book" as UC_BorrowBook
  usecase "Enroll Course" as UC_EnrollCourse
}
L --> UC_GradeExam
L --> UC_BorrowBook
L --> UC_EnrollCourse
A --> UC_IssueCertificate
A --> UC_BorrowBook
A --> UC_EnrollCourse
P --> UC_BorrowBook
UC_IssueCertificate ..|> UC_ViewSchedule : <<include>>
@enduml