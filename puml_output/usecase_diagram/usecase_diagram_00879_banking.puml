@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
left to right direction
actor "ATM" as A
actor "Branch Manager" as BM
actor "Bank Teller" as BT
actor "Account Holder" as AH
rectangle "Banking System" {
  usecase "Deposit Money" as UC_DepositMoney
  usecase "View Statement" as UC_ViewStatement
  usecase "Apply For Loan" as UC_ApplyForLoan
  usecase "Transfer Funds" as UC_TransferFunds
  usecase "Block Card" as UC_BlockCard
  usecase "Open Account" as UC_OpenAccount
  usecase "Withdraw Cash" as UC_WithdrawCash
  usecase "Pay Bill" as UC_PayBill
}
A --> UC_BlockCard
A --> UC_OpenAccount
A --> UC_DepositMoney
BM --> UC_DepositMoney
BM --> UC_OpenAccount
BT --> UC_BlockCard
BT --> UC_ViewStatement
AH --> UC_WithdrawCash
AH --> UC_ApplyForLoan
AH --> UC_TransferFunds
UC_ViewStatement ..> UC_PayBill : <<include>>
@enduml