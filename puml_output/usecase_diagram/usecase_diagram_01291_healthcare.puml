@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
left to right direction
actor "Doctor" as Doctor
actor "Receptionist" as Receptionist
actor "Patient" as Patient
rectangle "Healthcare System" {
  usecase "Book Appointment" as UC_BookAppointment
  usecase "Examine Patient" as UC_ExaminePatient
  usecase "Discharge Patient" as UC_DischargePatient
  usecase "Admit Patient" as UC_AdmitPatient
  usecase "Run Lab Test" as UC_RunLabTest
}
Doctor --> UC_RunLabTest
Doctor --> UC_BookAppointment
Receptionist --> UC_ExaminePatient
Receptionist --> UC_DischargePatient
Receptionist --> UC_BookAppointment
Patient --> UC_AdmitPatient
Patient --> UC_ExaminePatient
UC_BookAppointment ..> UC_ExaminePatient : <<include>>
@enduml