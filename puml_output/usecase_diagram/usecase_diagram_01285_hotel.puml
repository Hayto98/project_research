@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
left to right direction
actor "Housekeeper" as H
actor "Manager" as M
actor "Guest" as G
actor "Chef" as C
rectangle "Hotel System" {
  usecase "Check Out" as UC_CheckOut
  usecase "Order Room Service" as UC_OrderRoomService
  usecase "Cancel Reservation" as UC_CancelReservation
  usecase "Request Service" as UC_RequestService
  usecase "Process Payment" as UC_ProcessPayment
  usecase "Book Room" as UC_BookRoom
}
H --> UC_ProcessPayment
H --> UC_CheckOut
H --> UC_RequestService
M --> UC_BookRoom
M --> UC_OrderRoomService
M --> UC_CancelReservation
G --> UC_CancelReservation
G --> UC_BookRoom
G --> UC_CheckOut
C --> UC_RequestService
C --> UC_ProcessPayment
UC_OrderRoomService ..> UC_RequestService : <<extend>>
@enduml