@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
left to right direction
actor "Admin" as A
actor "Advertiser" as A1
actor "User" as U
actor "Moderator" as M
rectangle "Social Media System" {
  usecase "Edit Profile" as UC_EditProfile
  usecase "Share Post" as UC_SharePost
  usecase "Send Message" as UC_SendMessage
  usecase "Create Post" as UC_CreatePost
  usecase "Follow User" as UC_FollowUser
}
A --> UC_FollowUser
A --> UC_EditProfile
A1 --> UC_CreatePost
A1 --> UC_EditProfile
A1 --> UC_FollowUser
U --> UC_FollowUser
U --> UC_SendMessage
U --> UC_SharePost
M --> UC_SendMessage
M --> UC_SharePost
M --> UC_EditProfile
UC_CreatePost ..|> UC_SendMessage : <<extend>>
@enduml