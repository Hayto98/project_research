@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
left to right direction
actor "Admin" as Admin
actor "Advertiser" as Advertiser
actor "User" as User
actor "Moderator" as Moderator
rectangle "Social Media System" {
  usecase "Edit Profile" as UC_EditProfile
  usecase "Share Post" as UC_SharePost
  usecase "Send Message" as UC_SendMessage
  usecase "Create Post" as UC_CreatePost
  usecase "Follow User" as UC_FollowUser
}
Admin --> UC_FollowUser
Admin --> UC_EditProfile
Advertiser --> UC_CreatePost
Advertiser --> UC_EditProfile
Advertiser --> UC_FollowUser
User --> UC_FollowUser
User --> UC_SendMessage
User --> UC_SharePost
Moderator --> UC_SendMessage
Moderator --> UC_SharePost
Moderator --> UC_EditProfile
UC_CreatePost ..|> UC_SendMessage : <<extend>>
@enduml