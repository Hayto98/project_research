@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
left to right direction
actor "Nurse" as N
actor "Lab Technician" as LT
actor "Doctor" as D
rectangle "Healthcare System" {
  usecase "Update Medical Record" as UC_UpdateMedicalRecord
  usecase "Admit Patient" as UC_AdmitPatient
  usecase "Run Lab Test" as UC_RunLabTest
  usecase "Discharge Patient" as UC_DischargePatient
  usecase "Examine Patient" as UC_ExaminePatient
}
N --> UC_AdmitPatient
N --> UC_UpdateMedicalRecord
N --> UC_ExaminePatient
LT --> UC_UpdateMedicalRecord
LT --> UC_ExaminePatient
D --> UC_AdmitPatient
D --> UC_DischargePatient
D --> UC_UpdateMedicalRecord
UC_AdmitPatient ..> UC_UpdateMedicalRecord : <<extend>>
@enduml