@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
left to right direction
actor "User" as U
actor "Moderator" as M
actor "Advertiser" as A
actor "Admin" as A1
rectangle "Social Media System" {
  usecase "Send Message" as UC_SendMessage
  usecase "Edit Profile" as UC_EditProfile
  usecase "Like Post" as UC_LikePost
  usecase "Share Post" as UC_SharePost
  usecase "Follow User" as UC_FollowUser
}
U --> UC_SendMessage
U --> UC_LikePost
M --> UC_EditProfile
M --> UC_LikePost
M --> UC_SendMessage
A --> UC_LikePost
A --> UC_SendMessage
A --> UC_EditProfile
A1 --> UC_LikePost
A1 --> UC_FollowUser
UC_LikePost ..> UC_SendMessage : <<extend>>
@enduml