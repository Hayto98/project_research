@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
left to right direction
actor "Admin" as A
actor "Parent" as P
actor "Teacher" as T
actor "Registrar" as R
rectangle "Education System" {
  usecase "Borrow Book" as UC_BorrowBook
  usecase "Register Student" as UC_RegisterStudent
  usecase "Enroll Course" as UC_EnrollCourse
  usecase "Take Attendance" as UC_TakeAttendance
  usecase "Issue Certificate" as UC_IssueCertificate
  usecase "View Schedule" as UC_ViewSchedule
  usecase "Submit Assignment" as UC_SubmitAssignment
}
A --> UC_IssueCertificate
A --> UC_EnrollCourse
A --> UC_BorrowBook
P --> UC_TakeAttendance
P --> UC_SubmitAssignment
T --> UC_BorrowBook
T --> UC_ViewSchedule
T --> UC_RegisterStudent
R --> UC_SubmitAssignment
R --> UC_BorrowBook
R --> UC_EnrollCourse
UC_IssueCertificate ..> UC_ViewSchedule : <<extend>>
@enduml