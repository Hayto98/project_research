@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
left to right direction
actor "Admin" as Admin
actor "Parent" as Parent
actor "Teacher" as Teacher
actor "Registrar" as Registrar
rectangle "Education System" {
  usecase "Borrow Book" as UC_BorrowBook
  usecase "Register Student" as UC_RegisterStudent
  usecase "Enroll Course" as UC_EnrollCourse
  usecase "Take Attendance" as UC_TakeAttendance
  usecase "Issue Certificate" as UC_IssueCertificate
  usecase "View Schedule" as UC_ViewSchedule
  usecase "Submit Assignment" as UC_SubmitAssignment
}
Admin --> UC_IssueCertificate
Admin --> UC_EnrollCourse
Admin --> UC_BorrowBook
Parent --> UC_TakeAttendance
Parent --> UC_SubmitAssignment
Teacher --> UC_BorrowBook
Teacher --> UC_ViewSchedule
Teacher --> UC_RegisterStudent
Registrar --> UC_SubmitAssignment
Registrar --> UC_BorrowBook
Registrar --> UC_EnrollCourse
UC_IssueCertificate ..> UC_ViewSchedule : <<extend>>
@enduml