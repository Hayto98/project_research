@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
left to right direction
actor "Insurance Provider" as InsuranceProvider
actor "Patient" as Patient
actor "Doctor" as Doctor
actor "Lab Technician" as LabTechnician
rectangle "Healthcare System" {
  usecase "Examine Patient" as UC_ExaminePatient
  usecase "Run Lab Test" as UC_RunLabTest
  usecase "Book Appointment" as UC_BookAppointment
  usecase "Issue Prescription" as UC_IssuePrescription
  usecase "Update Medical Record" as UC_UpdateMedicalRecord
  usecase "Admit Patient" as UC_AdmitPatient
  usecase "Discharge Patient" as UC_DischargePatient
}
InsuranceProvider --> UC_DischargePatient
InsuranceProvider --> UC_AdmitPatient
InsuranceProvider --> UC_UpdateMedicalRecord
Patient --> UC_IssuePrescription
Patient --> UC_UpdateMedicalRecord
Patient --> UC_AdmitPatient
Doctor --> UC_AdmitPatient
LabTechnician --> UC_ExaminePatient
LabTechnician --> UC_BookAppointment
LabTechnician --> UC_UpdateMedicalRecord
UC_ExaminePatient ..|> UC_AdmitPatient : <<include>>
@enduml