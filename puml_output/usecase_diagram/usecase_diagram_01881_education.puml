@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
left to right direction
actor "Teacher" as T
actor "Student" as S
actor "Admin" as A
actor "Librarian" as L
rectangle "Education System" {
  usecase "Grade Exam" as UC_GradeExam
  usecase "View Schedule" as UC_ViewSchedule
  usecase "Take Attendance" as UC_TakeAttendance
  usecase "Borrow Book" as UC_BorrowBook
  usecase "Submit Assignment" as UC_SubmitAssignment
}
T --> UC_BorrowBook
S --> UC_SubmitAssignment
A --> UC_BorrowBook
A --> UC_TakeAttendance
L --> UC_SubmitAssignment
UC_BorrowBook ..> UC_TakeAttendance : <<include>>
@enduml