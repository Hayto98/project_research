@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
left to right direction
actor "Bank Teller" as BT
actor "ATM" as A
actor "Auditor" as A1
actor "Account Holder" as AH
rectangle "Banking System" {
  usecase "Pay Bill" as UC_PayBill
  usecase "Apply For Loan" as UC_ApplyForLoan
  usecase "Deposit Money" as UC_DepositMoney
  usecase "Block Card" as UC_BlockCard
  usecase "Withdraw Cash" as UC_WithdrawCash
  usecase "Open Account" as UC_OpenAccount
}
BT --> UC_OpenAccount
A --> UC_BlockCard
A --> UC_PayBill
A --> UC_ApplyForLoan
A1 --> UC_BlockCard
A1 --> UC_DepositMoney
A1 --> UC_WithdrawCash
AH --> UC_WithdrawCash
UC_BlockCard ..|> UC_WithdrawCash : <<include>>
@enduml