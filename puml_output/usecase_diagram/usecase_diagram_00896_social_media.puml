@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
left to right direction
actor "Advertiser" as A
actor "Admin" as A1
rectangle "Social Media System" {
  usecase "Edit Profile" as UC_EditProfile
  usecase "Share Post" as UC_SharePost
  usecase "Like Post" as UC_LikePost
  usecase "Follow User" as UC_FollowUser
  usecase "Comment" as UC_Comment
}
A --> UC_FollowUser
A --> UC_EditProfile
A1 --> UC_FollowUser
A1 --> UC_SharePost
A1 --> UC_EditProfile
UC_FollowUser ..> UC_LikePost : <<extend>>
@enduml