@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
left to right direction
actor "Admin" as A
actor "Payment Gateway" as PG
actor "Seller" as S
actor "Customer" as C
rectangle "Ecommerce System" {
  usecase "Write Review" as UC_WriteReview
  usecase "Apply Coupon" as UC_ApplyCoupon
  usecase "Cancel Order" as UC_CancelOrder
  usecase "Checkout" as UC_Checkout
  usecase "Track Order" as UC_TrackOrder
  usecase "Browse Products" as UC_BrowseProducts
  usecase "Manage Inventory" as UC_ManageInventory
}
A --> UC_ApplyCoupon
A --> UC_CancelOrder
A --> UC_TrackOrder
PG --> UC_WriteReview
S --> UC_ManageInventory
S --> UC_Checkout
S --> UC_WriteReview
C --> UC_WriteReview
C --> UC_ManageInventory
C --> UC_TrackOrder
@enduml