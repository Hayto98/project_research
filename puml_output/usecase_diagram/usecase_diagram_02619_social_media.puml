@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
left to right direction
actor "Admin" as A
actor "User" as U
actor "Advertiser" as A1
actor "Moderator" as M
rectangle "Social Media System" {
  usecase "Like Post" as UC_LikePost
  usecase "Edit Profile" as UC_EditProfile
  usecase "Follow User" as UC_FollowUser
  usecase "Share Post" as UC_SharePost
  usecase "Comment" as UC_Comment
  usecase "Report Content" as UC_ReportContent
}
A --> UC_EditProfile
A --> UC_FollowUser
A --> UC_LikePost
U --> UC_Comment
A1 --> UC_LikePost
A1 --> UC_FollowUser
A1 --> UC_ReportContent
M --> UC_SharePost
M --> UC_FollowUser
M --> UC_Comment
UC_LikePost ..> UC_SharePost : <<extend>>
@enduml