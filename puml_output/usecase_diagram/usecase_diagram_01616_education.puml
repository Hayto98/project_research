@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
left to right direction
actor "Parent" as P
actor "Librarian" as L
actor "Teacher" as T
actor "Student" as S
rectangle "Education System" {
  usecase "Grade Exam" as UC_GradeExam
  usecase "Take Attendance" as UC_TakeAttendance
  usecase "Borrow Book" as UC_BorrowBook
  usecase "View Schedule" as UC_ViewSchedule
  usecase "Issue Certificate" as UC_IssueCertificate
  usecase "Submit Assignment" as UC_SubmitAssignment
}
P --> UC_GradeExam
P --> UC_SubmitAssignment
P --> UC_TakeAttendance
L --> UC_ViewSchedule
L --> UC_GradeExam
T --> UC_SubmitAssignment
T --> UC_ViewSchedule
T --> UC_GradeExam
S --> UC_BorrowBook
S --> UC_TakeAttendance
S --> UC_SubmitAssignment
@enduml