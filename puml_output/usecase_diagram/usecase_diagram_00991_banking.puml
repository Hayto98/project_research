@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
left to right direction
actor "Branch Manager" as BM
actor "Bank Teller" as BT
actor "ATM" as A
actor "Account Holder" as AH
rectangle "Banking System" {
  usecase "Deposit Money" as UC_DepositMoney
  usecase "Transfer Funds" as UC_TransferFunds
  usecase "Pay Bill" as UC_PayBill
  usecase "Block Card" as UC_BlockCard
  usecase "Withdraw Cash" as UC_WithdrawCash
}
BM --> UC_TransferFunds
BT --> UC_WithdrawCash
BT --> UC_TransferFunds
BT --> UC_PayBill
A --> UC_BlockCard
A --> UC_DepositMoney
A --> UC_WithdrawCash
AH --> UC_DepositMoney
AH --> UC_WithdrawCash
@enduml