@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
left to right direction
actor "Doctor" as Doctor
actor "Lab Technician" as LabTechnician
actor "Receptionist" as Receptionist
rectangle "Healthcare System" {
  usecase "Process Insurance Claim" as UC_ProcessInsuranceClaim
  usecase "Admit Patient" as UC_AdmitPatient
  usecase "Update Medical Record" as UC_UpdateMedicalRecord
  usecase "Run Lab Test" as UC_RunLabTest
  usecase "Book Appointment" as UC_BookAppointment
}
Doctor --> UC_RunLabTest
Doctor --> UC_BookAppointment
Doctor --> UC_ProcessInsuranceClaim
LabTechnician --> UC_UpdateMedicalRecord
Receptionist --> UC_ProcessInsuranceClaim
Receptionist --> UC_BookAppointment
Receptionist --> UC_RunLabTest
UC_UpdateMedicalRecord ..|> UC_ProcessInsuranceClaim : <<extend>>
@enduml