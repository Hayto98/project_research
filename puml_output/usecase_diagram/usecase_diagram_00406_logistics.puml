@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
left to right direction
actor "Driver" as Driver
actor "Warehouse Staff" as WarehouseStaff
actor "Customer" as Customer
actor "Dispatcher" as Dispatcher
rectangle "Logistics System" {
  usecase "Track Shipment" as UC_TrackShipment
  usecase "Update Inventory" as UC_UpdateInventory
  usecase "Assign Route" as UC_AssignRoute
  usecase "Load Package" as UC_LoadPackage
  usecase "Deliver Package" as UC_DeliverPackage
}
Driver --> UC_AssignRoute
Driver --> UC_TrackShipment
Driver --> UC_DeliverPackage
WarehouseStaff --> UC_DeliverPackage
WarehouseStaff --> UC_LoadPackage
WarehouseStaff --> UC_UpdateInventory
Customer --> UC_AssignRoute
Customer --> UC_DeliverPackage
Customer --> UC_LoadPackage
Dispatcher --> UC_LoadPackage
Dispatcher --> UC_DeliverPackage
Dispatcher --> UC_AssignRoute
UC_LoadPackage ..> UC_DeliverPackage : <<extend>>
@enduml