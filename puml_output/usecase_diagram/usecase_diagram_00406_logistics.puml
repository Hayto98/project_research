@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
left to right direction
actor "Driver" as D
actor "Warehouse Staff" as WS
actor "Customer" as C
actor "Dispatcher" as D1
rectangle "Logistics System" {
  usecase "Track Shipment" as UC_TrackShipment
  usecase "Update Inventory" as UC_UpdateInventory
  usecase "Assign Route" as UC_AssignRoute
  usecase "Load Package" as UC_LoadPackage
  usecase "Deliver Package" as UC_DeliverPackage
}
D --> UC_AssignRoute
D --> UC_TrackShipment
D --> UC_DeliverPackage
WS --> UC_DeliverPackage
WS --> UC_LoadPackage
WS --> UC_UpdateInventory
C --> UC_AssignRoute
C --> UC_DeliverPackage
C --> UC_LoadPackage
D1 --> UC_LoadPackage
D1 --> UC_DeliverPackage
D1 --> UC_AssignRoute
UC_LoadPackage ..> UC_DeliverPackage : <<extend>>
@enduml