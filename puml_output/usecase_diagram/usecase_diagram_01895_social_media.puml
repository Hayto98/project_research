@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
left to right direction
actor "Admin" as A
actor "Moderator" as M
actor "User" as U
rectangle "Social Media System" {
  usecase "Create Post" as UC_CreatePost
  usecase "Share Post" as UC_SharePost
  usecase "Edit Profile" as UC_EditProfile
  usecase "Send Message" as UC_SendMessage
  usecase "Like Post" as UC_LikePost
}
A --> UC_EditProfile
M --> UC_LikePost
M --> UC_SendMessage
M --> UC_CreatePost
U --> UC_EditProfile
U --> UC_LikePost
U --> UC_SendMessage
UC_EditProfile ..|> UC_SendMessage : <<extend>>
@enduml