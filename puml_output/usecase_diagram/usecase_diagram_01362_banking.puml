@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
left to right direction
actor "Branch Manager" as BM
actor "Bank Teller" as BT
actor "ATM" as A
actor "Account Holder" as AH
rectangle "Banking System" {
  usecase "Apply For Loan" as UC_ApplyForLoan
  usecase "Block Card" as UC_BlockCard
  usecase "View Statement" as UC_ViewStatement
  usecase "Pay Bill" as UC_PayBill
  usecase "Deposit Money" as UC_DepositMoney
  usecase "Withdraw Cash" as UC_WithdrawCash
}
BM --> UC_ApplyForLoan
BM --> UC_WithdrawCash
BM --> UC_BlockCard
BT --> UC_PayBill
BT --> UC_ViewStatement
A --> UC_ApplyForLoan
A --> UC_WithdrawCash
A --> UC_ViewStatement
AH --> UC_BlockCard
UC_DepositMoney ..> UC_ViewStatement : <<include>>
@enduml