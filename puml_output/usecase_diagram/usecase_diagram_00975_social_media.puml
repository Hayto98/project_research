@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
left to right direction
actor "User" as U
actor "Advertiser" as A
actor "Moderator" as M
actor "Admin" as A1
rectangle "Social Media System" {
  usecase "Create Post" as UC_CreatePost
  usecase "Edit Profile" as UC_EditProfile
  usecase "Share Post" as UC_SharePost
  usecase "Comment" as UC_Comment
  usecase "Send Message" as UC_SendMessage
}
U --> UC_SendMessage
A --> UC_CreatePost
A --> UC_SharePost
A --> UC_SendMessage
M --> UC_Comment
M --> UC_EditProfile
A1 --> UC_SendMessage
@enduml