@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
left to right direction
actor "ATM" as A
actor "Bank Teller" as BT
actor "Branch Manager" as BM
actor "Auditor" as A1
rectangle "Banking System" {
  usecase "Pay Bill" as UC_PayBill
  usecase "View Statement" as UC_ViewStatement
  usecase "Deposit Money" as UC_DepositMoney
  usecase "Transfer Funds" as UC_TransferFunds
  usecase "Withdraw Cash" as UC_WithdrawCash
  usecase "Apply For Loan" as UC_ApplyForLoan
  usecase "Open Account" as UC_OpenAccount
}
A --> UC_OpenAccount
A --> UC_DepositMoney
A --> UC_ApplyForLoan
BT --> UC_OpenAccount
BT --> UC_PayBill
BT --> UC_DepositMoney
BM --> UC_TransferFunds
BM --> UC_DepositMoney
BM --> UC_WithdrawCash
A1 --> UC_DepositMoney
A1 --> UC_OpenAccount
UC_DepositMoney ..|> UC_ViewStatement : <<include>>
@enduml