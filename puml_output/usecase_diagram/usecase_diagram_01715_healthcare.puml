@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
left to right direction
actor "Patient" as P
actor "Nurse" as N
actor "Lab Technician" as LT
actor "Doctor" as D
rectangle "Healthcare System" {
  usecase "Issue Prescription" as UC_IssuePrescription
  usecase "Examine Patient" as UC_ExaminePatient
  usecase "Discharge Patient" as UC_DischargePatient
  usecase "Admit Patient" as UC_AdmitPatient
  usecase "Book Appointment" as UC_BookAppointment
}
P --> UC_ExaminePatient
P --> UC_BookAppointment
P --> UC_AdmitPatient
N --> UC_DischargePatient
N --> UC_ExaminePatient
LT --> UC_DischargePatient
LT --> UC_ExaminePatient
D --> UC_DischargePatient
D --> UC_BookAppointment
D --> UC_AdmitPatient
@enduml