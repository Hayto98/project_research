@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
left to right direction
actor "Delivery Service" as DS
actor "Admin" as A
actor "Customer" as C
rectangle "Ecommerce System" {
  usecase "Make Payment" as UC_MakePayment
  usecase "Apply Coupon" as UC_ApplyCoupon
  usecase "Track Order" as UC_TrackOrder
  usecase "Write Review" as UC_WriteReview
  usecase "Add To Cart" as UC_AddToCart
  usecase "Checkout" as UC_Checkout
  usecase "Cancel Order" as UC_CancelOrder
  usecase "Manage Inventory" as UC_ManageInventory
}
DS --> UC_ApplyCoupon
DS --> UC_TrackOrder
DS --> UC_MakePayment
A --> UC_CancelOrder
A --> UC_ApplyCoupon
C --> UC_TrackOrder
C --> UC_WriteReview
C --> UC_ManageInventory
UC_MakePayment ..> UC_Checkout : <<extend>>
@enduml