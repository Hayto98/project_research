@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
left to right direction
actor "Librarian" as L
actor "Parent" as P
actor "Admin" as A
rectangle "Education System" {
  usecase "Submit Assignment" as UC_SubmitAssignment
  usecase "Take Attendance" as UC_TakeAttendance
  usecase "View Schedule" as UC_ViewSchedule
  usecase "Borrow Book" as UC_BorrowBook
  usecase "Register Student" as UC_RegisterStudent
}
L --> UC_BorrowBook
L --> UC_TakeAttendance
L --> UC_ViewSchedule
P --> UC_BorrowBook
P --> UC_SubmitAssignment
A --> UC_BorrowBook
A --> UC_TakeAttendance
A --> UC_SubmitAssignment
UC_ViewSchedule ..> UC_TakeAttendance : <<extend>>
@enduml