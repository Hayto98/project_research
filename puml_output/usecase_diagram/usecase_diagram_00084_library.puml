@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
left to right direction
actor "Member" as M
actor "Admin" as A
actor "Librarian" as L
rectangle "Library System" {
  usecase "Search Catalog" as UC_SearchCatalog
  usecase "Renew Loan" as UC_RenewLoan
  usecase "Add New Book" as UC_AddNewBook
  usecase "Register Member" as UC_RegisterMember
  usecase "Pay Fine" as UC_PayFine
  usecase "Reserve Book" as UC_ReserveBook
  usecase "Borrow Book" as UC_BorrowBook
}
M --> UC_RenewLoan
A --> UC_RegisterMember
A --> UC_RenewLoan
A --> UC_SearchCatalog
L --> UC_AddNewBook
L --> UC_ReserveBook
L --> UC_PayFine
UC_RenewLoan ..|> UC_PayFine : <<extend>>
@enduml