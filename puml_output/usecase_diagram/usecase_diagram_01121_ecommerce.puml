@startuml
skinparam monochrome true
skinparam defaultFontSize 11
left to right direction
actor "Payment Gateway" as PG
actor "Delivery Service" as DS
actor "Customer" as C
actor "Seller" as S
rectangle "Ecommerce System" {
  usecase "Cancel Order" as UC_CancelOrder
  usecase "Make Payment" as UC_MakePayment
  usecase "Write Review" as UC_WriteReview
  usecase "Checkout" as UC_Checkout
  usecase "Browse Products" as UC_BrowseProducts
}
PG --> UC_WriteReview
PG --> UC_MakePayment
PG --> UC_CancelOrder
DS --> UC_MakePayment
C --> UC_Checkout
S --> UC_CancelOrder
S --> UC_MakePayment
S --> UC_BrowseProducts
UC_BrowseProducts ..|> UC_WriteReview : <<extend>>
@enduml