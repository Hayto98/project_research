@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
left to right direction
actor "Customer" as C
actor "Fleet Manager" as FM
rectangle "Logistics System" {
  usecase "Load Package" as UC_LoadPackage
  usecase "Schedule Pickup" as UC_SchedulePickup
  usecase "Update Inventory" as UC_UpdateInventory
  usecase "Deliver Package" as UC_DeliverPackage
  usecase "Track Shipment" as UC_TrackShipment
}
C --> UC_LoadPackage
C --> UC_DeliverPackage
FM --> UC_UpdateInventory
FM --> UC_SchedulePickup
FM --> UC_DeliverPackage
UC_SchedulePickup ..|> UC_UpdateInventory : <<extend>>
@enduml