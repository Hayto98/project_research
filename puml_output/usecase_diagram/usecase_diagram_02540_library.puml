@startuml
skinparam defaultFontSize 11
left to right direction
actor "Admin" as A
actor "Member" as M
rectangle "Library System" {
  usecase "Return Book" as UC_ReturnBook
  usecase "Pay Fine" as UC_PayFine
  usecase "Add New Book" as UC_AddNewBook
  usecase "Reserve Book" as UC_ReserveBook
  usecase "Renew Loan" as UC_RenewLoan
}
A --> UC_ReturnBook
A --> UC_AddNewBook
M --> UC_PayFine
M --> UC_ReturnBook
M --> UC_AddNewBook
UC_ReturnBook ..> UC_PayFine : <<extend>>
@enduml