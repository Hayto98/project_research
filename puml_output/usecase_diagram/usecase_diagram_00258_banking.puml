@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
left to right direction
actor "Auditor" as A
actor "ATM" as A1
actor "Branch Manager" as BM
actor "Account Holder" as AH
rectangle "Banking System" {
  usecase "Block Card" as UC_BlockCard
  usecase "Transfer Funds" as UC_TransferFunds
  usecase "Open Account" as UC_OpenAccount
  usecase "Apply For Loan" as UC_ApplyForLoan
  usecase "Withdraw Cash" as UC_WithdrawCash
  usecase "Pay Bill" as UC_PayBill
}
A --> UC_PayBill
A --> UC_ApplyForLoan
A1 --> UC_OpenAccount
BM --> UC_WithdrawCash
BM --> UC_ApplyForLoan
AH --> UC_OpenAccount
AH --> UC_BlockCard
AH --> UC_ApplyForLoan
UC_TransferFunds ..|> UC_WithdrawCash : <<include>>
@enduml