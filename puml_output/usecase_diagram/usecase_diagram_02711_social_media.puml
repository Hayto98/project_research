@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
left to right direction
actor "User" as U
actor "Admin" as A
actor "Advertiser" as A1
actor "Moderator" as M
rectangle "Social Media System" {
  usecase "Share Post" as UC_SharePost
  usecase "Comment" as UC_Comment
  usecase "Like Post" as UC_LikePost
  usecase "Send Message" as UC_SendMessage
  usecase "Follow User" as UC_FollowUser
}
U --> UC_Comment
U --> UC_SharePost
A --> UC_SharePost
A1 --> UC_LikePost
A1 --> UC_FollowUser
A1 --> UC_Comment
M --> UC_SharePost
M --> UC_SendMessage
UC_Comment ..> UC_LikePost : <<include>>
@enduml