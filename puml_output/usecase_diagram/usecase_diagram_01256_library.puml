@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
left to right direction
actor "Admin" as A
actor "Member" as M
actor "Librarian" as L
rectangle "Library System" {
  usecase "Pay Fine" as UC_PayFine
  usecase "Search Catalog" as UC_SearchCatalog
  usecase "Return Book" as UC_ReturnBook
  usecase "Reserve Book" as UC_ReserveBook
  usecase "Add New Book" as UC_AddNewBook
}
A --> UC_PayFine
A --> UC_ReserveBook
A --> UC_AddNewBook
M --> UC_AddNewBook
M --> UC_SearchCatalog
L --> UC_ReturnBook
L --> UC_PayFine
L --> UC_SearchCatalog
@enduml