@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
left to right direction
actor "Advertiser" as Advertiser
actor "User" as User
actor "Admin" as Admin
rectangle "Social Media System" {
  usecase "Send Message" as UC_SendMessage
  usecase "Comment" as UC_Comment
  usecase "Share Post" as UC_SharePost
  usecase "Like Post" as UC_LikePost
  usecase "Edit Profile" as UC_EditProfile
}
Advertiser --> UC_LikePost
Advertiser --> UC_Comment
Advertiser --> UC_SendMessage
User --> UC_SendMessage
User --> UC_LikePost
User --> UC_Comment
Admin --> UC_SendMessage
Admin --> UC_Comment
UC_Comment ..> UC_EditProfile : <<extend>>
@enduml