@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
left to right direction
actor "Receptionist" as R
actor "Nurse" as N
rectangle "Healthcare System" {
  usecase "Admit Patient" as UC_AdmitPatient
  usecase "Issue Prescription" as UC_IssuePrescription
  usecase "Book Appointment" as UC_BookAppointment
  usecase "Run Lab Test" as UC_RunLabTest
  usecase "Process Insurance Claim" as UC_ProcessInsuranceClaim
  usecase "Discharge Patient" as UC_DischargePatient
  usecase "Examine Patient" as UC_ExaminePatient
  usecase "Update Medical Record" as UC_UpdateMedicalRecord
}
R --> UC_ExaminePatient
R --> UC_RunLabTest
N --> UC_DischargePatient
N --> UC_RunLabTest
N --> UC_AdmitPatient
UC_AdmitPatient ..> UC_ExaminePatient : <<extend>>
@enduml