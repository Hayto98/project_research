@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
left to right direction
actor "Advertiser" as A
actor "Moderator" as M
actor "Admin" as A1
actor "User" as U
rectangle "Social Media System" {
  usecase "Like Post" as UC_LikePost
  usecase "Share Post" as UC_SharePost
  usecase "Send Message" as UC_SendMessage
  usecase "Follow User" as UC_FollowUser
  usecase "Comment" as UC_Comment
  usecase "Create Post" as UC_CreatePost
}
A --> UC_CreatePost
M --> UC_SharePost
A1 --> UC_LikePost
A1 --> UC_FollowUser
A1 --> UC_SharePost
U --> UC_LikePost
UC_FollowUser ..|> UC_LikePost : <<extend>>
@enduml