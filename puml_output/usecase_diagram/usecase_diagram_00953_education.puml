@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
left to right direction
actor "Student" as S
actor "Admin" as A
actor "Parent" as P
actor "Teacher" as T
rectangle "Education System" {
  usecase "Grade Exam" as UC_GradeExam
  usecase "View Schedule" as UC_ViewSchedule
  usecase "Register Student" as UC_RegisterStudent
  usecase "Borrow Book" as UC_BorrowBook
  usecase "Enroll Course" as UC_EnrollCourse
  usecase "Take Attendance" as UC_TakeAttendance
}
S --> UC_ViewSchedule
S --> UC_EnrollCourse
S --> UC_RegisterStudent
A --> UC_ViewSchedule
P --> UC_BorrowBook
T --> UC_TakeAttendance
T --> UC_ViewSchedule
UC_BorrowBook ..> UC_RegisterStudent : <<extend>>
@enduml