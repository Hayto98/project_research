@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
left to right direction
actor "Librarian" as L
actor "Member" as M
rectangle "Library System" {
  usecase "Borrow Book" as UC_BorrowBook
  usecase "Add New Book" as UC_AddNewBook
  usecase "Pay Fine" as UC_PayFine
  usecase "Renew Loan" as UC_RenewLoan
  usecase "Register Member" as UC_RegisterMember
}
L --> UC_RegisterMember
L --> UC_PayFine
L --> UC_AddNewBook
M --> UC_PayFine
M --> UC_BorrowBook
M --> UC_AddNewBook
UC_BorrowBook ..|> UC_RenewLoan : <<extend>>
@enduml