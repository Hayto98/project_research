@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
left to right direction
actor "Chef" as C
actor "Housekeeper" as H
actor "Manager" as M
rectangle "Hotel System" {
  usecase "Clean Room" as UC_CleanRoom
  usecase "Process Payment" as UC_ProcessPayment
  usecase "Check In" as UC_CheckIn
  usecase "Check Out" as UC_CheckOut
  usecase "Book Room" as UC_BookRoom
}
C --> UC_BookRoom
H --> UC_CheckIn
H --> UC_BookRoom
H --> UC_CleanRoom
M --> UC_BookRoom
M --> UC_CheckIn
@enduml