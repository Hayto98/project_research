@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
left to right direction
actor "Account Holder" as AH
actor "ATM" as A
actor "Auditor" as A1
actor "Branch Manager" as BM
rectangle "Banking System" {
  usecase "Pay Bill" as UC_PayBill
  usecase "Transfer Funds" as UC_TransferFunds
  usecase "Withdraw Cash" as UC_WithdrawCash
  usecase "Block Card" as UC_BlockCard
  usecase "Apply For Loan" as UC_ApplyForLoan
  usecase "Open Account" as UC_OpenAccount
}
AH --> UC_OpenAccount
A --> UC_OpenAccount
A --> UC_ApplyForLoan
A --> UC_BlockCard
A1 --> UC_WithdrawCash
BM --> UC_OpenAccount
BM --> UC_BlockCard
UC_ApplyForLoan ..> UC_WithdrawCash : <<include>>
@enduml