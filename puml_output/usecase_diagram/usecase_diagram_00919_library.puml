@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
left to right direction
actor "Admin" as A
actor "Librarian" as L
actor "Member" as M
rectangle "Library System" {
  usecase "Borrow Book" as UC_BorrowBook
  usecase "Return Book" as UC_ReturnBook
  usecase "Register Member" as UC_RegisterMember
  usecase "Pay Fine" as UC_PayFine
  usecase "Reserve Book" as UC_ReserveBook
}
A --> UC_ReserveBook
L --> UC_ReturnBook
L --> UC_PayFine
L --> UC_RegisterMember
M --> UC_ReturnBook
M --> UC_BorrowBook
M --> UC_ReserveBook
UC_ReturnBook ..> UC_RegisterMember : <<extend>>
@enduml