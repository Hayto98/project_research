@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
left to right direction
actor "Parent" as P
actor "Librarian" as L
actor "Registrar" as R
rectangle "Education System" {
  usecase "Submit Assignment" as UC_SubmitAssignment
  usecase "Grade Exam" as UC_GradeExam
  usecase "Register Student" as UC_RegisterStudent
  usecase "Borrow Book" as UC_BorrowBook
  usecase "Take Attendance" as UC_TakeAttendance
}
P --> UC_RegisterStudent
P --> UC_SubmitAssignment
L --> UC_TakeAttendance
L --> UC_SubmitAssignment
R --> UC_BorrowBook
R --> UC_TakeAttendance
UC_SubmitAssignment ..|> UC_GradeExam : <<extend>>
@enduml