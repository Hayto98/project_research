@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
left to right direction
actor "Fleet Manager" as FM
actor "Dispatcher" as D
actor "Customer" as C
rectangle "Logistics System" {
  usecase "Schedule Pickup" as UC_SchedulePickup
  usecase "Fuel Vehicle" as UC_FuelVehicle
  usecase "Load Package" as UC_LoadPackage
  usecase "Track Shipment" as UC_TrackShipment
  usecase "Report Issue" as UC_ReportIssue
  usecase "Deliver Package" as UC_DeliverPackage
  usecase "Assign Route" as UC_AssignRoute
}
FM --> UC_DeliverPackage
FM --> UC_ReportIssue
FM --> UC_SchedulePickup
D --> UC_TrackShipment
D --> UC_SchedulePickup
C --> UC_LoadPackage
C --> UC_TrackShipment
UC_DeliverPackage ..> UC_ReportIssue : <<extend>>
@enduml