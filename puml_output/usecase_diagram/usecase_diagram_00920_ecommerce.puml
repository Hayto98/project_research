@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
left to right direction
actor "Payment Gateway" as PG
actor "Seller" as S
actor "Customer" as C
actor "Delivery Service" as DS
rectangle "Ecommerce System" {
  usecase "Write Review" as UC_WriteReview
  usecase "Browse Products" as UC_BrowseProducts
  usecase "Make Payment" as UC_MakePayment
  usecase "Apply Coupon" as UC_ApplyCoupon
  usecase "Manage Inventory" as UC_ManageInventory
  usecase "Checkout" as UC_Checkout
}
PG --> UC_ManageInventory
S --> UC_MakePayment
C --> UC_MakePayment
C --> UC_Checkout
C --> UC_ManageInventory
DS --> UC_Checkout
DS --> UC_BrowseProducts
DS --> UC_WriteReview
UC_MakePayment ..|> UC_WriteReview : <<include>>
@enduml