@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
left to right direction
actor "Driver" as D
actor "Dispatcher" as D1
actor "Warehouse Staff" as WS
actor "Fleet Manager" as FM
rectangle "Logistics System" {
  usecase "Track Shipment" as UC_TrackShipment
  usecase "Update Inventory" as UC_UpdateInventory
  usecase "Fuel Vehicle" as UC_FuelVehicle
  usecase "Schedule Pickup" as UC_SchedulePickup
  usecase "Load Package" as UC_LoadPackage
}
D --> UC_TrackShipment
D --> UC_FuelVehicle
D --> UC_UpdateInventory
D1 --> UC_UpdateInventory
WS --> UC_SchedulePickup
WS --> UC_TrackShipment
FM --> UC_TrackShipment
FM --> UC_UpdateInventory
FM --> UC_SchedulePickup
UC_UpdateInventory ..|> UC_SchedulePickup : <<include>>
@enduml