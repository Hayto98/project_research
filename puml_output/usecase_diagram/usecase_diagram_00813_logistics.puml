@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
left to right direction
actor "Dispatcher" as D
actor "Driver" as D1
actor "Customer" as C
actor "Fleet Manager" as FM
rectangle "Logistics System" {
  usecase "Fuel Vehicle" as UC_FuelVehicle
  usecase "Load Package" as UC_LoadPackage
  usecase "Assign Route" as UC_AssignRoute
  usecase "Update Inventory" as UC_UpdateInventory
  usecase "Report Issue" as UC_ReportIssue
  usecase "Schedule Pickup" as UC_SchedulePickup
  usecase "Track Shipment" as UC_TrackShipment
}
D --> UC_LoadPackage
D1 --> UC_FuelVehicle
D1 --> UC_TrackShipment
C --> UC_FuelVehicle
C --> UC_AssignRoute
C --> UC_SchedulePickup
FM --> UC_SchedulePickup
FM --> UC_FuelVehicle
FM --> UC_ReportIssue
@enduml