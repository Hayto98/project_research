@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
left to right direction
actor "Admin" as Admin
actor "Seller" as Seller
rectangle "Ecommerce System" {
  usecase "Apply Coupon" as UC_ApplyCoupon
  usecase "Track Order" as UC_TrackOrder
  usecase "Manage Inventory" as UC_ManageInventory
  usecase "Checkout" as UC_Checkout
  usecase "Browse Products" as UC_BrowseProducts
  usecase "Write Review" as UC_WriteReview
}
Admin --> UC_ManageInventory
Admin --> UC_BrowseProducts
Seller --> UC_BrowseProducts
Seller --> UC_ApplyCoupon
UC_ApplyCoupon ..> UC_WriteReview : <<extend>>
@enduml