@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
left to right direction
actor "Registrar" as R
actor "Admin" as A
actor "Teacher" as T
rectangle "Education System" {
  usecase "View Schedule" as UC_ViewSchedule
  usecase "Issue Certificate" as UC_IssueCertificate
  usecase "Grade Exam" as UC_GradeExam
  usecase "Take Attendance" as UC_TakeAttendance
  usecase "Borrow Book" as UC_BorrowBook
  usecase "Submit Assignment" as UC_SubmitAssignment
}
R --> UC_IssueCertificate
A --> UC_ViewSchedule
A --> UC_SubmitAssignment
A --> UC_TakeAttendance
T --> UC_ViewSchedule
T --> UC_TakeAttendance
UC_BorrowBook ..> UC_SubmitAssignment : <<extend>>
@enduml