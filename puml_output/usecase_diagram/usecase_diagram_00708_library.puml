@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
left to right direction
actor "Member" as M
actor "Admin" as A
rectangle "Library System" {
  usecase "Register Member" as UC_RegisterMember
  usecase "Add New Book" as UC_AddNewBook
  usecase "Return Book" as UC_ReturnBook
  usecase "Borrow Book" as UC_BorrowBook
  usecase "Pay Fine" as UC_PayFine
}
M --> UC_ReturnBook
A --> UC_PayFine
A --> UC_BorrowBook
A --> UC_ReturnBook
UC_AddNewBook ..|> UC_PayFine : <<include>>
@enduml