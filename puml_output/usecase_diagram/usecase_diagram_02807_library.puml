@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
left to right direction
actor "Admin" as A
actor "Member" as M
rectangle "Library System" {
  usecase "Reserve Book" as UC_ReserveBook
  usecase "Borrow Book" as UC_BorrowBook
  usecase "Return Book" as UC_ReturnBook
  usecase "Renew Loan" as UC_RenewLoan
  usecase "Add New Book" as UC_AddNewBook
}
A --> UC_RenewLoan
M --> UC_ReserveBook
M --> UC_ReturnBook
UC_ReserveBook ..|> UC_RenewLoan : <<include>>
@enduml