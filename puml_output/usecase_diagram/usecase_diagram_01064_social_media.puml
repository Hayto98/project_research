@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
left to right direction
actor "Advertiser" as A
actor "User" as U
actor "Moderator" as M
actor "Admin" as A1
rectangle "Social Media System" {
  usecase "Like Post" as UC_LikePost
  usecase "Follow User" as UC_FollowUser
  usecase "Comment" as UC_Comment
  usecase "Send Message" as UC_SendMessage
  usecase "Report Content" as UC_ReportContent
}
A --> UC_LikePost
A --> UC_FollowUser
U --> UC_SendMessage
M --> UC_SendMessage
M --> UC_FollowUser
A1 --> UC_ReportContent
A1 --> UC_SendMessage
A1 --> UC_FollowUser
@enduml