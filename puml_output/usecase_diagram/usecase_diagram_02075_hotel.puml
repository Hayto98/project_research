@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
left to right direction
actor "Receptionist" as R
actor "Chef" as C
actor "Manager" as M
actor "Guest" as G
rectangle "Hotel System" {
  usecase "Check In" as UC_CheckIn
  usecase "Clean Room" as UC_CleanRoom
  usecase "Check Out" as UC_CheckOut
  usecase "Order Room Service" as UC_OrderRoomService
  usecase "Request Service" as UC_RequestService
  usecase "Cancel Reservation" as UC_CancelReservation
}
R --> UC_CheckIn
R --> UC_CheckOut
C --> UC_CheckOut
M --> UC_CheckOut
G --> UC_CleanRoom
G --> UC_RequestService
@enduml