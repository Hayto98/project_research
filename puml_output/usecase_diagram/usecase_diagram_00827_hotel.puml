@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
left to right direction
actor "Manager" as M
actor "Housekeeper" as H
actor "Chef" as C
actor "Guest" as G
rectangle "Hotel System" {
  usecase "Check Out" as UC_CheckOut
  usecase "Check In" as UC_CheckIn
  usecase "Order Room Service" as UC_OrderRoomService
  usecase "Process Payment" as UC_ProcessPayment
  usecase "Clean Room" as UC_CleanRoom
  usecase "Cancel Reservation" as UC_CancelReservation
  usecase "Request Service" as UC_RequestService
}
M --> UC_CheckOut
M --> UC_ProcessPayment
M --> UC_RequestService
H --> UC_CheckOut
H --> UC_CheckIn
H --> UC_CancelReservation
C --> UC_CancelReservation
C --> UC_ProcessPayment
G --> UC_CleanRoom
G --> UC_CancelReservation
G --> UC_OrderRoomService
UC_OrderRoomService ..|> UC_ProcessPayment : <<extend>>
@enduml