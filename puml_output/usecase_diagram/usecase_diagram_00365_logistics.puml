@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
left to right direction
actor "Fleet Manager" as FM
actor "Driver" as D
actor "Warehouse Staff" as WS
actor "Dispatcher" as D1
rectangle "Logistics System" {
  usecase "Load Package" as UC_LoadPackage
  usecase "Schedule Pickup" as UC_SchedulePickup
  usecase "Deliver Package" as UC_DeliverPackage
  usecase "Report Issue" as UC_ReportIssue
  usecase "Update Inventory" as UC_UpdateInventory
}
FM --> UC_LoadPackage
FM --> UC_UpdateInventory
D --> UC_SchedulePickup
D --> UC_DeliverPackage
D --> UC_UpdateInventory
WS --> UC_LoadPackage
WS --> UC_DeliverPackage
D1 --> UC_DeliverPackage
D1 --> UC_LoadPackage
UC_SchedulePickup ..|> UC_DeliverPackage : <<extend>>
@enduml