@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
left to right direction
actor "User" as User
actor "Moderator" as Moderator
rectangle "Social Media System" {
  usecase "Send Message" as UC_SendMessage
  usecase "Like Post" as UC_LikePost
  usecase "Report Content" as UC_ReportContent
  usecase "Comment" as UC_Comment
  usecase "Edit Profile" as UC_EditProfile
}
User --> UC_SendMessage
Moderator --> UC_LikePost
Moderator --> UC_ReportContent
Moderator --> UC_Comment
UC_ReportContent ..> UC_EditProfile : <<include>>
@enduml