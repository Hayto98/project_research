@startuml
skinparam shadowing true
left to right direction
actor "Registrar" as R
actor "Librarian" as L
actor "Admin" as A
actor "Teacher" as T
rectangle "Education System" {
  usecase "Issue Certificate" as UC_IssueCertificate
  usecase "View Schedule" as UC_ViewSchedule
  usecase "Borrow Book" as UC_BorrowBook
  usecase "Register Student" as UC_RegisterStudent
  usecase "Grade Exam" as UC_GradeExam
  usecase "Submit Assignment" as UC_SubmitAssignment
}
R --> UC_RegisterStudent
R --> UC_IssueCertificate
L --> UC_ViewSchedule
A --> UC_RegisterStudent
A --> UC_IssueCertificate
T --> UC_GradeExam
T --> UC_SubmitAssignment
T --> UC_IssueCertificate
UC_SubmitAssignment ..> UC_GradeExam : <<extend>>
@enduml