@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
left to right direction
actor "Payment Gateway" as PG
actor "Delivery Service" as DS
actor "Seller" as S
rectangle "Ecommerce System" {
  usecase "Apply Coupon" as UC_ApplyCoupon
  usecase "Manage Inventory" as UC_ManageInventory
  usecase "Write Review" as UC_WriteReview
  usecase "Add To Cart" as UC_AddToCart
  usecase "Make Payment" as UC_MakePayment
}
PG --> UC_ApplyCoupon
PG --> UC_MakePayment
PG --> UC_AddToCart
DS --> UC_ManageInventory
DS --> UC_ApplyCoupon
DS --> UC_MakePayment
S --> UC_AddToCart
S --> UC_WriteReview
UC_ManageInventory ..> UC_AddToCart : <<extend>>
@enduml