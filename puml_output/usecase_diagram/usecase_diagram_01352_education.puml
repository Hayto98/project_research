@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
left to right direction
actor "Student" as S
actor "Parent" as P
actor "Teacher" as T
rectangle "Education System" {
  usecase "View Schedule" as UC_ViewSchedule
  usecase "Submit Assignment" as UC_SubmitAssignment
  usecase "Grade Exam" as UC_GradeExam
  usecase "Register Student" as UC_RegisterStudent
  usecase "Borrow Book" as UC_BorrowBook
}
S --> UC_ViewSchedule
P --> UC_RegisterStudent
P --> UC_BorrowBook
P --> UC_SubmitAssignment
T --> UC_ViewSchedule
UC_ViewSchedule ..> UC_RegisterStudent : <<extend>>
@enduml