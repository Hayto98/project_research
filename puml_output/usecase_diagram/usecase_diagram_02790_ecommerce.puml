@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
left to right direction
actor "Seller" as S
actor "Customer" as C
actor "Payment Gateway" as PG
rectangle "Ecommerce System" {
  usecase "Track Order" as UC_TrackOrder
  usecase "Manage Inventory" as UC_ManageInventory
  usecase "Add To Cart" as UC_AddToCart
  usecase "Apply Coupon" as UC_ApplyCoupon
  usecase "Write Review" as UC_WriteReview
  usecase "Make Payment" as UC_MakePayment
}
S --> UC_ApplyCoupon
S --> UC_MakePayment
C --> UC_TrackOrder
C --> UC_WriteReview
C --> UC_AddToCart
PG --> UC_WriteReview
PG --> UC_ApplyCoupon
PG --> UC_MakePayment
@enduml