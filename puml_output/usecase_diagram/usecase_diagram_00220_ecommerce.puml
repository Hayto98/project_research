@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
left to right direction
actor "Payment Gateway" as PG
actor "Seller" as S
actor "Admin" as A
actor "Customer" as C
rectangle "Ecommerce System" {
  usecase "Add To Cart" as UC_AddToCart
  usecase "Browse Products" as UC_BrowseProducts
  usecase "Track Order" as UC_TrackOrder
  usecase "Make Payment" as UC_MakePayment
  usecase "Checkout" as UC_Checkout
  usecase "Manage Inventory" as UC_ManageInventory
}
PG --> UC_TrackOrder
PG --> UC_AddToCart
PG --> UC_BrowseProducts
S --> UC_Checkout
A --> UC_AddToCart
A --> UC_ManageInventory
A --> UC_BrowseProducts
C --> UC_MakePayment
C --> UC_BrowseProducts
C --> UC_Checkout
UC_Checkout ..|> UC_ManageInventory : <<extend>>
@enduml