@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
left to right direction
actor "Admin" as A
actor "Student" as S
actor "Librarian" as L
actor "Parent" as P
rectangle "Education System" {
  usecase "Borrow Book" as UC_BorrowBook
  usecase "Register Student" as UC_RegisterStudent
  usecase "Enroll Course" as UC_EnrollCourse
  usecase "View Schedule" as UC_ViewSchedule
  usecase "Issue Certificate" as UC_IssueCertificate
}
A --> UC_IssueCertificate
A --> UC_BorrowBook
S --> UC_ViewSchedule
S --> UC_RegisterStudent
S --> UC_BorrowBook
L --> UC_IssueCertificate
L --> UC_RegisterStudent
L --> UC_BorrowBook
P --> UC_IssueCertificate
UC_ViewSchedule ..|> UC_IssueCertificate : <<extend>>
@enduml