@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
left to right direction
actor "Admin" as Admin
actor "Teacher" as Teacher
actor "Parent" as Parent
actor "Student" as Student
rectangle "Education System" {
  usecase "Register Student" as UC_RegisterStudent
  usecase "Take Attendance" as UC_TakeAttendance
  usecase "Issue Certificate" as UC_IssueCertificate
  usecase "Submit Assignment" as UC_SubmitAssignment
  usecase "View Schedule" as UC_ViewSchedule
  usecase "Enroll Course" as UC_EnrollCourse
  usecase "Borrow Book" as UC_BorrowBook
  usecase "Grade Exam" as UC_GradeExam
}
Admin --> UC_GradeExam
Admin --> UC_TakeAttendance
Teacher --> UC_IssueCertificate
Parent --> UC_RegisterStudent
Parent --> UC_GradeExam
Parent --> UC_TakeAttendance
Student --> UC_TakeAttendance
Student --> UC_RegisterStudent
Student --> UC_IssueCertificate
@enduml