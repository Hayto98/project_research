@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
left to right direction
actor "Parent" as P
actor "Teacher" as T
rectangle "Education System" {
  usecase "Borrow Book" as UC_BorrowBook
  usecase "Issue Certificate" as UC_IssueCertificate
  usecase "Take Attendance" as UC_TakeAttendance
  usecase "Enroll Course" as UC_EnrollCourse
  usecase "Register Student" as UC_RegisterStudent
}
P --> UC_TakeAttendance
P --> UC_IssueCertificate
P --> UC_BorrowBook
T --> UC_TakeAttendance
T --> UC_EnrollCourse
UC_IssueCertificate ..> UC_RegisterStudent : <<extend>>
@enduml