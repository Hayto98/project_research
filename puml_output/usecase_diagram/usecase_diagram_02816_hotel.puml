@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
left to right direction
actor "Receptionist" as R
actor "Chef" as C
actor "Manager" as M
actor "Guest" as G
rectangle "Hotel System" {
  usecase "Check Out" as UC_CheckOut
  usecase "Order Room Service" as UC_OrderRoomService
  usecase "Cancel Reservation" as UC_CancelReservation
  usecase "Process Payment" as UC_ProcessPayment
  usecase "Check In" as UC_CheckIn
  usecase "Clean Room" as UC_CleanRoom
}
R --> UC_CancelReservation
R --> UC_CleanRoom
C --> UC_ProcessPayment
C --> UC_CleanRoom
C --> UC_CheckIn
M --> UC_CheckOut
G --> UC_CancelReservation
UC_ProcessPayment ..|> UC_OrderRoomService : <<include>>
@enduml