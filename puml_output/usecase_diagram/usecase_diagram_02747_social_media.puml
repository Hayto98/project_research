@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
left to right direction
actor "User" as U
actor "Admin" as A
actor "Advertiser" as A1
actor "Moderator" as M
rectangle "Social Media System" {
  usecase "Comment" as UC_Comment
  usecase "Share Post" as UC_SharePost
  usecase "Report Content" as UC_ReportContent
  usecase "Edit Profile" as UC_EditProfile
  usecase "Like Post" as UC_LikePost
  usecase "Create Post" as UC_CreatePost
}
U --> UC_SharePost
U --> UC_Comment
A --> UC_ReportContent
A --> UC_LikePost
A1 --> UC_Comment
A1 --> UC_LikePost
M --> UC_LikePost
M --> UC_SharePost
UC_LikePost ..> UC_Comment : <<include>>
@enduml