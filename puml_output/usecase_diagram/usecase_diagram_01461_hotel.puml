@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
left to right direction
actor "Chef" as C
actor "Housekeeper" as H
actor "Guest" as G
actor "Manager" as M
rectangle "Hotel System" {
  usecase "Check Out" as UC_CheckOut
  usecase "Request Service" as UC_RequestService
  usecase "Order Room Service" as UC_OrderRoomService
  usecase "Clean Room" as UC_CleanRoom
  usecase "Check In" as UC_CheckIn
  usecase "Cancel Reservation" as UC_CancelReservation
  usecase "Process Payment" as UC_ProcessPayment
}
C --> UC_CleanRoom
C --> UC_OrderRoomService
C --> UC_CancelReservation
H --> UC_ProcessPayment
H --> UC_OrderRoomService
H --> UC_CancelReservation
G --> UC_RequestService
G --> UC_ProcessPayment
G --> UC_CleanRoom
M --> UC_CleanRoom
M --> UC_ProcessPayment
UC_CleanRoom ..> UC_RequestService : <<extend>>
@enduml