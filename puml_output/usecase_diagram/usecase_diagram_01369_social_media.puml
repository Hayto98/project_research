@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
left to right direction
actor "Advertiser" as A
actor "Moderator" as M
actor "User" as U
actor "Admin" as A1
rectangle "Social Media System" {
  usecase "Share Post" as UC_SharePost
  usecase "Send Message" as UC_SendMessage
  usecase "Follow User" as UC_FollowUser
  usecase "Create Post" as UC_CreatePost
  usecase "Report Content" as UC_ReportContent
}
A --> UC_FollowUser
A --> UC_CreatePost
M --> UC_SendMessage
U --> UC_FollowUser
U --> UC_ReportContent
U --> UC_SendMessage
A1 --> UC_SharePost
UC_SendMessage ..|> UC_CreatePost : <<include>>
@enduml