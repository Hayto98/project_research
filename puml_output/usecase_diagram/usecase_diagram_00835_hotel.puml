@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
left to right direction
actor "Housekeeper" as H
actor "Guest" as G
actor "Receptionist" as R
rectangle "Hotel System" {
  usecase "Check In" as UC_CheckIn
  usecase "Request Service" as UC_RequestService
  usecase "Cancel Reservation" as UC_CancelReservation
  usecase "Order Room Service" as UC_OrderRoomService
  usecase "Check Out" as UC_CheckOut
  usecase "Book Room" as UC_BookRoom
}
H --> UC_RequestService
H --> UC_CheckIn
G --> UC_OrderRoomService
G --> UC_BookRoom
G --> UC_RequestService
R --> UC_BookRoom
R --> UC_OrderRoomService
UC_RequestService ..> UC_BookRoom : <<include>>
@enduml