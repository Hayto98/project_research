@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
left to right direction
actor "Advertiser" as A
actor "Admin" as A1
actor "User" as U
rectangle "Social Media System" {
  usecase "Like Post" as UC_LikePost
  usecase "Create Post" as UC_CreatePost
  usecase "Comment" as UC_Comment
  usecase "Share Post" as UC_SharePost
  usecase "Send Message" as UC_SendMessage
  usecase "Follow User" as UC_FollowUser
}
A --> UC_SendMessage
A --> UC_SharePost
A1 --> UC_SendMessage
A1 --> UC_LikePost
A1 --> UC_FollowUser
U --> UC_SharePost
U --> UC_LikePost
U --> UC_SendMessage
UC_Comment ..|> UC_LikePost : <<extend>>
@enduml