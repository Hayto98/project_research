@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
left to right direction
actor "Driver" as Driver
actor "Dispatcher" as Dispatcher
actor "Customer" as Customer
actor "Fleet Manager" as FleetManager
rectangle "Logistics System" {
  usecase "Deliver Package" as UC_DeliverPackage
  usecase "Track Shipment" as UC_TrackShipment
  usecase "Load Package" as UC_LoadPackage
  usecase "Fuel Vehicle" as UC_FuelVehicle
  usecase "Report Issue" as UC_ReportIssue
  usecase "Schedule Pickup" as UC_SchedulePickup
}
Driver --> UC_DeliverPackage
Dispatcher --> UC_FuelVehicle
Dispatcher --> UC_LoadPackage
Customer --> UC_LoadPackage
FleetManager --> UC_ReportIssue
FleetManager --> UC_DeliverPackage
FleetManager --> UC_FuelVehicle
UC_SchedulePickup ..|> UC_FuelVehicle : <<extend>>
@enduml