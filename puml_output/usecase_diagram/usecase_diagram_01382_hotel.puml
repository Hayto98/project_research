@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
left to right direction
actor "Chef" as Chef
actor "Manager" as Manager
actor "Guest" as Guest
rectangle "Hotel System" {
  usecase "Order Room Service" as UC_OrderRoomService
  usecase "Check Out" as UC_CheckOut
  usecase "Check In" as UC_CheckIn
  usecase "Book Room" as UC_BookRoom
  usecase "Cancel Reservation" as UC_CancelReservation
  usecase "Request Service" as UC_RequestService
  usecase "Clean Room" as UC_CleanRoom
}
Chef --> UC_CheckIn
Manager --> UC_BookRoom
Manager --> UC_RequestService
Guest --> UC_RequestService
Guest --> UC_CheckOut
Guest --> UC_CheckIn
@enduml