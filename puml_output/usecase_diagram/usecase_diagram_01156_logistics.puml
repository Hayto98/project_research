@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
left to right direction
actor "Dispatcher" as D
actor "Customer" as C
actor "Driver" as D1
actor "Warehouse Staff" as WS
rectangle "Logistics System" {
  usecase "Deliver Package" as UC_DeliverPackage
  usecase "Schedule Pickup" as UC_SchedulePickup
  usecase "Update Inventory" as UC_UpdateInventory
  usecase "Load Package" as UC_LoadPackage
  usecase "Fuel Vehicle" as UC_FuelVehicle
}
D --> UC_LoadPackage
D --> UC_SchedulePickup
C --> UC_FuelVehicle
D1 --> UC_DeliverPackage
D1 --> UC_SchedulePickup
D1 --> UC_FuelVehicle
WS --> UC_UpdateInventory
WS --> UC_FuelVehicle
WS --> UC_DeliverPackage
UC_DeliverPackage ..> UC_LoadPackage : <<include>>
@enduml