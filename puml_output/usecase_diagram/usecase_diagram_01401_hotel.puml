@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
left to right direction
actor "Chef" as C
actor "Manager" as M
actor "Housekeeper" as H
actor "Guest" as G
rectangle "Hotel System" {
  usecase "Check In" as UC_CheckIn
  usecase "Cancel Reservation" as UC_CancelReservation
  usecase "Order Room Service" as UC_OrderRoomService
  usecase "Check Out" as UC_CheckOut
  usecase "Book Room" as UC_BookRoom
}
C --> UC_CheckIn
C --> UC_OrderRoomService
C --> UC_BookRoom
M --> UC_CheckIn
M --> UC_CheckOut
M --> UC_BookRoom
H --> UC_OrderRoomService
G --> UC_OrderRoomService
G --> UC_CancelReservation
G --> UC_BookRoom
UC_CancelReservation ..|> UC_OrderRoomService : <<include>>
@enduml