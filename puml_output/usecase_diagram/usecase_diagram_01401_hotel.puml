@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
left to right direction
actor "Chef" as Chef
actor "Manager" as Manager
actor "Housekeeper" as Housekeeper
actor "Guest" as Guest
rectangle "Hotel System" {
  usecase "Check In" as UC_CheckIn
  usecase "Cancel Reservation" as UC_CancelReservation
  usecase "Order Room Service" as UC_OrderRoomService
  usecase "Check Out" as UC_CheckOut
  usecase "Book Room" as UC_BookRoom
}
Chef --> UC_CheckIn
Chef --> UC_OrderRoomService
Chef --> UC_BookRoom
Manager --> UC_CheckIn
Manager --> UC_CheckOut
Manager --> UC_BookRoom
Housekeeper --> UC_OrderRoomService
Guest --> UC_OrderRoomService
Guest --> UC_CancelReservation
Guest --> UC_BookRoom
UC_CancelReservation ..|> UC_OrderRoomService : <<include>>
@enduml