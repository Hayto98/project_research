@startuml
skinparam monochrome true
skinparam defaultFontSize 11
left to right direction
actor "Bank Teller" as BT
actor "Auditor" as A
actor "ATM" as A1
actor "Branch Manager" as BM
rectangle "Banking System" {
  usecase "Pay Bill" as UC_PayBill
  usecase "Deposit Money" as UC_DepositMoney
  usecase "View Statement" as UC_ViewStatement
  usecase "Open Account" as UC_OpenAccount
  usecase "Block Card" as UC_BlockCard
}
BT --> UC_OpenAccount
A --> UC_OpenAccount
A --> UC_BlockCard
A --> UC_PayBill
A1 --> UC_ViewStatement
A1 --> UC_OpenAccount
A1 --> UC_BlockCard
BM --> UC_DepositMoney
BM --> UC_OpenAccount
UC_DepositMoney ..> UC_OpenAccount : <<extend>>
@enduml