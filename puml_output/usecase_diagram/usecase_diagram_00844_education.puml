@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
left to right direction
actor "Teacher" as T
actor "Admin" as A
actor "Librarian" as L
actor "Student" as S
rectangle "Education System" {
  usecase "Submit Assignment" as UC_SubmitAssignment
  usecase "Take Attendance" as UC_TakeAttendance
  usecase "Grade Exam" as UC_GradeExam
  usecase "Enroll Course" as UC_EnrollCourse
  usecase "Borrow Book" as UC_BorrowBook
}
T --> UC_TakeAttendance
A --> UC_EnrollCourse
A --> UC_GradeExam
A --> UC_SubmitAssignment
L --> UC_GradeExam
L --> UC_TakeAttendance
S --> UC_BorrowBook
S --> UC_TakeAttendance
S --> UC_EnrollCourse
UC_SubmitAssignment ..|> UC_TakeAttendance : <<include>>
@enduml