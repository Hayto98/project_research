@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
left to right direction
actor "Advertiser" as A
actor "User" as U
actor "Moderator" as M
actor "Admin" as A1
rectangle "Social Media System" {
  usecase "Edit Profile" as UC_EditProfile
  usecase "Comment" as UC_Comment
  usecase "Send Message" as UC_SendMessage
  usecase "Report Content" as UC_ReportContent
  usecase "Follow User" as UC_FollowUser
  usecase "Share Post" as UC_SharePost
}
A --> UC_FollowUser
A --> UC_SharePost
U --> UC_Comment
M --> UC_ReportContent
M --> UC_Comment
M --> UC_EditProfile
A1 --> UC_EditProfile
A1 --> UC_FollowUser
A1 --> UC_SendMessage
UC_FollowUser ..|> UC_SendMessage : <<include>>
@enduml