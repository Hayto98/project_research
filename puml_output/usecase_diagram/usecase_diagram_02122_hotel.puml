@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
left to right direction
actor "Manager" as M
actor "Chef" as C
actor "Guest" as G
actor "Receptionist" as R
rectangle "Hotel System" {
  usecase "Clean Room" as UC_CleanRoom
  usecase "Process Payment" as UC_ProcessPayment
  usecase "Book Room" as UC_BookRoom
  usecase "Request Service" as UC_RequestService
  usecase "Check Out" as UC_CheckOut
}
M --> UC_ProcessPayment
M --> UC_CheckOut
M --> UC_RequestService
C --> UC_CheckOut
C --> UC_CleanRoom
G --> UC_BookRoom
G --> UC_ProcessPayment
R --> UC_ProcessPayment
UC_CleanRoom ..|> UC_ProcessPayment : <<extend>>
@enduml