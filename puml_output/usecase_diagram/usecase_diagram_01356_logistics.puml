@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
left to right direction
actor "Driver" as D
actor "Customer" as C
actor "Fleet Manager" as FM
actor "Dispatcher" as D1
rectangle "Logistics System" {
  usecase "Update Inventory" as UC_UpdateInventory
  usecase "Deliver Package" as UC_DeliverPackage
  usecase "Track Shipment" as UC_TrackShipment
  usecase "Report Issue" as UC_ReportIssue
  usecase "Fuel Vehicle" as UC_FuelVehicle
}
D --> UC_FuelVehicle
D --> UC_DeliverPackage
D --> UC_TrackShipment
C --> UC_DeliverPackage
C --> UC_ReportIssue
FM --> UC_ReportIssue
FM --> UC_UpdateInventory
FM --> UC_FuelVehicle
D1 --> UC_UpdateInventory
D1 --> UC_DeliverPackage
D1 --> UC_ReportIssue
UC_ReportIssue ..|> UC_DeliverPackage : <<extend>>
@enduml