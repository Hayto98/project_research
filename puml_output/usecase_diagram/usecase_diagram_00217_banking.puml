@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
left to right direction
actor "Bank Teller" as BT
actor "ATM" as A
actor "Branch Manager" as BM
actor "Auditor" as A1
rectangle "Banking System" {
  usecase "Block Card" as UC_BlockCard
  usecase "View Statement" as UC_ViewStatement
  usecase "Apply For Loan" as UC_ApplyForLoan
  usecase "Deposit Money" as UC_DepositMoney
  usecase "Transfer Funds" as UC_TransferFunds
  usecase "Withdraw Cash" as UC_WithdrawCash
  usecase "Open Account" as UC_OpenAccount
  usecase "Pay Bill" as UC_PayBill
}
BT --> UC_BlockCard
BT --> UC_TransferFunds
A --> UC_BlockCard
A --> UC_TransferFunds
BM --> UC_DepositMoney
BM --> UC_OpenAccount
BM --> UC_TransferFunds
A1 --> UC_DepositMoney
A1 --> UC_WithdrawCash
UC_DepositMoney ..|> UC_BlockCard : <<extend>>
@enduml