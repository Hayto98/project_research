@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
left to right direction
actor "Customer" as C
actor "Payment Gateway" as PG
actor "Delivery Service" as DS
rectangle "Ecommerce System" {
  usecase "Track Order" as UC_TrackOrder
  usecase "Write Review" as UC_WriteReview
  usecase "Apply Coupon" as UC_ApplyCoupon
  usecase "Add To Cart" as UC_AddToCart
  usecase "Checkout" as UC_Checkout
}
C --> UC_ApplyCoupon
C --> UC_TrackOrder
C --> UC_AddToCart
PG --> UC_ApplyCoupon
PG --> UC_TrackOrder
DS --> UC_WriteReview
UC_TrackOrder ..|> UC_WriteReview : <<include>>
@enduml