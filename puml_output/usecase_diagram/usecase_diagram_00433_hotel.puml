@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
left to right direction
actor "Receptionist" as R
actor "Manager" as M
actor "Guest" as G
actor "Housekeeper" as H
rectangle "Hotel System" {
  usecase "Cancel Reservation" as UC_CancelReservation
  usecase "Book Room" as UC_BookRoom
  usecase "Check In" as UC_CheckIn
  usecase "Request Service" as UC_RequestService
  usecase "Check Out" as UC_CheckOut
}
R --> UC_BookRoom
R --> UC_CheckIn
M --> UC_CancelReservation
M --> UC_RequestService
M --> UC_BookRoom
G --> UC_CancelReservation
G --> UC_CheckIn
G --> UC_RequestService
H --> UC_RequestService
H --> UC_CheckIn
UC_CheckIn ..> UC_CheckOut : <<include>>
@enduml