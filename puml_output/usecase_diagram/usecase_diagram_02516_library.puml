@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
left to right direction
actor "Admin" as A
actor "Member" as M
actor "Librarian" as L
rectangle "Library System" {
  usecase "Renew Loan" as UC_RenewLoan
  usecase "Add New Book" as UC_AddNewBook
  usecase "Register Member" as UC_RegisterMember
  usecase "Pay Fine" as UC_PayFine
  usecase "Search Catalog" as UC_SearchCatalog
}
A --> UC_SearchCatalog
A --> UC_RegisterMember
A --> UC_RenewLoan
M --> UC_RenewLoan
M --> UC_SearchCatalog
M --> UC_RegisterMember
L --> UC_RenewLoan
L --> UC_PayFine
L --> UC_SearchCatalog
@enduml