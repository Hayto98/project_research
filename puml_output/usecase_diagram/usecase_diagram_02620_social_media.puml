@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
left to right direction
actor "User" as U
actor "Moderator" as M
actor "Advertiser" as A
actor "Admin" as A1
rectangle "Social Media System" {
  usecase "Edit Profile" as UC_EditProfile
  usecase "Send Message" as UC_SendMessage
  usecase "Report Content" as UC_ReportContent
  usecase "Like Post" as UC_LikePost
  usecase "Follow User" as UC_FollowUser
  usecase "Share Post" as UC_SharePost
}
U --> UC_EditProfile
U --> UC_LikePost
M --> UC_ReportContent
M --> UC_SendMessage
M --> UC_EditProfile
A --> UC_FollowUser
A --> UC_ReportContent
A1 --> UC_FollowUser
UC_LikePost ..> UC_FollowUser : <<include>>
@enduml