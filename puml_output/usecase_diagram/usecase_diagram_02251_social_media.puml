@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
left to right direction
actor "User" as U
actor "Advertiser" as A
actor "Admin" as A1
rectangle "Social Media System" {
  usecase "Share Post" as UC_SharePost
  usecase "Comment" as UC_Comment
  usecase "Like Post" as UC_LikePost
  usecase "Follow User" as UC_FollowUser
  usecase "Report Content" as UC_ReportContent
  usecase "Create Post" as UC_CreatePost
}
U --> UC_SharePost
U --> UC_LikePost
U --> UC_CreatePost
A --> UC_LikePost
A1 --> UC_FollowUser
A1 --> UC_SharePost
UC_FollowUser ..|> UC_ReportContent : <<extend>>
@enduml