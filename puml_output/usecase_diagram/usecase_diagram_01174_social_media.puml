@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
left to right direction
actor "User" as U
actor "Admin" as A
actor "Moderator" as M
actor "Advertiser" as A1
rectangle "Social Media System" {
  usecase "Create Post" as UC_CreatePost
  usecase "Report Content" as UC_ReportContent
  usecase "Like Post" as UC_LikePost
  usecase "Send Message" as UC_SendMessage
  usecase "Edit Profile" as UC_EditProfile
  usecase "Comment" as UC_Comment
}
U --> UC_SendMessage
U --> UC_EditProfile
U --> UC_ReportContent
A --> UC_CreatePost
A --> UC_LikePost
A --> UC_SendMessage
M --> UC_LikePost
M --> UC_SendMessage
M --> UC_CreatePost
A1 --> UC_SendMessage
@enduml