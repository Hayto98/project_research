@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
left to right direction
actor "Guest" as Guest
actor "Manager" as Manager
actor "Receptionist" as Receptionist
actor "Housekeeper" as Housekeeper
rectangle "Hotel System" {
  usecase "Order Room Service" as UC_OrderRoomService
  usecase "Check In" as UC_CheckIn
  usecase "Cancel Reservation" as UC_CancelReservation
  usecase "Check Out" as UC_CheckOut
  usecase "Process Payment" as UC_ProcessPayment
}
Guest --> UC_CheckOut
Guest --> UC_ProcessPayment
Manager --> UC_CheckIn
Manager --> UC_CheckOut
Manager --> UC_ProcessPayment
Receptionist --> UC_OrderRoomService
Receptionist --> UC_CheckOut
Housekeeper --> UC_CheckIn
@enduml