@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
left to right direction
actor "Admin" as A
actor "Moderator" as M
actor "User" as U
actor "Advertiser" as A1
rectangle "Social Media System" {
  usecase "Share Post" as UC_SharePost
  usecase "Like Post" as UC_LikePost
  usecase "Create Post" as UC_CreatePost
  usecase "Edit Profile" as UC_EditProfile
  usecase "Comment" as UC_Comment
}
A --> UC_CreatePost
M --> UC_CreatePost
M --> UC_LikePost
M --> UC_SharePost
U --> UC_EditProfile
U --> UC_CreatePost
A1 --> UC_LikePost
UC_CreatePost ..|> UC_EditProfile : <<extend>>
@enduml