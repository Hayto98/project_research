@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
left to right direction
actor "Auditor" as A
actor "Bank Teller" as BT
actor "Account Holder" as AH
actor "ATM" as A1
rectangle "Banking System" {
  usecase "Pay Bill" as UC_PayBill
  usecase "Apply For Loan" as UC_ApplyForLoan
  usecase "Withdraw Cash" as UC_WithdrawCash
  usecase "View Statement" as UC_ViewStatement
  usecase "Open Account" as UC_OpenAccount
}
A --> UC_WithdrawCash
A --> UC_OpenAccount
BT --> UC_WithdrawCash
AH --> UC_ViewStatement
AH --> UC_WithdrawCash
A1 --> UC_ApplyForLoan
UC_ApplyForLoan ..|> UC_WithdrawCash : <<include>>
@enduml