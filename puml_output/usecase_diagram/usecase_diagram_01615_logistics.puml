@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
left to right direction
actor "Fleet Manager" as FM
actor "Customer" as C
actor "Driver" as D
rectangle "Logistics System" {
  usecase "Schedule Pickup" as UC_SchedulePickup
  usecase "Assign Route" as UC_AssignRoute
  usecase "Report Issue" as UC_ReportIssue
  usecase "Update Inventory" as UC_UpdateInventory
  usecase "Fuel Vehicle" as UC_FuelVehicle
}
FM --> UC_AssignRoute
FM --> UC_FuelVehicle
C --> UC_ReportIssue
C --> UC_UpdateInventory
C --> UC_SchedulePickup
D --> UC_SchedulePickup
D --> UC_FuelVehicle
D --> UC_AssignRoute
UC_ReportIssue ..> UC_SchedulePickup : <<include>>
@enduml