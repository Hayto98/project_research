@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
left to right direction
actor "Customer" as C
actor "Driver" as D
actor "Dispatcher" as D1
rectangle "Logistics System" {
  usecase "Track Shipment" as UC_TrackShipment
  usecase "Assign Route" as UC_AssignRoute
  usecase "Update Inventory" as UC_UpdateInventory
  usecase "Load Package" as UC_LoadPackage
  usecase "Report Issue" as UC_ReportIssue
}
C --> UC_TrackShipment
C --> UC_LoadPackage
C --> UC_UpdateInventory
D --> UC_TrackShipment
D --> UC_ReportIssue
D1 --> UC_TrackShipment
D1 --> UC_UpdateInventory
@enduml