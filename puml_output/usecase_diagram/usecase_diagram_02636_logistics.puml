@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
left to right direction
actor "Dispatcher" as D
actor "Fleet Manager" as FM
actor "Driver" as D1
actor "Customer" as C
rectangle "Logistics System" {
  usecase "Track Shipment" as UC_TrackShipment
  usecase "Deliver Package" as UC_DeliverPackage
  usecase "Schedule Pickup" as UC_SchedulePickup
  usecase "Update Inventory" as UC_UpdateInventory
  usecase "Assign Route" as UC_AssignRoute
}
D --> UC_DeliverPackage
D --> UC_SchedulePickup
FM --> UC_UpdateInventory
FM --> UC_DeliverPackage
FM --> UC_TrackShipment
D1 --> UC_TrackShipment
D1 --> UC_AssignRoute
D1 --> UC_UpdateInventory
C --> UC_DeliverPackage
UC_SchedulePickup ..|> UC_DeliverPackage : <<include>>
@enduml