@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
left to right direction
actor "Moderator" as M
actor "Advertiser" as A
actor "User" as U
actor "Admin" as A1
rectangle "Social Media System" {
  usecase "Create Post" as UC_CreatePost
  usecase "Share Post" as UC_SharePost
  usecase "Send Message" as UC_SendMessage
  usecase "Edit Profile" as UC_EditProfile
  usecase "Report Content" as UC_ReportContent
  usecase "Like Post" as UC_LikePost
  usecase "Follow User" as UC_FollowUser
}
M --> UC_EditProfile
M --> UC_FollowUser
M --> UC_SendMessage
A --> UC_FollowUser
A --> UC_ReportContent
A --> UC_SendMessage
U --> UC_SendMessage
U --> UC_LikePost
U --> UC_SharePost
A1 --> UC_ReportContent
@enduml