@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
left to right direction
actor "Delivery Service" as DS
actor "Customer" as C
actor "Seller" as S
actor "Admin" as A
rectangle "Ecommerce System" {
  usecase "Make Payment" as UC_MakePayment
  usecase "Browse Products" as UC_BrowseProducts
  usecase "Add To Cart" as UC_AddToCart
  usecase "Manage Inventory" as UC_ManageInventory
  usecase "Track Order" as UC_TrackOrder
  usecase "Checkout" as UC_Checkout
}
DS --> UC_TrackOrder
DS --> UC_Checkout
DS --> UC_MakePayment
C --> UC_TrackOrder
S --> UC_Checkout
S --> UC_MakePayment
S --> UC_ManageInventory
A --> UC_Checkout
A --> UC_TrackOrder
UC_ManageInventory ..> UC_MakePayment : <<extend>>
@enduml