@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
left to right direction
actor "Advertiser" as A
actor "Moderator" as M
actor "User" as U
rectangle "Social Media System" {
  usecase "Edit Profile" as UC_EditProfile
  usecase "Share Post" as UC_SharePost
  usecase "Send Message" as UC_SendMessage
  usecase "Comment" as UC_Comment
  usecase "Follow User" as UC_FollowUser
}
A --> UC_SendMessage
A --> UC_FollowUser
A --> UC_EditProfile
M --> UC_SendMessage
M --> UC_SharePost
U --> UC_FollowUser
U --> UC_EditProfile
UC_FollowUser ..> UC_EditProfile : <<include>>
@enduml