@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
left to right direction
actor "Doctor" as Doctor
actor "Receptionist" as Receptionist
actor "Insurance Provider" as InsuranceProvider
rectangle "Healthcare System" {
  usecase "Discharge Patient" as UC_DischargePatient
  usecase "Update Medical Record" as UC_UpdateMedicalRecord
  usecase "Examine Patient" as UC_ExaminePatient
  usecase "Book Appointment" as UC_BookAppointment
  usecase "Process Insurance Claim" as UC_ProcessInsuranceClaim
  usecase "Run Lab Test" as UC_RunLabTest
}
Doctor --> UC_DischargePatient
Doctor --> UC_BookAppointment
Doctor --> UC_ExaminePatient
Receptionist --> UC_ProcessInsuranceClaim
InsuranceProvider --> UC_UpdateMedicalRecord
InsuranceProvider --> UC_ProcessInsuranceClaim
InsuranceProvider --> UC_RunLabTest
UC_ExaminePatient ..|> UC_UpdateMedicalRecord : <<extend>>
@enduml