@startuml
skinparam monochrome true
skinparam defaultFontSize 13
left to right direction
actor "Bank Teller" as BT
actor "Auditor" as A
actor "ATM" as A1
actor "Branch Manager" as BM
rectangle "Banking System" {
  usecase "View Statement" as UC_ViewStatement
  usecase "Apply For Loan" as UC_ApplyForLoan
  usecase "Block Card" as UC_BlockCard
  usecase "Pay Bill" as UC_PayBill
  usecase "Transfer Funds" as UC_TransferFunds
}
BT --> UC_ApplyForLoan
A --> UC_TransferFunds
A --> UC_ApplyForLoan
A1 --> UC_BlockCard
A1 --> UC_TransferFunds
A1 --> UC_ApplyForLoan
BM --> UC_BlockCard
BM --> UC_ApplyForLoan
UC_ViewStatement ..> UC_PayBill : <<include>>
@enduml