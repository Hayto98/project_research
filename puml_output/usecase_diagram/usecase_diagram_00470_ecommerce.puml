@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
left to right direction
actor "Customer" as C
actor "Seller" as S
actor "Admin" as A
actor "Delivery Service" as DS
rectangle "Ecommerce System" {
  usecase "Checkout" as UC_Checkout
  usecase "Browse Products" as UC_BrowseProducts
  usecase "Track Order" as UC_TrackOrder
  usecase "Cancel Order" as UC_CancelOrder
  usecase "Apply Coupon" as UC_ApplyCoupon
  usecase "Make Payment" as UC_MakePayment
  usecase "Add To Cart" as UC_AddToCart
}
C --> UC_CancelOrder
C --> UC_AddToCart
C --> UC_MakePayment
S --> UC_MakePayment
S --> UC_CancelOrder
S --> UC_ApplyCoupon
A --> UC_BrowseProducts
A --> UC_AddToCart
A --> UC_Checkout
DS --> UC_ApplyCoupon
DS --> UC_CancelOrder
DS --> UC_BrowseProducts
UC_ApplyCoupon ..> UC_CancelOrder : <<include>>
@enduml