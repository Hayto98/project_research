@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
left to right direction
actor "Customer" as Customer
actor "Seller" as Seller
actor "Admin" as Admin
actor "Delivery Service" as DeliveryService
rectangle "Ecommerce System" {
  usecase "Checkout" as UC_Checkout
  usecase "Browse Products" as UC_BrowseProducts
  usecase "Track Order" as UC_TrackOrder
  usecase "Cancel Order" as UC_CancelOrder
  usecase "Apply Coupon" as UC_ApplyCoupon
  usecase "Make Payment" as UC_MakePayment
  usecase "Add To Cart" as UC_AddToCart
}
Customer --> UC_CancelOrder
Customer --> UC_AddToCart
Customer --> UC_MakePayment
Seller --> UC_MakePayment
Seller --> UC_CancelOrder
Seller --> UC_ApplyCoupon
Admin --> UC_BrowseProducts
Admin --> UC_AddToCart
Admin --> UC_Checkout
DeliveryService --> UC_ApplyCoupon
DeliveryService --> UC_CancelOrder
DeliveryService --> UC_BrowseProducts
UC_ApplyCoupon ..> UC_CancelOrder : <<include>>
@enduml