@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
left to right direction
actor "Fleet Manager" as FM
actor "Dispatcher" as D
actor "Customer" as C
actor "Driver" as D1
rectangle "Logistics System" {
  usecase "Assign Route" as UC_AssignRoute
  usecase "Schedule Pickup" as UC_SchedulePickup
  usecase "Fuel Vehicle" as UC_FuelVehicle
  usecase "Report Issue" as UC_ReportIssue
  usecase "Update Inventory" as UC_UpdateInventory
}
FM --> UC_FuelVehicle
D --> UC_FuelVehicle
C --> UC_UpdateInventory
C --> UC_ReportIssue
C --> UC_FuelVehicle
D1 --> UC_UpdateInventory
D1 --> UC_FuelVehicle
D1 --> UC_ReportIssue
UC_FuelVehicle ..> UC_AssignRoute : <<extend>>
@enduml