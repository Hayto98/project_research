@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
left to right direction
actor "Dispatcher" as D
actor "Driver" as D1
actor "Warehouse Staff" as WS
actor "Fleet Manager" as FM
rectangle "Logistics System" {
  usecase "Track Shipment" as UC_TrackShipment
  usecase "Assign Route" as UC_AssignRoute
  usecase "Schedule Pickup" as UC_SchedulePickup
  usecase "Report Issue" as UC_ReportIssue
  usecase "Fuel Vehicle" as UC_FuelVehicle
  usecase "Deliver Package" as UC_DeliverPackage
  usecase "Update Inventory" as UC_UpdateInventory
}
D --> UC_UpdateInventory
D --> UC_FuelVehicle
D --> UC_SchedulePickup
D1 --> UC_FuelVehicle
D1 --> UC_UpdateInventory
WS --> UC_AssignRoute
WS --> UC_ReportIssue
WS --> UC_SchedulePickup
FM --> UC_FuelVehicle
FM --> UC_SchedulePickup
FM --> UC_AssignRoute
UC_SchedulePickup ..|> UC_AssignRoute : <<extend>>
@enduml