@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
left to right direction
actor "Fleet Manager" as FM
actor "Customer" as C
actor "Driver" as D
rectangle "Logistics System" {
  usecase "Report Issue" as UC_ReportIssue
  usecase "Fuel Vehicle" as UC_FuelVehicle
  usecase "Track Shipment" as UC_TrackShipment
  usecase "Load Package" as UC_LoadPackage
  usecase "Deliver Package" as UC_DeliverPackage
}
FM --> UC_LoadPackage
FM --> UC_ReportIssue
C --> UC_TrackShipment
C --> UC_FuelVehicle
C --> UC_DeliverPackage
D --> UC_DeliverPackage
D --> UC_ReportIssue
UC_DeliverPackage ..> UC_TrackShipment : <<extend>>
@enduml