@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
left to right direction
actor "Admin" as A
actor "Moderator" as M
actor "User" as U
rectangle "Social Media System" {
  usecase "Comment" as UC_Comment
  usecase "Share Post" as UC_SharePost
  usecase "Follow User" as UC_FollowUser
  usecase "Like Post" as UC_LikePost
  usecase "Edit Profile" as UC_EditProfile
  usecase "Report Content" as UC_ReportContent
}
A --> UC_FollowUser
A --> UC_LikePost
A --> UC_Comment
M --> UC_SharePost
M --> UC_EditProfile
M --> UC_FollowUser
U --> UC_EditProfile
U --> UC_FollowUser
U --> UC_SharePost
UC_EditProfile ..|> UC_ReportContent : <<include>>
@enduml