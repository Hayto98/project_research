@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
left to right direction
actor "Admin" as A
actor "Member" as M
actor "Librarian" as L
rectangle "Library System" {
  usecase "Reserve Book" as UC_ReserveBook
  usecase "Return Book" as UC_ReturnBook
  usecase "Search Catalog" as UC_SearchCatalog
  usecase "Pay Fine" as UC_PayFine
  usecase "Borrow Book" as UC_BorrowBook
  usecase "Renew Loan" as UC_RenewLoan
}
A --> UC_BorrowBook
A --> UC_PayFine
A --> UC_ReserveBook
M --> UC_SearchCatalog
M --> UC_BorrowBook
M --> UC_ReserveBook
L --> UC_SearchCatalog
L --> UC_ReserveBook
L --> UC_RenewLoan
UC_RenewLoan ..|> UC_BorrowBook : <<include>>
@enduml