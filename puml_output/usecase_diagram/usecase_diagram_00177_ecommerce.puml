@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
left to right direction
actor "Customer" as Customer
actor "Admin" as Admin
actor "Delivery Service" as DeliveryService
actor "Payment Gateway" as PaymentGateway
rectangle "Ecommerce System" {
  usecase "Write Review" as UC_WriteReview
  usecase "Track Order" as UC_TrackOrder
  usecase "Manage Inventory" as UC_ManageInventory
  usecase "Make Payment" as UC_MakePayment
  usecase "Checkout" as UC_Checkout
  usecase "Cancel Order" as UC_CancelOrder
  usecase "Browse Products" as UC_BrowseProducts
  usecase "Add To Cart" as UC_AddToCart
}
Customer --> UC_BrowseProducts
Customer --> UC_Checkout
Customer --> UC_MakePayment
Admin --> UC_TrackOrder
Admin --> UC_AddToCart
DeliveryService --> UC_CancelOrder
DeliveryService --> UC_AddToCart
PaymentGateway --> UC_BrowseProducts
PaymentGateway --> UC_TrackOrder
UC_TrackOrder ..> UC_WriteReview : <<extend>>
@enduml