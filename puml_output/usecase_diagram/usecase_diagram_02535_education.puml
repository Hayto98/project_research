@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
left to right direction
actor "Librarian" as L
actor "Parent" as P
actor "Teacher" as T
rectangle "Education System" {
  usecase "View Schedule" as UC_ViewSchedule
  usecase "Register Student" as UC_RegisterStudent
  usecase "Enroll Course" as UC_EnrollCourse
  usecase "Issue Certificate" as UC_IssueCertificate
  usecase "Take Attendance" as UC_TakeAttendance
}
L --> UC_IssueCertificate
L --> UC_TakeAttendance
L --> UC_ViewSchedule
P --> UC_RegisterStudent
P --> UC_IssueCertificate
P --> UC_EnrollCourse
T --> UC_IssueCertificate
UC_IssueCertificate ..> UC_EnrollCourse : <<extend>>
@enduml