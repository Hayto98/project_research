@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
left to right direction
actor "Librarian" as Librarian
actor "Admin" as Admin
actor "Registrar" as Registrar
actor "Student" as Student
rectangle "Education System" {
  usecase "Grade Exam" as UC_GradeExam
  usecase "Take Attendance" as UC_TakeAttendance
  usecase "View Schedule" as UC_ViewSchedule
  usecase "Issue Certificate" as UC_IssueCertificate
  usecase "Borrow Book" as UC_BorrowBook
  usecase "Enroll Course" as UC_EnrollCourse
}
Librarian --> UC_GradeExam
Librarian --> UC_IssueCertificate
Librarian --> UC_EnrollCourse
Admin --> UC_EnrollCourse
Admin --> UC_GradeExam
Admin --> UC_BorrowBook
Registrar --> UC_EnrollCourse
Registrar --> UC_TakeAttendance
Registrar --> UC_BorrowBook
Student --> UC_GradeExam
Student --> UC_ViewSchedule
Student --> UC_EnrollCourse
UC_BorrowBook ..|> UC_ViewSchedule : <<include>>
@enduml