@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
left to right direction
actor "Auditor" as A
actor "Bank Teller" as BT
actor "Account Holder" as AH
actor "Branch Manager" as BM
rectangle "Banking System" {
  usecase "Pay Bill" as UC_PayBill
  usecase "Block Card" as UC_BlockCard
  usecase "View Statement" as UC_ViewStatement
  usecase "Deposit Money" as UC_DepositMoney
  usecase "Apply For Loan" as UC_ApplyForLoan
}
A --> UC_DepositMoney
A --> UC_ApplyForLoan
BT --> UC_ApplyForLoan
BT --> UC_PayBill
AH --> UC_BlockCard
AH --> UC_PayBill
AH --> UC_DepositMoney
BM --> UC_ViewStatement
BM --> UC_DepositMoney
UC_DepositMoney ..> UC_PayBill : <<include>>
@enduml