@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
left to right direction
actor "Housekeeper" as Housekeeper
actor "Receptionist" as Receptionist
actor "Chef" as Chef
actor "Manager" as Manager
rectangle "Hotel System" {
  usecase "Cancel Reservation" as UC_CancelReservation
  usecase "Request Service" as UC_RequestService
  usecase "Check Out" as UC_CheckOut
  usecase "Process Payment" as UC_ProcessPayment
  usecase "Order Room Service" as UC_OrderRoomService
}
Housekeeper --> UC_CancelReservation
Housekeeper --> UC_RequestService
Receptionist --> UC_ProcessPayment
Receptionist --> UC_CancelReservation
Receptionist --> UC_RequestService
Chef --> UC_ProcessPayment
Chef --> UC_OrderRoomService
Chef --> UC_CancelReservation
Manager --> UC_CancelReservation
Manager --> UC_RequestService
Manager --> UC_CheckOut
UC_CancelReservation ..|> UC_OrderRoomService : <<include>>
@enduml