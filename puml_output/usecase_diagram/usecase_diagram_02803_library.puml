@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
left to right direction
actor "Librarian" as L
actor "Member" as M
actor "Admin" as A
rectangle "Library System" {
  usecase "Borrow Book" as UC_BorrowBook
  usecase "Search Catalog" as UC_SearchCatalog
  usecase "Pay Fine" as UC_PayFine
  usecase "Return Book" as UC_ReturnBook
  usecase "Reserve Book" as UC_ReserveBook
  usecase "Renew Loan" as UC_RenewLoan
  usecase "Register Member" as UC_RegisterMember
}
L --> UC_ReserveBook
L --> UC_BorrowBook
M --> UC_SearchCatalog
M --> UC_RegisterMember
A --> UC_PayFine
A --> UC_SearchCatalog
A --> UC_BorrowBook
@enduml