@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
left to right direction
actor "Admin" as A
actor "Payment Gateway" as PG
actor "Delivery Service" as DS
actor "Seller" as S
rectangle "Ecommerce System" {
  usecase "Add To Cart" as UC_AddToCart
  usecase "Write Review" as UC_WriteReview
  usecase "Track Order" as UC_TrackOrder
  usecase "Cancel Order" as UC_CancelOrder
  usecase "Apply Coupon" as UC_ApplyCoupon
  usecase "Manage Inventory" as UC_ManageInventory
  usecase "Checkout" as UC_Checkout
}
A --> UC_TrackOrder
A --> UC_Checkout
A --> UC_CancelOrder
PG --> UC_Checkout
PG --> UC_TrackOrder
PG --> UC_ManageInventory
DS --> UC_ManageInventory
S --> UC_WriteReview
S --> UC_ApplyCoupon
S --> UC_CancelOrder
UC_TrackOrder ..|> UC_CancelOrder : <<extend>>
@enduml