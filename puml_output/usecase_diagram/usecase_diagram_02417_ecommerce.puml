@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
left to right direction
actor "Admin" as A
actor "Payment Gateway" as PG
actor "Delivery Service" as DS
actor "Seller" as S
rectangle "Ecommerce System" {
  usecase "Make Payment" as UC_MakePayment
  usecase "Write Review" as UC_WriteReview
  usecase "Add To Cart" as UC_AddToCart
  usecase "Cancel Order" as UC_CancelOrder
  usecase "Apply Coupon" as UC_ApplyCoupon
}
A --> UC_AddToCart
A --> UC_CancelOrder
A --> UC_WriteReview
PG --> UC_AddToCart
PG --> UC_WriteReview
DS --> UC_AddToCart
DS --> UC_MakePayment
S --> UC_ApplyCoupon
S --> UC_MakePayment
UC_WriteReview ..> UC_CancelOrder : <<include>>
@enduml