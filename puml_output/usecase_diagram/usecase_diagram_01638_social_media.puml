@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
left to right direction
actor "User" as U
actor "Moderator" as M
actor "Advertiser" as A
actor "Admin" as A1
rectangle "Social Media System" {
  usecase "Comment" as UC_Comment
  usecase "Share Post" as UC_SharePost
  usecase "Report Content" as UC_ReportContent
  usecase "Edit Profile" as UC_EditProfile
  usecase "Like Post" as UC_LikePost
  usecase "Follow User" as UC_FollowUser
  usecase "Create Post" as UC_CreatePost
}
U --> UC_SharePost
M --> UC_SharePost
M --> UC_Comment
A --> UC_EditProfile
A --> UC_SharePost
A --> UC_CreatePost
A1 --> UC_FollowUser
A1 --> UC_EditProfile
UC_CreatePost ..|> UC_EditProfile : <<extend>>
@enduml