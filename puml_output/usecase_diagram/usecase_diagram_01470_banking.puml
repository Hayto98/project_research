@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
left to right direction
actor "Branch Manager" as BranchManager
actor "Bank Teller" as BankTeller
actor "Account Holder" as AccountHolder
actor "ATM" as ATM
rectangle "Banking System" {
  usecase "Block Card" as UC_BlockCard
  usecase "Deposit Money" as UC_DepositMoney
  usecase "View Statement" as UC_ViewStatement
  usecase "Open Account" as UC_OpenAccount
  usecase "Pay Bill" as UC_PayBill
}
BranchManager --> UC_OpenAccount
BankTeller --> UC_ViewStatement
BankTeller --> UC_BlockCard
AccountHolder --> UC_OpenAccount
AccountHolder --> UC_PayBill
AccountHolder --> UC_BlockCard
ATM --> UC_OpenAccount
@enduml