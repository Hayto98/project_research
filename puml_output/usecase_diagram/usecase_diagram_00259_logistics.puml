@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
left to right direction
actor "Fleet Manager" as FM
actor "Dispatcher" as D
actor "Customer" as C
actor "Driver" as D1
rectangle "Logistics System" {
  usecase "Fuel Vehicle" as UC_FuelVehicle
  usecase "Report Issue" as UC_ReportIssue
  usecase "Schedule Pickup" as UC_SchedulePickup
  usecase "Load Package" as UC_LoadPackage
  usecase "Update Inventory" as UC_UpdateInventory
}
FM --> UC_SchedulePickup
FM --> UC_ReportIssue
D --> UC_FuelVehicle
D --> UC_SchedulePickup
C --> UC_LoadPackage
D1 --> UC_UpdateInventory
D1 --> UC_LoadPackage
UC_FuelVehicle ..> UC_ReportIssue : <<include>>
@enduml