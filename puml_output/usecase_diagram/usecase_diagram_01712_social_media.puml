@startuml
skinparam monochrome true
skinparam defaultFontSize 11
left to right direction
actor "Moderator" as M
actor "Advertiser" as A
actor "Admin" as A1
actor "User" as U
rectangle "Social Media System" {
  usecase "Send Message" as UC_SendMessage
  usecase "Report Content" as UC_ReportContent
  usecase "Follow User" as UC_FollowUser
  usecase "Create Post" as UC_CreatePost
  usecase "Comment" as UC_Comment
  usecase "Share Post" as UC_SharePost
}
M --> UC_SendMessage
M --> UC_FollowUser
M --> UC_CreatePost
A --> UC_CreatePost
A --> UC_Comment
A1 --> UC_CreatePost
A1 --> UC_ReportContent
A1 --> UC_SharePost
U --> UC_SharePost
UC_FollowUser ..|> UC_SendMessage : <<include>>
@enduml