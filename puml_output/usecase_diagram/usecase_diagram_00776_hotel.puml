@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
left to right direction
actor "Receptionist" as R
actor "Housekeeper" as H
actor "Chef" as C
actor "Guest" as G
rectangle "Hotel System" {
  usecase "Check Out" as UC_CheckOut
  usecase "Process Payment" as UC_ProcessPayment
  usecase "Check In" as UC_CheckIn
  usecase "Clean Room" as UC_CleanRoom
  usecase "Cancel Reservation" as UC_CancelReservation
  usecase "Order Room Service" as UC_OrderRoomService
}
R --> UC_CheckIn
R --> UC_CheckOut
R --> UC_CancelReservation
H --> UC_CleanRoom
H --> UC_CancelReservation
H --> UC_ProcessPayment
C --> UC_ProcessPayment
C --> UC_CleanRoom
C --> UC_CancelReservation
G --> UC_OrderRoomService
G --> UC_CheckIn
UC_CheckIn ..|> UC_ProcessPayment : <<extend>>
@enduml