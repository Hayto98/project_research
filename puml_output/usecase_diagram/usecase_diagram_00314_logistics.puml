@startuml
skinparam monochrome true
skinparam defaultFontSize 11
left to right direction
actor "Customer" as Customer
actor "Warehouse Staff" as WarehouseStaff
actor "Fleet Manager" as FleetManager
rectangle "Logistics System" {
  usecase "Deliver Package" as UC_DeliverPackage
  usecase "Assign Route" as UC_AssignRoute
  usecase "Load Package" as UC_LoadPackage
  usecase "Track Shipment" as UC_TrackShipment
  usecase "Report Issue" as UC_ReportIssue
  usecase "Fuel Vehicle" as UC_FuelVehicle
  usecase "Update Inventory" as UC_UpdateInventory
}
Customer --> UC_LoadPackage
WarehouseStaff --> UC_UpdateInventory
WarehouseStaff --> UC_TrackShipment
WarehouseStaff --> UC_DeliverPackage
FleetManager --> UC_UpdateInventory
FleetManager --> UC_DeliverPackage
FleetManager --> UC_ReportIssue
@enduml