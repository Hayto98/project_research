@startuml
skinparam ArrowColor #555555
left to right direction
actor "Payment Gateway" as PG
actor "Customer" as C
actor "Admin" as A
actor "Delivery Service" as DS
rectangle "Ecommerce System" {
  usecase "Write Review" as UC_WriteReview
  usecase "Checkout" as UC_Checkout
  usecase "Apply Coupon" as UC_ApplyCoupon
  usecase "Track Order" as UC_TrackOrder
  usecase "Add To Cart" as UC_AddToCart
  usecase "Browse Products" as UC_BrowseProducts
  usecase "Make Payment" as UC_MakePayment
  usecase "Manage Inventory" as UC_ManageInventory
}
PG --> UC_WriteReview
PG --> UC_BrowseProducts
PG --> UC_MakePayment
C --> UC_MakePayment
C --> UC_TrackOrder
C --> UC_AddToCart
A --> UC_MakePayment
A --> UC_WriteReview
DS --> UC_BrowseProducts
DS --> UC_ManageInventory
DS --> UC_ApplyCoupon
UC_AddToCart ..> UC_MakePayment : <<extend>>
@enduml