@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
left to right direction
actor "User" as U
actor "Advertiser" as A
actor "Admin" as A1
actor "Moderator" as M
rectangle "Social Media System" {
  usecase "Report Content" as UC_ReportContent
  usecase "Send Message" as UC_SendMessage
  usecase "Create Post" as UC_CreatePost
  usecase "Edit Profile" as UC_EditProfile
  usecase "Follow User" as UC_FollowUser
  usecase "Like Post" as UC_LikePost
}
U --> UC_EditProfile
A --> UC_EditProfile
A --> UC_CreatePost
A1 --> UC_LikePost
A1 --> UC_CreatePost
A1 --> UC_FollowUser
M --> UC_ReportContent
M --> UC_SendMessage
UC_EditProfile ..> UC_LikePost : <<include>>
@enduml