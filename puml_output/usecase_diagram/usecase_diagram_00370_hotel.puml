@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
left to right direction
actor "Manager" as Manager
actor "Receptionist" as Receptionist
actor "Housekeeper" as Housekeeper
actor "Chef" as Chef
rectangle "Hotel System" {
  usecase "Order Room Service" as UC_OrderRoomService
  usecase "Book Room" as UC_BookRoom
  usecase "Process Payment" as UC_ProcessPayment
  usecase "Check In" as UC_CheckIn
  usecase "Cancel Reservation" as UC_CancelReservation
  usecase "Clean Room" as UC_CleanRoom
}
Manager --> UC_CleanRoom
Manager --> UC_BookRoom
Manager --> UC_CancelReservation
Receptionist --> UC_OrderRoomService
Receptionist --> UC_ProcessPayment
Receptionist --> UC_BookRoom
Housekeeper --> UC_CleanRoom
Chef --> UC_CancelReservation
Chef --> UC_CleanRoom
Chef --> UC_CheckIn
@enduml