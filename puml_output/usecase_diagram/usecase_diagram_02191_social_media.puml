@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
left to right direction
actor "Advertiser" as A
actor "User" as U
actor "Moderator" as M
actor "Admin" as A1
rectangle "Social Media System" {
  usecase "Report Content" as UC_ReportContent
  usecase "Send Message" as UC_SendMessage
  usecase "Like Post" as UC_LikePost
  usecase "Create Post" as UC_CreatePost
  usecase "Share Post" as UC_SharePost
  usecase "Edit Profile" as UC_EditProfile
}
A --> UC_SendMessage
A --> UC_SharePost
A --> UC_LikePost
U --> UC_SendMessage
U --> UC_CreatePost
U --> UC_SharePost
M --> UC_ReportContent
M --> UC_CreatePost
M --> UC_SendMessage
A1 --> UC_EditProfile
A1 --> UC_ReportContent
@enduml