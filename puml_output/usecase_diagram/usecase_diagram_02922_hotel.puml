@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
left to right direction
actor "Guest" as G
actor "Manager" as M
actor "Housekeeper" as H
actor "Chef" as C
rectangle "Hotel System" {
  usecase "Request Service" as UC_RequestService
  usecase "Cancel Reservation" as UC_CancelReservation
  usecase "Process Payment" as UC_ProcessPayment
  usecase "Order Room Service" as UC_OrderRoomService
  usecase "Clean Room" as UC_CleanRoom
  usecase "Check Out" as UC_CheckOut
}
G --> UC_ProcessPayment
G --> UC_CleanRoom
G --> UC_OrderRoomService
M --> UC_CancelReservation
M --> UC_ProcessPayment
H --> UC_CleanRoom
H --> UC_CheckOut
C --> UC_OrderRoomService
C --> UC_RequestService
C --> UC_CleanRoom
UC_RequestService ..|> UC_CleanRoom : <<include>>
@enduml