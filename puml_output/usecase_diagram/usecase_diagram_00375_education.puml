@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
left to right direction
actor "Parent" as P
actor "Teacher" as T
actor "Librarian" as L
rectangle "Education System" {
  usecase "Grade Exam" as UC_GradeExam
  usecase "View Schedule" as UC_ViewSchedule
  usecase "Take Attendance" as UC_TakeAttendance
  usecase "Borrow Book" as UC_BorrowBook
  usecase "Enroll Course" as UC_EnrollCourse
  usecase "Register Student" as UC_RegisterStudent
  usecase "Submit Assignment" as UC_SubmitAssignment
}
P --> UC_TakeAttendance
P --> UC_EnrollCourse
T --> UC_BorrowBook
T --> UC_RegisterStudent
T --> UC_GradeExam
L --> UC_ViewSchedule
L --> UC_TakeAttendance
L --> UC_SubmitAssignment
UC_TakeAttendance ..> UC_ViewSchedule : <<extend>>
@enduml