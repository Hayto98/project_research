@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
left to right direction
actor "Nurse" as N
actor "Patient" as P
actor "Doctor" as D
rectangle "Healthcare System" {
  usecase "Run Lab Test" as UC_RunLabTest
  usecase "Update Medical Record" as UC_UpdateMedicalRecord
  usecase "Admit Patient" as UC_AdmitPatient
  usecase "Process Insurance Claim" as UC_ProcessInsuranceClaim
  usecase "Examine Patient" as UC_ExaminePatient
  usecase "Discharge Patient" as UC_DischargePatient
  usecase "Issue Prescription" as UC_IssuePrescription
}
N --> UC_AdmitPatient
N --> UC_UpdateMedicalRecord
N --> UC_RunLabTest
P --> UC_UpdateMedicalRecord
D --> UC_ExaminePatient
D --> UC_ProcessInsuranceClaim
D --> UC_RunLabTest
UC_UpdateMedicalRecord ..|> UC_ProcessInsuranceClaim : <<include>>
@enduml