@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
left to right direction
actor "Librarian" as L
actor "Member" as M
actor "Admin" as A
rectangle "Library System" {
  usecase "Reserve Book" as UC_ReserveBook
  usecase "Search Catalog" as UC_SearchCatalog
  usecase "Register Member" as UC_RegisterMember
  usecase "Return Book" as UC_ReturnBook
  usecase "Add New Book" as UC_AddNewBook
  usecase "Renew Loan" as UC_RenewLoan
}
L --> UC_AddNewBook
M --> UC_ReserveBook
M --> UC_SearchCatalog
M --> UC_RegisterMember
A --> UC_ReserveBook
A --> UC_RegisterMember
A --> UC_ReturnBook
UC_SearchCatalog ..> UC_ReturnBook : <<include>>
@enduml