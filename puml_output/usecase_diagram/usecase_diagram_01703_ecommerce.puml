@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
left to right direction
actor "Admin" as A
actor "Delivery Service" as DS
actor "Payment Gateway" as PG
actor "Customer" as C
rectangle "Ecommerce System" {
  usecase "Track Order" as UC_TrackOrder
  usecase "Cancel Order" as UC_CancelOrder
  usecase "Manage Inventory" as UC_ManageInventory
  usecase "Write Review" as UC_WriteReview
  usecase "Add To Cart" as UC_AddToCart
}
A --> UC_CancelOrder
A --> UC_WriteReview
DS --> UC_TrackOrder
PG --> UC_WriteReview
PG --> UC_CancelOrder
PG --> UC_TrackOrder
C --> UC_ManageInventory
C --> UC_AddToCart
UC_CancelOrder ..> UC_TrackOrder : <<extend>>
@enduml