@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
left to right direction
actor "Chef" as Chef
actor "Housekeeper" as Housekeeper
actor "Manager" as Manager
actor "Guest" as Guest
rectangle "Hotel System" {
  usecase "Check Out" as UC_CheckOut
  usecase "Book Room" as UC_BookRoom
  usecase "Process Payment" as UC_ProcessPayment
  usecase "Request Service" as UC_RequestService
  usecase "Cancel Reservation" as UC_CancelReservation
}
Chef --> UC_CheckOut
Chef --> UC_BookRoom
Chef --> UC_RequestService
Housekeeper --> UC_BookRoom
Housekeeper --> UC_RequestService
Manager --> UC_CancelReservation
Manager --> UC_CheckOut
Manager --> UC_RequestService
Guest --> UC_CancelReservation
Guest --> UC_BookRoom
Guest --> UC_CheckOut
@enduml