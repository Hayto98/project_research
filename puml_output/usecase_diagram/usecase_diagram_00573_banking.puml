@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
left to right direction
actor "Account Holder" as AH
actor "Auditor" as A
actor "ATM" as A1
actor "Bank Teller" as BT
rectangle "Banking System" {
  usecase "Block Card" as UC_BlockCard
  usecase "Apply For Loan" as UC_ApplyForLoan
  usecase "Transfer Funds" as UC_TransferFunds
  usecase "Deposit Money" as UC_DepositMoney
  usecase "View Statement" as UC_ViewStatement
}
AH --> UC_ApplyForLoan
AH --> UC_BlockCard
AH --> UC_DepositMoney
A --> UC_TransferFunds
A1 --> UC_DepositMoney
A1 --> UC_BlockCard
A1 --> UC_ApplyForLoan
BT --> UC_ViewStatement
UC_TransferFunds ..> UC_DepositMoney : <<include>>
@enduml