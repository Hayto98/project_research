@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
left to right direction
actor "Bank Teller" as BT
actor "Account Holder" as AH
actor "ATM" as A
actor "Auditor" as A1
rectangle "Banking System" {
  usecase "Apply For Loan" as UC_ApplyForLoan
  usecase "Deposit Money" as UC_DepositMoney
  usecase "Open Account" as UC_OpenAccount
  usecase "Block Card" as UC_BlockCard
  usecase "Withdraw Cash" as UC_WithdrawCash
  usecase "Pay Bill" as UC_PayBill
  usecase "View Statement" as UC_ViewStatement
}
BT --> UC_OpenAccount
AH --> UC_WithdrawCash
AH --> UC_ApplyForLoan
AH --> UC_BlockCard
A --> UC_ApplyForLoan
A --> UC_ViewStatement
A --> UC_DepositMoney
A1 --> UC_PayBill
UC_WithdrawCash ..> UC_ApplyForLoan : <<include>>
@enduml