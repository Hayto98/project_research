@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
left to right direction
actor "Seller" as S
actor "Admin" as A
actor "Customer" as C
rectangle "Ecommerce System" {
  usecase "Checkout" as UC_Checkout
  usecase "Write Review" as UC_WriteReview
  usecase "Make Payment" as UC_MakePayment
  usecase "Cancel Order" as UC_CancelOrder
  usecase "Manage Inventory" as UC_ManageInventory
}
S --> UC_MakePayment
A --> UC_MakePayment
A --> UC_CancelOrder
C --> UC_ManageInventory
UC_CancelOrder ..|> UC_Checkout : <<extend>>
@enduml