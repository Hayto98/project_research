@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
left to right direction
actor "Admin" as A
actor "Seller" as S
actor "Payment Gateway" as PG
actor "Delivery Service" as DS
rectangle "Ecommerce System" {
  usecase "Add To Cart" as UC_AddToCart
  usecase "Browse Products" as UC_BrowseProducts
  usecase "Make Payment" as UC_MakePayment
  usecase "Manage Inventory" as UC_ManageInventory
  usecase "Track Order" as UC_TrackOrder
  usecase "Write Review" as UC_WriteReview
}
A --> UC_WriteReview
A --> UC_BrowseProducts
S --> UC_ManageInventory
PG --> UC_AddToCart
PG --> UC_TrackOrder
PG --> UC_WriteReview
DS --> UC_TrackOrder
DS --> UC_MakePayment
UC_BrowseProducts ..> UC_AddToCart : <<include>>
@enduml