@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
left to right direction
actor "Parent" as Parent
actor "Librarian" as Librarian
actor "Teacher" as Teacher
actor "Student" as Student
rectangle "Education System" {
  usecase "Grade Exam" as UC_GradeExam
  usecase "Enroll Course" as UC_EnrollCourse
  usecase "View Schedule" as UC_ViewSchedule
  usecase "Register Student" as UC_RegisterStudent
  usecase "Borrow Book" as UC_BorrowBook
  usecase "Submit Assignment" as UC_SubmitAssignment
}
Parent --> UC_ViewSchedule
Librarian --> UC_BorrowBook
Librarian --> UC_ViewSchedule
Librarian --> UC_EnrollCourse
Teacher --> UC_RegisterStudent
Teacher --> UC_BorrowBook
Student --> UC_RegisterStudent
Student --> UC_BorrowBook
UC_BorrowBook ..|> UC_GradeExam : <<extend>>
@enduml