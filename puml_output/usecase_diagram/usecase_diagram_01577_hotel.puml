@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
left to right direction
actor "Housekeeper" as H
actor "Guest" as G
actor "Manager" as M
actor "Chef" as C
rectangle "Hotel System" {
  usecase "Check In" as UC_CheckIn
  usecase "Order Room Service" as UC_OrderRoomService
  usecase "Clean Room" as UC_CleanRoom
  usecase "Book Room" as UC_BookRoom
  usecase "Check Out" as UC_CheckOut
}
H --> UC_OrderRoomService
H --> UC_BookRoom
H --> UC_CheckOut
G --> UC_CheckOut
M --> UC_CheckOut
M --> UC_CheckIn
C --> UC_CheckOut
UC_CheckOut ..> UC_BookRoom : <<extend>>
@enduml