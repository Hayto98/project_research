@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
left to right direction
actor "Student" as S
actor "Registrar" as R
actor "Parent" as P
actor "Admin" as A
rectangle "Education System" {
  usecase "Register Student" as UC_RegisterStudent
  usecase "Submit Assignment" as UC_SubmitAssignment
  usecase "Borrow Book" as UC_BorrowBook
  usecase "View Schedule" as UC_ViewSchedule
  usecase "Take Attendance" as UC_TakeAttendance
}
S --> UC_TakeAttendance
R --> UC_TakeAttendance
R --> UC_SubmitAssignment
R --> UC_RegisterStudent
P --> UC_SubmitAssignment
A --> UC_TakeAttendance
UC_ViewSchedule ..> UC_RegisterStudent : <<include>>
@enduml