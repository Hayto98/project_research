@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
left to right direction
actor "Advertiser" as Advertiser
actor "Admin" as Admin
actor "User" as User
rectangle "Social Media System" {
  usecase "Edit Profile" as UC_EditProfile
  usecase "Follow User" as UC_FollowUser
  usecase "Comment" as UC_Comment
  usecase "Report Content" as UC_ReportContent
  usecase "Share Post" as UC_SharePost
}
Advertiser --> UC_Comment
Admin --> UC_FollowUser
Admin --> UC_EditProfile
User --> UC_ReportContent
UC_EditProfile ..> UC_Comment : <<extend>>
@enduml