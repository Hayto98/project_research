@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
left to right direction
actor "ATM" as ATM
actor "Auditor" as Auditor
actor "Account Holder" as AccountHolder
actor "Bank Teller" as BankTeller
rectangle "Banking System" {
  usecase "Apply For Loan" as UC_ApplyForLoan
  usecase "Transfer Funds" as UC_TransferFunds
  usecase "Withdraw Cash" as UC_WithdrawCash
  usecase "Deposit Money" as UC_DepositMoney
  usecase "Pay Bill" as UC_PayBill
  usecase "Open Account" as UC_OpenAccount
  usecase "View Statement" as UC_ViewStatement
}
ATM --> UC_TransferFunds
ATM --> UC_OpenAccount
ATM --> UC_PayBill
Auditor --> UC_PayBill
Auditor --> UC_WithdrawCash
AccountHolder --> UC_DepositMoney
AccountHolder --> UC_PayBill
BankTeller --> UC_ViewStatement
BankTeller --> UC_PayBill
@enduml