@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
left to right direction
actor "Admin" as A
actor "User" as U
actor "Advertiser" as A1
actor "Moderator" as M
rectangle "Social Media System" {
  usecase "Share Post" as UC_SharePost
  usecase "Report Content" as UC_ReportContent
  usecase "Like Post" as UC_LikePost
  usecase "Send Message" as UC_SendMessage
  usecase "Edit Profile" as UC_EditProfile
}
A --> UC_EditProfile
A --> UC_SendMessage
A --> UC_LikePost
U --> UC_SendMessage
A1 --> UC_SendMessage
M --> UC_SharePost
M --> UC_LikePost
M --> UC_EditProfile
UC_EditProfile ..|> UC_SendMessage : <<include>>
@enduml