@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
left to right direction
actor "Admin" as Admin
actor "Member" as Member
actor "Librarian" as Librarian
rectangle "Library System" {
  usecase "Add New Book" as UC_AddNewBook
  usecase "Pay Fine" as UC_PayFine
  usecase "Return Book" as UC_ReturnBook
  usecase "Reserve Book" as UC_ReserveBook
  usecase "Register Member" as UC_RegisterMember
  usecase "Borrow Book" as UC_BorrowBook
  usecase "Renew Loan" as UC_RenewLoan
  usecase "Search Catalog" as UC_SearchCatalog
}
Admin --> UC_AddNewBook
Admin --> UC_BorrowBook
Admin --> UC_ReturnBook
Member --> UC_BorrowBook
Member --> UC_AddNewBook
Librarian --> UC_PayFine
UC_BorrowBook ..> UC_SearchCatalog : <<extend>>
@enduml