@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
left to right direction
actor "Advertiser" as A
actor "Moderator" as M
actor "User" as U
actor "Admin" as A1
rectangle "Social Media System" {
  usecase "Create Post" as UC_CreatePost
  usecase "Follow User" as UC_FollowUser
  usecase "Like Post" as UC_LikePost
  usecase "Comment" as UC_Comment
  usecase "Send Message" as UC_SendMessage
  usecase "Share Post" as UC_SharePost
}
A --> UC_CreatePost
A --> UC_SendMessage
A --> UC_SharePost
M --> UC_FollowUser
U --> UC_LikePost
U --> UC_SendMessage
U --> UC_SharePost
A1 --> UC_SendMessage
A1 --> UC_Comment
A1 --> UC_FollowUser
@enduml