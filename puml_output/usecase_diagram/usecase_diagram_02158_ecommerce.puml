@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
left to right direction
actor "Delivery Service" as DS
actor "Customer" as C
actor "Seller" as S
actor "Admin" as A
rectangle "Ecommerce System" {
  usecase "Add To Cart" as UC_AddToCart
  usecase "Write Review" as UC_WriteReview
  usecase "Manage Inventory" as UC_ManageInventory
  usecase "Make Payment" as UC_MakePayment
  usecase "Checkout" as UC_Checkout
}
DS --> UC_MakePayment
C --> UC_AddToCart
C --> UC_MakePayment
C --> UC_ManageInventory
S --> UC_AddToCart
A --> UC_AddToCart
A --> UC_ManageInventory
A --> UC_Checkout
UC_Checkout ..> UC_MakePayment : <<include>>
@enduml