@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
left to right direction
actor "Branch Manager" as BM
actor "Auditor" as A
actor "ATM" as A1
actor "Bank Teller" as BT
rectangle "Banking System" {
  usecase "Withdraw Cash" as UC_WithdrawCash
  usecase "Apply For Loan" as UC_ApplyForLoan
  usecase "Deposit Money" as UC_DepositMoney
  usecase "Open Account" as UC_OpenAccount
  usecase "Pay Bill" as UC_PayBill
}
BM --> UC_DepositMoney
BM --> UC_ApplyForLoan
A --> UC_PayBill
A --> UC_WithdrawCash
A1 --> UC_ApplyForLoan
A1 --> UC_WithdrawCash
A1 --> UC_PayBill
BT --> UC_PayBill
BT --> UC_ApplyForLoan
UC_ApplyForLoan ..|> UC_OpenAccount : <<include>>
@enduml