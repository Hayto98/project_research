@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
left to right direction
actor "Seller" as S
actor "Delivery Service" as DS
actor "Customer" as C
actor "Payment Gateway" as PG
rectangle "Ecommerce System" {
  usecase "Cancel Order" as UC_CancelOrder
  usecase "Apply Coupon" as UC_ApplyCoupon
  usecase "Browse Products" as UC_BrowseProducts
  usecase "Track Order" as UC_TrackOrder
  usecase "Add To Cart" as UC_AddToCart
  usecase "Checkout" as UC_Checkout
  usecase "Make Payment" as UC_MakePayment
}
S --> UC_MakePayment
S --> UC_BrowseProducts
S --> UC_Checkout
DS --> UC_MakePayment
DS --> UC_CancelOrder
C --> UC_BrowseProducts
C --> UC_ApplyCoupon
PG --> UC_AddToCart
PG --> UC_MakePayment
UC_BrowseProducts ..|> UC_CancelOrder : <<include>>
@enduml