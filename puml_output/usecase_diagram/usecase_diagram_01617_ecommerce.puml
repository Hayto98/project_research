@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
left to right direction
actor "Customer" as C
actor "Admin" as A
actor "Seller" as S
rectangle "Ecommerce System" {
  usecase "Manage Inventory" as UC_ManageInventory
  usecase "Apply Coupon" as UC_ApplyCoupon
  usecase "Cancel Order" as UC_CancelOrder
  usecase "Checkout" as UC_Checkout
  usecase "Add To Cart" as UC_AddToCart
  usecase "Browse Products" as UC_BrowseProducts
  usecase "Make Payment" as UC_MakePayment
  usecase "Track Order" as UC_TrackOrder
}
C --> UC_ManageInventory
A --> UC_Checkout
S --> UC_ManageInventory
S --> UC_BrowseProducts
UC_AddToCart ..|> UC_CancelOrder : <<extend>>
@enduml