@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
left to right direction
actor "Payment Gateway" as PG
actor "Seller" as S
actor "Customer" as C
rectangle "Ecommerce System" {
  usecase "Apply Coupon" as UC_ApplyCoupon
  usecase "Make Payment" as UC_MakePayment
  usecase "Browse Products" as UC_BrowseProducts
  usecase "Add To Cart" as UC_AddToCart
  usecase "Cancel Order" as UC_CancelOrder
  usecase "Checkout" as UC_Checkout
}
PG --> UC_Checkout
S --> UC_ApplyCoupon
S --> UC_CancelOrder
S --> UC_MakePayment
C --> UC_Checkout
UC_ApplyCoupon ..|> UC_AddToCart : <<extend>>
@enduml