@startuml
skinparam monochrome true
skinparam ArrowColor #555555
left to right direction
actor "Driver" as D
actor "Warehouse Staff" as WS
actor "Customer" as C
actor "Dispatcher" as D1
rectangle "Logistics System" {
  usecase "Load Package" as UC_LoadPackage
  usecase "Deliver Package" as UC_DeliverPackage
  usecase "Fuel Vehicle" as UC_FuelVehicle
  usecase "Assign Route" as UC_AssignRoute
  usecase "Update Inventory" as UC_UpdateInventory
}
D --> UC_LoadPackage
D --> UC_UpdateInventory
WS --> UC_FuelVehicle
WS --> UC_DeliverPackage
WS --> UC_LoadPackage
C --> UC_DeliverPackage
C --> UC_AssignRoute
D1 --> UC_UpdateInventory
D1 --> UC_AssignRoute
D1 --> UC_DeliverPackage
@enduml