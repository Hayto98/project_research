@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
left to right direction
actor "Parent" as P
actor "Student" as S
actor "Librarian" as L
actor "Teacher" as T
rectangle "Education System" {
  usecase "Enroll Course" as UC_EnrollCourse
  usecase "Take Attendance" as UC_TakeAttendance
  usecase "Grade Exam" as UC_GradeExam
  usecase "View Schedule" as UC_ViewSchedule
  usecase "Borrow Book" as UC_BorrowBook
  usecase "Issue Certificate" as UC_IssueCertificate
}
P --> UC_EnrollCourse
P --> UC_IssueCertificate
P --> UC_BorrowBook
S --> UC_BorrowBook
L --> UC_BorrowBook
T --> UC_BorrowBook
T --> UC_TakeAttendance
T --> UC_GradeExam
UC_ViewSchedule ..> UC_GradeExam : <<include>>
@enduml