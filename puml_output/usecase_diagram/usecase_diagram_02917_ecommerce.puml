@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
left to right direction
actor "Payment Gateway" as PG
actor "Delivery Service" as DS
actor "Admin" as A
rectangle "Ecommerce System" {
  usecase "Browse Products" as UC_BrowseProducts
  usecase "Manage Inventory" as UC_ManageInventory
  usecase "Write Review" as UC_WriteReview
  usecase "Add To Cart" as UC_AddToCart
  usecase "Cancel Order" as UC_CancelOrder
  usecase "Checkout" as UC_Checkout
}
PG --> UC_AddToCart
PG --> UC_CancelOrder
DS --> UC_CancelOrder
DS --> UC_Checkout
DS --> UC_WriteReview
A --> UC_AddToCart
UC_AddToCart ..|> UC_ManageInventory : <<include>>
@enduml