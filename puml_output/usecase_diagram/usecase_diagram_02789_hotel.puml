@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
left to right direction
actor "Manager" as M
actor "Guest" as G
actor "Chef" as C
rectangle "Hotel System" {
  usecase "Clean Room" as UC_CleanRoom
  usecase "Check In" as UC_CheckIn
  usecase "Request Service" as UC_RequestService
  usecase "Process Payment" as UC_ProcessPayment
  usecase "Cancel Reservation" as UC_CancelReservation
}
M --> UC_CleanRoom
M --> UC_RequestService
G --> UC_RequestService
C --> UC_CheckIn
C --> UC_ProcessPayment
C --> UC_CleanRoom
UC_RequestService ..> UC_CancelReservation : <<extend>>
@enduml