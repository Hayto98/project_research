@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
left to right direction
actor "Customer" as C
actor "Seller" as S
rectangle "Ecommerce System" {
  usecase "Track Order" as UC_TrackOrder
  usecase "Add To Cart" as UC_AddToCart
  usecase "Cancel Order" as UC_CancelOrder
  usecase "Apply Coupon" as UC_ApplyCoupon
  usecase "Browse Products" as UC_BrowseProducts
}
C --> UC_BrowseProducts
S --> UC_BrowseProducts
S --> UC_CancelOrder
S --> UC_TrackOrder
@enduml