@startuml
skinparam monochrome true
skinparam shadowing true
left to right direction
actor "Manager" as M
actor "Guest" as G
actor "Receptionist" as R
actor "Housekeeper" as H
rectangle "Hotel System" {
  usecase "Cancel Reservation" as UC_CancelReservation
  usecase "Check In" as UC_CheckIn
  usecase "Request Service" as UC_RequestService
  usecase "Process Payment" as UC_ProcessPayment
  usecase "Check Out" as UC_CheckOut
}
M --> UC_CheckOut
M --> UC_ProcessPayment
M --> UC_RequestService
G --> UC_CheckOut
G --> UC_RequestService
G --> UC_CancelReservation
R --> UC_RequestService
R --> UC_CancelReservation
H --> UC_CheckIn
H --> UC_RequestService
H --> UC_ProcessPayment
@enduml