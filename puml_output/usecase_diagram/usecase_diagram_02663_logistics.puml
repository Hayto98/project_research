@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
left to right direction
actor "Customer" as C
actor "Warehouse Staff" as WS
actor "Fleet Manager" as FM
actor "Driver" as D
rectangle "Logistics System" {
  usecase "Deliver Package" as UC_DeliverPackage
  usecase "Assign Route" as UC_AssignRoute
  usecase "Schedule Pickup" as UC_SchedulePickup
  usecase "Update Inventory" as UC_UpdateInventory
  usecase "Track Shipment" as UC_TrackShipment
  usecase "Fuel Vehicle" as UC_FuelVehicle
}
C --> UC_FuelVehicle
C --> UC_SchedulePickup
C --> UC_UpdateInventory
WS --> UC_AssignRoute
WS --> UC_TrackShipment
WS --> UC_DeliverPackage
FM --> UC_TrackShipment
FM --> UC_AssignRoute
FM --> UC_DeliverPackage
D --> UC_TrackShipment
D --> UC_SchedulePickup
@enduml