@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
left to right direction
actor "Advertiser" as A
actor "Admin" as A1
actor "Moderator" as M
actor "User" as U
rectangle "Social Media System" {
  usecase "Report Content" as UC_ReportContent
  usecase "Share Post" as UC_SharePost
  usecase "Send Message" as UC_SendMessage
  usecase "Like Post" as UC_LikePost
  usecase "Comment" as UC_Comment
  usecase "Follow User" as UC_FollowUser
}
A --> UC_SharePost
A1 --> UC_ReportContent
M --> UC_SharePost
M --> UC_ReportContent
U --> UC_FollowUser
U --> UC_LikePost
UC_SharePost ..> UC_LikePost : <<include>>
@enduml