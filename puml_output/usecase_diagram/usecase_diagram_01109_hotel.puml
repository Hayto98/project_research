@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
left to right direction
actor "Housekeeper" as Housekeeper
actor "Receptionist" as Receptionist
actor "Chef" as Chef
rectangle "Hotel System" {
  usecase "Cancel Reservation" as UC_CancelReservation
  usecase "Request Service" as UC_RequestService
  usecase "Check In" as UC_CheckIn
  usecase "Check Out" as UC_CheckOut
  usecase "Book Room" as UC_BookRoom
}
Housekeeper --> UC_RequestService
Housekeeper --> UC_CheckIn
Receptionist --> UC_CancelReservation
Receptionist --> UC_RequestService
Receptionist --> UC_CheckOut
Chef --> UC_CancelReservation
Chef --> UC_CheckIn
Chef --> UC_BookRoom
UC_CheckIn ..|> UC_RequestService : <<extend>>
@enduml