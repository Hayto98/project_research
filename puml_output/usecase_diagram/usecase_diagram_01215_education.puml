@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
left to right direction
actor "Librarian" as Librarian
actor "Registrar" as Registrar
actor "Admin" as Admin
actor "Teacher" as Teacher
rectangle "Education System" {
  usecase "Issue Certificate" as UC_IssueCertificate
  usecase "View Schedule" as UC_ViewSchedule
  usecase "Submit Assignment" as UC_SubmitAssignment
  usecase "Borrow Book" as UC_BorrowBook
  usecase "Take Attendance" as UC_TakeAttendance
}
Librarian --> UC_ViewSchedule
Librarian --> UC_IssueCertificate
Librarian --> UC_TakeAttendance
Registrar --> UC_IssueCertificate
Admin --> UC_IssueCertificate
Teacher --> UC_BorrowBook
Teacher --> UC_IssueCertificate
Teacher --> UC_SubmitAssignment
UC_SubmitAssignment ..|> UC_IssueCertificate : <<include>>
@enduml