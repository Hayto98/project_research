@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
left to right direction
actor "Admin" as A
actor "Moderator" as M
actor "Advertiser" as A1
rectangle "Social Media System" {
  usecase "Follow User" as UC_FollowUser
  usecase "Edit Profile" as UC_EditProfile
  usecase "Like Post" as UC_LikePost
  usecase "Share Post" as UC_SharePost
  usecase "Comment" as UC_Comment
}
A --> UC_EditProfile
A --> UC_SharePost
A --> UC_FollowUser
M --> UC_FollowUser
A1 --> UC_EditProfile
A1 --> UC_Comment
UC_FollowUser ..|> UC_EditProfile : <<extend>>
@enduml