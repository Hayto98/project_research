@startuml
skinparam ArrowColor #555555
left to right direction
actor "Admin" as A
actor "Advertiser" as A1
actor "User" as U
actor "Moderator" as M
rectangle "Social Media System" {
  usecase "Send Message" as UC_SendMessage
  usecase "Create Post" as UC_CreatePost
  usecase "Share Post" as UC_SharePost
  usecase "Edit Profile" as UC_EditProfile
  usecase "Report Content" as UC_ReportContent
}
A --> UC_ReportContent
A --> UC_SharePost
A --> UC_CreatePost
A1 --> UC_SendMessage
A1 --> UC_SharePost
U --> UC_ReportContent
U --> UC_CreatePost
U --> UC_SendMessage
M --> UC_SharePost
M --> UC_CreatePost
M --> UC_SendMessage
UC_ReportContent ..|> UC_CreatePost : <<include>>
@enduml