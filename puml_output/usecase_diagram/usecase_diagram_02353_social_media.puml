@startuml
skinparam monochrome true
skinparam defaultFontSize 13
left to right direction
actor "Admin" as A
actor "Moderator" as M
actor "Advertiser" as A1
rectangle "Social Media System" {
  usecase "Send Message" as UC_SendMessage
  usecase "Create Post" as UC_CreatePost
  usecase "Share Post" as UC_SharePost
  usecase "Comment" as UC_Comment
  usecase "Report Content" as UC_ReportContent
  usecase "Follow User" as UC_FollowUser
  usecase "Like Post" as UC_LikePost
}
A --> UC_ReportContent
M --> UC_Comment
M --> UC_ReportContent
M --> UC_SendMessage
A1 --> UC_SharePost
A1 --> UC_CreatePost
A1 --> UC_LikePost
UC_CreatePost ..|> UC_FollowUser : <<include>>
@enduml