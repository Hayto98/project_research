@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
left to right direction
actor "Auditor" as A
actor "ATM" as A1
actor "Branch Manager" as BM
actor "Bank Teller" as BT
rectangle "Banking System" {
  usecase "View Statement" as UC_ViewStatement
  usecase "Apply For Loan" as UC_ApplyForLoan
  usecase "Block Card" as UC_BlockCard
  usecase "Deposit Money" as UC_DepositMoney
  usecase "Pay Bill" as UC_PayBill
}
A --> UC_ViewStatement
A --> UC_PayBill
A --> UC_DepositMoney
A1 --> UC_PayBill
A1 --> UC_ApplyForLoan
A1 --> UC_ViewStatement
BM --> UC_ViewStatement
BM --> UC_ApplyForLoan
BT --> UC_PayBill
BT --> UC_BlockCard
BT --> UC_ViewStatement
UC_ApplyForLoan ..|> UC_BlockCard : <<extend>>
@enduml