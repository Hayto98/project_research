@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
left to right direction
actor "Auditor" as Auditor
actor "ATM" as ATM
actor "Branch Manager" as BranchManager
actor "Bank Teller" as BankTeller
rectangle "Banking System" {
  usecase "View Statement" as UC_ViewStatement
  usecase "Apply For Loan" as UC_ApplyForLoan
  usecase "Block Card" as UC_BlockCard
  usecase "Deposit Money" as UC_DepositMoney
  usecase "Pay Bill" as UC_PayBill
}
Auditor --> UC_ViewStatement
Auditor --> UC_PayBill
Auditor --> UC_DepositMoney
ATM --> UC_PayBill
ATM --> UC_ApplyForLoan
ATM --> UC_ViewStatement
BranchManager --> UC_ViewStatement
BranchManager --> UC_ApplyForLoan
BankTeller --> UC_PayBill
BankTeller --> UC_BlockCard
BankTeller --> UC_ViewStatement
UC_ApplyForLoan ..|> UC_BlockCard : <<extend>>
@enduml