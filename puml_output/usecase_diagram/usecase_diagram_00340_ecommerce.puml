@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
left to right direction
actor "Delivery Service" as DS
actor "Customer" as C
actor "Admin" as A
actor "Seller" as S
rectangle "Ecommerce System" {
  usecase "Manage Inventory" as UC_ManageInventory
  usecase "Make Payment" as UC_MakePayment
  usecase "Write Review" as UC_WriteReview
  usecase "Browse Products" as UC_BrowseProducts
  usecase "Checkout" as UC_Checkout
}
DS --> UC_WriteReview
DS --> UC_ManageInventory
DS --> UC_BrowseProducts
C --> UC_ManageInventory
C --> UC_WriteReview
C --> UC_BrowseProducts
A --> UC_ManageInventory
A --> UC_BrowseProducts
A --> UC_WriteReview
S --> UC_BrowseProducts
S --> UC_MakePayment
S --> UC_Checkout
@enduml