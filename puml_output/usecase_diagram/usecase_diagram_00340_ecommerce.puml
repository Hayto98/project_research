@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
left to right direction
actor "Delivery Service" as DeliveryService
actor "Customer" as Customer
actor "Admin" as Admin
actor "Seller" as Seller
rectangle "Ecommerce System" {
  usecase "Manage Inventory" as UC_ManageInventory
  usecase "Make Payment" as UC_MakePayment
  usecase "Write Review" as UC_WriteReview
  usecase "Browse Products" as UC_BrowseProducts
  usecase "Checkout" as UC_Checkout
}
DeliveryService --> UC_WriteReview
DeliveryService --> UC_ManageInventory
DeliveryService --> UC_BrowseProducts
Customer --> UC_ManageInventory
Customer --> UC_WriteReview
Customer --> UC_BrowseProducts
Admin --> UC_ManageInventory
Admin --> UC_BrowseProducts
Admin --> UC_WriteReview
Seller --> UC_BrowseProducts
Seller --> UC_MakePayment
Seller --> UC_Checkout
@enduml