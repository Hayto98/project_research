@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
left to right direction
actor "Seller" as S
actor "Payment Gateway" as PG
actor "Customer" as C
actor "Admin" as A
rectangle "Ecommerce System" {
  usecase "Apply Coupon" as UC_ApplyCoupon
  usecase "Track Order" as UC_TrackOrder
  usecase "Manage Inventory" as UC_ManageInventory
  usecase "Checkout" as UC_Checkout
  usecase "Write Review" as UC_WriteReview
}
S --> UC_WriteReview
S --> UC_TrackOrder
S --> UC_ManageInventory
PG --> UC_WriteReview
PG --> UC_ManageInventory
C --> UC_WriteReview
C --> UC_ApplyCoupon
C --> UC_TrackOrder
A --> UC_WriteReview
UC_ManageInventory ..|> UC_ApplyCoupon : <<extend>>
@enduml