@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
left to right direction
actor "Seller" as Seller
actor "Payment Gateway" as PaymentGateway
actor "Customer" as Customer
actor "Admin" as Admin
rectangle "Ecommerce System" {
  usecase "Apply Coupon" as UC_ApplyCoupon
  usecase "Track Order" as UC_TrackOrder
  usecase "Manage Inventory" as UC_ManageInventory
  usecase "Checkout" as UC_Checkout
  usecase "Write Review" as UC_WriteReview
}
Seller --> UC_WriteReview
Seller --> UC_TrackOrder
Seller --> UC_ManageInventory
PaymentGateway --> UC_WriteReview
PaymentGateway --> UC_ManageInventory
Customer --> UC_WriteReview
Customer --> UC_ApplyCoupon
Customer --> UC_TrackOrder
Admin --> UC_WriteReview
UC_ManageInventory ..|> UC_ApplyCoupon : <<extend>>
@enduml