@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
left to right direction
actor "Customer" as C
actor "Seller" as S
actor "Payment Gateway" as PG
actor "Admin" as A
rectangle "Ecommerce System" {
  usecase "Browse Products" as UC_BrowseProducts
  usecase "Manage Inventory" as UC_ManageInventory
  usecase "Write Review" as UC_WriteReview
  usecase "Add To Cart" as UC_AddToCart
  usecase "Track Order" as UC_TrackOrder
}
C --> UC_BrowseProducts
S --> UC_WriteReview
PG --> UC_WriteReview
PG --> UC_ManageInventory
A --> UC_BrowseProducts
A --> UC_TrackOrder
UC_ManageInventory ..|> UC_AddToCart : <<include>>
@enduml