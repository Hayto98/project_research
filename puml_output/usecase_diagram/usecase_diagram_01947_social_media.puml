@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
left to right direction
actor "Admin" as A
actor "User" as U
actor "Moderator" as M
rectangle "Social Media System" {
  usecase "Edit Profile" as UC_EditProfile
  usecase "Report Content" as UC_ReportContent
  usecase "Like Post" as UC_LikePost
  usecase "Comment" as UC_Comment
  usecase "Follow User" as UC_FollowUser
}
A --> UC_LikePost
U --> UC_FollowUser
U --> UC_EditProfile
U --> UC_ReportContent
M --> UC_LikePost
M --> UC_ReportContent
M --> UC_EditProfile
UC_LikePost ..> UC_EditProfile : <<extend>>
@enduml