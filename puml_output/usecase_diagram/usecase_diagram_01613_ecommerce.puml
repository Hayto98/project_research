@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
left to right direction
actor "Seller" as S
actor "Admin" as A
actor "Customer" as C
actor "Payment Gateway" as PG
rectangle "Ecommerce System" {
  usecase "Browse Products" as UC_BrowseProducts
  usecase "Apply Coupon" as UC_ApplyCoupon
  usecase "Track Order" as UC_TrackOrder
  usecase "Checkout" as UC_Checkout
  usecase "Manage Inventory" as UC_ManageInventory
  usecase "Make Payment" as UC_MakePayment
}
S --> UC_BrowseProducts
S --> UC_TrackOrder
S --> UC_ApplyCoupon
A --> UC_ManageInventory
C --> UC_ApplyCoupon
C --> UC_BrowseProducts
PG --> UC_ManageInventory
PG --> UC_ApplyCoupon
@enduml