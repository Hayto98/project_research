@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
left to right direction
actor "Admin" as A
actor "Librarian" as L
actor "Member" as M
rectangle "Library System" {
  usecase "Renew Loan" as UC_RenewLoan
  usecase "Add New Book" as UC_AddNewBook
  usecase "Reserve Book" as UC_ReserveBook
  usecase "Register Member" as UC_RegisterMember
  usecase "Return Book" as UC_ReturnBook
}
A --> UC_ReturnBook
A --> UC_RegisterMember
L --> UC_RegisterMember
L --> UC_ReserveBook
L --> UC_AddNewBook
M --> UC_RenewLoan
M --> UC_RegisterMember
M --> UC_ReturnBook
@enduml