@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
left to right direction
actor "Receptionist" as Receptionist
actor "Housekeeper" as Housekeeper
rectangle "Hotel System" {
  usecase "Order Room Service" as UC_OrderRoomService
  usecase "Check Out" as UC_CheckOut
  usecase "Process Payment" as UC_ProcessPayment
  usecase "Clean Room" as UC_CleanRoom
  usecase "Book Room" as UC_BookRoom
  usecase "Request Service" as UC_RequestService
}
Receptionist --> UC_RequestService
Receptionist --> UC_ProcessPayment
Receptionist --> UC_CheckOut
Housekeeper --> UC_OrderRoomService
Housekeeper --> UC_ProcessPayment
Housekeeper --> UC_CleanRoom
@enduml