@startuml
skinparam monochrome true
skinparam shadowing true
left to right direction
actor "Librarian" as L
actor "Parent" as P
actor "Student" as S
actor "Teacher" as T
rectangle "Education System" {
  usecase "Issue Certificate" as UC_IssueCertificate
  usecase "Enroll Course" as UC_EnrollCourse
  usecase "Borrow Book" as UC_BorrowBook
  usecase "Submit Assignment" as UC_SubmitAssignment
  usecase "Take Attendance" as UC_TakeAttendance
}
L --> UC_EnrollCourse
L --> UC_BorrowBook
L --> UC_SubmitAssignment
P --> UC_TakeAttendance
S --> UC_IssueCertificate
T --> UC_EnrollCourse
T --> UC_SubmitAssignment
UC_BorrowBook ..> UC_SubmitAssignment : <<extend>>
@enduml