@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
left to right direction
actor "Customer" as C
actor "Fleet Manager" as FM
actor "Warehouse Staff" as WS
rectangle "Logistics System" {
  usecase "Track Shipment" as UC_TrackShipment
  usecase "Deliver Package" as UC_DeliverPackage
  usecase "Fuel Vehicle" as UC_FuelVehicle
  usecase "Report Issue" as UC_ReportIssue
  usecase "Update Inventory" as UC_UpdateInventory
  usecase "Assign Route" as UC_AssignRoute
}
C --> UC_AssignRoute
C --> UC_ReportIssue
C --> UC_DeliverPackage
FM --> UC_FuelVehicle
FM --> UC_TrackShipment
FM --> UC_DeliverPackage
WS --> UC_UpdateInventory
WS --> UC_ReportIssue
@enduml