@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
left to right direction
actor "Branch Manager" as BM
actor "Account Holder" as AH
actor "Auditor" as A
actor "Bank Teller" as BT
rectangle "Banking System" {
  usecase "Withdraw Cash" as UC_WithdrawCash
  usecase "Block Card" as UC_BlockCard
  usecase "Transfer Funds" as UC_TransferFunds
  usecase "Deposit Money" as UC_DepositMoney
  usecase "Pay Bill" as UC_PayBill
  usecase "View Statement" as UC_ViewStatement
  usecase "Open Account" as UC_OpenAccount
}
BM --> UC_ViewStatement
AH --> UC_BlockCard
A --> UC_ViewStatement
BT --> UC_WithdrawCash
UC_ViewStatement ..> UC_BlockCard : <<include>>
@enduml