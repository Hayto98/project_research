@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
left to right direction
actor "Delivery Service" as DS
actor "Customer" as C
actor "Admin" as A
actor "Seller" as S
rectangle "Ecommerce System" {
  usecase "Add To Cart" as UC_AddToCart
  usecase "Checkout" as UC_Checkout
  usecase "Make Payment" as UC_MakePayment
  usecase "Write Review" as UC_WriteReview
  usecase "Apply Coupon" as UC_ApplyCoupon
}
DS --> UC_WriteReview
C --> UC_AddToCart
A --> UC_ApplyCoupon
A --> UC_Checkout
S --> UC_AddToCart
UC_MakePayment ..|> UC_Checkout : <<extend>>
@enduml