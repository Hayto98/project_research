@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
left to right direction
actor "Admin" as A
actor "Librarian" as L
actor "Student" as S
actor "Parent" as P
rectangle "Education System" {
  usecase "Take Attendance" as UC_TakeAttendance
  usecase "Borrow Book" as UC_BorrowBook
  usecase "Issue Certificate" as UC_IssueCertificate
  usecase "Grade Exam" as UC_GradeExam
  usecase "Enroll Course" as UC_EnrollCourse
}
A --> UC_BorrowBook
A --> UC_EnrollCourse
L --> UC_BorrowBook
L --> UC_IssueCertificate
L --> UC_EnrollCourse
S --> UC_TakeAttendance
S --> UC_GradeExam
S --> UC_BorrowBook
P --> UC_GradeExam
P --> UC_EnrollCourse
P --> UC_TakeAttendance
@enduml