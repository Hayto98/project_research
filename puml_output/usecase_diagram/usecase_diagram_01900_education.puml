@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
left to right direction
actor "Registrar" as R
actor "Parent" as P
actor "Student" as S
actor "Librarian" as L
rectangle "Education System" {
  usecase "Take Attendance" as UC_TakeAttendance
  usecase "View Schedule" as UC_ViewSchedule
  usecase "Enroll Course" as UC_EnrollCourse
  usecase "Issue Certificate" as UC_IssueCertificate
  usecase "Submit Assignment" as UC_SubmitAssignment
  usecase "Register Student" as UC_RegisterStudent
  usecase "Grade Exam" as UC_GradeExam
  usecase "Borrow Book" as UC_BorrowBook
}
R --> UC_BorrowBook
R --> UC_ViewSchedule
P --> UC_IssueCertificate
P --> UC_RegisterStudent
S --> UC_GradeExam
S --> UC_TakeAttendance
S --> UC_EnrollCourse
L --> UC_RegisterStudent
@enduml