@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
left to right direction
actor "Admin" as Admin
actor "User" as User
actor "Moderator" as Moderator
actor "Advertiser" as Advertiser
rectangle "Social Media System" {
  usecase "Follow User" as UC_FollowUser
  usecase "Edit Profile" as UC_EditProfile
  usecase "Send Message" as UC_SendMessage
  usecase "Like Post" as UC_LikePost
  usecase "Report Content" as UC_ReportContent
  usecase "Create Post" as UC_CreatePost
  usecase "Share Post" as UC_SharePost
}
Admin --> UC_EditProfile
Admin --> UC_SharePost
User --> UC_ReportContent
Moderator --> UC_SharePost
Advertiser --> UC_SharePost
UC_ReportContent ..|> UC_LikePost : <<extend>>
@enduml