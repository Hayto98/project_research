@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
left to right direction
actor "Customer" as C
actor "Warehouse Staff" as WS
actor "Driver" as D
actor "Dispatcher" as D1
rectangle "Logistics System" {
  usecase "Load Package" as UC_LoadPackage
  usecase "Assign Route" as UC_AssignRoute
  usecase "Schedule Pickup" as UC_SchedulePickup
  usecase "Fuel Vehicle" as UC_FuelVehicle
  usecase "Report Issue" as UC_ReportIssue
}
C --> UC_SchedulePickup
WS --> UC_SchedulePickup
WS --> UC_ReportIssue
D --> UC_LoadPackage
D --> UC_ReportIssue
D --> UC_FuelVehicle
D1 --> UC_AssignRoute
D1 --> UC_LoadPackage
D1 --> UC_SchedulePickup
UC_FuelVehicle ..|> UC_LoadPackage : <<include>>
@enduml