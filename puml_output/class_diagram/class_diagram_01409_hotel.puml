@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Room {
  #float score
  -String amount
  -double type
  +saveId()
  +deletePrice()
}
class Service {
  -String status
  +String quantity
  +String name
  #String total
  -String createdAt
  +getEmail()
}
class Payment {
  -double duration
  #Date price
  +long status
  -long updatedAt
  +int type
  +setName()
}
class Reservation {
  +float address
  +Date type
  #float score
  +boolean createdAt
  +int email
  +findPrice()
  +deleteAmount()
  +setPhone()
  +setTotal()
}
class Staff {
  -double amount
  -double score
  #boolean duration
  #boolean active
  +String updatedAt
  +sendAddress()
  +setLevel()
  +createAddress()
  +createScore()
}
class Booking {
  -float active
  -String code
  -String email
  +saveUpdatedat()
}
abstract class Guest {
  #Date id
  -String amount
  -int name
  +boolean score
  +saveLevel()
  +sendAddress()
  +saveCode()
  +processAddress()
}
Service --> Payment : "1"
Booking --o Room
Booking --o Reservation
note right of Room : Hotel domain
@enduml