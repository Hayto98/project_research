@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Room {
  #float score
  -String amount
  -double type
  +calculateTotal()
  +deleteTotal()
}
class Service {
  +long price
  +double id
  #int duration
  +cancelEmail()
  +setName()
  +getLevel()
}
class Payment {
  +String name
  +long type
  +updateCode()
}
abstract class Reservation {
  #Date status
  +long updatedAt
  -long type
  +int score
  +String total
  +saveId()
}
abstract class Staff {
  +float type
  +Date score
  #float createdAt
  +boolean email
  +findPhone()
}
abstract class Booking {
  -String description
  #Date amount
  -Date status
  +float phone
  #int code
  +processTotal()
  +cancelQuantity()
}
class Guest {
  -boolean active
  -String score
  #boolean level
  -long amount
  -boolean status
  +deleteScore()
  +createUpdatedat()
  +getLevel()
}
Reservation --|> Guest
Payment --|> Room
Booking ..> Service : "*"
@enduml