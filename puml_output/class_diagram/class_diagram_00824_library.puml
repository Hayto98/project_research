@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Loan {
  +boolean updatedAt
  -float type
  #boolean duration
  +double address
  #double amount
  +updateDuration()
  +calculateName()
}
interface Publisher {
  -boolean createdAt
  +Date quantity
  +cancelPhone()
}
interface Reservation {
  -double updatedAt
  +String code
  +double name
  +Date level
  -int quantity
  +sendScore()
  +updatePrice()
}
abstract class Book {
  -double description
  +boolean name
  #Date level
  #boolean type
  +findAmount()
  +validateUpdatedat()
  +sendCreatedat()
}
class Author {
  +int active
  #int id
  #float quantity
  +double amount
  -int score
  +processPrice()
  +getLevel()
  +setType()
}
abstract class Fine {
  #String total
  -float id
  -int phone
  -String code
  -float level
  +updateCode()
  +sendPhone()
}
Reservation ..|> Fine
Author --> Loan : "0..1"
Reservation --|> Book
note right of Loan : Library domain
@enduml