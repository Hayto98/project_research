@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Loan {
  +boolean updatedAt
  -float type
  #boolean duration
  +double address
  #double amount
  +getDescription()
  +sendEmail()
}
interface Publisher {
  #int name
  #Date status
  #float createdAt
  #String quantity
  #long type
  +setCode()
  +setQuantity()
  +deleteAddress()
  +cancelStatus()
}
class Reservation {
  -int quantity
  +String address
  +validateEmail()
  +cancelUpdatedat()
  +cancelQuantity()
  +saveNote()
}
class Book {
  +String price
  +double total
  -double quantity
  +deleteDescription()
  +setId()
}
interface Author {
  +long amount
  #double phone
  #float updatedAt
  +long active
  +calculatePhone()
  +saveNote()
}
class Fine {
  -int duration
  #long updatedAt
  -double price
  +processId()
}
Book --o Fine
Book --* Loan
@enduml