@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Shelf {
  -float total
  -String duration
  +cancelType()
  +calculateAddress()
  +findQuantity()
}
class Book {
  #Date duration
  +float quantity
  #boolean type
  -boolean createdAt
  +processPrice()
}
class Publisher {
  #long amount
  +Date quantity
  #double id
  +validateEmail()
}
class Member {
  #double note
  #double updatedAt
  +double active
  #int description
  +cancelActive()
}
Shelf --o Book
Member --o Publisher
Shelf --* Publisher
note right of Shelf : Library domain
@enduml