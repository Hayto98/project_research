@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Shelf {
  -float total
  -String duration
  +sendActive()
  +getPrice()
  +findActive()
}
abstract class Book {
  -int quantity
  #Date amount
  +float email
  #boolean duration
  +calculateDuration()
  +setCode()
  +sendTotal()
}
abstract class Publisher {
  #long createdAt
  +Date description
  #double amount
  +long quantity
  -Date id
  +validatePrice()
}
class Member {
  #double updatedAt
  +double level
  #int active
  +float description
  #boolean note
  +validateId()
  +cancelCreatedat()
  +updateAmount()
  +deleteAmount()
}
Member ..> Shelf : "1..*"
Member --o Publisher
Shelf --o Publisher
@enduml