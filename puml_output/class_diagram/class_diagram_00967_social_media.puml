@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Post {
  +boolean duration
  #Date email
  +String address
  #long name
  +int active
  +setId()
}
class Comment {
  -boolean active
  #long createdAt
  -Date type
  +deleteTotal()
}
class Story {
  #double description
  #float score
  #double email
  +float note
  -long status
  +updateScore()
  +processTotal()
  +createType()
}
class Message {
  +int price
  -double updatedAt
  #int email
  +String name
  +deleteQuantity()
  +deleteAmount()
}
Post --* Comment
Comment ..> Message : "*"
Message ..|> Story
@enduml