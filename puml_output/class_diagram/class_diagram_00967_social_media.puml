@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Post {
  +boolean duration
  #Date email
  +String address
  #long name
  +int active
  +cancelStatus()
}
class Comment {
  #long type
  -Date email
  +float score
  +calculateDescription()
  +sendEmail()
  +processStatus()
}
abstract class Story {
  #float createdAt
  -long total
  -int address
  -String score
  +int note
  +processAmount()
  +getId()
  +updateStatus()
  +calculatePrice()
}
class Message {
  #double quantity
  -Date score
  +String updatedAt
  +boolean total
  +calculateActive()
  +setDescription()
  +createCreatedat()
  +saveId()
}
Story --|> Post
Post --|> Comment
Story --o Message
note right of Post : Social Media domain
@enduml