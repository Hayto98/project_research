@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
interface Driver {
  -boolean code
  #Date amount
  #String total
  +float name
  +String score
  +validateScore()
  +setCode()
}
class Vehicle {
  +double active
  -Date createdAt
  #long score
  #boolean description
  +getTotal()
}
interface Depot {
  #Date updatedAt
  #String email
  +boolean id
  -float description
  +createDescription()
  +cancelAddress()
  +createPhone()
}
class Tracking {
  +float description
  #boolean quantity
  +findCreatedat()
  +cancelName()
  +createType()
}
class Customer {
  +double active
  +int name
  #double address
  +long createdAt
  #String status
  +createAmount()
  +createName()
  +updateNote()
}
class Route {
  #long createdAt
  +double total
  +int score
  +setStatus()
  +updateLevel()
  +updatePhone()
}
Route --> Tracking : "1"
Depot ..> Driver : "*"
Driver ..|> Tracking
note right of Driver : Logistics domain
@enduml