@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
interface Driver {
  -boolean code
  #Date amount
  #String total
  +float name
  +String score
  +validateScore()
  +getDuration()
}
interface Vehicle {
  -boolean code
  +boolean amount
  +createNote()
  +findType()
}
class Depot {
  #boolean total
  -int phone
  -String code
  #int name
  #Date duration
  +sendId()
}
interface Tracking {
  -Date address
  -long quantity
  #String description
  +long duration
  +updateCreatedat()
}
interface Customer {
  #double createdAt
  +boolean level
  -boolean name
  +long email
  +deleteId()
  +updateUpdatedat()
}
class Route {
  #String status
  -float description
  -int total
  -String createdAt
  +double quantity
  +deleteTotal()
}
Vehicle ..> Tracking : "1..*"
Driver --|> Tracking
Vehicle ..> Customer : "1..*"
@enduml