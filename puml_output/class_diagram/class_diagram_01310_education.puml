@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
abstract class Schedule {
  +int duration
  -Date description
  +validateScore()
}
abstract class Book {
  +double score
  #Date price
  +float note
  +int id
  -float updatedAt
  +findCreatedat()
}
interface Exam {
  +int price
  #Date quantity
  -double active
  #double total
  +int status
  +findCode()
  +findPhone()
  +sendAmount()
  +saveNote()
}
abstract class Classroom {
  -long description
  +double createdAt
  +deleteUpdatedat()
  +sendCreatedat()
  +saveActive()
}
abstract class Student {
  +float total
  #Date phone
  +String duration
  #int quantity
  +boolean description
  +sendId()
}
class Attendance {
  +float total
  -Date createdAt
  +int active
  #String address
  #float amount
  +savePrice()
  +deleteLevel()
  +setActive()
  +calculateTotal()
}
Attendance --> Schedule : "1"
Book ..> Student : "1..*"
Exam ..|> Student
Attendance --o Book
@enduml