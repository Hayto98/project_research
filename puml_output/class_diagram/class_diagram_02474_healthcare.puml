@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
interface Patient {
  -float active
  -int status
  #float description
  -double duration
  #Date level
  +createUpdatedat()
  +sendDescription()
}
class Diagnosis {
  -long status
  +long score
  -String phone
  +getQuantity()
  +createId()
}
interface Ward {
  +boolean note
  #long level
  #float code
  +validateEmail()
  +saveStatus()
  +deleteQuantity()
  +setScore()
}
class Treatment {
  -float email
  +float total
  #long address
  +Date description
  +setActive()
  +findAddress()
}
abstract class Hospital {
  +long description
  #int quantity
  +createDuration()
}
Treatment ..> Patient : "1"
Ward --> Hospital : "1..*"
@enduml