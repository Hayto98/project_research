@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
interface Patient {
  -float active
  -int status
  #float description
  -double duration
  #Date level
  +sendDescription()
  +deleteStatus()
}
interface Diagnosis {
  -String type
  +boolean address
  #int id
  -boolean phone
  +deleteLevel()
}
class Ward {
  -Date status
  -Date duration
  #int quantity
  -float email
  +float active
  +setLevel()
  +deleteUpdatedat()
  +processCode()
}
class Treatment {
  #float createdAt
  +double quantity
  +double score
  +Date amount
  +createAddress()
}
interface Hospital {
  -String description
  +int status
  -double name
  +float level
  +cancelTotal()
}
Ward ..> Diagnosis : "1..*"
Ward --* Treatment
note right of Patient : Healthcare domain
@enduml