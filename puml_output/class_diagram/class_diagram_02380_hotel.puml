@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Guest {
  #String note
  -Date id
  +String name
  +int code
  +sendTotal()
}
abstract class Payment {
  -int description
  +long updatedAt
  +deletePrice()
  +setName()
  +calculateLevel()
}
class Room {
  -double quantity
  +Date amount
  +long updatedAt
  +sendNote()
  +validateId()
  +getUpdatedat()
}
interface Restaurant {
  -float total
  #Date note
  #String phone
  #int score
  -long code
  +createId()
}
class CheckOut {
  +int quantity
  +String address
  -float note
  +setName()
}
class Amenity {
  #double address
  -String name
  -double quantity
  +int total
  +saveNote()
  +processAmount()
}
class Booking {
  #boolean note
  #long type
  -int price
  +processDescription()
  +getActive()
  +processScore()
}
Guest --* Payment
Guest ..|> Booking
note right of Guest : Hotel domain
@enduml