@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Guest {
  #String note
  -Date id
  +String name
  +int code
  +sendAmount()
}
abstract class Payment {
  +long name
  #long description
  +double updatedAt
  +float address
  +double createdAt
  +validateQuantity()
  +calculatePhone()
  +calculateAddress()
}
class Room {
  #long note
  #double updatedAt
  -String description
  +int email
  +updateEmail()
  +validateStatus()
  +saveAmount()
  +cancelActive()
}
class Restaurant {
  #boolean level
  +Date code
  +long phone
  -String active
  +updateDuration()
  +cancelPhone()
  +updateDescription()
}
class CheckOut {
  +double note
  +String status
  +String description
  -Date updatedAt
  +setUpdatedat()
  +updateLevel()
  +updateEmail()
}
interface Amenity {
  +int note
  #double name
  -float price
  +String score
  +double code
  +processScore()
  +saveName()
  +saveActive()
  +saveTotal()
}
interface Booking {
  +String type
  #double amount
  #String address
  +int note
  +getType()
  +processPhone()
  +cancelEmail()
}
Room ..> Guest : "1"
Booking ..|> Payment
Guest ..|> Booking
@enduml