@startuml
skinparam monochrome true
skinparam ArrowColor #555555
interface Customer {
  #boolean email
  +Date address
  #Date total
  #long phone
  +sendNote()
  +processId()
  +cancelEmail()
}
class Manifest {
  +float quantity
  -long level
  +processPhone()
  +deleteLevel()
  +validateDuration()
}
class Package {
  +Date code
  +String address
  +sendQuantity()
  +validateCode()
  +cancelDescription()
  +savePrice()
}
interface Vehicle {
  +String score
  +long level
  #boolean id
  +updateCode()
  +sendAddress()
}
class Inventory {
  +Date email
  #String createdAt
  +long id
  +saveQuantity()
  +calculateNote()
  +createId()
  +sendId()
}
Vehicle --|> Inventory
Customer --* Package
Customer --> Vehicle : "1..*"
note right of Customer : Logistics domain
@enduml