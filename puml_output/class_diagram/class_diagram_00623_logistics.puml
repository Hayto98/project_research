@startuml
skinparam monochrome true
skinparam ArrowColor #555555
interface Customer {
  #boolean email
  +Date address
  #Date total
  #long phone
  +getDescription()
  +calculateDuration()
  +deleteDuration()
}
abstract class Manifest {
  +String level
  -boolean email
  +getDescription()
}
class Package {
  #long phone
  #long type
  +String duration
  -int description
  +saveTotal()
}
class Vehicle {
  #Date active
  -boolean quantity
  #boolean phone
  +boolean code
  #String description
  +getType()
}
class Inventory {
  #long level
  +int amount
  -float updatedAt
  +String code
  +findStatus()
  +findUpdatedat()
}
Manifest --> Package : "*"
Package --o Vehicle
@enduml