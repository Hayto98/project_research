@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Cart {
  +int quantity
  +double name
  +updateQuantity()
}
interface Coupon {
  -Date note
  +float address
  +float createdAt
  +float code
  +findUpdatedat()
  +processPrice()
  +getCode()
}
class Invoice {
  #String description
  +Date updatedAt
  +cancelId()
  +findCreatedat()
  +cancelType()
}
abstract class Wishlist {
  -int id
  -Date type
  +deleteStatus()
  +setEmail()
  +findQuantity()
}
class Category {
  +boolean createdAt
  -Date level
  +cancelDuration()
  +setTotal()
  +setId()
  +cancelType()
}
Cart ..> Invoice : "*"
Coupon ..|> Wishlist
Invoice --|> Cart
@enduml