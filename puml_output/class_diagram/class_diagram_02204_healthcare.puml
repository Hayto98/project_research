@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Ward {
  +long total
  +int status
  #boolean level
  +float updatedAt
  +long name
  +deleteQuantity()
  +findActive()
  +updatePrice()
  +deleteAmount()
}
class Hospital {
  -long level
  +float createdAt
  #int type
  #Date updatedAt
  +boolean score
  +sendActive()
  +cancelUpdatedat()
  +findStatus()
  +calculateStatus()
}
interface Nurse {
  -float price
  #Date active
  -float updatedAt
  +validateStatus()
  +cancelDuration()
}
interface Prescription {
  #long quantity
  +int duration
  #double type
  -long email
  +validateTotal()
  +setPrice()
  +calculateNote()
  +cancelLevel()
}
class Patient {
  +float note
  -Date phone
  +getTotal()
  +updateAddress()
}
abstract class Doctor {
  #float code
  -double id
  +boolean quantity
  +validateNote()
  +saveCode()
  +saveNote()
}
class MedicalRecord {
  #String description
  #long level
  #int email
  +setDuration()
  +getTotal()
}
Ward --|> Hospital
Doctor --* MedicalRecord
@enduml