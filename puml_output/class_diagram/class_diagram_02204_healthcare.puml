@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Ward {
  +long total
  +int status
  #boolean level
  +float updatedAt
  +long name
  +setType()
  +getPrice()
  +setType()
  +cancelCreatedat()
}
abstract class Hospital {
  -String level
  #int type
  #Date address
  +cancelNote()
  +cancelLevel()
}
class Nurse {
  #float active
  #long updatedAt
  -long type
  -long score
  #long level
  +deleteLevel()
  +calculateType()
}
class Prescription {
  +float createdAt
  -Date phone
  +int id
  #double note
  #Date level
  +setId()
  +createNote()
}
abstract class Patient {
  -int duration
  -int active
  +findUpdatedat()
  +deleteLevel()
}
class Doctor {
  #int level
  +int address
  +setUpdatedat()
}
class MedicalRecord {
  +String type
  +boolean email
  +String address
  +String total
  +createNote()
  +getStatus()
  +setDescription()
  +setScore()
}
Nurse --o Prescription
Prescription ..|> Ward
MedicalRecord --|> Ward
Hospital ..> Patient : "0..1"
Patient ..> Doctor : "0..1"
MedicalRecord ..|> Doctor
note right of Ward : Healthcare domain
@enduml