@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
abstract class CheckOut {
  -double price
  -double phone
  +Date duration
  #float name
  +boolean active
  +deleteActive()
  +cancelActive()
}
class Amenity {
  #long amount
  #boolean email
  #Date createdAt
  -long id
  +deleteCreatedat()
  +validateStatus()
  +cancelAmount()
  +updateAddress()
}
class Reservation {
  #float description
  -float note
  +int quantity
  -int duration
  +processName()
}
class Restaurant {
  +double code
  -Date phone
  #float price
  +double total
  #Date address
  +saveId()
  +deleteNote()
}
abstract class Staff {
  -boolean id
  +double createdAt
  +boolean price
  +validateDescription()
}
interface Booking {
  -Date email
  -boolean type
  +String note
  +sendName()
  +createTotal()
}
Amenity --o Restaurant
CheckOut ..|> Staff
@enduml