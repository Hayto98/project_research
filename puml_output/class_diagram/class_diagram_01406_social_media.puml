@startuml
skinparam defaultFontSize 13
class Hashtag {
  +long phone
  -Date active
  +createLevel()
  +createId()
  +setDuration()
  +deleteCode()
}
class Follower {
  #float level
  #long address
  #Date price
  #boolean description
  +setPhone()
  +createDuration()
}
class Album {
  -int level
  +int type
  +saveAmount()
}
interface Profile {
  +int total
  +float createdAt
  #boolean quantity
  +boolean status
  #float id
  +validateStatus()
  +validateAmount()
  +createDescription()
  +getCreatedat()
}
class Report {
  -Date status
  +float phone
  -boolean address
  +calculateName()
  +calculateAmount()
  +createPhone()
}
class Like {
  -String score
  -Date createdAt
  #double status
  #float id
  +setDescription()
  +cancelDuration()
  +setStatus()
  +deleteAddress()
}
Like --* Follower
Album ..|> Like
Like --o Profile
Like ..|> Album
Album --> Follower : "1..*"
note right of Hashtag : Social Media domain
@enduml