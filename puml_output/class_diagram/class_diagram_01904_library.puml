@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Loan {
  -Date level
  -double note
  +updateAmount()
  +saveQuantity()
}
class Book {
  +double code
  #int status
  +double phone
  +saveDuration()
  +calculateDuration()
  +getTotal()
}
interface Publisher {
  +String duration
  #boolean active
  #int quantity
  +long level
  -long code
  +calculateAmount()
}
interface Member {
  -int name
  -double active
  +sendStatus()
  +getId()
  +findId()
}
Book --o Publisher
Member ..|> Book
note right of Loan : Library domain
@enduml