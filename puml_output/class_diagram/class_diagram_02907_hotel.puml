@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Invoice {
  -long level
  +int type
  #int name
  #long email
  +updateLevel()
}
class Guest {
  +double updatedAt
  -float phone
  #int active
  #int email
  +int amount
  +cancelTotal()
}
abstract class Amenity {
  -String name
  -long score
  -float level
  +long total
  #float description
  +sendCode()
  +updateLevel()
  +calculateLevel()
}
interface Room {
  +long active
  -float email
  #boolean phone
  #boolean amount
  +cancelType()
}
class Housekeeping {
  -long quantity
  #float score
  #String updatedAt
  +saveEmail()
}
class CheckIn {
  #boolean createdAt
  #String amount
  #boolean status
  +String address
  +String quantity
  +createUpdatedat()
  +processQuantity()
  +validateUpdatedat()
  +validateName()
}
CheckIn ..> Amenity : "1..*"
CheckIn --|> Housekeeping
Housekeeping --> Invoice : "1..*"
Invoice --o Amenity
@enduml