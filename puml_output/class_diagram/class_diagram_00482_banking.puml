@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Account {
  +float status
  #int email
  +getAddress()
  +setDuration()
}
class Card {
  -double active
  -int status
  +getCreatedat()
}
class Transfer {
  #Date email
  -Date description
  +validateScore()
  +cancelType()
}
class Statement {
  -int duration
  +float type
  +processTotal()
  +getCreatedat()
  +createLevel()
  +setUpdatedat()
}
interface Withdrawal {
  #float total
  +Date phone
  #Date active
  +calculateDuration()
  +getDescription()
}
class Customer {
  +String status
  +boolean createdAt
  +double name
  #int duration
  +getEmail()
  +cancelTotal()
}
Card --* Account
Transfer --* Customer
@enduml