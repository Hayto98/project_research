@startuml
skinparam ArrowColor #555555
class Room {
  -boolean email
  -long score
  +long code
  +boolean duration
  +deleteActive()
}
class Amenity {
  +int total
  #boolean id
  +Date quantity
  -long name
  +int status
  +createNote()
  +saveEmail()
  +validateActive()
  +cancelType()
}
class Service {
  +boolean status
  -double updatedAt
  +int active
  +getCode()
  +findStatus()
}
class CheckIn {
  #Date duration
  +double type
  -long address
  #float createdAt
  #float quantity
  +getQuantity()
  +deleteCreatedat()
  +cancelName()
  +findType()
}
class Restaurant {
  -String duration
  +float active
  -int name
  #String status
  +createType()
  +findId()
  +deleteUpdatedat()
  +createType()
}
class Staff {
  #boolean id
  #long updatedAt
  #Date note
  -int phone
  +setUpdatedat()
  +validateStatus()
  +deleteAmount()
  +saveDescription()
}
Staff ..|> Amenity
Restaurant --|> Service
note right of Room : Hotel domain
@enduml