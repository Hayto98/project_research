@startuml
skinparam ArrowColor #555555
class Room {
  -boolean email
  -long score
  +long code
  +boolean duration
  +findId()
}
interface Amenity {
  -String note
  +int total
  +float id
  +setCreatedat()
}
abstract class Service {
  #double status
  #long createdAt
  -boolean type
  #double email
  +cancelAmount()
  +createScore()
}
class CheckIn {
  -double active
  +int name
  +String duration
  +createNote()
}
class Restaurant {
  -int price
  -boolean type
  +calculateQuantity()
  +findQuantity()
}
class Staff {
  #double name
  +long quantity
  #boolean description
  #String createdAt
  #Date duration
  +processScore()
}
Room --o Amenity
Amenity --|> Restaurant
CheckIn --o Service
Staff ..|> Room
Staff --* Amenity
@enduml