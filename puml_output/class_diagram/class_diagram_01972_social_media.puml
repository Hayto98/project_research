@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
interface Comment {
  -String status
  -boolean duration
  -int active
  -boolean type
  +double quantity
  +deleteName()
}
abstract class Post {
  +double id
  +long total
  -boolean price
  +createEmail()
  +setLevel()
  +cancelName()
}
class Like {
  #int price
  +long description
  +double email
  -boolean type
  #Date amount
  +getCreatedat()
  +setLevel()
  +updateCreatedat()
}
class Story {
  +String score
  -boolean name
  #boolean total
  #float phone
  #String active
  +deleteEmail()
  +validateCreatedat()
}
Post --* Story
@enduml