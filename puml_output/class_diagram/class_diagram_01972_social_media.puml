@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
interface Comment {
  -String status
  -boolean duration
  -int active
  -boolean type
  +double quantity
  +createPrice()
}
class Post {
  +double total
  +long price
  +cancelLevel()
  +createDescription()
  +findCreatedat()
}
abstract class Like {
  +long description
  +double email
  -boolean type
  #Date amount
  #Date active
  +sendDescription()
  +saveUpdatedat()
  +findTotal()
}
interface Story {
  -String total
  +float phone
  +sendDuration()
  +saveCode()
  +updateDescription()
}
Post --* Story
note right of Comment : Social Media domain
@enduml