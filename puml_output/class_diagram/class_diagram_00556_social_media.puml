@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
abstract class User {
  -float type
  -long total
  +float status
  +createActive()
  +findNote()
}
interface Group {
  -boolean phone
  #long status
  -double address
  +createQuantity()
  +setAmount()
  +sendNote()
  +updateCode()
}
class Comment {
  #float description
  -long score
  #float status
  +saveEmail()
  +cancelEmail()
  +processLevel()
  +createCreatedat()
}
abstract class Notification {
  #float updatedAt
  #boolean score
  +setId()
}
abstract class Story {
  -int total
  -String duration
  +setCode()
  +findType()
  +setAmount()
  +getActive()
}
interface Report {
  -double quantity
  #String phone
  #double id
  -double price
  +boolean status
  +saveStatus()
}
Story --|> User
Comment --> User : "*"
User ..> Comment : "1..*"
Notification ..|> Report
Story --|> Report
note right of User : Social Media domain
@enduml