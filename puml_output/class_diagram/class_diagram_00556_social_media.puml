@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
abstract class User {
  -float type
  -long total
  +float status
  +deleteCreatedat()
  +getStatus()
}
interface Group {
  -boolean active
  #long amount
  -double phone
  #Date status
  -long address
  +setStatus()
  +sendPrice()
  +calculateDescription()
}
class Comment {
  #String updatedAt
  #float code
  -long id
  #float amount
  -Date description
  +setPhone()
  +cancelPhone()
  +sendName()
}
interface Notification {
  +boolean createdAt
  #float total
  #boolean score
  +String id
  +setScore()
}
abstract class Story {
  -int total
  -String duration
  +createAddress()
  +processAmount()
  +createLevel()
  +saveType()
}
abstract class Report {
  #boolean amount
  #float name
  +calculatePhone()
  +saveScore()
  +updateDuration()
  +calculateCode()
}
Notification ..> Report : "1"
Story --o Notification
@enduml