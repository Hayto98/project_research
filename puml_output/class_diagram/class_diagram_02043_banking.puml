@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Loan {
  #String duration
  #double score
  +processPrice()
}
class Customer {
  #double duration
  #String quantity
  -String active
  +Date total
  +processLevel()
  +deleteName()
  +sendAddress()
}
interface Card {
  -double active
  -Date quantity
  #boolean status
  +int duration
  +processUpdatedat()
}
class Branch {
  +int note
  #String status
  -float id
  -Date total
  -Date code
  +findCreatedat()
  +processCreatedat()
}
Card ..> Branch : "*"
Branch ..> Card : "0..1"
Loan --o Branch
@enduml