@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Loan {
  #String duration
  #double score
  +updateEmail()
}
interface Customer {
  #double duration
  #String quantity
  -String active
  +Date total
  +calculateEmail()
  +createEmail()
  +cancelPhone()
}
interface Card {
  -Date status
  #boolean active
  +int price
  #boolean total
  +deleteId()
}
abstract class Branch {
  +boolean status
  +double id
  -Date total
  -Date code
  +long amount
  +createDuration()
  +findLevel()
  +processNote()
}
Loan --o Branch
Branch --* Customer
note right of Loan : Banking domain
@enduml