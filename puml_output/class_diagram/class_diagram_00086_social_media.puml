@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Story {
  #int quantity
  +double amount
  #boolean duration
  -String total
  -String description
  +validatePhone()
  +processPhone()
}
interface Report {
  #long code
  +float price
  +int type
  #Date duration
  #Date createdAt
  +findLevel()
  +deleteScore()
  +cancelUpdatedat()
}
class Album {
  -int description
  -String email
  +boolean id
  +long duration
  -boolean price
  +saveScore()
  +saveDescription()
}
class Follower {
  #boolean status
  -double createdAt
  -String phone
  +String active
  +deleteTotal()
}
Report --* Follower
Story --o Report
note right of Story : Social Media domain
@enduml