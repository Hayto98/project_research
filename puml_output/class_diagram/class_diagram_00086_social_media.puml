@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Story {
  #int quantity
  +double amount
  #boolean duration
  -String total
  -String description
  +validateDuration()
  +cancelId()
}
abstract class Report {
  #double duration
  +int total
  #long code
  +float price
  +setType()
}
interface Album {
  -double level
  +Date amount
  #long score
  +Date updatedAt
  +sendScore()
  +saveName()
}
class Follower {
  -boolean code
  +Date duration
  #float score
  #int createdAt
  +boolean email
  +cancelDescription()
  +validateEmail()
  +updateDescription()
}
Album --* Report
Story --|> Follower
@enduml