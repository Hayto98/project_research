@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
interface Prescription {
  -int description
  #float score
  +updateTotal()
}
class Nurse {
  -String price
  +long active
  +Date email
  -float address
  -long phone
  +sendCreatedat()
  +updateActive()
}
abstract class Patient {
  #Date email
  +boolean active
  +Date amount
  +getAmount()
}
interface Billing {
  -int id
  #String name
  #boolean active
  #int quantity
  +processScore()
  +createDuration()
}
class Doctor {
  +int note
  -String score
  -long name
  +createCreatedat()
  +deleteTotal()
  +processAddress()
  +sendPhone()
}
abstract class Treatment {
  +int type
  -double email
  #float active
  #long level
  -float updatedAt
  +saveNote()
  +cancelQuantity()
  +cancelAmount()
  +cancelActive()
}
Nurse --* Patient
Nurse --|> Doctor
note right of Prescription : Healthcare domain
@enduml