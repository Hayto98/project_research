@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
interface Prescription {
  -int description
  #float score
  +saveLevel()
}
class Nurse {
  -long quantity
  -String note
  +long price
  +Date active
  -float email
  +calculateCreatedat()
  +validateQuantity()
  +findPrice()
}
class Patient {
  +long active
  #Date note
  #int duration
  +saveActive()
  +updateStatus()
}
class Billing {
  #long amount
  +String active
  +createActive()
  +getTotal()
  +processEmail()
}
class Doctor {
  -Date createdAt
  #boolean note
  #Date score
  +cancelActive()
  +processAddress()
}
class Treatment {
  +double score
  -double name
  -int id
  +Date updatedAt
  -double address
  +setAddress()
  +saveScore()
  +deleteAmount()
}
Treatment --* Billing
Treatment --* Doctor
Nurse ..|> Treatment
Billing --> Treatment : "1..*"
@enduml