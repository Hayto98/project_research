@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
abstract class Group {
  -int code
  #long description
  +updateQuantity()
  +createType()
}
class Notification {
  +boolean quantity
  +float name
  +long status
  -double type
  +calculateEmail()
  +getActive()
  +deleteAddress()
}
class Follower {
  -boolean address
  +float phone
  +createDescription()
  +savePrice()
  +updateDescription()
  +sendActive()
}
class Post {
  -long createdAt
  +String phone
  +saveAddress()
}
class Story {
  #double active
  +double price
  #boolean duration
  -boolean address
  -float level
  +processType()
  +saveDuration()
  +validateLevel()
}
class Report {
  #String email
  +Date name
  #long level
  -double price
  +int quantity
  +calculateNote()
  +setLevel()
  +calculateCreatedat()
  +validateDuration()
}
Notification ..|> Report
Story --|> Follower
Notification --|> Follower
Report ..> Follower : "1"
note right of Group : Social Media domain
@enduml