@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
abstract class Group {
  -int code
  #long description
  +processActive()
  +deleteStatus()
}
class Notification {
  +String type
  -String status
  #int phone
  +long quantity
  +cancelCode()
  +sendAddress()
  +createDuration()
}
class Follower {
  -int active
  +float amount
  +createAmount()
  +saveScore()
  +createStatus()
}
class Post {
  #float email
  #int description
  +int price
  -long updatedAt
  -String level
  +sendAmount()
}
class Story {
  #long email
  -boolean total
  -int active
  -float price
  +createDescription()
  +findCode()
  +findLevel()
}
interface Report {
  -long note
  +float type
  +double address
  -Date id
  +setName()
}
Post ..|> Report
Notification --o Post
Post --> Group : "*"
Notification ..> Follower : "1..*"
@enduml