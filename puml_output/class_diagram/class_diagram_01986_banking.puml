@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Deposit {
  -long id
  -int amount
  +updateCreatedat()
  +setAmount()
  +getPrice()
}
interface Statement {
  +String phone
  +String type
  -float amount
  #int note
  +cancelTotal()
  +processAddress()
  +getPrice()
}
class Beneficiary {
  #String amount
  -String createdAt
  #Date total
  +processScore()
  +deleteTotal()
  +setLevel()
}
abstract class Card {
  +float total
  +boolean type
  +float id
  +getPhone()
}
class Interest {
  +double score
  -double active
  -boolean quantity
  -float name
  #int phone
  +createType()
}
class Customer {
  +Date id
  -int email
  +updateActive()
}
Deposit --o Statement
Interest --|> Card
Deposit ..|> Card
Deposit --> Beneficiary : "1..*"
Customer --o Interest
@enduml