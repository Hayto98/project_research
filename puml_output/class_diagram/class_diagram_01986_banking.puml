@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Deposit {
  -long id
  -int amount
  +cancelAddress()
  +validateType()
  +deleteNote()
}
class Statement {
  -float name
  #int status
  +getPhone()
  +updateAmount()
  +updateTotal()
}
interface Beneficiary {
  #Date phone
  -float id
  +calculateDuration()
  +cancelAmount()
}
abstract class Card {
  +double id
  +double status
  #boolean duration
  -String active
  -float level
  +calculatePrice()
}
abstract class Interest {
  #Date duration
  +float note
  +String createdAt
  #long name
  +findAddress()
  +updateStatus()
}
class Customer {
  +String code
  -int amount
  +long note
  #float active
  -Date price
  +findCreatedat()
  +savePrice()
  +findActive()
  +cancelEmail()
}
Deposit --|> Card
Statement --|> Customer
Interest ..> Statement : "0..1"
note right of Deposit : Banking domain
@enduml