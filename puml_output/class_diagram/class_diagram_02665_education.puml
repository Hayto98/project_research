@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Department {
  -String quantity
  +boolean address
  -double phone
  -String level
  +cancelActive()
  +saveStatus()
  +deleteNote()
}
interface Course {
  #boolean quantity
  -int level
  +setAddress()
}
abstract class Grade {
  #long price
  +float duration
  #double createdAt
  +saveName()
  +deleteQuantity()
  +setStatus()
}
class Attendance {
  +float price
  -long score
  -boolean description
  -long note
  +deleteQuantity()
  +validateScore()
}
interface Book {
  -long score
  -float updatedAt
  -int description
  +double createdAt
  -long level
  +getActive()
  +findDuration()
  +setPhone()
}
class Schedule {
  -Date quantity
  +String type
  #double email
  +findDescription()
  +deleteDescription()
}
class Teacher {
  #String updatedAt
  #double status
  #Date id
  -float level
  +boolean description
  +findUpdatedat()
  +saveStatus()
  +calculateName()
  +processCreatedat()
}
Attendance --o Grade
Schedule --o Attendance
note right of Department : Education domain
@enduml