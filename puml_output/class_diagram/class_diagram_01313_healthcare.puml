@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
interface Insurance {
  +double price
  #float note
  #long description
  +saveActive()
  +validateId()
}
class Nurse {
  -double code
  -double createdAt
  +savePrice()
  +saveDuration()
  +validatePrice()
}
class Ward {
  -Date amount
  +String score
  -float total
  #long note
  #double level
  +deleteAmount()
  +validatePrice()
}
abstract class Appointment {
  #boolean id
  #String level
  #long amount
  +processQuantity()
}
Nurse --* Insurance
Ward --o Nurse
Appointment --o Ward
@enduml