@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
interface Insurance {
  +double price
  #float note
  #long description
  +sendStatus()
  +getId()
}
class Nurse {
  -float total
  -boolean price
  #Date duration
  +findNote()
  +deleteScore()
}
abstract class Ward {
  #long total
  #double email
  #float amount
  +double status
  #Date duration
  +sendUpdatedat()
  +getLevel()
  +deleteActive()
  +findStatus()
}
class Appointment {
  +float name
  +long type
  +calculateType()
  +saveDuration()
  +calculateDuration()
}
Insurance --o Appointment
Appointment --|> Nurse
Insurance --* Nurse
note right of Insurance : Healthcare domain
@enduml