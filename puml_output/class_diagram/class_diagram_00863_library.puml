@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
abstract class Catalog {
  -long quantity
  -double updatedAt
  +boolean total
  #int name
  +int level
  +setAddress()
  +cancelQuantity()
}
class Branch {
  -long address
  +boolean phone
  +findActive()
  +createTotal()
  +processStatus()
}
interface Shelf {
  -float active
  #long note
  #int name
  +calculateDuration()
}
abstract class Librarian {
  +double name
  +double amount
  +float price
  #long score
  #Date active
  +validatePrice()
  +updateCreatedat()
}
class Fine {
  -String email
  #int status
  +saveLevel()
}
Branch --* Shelf
Librarian --* Catalog
@enduml