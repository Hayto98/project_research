@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
abstract class Catalog {
  -long quantity
  -double updatedAt
  +boolean total
  #int name
  +int level
  +sendNote()
  +setActive()
}
class Branch {
  #long phone
  -double note
  #long quantity
  #int amount
  +saveName()
  +createEmail()
  +sendCreatedat()
  +cancelCode()
}
interface Shelf {
  -float note
  +double name
  +double amount
  +float price
  #long active
  +saveAddress()
  +setEmail()
}
class Librarian {
  +long status
  -double createdAt
  +long duration
  #double description
  +setStatus()
}
class Fine {
  #double duration
  -Date active
  -String status
  +long level
  +findActive()
  +saveUpdatedat()
  +setPhone()
}
Catalog --> Fine : "1"
Shelf ..|> Fine
Branch --o Shelf
Fine ..|> Shelf
note right of Catalog : Library domain
@enduml