@startuml
skinparam ArrowColor #555555
interface Teacher {
  #long level
  -long price
  #long address
  -double email
  +updateStatus()
  +updateStatus()
  +saveName()
}
class Classroom {
  #double price
  +String active
  +Date email
  #int createdAt
  +calculateStatus()
}
class Student {
  -boolean createdAt
  -boolean price
  #double score
  +String phone
  +deleteDuration()
  +saveNote()
}
class Grade {
  #String code
  -int note
  -float email
  +long phone
  #int active
  +createType()
}
abstract class Course {
  -String price
  #double code
  -float total
  +String id
  #boolean quantity
  +calculateEmail()
}
abstract class Book {
  -Date name
  +long email
  +createStatus()
  +setAddress()
}
Classroom ..> Student : "1"
Classroom --> Course : "0..1"
Classroom --* Book
Student --|> Grade
note right of Teacher : Education domain
@enduml