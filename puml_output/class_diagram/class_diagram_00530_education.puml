@startuml
skinparam ArrowColor #555555
interface Teacher {
  #long level
  -long price
  #long address
  -double email
  +validateNote()
  +getUpdatedat()
  +validateEmail()
}
class Classroom {
  #Date name
  #float id
  +deleteAmount()
  +calculateLevel()
  +getScore()
}
interface Student {
  +Date createdAt
  #int note
  +double amount
  #String status
  +validateScore()
  +calculateNote()
  +createPrice()
}
interface Grade {
  +String address
  +int quantity
  #Date active
  -long note
  +setDescription()
  +setActive()
  +setPrice()
  +getDuration()
}
abstract class Course {
  +long phone
  +long duration
  #int id
  #String price
  +getId()
  +calculateType()
  +setId()
}
interface Book {
  -String price
  #double code
  -float total
  +String id
  #boolean quantity
  +processLevel()
}
Grade --|> Teacher
Student ..> Grade : "0..1"
Student --* Classroom
Teacher --* Book
@enduml