@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
abstract class Message {
  #float duration
  -double active
  -boolean status
  +validateAmount()
}
class Notification {
  #int updatedAt
  #double type
  #int code
  +String active
  #int createdAt
  +updateActive()
  +calculateAmount()
}
interface Album {
  -int address
  -String description
  -double updatedAt
  #long code
  +saveStatus()
  +processPhone()
  +sendNote()
}
class Group {
  +float status
  #Date type
  +Date email
  +int note
  +calculateUpdatedat()
  +sendCode()
  +getStatus()
  +calculateAmount()
}
class Like {
  +Date name
  #int code
  -Date address
  #String email
  +sendType()
}
abstract class Hashtag {
  #float type
  +int amount
  -String duration
  #boolean status
  +boolean active
  +updateLevel()
  +createAmount()
  +updateQuantity()
  +createAddress()
}
abstract class Post {
  #long note
  +Date status
  #String id
  #boolean price
  #boolean type
  +updateUpdatedat()
  +calculateUpdatedat()
}
Message ..> Post : "*"
Notification --* Album
note right of Message : Social Media domain
@enduml