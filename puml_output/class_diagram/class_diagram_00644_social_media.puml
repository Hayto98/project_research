@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
abstract class Message {
  #float duration
  -double active
  -boolean status
  +saveScore()
}
class Notification {
  +float type
  #int updatedAt
  #int duration
  +validateTotal()
  +updateAmount()
  +findId()
  +findNote()
}
class Album {
  -int createdAt
  #long updatedAt
  -int active
  +setCode()
  +createAddress()
}
abstract class Group {
  -Date quantity
  -long id
  #String duration
  +saveScore()
  +updateNote()
  +deletePrice()
  +setLevel()
}
class Like {
  #double type
  +float email
  +saveUpdatedat()
  +findId()
}
class Hashtag {
  +double total
  #int updatedAt
  +boolean active
  #long code
  +Date id
  +deleteTotal()
}
class Post {
  #boolean code
  +String level
  #double createdAt
  -double phone
  +calculateDescription()
  +setDuration()
  +updateType()
  +deletePhone()
}
Message --> Post : "0..1"
Notification --|> Album
Like ..|> Post
Like ..|> Group
Post --* Like
@enduml