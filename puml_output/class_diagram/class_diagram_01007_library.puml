@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Branch {
  #long updatedAt
  -double status
  #int score
  +deleteDuration()
}
class Catalog {
  -String id
  #boolean total
  -String phone
  #Date email
  -boolean duration
  +updateActive()
  +processEmail()
}
class Fine {
  -long note
  #String duration
  #double name
  +saveType()
  +updateCreatedat()
  +findEmail()
}
class Shelf {
  +String name
  #int total
  +saveType()
  +findStatus()
  +saveTotal()
}
interface Member {
  #float status
  #boolean amount
  #String active
  +Date duration
  +createStatus()
  +calculateName()
  +updateUpdatedat()
}
interface Renewal {
  +Date createdAt
  #Date score
  +int address
  #Date status
  -float amount
  +deletePrice()
}
class Publisher {
  +long createdAt
  +long quantity
  #String code
  -long total
  -float price
  +validateType()
  +setStatus()
  +updateName()
  +cancelUpdatedat()
}
Fine --* Renewal
Member ..|> Catalog
note right of Branch : Library domain
@enduml