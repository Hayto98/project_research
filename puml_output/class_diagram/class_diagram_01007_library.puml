@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Branch {
  #long updatedAt
  -double status
  #int score
  +setType()
}
interface Catalog {
  -Date type
  -long id
  +findAmount()
}
class Fine {
  #float id
  -float note
  -Date amount
  -int updatedAt
  +sendCode()
  +findName()
  +savePhone()
  +updateCode()
}
class Shelf {
  #double score
  +int id
  #long note
  +String phone
  +cancelCreatedat()
}
class Member {
  #double description
  #float address
  +updateQuantity()
}
abstract class Renewal {
  #float status
  #boolean amount
  #String active
  +Date duration
  +updateLevel()
  +getAmount()
  +updateName()
}
abstract class Publisher {
  #float updatedAt
  #boolean duration
  +getTotal()
  +getCreatedat()
  +calculateName()
  +deleteQuantity()
}
Catalog ..> Renewal : "1"
Catalog ..> Member : "*"
Publisher ..|> Branch
@enduml