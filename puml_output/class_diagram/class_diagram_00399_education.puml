@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
abstract class Library {
  #boolean id
  -String description
  +boolean address
  -long createdAt
  +setNote()
}
class Enrollment {
  #String createdAt
  -int id
  #boolean total
  +String code
  #String description
  +findEmail()
  +sendTotal()
  +updateQuantity()
  +calculateScore()
}
interface Teacher {
  -boolean description
  #boolean email
  -String quantity
  +sendAmount()
  +processDescription()
}
class Student {
  -double price
  +double createdAt
  #double id
  +cancelScore()
  +deletePhone()
  +calculatePrice()
  +setEmail()
}
Teacher --|> Enrollment
Enrollment --* Student
note right of Library : Education domain
@enduml