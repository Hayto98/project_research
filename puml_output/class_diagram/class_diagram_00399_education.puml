@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
abstract class Library {
  #boolean id
  -String description
  +boolean address
  -long createdAt
  +saveStatus()
}
class Enrollment {
  -String description
  #Date active
  +boolean total
  +long createdAt
  +Date id
  +cancelStatus()
  +updateId()
}
class Teacher {
  -boolean email
  #int active
  +float total
  -long updatedAt
  -boolean quantity
  +deleteQuantity()
  +cancelPrice()
  +updateType()
  +setAddress()
}
class Student {
  +double description
  -String phone
  -boolean duration
  -Date price
  #boolean createdAt
  +calculateLevel()
  +processId()
  +createStatus()
  +processUpdatedat()
}
Student --|> Enrollment
Teacher ..> Enrollment : "1..*"
Teacher ..> Library : "0..1"
@enduml