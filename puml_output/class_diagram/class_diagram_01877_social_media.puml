@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
interface Report {
  #boolean duration
  +boolean active
  #String amount
  -boolean note
  -long type
  +processId()
  +deletePhone()
}
abstract class Comment {
  +double quantity
  #boolean level
  +double createdAt
  +cancelEmail()
  +saveCreatedat()
  +saveDescription()
}
class Hashtag {
  #String name
  #int quantity
  #String duration
  #String status
  -String address
  +processCode()
  +setEmail()
  +cancelQuantity()
}
class Follower {
  +long quantity
  -float active
  #String email
  +cancelUpdatedat()
}
class Group {
  +int amount
  -int description
  -double name
  +deleteAmount()
}
Group ..|> Report
@enduml