@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
interface Report {
  #boolean duration
  +boolean active
  #String amount
  -boolean note
  -long type
  +cancelTotal()
  +updateQuantity()
}
interface Comment {
  #int name
  -Date total
  -String active
  +findCreatedat()
  +processName()
  +createName()
}
interface Hashtag {
  #int address
  #String status
  +calculateStatus()
}
class Follower {
  +int address
  #float note
  +sendEmail()
  +updateEmail()
  +processStatus()
}
class Group {
  +int createdAt
  -int amount
  -double description
  +double name
  +cancelName()
}
Group --|> Report
Comment --o Group
note right of Report : Social Media domain
@enduml