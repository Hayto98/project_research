@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
interface Card {
  #Date total
  #long id
  +String note
  +cancelDescription()
  +sendCode()
  +cancelName()
}
abstract class Withdrawal {
  +long total
  +Date price
  #double level
  +sendType()
  +deleteStatus()
  +createNote()
  +sendPhone()
}
class Branch {
  #String code
  +String score
  #float total
  +String active
  -float phone
  +createName()
}
class Deposit {
  -double total
  +float level
  +processDuration()
  +saveTotal()
  +createLevel()
}
Withdrawal --> Branch : "1"
Card --> Deposit : "1"
@enduml