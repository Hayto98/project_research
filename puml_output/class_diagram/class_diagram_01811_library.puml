@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Book {
  +boolean price
  -double address
  -String duration
  #long amount
  +cancelActive()
}
abstract class Renewal {
  +String type
  #long status
  +findNote()
  +calculateName()
}
class Librarian {
  #boolean duration
  #long total
  #float score
  +processLevel()
  +findPhone()
  +findPrice()
}
class Loan {
  -Date duration
  +String status
  +cancelPrice()
  +updateId()
  +deleteCreatedat()
  +cancelCreatedat()
}
class Branch {
  #String updatedAt
  +Date phone
  +long type
  -double quantity
  +processPrice()
}
class Reservation {
  +int score
  +Date id
  -int active
  +String email
  +createDuration()
}
abstract class Author {
  #double id
  -boolean score
  #String email
  -Date address
  -int amount
  +setCreatedat()
  +cancelPhone()
  +calculateLevel()
}
Author --> Librarian : "1..*"
Branch ..> Renewal : "1..*"
Book --|> Renewal
@enduml