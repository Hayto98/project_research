@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Book {
  +boolean price
  -double address
  -String duration
  #long amount
  +cancelType()
}
interface Renewal {
  +String type
  #long status
  +setAddress()
  +getUpdatedat()
}
interface Librarian {
  +boolean score
  #Date level
  +String email
  #String duration
  -Date total
  +setTotal()
  +saveEmail()
}
abstract class Loan {
  -double email
  -boolean updatedAt
  +updateAmount()
}
class Branch {
  -boolean note
  +boolean status
  -int updatedAt
  +int address
  +updateDescription()
  +getCode()
  +calculateTotal()
  +findActive()
}
abstract class Reservation {
  #Date score
  -Date email
  +cancelType()
  +createLevel()
}
class Author {
  -float note
  #float createdAt
  #long phone
  #int email
  #long active
  +deleteStatus()
}
Renewal ..> Book : "*"
Loan --* Renewal
note right of Book : Library domain
@enduml