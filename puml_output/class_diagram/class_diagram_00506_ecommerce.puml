@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Category {
  -int score
  +double total
  -float description
  +boolean price
  -int note
  +deletePhone()
  +cancelPrice()
}
class Cart {
  +String quantity
  +String status
  +createStatus()
  +deleteScore()
}
abstract class Review {
  #Date type
  +boolean amount
  +updateCode()
}
class Payment {
  #Date phone
  +float createdAt
  #int score
  -long id
  +setActive()
  +processNote()
  +getAddress()
  +sendEmail()
}
Cart --> Review : "1"
Review --> Cart : "1..*"
Category --* Payment
@enduml