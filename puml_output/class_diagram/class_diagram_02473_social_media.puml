@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
abstract class Comment {
  -double note
  #float total
  +updateTotal()
}
abstract class Hashtag {
  +String address
  +float status
  -double price
  +boolean id
  +setActive()
  +processAddress()
  +saveActive()
  +saveEmail()
}
class Profile {
  +float score
  -String total
  -String quantity
  +createPhone()
  +createPrice()
  +saveType()
}
class Group {
  +String status
  #long email
  +deleteAddress()
  +updatePhone()
  +setId()
}
interface Follower {
  -int status
  -Date updatedAt
  +int name
  +sendQuantity()
  +findDuration()
}
class Report {
  #float score
  -Date email
  -long phone
  +int total
  -long address
  +updateActive()
  +createActive()
  +validateName()
}
Group --* Comment
Profile --* Group
Report --* Hashtag
Hashtag ..> Profile : "*"
note right of Comment : Social Media domain
@enduml