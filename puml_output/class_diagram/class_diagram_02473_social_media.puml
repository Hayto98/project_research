@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
abstract class Comment {
  -double note
  #float total
  +createId()
}
class Hashtag {
  +float note
  +String email
  +float address
  -double status
  +boolean price
  +getLevel()
  +saveType()
  +findDuration()
  +saveAmount()
}
class Profile {
  -float address
  +float updatedAt
  -String score
  -String total
  +createQuantity()
  +deleteCode()
  +getNote()
}
abstract class Group {
  +Date phone
  -long status
  +long level
  +long email
  +Date code
  +deleteId()
}
interface Follower {
  -int status
  -Date updatedAt
  +int name
  +cancelAmount()
  +createQuantity()
}
interface Report {
  -boolean total
  #double score
  -Date email
  +cancelUpdatedat()
  +cancelId()
  +processStatus()
}
Hashtag --* Profile
Profile --> Hashtag : "1..*"
Follower --|> Profile
@enduml