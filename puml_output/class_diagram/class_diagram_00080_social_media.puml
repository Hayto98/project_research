@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
abstract class User {
  #Date description
  +boolean duration
  +findName()
  +findPhone()
  +sendPrice()
  +saveTotal()
}
class Notification {
  -Date price
  +float updatedAt
  -Date createdAt
  +int note
  +getUpdatedat()
  +setActive()
  +sendType()
}
class Group {
  -double total
  +Date price
  -String description
  #double id
  +processTotal()
  +getAddress()
  +saveNote()
}
interface Report {
  +long description
  #double price
  +findAddress()
  +updateScore()
  +setStatus()
  +deleteCode()
}
class Story {
  -Date note
  -Date description
  #float quantity
  +createAmount()
}
abstract class Album {
  #int active
  -Date status
  +Date updatedAt
  +deleteUpdatedat()
  +getTotal()
  +updateLevel()
  +processCode()
}
Story --* Report
Story --o User
note right of User : Social Media domain
@enduml