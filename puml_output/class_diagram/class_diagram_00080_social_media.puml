@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
abstract class User {
  #Date description
  +boolean duration
  +calculateStatus()
  +calculateEmail()
  +cancelUpdatedat()
  +createLevel()
}
class Notification {
  +boolean total
  -double createdAt
  #int quantity
  -Date price
  +int updatedAt
  +saveEmail()
  +getDescription()
  +findAddress()
}
class Group {
  +double id
  -String phone
  #double total
  +boolean price
  -long description
  +setNote()
  +updatePrice()
  +cancelDescription()
  +createActive()
}
abstract class Report {
  +long description
  #double price
  +updateScore()
  +calculateCreatedat()
  +sendId()
  +sendLevel()
}
interface Story {
  +float status
  +float amount
  +getName()
  +saveAmount()
}
class Album {
  -int address
  -float email
  +float active
  #float status
  +deleteAddress()
}
Report ..> Notification : "*"
Notification --|> Album
@enduml