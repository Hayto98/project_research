@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Assignment {
  +Date quantity
  #long id
  +setCode()
  +setUpdatedat()
}
interface Classroom {
  #long createdAt
  +boolean quantity
  -long total
  #boolean amount
  +deleteDescription()
  +validateDescription()
}
class Schedule {
  -float id
  +long type
  +String phone
  +cancelCreatedat()
  +calculateName()
  +findScore()
  +calculateCode()
}
abstract class Exam {
  +boolean type
  +String phone
  #int createdAt
  -boolean active
  +getName()
}
class Grade {
  +float type
  -String quantity
  +long status
  #String email
  +findScore()
  +updateDescription()
  +setTotal()
  +validateEmail()
}
Grade ..> Exam : "*"
Grade --* Classroom
@enduml