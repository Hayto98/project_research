@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Assignment {
  +Date quantity
  #long id
  +findName()
  +cancelEmail()
}
class Classroom {
  +boolean duration
  -long total
  #boolean amount
  +boolean email
  +updateId()
  +processDuration()
  +validateNote()
}
class Schedule {
  -long description
  -double name
  -double type
  -int total
  +sendDescription()
}
class Exam {
  #long total
  -double score
  -float status
  +findEmail()
}
class Grade {
  -int name
  -String createdAt
  +float address
  #double id
  #double type
  +createDescription()
  +calculateUpdatedat()
}
Assignment ..|> Schedule
Exam ..> Schedule : "*"
Schedule ..> Classroom : "*"
Exam --o Assignment
note right of Assignment : Education domain
@enduml