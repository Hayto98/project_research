@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Payment {
  +Date price
  #Date updatedAt
  #double code
  -int quantity
  +updateEmail()
  +processDuration()
  +saveUpdatedat()
}
class Review {
  #long id
  -String description
  +calculateActive()
  +deleteQuantity()
}
interface Warehouse {
  +boolean type
  #double amount
  +deleteCreatedat()
  +calculateDuration()
  +sendTotal()
}
class Return {
  +long active
  -Date duration
  +cancelActive()
}
class Customer {
  #int active
  #long description
  +boolean name
  -float id
  +cancelDuration()
  +deleteScore()
}
class Supplier {
  -Date type
  #Date description
  +findUpdatedat()
  +cancelType()
  +setStatus()
}
Payment --* Warehouse
Supplier --o Return
Supplier ..|> Warehouse
@enduml