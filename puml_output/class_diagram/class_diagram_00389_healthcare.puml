@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
abstract class Hospital {
  #double amount
  +String updatedAt
  +float createdAt
  +validateTotal()
  +updatePhone()
  +updatePrice()
}
class Nurse {
  +boolean level
  #Date createdAt
  +createId()
}
class Doctor {
  #int description
  +Date duration
  #String email
  -boolean note
  +getId()
}
abstract class LabTest {
  -float email
  #float active
  #boolean description
  +setCreatedat()
  +getId()
}
LabTest ..|> Hospital
Nurse --> LabTest : "1"
Nurse --> Hospital : "0..1"
@enduml