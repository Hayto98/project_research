@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Service {
  -String name
  -boolean status
  +createQuantity()
}
class Invoice {
  -float address
  -float type
  +cancelNote()
  +getDuration()
  +cancelType()
}
class CheckIn {
  #long amount
  +boolean level
  +Date price
  -long description
  #Date total
  +setPhone()
  +getId()
  +deleteEmail()
  +getActive()
}
class Restaurant {
  -boolean id
  -float description
  +getDescription()
  +calculateUpdatedat()
  +saveScore()
}
class Booking {
  +float createdAt
  -float total
  +boolean duration
  +int email
  +createUpdatedat()
  +setDuration()
}
interface Payment {
  -String status
  #int name
  +String price
  -boolean level
  +getPrice()
  +savePrice()
}
Service --> Booking : "1"
Service --|> Invoice
note right of Service : Hotel domain
@enduml