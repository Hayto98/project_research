@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Service {
  -String name
  -boolean status
  +updateLevel()
}
class Invoice {
  -float id
  -float address
  -boolean type
  +savePhone()
  +deleteStatus()
  +findDescription()
  +processId()
}
abstract class CheckIn {
  +float price
  -boolean amount
  -String duration
  +createTotal()
}
abstract class Restaurant {
  +String score
  +Date note
  -String status
  #Date phone
  +getName()
}
interface Booking {
  -boolean id
  -float description
  +calculateTotal()
  +calculateLevel()
  +processCode()
}
class Payment {
  -int updatedAt
  #float score
  -String status
  -float address
  +boolean createdAt
  +setLevel()
  +validateType()
}
CheckIn --|> Invoice
Booking --* Payment
Service ..> Payment : "*"
@enduml