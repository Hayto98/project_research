  +validateUpdatedat()
  +getScore()
}
class Invoice {
  #int createdAt
  #boolean address
  +int description
  #Date amount
  -int id
  +validateLevel()
  +findScore()
}
Product --* Category
Category ..> Invoice : "*"
@enduml