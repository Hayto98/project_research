@startuml
skinparam shadowing true
class Product {
  +double email
  +int id
  +float address
  +boolean note
  +boolean duration
  +processType()
  +calculateAddress()
  +validateDescription()
}
class Payment {
  #boolean type
  #int createdAt
  +int amount
  +setUpdatedat()
  +getDescription()
  +savePhone()
  +findTotal()
}
interface Coupon {
  +boolean name
  -float status
  #float type
  -float note
