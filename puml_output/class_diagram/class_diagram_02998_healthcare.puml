@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
interface Treatment {
  #long updatedAt
  #long code
  -String description
  #long note
  -int type
  +createAmount()
  +updateCode()
  +getNote()
}
abstract class Appointment {
  #Date createdAt
  -long address
  #String duration
  #long price
  +cancelDuration()
  +createType()
}
class Insurance {
  #String status
  #int name
  #int type
  +savePhone()
  +saveScore()
}
interface Nurse {
  -String level
  #int type
  +long id
  -int email
  -double name
  +findType()
  +validateEmail()
  +getUpdatedat()
}
class Hospital {
  #double total
  -long duration
  #double updatedAt
  #int amount
  +processCreatedat()
}
interface LabTest {
  #double amount
  +double email
  #long duration
  #float quantity
  +validateType()
  +findPrice()
  +setDuration()
  +deleteNote()
}
abstract class Diagnosis {
  +long score
  +boolean type
  +Date email
  -Date phone
  +Date description
  +sendDescription()
  +createAddress()
  +deleteTotal()
  +getPhone()
}
Nurse --> Hospital : "1"
Treatment ..> LabTest : "0..1"
Treatment ..|> Diagnosis
Diagnosis --* Hospital
Hospital --* Treatment
Insurance ..> Treatment : "1"
@enduml