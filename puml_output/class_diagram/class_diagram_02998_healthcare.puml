@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
interface Treatment {
  #long updatedAt
  #long code
  -String description
  #long note
  -int type
  +validateQuantity()
  +calculateDuration()
  +createCreatedat()
}
class Appointment {
  #String price
  #long quantity
  #int address
  +sendDescription()
  +setName()
}
abstract class Insurance {
  #int active
  +String amount
  +cancelPrice()
  +cancelType()
  +saveId()
}
class Nurse {
  #int type
  +long name
  +deleteNote()
  +processScore()
  +createStatus()
}
class Hospital {
  #double total
  -long duration
  #double updatedAt
  #int amount
  +saveActive()
}
class LabTest {
  #double email
  +double amount
  #long quantity
  +sendName()
  +processType()
  +sendType()
  +createScore()
}
class Diagnosis {
  #int status
  #long phone
  #int createdAt
  +setTotal()
  +cancelType()
  +cancelScore()
  +setId()
}
Treatment ..|> Diagnosis
Diagnosis --* Hospital
Hospital --* Treatment
note right of Treatment : Healthcare domain
@enduml