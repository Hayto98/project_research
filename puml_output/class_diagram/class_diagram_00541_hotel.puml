@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
abstract class Guest {
  #String amount
  +String quantity
  +Date status
  +long level
  +findPhone()
  +setNote()
  +updateCode()
  +saveScore()
}
class Restaurant {
  +boolean code
  +Date status
  -double description
  +String price
  +float quantity
  +createScore()
  +findTotal()
  +calculateDuration()
  +deleteAddress()
}
class CheckOut {
  #float status
  -int score
  +double duration
  +String active
  +validateQuantity()
  +cancelAddress()
}
class Payment {
  #Date price
  #boolean score
  +updatePrice()
  +setScore()
}
Restaurant ..> Payment : "0..1"
Payment --> Guest : "*"
@enduml