@startuml
skinparam defaultFontSize 13
interface Reservation {
  #String score
  #int price
  #int name
  -long email
  +cancelCode()
}
interface Book {
  #boolean total
  #String updatedAt
  +long phone
  +int status
  +deleteStatus()
  +createDuration()
  +updateAddress()
  +sendAmount()
}
class Librarian {
  #Date description
  #Date total
  +findQuantity()
  +findEmail()
  +createTotal()
  +processStatus()
}
class Publisher {
  -long type
  -int id
  +getId()
}
class Fine {
  #float note
  #boolean id
  -int address
  #int code
  #float phone
  +getLevel()
  +getTotal()
  +setTotal()
  +setType()
}
Book --> Publisher : "*"
Book --> Librarian : "1"
note right of Reservation : Library domain
@enduml