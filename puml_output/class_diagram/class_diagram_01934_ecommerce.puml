@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Order {
  +double score
  #double price
  +String level
  +setStatus()
}
class Warehouse {
  #String updatedAt
  +String name
  +calculateActive()
}
class Payment {
  -boolean active
  -boolean price
  +deletePrice()
  +processName()
}
class Supplier {
  #long price
  +float createdAt
  -String address
  -double description
  -int status
  +findEmail()
  +setAmount()
  +updateActive()
  +createTotal()
}
class Product {
  -float type
  +long code
  #int updatedAt
  #boolean id
  +calculateNote()
  +findPhone()
}
class Cart {
  +Date note
  -int type
  -boolean code
  -long duration
  +cancelLevel()
  +getTotal()
  +deleteEmail()
  +getType()
}
class Review {
  #long type
  +int price
  -long code
  #double updatedAt
  +setPhone()
  +getTotal()
}
Order --|> Warehouse
Payment --o Product
Cart --o Review
Order --> Product : "*"
Cart --> Product : "1"
Supplier --* Review
@enduml