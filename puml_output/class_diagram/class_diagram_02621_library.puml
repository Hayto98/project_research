@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
interface Librarian {
  #boolean active
  +Date type
  +boolean phone
  +calculateCreatedat()
  +sendAddress()
}
class Loan {
  -long updatedAt
  +long description
  #long level
  +calculateScore()
  +validateAmount()
  +setScore()
}
abstract class Shelf {
  #boolean code
  -Date score
  #Date createdAt
  -double updatedAt
  -float note
  +sendType()
}
abstract class Catalog {
  #boolean createdAt
  #String name
  -int quantity
  +validateQuantity()
}
interface Branch {
  -double amount
  #Date price
  +deleteTotal()
  +processAddress()
  +updateCode()
}
class Author {
  -String name
  -Date updatedAt
  +processName()
  +setPrice()
  +deleteCreatedat()
  +setLevel()
}
abstract class Publisher {
  +boolean level
  -float id
  -int note
  -long name
  #boolean code
  +cancelCode()
}
Author --o Loan
Librarian --* Shelf
Author ..> Branch : "0..1"
@enduml