@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
abstract class Shelf {
  +String updatedAt
  #boolean description
  +createNote()
  +createId()
  +deleteDuration()
}
class Catalog {
  #boolean price
  +double status
  -float total
  +getEmail()
  +saveId()
  +getTotal()
  +findAddress()
}
class Member {
  -Date total
  #double address
  #long note
  #String code
  +updateActive()
  +validateAddress()
  +deleteActive()
}
class Publisher {
  -long amount
  -Date note
  +sendCode()
  +getDuration()
}
class Author {
  +int price
  -double name
  +saveScore()
  +saveUpdatedat()
}
abstract class Renewal {
  +String price
  +String address
  +updateUpdatedat()
}
Shelf ..> Author : "0..1"
Publisher ..> Member : "1..*"
Publisher --|> Renewal
Shelf --> Member : "0..1"
note right of Shelf : Library domain
@enduml