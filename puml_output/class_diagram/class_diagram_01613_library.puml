@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
abstract class Shelf {
  +String updatedAt
  #boolean description
  +getNote()
  +cancelQuantity()
  +deleteCreatedat()
}
class Catalog {
  -Date duration
  #String description
  #double updatedAt
  +deleteActive()
}
class Member {
  #long name
  #int email
  -double id
  #float score
  -double total
  +updateQuantity()
}
abstract class Publisher {
  #long active
  -int quantity
  #String id
  +int email
  -double createdAt
  +findType()
  +processLevel()
  +calculateStatus()
}
class Author {
  +double name
  #String phone
  +findAddress()
  +calculateType()
}
class Renewal {
  #double description
  -int score
  +int updatedAt
  +float note
  #boolean status
  +updateDescription()
}
Renewal --|> Publisher
Author --o Catalog
Member ..> Author : "1..*"
@enduml