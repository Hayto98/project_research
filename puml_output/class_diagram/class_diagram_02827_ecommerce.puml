@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Warehouse {
  +double description
  -double email
  -boolean duration
  #double amount
  +boolean level
  +saveCreatedat()
  +calculateLevel()
}
class Return {
  #boolean level
  #int description
  +double address
  #int status
  +deleteId()
}
abstract class Coupon {
  +String type
  +boolean quantity
  +boolean level
  +long code
  +sendUpdatedat()
  +processNote()
}
class Review {
  #long createdAt
  +Date email
  +updateScore()
  +setType()
  +cancelCreatedat()
}
Coupon --* Review
Warehouse --o Return
@enduml