@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Author {
  +int type
  -boolean createdAt
  +deleteAddress()
}
abstract class Librarian {
  #double status
  +String level
  -long email
  #int description
  +sendEmail()
  +processActive()
  +saveScore()
}
class Fine {
  -long updatedAt
  +double quantity
  +calculateDuration()
  +getDescription()
  +sendTotal()
}
class Catalog {
  #boolean updatedAt
  +int email
  #int type
  +calculateId()
  +getCode()
}
class Shelf {
  +int updatedAt
  #long score
  -double description
  +int code
  #int amount
  +calculateType()
  +cancelCode()
  +updateTotal()
  +findStatus()
}
Fine --> Librarian : "*"
Fine --|> Author
Author ..> Shelf : "*"
@enduml