@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Author {
  +int type
  -boolean createdAt
  +updateNote()
}
class Librarian {
  #int level
  #double email
  +getPrice()
  +validateDuration()
}
class Fine {
  +int createdAt
  -float duration
  -long phone
  +double updatedAt
  +sendId()
  +deleteAmount()
  +findUpdatedat()
}
class Catalog {
  +boolean score
  -double createdAt
  #Date level
  +boolean duration
  +String updatedAt
  +deleteUpdatedat()
  +sendQuantity()
}
abstract class Shelf {
  -Date description
  #long amount
  #Date level
  #boolean price
  +boolean type
  +validateCode()
  +setEmail()
  +getCode()
  +findStatus()
}
Catalog ..|> Fine
Librarian ..|> Catalog
Author --> Shelf : "0..1"
Fine ..> Shelf : "1..*"
note right of Author : Library domain
@enduml