@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Album {
  +boolean phone
  -boolean duration
  +long price
  +sendId()
}
class Hashtag {
  #long active
  +Date phone
  +Date amount
  +cancelPhone()
  +cancelDescription()
  +calculateType()
}
interface Follower {
  -String quantity
  +long type
  +deletePhone()
}
class Group {
  #boolean type
  #String total
  #String price
  #long amount
  +Date active
  +validatePhone()
  +sendUpdatedat()
}
Album --* Hashtag
Follower ..|> Group
Follower --> Hashtag : "1..*"
note right of Album : Social Media domain
@enduml