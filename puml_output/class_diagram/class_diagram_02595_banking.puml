@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Card {
  +long address
  #String status
  -double phone
  -long type
  +long level
  +saveEmail()
  +sendScore()
  +deleteId()
  +calculateId()
}
abstract class Loan {
  -int note
  -boolean type
  +updateDuration()
  +deleteDuration()
}
class Beneficiary {
  -float description
  #int price
  +createEmail()
}
abstract class Branch {
  #boolean email
  +Date updatedAt
  +double quantity
  +validateNote()
  +processDuration()
}
interface Transfer {
  +double updatedAt
  -boolean duration
  #int id
  -long price
  +saveCode()
}
class Deposit {
  #boolean quantity
  #long name
  +boolean amount
  #double total
  +updateCreatedat()
  +saveId()
}
class Withdrawal {
  #float total
  #Date updatedAt
  #float code
  +float amount
  #Date duration
  +setDescription()
  +sendDuration()
  +deleteEmail()
  +getUpdatedat()
}
Withdrawal --|> Deposit
Deposit ..> Card : "1..*"
Loan --> Branch : "1"
Card --* Beneficiary
Withdrawal --o Loan
Card --> Transfer : "*"
@enduml