@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Card {
  +long address
  #String status
  -double phone
  -long type
  +long level
  +getPrice()
  +getType()
  +getNote()
  +processAddress()
}
class Loan {
  -String level
  #int amount
  -double id
  #int note
  +calculateCreatedat()
}
class Beneficiary {
  #int quantity
  -boolean score
  +int updatedAt
  +sendQuantity()
  +updateUpdatedat()
}
class Branch {
  -String createdAt
  -long type
  #Date total
  #Date description
  -Date price
  +getAmount()
  +calculateScore()
  +saveQuantity()
}
class Transfer {
  +String updatedAt
  +double name
  #float code
  #Date note
  #float total
  +saveType()
  +setScore()
}
class Deposit {
  -boolean quantity
  +String amount
  +validateDescription()
  +processName()
  +cancelLevel()
}
interface Withdrawal {
  -long quantity
  +double updatedAt
  #String note
  -Date duration
  -float address
  +setAddress()
  +validatePrice()
  +deletePhone()
  +createTotal()
}
Transfer --o Deposit
Loan --o Withdrawal
Card --> Beneficiary : "1..*"
Transfer ..> Loan : "1"
note right of Card : Banking domain
@enduml