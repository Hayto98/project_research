@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
interface Invoice {
  #int updatedAt
  #double note
  +saveDuration()
  +processCode()
  +saveAddress()
}
class CheckIn {
  #Date email
  #Date code
  -long quantity
  #long duration
  +findDuration()
  +sendAmount()
  +getUpdatedat()
  +sendQuantity()
}
class Staff {
  #Date type
  +int note
  +updateUpdatedat()
  +setCreatedat()
  +setCode()
  +cancelStatus()
}
class Service {
  -double name
  +float phone
  +Date duration
  #float address
  +validateLevel()
}
abstract class Guest {
  #boolean level
  +boolean createdAt
  #Date price
  +getType()
  +cancelType()
  +saveStatus()
}
CheckIn --> Service : "0..1"
CheckIn ..> Staff : "0..1"
Service --* Staff
@enduml