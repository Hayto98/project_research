@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
interface Invoice {
  #int updatedAt
  #double note
  +cancelId()
  +deleteName()
  +createEmail()
}
class CheckIn {
  #long score
  -boolean email
  #float total
  #long level
  +processNote()
}
class Staff {
  +long total
  +long status
  #Date code
  +saveAddress()
}
class Service {
  +float name
  #int amount
  #Date score
  -Date status
  #int price
  +setCode()
  +findUpdatedat()
  +processScore()
}
interface Guest {
  #int description
  #float active
  -long phone
  +saveAmount()
  +calculateUpdatedat()
  +deleteTotal()
}
CheckIn --* Service
Service --* Guest
Guest ..> Invoice : "0..1"
CheckIn ..|> Guest
note right of Invoice : Hotel domain
@enduml