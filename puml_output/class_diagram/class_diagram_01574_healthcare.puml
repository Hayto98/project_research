@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Nurse {
  +long description
  #Date name
  #float amount
  +setId()
  +validateEmail()
}
class LabTest {
  +double note
  #float status
  #int phone
  +getDuration()
  +getEmail()
  +sendStatus()
}
abstract class MedicalRecord {
  #float description
  #long active
  #String duration
  #float score
  -double code
  +processCreatedat()
  +validateNote()
  +createLevel()
}
class Hospital {
  #float price
  -boolean code
  -long total
  +String email
  +setPrice()
  +saveUpdatedat()
  +cancelPrice()
  +getTotal()
}
class Billing {
  -double quantity
  +float duration
  +boolean score
  -float total
  +getDuration()
  +cancelCreatedat()
  +cancelStatus()
  +deleteStatus()
}
abstract class Diagnosis {
  +long amount
  -int phone
  -String address
  +Date price
  -boolean score
  +saveStatus()
  +findLevel()
}
LabTest --> Nurse : "1"
Hospital ..|> Nurse
Billing ..> Nurse : "0..1"
@enduml