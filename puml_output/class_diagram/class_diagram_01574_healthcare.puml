@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Nurse {
  +long description
  #Date name
  #float amount
  +cancelStatus()
  +validateDescription()
}
abstract class LabTest {
  -boolean phone
  #int status
  +deleteNote()
  +calculateDescription()
  +sendDescription()
}
class MedicalRecord {
  #float email
  -double id
  +updateAmount()
  +validatePrice()
  +cancelCode()
}
abstract class Hospital {
  -int score
  +double note
  #Date duration
  +Date type
  +validateQuantity()
}
class Billing {
  -float address
  -String note
  #float code
  -double amount
  #int level
  +validatePrice()
  +validateStatus()
  +createNote()
}
class Diagnosis {
  +String status
  #String description
  -float total
  +int level
  #String createdAt
  +calculateAmount()
  +setDescription()
}
Hospital --|> MedicalRecord
Billing ..> LabTest : "0..1"
LabTest --* Billing
Diagnosis --> Hospital : "1..*"
note right of Nurse : Healthcare domain
@enduml