@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
interface Shipment {
  #String id
  +Date address
  +double status
  #long phone
  +processLevel()
  +processAddress()
}
class Payment {
  +int score
  -String createdAt
  +long level
  +calculateLevel()
  +createAddress()
  +setUpdatedat()
  +deletePhone()
}
class Customer {
  #Date code
  #int name
  #boolean duration
  +savePhone()
}
class Invoice {
  #boolean active
  -boolean note
  +processUpdatedat()
  +cancelDescription()
}
Payment ..> Shipment : "1"
Shipment --> Payment : "1..*"
note right of Shipment : Ecommerce domain
@enduml