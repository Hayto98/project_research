@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
interface Shipment {
  #String id
  +Date address
  +double status
  #long phone
  +saveStatus()
  +deleteActive()
}
interface Payment {
  +int address
  -String amount
  +long description
  #double createdAt
  -boolean active
  +validateScore()
  +updateUpdatedat()
  +validateStatus()
}
class Customer {
  +String phone
  #String amount
  #Date createdAt
  +createNote()
  +deleteUpdatedat()
}
interface Invoice {
  +boolean phone
  #double updatedAt
  +processEmail()
  +processUpdatedat()
  +deleteActive()
  +sendNote()
}
Payment --|> Shipment
Shipment --* Invoice
@enduml