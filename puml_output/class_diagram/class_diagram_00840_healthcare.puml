@startuml
skinparam monochrome true
skinparam ArrowColor #555555
abstract class Insurance {
  #Date createdAt
  -double price
  #Date amount
  +calculateScore()
  +getDescription()
}
class LabTest {
  -double amount
  #boolean note
  +int description
  +processName()
  +setTotal()
}
interface Treatment {
  -String score
  +double createdAt
  -boolean duration
  +findNote()
}
class Doctor {
  +int total
  +Date price
  +long note
  -float updatedAt
  +calculateNote()
  +createEmail()
  +sendScore()
  +validateEmail()
}
class Patient {
  #String total
  #int description
  -String code
  +double quantity
  +cancelEmail()
  +getEmail()
  +getUpdatedat()
  +calculateType()
}
abstract class Nurse {
  +String description
  -boolean amount
  #long quantity
  +String score
  -double duration
  +cancelEmail()
}
Doctor --o Nurse
Insurance ..|> Patient
Patient --* Insurance
Nurse ..> Treatment : "0..1"
@enduml