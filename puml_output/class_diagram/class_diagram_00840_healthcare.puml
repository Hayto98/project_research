@startuml
skinparam monochrome true
skinparam ArrowColor #555555
abstract class Insurance {
  #Date createdAt
  -double price
  #Date amount
  +createId()
  +deleteAmount()
}
abstract class LabTest {
  +Date quantity
  +String type
  -boolean name
  +sendCreatedat()
  +sendPrice()
}
class Treatment {
  +long price
  -double total
  #float status
  +processUpdatedat()
  +getDescription()
  +setUpdatedat()
  +createNote()
}
abstract class Doctor {
  -Date price
  -int status
  +float description
  +sendCode()
  +sendDescription()
  +validateCode()
}
class Patient {
  #Date type
  +int status
  #long description
  #long note
  #int price
  +setType()
}
interface Nurse {
  +String id
  -double name
  -double total
  +boolean type
  +sendName()
  +validateQuantity()
}
Treatment --o Patient
Treatment --|> LabTest
Doctor ..> Treatment : "*"
note right of Insurance : Healthcare domain
@enduml