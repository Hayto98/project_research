@startuml
skinparam ArrowColor #555555
interface Category {
  #boolean updatedAt
  -double phone
  #long total
  +deleteId()
  +setUpdatedat()
  +sendLevel()
  +deleteCreatedat()
}
class Supplier {
  -float level
  #boolean amount
  #int price
  #long name
  +processEmail()
  +validateLevel()
  +calculatePrice()
}
abstract class Review {
  +Date score
  #Date code
  -double createdAt
  +saveId()
  +findType()
  +updateId()
  +validateAddress()
}
abstract class Payment {
  +Date createdAt
  #float code
  #int status
  +setAmount()
  +cancelQuantity()
  +calculateType()
  +createPhone()
}
class Warehouse {
  #float id
  #boolean note
  +boolean address
  +calculatePrice()
  +saveDescription()
}
class Shipment {
  -int id
  +float status
  -double quantity
  #String phone
  +createAmount()
  +deleteCreatedat()
}
class Wishlist {
  +boolean duration
  -float level
  +cancelEmail()
  +saveEmail()
}
Review --|> Shipment
Category --o Payment
Category --* Review
@enduml