@startuml
skinparam ArrowColor #555555
interface Category {
  #boolean updatedAt
  -double phone
  #long total
  +getEmail()
  +setPhone()
  +findLevel()
  +findAmount()
}
abstract class Supplier {
  #Date note
  +Date level
  +validateLevel()
  +sendNote()
  +deleteScore()
}
class Review {
  -Date name
  #boolean level
  -String type
  +processAmount()
  +updateCode()
  +setId()
}
interface Payment {
  +float type
  +String note
  -boolean status
  +saveLevel()
  +sendDescription()
  +sendCreatedat()
}
interface Warehouse {
  -long address
  +int id
  -double status
  #String quantity
  +validateEmail()
  +deleteLevel()
}
class Shipment {
  #int level
  +String address
  +createStatus()
  +getPrice()
}
abstract class Wishlist {
  #Date phone
  +Date duration
  +updateAddress()
}
Wishlist ..> Shipment : "1"
Wishlist --> Review : "1"
note right of Category : Ecommerce domain
@enduml