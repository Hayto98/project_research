@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
interface Loan {
  +int code
  +float phone
  +float score
  #boolean address
  #Date duration
  +saveCreatedat()
  +deletePhone()
  +deleteDuration()
}
interface Customer {
  -String score
  -int description
  -long email
  +cancelId()
  +updateAddress()
  +setQuantity()
}
class Teller {
  -int createdAt
  #float email
  +long duration
  +Date address
  +saveActive()
  +cancelTotal()
  +findName()
}
class Transaction {
  +boolean duration
  #float price
  +deleteAmount()
}
class Account {
  #String id
  +long email
  +createQuantity()
  +setLevel()
  +setUpdatedat()
  +sendActive()
}
Transaction --> Account : "1..*"
Account --o Customer
Teller --* Transaction
@enduml