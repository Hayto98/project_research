@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
interface Shipment {
  -int createdAt
  +Date quantity
  +double total
  #Date address
  +deletePhone()
  +createAddress()
  +calculateAmount()
  +sendUpdatedat()
}
interface Warehouse {
  +String code
  #long note
  +boolean phone
  +getDuration()
}
class Category {
  #double createdAt
  #long email
  +createQuantity()
  +calculateStatus()
}
class Return {
  #double status
  +long address
  -float type
  +sendEmail()
  +processNote()
}
class Order {
  +Date total
  #String amount
  #float description
  -Date duration
  +saveLevel()
  +deleteQuantity()
  +cancelActive()
}
class Wishlist {
  #double price
  #String phone
  #boolean address
  -long total
  #Date active
  +setQuantity()
  +setNote()
  +cancelActive()
  +calculateCode()
}
Wishlist --o Order
Return ..|> Warehouse
Warehouse --* Shipment
@enduml