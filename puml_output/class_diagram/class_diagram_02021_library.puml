@startuml
skinparam ArrowColor #555555
interface Librarian {
  +String score
  -float description
  -String updatedAt
  #Date email
  +validateLevel()
  +setQuantity()
  +cancelName()
  +setPhone()
}
abstract class Reservation {
  #int name
  -boolean type
  -boolean level
  #int id
  +setDescription()
  +calculateStatus()
  +deletePrice()
}
interface Book {
  #boolean updatedAt
  #String score
  #boolean amount
  +long code
  -String type
  +processUpdatedat()
  +sendName()
  +saveUpdatedat()
}
class Fine {
  #String level
  +boolean duration
  +Date address
  +processName()
}
Reservation --o Book
Librarian ..|> Book
note right of Librarian : Library domain
@enduml