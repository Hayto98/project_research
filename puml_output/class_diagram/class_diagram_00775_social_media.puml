@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Report {
  #Date active
  +long quantity
  -String updatedAt
  #double id
  +updateCreatedat()
  +findEmail()
}
abstract class User {
  -long active
  +Date updatedAt
  -Date description
  -boolean price
  +findStatus()
  +saveEmail()
  +saveTotal()
  +cancelTotal()
}
abstract class Story {
  -int phone
  #double id
  #Date type
  +cancelCreatedat()
  +sendLevel()
  +saveId()
  +saveActive()
}
class Comment {
  #long amount
  #float total
  +updateStatus()
  +createUpdatedat()
}
Story --|> Comment
User --* Report
Story --> User : "0..1"
@enduml