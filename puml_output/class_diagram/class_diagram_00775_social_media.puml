@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Report {
  #Date active
  +long quantity
  -String updatedAt
  #double id
  +processPhone()
  +sendUpdatedat()
}
interface User {
  +Date price
  -Date type
  -boolean address
  +saveName()
  +getTotal()
  +findDuration()
  +deletePhone()
}
class Story {
  -String type
  #Date amount
  -String active
  +double note
  #long total
  +updateActive()
  +processAddress()
}
interface Comment {
  -long description
  -float id
  +getAmount()
  +saveTotal()
}
Report --o Story
Report ..|> Comment
Comment --> Report : "*"
note right of Report : Social Media domain
@enduml