@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Review {
  #Date score
  -String description
  #long status
  -int price
  -int updatedAt
  +deleteCreatedat()
  +cancelAmount()
  +savePhone()
}
class Coupon {
  #String active
  +boolean address
  +String total
  -double id
  #long duration
  +deleteStatus()
  +savePhone()
  +calculateId()
  +saveDescription()
}
interface Cart {
  -String phone
  +long amount
  -boolean duration
  -int quantity
  +findScore()
  +cancelId()
  +validateCode()
  +validateCreatedat()
}
class Return {
  +boolean score
  +float name
  +saveDuration()
}
abstract class Product {
  -float name
  -int level
  -String price
  +saveNote()
  +setName()
}
class Supplier {
  #int type
  +float id
  #Date updatedAt
  +double active
  +long email
  +saveId()
  +cancelStatus()
  +setEmail()
}
Product ..|> Coupon
Product --* Review
Supplier --> Coupon : "1"
@enduml