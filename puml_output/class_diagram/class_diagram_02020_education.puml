@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Library {
  +String quantity
  -double createdAt
  +setPrice()
  +validateStatus()
  +calculatePhone()
  +cancelType()
}
interface Teacher {
  +double status
  #Date level
  +createPrice()
  +cancelCode()
}
class Grade {
  #boolean amount
  #Date note
  #int email
  +processAmount()
  +deleteStatus()
  +findDescription()
}
class Classroom {
  -double description
  +float quantity
  +double note
  +boolean name
  +String level
  +createCreatedat()
  +validateCreatedat()
  +deletePrice()
  +processAddress()
}
interface Exam {
  #String createdAt
  +long address
  -long duration
  +boolean quantity
  +processNote()
}
interface Attendance {
  +float name
  -String createdAt
  -boolean type
  -boolean level
  -Date status
  +validateName()
}
Teacher --o Attendance
Attendance --> Teacher : "1..*"
@enduml