@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Library {
  +String quantity
  -double createdAt
  +createLevel()
  +setStatus()
  +cancelDescription()
  +processDuration()
}
class Teacher {
  -Date type
  #boolean phone
  #boolean createdAt
  +long amount
  +Date note
  +findType()
  +deleteQuantity()
  +processName()
}
class Grade {
  +boolean total
  +String name
  -int id
  +double type
  +updateAddress()
  +updateQuantity()
  +cancelStatus()
}
class Classroom {
  #boolean address
  -String quantity
  +double id
  +float name
  +updatePhone()
}
class Exam {
  #boolean duration
  +double total
  +int active
  +double quantity
  +cancelAddress()
  +processPrice()
}
class Attendance {
  +double createdAt
  #int total
  +long score
  -double status
  +setQuantity()
  +updateAddress()
}
Library --|> Teacher
Exam ..> Teacher : "1"
Classroom --> Library : "1..*"
note right of Library : Education domain
@enduml