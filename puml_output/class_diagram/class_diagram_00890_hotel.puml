@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Service {
  -float phone
  +int email
  #double address
  #boolean duration
  +processType()
  +validateAddress()
  +validateName()
  +deleteDuration()
}
class Booking {
  #Date name
  -Date level
  #int total
  #String amount
  -float createdAt
  +calculateDuration()
  +updateCreatedat()
}
class Guest {
  +float phone
  +long address
  +double id
  +setNote()
  +updateUpdatedat()
}
class Restaurant {
  #float name
  +double code
  -float active
  +deleteDescription()
  +getType()
}
interface Room {
  -float status
  #boolean score
  +Date total
  #boolean active
  -String level
  +updateAddress()
}
abstract class Staff {
  -long phone
  +boolean quantity
  #long code
  #double note
  +deleteName()
  +cancelAmount()
  +setId()
}
class Payment {
  +float address
  #float name
  +boolean quantity
  +calculateActive()
  +processNote()
  +createAddress()
}
Staff --* Restaurant
Payment --* Service
Staff ..> Guest : "1"
Payment ..|> Booking
note right of Service : Hotel domain
@enduml