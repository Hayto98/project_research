@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Service {
  -float phone
  +int email
  #double address
  #boolean duration
  +calculateAmount()
  +deletePhone()
  +getUpdatedat()
  +saveDescription()
}
abstract class Booking {
  #boolean address
  #float phone
  +double name
  +boolean amount
  +updateType()
  +saveNote()
  +updateAddress()
  +validatePrice()
}
class Guest {
  +double level
  #int status
  #int address
  +createCreatedat()
  +getDescription()
  +sendPrice()
}
class Restaurant {
  +double id
  #float createdAt
  #int amount
  +double phone
  +createTotal()
  +processDuration()
}
class Room {
  #float name
  +double code
  -float active
  +findId()
  +findPhone()
}
class Staff {
  -float active
  #boolean total
  +Date status
  #boolean level
  -String duration
  +updateQuantity()
}
class Payment {
  +boolean price
  -double address
  -String phone
  #Date quantity
  +deleteEmail()
  +saveUpdatedat()
  +saveName()
}
Booking --> Service : "0..1"
Service --* Payment
Booking ..> Guest : "1"
Guest --> Booking : "0..1"
@enduml