@startuml
skinparam defaultFontSize 11
class Service {
  #String updatedAt
  -String id
  -float description
  +boolean total
  +findActive()
  +getAddress()
  +createScore()
  +sendActive()
}
interface Restaurant {
  -int type
  -int address
  +findDescription()
  +calculateAddress()
}
class CheckOut {
  -int score
  +float status
  +int active
  #double amount
  #float phone
  +createDuration()
}
class Reservation {
  -long active
  -int name
  +calculateId()
  +calculateActive()
  +sendQuantity()
}
class Staff {
  #long duration
  #String score
  +setLevel()
}
class Housekeeping {
  -boolean type
  -String description
  +getUpdatedat()
  +calculateType()
  +saveDuration()
}
abstract class CheckIn {
  #float description
  +double status
  -double createdAt
  +validateUpdatedat()
  +calculateCreatedat()
}
Restaurant --o CheckOut
Staff --* Housekeeping
note right of Service : Hotel domain
@enduml