@startuml
skinparam defaultFontSize 11
class Service {
  #String updatedAt
  -String id
  -float description
  +boolean total
  +updateCode()
  +createTotal()
  +sendQuantity()
  +setQuantity()
}
class Restaurant {
  #String email
  -float score
  -double level
  +long active
  +updateId()
  +validateType()
}
interface CheckOut {
  -Date description
  -Date price
  #String address
  +cancelId()
  +saveCreatedat()
}
class Reservation {
  -boolean createdAt
  +long updatedAt
  #float score
  +setDescription()
  +findPrice()
}
class Staff {
  -float address
  +double duration
  #float createdAt
  #long level
  +createAddress()
  +cancelType()
}
interface Housekeeping {
  #Date active
  +String id
  -Date level
  +long code
  +calculateEmail()
  +deleteCreatedat()
  +validateLevel()
}
class CheckIn {
  #float price
  +int type
  +int level
  +calculateCode()
  +processAddress()
}
Reservation --* Restaurant
Housekeeping --o Restaurant
Restaurant ..|> Service
CheckOut --> Reservation : "1..*"
@enduml