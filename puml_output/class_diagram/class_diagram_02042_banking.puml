@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Transaction {
  -boolean status
  #long type
  +String amount
  +setActive()
}
abstract class Beneficiary {
  +float code
  -int quantity
  +double active
  +saveAmount()
  +saveId()
}
interface Account {
  +String active
  -Date price
  +sendDescription()
  +setQuantity()
}
abstract class Withdrawal {
  +boolean id
  -float amount
  +updateType()
}
class Card {
  -String createdAt
  -int type
  -boolean quantity
  #double amount
  #Date email
  +findScore()
  +saveCode()
  +savePrice()
  +getId()
}
Beneficiary ..> Transaction : "0..1"
Transaction --> Card : "1..*"
@enduml