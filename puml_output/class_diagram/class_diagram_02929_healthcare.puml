@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
interface Patient {
  #Date address
  +double phone
  #int updatedAt
  -String total
  -boolean score
  +setCode()
}
interface Hospital {
  #double id
  -Date amount
  +findCode()
  +sendQuantity()
  +deleteAddress()
  +cancelActive()
}
abstract class Nurse {
  #String quantity
  -boolean price
  -double note
  +processTotal()
  +cancelNote()
  +validateAddress()
  +validateCode()
}
abstract class Insurance {
  #long id
  +int address
  +double price
  -long createdAt
  -int active
  +validateType()
  +saveNote()
  +calculateQuantity()
  +processLevel()
}
abstract class MedicalRecord {
  +long code
  -String phone
  -int updatedAt
  #int active
  +sendPrice()
  +saveNote()
  +cancelType()
}
MedicalRecord ..> Hospital : "0..1"
Nurse --* Patient
@enduml