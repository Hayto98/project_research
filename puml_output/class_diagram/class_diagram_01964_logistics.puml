@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Manifest {
  +float price
  +String active
  +Date name
  +getDescription()
  +calculateQuantity()
  +createEmail()
}
class Route {
  -String name
  #Date phone
  -String level
  +cancelType()
  +saveId()
  +cancelType()
}
abstract class Inventory {
  +double price
  +boolean total
  #Date address
  -float name
  -double level
  +validateUpdatedat()
  +findPrice()
  +deleteTotal()
}
class Warehouse {
  +Date name
  #float score
  -float note
  +createType()
  +updateActive()
  +processType()
  +deleteAmount()
}
abstract class Depot {
  #long description
  #String duration
  +int name
  +String code
  +setTotal()
  +saveDescription()
}
Warehouse ..> Depot : "0..1"
Route ..|> Warehouse
note right of Manifest : Logistics domain
@enduml