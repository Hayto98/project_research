@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Manifest {
  +float price
  +String active
  +Date name
  +processCode()
  +validateCreatedat()
  +getName()
}
abstract class Route {
  #float quantity
  +long email
  -double name
  +Date amount
  +validateId()
  +updateAddress()
  +createNote()
  +setEmail()
}
interface Inventory {
  -float id
  -Date level
  -String type
  #boolean score
  -String price
  +setType()
  +saveDuration()
  +savePrice()
  +updateAddress()
}
class Warehouse {
  #double price
  +double address
  -int phone
  +float updatedAt
  +processName()
  +createTotal()
  +saveTotal()
  +deleteLevel()
}
interface Depot {
  #double price
  -float quantity
  +float type
  +double createdAt
  +validateDescription()
  +setLevel()
  +processQuantity()
}
Depot ..> Inventory : "1"
Route ..|> Depot
@enduml