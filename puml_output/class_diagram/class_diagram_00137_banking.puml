@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Interest {
  -boolean updatedAt
  #boolean status
  +validateAddress()
  +validateCode()
  +createAmount()
  +cancelScore()
}
class Customer {
  +long code
  +Date level
  +double score
  -double amount
  +findDuration()
  +getNote()
  +setActive()
  +findUpdatedat()
}
class Card {
  #String phone
  -int active
  +validateAmount()
  +validatePrice()
  +deleteStatus()
  +findType()
}
class Statement {
  +Date amount
  -boolean id
  -float code
  -long quantity
  #double note
  +setPrice()
  +validateNote()
  +sendNote()
}
abstract class Branch {
  -long createdAt
  -Date status
  +createId()
  +findAddress()
  +setDuration()
}
interface Account {
  -boolean createdAt
  #Date updatedAt
  -float amount
  +int note
  +sendAddress()
}
Customer --* Statement
Branch --o Customer
Interest ..> Statement : "0..1"
@enduml