@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Library {
  +double note
  #int phone
  +validateQuantity()
  +findDuration()
  +calculateDescription()
  +getPhone()
}
interface Classroom {
  +int active
  +boolean id
  +double phone
  +int createdAt
  -String level
  +sendUpdatedat()
  +getType()
  +updateDescription()
  +deleteActive()
}
class Attendance {
  #int updatedAt
  #Date active
  +float id
  -boolean total
  +cancelCreatedat()
  +sendId()
  +createActive()
  +sendNote()
}
abstract class Course {
  #long duration
  #int address
  #int total
  -int note
  #Date price
  +updateDuration()
}
class Schedule {
  +String description
  +boolean address
  -Date email
  +setDescription()
}
class Assignment {
  -int address
  +boolean score
  +boolean note
  +double level
  -Date phone
  +saveLevel()
  +deleteId()
  +processAmount()
}
class Teacher {
  -int status
  #boolean duration
  #Date description
  +sendName()
  +validateTotal()
  +validateAmount()
}
Attendance ..> Classroom : "1"
Classroom ..> Course : "1"
note right of Library : Education domain
@enduml