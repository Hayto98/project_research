@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Library {
  +double note
  #int phone
  +saveScore()
  +calculateTotal()
  +createEmail()
  +calculateDescription()
}
class Classroom {
  #float description
  -int id
  +int phone
  +int type
  #int level
  +cancelEmail()
  +validateCreatedat()
  +validateAmount()
  +validateId()
}
abstract class Attendance {
  +int id
  #int type
  -int updatedAt
  +cancelCreatedat()
}
class Course {
  #int note
  #Date score
  +long total
  +validateType()
  +deleteActive()
  +createDuration()
  +setAmount()
}
interface Schedule {
  #int total
  #int note
  -int price
  #Date phone
  +sendNote()
}
interface Assignment {
  -long createdAt
  +String description
  +findUpdatedat()
}
class Teacher {
  #float status
  +double description
  +setAddress()
  +sendCode()
  +calculateAmount()
}
Course ..|> Classroom
Schedule --> Classroom : "0..1"
Course ..> Teacher : "1..*"
Assignment ..|> Schedule
@enduml