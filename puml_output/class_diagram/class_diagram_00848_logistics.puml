@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Vehicle {
  #String updatedAt
  #Date description
  -double quantity
  -int duration
  -long address
  +getLevel()
  +getStatus()
  +validateDuration()
  +createType()
}
class Depot {
  #int type
  +String phone
  +calculateNote()
  +createName()
}
class Customer {
  -long duration
  +Date id
  +sendActive()
}
class Driver {
  #String description
  #long type
  +validateScore()
}
Customer --o Vehicle
Depot --* Vehicle
@enduml