@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Vehicle {
  #String updatedAt
  #Date description
  -double quantity
  -int duration
  -long address
  +setAddress()
  +savePhone()
  +cancelId()
  +processPhone()
}
class Depot {
  -String id
  +boolean createdAt
  +float level
  +validateCreatedat()
  +findCode()
  +cancelId()
}
class Customer {
  #long type
  +long level
  #Date code
  +sendQuantity()
  +getPrice()
}
interface Driver {
  -float description
  #long email
  -boolean status
  +getId()
  +sendType()
  +setId()
  +setAddress()
}
Vehicle --o Driver
Depot --> Customer : "0..1"
note right of Vehicle : Logistics domain
@enduml