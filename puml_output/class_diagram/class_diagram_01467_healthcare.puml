@startuml
skinparam defaultFontSize 13
class Prescription {
  -int active
  #String quantity
  +validateLevel()
  +deleteType()
  +findAmount()
  +updateQuantity()
}
class LabTest {
  -double email
  #Date type
  +float duration
  +createCode()
  +createCreatedat()
  +cancelName()
  +createTotal()
}
interface Treatment {
  -float amount
  +double address
  +findNote()
  +sendType()
}
class Patient {
  -boolean price
  #String type
  -Date phone
  +long amount
  +findStatus()
  +cancelPhone()
  +sendId()
  +setTotal()
}
LabTest --|> Treatment
Patient ..|> Treatment
note right of Prescription : Healthcare domain
@enduml