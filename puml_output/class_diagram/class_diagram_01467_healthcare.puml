@startuml
skinparam defaultFontSize 13
class Prescription {
  -int active
  #String quantity
  +sendPhone()
  +processId()
  +saveQuantity()
  +validateName()
}
class LabTest {
  #long quantity
  -long code
  -double updatedAt
  +cancelType()
}
abstract class Treatment {
  -double code
  #float email
  +int createdAt
  #Date name
  +createName()
  +setQuantity()
  +saveAddress()
}
abstract class Patient {
  +long note
  -double score
  -int type
  +cancelActive()
  +cancelScore()
  +setUpdatedat()
  +sendType()
}
LabTest ..> Patient : "*"
Prescription --* Treatment
Prescription --o Patient
@enduml