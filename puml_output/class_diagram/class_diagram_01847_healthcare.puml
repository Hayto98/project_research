@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
interface Diagnosis {
  -int phone
  #Date note
  +deleteScore()
  +sendDescription()
  +sendCreatedat()
}
class Prescription {
  -boolean duration
  +int quantity
  #float id
  +processPhone()
  +setDescription()
  +createTotal()
  +sendAmount()
}
abstract class Billing {
  #long createdAt
  +String level
  +calculateNote()
  +validateStatus()
  +processNote()
  +findDescription()
}
class Doctor {
  +String description
  -boolean address
  -boolean phone
  -long duration
  +findQuantity()
  +findStatus()
  +updateScore()
  +calculateType()
}
interface Hospital {
  -Date status
  +boolean note
  -boolean phone
  +validateId()
}
Prescription --> Billing : "1"
Hospital ..> Prescription : "*"
Prescription --> Doctor : "1"
Diagnosis --> Prescription : "1..*"
@enduml