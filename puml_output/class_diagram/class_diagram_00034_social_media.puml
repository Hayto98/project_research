@startuml
skinparam monochrome true
skinparam shadowing true
class Story {
  #Date level
  +boolean type
  +boolean phone
  +int code
  #long createdAt
  +updatePhone()
  +sendStatus()
  +findDuration()
}
interface Follower {
  #int address
  #double name
  +long email
  #boolean level
  +updateUpdatedat()
  +setNote()
}
interface Hashtag {
  +Date type
  +double quantity
  +calculatePrice()
  +updateType()
  +saveUpdatedat()
  +updateActive()
}
class User {
  #String level
  -long email
  +validateDuration()
  +createAddress()
}
class Message {
  +long score
  #int name
  +saveLevel()
  +findAmount()
}
class Profile {
  #boolean level
  +long total
  +boolean quantity
  +int active
  +boolean address
  +saveLevel()
  +setPhone()
  +processTotal()
}
class Like {
  #double score
  +double updatedAt
  -long code
  +String amount
  +getNote()
  +sendId()
}
Profile --|> Hashtag
Story --* Like
@enduml