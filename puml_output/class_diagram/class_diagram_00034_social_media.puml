@startuml
skinparam monochrome true
skinparam shadowing true
class Story {
  #Date level
  +boolean type
  +boolean phone
  +int code
  #long createdAt
  +saveActive()
  +sendEmail()
  +validateName()
}
class Follower {
  +long updatedAt
  #boolean total
  +setTotal()
  +cancelCode()
}
abstract class Hashtag {
  #int status
  #String id
  #float price
  #String score
  +cancelEmail()
}
interface User {
  #float total
  +long quantity
  +validateName()
}
interface Message {
  #int status
  +float address
  +updateNote()
  +cancelTotal()
  +createActive()
  +validateDuration()
}
class Profile {
  +boolean code
  -float level
  #double amount
  +long description
  +findCode()
  +deleteType()
}
class Like {
  -int address
  +Date quantity
  -String updatedAt
  +String id
  -int description
  +validateLevel()
}
User --* Follower
Message --|> User
Profile ..> User : "1"
note right of Story : Social Media domain
@enduml