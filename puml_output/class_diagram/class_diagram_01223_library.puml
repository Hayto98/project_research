@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Renewal {
  +double amount
  #double score
  #double price
  +Date createdAt
  +Date quantity
  +validateUpdatedat()
}
class Fine {
  #int phone
  #float code
  +sendId()
}
abstract class Member {
  +int email
  +long address
  +double status
  #String level
  +double updatedAt
  +cancelActive()
  +calculateStatus()
  +updateStatus()
  +deleteName()
}
abstract class Publisher {
  -Date quantity
  #Date duration
  +String type
  +findPrice()
}
abstract class Loan {
  #int updatedAt
  #String address
  -String description
  +float active
  +cancelLevel()
  +findQuantity()
}
abstract class Branch {
  +float createdAt
  -double price
  #long note
  #float email
  +setStatus()
  +updateCreatedat()
  +saveUpdatedat()
}
Member ..|> Branch
Member --o Loan
Fine ..|> Publisher
note right of Renewal : Library domain
@enduml