@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Renewal {
  +double amount
  #double score
  #double price
  +Date createdAt
  +Date quantity
  +getUpdatedat()
}
class Fine {
  +Date code
  +boolean name
  +boolean phone
  +calculateAmount()
}
abstract class Member {
  +int address
  +long status
  +double duration
  #String updatedAt
  +updateEmail()
}
abstract class Publisher {
  -float status
  #boolean createdAt
  +float duration
  -long description
  -double name
  +processCode()
  +findName()
}
class Loan {
  #Date type
  +boolean score
  #int phone
  #String updatedAt
  -String address
  +getPrice()
  +updateScore()
}
class Branch {
  -Date note
  -String quantity
  -double createdAt
  #long price
  +updateCreatedat()
  +getType()
  +setStatus()
}
Fine ..|> Branch
Member ..|> Branch
Member --o Loan
@enduml