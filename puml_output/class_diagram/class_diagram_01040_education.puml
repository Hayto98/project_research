@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
abstract class Grade {
  #double price
  +float quantity
  +deleteNote()
  +setActive()
  +validateDuration()
}
class Student {
  #boolean price
  -String status
  +int amount
  #String duration
  +saveCreatedat()
  +findAddress()
  +createUpdatedat()
  +createAmount()
}
abstract class Department {
  +float active
  +double description
  +Date id
  +Date createdAt
  +String total
  +updateDescription()
  +processId()
  +createCode()
}
abstract class Exam {
  +float name
  -int active
  +int score
  +Date description
  +saveDuration()
  +findAddress()
}
interface Assignment {
  +double note
  -long description
  -int quantity
  #long active
  #Date duration
  +validateQuantity()
  +deleteCreatedat()
  +sendStatus()
}
Exam --> Grade : "*"
Grade --> Student : "0..1"
Assignment --o Grade
note right of Grade : Education domain
@enduml