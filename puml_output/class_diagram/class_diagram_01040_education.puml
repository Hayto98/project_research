@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
abstract class Grade {
  #double price
  +float quantity
  +processUpdatedat()
  +saveAmount()
  +findNote()
}
interface Student {
  -String duration
  #Date name
  +double active
  #boolean address
  +setUpdatedat()
  +calculateAddress()
  +sendId()
}
interface Department {
  #int level
  #long price
  +findAddress()
  +cancelPhone()
  +createCode()
}
abstract class Exam {
  +float active
  +double description
  +Date id
  +Date createdAt
  +String total
  +findAddress()
  +validateCode()
  +deleteDuration()
}
class Assignment {
  #boolean code
  #int price
  +float address
  -int name
  +createScore()
  +deleteQuantity()
}
Student --> Department : "*"
Exam --* Student
Assignment --|> Exam
Exam --* Department
@enduml