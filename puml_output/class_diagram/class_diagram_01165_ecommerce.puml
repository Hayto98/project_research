@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Cart {
  #boolean status
  #boolean note
  #boolean quantity
  #boolean createdAt
  +validateDescription()
  +sendAddress()
}
interface Product {
  -double quantity
  -boolean id
  -boolean code
  +saveDescription()
  +validateType()
  +validateQuantity()
}
class Payment {
  -boolean status
  +double score
  +findName()
}
class Invoice {
  +int createdAt
  #double code
  +validateDescription()
  +getQuantity()
  +findCode()
}
class Customer {
  +float address
  -int type
  +processQuantity()
  +calculatePrice()
  +sendUpdatedat()
  +deleteTotal()
}
class Category {
  +float type
  #long total
  +saveName()
}
Payment ..> Product : "*"
Customer --o Cart
@enduml