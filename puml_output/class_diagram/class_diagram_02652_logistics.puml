@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Inventory {
  #Date price
  #double type
  +getCreatedat()
  +sendAmount()
  +cancelUpdatedat()
}
class Vehicle {
  +double code
  -int total
  #long level
  +createCreatedat()
}
class Depot {
  +double code
  +int createdAt
  +long address
  #long name
  -String phone
  +cancelDuration()
  +processStatus()
  +savePrice()
}
class DeliveryNote {
  #int active
  +int note
  +processUpdatedat()
  +calculateLevel()
  +sendStatus()
}
class FuelLog {
  -int name
  +String quantity
  -Date id
  +updateAmount()
}
class Customer {
  -Date score
  #boolean level
  #float address
  -boolean id
  +createName()
  +validatePhone()
  +sendCode()
  +setNote()
}
FuelLog --* Vehicle
DeliveryNote --> Customer : "1..*"
@enduml