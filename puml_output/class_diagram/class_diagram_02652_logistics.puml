@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Inventory {
  #Date price
  #double type
  +sendScore()
  +findAddress()
  +updateCode()
}
abstract class Vehicle {
  +int status
  #float price
  +double note
  +Date amount
  #int quantity
  +getPhone()
  +setNote()
  +getDescription()
}
class Depot {
  -Date active
  -boolean email
  +float phone
  +boolean name
  +sendDescription()
  +getCreatedat()
  +createAmount()
  +deleteUpdatedat()
}
class DeliveryNote {
  +double id
  #Date total
  +String amount
  -boolean createdAt
  +getQuantity()
  +findActive()
  +cancelPrice()
}
interface FuelLog {
  #int note
  -double code
  -boolean duration
  #boolean total
  -int status
  +createQuantity()
  +calculateQuantity()
  +processId()
}
abstract class Customer {
  #Date level
  +int updatedAt
  +int createdAt
  #long note
  +calculateCode()
  +findAddress()
  +createNote()
}
Depot ..> Vehicle : "0..1"
Vehicle --|> Customer
note right of Inventory : Logistics domain
@enduml