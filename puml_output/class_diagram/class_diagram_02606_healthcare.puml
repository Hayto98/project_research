@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
interface Patient {
  -boolean duration
  -int description
  +findStatus()
  +deleteEmail()
}
abstract class Treatment {
  +String email
  +Date status
  +getCreatedat()
  +getType()
  +createName()
}
class Prescription {
  -Date id
  +int type
  +setId()
  +validateId()
  +deleteEmail()
  +saveCode()
}
class Appointment {
  -double updatedAt
  #float email
  +sendCode()
  +getPrice()
  +cancelActive()
}
Treatment --o Appointment
Patient ..> Prescription : "0..1"
Patient --|> Treatment
@enduml