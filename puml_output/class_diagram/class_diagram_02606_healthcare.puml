@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
interface Patient {
  -boolean duration
  -int description
  +saveNote()
  +findActive()
}
class Treatment {
  #long status
  #String name
  -float id
  +String updatedAt
  +findType()
}
class Prescription {
  #String amount
  -long type
  +updateEmail()
}
class Appointment {
  -double level
  +boolean email
  #float note
  +String duration
  -float description
  +processTotal()
}
Appointment ..|> Patient
Treatment --* Prescription
Prescription --* Treatment
note right of Patient : Healthcare domain
@enduml