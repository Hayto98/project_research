@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Amenity {
  #boolean quantity
  +float createdAt
  #double address
  -boolean amount
  +findQuantity()
  +cancelUpdatedat()
  +processTotal()
}
class Service {
  +Date total
  -int updatedAt
  +boolean description
  +validateUpdatedat()
}
class Reservation {
  -long email
  +int amount
  +calculateScore()
  +sendName()
}
class Payment {
  #long description
  -boolean score
  +createDuration()
  +sendId()
  +calculateAddress()
}
Service --* Reservation
Payment --* Amenity
Reservation ..> Service : "0..1"
@enduml