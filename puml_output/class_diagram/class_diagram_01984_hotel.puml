@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Amenity {
  #boolean quantity
  +float createdAt
  #double address
  -boolean amount
  +validateNote()
  +deleteAmount()
  +calculateUpdatedat()
}
class Service {
  +boolean email
  +double description
  +getEmail()
}
class Reservation {
  -double phone
  +String status
  +boolean createdAt
  #long amount
  +cancelQuantity()
  +calculateCreatedat()
  +deleteAddress()
}
class Payment {
  -Date price
  #Date status
  #int phone
  #boolean address
  +setDuration()
  +getPhone()
  +cancelName()
}
Service ..> Payment : "*"
Service ..> Amenity : "1"
note right of Amenity : Hotel domain
@enduml