@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class FuelLog {
  +double note
  +float amount
  +saveAddress()
  +getAddress()
  +saveDuration()
}
class Route {
  -float description
  -float code
  +float name
  +setDescription()
}
class DeliveryNote {
  -boolean description
  +boolean type
  +float code
  #String address
  +saveQuantity()
}
abstract class Manifest {
  #float type
  +int price
  +long id
  -int level
  +Date description
  +findAmount()
}
class Warehouse {
  #double phone
  -double price
  +String type
  +processQuantity()
  +getUpdatedat()
  +sendCode()
  +processType()
}
Route ..> Warehouse : "1"
FuelLog --|> DeliveryNote
Manifest ..|> FuelLog
@enduml