@startuml
skinparam defaultFontSize 13
class Enrollment {
  #float type
  -String level
  +float phone
  +String description
  +deleteTotal()
  +setTotal()
}
class Department {
  #int type
  -double updatedAt
  #double phone
  +validateType()
  +sendPrice()
  +processName()
  +processCreatedat()
}
interface Exam {
  +long address
  #boolean code
  #int amount
  +boolean active
  +long score
  +validateType()
}
interface Student {
  +int description
  +boolean type
  #String phone
  -float updatedAt
  -long address
  +saveId()
}
interface Classroom {
  #int status
  #long duration
  +long quantity
  +createStatus()
  +findCreatedat()
}
class Schedule {
  -float amount
  -String level
  #Date duration
  -boolean active
  +float code
  +createScore()
}
class Teacher {
  #int amount
  +int createdAt
  -Date active
  -String type
  -double duration
  +sendLevel()
  +sendEmail()
  +calculateId()
}
Schedule ..> Teacher : "0..1"
Department --|> Classroom
Enrollment --|> Exam
note right of Enrollment : Education domain
@enduml