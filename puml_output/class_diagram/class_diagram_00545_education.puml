@startuml
skinparam defaultFontSize 13
class Enrollment {
  #float type
  -String level
  +float phone
  +String description
  +saveAddress()
  +getAddress()
}
class Department {
  #int code
  -double createdAt
  #double type
  -long updatedAt
  -boolean phone
  +cancelCode()
  +calculateEmail()
  +setActive()
  +deleteDuration()
}
class Exam {
  +long address
  #boolean code
  #int amount
  +boolean active
  +long score
  +createActive()
}
abstract class Student {
  +int description
  +boolean type
  #String phone
  -float updatedAt
  -long address
  +saveTotal()
}
class Classroom {
  #int status
  #long duration
  +long quantity
  +sendType()
  +calculatePhone()
}
class Schedule {
  #int quantity
  #String total
  -float amount
  +savePhone()
  +createDescription()
  +calculateDescription()
}
abstract class Teacher {
  #Date duration
  #float status
  +boolean email
  +setQuantity()
  +findType()
  +validateQuantity()
  +updateDescription()
}
Teacher ..|> Student
Teacher ..|> Schedule
Enrollment --* Department
Schedule --|> Student
Student --* Teacher
Classroom --> Teacher : "1..*"
@enduml