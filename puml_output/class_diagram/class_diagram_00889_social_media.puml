@startuml
skinparam defaultFontSize 11
interface Group {
  +double type
  #int description
  +String updatedAt
  +float code
  +cancelDescription()
}
class Album {
  +float total
  -Date score
  #boolean type
  +long address
  +updatePhone()
  +saveQuantity()
  +validateAmount()
}
interface Story {
  +long id
  +String createdAt
  +sendEmail()
  +setDuration()
}
abstract class Notification {
  +double phone
  #String active
  -boolean email
  -boolean description
  +sendActive()
  +createStatus()
  +saveCode()
  +saveLevel()
}
class Report {
  +double description
  -long address
  #int note
  +Date quantity
  +String price
  +cancelName()
  +calculateTotal()
  +cancelQuantity()
  +setAddress()
}
interface Like {
  #float note
  +double total
  #long level
  +double amount
  +String type
  +validateCreatedat()
  +validateName()
}
class Hashtag {
  -boolean level
  #int total
  -double updatedAt
  #String status
  +deleteEmail()
  +updateQuantity()
  +deleteStatus()
  +sendEmail()
}
Story ..|> Report
Group ..> Like : "*"
Hashtag ..|> Group
note right of Group : Social Media domain
@enduml