@startuml
skinparam defaultFontSize 11
interface Group {
  +double type
  #int description
  +String updatedAt
  +float code
  +setId()
}
class Album {
  #float address
  -long total
  +sendStatus()
  +calculateAmount()
}
interface Story {
  +long quantity
  #long phone
  +validateQuantity()
  +sendActive()
  +updateName()
}
class Notification {
  +int code
  #long address
  +boolean status
  +createQuantity()
  +getAmount()
  +updateAmount()
  +cancelId()
}
interface Report {
  -boolean description
  -boolean id
  -boolean type
  #float code
  +updateUpdatedat()
  +updatePhone()
  +cancelStatus()
}
interface Like {
  -double level
  -float total
  #double description
  +processLevel()
  +calculateScore()
}
class Hashtag {
  #double updatedAt
  #String amount
  -float code
  +sendActive()
  +calculatePhone()
  +updateName()
  +setEmail()
}
Like ..> Notification : "*"
Notification --o Like
Hashtag --o Album
Report --o Album
Report --|> Story
Notification --|> Album
@enduml