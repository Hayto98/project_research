@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
abstract class Library {
  +String total
  -boolean phone
  +findScore()
  +saveEmail()
  +getAmount()
}
class Course {
  #Date price
  -boolean status
  -boolean score
  +float address
  #boolean name
  +calculatePrice()
  +calculateEmail()
}
class Exam {
  +double updatedAt
  -double email
  -int code
  #String phone
  #Date id
  +processCreatedat()
  +cancelQuantity()
}
class Student {
  #int description
  #boolean address
  +validateId()
}
interface Department {
  -boolean status
  +boolean id
  #int phone
  +String name
  #int active
  +setId()
  +updatePrice()
  +sendLevel()
  +findAmount()
}
Exam ..> Department : "1"
Exam --o Course
@enduml