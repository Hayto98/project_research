@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
abstract class Library {
  +String total
  -boolean phone
  +createName()
  +savePhone()
  +saveNote()
}
abstract class Course {
  +boolean score
  #double address
  +sendUpdatedat()
  +cancelActive()
  +updateScore()
}
class Exam {
  -String total
  +double updatedAt
  -double email
  -int code
  +cancelScore()
}
class Student {
  #boolean email
  #Date status
  +String description
  #Date address
  -String updatedAt
  +savePhone()
}
class Department {
  #boolean quantity
  +String status
  +sendAmount()
}
Department --o Library
Exam ..> Department : "1..*"
note right of Library : Education domain
@enduml