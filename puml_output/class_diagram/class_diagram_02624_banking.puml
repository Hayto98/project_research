@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
interface Transfer {
  +Date price
  -String id
  #int amount
  +Date createdAt
  -String updatedAt
  +findActive()
  +processNote()
  +deleteLevel()
  +calculateScore()
}
class Transaction {
  -float createdAt
  #int name
  -boolean description
  -long status
  +float email
  +getLevel()
  +deleteUpdatedat()
  +sendStatus()
}
abstract class Beneficiary {
  -Date price
  -long id
  +long name
  #boolean level
  +createLevel()
  +setActive()
}
class Teller {
  +double type
  -int updatedAt
  +calculatePhone()
}
class Deposit {
  +Date active
  #float type
  +updateDescription()
  +validateStatus()
  +updateDuration()
}
class Interest {
  +boolean level
  +double updatedAt
  -double email
  #String createdAt
  +getCode()
  +updateScore()
}
Transaction ..|> Interest
Transfer --> Teller : "1"
@enduml