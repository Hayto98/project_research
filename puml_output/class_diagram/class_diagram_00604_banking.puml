@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
abstract class Transaction {
  -String id
  #String quantity
  +boolean price
  +validateDuration()
}
interface Account {
  -long email
  #String active
  +validateQuantity()
  +getNote()
  +calculateAddress()
}
class Interest {
  -boolean code
  +int score
  +float updatedAt
  +createQuantity()
  +validateUpdatedat()
  +sendCreatedat()
}
interface Beneficiary {
  #String duration
  -int amount
  #String type
  -double quantity
  -long price
  +updateAddress()
  +calculatePhone()
  +sendUpdatedat()
}
abstract class Customer {
  #String name
  +double createdAt
  #int score
  #int status
  +String type
  +setNote()
  +processLevel()
  +createId()
  +calculateNote()
}
class Withdrawal {
  -float score
  +int createdAt
  +validateCode()
}
class Branch {
  -boolean address
  #int status
  -Date updatedAt
  -Date duration
  +updateStatus()
  +processScore()
  +deleteTotal()
}
Transaction --> Branch : "*"
Account --|> Branch
@enduml