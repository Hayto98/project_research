@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
interface Comment {
  +Date description
  -long level
  +long address
  -double phone
  -String name
  +processQuantity()
}
abstract class User {
  -float updatedAt
  +boolean price
  +findAddress()
  +createEmail()
}
interface Post {
  -Date address
  #String duration
  -String description
  -int code
  +float level
  +validateCode()
  +processEmail()
  +getQuantity()
}
class Story {
  -double createdAt
  #Date amount
  #long level
  #double code
  +double address
  +deletePrice()
  +processCode()
  +getEmail()
}
Comment --|> Story
Comment --o Post
Post ..> Story : "*"
note right of Comment : Social Media domain
@enduml