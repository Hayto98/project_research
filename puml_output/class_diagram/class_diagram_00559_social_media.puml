@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
interface Comment {
  +Date description
  -long level
  +long address
  -double phone
  -String name
  +sendCreatedat()
}
class User {
  #boolean id
  #int updatedAt
  #long price
  -long total
  #float description
  +validateScore()
  +validateDuration()
  +setLevel()
  +calculateType()
}
interface Post {
  #boolean address
  +double email
  +createName()
}
class Story {
  -String level
  -long quantity
  +deleteLevel()
}
User ..|> Story
User ..> Comment : "1"
Post --o User
@enduml