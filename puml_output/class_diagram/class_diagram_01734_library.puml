@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
abstract class Shelf {
  +double duration
  +boolean email
  -int amount
  -int updatedAt
  +savePhone()
  +getEmail()
}
class Branch {
  +float active
  #boolean phone
  -float name
  -String status
  +deleteUpdatedat()
  +findScore()
}
class Member {
  -int score
  +boolean phone
  -boolean level
  #double note
  +createUpdatedat()
  +processAmount()
  +setCode()
  +calculateId()
}
class Loan {
  +String total
  #String address
  +updatePrice()
}
class Author {
  #boolean address
  -boolean phone
  -double amount
  +validatePrice()
  +updateNote()
  +validateCreatedat()
}
class Book {
  #long code
  -String price
  +int status
  +getLevel()
}
Branch --|> Book
Loan --o Shelf
Loan ..|> Branch
@enduml