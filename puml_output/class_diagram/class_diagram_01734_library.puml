@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
abstract class Shelf {
  +double duration
  +boolean email
  -int amount
  -int updatedAt
  +getDescription()
  +deleteActive()
}
class Branch {
  -String name
  #int status
  #long id
  +long quantity
  +validateDuration()
  +cancelScore()
  +processType()
}
class Member {
  #float active
  #boolean type
  -boolean total
  +findName()
}
class Loan {
  +String total
  #String address
  +getStatus()
}
class Author {
  #long phone
  -long amount
  #boolean active
  +String duration
  +setPrice()
  +setActive()
}
class Book {
  +int code
  +String amount
  -String updatedAt
  -double name
  +float duration
  +calculateLevel()
  +createCode()
}
Branch ..|> Shelf
Member --o Branch
Branch --o Loan
note right of Shelf : Library domain
@enduml