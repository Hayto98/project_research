@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
abstract class Customer {
  +double note
  #float phone
  +Date score
  +float status
  #int id
  +saveAmount()
  +setCreatedat()
}
class Route {
  +Date type
  +Date address
  #int total
  +double duration
  +String id
  +findLevel()
  +getEmail()
}
class Tracking {
  #int name
  #double active
  -String code
  +Date price
  +boolean total
  +saveDuration()
  +cancelEmail()
  +calculateAmount()
}
interface Vehicle {
  -Date price
  +Date active
  -String phone
  +validatePrice()
}
class Warehouse {
  +String createdAt
  #Date type
  #float total
  #Date note
  +updateAddress()
  +createPhone()
  +validateAddress()
  +setAmount()
}
interface Shipment {
  -boolean level
  #String createdAt
  #String id
  +validateNote()
}
Warehouse --* Customer
Route --> Vehicle : "1..*"
Tracking --* Shipment
Shipment ..> Route : "1"
@enduml