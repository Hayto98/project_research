@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
abstract class Customer {
  +double note
  #float phone
  +Date score
  +float status
  #int id
  +processAmount()
  +calculateType()
}
class Route {
  #boolean type
  +int score
  -String id
  +int amount
  +String level
  +getActive()
  +setPrice()
  +cancelActive()
  +calculateDuration()
}
class Tracking {
  #String quantity
  -boolean code
  #int updatedAt
  -boolean createdAt
  #Date address
  +calculateAmount()
  +findQuantity()
  +setCode()
}
class Vehicle {
  +String createdAt
  #Date type
  #float total
  #Date note
  +saveStatus()
  +createDuration()
  +cancelCreatedat()
  +cancelCreatedat()
}
class Warehouse {
  -boolean level
  +float code
  -int name
  -boolean score
  -long updatedAt
  +validateUpdatedat()
  +findStatus()
  +calculateName()
}
abstract class Shipment {
  #float amount
  +boolean quantity
  +double type
  #Date note
  #double id
  +setPrice()
  +deleteTotal()
  +cancelCode()
}
Customer --|> Shipment
Vehicle ..|> Warehouse
note right of Customer : Logistics domain
@enduml