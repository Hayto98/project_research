@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Shipment {
  +String quantity
  +Date phone
  #String id
  +double amount
  +setName()
  +cancelCode()
  +sendDescription()
}
class Invoice {
  #String duration
  -boolean address
  +boolean id
  -long status
  +float note
  +processNote()
}
class Payment {
  -Date phone
  #Date score
  +getActive()
  +deleteAddress()
  +createPhone()
  +updateLevel()
}
class Product {
  -String email
  +int updatedAt
  -int note
  -float status
  +int name
  +getActive()
  +validateCreatedat()
  +cancelDuration()
}
class Customer {
  #int duration
  +float code
  +Date status
  -long id
  -long level
  +sendId()
}
class Category {
  #long level
  -int code
  +sendAmount()
  +calculateName()
  +createCreatedat()
  +calculateAddress()
}
Category ..|> Invoice
Category --* Product
Shipment --|> Invoice
Invoice --o Category
Customer ..|> Category
@enduml