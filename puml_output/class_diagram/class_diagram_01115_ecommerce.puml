@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Shipment {
  +String quantity
  +Date phone
  #String id
  +double amount
  +getType()
  +deleteNote()
  +cancelAddress()
}
class Invoice {
  +float note
  -boolean level
  +cancelEmail()
}
class Payment {
  -boolean id
  -Date amount
  #Date status
  +findUpdatedat()
  +setQuantity()
  +findEmail()
  +saveType()
}
class Product {
  -String note
  +int status
  -int name
  +getAmount()
  +validateDescription()
  +saveAddress()
}
interface Customer {
  #int duration
  +float code
  +Date status
  -long id
  -long level
  +updateQuantity()
}
class Category {
  -int level
  -boolean phone
  +deleteAmount()
  +calculateUpdatedat()
  +updatePrice()
}
Shipment --|> Invoice
Invoice --o Category
Customer ..|> Category
Shipment ..> Product : "*"
note right of Shipment : Ecommerce domain
@enduml