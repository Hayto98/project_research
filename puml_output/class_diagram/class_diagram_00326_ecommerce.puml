@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
abstract class Invoice {
  +String price
  +String level
  -String type
  +float active
  +long duration
  +processLevel()
  +calculateName()
  +deleteLevel()
  +getEmail()
}
abstract class Product {
  #Date email
  #float total
  -String note
  -double code
  -Date score
  +cancelId()
  +validateAddress()
  +getQuantity()
  +updateId()
}
class Shipment {
  -String level
  +int code
  +findId()
  +getDuration()
}
class Supplier {
  +long score
  -boolean email
  -String createdAt
  +saveQuantity()
  +calculateDuration()
  +findAddress()
}
class Category {
  +boolean type
  +int id
  +updateActive()
  +updateTotal()
  +saveType()
  +createType()
}
Supplier ..|> Product
Supplier --|> Category
@enduml