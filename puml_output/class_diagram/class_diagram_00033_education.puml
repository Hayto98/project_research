@startuml

abstract class Enrollment {
  +float id
  +String updatedAt
  #int description
  +setId()
  +sendQuantity()
}
class Schedule {
  #boolean email
  #double phone
  +int price
  +saveCreatedat()
}
class Book {
  #double quantity
  +long note
  +int createdAt
  +int name
  #int id
  +cancelScore()
  +sendTotal()
  +getQuantity()
}
class Library {
  -boolean active
  -String duration
  -Date code
  +double price
  #String phone
  +calculateLevel()
  +processType()
  +validateName()
}
class Attendance {
  -Date id
  #float createdAt
  +setEmail()
  +sendAmount()
  +findActive()
}
Book --* Enrollment
Book --|> Library
Book --|> Attendance
note right of Enrollment : Education domain
@enduml