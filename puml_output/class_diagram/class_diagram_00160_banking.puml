@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Transaction {
  #String price
  -long note
  #long duration
  +validateCreatedat()
}
interface Statement {
  +boolean email
  -boolean price
  +findDescription()
}
interface Beneficiary {
  -float level
  +double duration
  #double amount
  #String address
  +cancelUpdatedat()
  +saveCreatedat()
  +cancelQuantity()
}
class Interest {
  +double amount
  +String address
  +getEmail()
  +createTotal()
  +calculateStatus()
  +saveAmount()
}
class Loan {
  +boolean total
  #boolean createdAt
  -long type
  -boolean id
  +validateScore()
  +findAddress()
  +getPrice()
}
class Account {
  -Date email
  #String type
  +savePrice()
  +validateEmail()
}
Statement --> Loan : "1"
Account --> Interest : "*"
Statement --o Transaction
Beneficiary --o Transaction
@enduml