@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Transaction {
  #String price
  -long note
  #long duration
  +deleteActive()
}
class Statement {
  #boolean price
  -boolean name
  #int email
  -long status
  +processTotal()
}
class Beneficiary {
  #int address
  -int note
  -int amount
  +double id
  +findNote()
  +createEmail()
}
abstract class Interest {
  #float type
  #boolean id
  -long name
  +cancelQuantity()
  +validateUpdatedat()
  +createStatus()
  +createType()
}
abstract class Loan {
  +double updatedAt
  +float level
  +findType()
}
interface Account {
  -int updatedAt
  #double code
  +int price
  +long phone
  -long status
  +deleteName()
  +savePhone()
  +setType()
}
Account --> Transaction : "*"
Loan --o Statement
note right of Transaction : Banking domain
@enduml