@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Warehouse {
  +float duration
  -Date createdAt
  #double level
  -boolean note
  #long type
  +createNote()
  +findPhone()
}
class Coupon {
  +float quantity
  +String id
  +double code
  -boolean duration
  #Date price
  +getLevel()
}
class Return {
  -Date level
  #String quantity
  -long id
  -double phone
  +findId()
}
abstract class Supplier {
  #boolean address
  -String total
  +sendQuantity()
  +updateDuration()
  +createTotal()
}
class Invoice {
  #long level
  +long duration
  -Date status
  +double name
  +long address
  +cancelEmail()
  +createCode()
  +cancelQuantity()
}
Invoice --o Return
Return --o Invoice
Coupon --o Return
Warehouse ..|> Supplier
note right of Warehouse : Ecommerce domain
@enduml