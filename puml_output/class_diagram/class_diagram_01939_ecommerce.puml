@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Warehouse {
  +float duration
  -Date createdAt
  #double level
  -boolean note
  #long type
  +findScore()
  +deleteDuration()
}
class Coupon {
  #boolean price
  -float quantity
  #float id
  -String code
  +setStatus()
  +findAddress()
}
abstract class Return {
  #long level
  #long active
  +long name
  -Date id
  #String address
  +findCode()
  +getStatus()
  +sendCreatedat()
}
abstract class Supplier {
  +long id
  #double note
  +validatePhone()
  +processScore()
  +getNote()
}
interface Invoice {
  -boolean createdAt
  #String email
  +boolean total
  -boolean description
  +calculateNote()
  +updateLevel()
  +calculateName()
}
Coupon ..|> Supplier
Return --> Invoice : "1..*"
Return --> Warehouse : "1..*"
Invoice --o Return
@enduml