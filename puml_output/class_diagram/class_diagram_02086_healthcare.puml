@startuml
skinparam monochrome true
skinparam ArrowColor #555555
interface LabTest {
  #boolean active
  -float email
  +cancelName()
  +cancelNote()
  +calculateScore()
}
class Hospital {
  -Date updatedAt
  -float phone
  +Date status
  #Date score
  +Date amount
  +deleteNote()
  +createNote()
}
class Diagnosis {
  -Date id
  #Date total
  -int price
  -float updatedAt
  +cancelAmount()
  +getCode()
}
interface Treatment {
  #float updatedAt
  -long email
  +float address
  +long description
  +setQuantity()
  +cancelStatus()
}
interface Doctor {
  +String duration
  +boolean address
  #Date active
  -int level
  #float score
  +sendNote()
}
class Billing {
  #boolean type
  +double price
  -String quantity
  +findScore()
  +validateEmail()
}
LabTest --* Doctor
Billing ..> Diagnosis : "1"
Hospital ..> Billing : "*"
@enduml