@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
interface Beneficiary {
  -String price
  #String code
  +boolean address
  #float score
  +calculateCode()
}
abstract class Customer {
  #float score
  #Date phone
  #long total
  #double price
  #boolean quantity
  +deleteActive()
  +saveCreatedat()
}
class Teller {
  #long code
  +boolean type
  -double updatedAt
  +sendLevel()
  +processPrice()
  +getCode()
  +processTotal()
}
class Loan {
  +Date code
  #int email
  +calculateCreatedat()
  +processName()
  +calculateTotal()
  +calculateType()
}
class Withdrawal {
  #String code
  -double address
  +Date id
  +getId()
  +deleteQuantity()
  +updateEmail()
  +setEmail()
}
class Transaction {
  #Date type
  #double createdAt
  #Date price
  #String amount
  +getAddress()
  +deleteType()
}
class Branch {
  -double name
  +float total
  #Date type
  +updateQuantity()
  +setLevel()
  +createActive()
}
Beneficiary --> Transaction : "1..*"
Branch --o Beneficiary
Beneficiary --o Loan
Loan ..|> Withdrawal
Branch --|> Loan
@enduml