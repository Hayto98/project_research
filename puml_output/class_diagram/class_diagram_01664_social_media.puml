@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
abstract class Hashtag {
  -Date phone
  #float level
  +cancelLevel()
  +getType()
  +saveUpdatedat()
}
class Profile {
  #long score
  +String price
  +createCode()
  +cancelActive()
  +cancelAmount()
  +setDuration()
}
class Message {
  -double score
  -boolean duration
  -boolean active
  -boolean email
  +updateNote()
}
class Like {
  +double status
  +Date description
  +long level
  +float type
  +getDuration()
  +createEmail()
  +processUpdatedat()
  +validateDuration()
}
interface Follower {
  +Date amount
  -long score
  +getId()
}
class User {
  -String price
  -int total
  +createTotal()
  +updatePhone()
  +processDescription()
}
interface Post {
  -double description
  #String note
  #long type
  +deleteActive()
}
Follower --|> Profile
Post ..|> Profile
Message ..> Hashtag : "*"
note right of Hashtag : Social Media domain
@enduml