@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
abstract class Hashtag {
  -Date phone
  #float level
  +savePrice()
  +cancelLevel()
  +updateActive()
}
abstract class Profile {
  -boolean description
  -float id
  +String score
  +validateAmount()
  +getLevel()
  +savePrice()
  +calculateActive()
}
interface Message {
  #boolean code
  #boolean createdAt
  #boolean quantity
  +findAmount()
  +setNote()
  +saveName()
}
interface Like {
  #double active
  +long address
  +int score
  +float code
  -String updatedAt
  +validateNote()
  +deleteType()
  +saveNote()
  +processStatus()
}
class Follower {
  -boolean id
  #float email
  #boolean level
  +int type
  #int updatedAt
  +setDuration()
  +cancelAddress()
  +processName()
  +validateDescription()
}
class User {
  -double createdAt
  -String name
  +deleteScore()
  +validateAddress()
  +saveType()
}
class Post {
  +double createdAt
  -long phone
  -Date type
  +boolean description
  -String duration
  +createDescription()
  +getAmount()
}
Follower --|> Profile
Post ..|> Profile
Message ..> Hashtag : "*"
@enduml