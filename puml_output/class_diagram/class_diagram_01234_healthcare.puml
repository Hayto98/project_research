@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Billing {
  #Date status
  #int amount
  +getDescription()
}
class Nurse {
  -int level
  #Date updatedAt
  +Date address
  -float duration
  +int active
  +cancelUpdatedat()
  +saveEmail()
  +findTotal()
  +validateActive()
}
class Hospital {
  +String name
  +long note
  +boolean type
  +saveScore()
  +cancelDuration()
}
class Insurance {
  #long id
  +long quantity
  +Date phone
  #long updatedAt
  +deleteCode()
  +saveAddress()
  +cancelDescription()
  +createLevel()
}
interface Patient {
  +long type
  -long updatedAt
  #boolean name
  +findAddress()
  +sendType()
  +getQuantity()
  +sendScore()
}
class Treatment {
  +boolean id
  -boolean address
  +float description
  +Date duration
  +updateDescription()
  +calculateDuration()
  +createStatus()
}
class Doctor {
  +double level
  -Date type
  -Date status
  +String code
  +Date email
  +sendCode()
  +validateScore()
  +createType()
}
Hospital --* Patient
Nurse --o Doctor
Billing --o Hospital
Insurance --|> Patient
Patient --|> Billing
@enduml