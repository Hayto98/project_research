@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Billing {
  #Date status
  #int amount
  +updateTotal()
}
interface Nurse {
  -int address
  #Date updatedAt
  +Date level
  +getDescription()
  +calculateName()
  +cancelEmail()
}
interface Hospital {
  +String name
  +long note
  +boolean type
  +validateName()
  +saveAddress()
}
class Insurance {
  +long phone
  +Date score
  #long updatedAt
  #double duration
  +deleteLevel()
  +cancelCreatedat()
  +processUpdatedat()
}
class Patient {
  #boolean quantity
  #double type
  +boolean address
  +deleteDuration()
  +saveAddress()
  +getAddress()
  +deleteId()
}
class Treatment {
  +boolean level
  #String createdAt
  -boolean amount
  -String quantity
  +createAmount()
}
abstract class Doctor {
  -long total
  #double id
  -boolean name
  -int status
  +float phone
  +setAddress()
  +processTotal()
  +cancelCode()
  +cancelName()
}
Hospital --* Nurse
Billing --|> Insurance
note right of Billing : Healthcare domain
@enduml