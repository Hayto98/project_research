@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Prescription {
  +double score
  -String id
  #Date level
  #String active
  #String updatedAt
  +validateScore()
  +deleteLevel()
}
class Nurse {
  -String code
  -double level
  +getCode()
  +findNote()
  +saveType()
  +calculateScore()
}
class Hospital {
  +boolean status
  +Date duration
  +calculateLevel()
  +setName()
}
abstract class Diagnosis {
  #float id
  -float note
  -double amount
  +float level
  +setPhone()
  +findUpdatedat()
  +sendCode()
}
abstract class MedicalRecord {
  +long price
  #float updatedAt
  +float score
  #boolean active
  +double status
  +setActive()
}
interface Billing {
  #int amount
  #boolean total
  +boolean phone
  -String name
  #float score
  +validateStatus()
  +getCode()
  +deleteId()
  +validateAmount()
}
class Treatment {
  -boolean level
  #Date email
  #float status
  -String phone
  +boolean code
  +createAddress()
  +findPrice()
  +calculateAddress()
  +cancelDuration()
}
Nurse ..> Prescription : "1..*"
Diagnosis --* Billing
Nurse --|> Diagnosis
@enduml