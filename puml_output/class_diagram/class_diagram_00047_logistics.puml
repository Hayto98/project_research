@startuml
skinparam defaultFontSize 11
interface Depot {
  #boolean createdAt
  #int duration
  +validateUpdatedat()
  +getLevel()
}
abstract class Route {
  -boolean price
  +long code
  #int updatedAt
  +validateNote()
  +saveDescription()
}
class Customer {
  +Date quantity
  #long updatedAt
  +boolean score
  -Date amount
  +setPrice()
  +findTotal()
  +processType()
}
class Driver {
  -int description
  +float amount
  -double active
  +saveId()
  +calculateCode()
  +findLevel()
  +setEmail()
}
abstract class FuelLog {
  +boolean id
  +double name
  +Date code
  -Date quantity
  -float duration
  +cancelId()
  +setDuration()
}
class Vehicle {
  -long phone
  +int duration
  -boolean level
  -int price
  #int createdAt
  +findUpdatedat()
}
Depot --> Route : "1"
Vehicle --o FuelLog
Route --* FuelLog
Customer --* Route
@enduml