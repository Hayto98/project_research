@startuml
skinparam monochrome true
skinparam defaultFontSize 11
abstract class Doctor {
  +String name
  #float code
  -Date id
  +validateQuantity()
  +calculateTotal()
}
class Appointment {
  -boolean type
  -double name
  +processPrice()
  +sendCode()
  +setScore()
}
class MedicalRecord {
  -double type
  -boolean active
  +updateCreatedat()
}
interface Hospital {
  +double description
  -boolean score
  +Date email
  +sendEmail()
  +updatePrice()
  +calculateLevel()
}
class Diagnosis {
  #String active
  +String price
  +findActive()
}
class Treatment {
  -long status
  +long name
  -String phone
  +String total
  +long code
  +createName()
  +createStatus()
}
class Billing {
  -Date updatedAt
  +Date status
  +saveId()
  +processCreatedat()
  +saveEmail()
}
Billing ..> Hospital : "*"
Diagnosis ..|> MedicalRecord
Treatment ..> Hospital : "0..1"
Appointment --|> Billing
MedicalRecord ..> Appointment : "*"
@enduml