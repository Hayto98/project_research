@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
interface Interest {
  #boolean code
  #float level
  +double createdAt
  +boolean price
  +deleteCreatedat()
  +processQuantity()
}
abstract class Branch {
  -boolean amount
  -int price
  +Date updatedAt
  +int total
  -Date description
  +updateAddress()
  +findTotal()
  +sendScore()
  +createActive()
}
class Transfer {
  +int level
  +float type
  +double description
  #int phone
  -double address
  +getCode()
  +setPrice()
}
interface Statement {
  #boolean name
  #boolean score
  +double type
  #long updatedAt
  +updateTotal()
}
class Loan {
  -int price
  +long amount
  #float type
  +validateUpdatedat()
  +setUpdatedat()
  +calculateLevel()
  +getQuantity()
}
Statement ..> Interest : "1..*"
Branch ..> Loan : "1"
note right of Interest : Banking domain
@enduml