@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
interface Interest {
  #boolean code
  #float level
  +double createdAt
  +boolean price
  +createCreatedat()
  +updateQuantity()
}
class Branch {
  +double quantity
  #Date price
  +double total
  #double amount
  +String level
  +deleteScore()
  +processDescription()
}
abstract class Transfer {
  #long address
  #long total
  #double active
  +createTotal()
  +getEmail()
  +findCode()
  +findLevel()
}
class Statement {
  -Date updatedAt
  +long code
  -int level
  +createAddress()
}
class Loan {
  #boolean active
  #boolean address
  +double name
  #long type
  +int updatedAt
  +updateDuration()
  +sendQuantity()
  +findId()
  +createPrice()
}
Branch --* Statement
Branch --* Interest
Statement ..|> Transfer
Interest --o Branch
@enduml