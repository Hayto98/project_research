@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Loan {
  +Date address
  #Date code
  +String id
  -double active
  #boolean quantity
  +calculateCreatedat()
  +createAmount()
}
class Account {
  #float level
  +double updatedAt
  #boolean email
  +long createdAt
  -Date id
  +getQuantity()
  +saveScore()
}
class Transfer {
  #float name
  #double createdAt
  -String note
  -int code
  +saveDescription()
}
interface Deposit {
  #int code
  #float type
  +int address
  +findId()
  +createAmount()
  +getScore()
}
Account --o Transfer
Transfer --* Loan
note right of Loan : Banking domain
@enduml