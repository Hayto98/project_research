@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Loan {
  +Date address
  #Date code
  +String id
  -double active
  #boolean quantity
  +findAmount()
  +createEmail()
}
class Account {
  -float amount
  +String createdAt
  #float total
  +double updatedAt
  +findQuantity()
  +calculatePhone()
}
class Transfer {
  +Date quantity
  -String score
  +sendCode()
  +validatePhone()
}
interface Deposit {
  #Date quantity
  +boolean code
  #boolean type
  #int amount
  +double name
  +saveType()
  +validateType()
  +calculateStatus()
}
Account --* Loan
Loan ..|> Account
@enduml