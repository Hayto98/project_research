@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Enrollment {
  -int code
  -float description
  -long phone
  +getQuantity()
  +getUpdatedat()
  +sendPrice()
  +sendTotal()
}
class Assignment {
  -long name
  +long code
  +double phone
  #String id
  +updateTotal()
  +cancelDescription()
}
class Attendance {
  +String email
  #Date amount
  +sendScore()
}
abstract class Classroom {
  #long score
  -Date name
  +cancelDuration()
  +sendPhone()
  +cancelStatus()
}
class Book {
  +boolean active
  -String phone
  #double address
  -double status
  +setName()
  +sendAmount()
  +getPhone()
  +findDuration()
}
Classroom --o Assignment
Attendance ..> Enrollment : "1..*"
Book --o Classroom
note right of Enrollment : Education domain
@enduml