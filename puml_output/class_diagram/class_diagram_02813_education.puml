@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Enrollment {
  -int code
  -float description
  -long phone
  +deleteNote()
  +findType()
  +calculatePhone()
  +processName()
}
class Assignment {
  #Date active
  +float total
  -String address
  -long score
  +long name
  +createPrice()
  +saveActive()
}
class Attendance {
  +Date createdAt
  +long total
  +float description
  +setDuration()
  +getLevel()
}
interface Classroom {
  -String active
  #String score
  +sendStatus()
  +createId()
  +setEmail()
}
class Book {
  #long duration
  #Date status
  -String phone
  +boolean score
  +sendTotal()
  +updateScore()
  +sendScore()
  +updateTotal()
}
Classroom --|> Enrollment
Book --|> Assignment
Attendance ..|> Classroom
@enduml