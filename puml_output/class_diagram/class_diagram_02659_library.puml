@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Book {
  +float price
  -int level
  +int score
  -float updatedAt
  +deleteAmount()
  +updateDescription()
  +cancelTotal()
  +getCreatedat()
}
class Fine {
  #long note
  -long address
  +sendLevel()
  +setNote()
  +sendAddress()
}
interface Renewal {
  -Date name
  #String id
  +cancelStatus()
  +setId()
  +cancelUpdatedat()
}
interface Librarian {
  -String duration
  #String quantity
  -double id
  +createUpdatedat()
  +validatePhone()
}
class Reservation {
  +boolean createdAt
  #long type
  +String amount
  -long note
  +getAddress()
  +saveAmount()
  +saveEmail()
  +updateType()
}
interface Publisher {
  +boolean quantity
  +float createdAt
  #double price
  +calculatePhone()
  +updateAddress()
  +updateAmount()
  +findPhone()
}
Book --> Reservation : "*"
Fine ..|> Reservation
Renewal --> Publisher : "0..1"
note right of Book : Library domain
@enduml