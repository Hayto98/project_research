@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Book {
  +float price
  -int level
  +int score
  -float updatedAt
  +processScore()
  +findPhone()
  +deleteType()
  +deleteScore()
}
class Fine {
  +long level
  +double total
  #long id
  +findLevel()
  +calculateQuantity()
  +saveScore()
}
class Renewal {
  -float note
  #boolean active
  +deleteNote()
}
class Librarian {
  #String id
  #int email
  #float status
  +boolean score
  +setName()
  +deleteCode()
  +setUpdatedat()
}
class Reservation {
  -long total
  -float updatedAt
  -int email
  -float level
  +calculateAmount()
  +createEmail()
}
class Publisher {
  #double status
  +long code
  #Date email
  +Date score
  +getTotal()
  +findActive()
  +processId()
}
Renewal ..> Fine : "*"
Fine ..|> Reservation
Reservation --o Librarian
@enduml