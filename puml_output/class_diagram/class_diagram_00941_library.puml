@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
abstract class Member {
  +long total
  -String email
  +double code
  +createAddress()
  +calculateDescription()
  +validateStatus()
}
class Renewal {
  -int email
  -Date price
  -boolean quantity
  #boolean type
  +float description
  +createStatus()
  +getTotal()
  +saveCreatedat()
}
abstract class Shelf {
  #float status
  -Date amount
  +sendAmount()
  +getCode()
  +getCode()
}
abstract class Loan {
  +boolean phone
  -String code
  +validateCode()
  +getUpdatedat()
  +validateDescription()
  +saveLevel()
}
class Author {
  #long price
  +long email
  #double description
  +int score
  +long updatedAt
  +getQuantity()
  +calculateQuantity()
  +setAmount()
  +validateStatus()
}
class Fine {
  +Date code
  +float note
  +int price
  -int total
  +saveScore()
  +setAddress()
  +saveDuration()
  +createScore()
}
interface Branch {
  #double name
  -double address
  -boolean phone
  -float type
  #int duration
  +cancelTotal()
  +cancelCreatedat()
  +cancelAmount()
}
Branch --|> Shelf
Member ..> Fine : "1"
Fine ..|> Loan
note right of Member : Library domain
@enduml