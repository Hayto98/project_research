@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
abstract class Member {
  +long total
  -String email
  +double code
  +setTotal()
  +saveCreatedat()
  +saveCode()
}
class Renewal {
  -Date status
  -double amount
  +double total
  +long email
  +findDuration()
  +findUpdatedat()
  +createDescription()
}
class Shelf {
  #int email
  #double status
  +String id
  +Date total
  +cancelUpdatedat()
  +calculateName()
  +processAddress()
}
interface Loan {
  +double id
  +Date code
  -String name
  +findUpdatedat()
  +saveCreatedat()
}
class Author {
  +float address
  #boolean code
  +double name
  -float updatedAt
  -Date phone
  +findStatus()
  +setType()
}
class Fine {
  +int id
  +long quantity
  #double score
  +long note
  +setQuantity()
  +deleteStatus()
  +updateLevel()
  +setStatus()
}
class Branch {
  -double status
  #float id
  -int quantity
  #String code
  +getTotal()
}
Renewal ..> Loan : "1"
Fine ..> Shelf : "1..*"
Branch --> Fine : "*"
Fine --* Member
Branch --o Shelf
@enduml