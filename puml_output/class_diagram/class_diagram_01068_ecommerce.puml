@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Coupon {
  #double price
  +double amount
  +int email
  -long level
  -int id
  +createId()
  +setPrice()
  +saveStatus()
  +createPhone()
}
class Invoice {
  +double active
  #boolean quantity
  +float email
  #boolean id
  #double score
  +getAddress()
}
class Cart {
  +boolean type
  +float level
  #String status
  +setType()
  +sendActive()
  +findLevel()
  +saveScore()
}
class Return {
  #double email
  +int active
  +String code
  #Date duration
  +createCreatedat()
  +calculateNote()
}
class Category {
  -float updatedAt
  -int phone
  #boolean duration
  +findType()
  +getDescription()
  +getUpdatedat()
  +sendTotal()
}
abstract class Payment {
  +boolean quantity
  +Date address
  +Date type
  +float createdAt
  +getPrice()
}
class Supplier {
  +double level
  -String active
  #Date note
  +boolean email
  +saveName()
  +sendQuantity()
  +updateCode()
}
Payment ..|> Category
Invoice ..|> Category
Return --|> Supplier
Coupon ..|> Payment
Supplier --> Coupon : "0..1"
note right of Coupon : Ecommerce domain
@enduml