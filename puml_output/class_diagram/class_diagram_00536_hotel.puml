@startuml
skinparam shadowing true
class CheckOut {
  -long phone
  #int code
  -String duration
  +updateId()
  +updateScore()
}
class Restaurant {
  -int duration
  #String description
  +calculateName()
  +sendDuration()
  +createStatus()
}
abstract class Amenity {
  #double createdAt
  +int score
  -String total
  +createTotal()
  +processCode()
  +processPhone()
  +processActive()
}
abstract class Reservation {
  +String updatedAt
  +Date description
  +validateActive()
  +calculateUpdatedat()
  +updateType()
}
interface Housekeeping {
  +float active
  -boolean code
  #float phone
  +processDescription()
  +getCode()
  +setPrice()
  +setAddress()
}
interface Booking {
  -long status
  +Date address
  -double createdAt
  #float active
  +calculateQuantity()
  +deleteCode()
}
class Room {
  -int email
  -double note
  +float description
  -float score
  +deletePrice()
  +cancelPhone()
  +updatePhone()
}
Amenity --o Restaurant
Room ..> CheckOut : "0..1"
Booking ..> Housekeeping : "1"
Restaurant ..> Housekeeping : "*"
CheckOut ..|> Reservation
@enduml