@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Publisher {
  -boolean id
  -String address
  #double email
  #long createdAt
  -double status
  +deleteScore()
}
interface Shelf {
  +float code
  -float status
  -long active
  +float updatedAt
  #double id
  +createPhone()
  +sendId()
}
class Fine {
  #String note
  +String status
  -float price
  +long level
  -float phone
  +setUpdatedat()
  +getScore()
  +sendPhone()
  +deleteAddress()
}
abstract class Renewal {
  +String description
  #boolean address
  #String name
  -String amount
  -Date total
  +calculateName()
  +deleteDuration()
  +setCode()
}
class Author {
  #float email
  +float amount
  #boolean level
  +validateTotal()
  +saveEmail()
  +findPrice()
  +saveDescription()
}
Publisher --> Fine : "0..1"
Shelf --|> Publisher
@enduml