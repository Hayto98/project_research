@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
abstract class Branch {
  #long phone
  -boolean status
  +processScore()
  +createId()
  +deleteScore()
  +processNote()
}
interface Fine {
  +long score
  +String updatedAt
  +updateQuantity()
}
class Librarian {
  #Date status
  -boolean amount
  +Date address
  #Date phone
  #boolean updatedAt
  +setType()
}
abstract class Catalog {
  #boolean active
  #String name
  #String price
  +int total
  -double type
  +sendCode()
}
class Renewal {
  #int email
  #int note
  +double name
  -int price
  +getStatus()
  +findStatus()
}
abstract class Author {
  -float updatedAt
  -boolean total
  +processDescription()
  +findPrice()
  +createPrice()
}
abstract class Reservation {
  #long type
  #double name
  +Date quantity
  +long address
  +cancelAmount()
  +updateName()
  +findCode()
  +getCreatedat()
}
Renewal ..> Branch : "*"
Renewal --o Fine
@enduml