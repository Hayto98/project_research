@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
abstract class Branch {
  #long phone
  -boolean status
  +deleteActive()
  +setScore()
  +updateAmount()
  +validateId()
}
class Fine {
  +Date address
  +float type
  +validateUpdatedat()
  +findEmail()
  +sendCreatedat()
}
interface Librarian {
  -boolean description
  +double price
  +processActive()
  +findName()
  +cancelName()
  +getAmount()
}
class Catalog {
  -float code
  #String note
  #double name
  #int quantity
  #int email
  +processNote()
  +deleteAmount()
}
abstract class Renewal {
  -float updatedAt
  -boolean total
  +createActive()
  +calculateType()
  +createType()
}
class Author {
  +Date address
  +long quantity
  -boolean score
  +long type
  +cancelName()
}
abstract class Reservation {
  +boolean type
  +boolean name
  +String status
  +setId()
}
Renewal ..> Fine : "1..*"
Author --|> Librarian
Branch ..> Author : "*"
note right of Branch : Library domain
@enduml