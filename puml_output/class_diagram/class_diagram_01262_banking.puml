@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
abstract class Loan {
  +String phone
  -long code
  #long total
  +Date duration
  -double note
  +calculateName()
}
class Customer {
  +Date duration
  -float name
  +deleteNote()
}
class Card {
  +Date createdAt
  -Date code
  -Date address
  -boolean duration
  +findUpdatedat()
}
abstract class Withdrawal {
  #boolean amount
  -Date score
  +createPhone()
}
abstract class Transfer {
  +String quantity
  #float level
  +boolean total
  +sendStatus()
  +createAddress()
}
Customer --> Withdrawal : "0..1"
Transfer --* Customer
@enduml