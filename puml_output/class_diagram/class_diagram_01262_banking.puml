@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
abstract class Loan {
  +String phone
  -long code
  #long total
  +Date duration
  -double note
  +validateName()
}
class Customer {
  +String updatedAt
  +long total
  +setAddress()
  +updateAmount()
}
class Card {
  #boolean email
  #long name
  #String price
  +double code
  +long amount
  +setId()
  +findUpdatedat()
  +sendUpdatedat()
  +setDescription()
}
class Withdrawal {
  -String duration
  -float createdAt
  #int score
  +String description
  #float phone
  +sendActive()
}
abstract class Transfer {
  -long amount
  #long email
  -long name
  +deleteId()
  +getScore()
  +processAddress()
  +deleteUpdatedat()
}
Customer --> Card : "1..*"
Withdrawal --o Loan
note right of Loan : Banking domain
@enduml