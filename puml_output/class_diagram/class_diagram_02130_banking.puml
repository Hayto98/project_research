@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
interface Transaction {
  #double address
  +int createdAt
  +Date amount
  -Date name
  +createTotal()
  +sendNote()
  +sendUpdatedat()
}
class Deposit {
  #Date address
  #Date code
  #String amount
  +boolean email
  +findNote()
  +processPrice()
  +validateQuantity()
}
class Withdrawal {
  -boolean email
  +Date status
  #boolean phone
  +getAmount()
}
abstract class Account {
  #long updatedAt
  +boolean createdAt
  +boolean phone
  -float price
  -int address
  +deleteEmail()
  +cancelActive()
  +getName()
}
interface Transfer {
  -int amount
  #Date type
  +boolean code
  +double price
  +saveAmount()
}
Withdrawal --> Account : "1..*"
Account ..> Transfer : "0..1"
Transaction ..|> Transfer
@enduml