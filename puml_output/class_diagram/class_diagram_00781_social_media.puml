@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
abstract class Hashtag {
  #int email
  +int total
  #boolean note
  #float name
  +int createdAt
  +sendAmount()
  +setNote()
  +deleteId()
}
class Report {
  +float type
  +float phone
  +createDescription()
  +findType()
}
class Follower {
  +long quantity
  -int createdAt
  +boolean phone
  +String note
  #int amount
  +deleteNote()
}
class Profile {
  #float address
  +int code
  #boolean score
  #double quantity
  +setScore()
  +getAddress()
  +setDuration()
}
class Like {
  #boolean type
  +float price
  +boolean active
  +setAmount()
}
interface User {
  #boolean description
  #int address
  +createTotal()
}
class Notification {
  -long note
  #boolean active
  -float duration
  #double code
  -double amount
  +deleteAddress()
  +cancelPrice()
}
Notification ..> Report : "*"
Notification ..> Follower : "*"
Profile --> Hashtag : "0..1"
Profile --|> Notification
Report --* Notification
@enduml