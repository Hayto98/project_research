@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
abstract class Hashtag {
  #int email
  +int total
  #boolean note
  #float name
  +int createdAt
  +sendTotal()
  +validateName()
  +processPhone()
}
class Report {
  -Date updatedAt
  -float active
  #float duration
  +savePhone()
  +processAmount()
}
class Follower {
  +boolean phone
  +boolean amount
  +String status
  +long updatedAt
  +setScore()
  +createAmount()
  +updateActive()
}
interface Profile {
  -boolean email
  #boolean total
  +float duration
  +boolean updatedAt
  +float type
  +deleteAddress()
}
interface Like {
  -boolean code
  -String createdAt
  +long note
  +sendDuration()
  +createLevel()
  +processPrice()
}
abstract class User {
  #double updatedAt
  -Date total
  #double description
  +getLevel()
  +sendLevel()
  +saveAmount()
  +calculateTotal()
}
class Notification {
  -long amount
  #boolean quantity
  #Date total
  +cancelId()
}
Like --> Profile : "1..*"
User ..> Like : "0..1"
Like ..> Hashtag : "*"
note right of Hashtag : Social Media domain
@enduml