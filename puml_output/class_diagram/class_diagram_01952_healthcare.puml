@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Treatment {
  #float price
  +float total
  #Date score
  +String createdAt
  +deleteDuration()
  +sendTotal()
  +sendAddress()
}
class MedicalRecord {
  #long updatedAt
  -float phone
  -Date active
  +Date description
  +findEmail()
  +createUpdatedat()
  +cancelCode()
  +sendActive()
}
class Patient {
  +boolean updatedAt
  -int level
  +cancelType()
  +saveId()
  +setId()
  +sendAddress()
}
class Appointment {
  -float level
  #int updatedAt
  -String amount
  +cancelEmail()
}
class Insurance {
  -long name
  #float status
  -double level
  -boolean score
  -Date type
  +deleteId()
  +findLevel()
  +findPrice()
  +validateCode()
}
class LabTest {
  -int code
  +Date address
  -float active
  #float quantity
  #int id
  +sendDescription()
  +getName()
}
abstract class Prescription {
  #Date total
  -double note
  #double description
  +float createdAt
  +deleteLevel()
  +deleteAddress()
}
Prescription ..|> Patient
Appointment --o Treatment
Insurance --* Patient
Insurance --> LabTest : "1..*"
LabTest --o Appointment
note right of Treatment : Healthcare domain
@enduml