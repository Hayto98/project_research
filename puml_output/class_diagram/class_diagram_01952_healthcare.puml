@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Treatment {
  #float price
  +float total
  #Date score
  +String createdAt
  +validateCode()
  +setId()
  +setActive()
}
interface MedicalRecord {
  #Date active
  #long address
  #float status
  +boolean phone
  -long updatedAt
  +updateAddress()
  +cancelNote()
  +deleteType()
  +processEmail()
}
abstract class Patient {
  +float quantity
  +int updatedAt
  #String code
  #double active
  +processLevel()
  +getCode()
}
abstract class Appointment {
  #long code
  #long id
  +setScore()
  +setCreatedat()
}
interface Insurance {
  -String amount
  #String total
  #long description
  +cancelQuantity()
}
class LabTest {
  +float duration
  -double status
  +cancelUpdatedat()
  +cancelLevel()
  +deleteTotal()
}
class Prescription {
  +Date type
  #boolean email
  #double score
  -String price
  +float amount
  +validatePhone()
  +setEmail()
  +processPhone()
  +createUpdatedat()
}
Patient --> LabTest : "1"
Appointment --|> MedicalRecord
LabTest ..> Appointment : "0..1"
MedicalRecord ..|> Insurance
Treatment --o Prescription
Patient --o Appointment
@enduml