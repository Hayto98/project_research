@startuml
skinparam shadowing true
class Coupon {
  -boolean quantity
  #Date score
  #float price
  +calculateDuration()
  +getPrice()
}
class Category {
  #Date total
  -Date level
  +getQuantity()
}
abstract class Product {
  +float address
  +Date total
  -boolean level
  #int type
  +validateCreatedat()
  +saveQuantity()
  +getAmount()
  +getQuantity()
}
interface Customer {
  #float active
  #boolean createdAt
  -double address
  #Date description
  +calculateStatus()
}
class Review {
  -double score
  -long address
  -long updatedAt
  #double createdAt
  +float level
  +cancelName()
}
interface Supplier {
  +String address
  +long type
  +double phone
  +sendName()
  +validateCreatedat()
  +sendCreatedat()
  +findAmount()
}
interface Warehouse {
  +int updatedAt
  #boolean email
  #Date status
  +createPhone()
  +deleteId()
  +calculateNote()
}
Category --|> Customer
Customer --* Coupon
Category --* Coupon
@enduml