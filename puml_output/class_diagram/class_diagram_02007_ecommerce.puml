@startuml
skinparam shadowing true
class Coupon {
  -boolean quantity
  #Date score
  #float price
  +sendDescription()
  +setTotal()
}
interface Category {
  #boolean status
  -double total
  -int quantity
  +Date address
  +cancelUpdatedat()
  +processDescription()
  +deleteDuration()
  +cancelQuantity()
}
interface Product {
  #float address
  -double description
  #Date score
  +findAddress()
}
interface Customer {
  -double score
  -long address
  -long updatedAt
  #double createdAt
  +float level
  +findScore()
}
class Review {
  +long type
  +double phone
  -double name
  +double status
  +sendDescription()
  +updateEmail()
  +setAmount()
  +updateActive()
}
class Supplier {
  +double createdAt
  +double updatedAt
  +createUpdatedat()
}
class Warehouse {
  #int phone
  #String level
  -double status
  -double amount
  +sendAddress()
  +findDescription()
  +createPhone()
  +setAmount()
}
Coupon --> Review : "1"
Product ..> Supplier : "1"
Coupon --* Supplier
Warehouse --> Coupon : "1..*"
note right of Coupon : Ecommerce domain
@enduml