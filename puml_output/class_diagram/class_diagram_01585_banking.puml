@startuml
skinparam monochrome true
skinparam defaultFontSize 13
abstract class Interest {
  +double amount
  #long active
  +setAmount()
  +createActive()
}
interface Branch {
  #int email
  #long duration
  +getId()
  +setLevel()
  +validateActive()
  +validateId()
}
class Customer {
  #boolean quantity
  -String level
  -float amount
  +calculateNote()
  +updateLevel()
  +createType()
}
class Beneficiary {
  -String type
  +long active
  +deleteDuration()
  +findPrice()
}
Branch ..|> Interest
Customer --o Beneficiary
note right of Interest : Banking domain
@enduml