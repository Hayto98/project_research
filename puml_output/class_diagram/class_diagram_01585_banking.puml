@startuml
skinparam monochrome true
skinparam defaultFontSize 13
abstract class Interest {
  +double amount
  #long active
  +createPhone()
  +saveAddress()
}
class Branch {
  #int email
  #long duration
  +updateDuration()
  +cancelTotal()
  +getType()
  +updateId()
}
interface Customer {
  +long active
  #Date address
  #int id
  #boolean quantity
  +updateName()
  +cancelCreatedat()
  +createId()
  +getQuantity()
}
class Beneficiary {
  +double note
  #double createdAt
  +float email
  +long type
  #boolean quantity
  +findEmail()
  +processUpdatedat()
}
Branch --|> Interest
Branch --> Beneficiary : "*"
@enduml