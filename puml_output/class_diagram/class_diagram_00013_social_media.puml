@startuml
skinparam defaultFontSize 11
class Report {
  -Date description
  +String address
  +Date score
  +saveStatus()
}
class Hashtag {
  -String quantity
  -long name
  +boolean phone
  +processId()
  +findId()
  +updateStatus()
}
class Album {
  +long address
  #int id
  +long score
  +long duration
  -boolean updatedAt
  +setCode()
  +getEmail()
}
class Notification {
  +double level
  +String total
  +int active
  +updatePhone()
  +updateActive()
  +deleteStatus()
}
Album --> Notification : "1"
Hashtag ..> Notification : "1..*"
Notification --|> Hashtag
@enduml