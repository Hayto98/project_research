@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Beneficiary {
  #float duration
  #int id
  +saveType()
  +updateActive()
  +deleteId()
  +processActive()
}
class Statement {
  #float id
  +long amount
  +int level
  +processDescription()
}
class Transfer {
  #double updatedAt
  #double name
  +updateScore()
}
class Teller {
  -double note
  -int quantity
  +boolean amount
  #float email
  +long total
  +createAmount()
  +deletePrice()
  +processAddress()
  +calculateStatus()
}
class Withdrawal {
  +long total
  #boolean amount
  -float level
  +int price
  -int status
  +calculateStatus()
  +deleteName()
}
class Interest {
  +String id
  -float name
  +calculatePrice()
}
class Deposit {
  -boolean active
  -boolean address
  +cancelCode()
  +getScore()
}
Statement ..> Transfer : "0..1"
Interest ..> Statement : "*"
Statement --> Interest : "*"
Teller ..> Withdrawal : "1..*"
Transfer --> Withdrawal : "0..1"
@enduml