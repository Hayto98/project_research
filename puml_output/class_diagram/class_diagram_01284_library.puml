@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Fine {
  #String phone
  -Date duration
  #Date email
  +double note
  -boolean score
  +sendLevel()
  +setPhone()
  +validateDescription()
}
interface Branch {
  -double status
  -boolean code
  +setActive()
}
interface Librarian {
  #boolean address
  -String amount
  -String status
  #String updatedAt
  #boolean duration
  +calculateTotal()
}
class Loan {
  #float amount
  #boolean quantity
  -boolean total
  +validatePrice()
}
class Reservation {
  +int amount
  #float code
  +setAddress()
  +setId()
}
class Author {
  -boolean price
  #boolean description
  +validateTotal()
  +createDescription()
}
class Publisher {
  +Date duration
  +float level
  +saveTotal()
  +processEmail()
  +calculateUpdatedat()
  +processCreatedat()
}
Author --> Publisher : "1..*"
Fine --* Publisher
Fine --|> Branch
Loan --* Fine
Reservation ..> Loan : "*"
Reservation --* Publisher
note right of Fine : Library domain
@enduml