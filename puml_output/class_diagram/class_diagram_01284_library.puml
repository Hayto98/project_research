@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Fine {
  #String phone
  -Date duration
  #Date email
  +double note
  -boolean score
  +sendDescription()
  +sendQuantity()
  +deleteUpdatedat()
}
class Branch {
  +double phone
  -long description
  #String status
  +boolean score
  +createEmail()
  +cancelType()
  +setEmail()
  +saveAddress()
}
class Librarian {
  -String address
  -String active
  #String level
  +setNote()
}
abstract class Loan {
  +int active
  -double duration
  +calculateDuration()
  +setDescription()
  +sendPhone()
}
abstract class Reservation {
  +Date id
  #int amount
  +long code
  +String score
  +setId()
  +sendUpdatedat()
  +createStatus()
}
class Author {
  -int description
  -String price
  #Date updatedAt
  #int phone
  #int total
  +getAmount()
  +getPhone()
  +deletePrice()
  +findCreatedat()
}
abstract class Publisher {
  #float note
  #boolean createdAt
  -String active
  +validateAmount()
}
Publisher --|> Branch
Loan --* Fine
@enduml