@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
interface Message {
  -Date createdAt
  #boolean active
  #boolean address
  #int phone
  +getDescription()
}
abstract class Story {
  +long price
  #String updatedAt
  -boolean createdAt
  #String amount
  -boolean quantity
  +processDuration()
  +calculateType()
}
class Like {
  +boolean level
  -Date code
  +long duration
  +float phone
  -float name
  +savePrice()
}
class Album {
  #boolean phone
  +boolean duration
  +updateTotal()
  +saveQuantity()
  +validateNote()
  +sendPhone()
}
abstract class Comment {
  #Date id
  -Date note
  #double price
  +Date amount
  +cancelDuration()
  +saveQuantity()
}
abstract class Report {
  +float price
  -boolean updatedAt
  +sendAddress()
}
class Follower {
  -double amount
  #boolean note
  +String quantity
  +calculateQuantity()
  +getActive()
  +deletePrice()
  +createActive()
}
Story ..|> Comment
Like --o Report
Album --|> Follower
Story --> Album : "1..*"
Like --* Album
@enduml