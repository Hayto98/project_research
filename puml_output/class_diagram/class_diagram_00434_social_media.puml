@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
interface Message {
  -Date createdAt
  #boolean active
  #boolean address
  #int phone
  +processType()
}
abstract class Story {
  -String duration
  -float createdAt
  #String amount
  +sendDuration()
  +setPhone()
  +sendDescription()
  +updateAddress()
}
abstract class Like {
  #float code
  +int phone
  +saveCreatedat()
  +validateUpdatedat()
  +validateCode()
  +cancelAddress()
}
class Album {
  -int phone
  +long active
  -float status
  -String type
  +savePrice()
  +findAmount()
  +sendNote()
  +saveType()
}
class Comment {
  -int description
  +float total
  -boolean code
  +createAmount()
}
class Report {
  -double note
  #boolean level
  +String quantity
  +calculateNote()
  +validateTotal()
  +deleteLevel()
  +deleteEmail()
}
abstract class Follower {
  -double note
  -double status
  #String description
  #int duration
  +long email
  +updatePhone()
  +getNote()
}
Message --|> Album
Report --o Like
Follower --|> Like
Comment --o Album
Album --* Story
Like --|> Report
note right of Message : Social Media domain
@enduml