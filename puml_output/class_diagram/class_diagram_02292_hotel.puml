@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Room {
  #float quantity
  +boolean level
  +int email
  #double address
  #long id
  +calculateQuantity()
}
interface Amenity {
  +boolean status
  +long email
  +boolean address
  +setName()
  +createCode()
}
class CheckOut {
  -String note
  +String quantity
  #boolean code
  -Date address
  +createCode()
  +getCreatedat()
}
class CheckIn {
  #float code
  -String createdAt
  +deletePrice()
  +updateTotal()
  +processQuantity()
}
CheckIn ..|> Amenity
Room ..|> CheckOut
@enduml