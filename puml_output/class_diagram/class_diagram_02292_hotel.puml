@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Room {
  #float quantity
  +boolean level
  +int email
  #double address
  #long id
  +calculateActive()
}
class Amenity {
  +boolean email
  +long address
  +sendUpdatedat()
  +getAmount()
}
class CheckOut {
  -String note
  +String quantity
  #boolean code
  -Date address
  +deleteScore()
  +setLevel()
}
interface CheckIn {
  #float code
  -String createdAt
  +processPhone()
  +getLevel()
  +setScore()
}
CheckIn --> Room : "1"
Amenity ..|> CheckIn
Amenity --o CheckOut
note right of Room : Hotel domain
@enduml