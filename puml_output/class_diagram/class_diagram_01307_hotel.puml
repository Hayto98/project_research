@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
abstract class Room {
  -float note
  #long id
  #double name
  +createScore()
  +processTotal()
  +processCode()
}
class Staff {
  +float address
  #int createdAt
  #boolean duration
  +cancelName()
}
class Housekeeping {
  +long active
  +float phone
  #String quantity
  +long level
  -Date duration
  +cancelTotal()
  +createAddress()
  +sendCode()
  +saveNote()
}
abstract class Payment {
  -String status
  +long code
  #String duration
  +processAddress()
  +getType()
}
class Service {
  -Date total
  +float description
  +validateScore()
}
class Restaurant {
  +Date amount
  #int updatedAt
  +saveId()
}
class Booking {
  -double total
  +String quantity
  -boolean code
  -float duration
  +processPrice()
  +deleteAmount()
}
Staff --o Service
Room --o Staff
Payment ..> Booking : "*"
@enduml