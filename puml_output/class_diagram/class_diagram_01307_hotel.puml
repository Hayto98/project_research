@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
abstract class Room {
  -float note
  #long id
  #double name
  +updateNote()
  +getQuantity()
  +sendCreatedat()
}
class Staff {
  #boolean address
  +Date name
  #long description
  +sendPhone()
  +createLevel()
  +validatePhone()
  +getPhone()
}
class Housekeeping {
  -Date status
  -String email
  +getNote()
}
class Payment {
  +int description
  -Date status
  +int code
  +long level
  +double type
  +validateCreatedat()
  +saveStatus()
}
class Service {
  +float duration
  +String id
  +findName()
  +getUpdatedat()
}
class Restaurant {
  +String quantity
  -boolean code
  -float total
  #Date type
  +int active
  +saveAmount()
  +updateScore()
  +calculateCode()
  +deleteType()
}
abstract class Booking {
  #String price
  -int duration
  -float email
  -long description
  -String note
  +cancelDuration()
  +deleteDescription()
}
Staff --> Room : "*"
Room --> Payment : "1"
Staff --o Service
Room --> Staff : "0..1"
note right of Room : Hotel domain
@enduml