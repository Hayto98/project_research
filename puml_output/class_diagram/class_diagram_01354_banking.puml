@startuml
skinparam monochrome true
interface Interest {
  #String createdAt
  -long price
  +updateNote()
  +savePhone()
}
class Deposit {
  -Date level
  #String total
  +String description
  +findName()
  +cancelDuration()
}
class Beneficiary {
  -long description
  +double active
  +int score
  +double type
  +saveStatus()
  +calculateDuration()
  +deleteDuration()
  +validateStatus()
}
class Card {
  -Date description
  -boolean active
  +double email
  #String price
  +String id
  +calculateCode()
  +updateCreatedat()
  +saveCode()
}
abstract class Account {
  -double email
  -String phone
  -Date description
  -String score
  -Date type
  +cancelScore()
  +sendId()
  +updateTotal()
  +validateNote()
}
interface Branch {
  +String status
  +double phone
  +findActive()
  +updateUpdatedat()
  +processType()
}
Beneficiary --|> Interest
Card ..|> Deposit
note right of Interest : Banking domain
@enduml