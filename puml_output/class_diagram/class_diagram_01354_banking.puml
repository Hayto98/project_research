@startuml
skinparam monochrome true
interface Interest {
  #String createdAt
  -long price
  +sendId()
  +deleteDuration()
}
class Deposit {
  #int score
  -Date description
  #String total
  +getLevel()
}
class Beneficiary {
  -Date level
  +Date description
  +cancelQuantity()
  +calculateScore()
  +getTotal()
  +createDuration()
}
class Card {
  #String updatedAt
  -Date price
  #float note
  +findDescription()
  +cancelId()
}
class Account {
  +float active
  #long note
  +getActive()
  +setName()
  +deletePhone()
  +processDescription()
}
abstract class Branch {
  +long total
  -String id
  +float createdAt
  +saveTotal()
  +deleteStatus()
}
Card --o Account
Beneficiary ..|> Branch
@enduml