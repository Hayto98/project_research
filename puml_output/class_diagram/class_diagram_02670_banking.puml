@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Account {
  +boolean status
  +boolean id
  #long amount
  -Date email
  +String phone
  +validateUpdatedat()
}
class Teller {
  +String quantity
  +long address
  +getCreatedat()
  +setActive()
}
abstract class Statement {
  -double email
  #long price
  +findAmount()
  +createAddress()
}
class Loan {
  #double level
  #float id
  -float total
  +calculateStatus()
  +getCode()
  +createNote()
}
interface Deposit {
  #Date type
  #int address
  +validateName()
}
class Branch {
  #Date price
  -double active
  -boolean type
  +setActive()
  +getName()
}
Loan --|> Deposit
Account ..> Deposit : "1..*"
Deposit --> Teller : "1..*"
Statement --* Teller
@enduml