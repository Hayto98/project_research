@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class MedicalRecord {
  +long code
  -float id
  +String total
  +saveCode()
}
abstract class Appointment {
  +int updatedAt
  +float email
  +saveScore()
  +processId()
  +sendActive()
}
class Prescription {
  +String code
  -boolean score
  +findLevel()
  +saveName()
}
interface Billing {
  -String code
  +int id
  -Date description
  +saveName()
  +calculateTotal()
}
class Doctor {
  +double active
  -double status
  +Date note
  +long phone
  +cancelNote()
  +sendPhone()
  +createName()
  +calculateQuantity()
}
class Hospital {
  +Date active
  -int amount
  -String score
  #int description
  +sendDescription()
  +calculateNote()
  +findCode()
  +processActive()
}
Hospital ..> MedicalRecord : "1"
Doctor --|> Prescription
@enduml