@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class MedicalRecord {
  +long code
  -float id
  +String total
  +calculateTotal()
}
class Appointment {
  +int duration
  -long email
  #boolean code
  +getCode()
}
interface Prescription {
  #boolean id
  +float email
  +cancelActive()
  +updateCode()
  +getDescription()
  +validateId()
}
class Billing {
  -long price
  -boolean active
  #float description
  +processPhone()
}
class Doctor {
  #Date note
  -int price
  -double name
  -long amount
  -boolean email
  +sendDescription()
  +setQuantity()
}
class Hospital {
  -int status
  +Date updatedAt
  +Date price
  +boolean createdAt
  +getCode()
  +updateId()
  +findPhone()
}
Doctor ..|> Billing
Doctor ..|> Appointment
Prescription ..|> MedicalRecord
Hospital --* Doctor
note right of MedicalRecord : Healthcare domain
@enduml