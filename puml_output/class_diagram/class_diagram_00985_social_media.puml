@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
interface Profile {
  +Date type
  #boolean quantity
  #int id
  #int note
  +validateStatus()
  +updatePhone()
  +calculateAddress()
}
class Like {
  -boolean address
  -float total
  #boolean status
  #int level
  +createQuantity()
  +calculateEmail()
}
class Report {
  #int duration
  +String active
  #double price
  +sendId()
  +calculateTotal()
}
class Hashtag {
  -Date email
  #String name
  +sendActive()
}
class User {
  +String id
  -float price
  -float status
  #float createdAt
  +findName()
  +setName()
}
class Message {
  #boolean phone
  -Date active
  +Date createdAt
  +updateAmount()
  +cancelPhone()
  +createActive()
}
class Comment {
  -double amount
  #long price
  -int updatedAt
  -boolean type
  +float createdAt
  +getStatus()
}
Like --* Profile
Comment ..> Report : "1..*"
Report --|> Like
Like --> Hashtag : "*"
note right of Profile : Social Media domain
@enduml