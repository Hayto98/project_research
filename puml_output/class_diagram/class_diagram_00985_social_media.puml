@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
interface Profile {
  +Date type
  #boolean quantity
  #int id
  #int note
  +calculateName()
  +validateId()
  +saveNote()
}
class Like {
  #String address
  -long description
  #float duration
  -float score
  #boolean total
  +sendEmail()
  +calculatePhone()
}
class Report {
  #int email
  +String status
  #double updatedAt
  #float active
  +boolean price
  +updateAmount()
}
abstract class Hashtag {
  -Date name
  #String level
  #String duration
  #boolean email
  #long score
  +setName()
  +setActive()
  +createPrice()
}
class User {
  -float name
  #float status
  +Date address
  +updateUpdatedat()
}
class Message {
  -boolean level
  +boolean description
  +calculateUpdatedat()
  +getType()
  +sendUpdatedat()
}
class Comment {
  #boolean amount
  -double phone
  #int email
  +deleteAddress()
  +setAddress()
  +cancelCode()
  +calculateNote()
}
Hashtag --* User
Report --o Like
User --> Like : "1"
Profile --* Comment
Like --* Profile
@enduml