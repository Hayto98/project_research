@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Diagnosis {
  +Date total
  #long updatedAt
  -boolean phone
  -boolean code
  -boolean name
  +setLevel()
  +deleteEmail()
  +sendUpdatedat()
  +findName()
}
class Prescription {
  #double email
  #Date price
  #float score
  -long address
  +deleteName()
  +setPhone()
  +validateDuration()
}
interface Insurance {
  -boolean email
  -long note
  -float score
  +updateId()
}
abstract class Treatment {
  +Date address
  +float score
  -int status
  +boolean total
  +Date amount
  +setDescription()
}
class Appointment {
  #long level
  +long description
  +createAddress()
  +validateDuration()
  +deleteScore()
  +setAddress()
}
class Hospital {
  +String code
  +String id
  +deleteType()
  +cancelType()
  +calculateAmount()
}
Diagnosis --> Appointment : "1..*"
Prescription --* Appointment
Appointment ..> Diagnosis : "*"
@enduml