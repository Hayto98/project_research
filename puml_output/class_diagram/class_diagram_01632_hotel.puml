@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
abstract class Amenity {
  #long description
  -Date id
  +cancelScore()
  +sendScore()
  +processTotal()
  +validateName()
}
class Payment {
  #String quantity
  -int duration
  #long description
  -int price
  #float name
  +sendAmount()
}
class Staff {
  +float price
  +double quantity
  #boolean createdAt
  #int type
  -boolean name
  +createUpdatedat()
  +deletePhone()
}
interface Restaurant {
  #String total
  #String type
  #Date id
  +double createdAt
  +setName()
  +createQuantity()
}
class Reservation {
  -float updatedAt
  +long phone
  #boolean email
  +sendNote()
  +setScore()
  +findId()
  +setActive()
}
interface CheckOut {
  -double total
  -double quantity
  +Date active
  +float duration
  +validateActive()
  +validatePhone()
}
Reservation --o Staff
Restaurant --> Payment : "*"
@enduml