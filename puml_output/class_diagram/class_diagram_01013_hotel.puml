@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
abstract class Amenity {
  +boolean email
  #int price
  +Date createdAt
  -long description
  +cancelActive()
  +findTotal()
  +saveUpdatedat()
  +sendUpdatedat()
}
class Reservation {
  #float code
  #double score
  #float total
  +setStatus()
  +validateUpdatedat()
}
class Housekeeping {
  -long updatedAt
  #boolean address
  +Date code
  -double level
  +getCode()
  +getAddress()
  +findId()
}
class Staff {
  +boolean updatedAt
  -int phone
  +deleteType()
  +saveUpdatedat()
}
interface Booking {
  +float updatedAt
  -Date level
  #float description
  +String price
  +createUpdatedat()
  +findActive()
}
class Invoice {
  +Date type
  #int score
  -long level
  +getUpdatedat()
  +setUpdatedat()
  +calculateCreatedat()
}
class Room {
  +Date score
  -Date code
  +calculatePhone()
  +findEmail()
  +savePhone()
}
Booking ..|> Room
Room --* Booking
Booking --|> Housekeeping
@enduml