@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
abstract class Category {
  -long score
  -float phone
  #long note
  #double active
  +setScore()
  +setPrice()
  +setId()
}
abstract class Cart {
  -Date score
  +double note
  +float price
  -double address
  +findLevel()
}
abstract class Invoice {
  -boolean createdAt
  #float phone
  -Date price
  #int quantity
  +String id
  +saveName()
  +updateCode()
}
class Shipment {
  -float quantity
  +boolean level
  -boolean createdAt
  #String type
  -float description
  +getAmount()
  +cancelActive()
  +deleteUpdatedat()
}
Category --* Shipment
Invoice ..|> Cart
@enduml