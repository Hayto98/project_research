@startuml

class Group {
  #double type
  +float updatedAt
  #int level
  #String name
  +long score
  +saveId()
  +processUpdatedat()
  +cancelStatus()
  +deleteStatus()
}
abstract class Report {
  -String email
  #double amount
  #double note
  -String phone
  +processEmail()
  +calculatePhone()
  +validateDuration()
  +saveCreatedat()
}
class Profile {
  -double price
  -Date note
  #int status
  +findCreatedat()
  +createStatus()
  +saveId()
}
class Post {
  #Date level
  +double email
  #long quantity
  +getTotal()
  +processScore()
  +findPhone()
}
interface Notification {
  -long createdAt
  -float note
  +String total
  -String level
  +processNote()
  +getTotal()
  +getType()
  +processPhone()
}
class Story {
  -float phone
  #double level
  -String status
  +saveQuantity()
  +getAmount()
  +updateNote()
  +updateDescription()
}
class Album {
  -double score
  +Date status
  +updateScore()
  +cancelUpdatedat()
  +sendCreatedat()
}
Notification --o Album
Report --o Story
Report ..|> Notification
Post --* Group
@enduml