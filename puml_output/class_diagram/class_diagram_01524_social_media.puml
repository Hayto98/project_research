@startuml

class Group {
  #double type
  +float updatedAt
  #int level
  #String name
  +long score
  +getAmount()
  +setNote()
  +validateEmail()
  +findAmount()
}
interface Report {
  -String phone
  #double address
  #long id
  -long note
  #Date price
  +deletePrice()
  +processStatus()
  +createPrice()
}
abstract class Profile {
  #String level
  +int quantity
  #float email
  +createCode()
  +calculateScore()
  +validatePhone()
}
class Post {
  +Date duration
  -double level
  -float address
  +validatePhone()
  +setId()
  +createName()
}
interface Notification {
  #String createdAt
  -float code
  #double duration
  -String amount
  #double phone
  +saveActive()
  +updateAmount()
}
class Story {
  +Date total
  -Date note
  +validateActive()
  +sendTotal()
  +deletePrice()
  +deleteActive()
}
class Album {
  +float status
  #long address
  -int updatedAt
  -Date duration
  +Date name
  +validateDescription()
}
Report ..|> Group
Profile ..|> Group
Post ..> Report : "*"
Album --o Report
Report ..> Story : "1..*"
note right of Group : Social Media domain
@enduml