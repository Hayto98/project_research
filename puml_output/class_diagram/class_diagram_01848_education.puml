@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Grade {
  #Date active
  #long type
  +long amount
  +getScore()
  +getNote()
  +validateCode()
}
class Exam {
  -String level
  -float duration
  +double active
  #double amount
  +sendScore()
  +setPhone()
  +sendActive()
}
class Library {
  +boolean status
  +float id
  +saveTotal()
  +deleteUpdatedat()
}
class Student {
  #String quantity
  -Date email
  #int address
  -String status
  +setEmail()
  +processId()
  +updateDuration()
}
interface Assignment {
  #float amount
  -int id
  +float email
  +String updatedAt
  #boolean code
  +cancelUpdatedat()
}
Exam --o Student
Student ..> Library : "1"
Grade ..|> Library
Exam --o Assignment
@enduml