@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Enrollment {
  -double type
  -double score
  +validateNote()
}
class Department {
  -long quantity
  +float id
  +float name
  -double updatedAt
  +processAmount()
  +findTotal()
  +getAmount()
  +processNote()
}
class Teacher {
  -double name
  -long level
  -int active
  +boolean score
  +sendDuration()
  +setPhone()
}
class Grade {
  +float email
  #float duration
  #double price
  #Date total
  #double id
  +createActive()
  +getDuration()
  +deleteCreatedat()
}
abstract class Library {
  +String amount
  +Date phone
  +processNote()
  +getStatus()
  +createAmount()
}
class Student {
  -Date code
  -int description
  +Date amount
  +saveDuration()
  +findAmount()
  +getDescription()
  +setNote()
}
class Course {
  #float total
  -float description
  #boolean id
  -boolean amount
  +updateDescription()
  +findActive()
  +updatePhone()
}
Department --|> Library
Department ..> Grade : "0..1"
Teacher --o Course
@enduml