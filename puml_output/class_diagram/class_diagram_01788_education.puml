@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Enrollment {
  -double type
  -double score
  +updatePhone()
}
class Department {
  -String id
  +float name
  -double updatedAt
  #float total
  +setAddress()
  +createName()
  +cancelActive()
  +sendType()
}
abstract class Teacher {
  #int quantity
  #boolean email
  #String createdAt
  -float code
  +findEmail()
  +calculateTotal()
  +sendId()
}
class Grade {
  -boolean duration
  #String price
  +boolean quantity
  -int address
  +String email
  +savePhone()
  +deleteUpdatedat()
  +setDescription()
}
class Library {
  #double note
  -int amount
  -double id
  +String duration
  +findTotal()
  +findLevel()
}
abstract class Student {
  #String createdAt
  +float type
  -Date amount
  #Date updatedAt
  +createAddress()
  +calculateCode()
}
class Course {
  -boolean total
  -double note
  #double level
  #Date duration
  +long status
  +processActive()
  +deleteCreatedat()
  +getTotal()
}
Grade ..|> Department
Library --o Student
Student --> Department : "*"
Course --* Enrollment
Teacher --> Course : "1..*"
note right of Enrollment : Education domain
@enduml