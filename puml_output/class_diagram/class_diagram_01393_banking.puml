@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
interface Account {
  -long amount
  -Date createdAt
  #Date score
  #float updatedAt
  +String quantity
  +cancelDuration()
  +cancelScore()
}
class Transaction {
  #String phone
  +Date duration
  #String type
  +processType()
  +getLevel()
  +createName()
  +validatePhone()
}
interface Withdrawal {
  +float amount
  #int name
  +validateType()
  +sendPrice()
}
class Deposit {
  +String name
  +int price
  #Date createdAt
  -Date quantity
  -long note
  +calculateTotal()
  +cancelUpdatedat()
  +getLevel()
  +updateScore()
}
Account --o Withdrawal
Transaction --> Withdrawal : "1..*"
@enduml