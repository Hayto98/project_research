@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
interface Account {
  -long amount
  -Date createdAt
  #Date score
  #float updatedAt
  +String quantity
  +saveName()
  +deletePhone()
}
class Transaction {
  #boolean score
  -double name
  +double amount
  +boolean active
  +int id
  +getActive()
}
class Withdrawal {
  -int createdAt
  -double total
  +String name
  +deleteDuration()
  +saveNote()
}
class Deposit {
  #float note
  -Date code
  +float id
  #boolean score
  +calculateQuantity()
  +deleteScore()
  +saveCode()
}
Account --|> Transaction
Deposit ..> Withdrawal : "1..*"
note right of Account : Banking domain
@enduml