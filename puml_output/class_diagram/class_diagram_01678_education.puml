@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Classroom {
  -boolean description
  #Date amount
  -boolean phone
  -int score
  #float duration
  +cancelNote()
}
class Exam {
  -boolean price
  -String amount
  +double address
  -String description
  +findEmail()
  +saveCode()
  +saveStatus()
}
interface Assignment {
  +int active
  -int email
  -boolean description
  +findDescription()
  +updateUpdatedat()
  +findScore()
}
abstract class Student {
  +long status
  +Date name
  +updateDuration()
}
Classroom --* Student
Exam --> Student : "*"
note right of Classroom : Education domain
@enduml