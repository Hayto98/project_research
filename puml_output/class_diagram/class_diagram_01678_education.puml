@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Classroom {
  -boolean description
  #Date amount
  -boolean phone
  -int score
  #float duration
  +validateType()
}
interface Exam {
  +long id
  #long phone
  +int price
  -long amount
  +long address
  +findStatus()
  +createAddress()
  +calculateUpdatedat()
}
class Assignment {
  +int active
  -int email
  -boolean description
  +cancelName()
  +getEmail()
  +sendStatus()
}
class Student {
  +String score
  +long total
  +Date code
  +processActive()
}
Classroom --* Student
Exam --> Student : "*"
@enduml