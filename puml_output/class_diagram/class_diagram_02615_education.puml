@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Course {
  #int address
  +double createdAt
  -int name
  +int id
  +saveType()
  +createAmount()
  +findScore()
}
class Schedule {
  #float note
  -long id
  +Date duration
  #int phone
  +validateActive()
  +findDuration()
  +createStatus()
  +saveCode()
}
class Department {
  #int id
  #int email
  +Date address
  -Date status
  #int name
  +saveLevel()
}
abstract class Grade {
  -long note
  -long price
  +sendName()
  +updateId()
  +saveUpdatedat()
}
interface Assignment {
  +Date type
  +String phone
  +sendStatus()
}
class Attendance {
  -String quantity
  +int code
  +Date updatedAt
  #double score
  +deleteUpdatedat()
  +createQuantity()
  +calculateTotal()
}
class Book {
  #String description
  #Date address
  -double amount
  #int code
  +validatePhone()
  +createCreatedat()
  +calculateEmail()
  +getType()
}
Department --* Assignment
Grade ..> Course : "1..*"
Assignment ..|> Attendance
Grade ..|> Book
Department --|> Schedule
Book --* Course
note right of Course : Education domain
@enduml