@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Course {
  #int address
  +double createdAt
  -int name
  +int id
  +saveUpdatedat()
  +getId()
  +findCreatedat()
}
class Schedule {
  -long quantity
  #float note
  -long id
  +setCreatedat()
}
class Department {
  +double phone
  +long active
  -String quantity
  #float status
  #String code
  +findUpdatedat()
  +sendId()
}
class Grade {
  -Date description
  -long name
  -long total
  -Date code
  +calculateActive()
  +saveEmail()
  +cancelNote()
}
class Assignment {
  -String score
  #String id
  +float type
  +getCreatedat()
}
class Attendance {
  +int phone
  +long quantity
  +findNote()
}
class Book {
  -float active
  +int total
  +processDescription()
  +createId()
  +calculateCode()
}
Department ..|> Book
Department --|> Schedule
Assignment ..> Course : "*"
Grade ..|> Assignment
Grade --* Department
@enduml