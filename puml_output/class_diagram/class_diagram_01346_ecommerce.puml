@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
interface Cart {
  +long address
  #long email
  -double code
  #float name
  +setPrice()
  +findCode()
}
interface Product {
  #long type
  #long status
  -double active
  -double createdAt
  #long name
  +getLevel()
}
class Shipment {
  #float price
  #double phone
  -String code
  -float quantity
  +validateNote()
}
class Order {
  #int quantity
  +boolean active
  #boolean duration
  #float createdAt
  +saveType()
  +processTotal()
  +getPhone()
}
class Customer {
  -double address
  #Date description
  #int note
  -float createdAt
  -Date level
  +findDescription()
  +createCode()
  +updateTotal()
}
class Supplier {
  #float address
  #boolean createdAt
  #double email
  +boolean score
  #float updatedAt
  +saveStatus()
  +validateCreatedat()
  +validatePhone()
  +updatePrice()
}
class Review {
  +double description
  #float phone
  -float note
  +sendId()
  +validateUpdatedat()
  +saveDescription()
}
Order ..> Supplier : "1..*"
Cart --* Order
@enduml