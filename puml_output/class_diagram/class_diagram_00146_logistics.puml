@startuml
skinparam shadowing true
interface Shipment {
  +double code
  -double note
  #String active
  +Date id
  +processUpdatedat()
}
interface Tracking {
  +boolean email
  +boolean id
  #String type
  -float updatedAt
  #int note
  +calculateName()
  +sendType()
  +setAmount()
  +sendStatus()
}
abstract class Manifest {
  -Date note
  -float active
  +updateUpdatedat()
  +sendTotal()
  +saveName()
  +updateActive()
}
abstract class FuelLog {
  #long description
  #String updatedAt
  -float status
  +calculateStatus()
}
interface Driver {
  +Date score
  #double note
  #Date createdAt
  +int price
  +boolean level
  +calculateId()
  +validatePrice()
  +findNote()
  +cancelCode()
}
Manifest ..> FuelLog : "1..*"
FuelLog --|> Manifest
Manifest --o Shipment
Shipment --|> FuelLog
@enduml