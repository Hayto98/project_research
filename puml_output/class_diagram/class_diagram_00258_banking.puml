@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
abstract class Card {
  #float price
  -float quantity
  -boolean address
  +validateQuantity()
  +findName()
  +validateEmail()
  +sendType()
}
class Transaction {
  -long type
  -int phone
  -float level
  +deleteDescription()
  +findTotal()
  +getCode()
}
interface Teller {
  -boolean description
  -Date status
  -String email
  +String level
  #double total
  +deleteActive()
  +setDescription()
  +cancelName()
  +createDescription()
}
interface Transfer {
  -int updatedAt
  +float email
  -boolean phone
  -int quantity
  +String code
  +sendId()
}
interface Branch {
  #int id
  #boolean level
  -long amount
  #long total
  +getUpdatedat()
  +saveType()
}
Teller ..> Branch : "1..*"
Branch --|> Teller
note right of Card : Banking domain
@enduml