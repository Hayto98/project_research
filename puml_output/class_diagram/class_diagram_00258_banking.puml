@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
abstract class Card {
  #float price
  -float quantity
  -boolean address
  +setEmail()
  +sendUpdatedat()
  +cancelAddress()
  +updateId()
}
class Transaction {
  #int email
  #double score
  -float type
  #long address
  +sendAddress()
  +validateDuration()
  +processActive()
  +updateQuantity()
}
class Teller {
  +boolean description
  -int total
  +long name
  +calculateQuantity()
}
class Transfer {
  -int type
  #String status
  +boolean name
  +long id
  +boolean total
  +processPrice()
  +deleteName()
  +createAmount()
  +findStatus()
}
class Branch {
  +float type
  -boolean updatedAt
  +updateType()
  +createCreatedat()
  +cancelStatus()
}
Branch --> Card : "1..*"
Card ..> Transaction : "*"
@enduml