@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Invoice {
  -int level
  -double email
  +updateCreatedat()
  +cancelId()
}
abstract class Booking {
  -String level
  +Date description
  +validateScore()
}
class Staff {
  -int phone
  -Date name
  #Date updatedAt
  -float note
  +processId()
  +saveType()
  +cancelStatus()
}
abstract class Service {
  +boolean status
  +boolean name
  #Date type
  +calculateEmail()
  +getNote()
  +cancelType()
  +setPrice()
}
class Payment {
  -double active
  -boolean level
  +Date price
  +setAddress()
  +createLevel()
  +processLevel()
  +saveStatus()
}
interface Restaurant {
  -Date code
  #String address
  -boolean type
  -float email
  +processUpdatedat()
  +saveUpdatedat()
  +validateAddress()
  +validateTotal()
}
class Guest {
  #double duration
  +float code
  #boolean createdAt
  +cancelTotal()
  +sendId()
  +calculateAddress()
}
Payment ..> Guest : "0..1"
Restaurant ..> Guest : "1..*"
Invoice --|> Payment
Service ..|> Invoice
Staff ..|> Invoice
Payment --* Invoice
@enduml