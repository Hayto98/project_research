@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Invoice {
  -int level
  -double email
  +validateTotal()
  +findCode()
}
interface Booking {
  #float email
  #String id
  -float amount
  +findScore()
  +createPhone()
  +getUpdatedat()
}
abstract class Staff {
  -boolean updatedAt
  +double email
  #boolean score
  #int address
  +getType()
}
class Service {
  +long level
  +float price
  +saveActive()
  +cancelLevel()
}
abstract class Payment {
  #boolean total
  #double duration
  #Date active
  -float status
  +setAddress()
  +processEmail()
  +calculateActive()
}
class Restaurant {
  #int level
  +boolean price
  +int type
  #double amount
  +float email
  +getCreatedat()
  +deleteLevel()
  +cancelScore()
}
class Guest {
  +int name
  -String score
  +boolean code
  +long note
  +updateUpdatedat()
  +deleteTotal()
}
Booking --o Guest
Booking ..> Staff : "1..*"
Service --|> Payment
Guest ..> Staff : "*"
Invoice ..> Payment : "1..*"
note right of Invoice : Hotel domain
@enduml