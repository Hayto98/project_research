@startuml
skinparam monochrome true
interface Supplier {
  -int name
  +boolean active
  -long level
  +cancelAddress()
  +deleteStatus()
  +saveId()
  +deleteActive()
}
class Customer {
  -boolean createdAt
  #float duration
  +float code
  -boolean level
  +processAmount()
  +sendEmail()
}
class Product {
  -int duration
  -long amount
  +validateDescription()
  +findId()
  +getAddress()
  +validateUpdatedat()
}
abstract class Return {
  +boolean status
  +double note
  -float code
  +calculateDescription()
}
interface Wishlist {
  +long description
  #float total
  +updateDuration()
}
class Review {
  -boolean email
  -double quantity
  +float price
  -boolean level
  -boolean note
  +processDescription()
  +deleteAmount()
  +updateEmail()
  +processId()
}
abstract class Invoice {
  -String address
  -float score
  #boolean level
  +createEmail()
  +setName()
  +createAddress()
  +findPrice()
}
Product ..|> Review
Review --o Product
Customer --* Wishlist
Supplier --o Wishlist
Wishlist --o Return
@enduml