@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Patient {
  #long price
  #float type
  -Date duration
  +createPhone()
  +updateScore()
  +cancelTotal()
  +deleteEmail()
}
class MedicalRecord {
  -String total
  +String name
  +updateAmount()
  +findUpdatedat()
  +setAddress()
  +cancelAddress()
}
class Hospital {
  #double amount
  #float status
  +float email
  #float updatedAt
  +saveType()
  +findPrice()
  +deleteType()
}
class Prescription {
  #long price
  -String total
  +setEmail()
  +updateId()
}
interface Billing {
  -String level
  +float address
  -String status
  +float email
  +setAmount()
  +validateTotal()
}
class Insurance {
  #int type
  -String level
  #Date status
  -float amount
  +getNote()
}
interface LabTest {
  +double updatedAt
  -double price
  +Date email
  +validateType()
  +createPhone()
  +cancelPhone()
  +calculateQuantity()
}
Prescription ..> Insurance : "1"
Hospital ..|> Billing
Insurance --o Hospital
Prescription --|> MedicalRecord
Patient --|> Insurance
note right of Patient : Healthcare domain
@enduml