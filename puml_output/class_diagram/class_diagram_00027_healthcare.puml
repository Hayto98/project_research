@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Patient {
  #long price
  #float type
  -Date duration
  +setPrice()
  +validateAmount()
  +saveTotal()
  +cancelId()
}
class MedicalRecord {
  +double description
  +int email
  +double id
  +Date name
  +float total
  +getType()
  +createActive()
}
interface Hospital {
  -Date description
  +Date phone
  -boolean amount
  +float status
  +validatePrice()
  +validateUpdatedat()
  +createTotal()
}
abstract class Prescription {
  -double type
  #long createdAt
  -String status
  +saveLevel()
  +updateUpdatedat()
}
class Billing {
  -boolean id
  -String active
  -long level
  +setName()
}
class Insurance {
  +int id
  -double amount
  +deleteCode()
  +deleteEmail()
}
abstract class LabTest {
  -String amount
  #Date updatedAt
  +getUpdatedat()
  +updateDuration()
  +updatePrice()
}
Billing ..|> MedicalRecord
Prescription ..|> Hospital
Prescription --o LabTest
Patient --o Insurance
LabTest ..> Hospital : "*"
@enduml