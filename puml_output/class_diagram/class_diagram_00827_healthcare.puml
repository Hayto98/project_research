@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Appointment {
  +float id
  #String updatedAt
  +validateQuantity()
}
class MedicalRecord {
  +long amount
  +long code
  +saveId()
  +getPhone()
  +updateName()
  +setUpdatedat()
}
interface Insurance {
  -long type
  +long code
  +float score
  -Date note
  +processLevel()
  +calculateDescription()
  +updateCode()
  +getAddress()
}
class Prescription {
  +int address
  -int phone
  #String note
  +float description
  #Date total
  +cancelActive()
  +createNote()
  +getDescription()
}
abstract class Doctor {
  -int status
  +Date level
  +boolean score
  +getAddress()
}
class LabTest {
  +double updatedAt
  +String description
  +deleteEmail()
  +cancelType()
  +sendName()
  +validateAmount()
}
Appointment --o LabTest
LabTest --* MedicalRecord
Doctor ..|> MedicalRecord
MedicalRecord --* Appointment
@enduml