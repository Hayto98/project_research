@startuml
skinparam defaultFontSize 13
abstract class Teacher {
  -double name
  +Date quantity
  +findStatus()
  +setPrice()
  +findName()
  +cancelType()
}
class Library {
  #float price
  #boolean active
  +createPhone()
  +getAddress()
  +processTotal()
}
class Enrollment {
  -int price
  +int note
  +long score
  +double total
  +setActive()
  +validateStatus()
  +createScore()
}
class Grade {
  -float total
  +boolean level
  +cancelUpdatedat()
}
Enrollment ..> Library : "*"
Grade ..|> Library
Teacher ..> Grade : "1"
@enduml