@startuml
skinparam defaultFontSize 13
abstract class Teacher {
  -double name
  +Date quantity
  +saveLevel()
  +validateStatus()
  +calculateActive()
  +saveDuration()
}
interface Library {
  -double status
  -boolean total
  -long note
  +int address
  +setEmail()
  +deleteType()
}
class Enrollment {
  #Date createdAt
  #boolean name
  -float total
  +sendId()
  +findPrice()
}
interface Grade {
  -long price
  +Date type
  #String score
  +Date active
  +processDuration()
}
Grade ..|> Enrollment
Teacher ..|> Grade
note right of Teacher : Education domain
@enduml