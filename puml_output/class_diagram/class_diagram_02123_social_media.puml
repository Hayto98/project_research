@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Like {
  -long email
  +boolean level
  +sendLevel()
  +processType()
  +setPrice()
}
class Comment {
  +Date address
  +long level
  -float duration
  -String code
  +saveName()
  +calculateTotal()
}
interface Group {
  -boolean description
  #String address
  #long amount
  +getId()
  +findLevel()
  +saveType()
  +cancelDescription()
}
interface Story {
  #float address
  +float price
  #int duration
  #int name
  #int code
  +processId()
  +createAmount()
  +setLevel()
}
abstract class Album {
  -long description
  #int duration
  +Date code
  #double name
  +saveId()
}
Comment --o Album
Story --|> Album
@enduml