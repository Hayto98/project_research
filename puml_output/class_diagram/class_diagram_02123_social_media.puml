@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Like {
  -long email
  +boolean level
  +calculateAmount()
  +savePhone()
  +validateLevel()
}
class Comment {
  -double createdAt
  -String name
  +calculateActive()
  +deleteDescription()
}
class Group {
  #long total
  -double active
  #float status
  +findAddress()
  +calculateAddress()
  +getCode()
  +sendCode()
}
class Story {
  #long score
  +double updatedAt
  -int phone
  +findCode()
  +getTotal()
}
class Album {
  +String name
  +int type
  -double code
  +setType()
  +setId()
  +getPrice()
  +deleteDuration()
}
Like ..> Comment : "1..*"
Story ..> Album : "*"
Group ..> Album : "*"
Like --> Story : "1..*"
note right of Like : Social Media domain
@enduml