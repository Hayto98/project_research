@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Attendance {
  #Date id
  -double amount
  +float note
  #String name
  +processUpdatedat()
}
class Student {
  -int status
  -Date code
  +int id
  +float email
  -double address
  +processNote()
}
class Exam {
  -boolean phone
  -int status
  -Date duration
  -String active
  -Date createdAt
  +sendScore()
  +findActive()
  +validateCode()
  +sendAmount()
}
class Enrollment {
  -int phone
  +float score
  +getLevel()
  +sendScore()
}
class Grade {
  +int updatedAt
  -String createdAt
  +validateType()
  +saveName()
  +saveId()
}
class Classroom {
  -int level
  #int amount
  +long createdAt
  -double status
  +validateUpdatedat()
  +validateScore()
  +setActive()
  +processId()
}
abstract class Schedule {
  -float updatedAt
  #float address
  -boolean name
  +findNote()
  +saveAmount()
}
Enrollment --* Classroom
Grade ..|> Schedule
Enrollment --|> Schedule
Attendance --o Grade
Exam ..> Enrollment : "1..*"
@enduml