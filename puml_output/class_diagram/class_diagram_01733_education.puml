@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Attendance {
  #Date id
  -double amount
  +float note
  #String name
  +deleteCreatedat()
}
abstract class Student {
  -float code
  #long id
  +deleteQuantity()
  +saveId()
  +deleteAmount()
  +createPrice()
}
class Exam {
  #float price
  +long phone
  +processDuration()
  +processCreatedat()
}
class Enrollment {
  -int name
  #int phone
  +long price
  #float score
  +deleteCreatedat()
  +updateCode()
  +calculateQuantity()
  +setUpdatedat()
}
interface Grade {
  +long description
  -String amount
  -long quantity
  +updateStatus()
  +processDescription()
}
class Classroom {
  -double email
  -long note
  +deleteUpdatedat()
  +validateName()
  +validateType()
  +sendCreatedat()
}
class Schedule {
  -double total
  +String price
  #double address
  -double active
  #float createdAt
  +validateDuration()
  +updateUpdatedat()
  +processCreatedat()
}
Attendance --o Grade
Schedule ..|> Grade
Exam --* Attendance
Schedule --> Attendance : "1..*"
Grade --o Student
note right of Attendance : Education domain
@enduml