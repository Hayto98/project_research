@startuml
skinparam monochrome true
skinparam ArrowColor #555555
interface FuelLog {
  #String code
  +Date createdAt
  +validateAmount()
  +cancelTotal()
  +saveType()
  +getType()
}
class Shipment {
  -long description
  -float address
  +findNote()
  +cancelName()
  +calculateTotal()
  +processQuantity()
}
class Package {
  #float phone
  +float amount
  #Date price
  -String code
  +saveCode()
  +deleteDuration()
}
class Tracking {
  #double phone
  #double updatedAt
  -long level
  +sendDescription()
  +cancelNote()
}
interface Route {
  -float email
  #int duration
  #float description
  +validateName()
  +calculateScore()
  +getEmail()
}
class Depot {
  -Date total
  #int active
  -int email
  #String updatedAt
  #Date level
  +deleteTotal()
  +calculatePhone()
}
abstract class Customer {
  #double code
  #Date updatedAt
  -double address
  #long email
  +updatePrice()
  +updateEmail()
}
Shipment --* Depot
Depot --o FuelLog
@enduml