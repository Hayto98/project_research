@startuml
skinparam defaultFontSize 13
class Customer {
  +long active
  #Date note
  #long id
  +long price
  +validateAmount()
  +setStatus()
}
class Withdrawal {
  -String description
  +Date duration
  #int address
  +cancelActive()
  +calculateId()
  +validateCreatedat()
  +deletePrice()
}
abstract class Loan {
  +Date price
  #String amount
  #boolean note
  -String updatedAt
  +findLevel()
}
class Card {
  #String total
  -Date status
  +cancelUpdatedat()
  +findPhone()
  +cancelCreatedat()
}
Customer --> Withdrawal : "*"
Customer --* Card
Loan --> Customer : "1..*"
@enduml