@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Service {
  -double address
  +boolean description
  #boolean status
  +setActive()
  +getQuantity()
  +calculateType()
  +updateAmount()
}
interface Room {
  #boolean score
  +float phone
  -double duration
  +sendActive()
  +sendType()
  +getQuantity()
  +getAddress()
}
class Booking {
  +double updatedAt
  +double price
  +processAmount()
  +cancelNote()
}
interface Guest {
  -boolean price
  +String level
  -Date note
  -Date email
  #boolean code
  +sendQuantity()
  +sendNote()
}
Room --> Guest : "1..*"
Service --* Guest
Service ..|> Booking
@enduml