@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Department {
  -double createdAt
  -double phone
  +updateQuantity()
  +findQuantity()
  +processCreatedat()
  +validateDescription()
}
abstract class Grade {
  +int code
  +int quantity
  #double status
  +saveUpdatedat()
  +calculateScore()
}
class Course {
  -int active
  +String name
  +setUpdatedat()
  +updateQuantity()
}
abstract class Book {
  +String active
  #Date description
  -String address
  +float status
  -long score
  +updateName()
  +cancelAddress()
}
interface Attendance {
  -long name
  -float active
  #String email
  +double updatedAt
  +saveAddress()
  +sendScore()
  +getName()
  +cancelEmail()
}
interface Exam {
  -float price
  -float level
  -double note
  +updateName()
  +cancelStatus()
  +createAddress()
  +processLevel()
}
Grade ..|> Course
Grade --|> Exam
Department --> Grade : "0..1"
@enduml