@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Department {
  -double createdAt
  -double phone
  +validateNote()
  +cancelDescription()
  +saveCode()
  +createStatus()
}
class Grade {
  #boolean name
  #int description
  #long price
  +getActive()
  +getNote()
  +deleteUpdatedat()
}
class Course {
  #int name
  -float note
  +long total
  +getEmail()
}
class Book {
  +long total
  #boolean email
  #long updatedAt
  +sendEmail()
}
class Attendance {
  +double phone
  -int price
  -float score
  +float id
  +savePrice()
  +cancelNote()
}
abstract class Exam {
  +String note
  +double duration
  #boolean score
  +int price
  +deleteUpdatedat()
  +deleteStatus()
  +setAmount()
}
Attendance ..> Book : "1"
Book --o Course
Course --> Attendance : "1..*"
note right of Department : Education domain
@enduml