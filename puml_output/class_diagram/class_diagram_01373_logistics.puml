@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Shipment {
  #Date address
  #float price
  #String status
  +long updatedAt
  +int total
  +sendTotal()
}
class Tracking {
  -float amount
  #boolean quantity
  +getEmail()
}
abstract class Package {
  -String duration
  #Date phone
  +double quantity
  -int id
  -float description
  +calculateQuantity()
  +deletePhone()
  +deleteUpdatedat()
  +getNote()
}
abstract class Route {
  #double note
  -int updatedAt
  #int amount
  +boolean code
  -long active
  +updateScore()
  +findDuration()
  +deleteNote()
  +sendId()
}
class Customer {
  +float total
  +float active
  -boolean note
  +sendTotal()
  +createQuantity()
  +sendCreatedat()
}
class Vehicle {
  #String createdAt
  #int address
  -long updatedAt
  +String description
  -boolean status
  +setStatus()
  +deleteId()
  +getPhone()
}
Route --> Package : "*"
Shipment --o Route
Customer --> Vehicle : "1"
@enduml