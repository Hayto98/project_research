@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Branch {
  -Date name
  -float address
  +setId()
  +updateNote()
}
interface Publisher {
  -int name
  -String description
  +int type
  -Date level
  +Date price
  +deletePhone()
}
class Fine {
  +boolean amount
  #String id
  -float description
  +int note
  -String type
  +calculateNote()
  +updateEmail()
  +createType()
  +getLevel()
}
abstract class Librarian {
  #Date id
  #String amount
  +boolean code
  #boolean score
  -String total
  +validateQuantity()
}
class Shelf {
  #String email
  +double name
  +updateTotal()
  +findDuration()
  +calculateEmail()
  +saveUpdatedat()
}
Branch --|> Fine
Branch ..> Librarian : "*"
@enduml