@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Branch {
  -Date name
  -float address
  +cancelActive()
  +sendDuration()
}
abstract class Publisher {
  #boolean description
  +double type
  +updateType()
  +getUpdatedat()
  +deletePrice()
}
class Fine {
  +Date address
  +int total
  +processId()
  +cancelStatus()
  +processName()
  +deletePrice()
}
class Librarian {
  +int createdAt
  #float total
  +String code
  -float level
  #Date active
  +setDuration()
}
interface Shelf {
  -String code
  #String status
  +double amount
  #float email
  #Date name
  +validateActive()
  +getId()
  +setEmail()
  +setStatus()
}
Librarian ..|> Publisher
Fine --* Publisher
Publisher --|> Fine
note right of Branch : Library domain
@enduml