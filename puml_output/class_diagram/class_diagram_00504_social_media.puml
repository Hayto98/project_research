@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
interface Post {
  -double amount
  +String updatedAt
  +setNote()
}
class Report {
  -int note
  -Date level
  #Date status
  +calculateAddress()
}
interface Message {
  +double updatedAt
  -String score
  +createNote()
  +validateDescription()
}
class Album {
  -boolean duration
  +int address
  #float amount
  #long updatedAt
  -String email
  +processTotal()
  +deleteAmount()
  +setId()
}
abstract class Group {
  -double type
  +int active
  #Date name
  +deleteLevel()
  +sendCreatedat()
}
class Profile {
  #long score
  #int type
  +String note
  -String price
  #boolean level
  +getPhone()
}
Message ..> Report : "*"
Post --|> Message
@enduml