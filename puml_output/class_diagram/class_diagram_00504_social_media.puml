@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
interface Post {
  -double amount
  +String updatedAt
  +calculatePhone()
}
class Report {
  #Date level
  #String status
  +boolean phone
  +int amount
  #float quantity
  +calculateType()
}
class Message {
  +float id
  #Date type
  +long address
  +cancelCode()
  +deleteDuration()
  +sendAddress()
  +calculateId()
}
class Album {
  -double price
  +int type
  #Date createdAt
  #int level
  -String name
  +sendType()
  +processLevel()
  +cancelPrice()
  +saveType()
}
interface Group {
  +Date createdAt
  #Date duration
  #String id
  -Date quantity
  +validateUpdatedat()
}
interface Profile {
  -long name
  -float email
  -int duration
  #boolean updatedAt
  -Date note
  +processTotal()
}
Group --> Message : "1..*"
Album --> Post : "1..*"
Group --|> Post
Message --o Profile
note right of Post : Social Media domain
@enduml