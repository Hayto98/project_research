@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
interface Ward {
  +float score
  +double createdAt
  +Date amount
  +long price
  +updateId()
  +calculateTotal()
  +processCreatedat()
  +validateAddress()
}
class LabTest {
  +String updatedAt
  +Date code
  -float active
  +findTotal()
  +calculateTotal()
  +setDescription()
  +sendNote()
}
interface Doctor {
  -long updatedAt
  -Date address
  #int quantity
  -int type
  #double level
  +updatePhone()
  +sendName()
}
class Hospital {
  +float score
  -Date active
  -boolean level
  +updateUpdatedat()
}
abstract class Patient {
  +Date email
  +Date duration
  -Date quantity
  #Date amount
  +calculateName()
}
Hospital --> Doctor : "1..*"
Patient ..|> Doctor
Patient --o Ward
Ward --|> Doctor
@enduml