@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
interface Ward {
  +float score
  +double createdAt
  +Date amount
  +long price
  +findEmail()
  +setAmount()
  +saveUpdatedat()
  +setActive()
}
class LabTest {
  -float description
  +int note
  +updateDuration()
  +validateQuantity()
  +findType()
  +cancelScore()
}
class Doctor {
  +float address
  #double quantity
  +Date score
  -long amount
  +float level
  +createQuantity()
}
interface Hospital {
  -long status
  -Date note
  +deleteUpdatedat()
  +findDescription()
  +findAddress()
}
class Patient {
  #long duration
  +Date total
  #String email
  -String phone
  +setScore()
  +deleteScore()
  +saveName()
}
Doctor ..|> Ward
Hospital --|> Doctor
Patient ..|> Ward
Doctor --* LabTest
note right of Ward : Healthcare domain
@enduml