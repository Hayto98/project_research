@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Tracking {
  -float address
  #boolean name
  -int total
  +Date amount
  +long phone
  +updateTotal()
  +getNote()
}
interface Manifest {
  -boolean amount
  +long updatedAt
  #boolean total
  +updateScore()
  +saveActive()
}
interface DeliveryNote {
  +long email
  +float note
  #float amount
  #float id
  +String createdAt
  +deleteUpdatedat()
}
class Shipment {
  -float quantity
  -boolean status
  +float price
  +sendScore()
}
interface Package {
  +int createdAt
  +double email
  #boolean total
  +long active
  -long level
  +saveLevel()
  +setDuration()
  +createLevel()
}
Tracking --|> Manifest
DeliveryNote ..|> Tracking
Package ..> DeliveryNote : "0..1"
Tracking --* Package
@enduml