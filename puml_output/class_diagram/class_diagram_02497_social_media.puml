@startuml
skinparam monochrome true
skinparam defaultFontSize 13
abstract class Post {
  +float note
  -long total
  +float address
  #String code
  +sendAddress()
  +cancelStatus()
  +updateTotal()
  +createDuration()
}
class Report {
  #double name
  +String quantity
  +findPhone()
}
interface Like {
  +long code
  +long id
  #float quantity
  +float status
  -Date duration
  +setAddress()
  +getDescription()
  +validateNote()
}
interface Album {
  +boolean createdAt
  -boolean quantity
  +deleteDescription()
  +getStatus()
  +deleteNote()
}
class Notification {
  +Date total
  -int email
  -float type
  +calculateActive()
  +setPhone()
}
class Profile {
  -long amount
  +float type
  -double description
  -double phone
  +float updatedAt
  +sendCode()
  +setPhone()
  +saveDuration()
}
Post --> Report : "0..1"
Album --o Notification
Profile --|> Like
@enduml