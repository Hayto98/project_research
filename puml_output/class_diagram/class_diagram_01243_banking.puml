@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Statement {
  +Date createdAt
  +String active
  +Date updatedAt
  -int phone
  +getPhone()
  +processDuration()
  +deletePrice()
}
class Customer {
  +long score
  +long description
  -String email
  -double duration
  +deleteNote()
  +saveNote()
  +deleteTotal()
}
class Loan {
  -float level
  +String score
  +setScore()
}
class Withdrawal {
  -int level
  #double score
  +float description
  +double updatedAt
  -int name
  +sendId()
  +updatePrice()
  +saveAmount()
}
interface Card {
  -float level
  #double note
  +sendLevel()
  +deleteName()
}
class Transfer {
  -boolean createdAt
  -Date note
  +long email
  +cancelEmail()
  +validateCode()
  +getCode()
}
Withdrawal --o Statement
Transfer ..|> Loan
Card --|> Customer
Withdrawal --|> Customer
@enduml