@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Statement {
  +Date createdAt
  +String active
  +Date updatedAt
  -int phone
  +calculateUpdatedat()
  +processStatus()
  +createScore()
}
class Customer {
  -double email
  +double description
  -long duration
  +int updatedAt
  +sendStatus()
}
interface Loan {
  -boolean amount
  #float status
  +int code
  +float duration
  +deleteLevel()
  +processCreatedat()
  +updateType()
}
class Withdrawal {
  -boolean email
  +boolean createdAt
  -double id
  +deleteEmail()
  +deleteUpdatedat()
  +findCreatedat()
  +processEmail()
}
abstract class Card {
  +boolean status
  #Date address
  -float level
  -String duration
  +saveQuantity()
  +updateLevel()
  +deleteId()
  +processAmount()
}
class Transfer {
  #double code
  +long email
  +double description
  +createActive()
}
Customer --|> Transfer
Transfer --* Withdrawal
Loan --o Withdrawal
note right of Statement : Banking domain
@enduml