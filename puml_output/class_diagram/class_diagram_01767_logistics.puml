@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Inventory {
  #long active
  #Date amount
  +String email
  #boolean score
  #boolean quantity
  +findUpdatedat()
}
interface Vehicle {
  +Date name
  +float score
  +processId()
  +sendActive()
  +saveCreatedat()
}
class Package {
  +String description
  #float quantity
  +calculateUpdatedat()
  +validateStatus()
  +calculateTotal()
  +validateLevel()
}
interface DeliveryNote {
  +String id
  +long quantity
  #long updatedAt
  +createType()
  +cancelUpdatedat()
}
class Warehouse {
  -long email
  -boolean createdAt
  -float amount
  +saveType()
  +setCreatedat()
  +deletePhone()
}
Vehicle --o Warehouse
Warehouse --> Package : "*"
note right of Inventory : Logistics domain
@enduml