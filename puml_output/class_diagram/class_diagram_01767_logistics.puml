@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Inventory {
  #long active
  #Date amount
  +String email
  #boolean score
  #boolean quantity
  +saveStatus()
}
class Vehicle {
  +Date name
  +float score
  +setPrice()
  +deleteId()
  +sendCreatedat()
}
class Package {
  -String code
  +boolean id
  #double description
  +processDuration()
  +createAmount()
  +validateDescription()
  +validateType()
}
class DeliveryNote {
  -float total
  +String phone
  +int score
  -boolean updatedAt
  -float id
  +sendAddress()
  +findActive()
}
interface Warehouse {
  +Date description
  -float level
  +int score
  +sendPhone()
  +deleteCreatedat()
  +processEmail()
  +updateLevel()
}
DeliveryNote ..|> Inventory
Vehicle ..|> Package
Vehicle --o Warehouse
@enduml