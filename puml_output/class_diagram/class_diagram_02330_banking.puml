@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Branch {
  #int createdAt
  +float updatedAt
  +double score
  +Date phone
  +float note
  +sendCreatedat()
}
abstract class Customer {
  #int address
  +int type
  -boolean quantity
  #boolean score
  +String status
  +updateQuantity()
}
class Interest {
  -double createdAt
  #long id
  -long name
  -int type
  -boolean total
  +findName()
  +deleteId()
}
class Card {
  +int email
  +long amount
  +Date address
  #double score
  #double code
  +processScore()
}
interface Transfer {
  #int description
  -float createdAt
  #double amount
  +Date phone
  -int quantity
  +sendPhone()
  +cancelAmount()
}
abstract class Teller {
  +double address
  #boolean type
  +int duration
  +getEmail()
  +getScore()
  +deleteAmount()
}
class Statement {
  +float email
  -Date address
  #double id
  +float updatedAt
  #double price
  +sendId()
  +calculateStatus()
  +sendPhone()
  +deleteScore()
}
Statement --|> Transfer
Teller --|> Branch
Customer ..|> Interest
Customer --o Branch
Card --* Statement
@enduml