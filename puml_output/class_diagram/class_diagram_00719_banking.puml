@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
interface Transfer {
  +long email
  +boolean total
  +double id
  #Date quantity
  +saveTotal()
  +saveQuantity()
}
class Branch {
  -Date address
  #Date type
  +long note
  -String code
  +float quantity
  +processScore()
}
class Card {
  +String total
  #long amount
  #long active
  +sendId()
}
class Teller {
  -int name
  #float duration
  +long type
  #int active
  +deleteType()
}
class Interest {
  +Date name
  -long level
  #String amount
  +Date duration
  #long phone
  +getDescription()
  +updateCreatedat()
}
abstract class Loan {
  #float status
  -String address
  +findLevel()
  +findTotal()
  +processPrice()
  +findCode()
}
Transfer --> Branch : "0..1"
Transfer --o Card
Branch --* Card
Loan ..> Transfer : "1..*"
Teller ..> Interest : "1"
@enduml