@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Teller {
  +boolean description
  -double code
  #long type
  +float id
  +long note
  +sendCreatedat()
}
class Beneficiary {
  -boolean createdAt
  #float name
  #String score
  +validateScore()
  +processDescription()
  +calculateDuration()
}
abstract class Account {
  -double active
  +long level
  +findPhone()
}
abstract class Branch {
  -boolean address
  +int active
  #float type
  #float status
  #int price
  +setDescription()
  +cancelQuantity()
  +findDuration()
}
abstract class Transfer {
  +String name
  -float address
  -long total
  +boolean email
  +deleteScore()
  +processId()
  +setEmail()
  +createType()
}
Branch --* Transfer
Account ..> Teller : "1"
Beneficiary --|> Account
Beneficiary ..|> Teller
@enduml