@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Teller {
  +boolean description
  -double code
  #long type
  +float id
  +long note
  +processEmail()
}
interface Beneficiary {
  -boolean createdAt
  #float name
  #String score
  +validateQuantity()
  +sendPrice()
  +cancelStatus()
}
interface Account {
  -float price
  -long description
  #Date address
  -String name
  #boolean level
  +createLevel()
  +deleteAmount()
  +sendDuration()
  +deleteScore()
}
class Branch {
  -long note
  +float active
  +calculateEmail()
  +setCode()
  +createTotal()
}
class Transfer {
  +boolean duration
  -Date type
  +processPhone()
  +createId()
  +findCode()
  +deleteEmail()
}
Beneficiary ..|> Teller
Teller ..|> Account
note right of Teller : Banking domain
@enduml