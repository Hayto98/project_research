@startuml
skinparam ArrowColor #555555
class Librarian {
  +Date id
  #Date description
  #float name
  #int type
  +deleteTotal()
  +validateCreatedat()
}
abstract class Author {
  +double createdAt
  +long level
  +deleteStatus()
  +updateNote()
  +findActive()
}
class Fine {
  #double name
  -Date price
  +createPhone()
  +setAddress()
}
abstract class Publisher {
  +Date total
  #Date email
  -double note
  +int quantity
  +calculateQuantity()
  +findType()
}
interface Loan {
  #int createdAt
  #long type
  +setNote()
  +validateName()
  +calculateUpdatedat()
  +createCode()
}
Author --o Publisher
Publisher --|> Fine
@enduml