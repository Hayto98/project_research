@startuml
skinparam ArrowColor #555555
class Librarian {
  +Date id
  #Date description
  #float name
  #int type
  +deleteTotal()
  +getCreatedat()
}
interface Author {
  -long note
  #boolean id
  +updateCode()
  +saveName()
  +calculatePrice()
  +processUpdatedat()
}
class Fine {
  -float active
  +Date address
  #Date total
  -double email
  +int note
  +calculateActive()
  +findStatus()
}
class Publisher {
  -double duration
  #int amount
  +int score
  #double email
  -double note
  +setUpdatedat()
  +getLevel()
  +cancelTotal()
}
abstract class Loan {
  -boolean quantity
  +float updatedAt
  -String description
  +processTotal()
  +cancelName()
}
Loan ..> Librarian : "0..1"
Author --|> Fine
Fine ..|> Librarian
note right of Librarian : Library domain
@enduml