@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
abstract class Transaction {
  -double code
  +double active
  -Date total
  +Date description
  +setPrice()
  +validateActive()
}
abstract class Customer {
  -long duration
  +int type
  #int createdAt
  +updateStatus()
}
abstract class Account {
  #long address
  #double score
  #boolean name
  #Date level
  +long quantity
  +updateTotal()
  +validateCreatedat()
  +validatePrice()
}
abstract class Teller {
  +Date id
  +String duration
  +updateCode()
}
class Withdrawal {
  #Date status
  #Date address
  +float duration
  +createEmail()
  +deleteDuration()
  +updateUpdatedat()
}
class Deposit {
  #boolean amount
  #String email
  +float createdAt
  +findId()
  +processStatus()
  +deleteQuantity()
}
Account --|> Transaction
Customer ..> Withdrawal : "1..*"
Deposit ..|> Customer
@enduml