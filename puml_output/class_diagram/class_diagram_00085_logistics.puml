@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Tracking {
  #double description
  -boolean duration
  #boolean note
  #long phone
  +deleteDuration()
  +setCreatedat()
}
class Shipment {
  +int type
  #double code
  +processPhone()
  +saveEmail()
  +findCreatedat()
  +deleteId()
}
class Vehicle {
  -float email
  -Date total
  +deleteCreatedat()
  +validateDescription()
  +createId()
}
class Route {
  +float note
  +int phone
  +float id
  -String name
  +float code
  +createName()
}
abstract class Driver {
  +double createdAt
  -boolean id
  -double updatedAt
  #boolean type
  +cancelActive()
}
class Depot {
  #boolean amount
  +Date name
  +processCode()
  +cancelAddress()
  +findActive()
}
interface FuelLog {
  #String name
  +boolean score
  #double duration
  +getStatus()
  +saveStatus()
  +saveCreatedat()
  +setTotal()
}
Driver --* Route
FuelLog --|> Depot
Tracking ..> Route : "1..*"
Shipment --* Driver
@enduml