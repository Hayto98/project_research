@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Order {
  +int score
  +double duration
  +double updatedAt
  +updateLevel()
  +updateType()
  +createAddress()
}
abstract class Customer {
  -long updatedAt
  -long duration
  +boolean code
  +int createdAt
  +calculateScore()
  +updateAmount()
  +saveCode()
}
class Payment {
  #long price
  +int address
  #double level
  -boolean status
  -Date amount
  +updateCreatedat()
  +updateLevel()
  +deleteNote()
  +validatePrice()
}
class Review {
  #double updatedAt
  -int price
  +String address
  +String active
  +validateQuantity()
  +calculateEmail()
  +deleteName()
  +sendId()
}
abstract class Product {
  #float duration
  -boolean type
  +boolean address
  +boolean updatedAt
  +Date price
  +cancelEmail()
  +deleteCode()
}
Order --> Customer : "0..1"
Review --> Order : "1..*"
@enduml