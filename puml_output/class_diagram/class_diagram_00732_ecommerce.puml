@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Order {
  +int score
  +double duration
  +double updatedAt
  +createAmount()
  +setTotal()
  +validateUpdatedat()
}
class Customer {
  -double createdAt
  -float email
  +cancelDescription()
}
class Payment {
  #double email
  -long price
  +int phone
  #long type
  +updateNote()
}
class Review {
  +double type
  -float quantity
  #Date name
  -long address
  +String phone
  +getName()
}
abstract class Product {
  -double name
  #double email
  -float createdAt
  +findDuration()
  +calculateScore()
}
Product --> Customer : "0..1"
Customer --* Order
note right of Order : Ecommerce domain
@enduml