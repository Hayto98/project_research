@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Exam {
  #boolean createdAt
  #int level
  +String price
  +processEmail()
}
class Course {
  -boolean amount
  #boolean createdAt
  -Date type
  #int description
  +double name
  +sendDuration()
}
abstract class Library {
  -int price
  +int type
  +double email
  -float id
  +updateName()
}
class Book {
  +String type
  +boolean updatedAt
  +long email
  -float description
  #float name
  +cancelQuantity()
  +updateLevel()
  +createPrice()
  +calculateCode()
}
Exam ..|> Book
Book ..> Exam : "1..*"
Course --* Book
note right of Exam : Education domain
@enduml