@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Exam {
  #boolean createdAt
  #int level
  +String price
  +saveAmount()
}
class Course {
  +double note
  +String amount
  +saveTotal()
  +validateActive()
  +setPhone()
}
interface Library {
  +boolean active
  #double description
  -double createdAt
  -long type
  +findActive()
}
class Book {
  -double updatedAt
  #String name
  +saveId()
  +updateStatus()
}
Book --* Exam
Course ..|> Exam
Exam --> Book : "1"
@enduml