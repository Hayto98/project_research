@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
interface Insurance {
  +Date createdAt
  -Date note
  #Date status
  #long price
  +findId()
  +cancelCode()
  +findCode()
}
class Hospital {
  +boolean active
  +Date quantity
  +createEmail()
  +sendType()
  +savePrice()
  +calculateAmount()
}
class Nurse {
  #float level
  +int id
  +updateTotal()
  +getEmail()
  +setPrice()
  +processCreatedat()
}
class Prescription {
  -String amount
  +long id
  +float name
  +validateId()
  +validateUpdatedat()
  +deleteTotal()
}
class Doctor {
  -int level
  +double phone
  +int email
  +deleteCreatedat()
  +findDuration()
  +setTotal()
}
interface Diagnosis {
  #Date duration
  #Date address
  +Date price
  +int code
  +updateUpdatedat()
}
Diagnosis ..|> Prescription
Insurance --> Nurse : "0..1"
Prescription ..|> Hospital
Diagnosis --* Doctor
@enduml