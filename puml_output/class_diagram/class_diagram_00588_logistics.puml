@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
interface Driver {
  #String id
  +boolean phone
  +int duration
  +sendType()
}
class Tracking {
  #float address
  -int level
  +setDescription()
  +cancelCreatedat()
  +updateType()
}
interface DeliveryNote {
  +boolean id
  +Date address
  +getAmount()
  +processId()
  +updateDescription()
}
class Depot {
  +String score
  -boolean level
  +updateEmail()
}
class Warehouse {
  #boolean updatedAt
  -int duration
  +boolean email
  +boolean type
  +setDuration()
  +findNote()
  +calculateName()
  +deletePhone()
}
Tracking --> DeliveryNote : "0..1"
DeliveryNote --|> Warehouse
Depot --|> Warehouse
@enduml