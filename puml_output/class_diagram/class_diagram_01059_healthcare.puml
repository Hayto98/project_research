@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Ward {
  -int amount
  #long updatedAt
  +double id
  +createStatus()
  +findActive()
  +validateActive()
}
class Doctor {
  +double id
  -double code
  +Date quantity
  #float email
  +processDescription()
  +processActive()
}
abstract class Nurse {
  -double score
  +double note
  #double total
  +processUpdatedat()
  +updateName()
  +cancelCode()
}
class Treatment {
  #boolean code
  #Date score
  -boolean amount
  +boolean note
  #int id
  +validateNote()
  +processId()
  +setPhone()
  +sendId()
}
Ward --> Treatment : "1"
Nurse ..|> Doctor
Treatment ..|> Ward
note right of Ward : Healthcare domain
@enduml