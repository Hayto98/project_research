@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Ward {
  -int amount
  #long updatedAt
  +double id
  +cancelAddress()
  +findType()
  +setStatus()
}
interface Doctor {
  +long active
  -int address
  -long phone
  -String id
  +calculateLevel()
  +sendCode()
}
class Nurse {
  -double active
  +double total
  #double description
  -float note
  -int level
  +calculateId()
  +savePrice()
}
class Treatment {
  #double duration
  #Date price
  +Date code
  #boolean amount
  +findName()
  +deleteTotal()
  +calculateAddress()
  +updateNote()
}
Treatment --o Doctor
Treatment --|> Ward
@enduml