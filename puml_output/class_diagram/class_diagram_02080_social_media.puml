@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
interface Message {
  #float code
  #long type
  -long description
  #double price
  +long amount
  +updateStatus()
}
interface Hashtag {
  -Date id
  +boolean status
  +long score
  #boolean duration
  -String updatedAt
  +cancelPrice()
}
class User {
  #Date name
  -Date quantity
  #int id
  #Date price
  +findLevel()
  +saveCreatedat()
  +cancelUpdatedat()
  +saveScore()
}
class Like {
  -boolean id
  +Date quantity
  +createScore()
  +processName()
}
class Notification {
  #long score
  #long description
  -float createdAt
  -float note
  +createQuantity()
}
Notification --|> Hashtag
Notification ..|> Message
note right of Message : Social Media domain
@enduml