@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
interface Message {
  #float code
  #long type
  -long description
  #double price
  +long amount
  +findTotal()
}
class Hashtag {
  +Date duration
  +boolean type
  +getAmount()
}
class User {
  #long code
  +String updatedAt
  #double phone
  +boolean active
  +setUpdatedat()
  +calculatePhone()
  +sendTotal()
}
abstract class Like {
  +float createdAt
  +long note
  -boolean duration
  +Date updatedAt
  +long active
  +setUpdatedat()
  +updateDuration()
  +saveScore()
  +saveActive()
}
class Notification {
  #long note
  -float active
  -float address
  +cancelAddress()
}
User --> Hashtag : "0..1"
Message ..|> Notification
Message --> Hashtag : "*"
@enduml