@startuml
skinparam monochrome true
skinparam defaultFontSize 13
abstract class Librarian {
  +float quantity
  +long score
  #double email
  +long note
  +getScore()
  +processTotal()
  +deleteCreatedat()
  +setPhone()
}
interface Publisher {
  -String id
  -long email
  +updateEmail()
  +getUpdatedat()
}
interface Member {
  -long updatedAt
  +double type
  +float amount
  #long email
  +saveCreatedat()
  +updateAmount()
  +processType()
}
class Reservation {
  -float type
  -int score
  -int description
  -float name
  +deleteType()
  +getCreatedat()
  +validateCreatedat()
}
Librarian --|> Reservation
@enduml