@startuml
skinparam monochrome true
skinparam defaultFontSize 13
abstract class Librarian {
  +float quantity
  +long score
  #double email
  +long note
  +sendNote()
  +createDuration()
  +findDuration()
  +cancelName()
}
class Publisher {
  +double note
  #long status
  +double address
  #float quantity
  +createEmail()
  +createUpdatedat()
}
abstract class Member {
  -double address
  +Date phone
  +processScore()
  +deleteName()
  +validateTotal()
}
class Reservation {
  #String createdAt
  +float price
  +String email
  +int description
  +float status
  +setDescription()
  +calculateQuantity()
  +createCreatedat()
}
Reservation --* Publisher
Member ..> Librarian : "*"
note right of Librarian : Library domain
@enduml