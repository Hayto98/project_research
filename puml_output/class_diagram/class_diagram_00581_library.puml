@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
abstract class Loan {
  -double duration
  #String quantity
  +saveType()
}
class Catalog {
  -String active
  #Date id
  +long duration
  +boolean phone
  #float score
  +cancelCreatedat()
  +sendScore()
  +calculateType()
}
abstract class Shelf {
  #Date level
  -long amount
  +int createdAt
  -int updatedAt
  +setCreatedat()
  +updateLevel()
  +processNote()
  +processTotal()
}
class Reservation {
  -Date code
  #double email
  #int updatedAt
  #boolean note
  +processDuration()
  +validateId()
  +calculateName()
}
Shelf --|> Catalog
Shelf ..> Reservation : "*"
Catalog --> Reservation : "*"
@enduml