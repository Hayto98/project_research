@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
abstract class Loan {
  -double duration
  #String quantity
  +saveUpdatedat()
}
abstract class Catalog {
  #float active
  #float phone
  +calculateStatus()
  +cancelId()
  +validateDescription()
}
interface Shelf {
  -boolean total
  +int price
  +boolean note
  #double active
  +getCreatedat()
  +calculateCreatedat()
  +calculateQuantity()
}
abstract class Reservation {
  -float phone
  +Date code
  +processNote()
  +sendUpdatedat()
  +sendLevel()
  +createUpdatedat()
}
Shelf --> Catalog : "1..*"
Shelf --* Loan
note right of Loan : Library domain
@enduml