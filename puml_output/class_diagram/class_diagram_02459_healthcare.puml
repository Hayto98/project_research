@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
interface Insurance {
  -float duration
  #double price
  -boolean level
  -double id
  #long address
  +getCode()
  +createCode()
  +cancelCode()
}
interface Appointment {
  -long quantity
  #boolean email
  +setType()
}
class Diagnosis {
  #float name
  -boolean phone
  -double price
  #String id
  +validateEmail()
  +calculateDescription()
}
interface Treatment {
  +boolean total
  +String type
  +String quantity
  #long updatedAt
  #float email
  +cancelActive()
}
class Prescription {
  #long email
  +float active
  +cancelTotal()
  +calculatePhone()
  +calculateDescription()
}
Diagnosis --|> Prescription
Appointment --|> Insurance
@enduml