@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Catalog {
  +double amount
  +String price
  +findQuantity()
}
interface Librarian {
  -long quantity
  -boolean total
  +cancelScore()
  +saveStatus()
}
interface Publisher {
  -int quantity
  -long code
  #boolean description
  +cancelStatus()
  +findType()
  +deleteActive()
}
interface Shelf {
  -String phone
  -long email
  +savePrice()
  +saveScore()
  +sendTotal()
  +calculateScore()
}
class Reservation {
  +long level
  +String address
  +Date active
  +getAddress()
  +getTotal()
  +updateEmail()
}
class Member {
  +Date address
  -boolean note
  +setTotal()
  +getDuration()
  +processUpdatedat()
}
Member --|> Librarian
Publisher --o Catalog
Catalog ..|> Publisher
Librarian --|> Reservation
@enduml