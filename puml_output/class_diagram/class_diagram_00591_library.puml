@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Catalog {
  +double amount
  +String price
  +validateActive()
}
class Librarian {
  #Date total
  #float note
  +Date phone
  #int price
  +setDescription()
  +validateCreatedat()
  +createPhone()
}
interface Publisher {
  -long code
  +double type
  -double status
  #long phone
  +createAmount()
}
class Shelf {
  +String active
  #long updatedAt
  -int quantity
  -long name
  +validateNote()
}
class Reservation {
  #int level
  +long email
  +double quantity
  +long amount
  +int duration
  +cancelUpdatedat()
}
interface Member {
  -double phone
  -long duration
  #int status
  +deleteDuration()
  +setCreatedat()
}
Catalog --> Publisher : "1..*"
Shelf --|> Publisher
Shelf --|> Librarian
Catalog --o Shelf
note right of Catalog : Library domain
@enduml