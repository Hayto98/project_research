@startuml
skinparam shadowing true
abstract class Member {
  +int note
  -float duration
  #int description
  -long active
  +getEmail()
}
interface Reservation {
  +Date code
  #int status
  +double quantity
  #String updatedAt
  +int score
  +setQuantity()
  +deleteStatus()
  +getPhone()
  +calculateAddress()
}
interface Catalog {
  #double id
  +Date price
  +Date total
  #String active
  -Date duration
  +saveActive()
  +processStatus()
  +setEmail()
}
abstract class Librarian {
  #float price
  -String duration
  +long total
  +updateDescription()
  +saveEmail()
  +validateCode()
  +processActive()
}
class Book {
  #long price
  +int total
  +getPrice()
  +validateCode()
  +updateQuantity()
}
interface Loan {
  -long phone
  -long duration
  -String total
  +getType()
  +findQuantity()
}
class Author {
  +boolean quantity
  #long id
  #String createdAt
  #double email
  #long amount
  +calculateLevel()
  +createCode()
}
Loan --o Reservation
Reservation --o Librarian
Author --> Catalog : "0..1"
Member ..> Book : "1"
@enduml