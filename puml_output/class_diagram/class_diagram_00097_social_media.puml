@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Story {
  -float active
  #String price
  -Date status
  #boolean duration
  +createTotal()
  +processQuantity()
  +getNote()
}
interface Message {
  #long updatedAt
  #boolean name
  +createType()
}
interface Like {
  #double duration
  +long type
  #int phone
  +String createdAt
  +setCreatedat()
  +processAddress()
  +calculateCode()
}
class User {
  -double amount
  -boolean code
  +saveName()
  +calculateTotal()
}
class Report {
  -boolean duration
  #int type
  +createActive()
}
class Post {
  #Date address
  +Date total
  +getPhone()
}
abstract class Notification {
  -float address
  #int amount
  -Date name
  +getName()
  +setLevel()
  +sendType()
  +validatePhone()
}
Notification ..> User : "*"
Message ..|> Story
Like --|> Message
Post ..> Like : "0..1"
@enduml