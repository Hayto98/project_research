@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Story {
  -float active
  #String price
  -Date status
  #boolean duration
  +findName()
  +createActive()
  +findCode()
}
class Message {
  +Date phone
  #boolean score
  +cancelType()
  +validateCreatedat()
  +saveType()
}
class Like {
  #long score
  #float description
  -float level
  +String id
  +saveCode()
  +processTotal()
}
abstract class User {
  #double price
  -boolean id
  #int code
  +validateUpdatedat()
}
interface Report {
  #Date address
  +Date total
  +calculateTotal()
}
class Post {
  #int amount
  -Date level
  -float name
  +String phone
  +calculateType()
  +deleteCode()
  +deleteEmail()
}
class Notification {
  +long address
  +double updatedAt
  +findCreatedat()
}
Like ..> Report : "1..*"
Message --o Report
Notification --|> Post
Message --o Like
note right of Story : Social Media domain
@enduml