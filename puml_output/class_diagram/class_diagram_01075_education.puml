@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Teacher {
  #int name
  -String status
  -float email
  #float score
  +double duration
  +updateDescription()
  +getType()
  +createEmail()
}
class Schedule {
  #long active
  #Date status
  #String email
  #boolean address
  -float code
  +sendStatus()
  +updateCode()
}
class Department {
  -long amount
  #String name
  #Date id
  +long code
  +String address
  +getScore()
  +setStatus()
}
class Course {
  -float updatedAt
  -long phone
  #boolean duration
  +sendTotal()
  +cancelAddress()
  +updateId()
}
interface Library {
  #int status
  -double score
  -float createdAt
  -boolean total
  +saveCreatedat()
}
Library ..> Schedule : "*"
Course --o Department
note right of Teacher : Education domain
@enduml