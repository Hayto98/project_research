@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Teacher {
  #int name
  -String status
  -float email
  #float score
  +double duration
  +processPrice()
  +getDuration()
  +saveQuantity()
}
class Schedule {
  -long quantity
  +boolean email
  -boolean id
  #Date note
  +Date status
  +setQuantity()
  +findAddress()
  +getCreatedat()
}
class Department {
  +String code
  #float phone
  #String type
  +processAddress()
}
class Course {
  #int email
  -float level
  +String status
  #int active
  +setAddress()
}
class Library {
  +long updatedAt
  #float createdAt
  +sendScore()
  +createEmail()
}
Department --> Library : "*"
Library ..|> Department
Teacher --|> Department
@enduml