@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Deposit {
  +int id
  #int level
  +long amount
  #double createdAt
  +updateId()
  +sendAddress()
  +createEmail()
  +cancelQuantity()
}
abstract class Branch {
  #boolean duration
  +boolean address
  +Date level
  #float code
  -float updatedAt
  +processStatus()
}
class Interest {
  #Date duration
  +Date address
  +double email
  -boolean description
  +boolean createdAt
  +calculateCreatedat()
  +cancelType()
  +saveScore()
}
interface Customer {
  -boolean updatedAt
  #double duration
  +updateCreatedat()
  +setPrice()
}
class Transaction {
  #Date amount
  #long score
  #String status
  #float createdAt
  #int total
  +validateDuration()
  +processId()
  +validateUpdatedat()
}
class Account {
  -int score
  #Date total
  +createNote()
  +sendStatus()
}
class Statement {
  -long createdAt
  #double description
  +String score
  +cancelLevel()
  +createDescription()
  +validateActive()
  +sendEmail()
}
Statement --* Account
Deposit ..> Customer : "1"
Deposit --|> Interest
@enduml