@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Deposit {
  +int id
  #int level
  +long amount
  #double createdAt
  +findEmail()
  +processPrice()
  +calculateDuration()
  +validateAddress()
}
class Branch {
  #String level
  #boolean score
  -float updatedAt
  +validateUpdatedat()
}
abstract class Interest {
  #int email
  -long description
  #String createdAt
  #long amount
  +validateDuration()
  +setUpdatedat()
  +cancelUpdatedat()
}
abstract class Customer {
  #int amount
  -Date email
  #Date type
  -boolean duration
  +Date status
  +validateAddress()
  +cancelType()
}
class Transaction {
  -int score
  #Date total
  +findQuantity()
  +findAmount()
}
class Account {
  #double score
  +String email
  -boolean address
  +deleteQuantity()
  +getPrice()
}
class Statement {
  -float quantity
  -int code
  +validateName()
}
Interest ..> Statement : "1"
Interest ..|> Branch
Deposit --o Account
Transaction ..|> Account
Customer --o Account
note right of Deposit : Banking domain
@enduml