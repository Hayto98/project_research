@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class FuelLog {
  +String description
  -Date email
  +deleteActive()
  +cancelAddress()
}
class Shipment {
  -float note
  #int total
  +String address
  +String status
  #Date name
  +findCode()
  +getActive()
}
class Manifest {
  -Date active
  +long name
  +updateLevel()
  +validateScore()
  +processScore()
  +updatePhone()
}
class Warehouse {
  -float status
  #Date name
  +saveActive()
}
Shipment --* FuelLog
Shipment ..> Manifest : "1"
Warehouse --|> Shipment
@enduml