@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
abstract class Course {
  #boolean createdAt
  +String updatedAt
  -long total
  +boolean quantity
  +calculateCode()
}
interface Library {
  #int createdAt
  -Date email
  +Date score
  -String description
  #String id
  +validateScore()
}
abstract class Exam {
  +long score
  +boolean duration
  -long status
  #double id
  -boolean updatedAt
  +createScore()
  +processPrice()
}
abstract class Assignment {
  +Date phone
  +float type
  #float total
  -Date status
  +processQuantity()
}
interface Department {
  -Date price
  -double active
  -long amount
  +processCreatedat()
  +createAddress()
}
Exam --> Library : "0..1"
Assignment ..|> Library
note right of Course : Education domain
@enduml