@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
abstract class Course {
  #boolean createdAt
  +String updatedAt
  -long total
  +boolean quantity
  +updateEmail()
}
class Library {
  #int createdAt
  -Date email
  +Date score
  -String description
  #String id
  +updateTotal()
}
interface Exam {
  +String price
  -String score
  #double level
  -Date status
  -long id
  +validateDescription()
  +setDuration()
}
class Assignment {
  -float price
  +String duration
  #String phone
  #float score
  -Date type
  +cancelLevel()
}
abstract class Department {
  +long level
  #long createdAt
  -double price
  -int active
  +processActive()
  +findCreatedat()
  +cancelScore()
  +calculateName()
}
Exam --> Library : "0..1"
Assignment ..|> Library
@enduml