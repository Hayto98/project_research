@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Supplier {
  -Date note
  -long type
  -float createdAt
  -String duration
  +getAmount()
  +calculateStatus()
  +updateAmount()
}
interface Warehouse {
  -long price
  #boolean total
  #double score
  #float address
  +calculateDuration()
  +calculateScore()
  +updatePhone()
  +updateActive()
}
class Return {
  +int description
  +float level
  +findActive()
  +sendActive()
  +validatePrice()
  +getName()
}
interface Cart {
  -Date updatedAt
  -Date phone
  +long description
  -boolean createdAt
  +getUpdatedat()
  +setCode()
}
Warehouse --> Cart : "*"
Cart --* Warehouse
@enduml