@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
abstract class Assignment {
  +boolean createdAt
  #double note
  +cancelType()
  +deleteUpdatedat()
  +processScore()
  +processPrice()
}
class Classroom {
  -Date createdAt
  +int updatedAt
  #long quantity
  +boolean description
  +findQuantity()
  +saveLevel()
}
class Student {
  #boolean status
  -double id
  +createQuantity()
  +processActive()
}
class Department {
  +double status
  #Date amount
  +Date note
  -Date id
  +getQuantity()
  +validateUpdatedat()
  +findCode()
}
abstract class Book {
  -long amount
  +int description
  +String createdAt
  -long level
  +String email
  +validateUpdatedat()
  +updateUpdatedat()
  +deletePrice()
}
class Course {
  -Date active
  +boolean duration
  -Date level
  +deleteActive()
  +updateId()
}
Classroom ..|> Student
Student --|> Course
Course ..> Classroom : "*"
Course --* Department
@enduml