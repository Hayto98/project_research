@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
abstract class Assignment {
  +boolean createdAt
  #double note
  +cancelUpdatedat()
  +validateAddress()
  +updateUpdatedat()
  +findQuantity()
}
class Classroom {
  -float name
  -boolean amount
  +float email
  +String level
  #boolean active
  +calculateUpdatedat()
  +createCreatedat()
  +getPhone()
  +saveStatus()
}
class Student {
  #long id
  #long description
  #double price
  -float active
  -Date name
  +deleteDuration()
  +findDescription()
  +updateDescription()
  +createEmail()
}
class Department {
  -long updatedAt
  +String code
  -double name
  +processStatus()
}
class Book {
  -Date createdAt
  -int level
  -int type
  -long description
  +findDescription()
}
abstract class Course {
  +boolean quantity
  -double active
  #Date score
  -boolean note
  #int id
  +findAddress()
  +createPhone()
  +createScore()
  +calculateActive()
}
Department ..|> Classroom
Assignment --* Course
note right of Assignment : Education domain
@enduml