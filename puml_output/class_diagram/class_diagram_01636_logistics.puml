@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Inventory {
  #String email
  -long note
  +int address
  +updateName()
  +getQuantity()
  +saveEmail()
}
class Package {
  -float duration
  #String level
  +savePhone()
  +getCode()
  +getAddress()
}
abstract class FuelLog {
  +boolean level
  +boolean active
  -long phone
  -Date status
  +getAddress()
}
class Warehouse {
  +int createdAt
  -boolean phone
  -int score
  +getType()
  +validateCreatedat()
}
class Manifest {
  -long description
  -boolean phone
  +Date price
  +cancelId()
}
class Tracking {
  #int createdAt
  #String code
  -boolean type
  -double duration
  +validateDescription()
  +validateUpdatedat()
  +setNote()
}
class DeliveryNote {
  #Date price
  #Date createdAt
  -Date description
  +cancelDescription()
}
Manifest --> Inventory : "1..*"
Warehouse --* FuelLog
Tracking ..> Package : "*"
note right of Inventory : Logistics domain
@enduml