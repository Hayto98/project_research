@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Inventory {
  #String email
  -long note
  +int address
  +sendNote()
  +savePhone()
  +saveId()
}
class Package {
  -Date name
  -float id
  +Date email
  +String status
  +createPrice()
  +calculatePhone()
  +calculateLevel()
}
interface FuelLog {
  #double status
  -double amount
  #String score
  +long updatedAt
  +deleteStatus()
  +findAddress()
  +processPhone()
}
class Warehouse {
  -boolean level
  -int score
  +String name
  #Date updatedAt
  +processStatus()
  +validateType()
  +setQuantity()
  +sendId()
}
class Manifest {
  -long description
  -boolean phone
  +Date price
  +deleteDescription()
}
class Tracking {
  +String active
  -int email
  +validateTotal()
  +saveId()
}
class DeliveryNote {
  -int total
  +float quantity
  -float address
  #int description
  +sendScore()
  +setCode()
}
Package ..> Manifest : "1..*"
Tracking --|> Manifest
Manifest ..> Package : "0..1"
@enduml