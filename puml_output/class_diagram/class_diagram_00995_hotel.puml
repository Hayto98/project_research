@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Reservation {
  -int description
  -long duration
  #float note
  #String type
  +deleteDuration()
  +setDuration()
  +findNote()
}
interface Restaurant {
  #String level
  #float duration
  +double phone
  #String address
  +float active
  +findCode()
  +deleteActive()
}
class CheckIn {
  #Date updatedAt
  #String note
  +calculateStatus()
  +calculateStatus()
}
class Amenity {
  +long price
  +int name
  +long address
  +sendName()
  +cancelScore()
  +calculateTotal()
  +calculateEmail()
}
class Housekeeping {
  #String createdAt
  -String status
  -double note
  #float code
  -Date active
  +saveUpdatedat()
}
class Room {
  -long code
  +Date amount
  #String total
  -Date phone
  +processUpdatedat()
  +createQuantity()
  +calculateUpdatedat()
}
class Booking {
  -String address
  -boolean createdAt
  +saveUpdatedat()
  +updateActive()
  +calculateLevel()
  +getType()
}
Restaurant ..|> Booking
Reservation --|> Room
Housekeeping --* Amenity
Amenity --> Restaurant : "*"
Reservation ..> Housekeeping : "*"
note right of Reservation : Hotel domain
@enduml