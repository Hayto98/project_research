@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Reservation {
  -int description
  -long duration
  #float note
  #String type
  +createEmail()
  +setType()
  +setPhone()
}
class Restaurant {
  #String duration
  #float note
  +double phone
  #String address
  +float active
  +validateTotal()
  +getLevel()
}
class CheckIn {
  -boolean name
  #Date updatedAt
  +processUpdatedat()
}
abstract class Amenity {
  -int total
  -String status
  +createNote()
  +validateId()
  +sendPhone()
}
class Housekeeping {
  #String createdAt
  #Date quantity
  #double total
  +setPrice()
  +setNote()
  +deleteName()
  +deleteLevel()
}
class Room {
  #String createdAt
  -String status
  -double note
  #float code
  -Date active
  +processCreatedat()
}
class Booking {
  #float email
  #Date code
  +findAmount()
  +createAmount()
}
CheckIn ..> Restaurant : "1"
Booking ..> Amenity : "1..*"
Amenity --* Restaurant
CheckIn ..|> Amenity
Restaurant --|> Room
@enduml