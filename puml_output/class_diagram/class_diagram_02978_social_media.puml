@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Comment {
  #long phone
  +String updatedAt
  -long status
  +processTotal()
  +saveName()
  +validatePhone()
  +calculateNote()
}
class Story {
  #Date note
  +float amount
  +saveAmount()
  +sendAddress()
}
interface Report {
  +boolean id
  #int score
  -double type
  #int quantity
  +createUpdatedat()
  +cancelUpdatedat()
}
class Post {
  +float price
  -Date status
  #String amount
  +int score
  #float description
  +cancelName()
}
class Like {
  -long quantity
  #float level
  -boolean duration
  +validateActive()
  +validatePhone()
}
abstract class Profile {
  +long price
  -long address
  +updateScore()
  +calculateActive()
  +setStatus()
}
class Group {
  +int total
  +Date updatedAt
  -long code
  +boolean phone
  -long duration
  +getEmail()
  +processId()
}
Story ..> Like : "0..1"
Post ..|> Group
Comment --* Post
note right of Comment : Social Media domain
@enduml