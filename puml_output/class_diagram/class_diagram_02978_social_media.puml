@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Comment {
  #long phone
  +String updatedAt
  -long status
  +calculateAmount()
  +findAmount()
  +deleteStatus()
  +saveEmail()
}
class Story {
  #float total
  -int note
  #Date amount
  +float status
  +createType()
  +cancelDescription()
}
class Report {
  #boolean active
  -long score
  +boolean email
  #int id
  +getAddress()
  +cancelAmount()
  +processActive()
  +setType()
}
class Post {
  #double duration
  -float updatedAt
  #String id
  +findId()
  +getEmail()
}
class Like {
  #float level
  +boolean id
  #String updatedAt
  #long amount
  +processDescription()
  +setPrice()
}
interface Profile {
  -boolean address
  -float quantity
  -double duration
  +Date amount
  +validateScore()
  +createCode()
  +sendPhone()
  +saveCode()
}
class Group {
  +String updatedAt
  #int score
  -float total
  -int active
  +sendPhone()
}
Comment ..|> Story
Profile --* Report
Comment --o Like
Report --|> Story
@enduml