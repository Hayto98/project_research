@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Product {
  #int phone
  +long description
  -Date email
  #Date score
  +String amount
  +saveCreatedat()
}
class Coupon {
  -Date email
  -Date quantity
  -boolean total
  +long level
  +long score
  +createType()
  +getTotal()
  +validateQuantity()
}
interface Review {
  +int note
  #float phone
  +long name
  +float email
  +deleteNote()
  +setPhone()
}
class Wishlist {
  +String quantity
  #float email
  #int duration
  +validateAmount()
  +setPrice()
}
abstract class Supplier {
  #double amount
  #boolean description
  +validatePrice()
}
abstract class Return {
  #long duration
  -float active
  #String price
  +String email
  +long createdAt
  +deleteId()
  +processDuration()
}
Product ..|> Coupon
Wishlist --|> Supplier
note right of Product : Ecommerce domain
@enduml