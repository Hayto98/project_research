@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Product {
  #int phone
  +long description
  -Date email
  #Date score
  +String amount
  +sendPrice()
}
class Coupon {
  -long level
  -long total
  +validateAddress()
  +cancelDescription()
  +deleteCreatedat()
  +sendDuration()
}
abstract class Review {
  -long email
  -double id
  +getPhone()
}
class Wishlist {
  +Date active
  -float phone
  +int note
  #float level
  +validateDuration()
  +calculateEmail()
}
class Supplier {
  +int note
  -long status
  -int phone
  +calculateDuration()
}
class Return {
  #double phone
  -String amount
  +int code
  +findDescription()
  +calculateTotal()
  +deleteUpdatedat()
  +updatePrice()
}
Wishlist --o Return
Supplier --o Return
Return --> Review : "0..1"
@enduml