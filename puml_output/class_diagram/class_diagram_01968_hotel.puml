@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Reservation {
  +float amount
  #String level
  #String price
  +processAmount()
  +createNote()
  +calculateCreatedat()
  +sendNote()
}
class Payment {
  -int address
  +boolean phone
  +cancelDescription()
  +validateScore()
}
class Staff {
  -long updatedAt
  #int level
  +double name
  -double email
  #double score
  +saveId()
  +sendCreatedat()
  +processStatus()
}
interface Service {
  #Date address
  #int email
  +deleteLevel()
  +updateTotal()
}
Staff --> Payment : "1..*"
Service --o Payment
@enduml