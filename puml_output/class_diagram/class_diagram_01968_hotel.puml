@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Reservation {
  +float amount
  #String level
  #String price
  +setAddress()
  +updateQuantity()
  +sendLevel()
  +saveId()
}
class Payment {
  #int total
  #long amount
  +Date level
  -int active
  +createName()
}
abstract class Staff {
  -Date updatedAt
  -long status
  +double type
  -boolean email
  +validateEmail()
}
interface Service {
  #float level
  -long createdAt
  -boolean phone
  +processType()
  +processEmail()
  +validateDescription()
}
Service --> Reservation : "0..1"
Payment --|> Staff
note right of Reservation : Hotel domain
@enduml