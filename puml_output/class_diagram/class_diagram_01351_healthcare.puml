@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class MedicalRecord {
  -long score
  #float quantity
  +getStatus()
  +getAmount()
}
class Patient {
  -float address
  +long status
  +findActive()
  +sendQuantity()
  +validateCode()
}
abstract class Prescription {
  -boolean createdAt
  -double name
  -long note
  #double id
  -String total
  +setQuantity()
  +calculateCode()
  +saveUpdatedat()
}
class Diagnosis {
  -boolean amount
  #double description
  +cancelName()
  +getEmail()
  +findLevel()
  +saveType()
}
class Insurance {
  #boolean total
  #boolean address
  +String description
  +calculateName()
}
class Ward {
  -Date code
  +Date level
  +int name
  -boolean active
  +deleteQuantity()
  +saveStatus()
  +deleteEmail()
  +createPrice()
}
Ward ..> Patient : "*"
Ward ..|> Prescription
note right of MedicalRecord : Healthcare domain
@enduml