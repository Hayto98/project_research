@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class MedicalRecord {
  -long score
  #float quantity
  +calculateId()
  +setStatus()
}
class Patient {
  #String updatedAt
  -float code
  +long address
  +createLevel()
  +findPrice()
  +saveActive()
}
class Prescription {
  +double code
  #String type
  #boolean note
  -long createdAt
  +sendCreatedat()
  +deleteDuration()
  +cancelPhone()
}
interface Diagnosis {
  -String quantity
  #Date name
  #int phone
  -String code
  +float duration
  +cancelCode()
  +getQuantity()
}
abstract class Insurance {
  +int level
  -long name
  +Date id
  #float email
  #boolean type
  +sendTotal()
}
class Ward {
  #long name
  #String code
  #int address
  +long level
  #boolean duration
  +findPhone()
  +getNote()
  +calculateTotal()
  +findStatus()
}
Patient --* Prescription
Ward --|> Diagnosis
@enduml