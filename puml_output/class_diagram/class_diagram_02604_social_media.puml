@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Follower {
  -long name
  +double type
  +cancelEmail()
  +getTotal()
  +cancelType()
  +calculateEmail()
}
class Group {
  -boolean createdAt
  #long phone
  #float note
  -long duration
  +setQuantity()
  +validateActive()
  +validateEmail()
  +findAmount()
}
class User {
  -boolean createdAt
  +boolean active
  +deleteEmail()
  +setId()
  +calculatePrice()
}
class Message {
  -Date updatedAt
  +int total
  +float quantity
  +float active
  +createScore()
  +findActive()
  +processActive()
}
class Notification {
  -Date duration
  -float phone
  +validateAmount()
  +setDescription()
  +calculateQuantity()
  +saveId()
}
Notification ..|> Message
Follower ..|> Message
note right of Follower : Social Media domain
@enduml