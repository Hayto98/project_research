@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Follower {
  -long name
  +double type
  +findLevel()
  +createId()
  +savePrice()
  +findCreatedat()
}
class Group {
  -int duration
  -float type
  -int price
  -boolean email
  #long phone
  +calculateScore()
  +calculateCode()
  +setDescription()
}
class User {
  +String active
  #int address
  #double email
  #int amount
  +setLevel()
  +findCreatedat()
  +validatePhone()
}
class Message {
  #float price
  -boolean status
  -Date address
  +int updatedAt
  +float total
  +cancelType()
  +createActive()
}
class Notification {
  #long active
  -long email
  +String status
  +double phone
  -Date total
  +findId()
}
Message --|> Group
Notification ..|> Message
User ..> Message : "0..1"
User ..> Follower : "0..1"
@enduml