@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
abstract class User {
  #int amount
  +String note
  -double email
  +cancelCode()
  +validateEmail()
  +updateAddress()
  +saveDuration()
}
class Message {
  -int updatedAt
  +long code
  -float total
  +sendAddress()
  +sendActive()
}
interface Group {
  -Date amount
  -float updatedAt
  +processCreatedat()
  +setNote()
  +calculateId()
}
class Story {
  -float status
  #boolean address
  +double email
  -double quantity
  +updateStatus()
  +getPhone()
}
interface Comment {
  #double amount
  +boolean id
  -String total
  +long address
  -double price
  +saveType()
  +validateAddress()
}
class Profile {
  #int address
  +float total
  +createTotal()
  +processPrice()
  +processAddress()
}
Group --o Profile
Comment --|> User
Message ..> Comment : "1..*"
Story --|> Comment
@enduml