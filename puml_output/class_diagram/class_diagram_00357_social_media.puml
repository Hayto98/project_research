@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
abstract class User {
  #int amount
  +String note
  -double email
  +processStatus()
  +saveLevel()
  +findAmount()
  +sendUpdatedat()
}
class Message {
  +float total
  +long quantity
  +deleteEmail()
  +cancelScore()
  +setAmount()
}
class Group {
  #Date email
  -String phone
  -long total
  -double name
  #boolean duration
  +calculateQuantity()
  +calculateAmount()
}
class Story {
  -float duration
  #Date price
  -boolean amount
  -String id
  #long total
  +updateAddress()
}
class Comment {
  -Date amount
  +int email
  -Date duration
  +float status
  -long address
  +calculateActive()
  +getCode()
  +deleteScore()
}
interface Profile {
  #Date note
  +Date score
  -boolean code
  -boolean phone
  +validateLevel()
  +cancelTotal()
}
Story --o Group
User ..|> Story
Message --o Group
Profile --* User
Comment --> Group : "1"
note right of User : Social Media domain
@enduml