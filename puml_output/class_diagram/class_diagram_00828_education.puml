@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
interface Teacher {
  -boolean level
  -Date active
  +double id
  +String note
  +validatePrice()
}
abstract class Book {
  -long createdAt
  +Date price
  +int code
  +cancelAddress()
}
abstract class Schedule {
  -Date price
  +double name
  +validateName()
}
class Grade {
  -long description
  #float address
  -long phone
  #boolean type
  +int name
  +sendStatus()
  +sendCreatedat()
  +findUpdatedat()
  +updateNote()
}
class Library {
  #int level
  +double code
  #Date description
  -boolean address
  +deleteStatus()
  +calculateNote()
}
class Attendance {
  -boolean id
  -long quantity
  +Date level
  -String note
  #long score
  +deleteStatus()
  +setDescription()
  +updateType()
  +cancelPhone()
}
abstract class Student {
  #long createdAt
  +boolean name
  -Date description
  #String note
  +String score
  +calculateQuantity()
}
Library --o Grade
Schedule ..|> Teacher
Library ..> Attendance : "1..*"
note right of Teacher : Education domain
@enduml