@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
interface Teacher {
  -boolean level
  -Date active
  +double id
  +String note
  +findQuantity()
}
abstract class Book {
  +double active
  -String level
  #int createdAt
  +String score
  #float price
  +sendCode()
  +sendTotal()
  +processNote()
}
abstract class Schedule {
  -String address
  -String id
  +savePrice()
  +findStatus()
}
abstract class Grade {
  +double address
  -Date phone
  -long type
  +getEmail()
}
abstract class Library {
  #int active
  +double createdAt
  +saveDescription()
}
class Attendance {
  #int description
  +double address
  +createUpdatedat()
  +validateNote()
  +createCreatedat()
  +cancelEmail()
}
abstract class Student {
  -float quantity
  -double total
  #double id
  -int duration
  #long active
  +calculateDuration()
}
Attendance --o Library
Book --|> Teacher
Book --o Student
Library --o Schedule
@enduml