@startuml
skinparam monochrome true
class Transaction {
  +Date phone
  -String address
  +sendTotal()
  +setUpdatedat()
  +calculateCreatedat()
  +cancelCode()
}
abstract class Deposit {
  +long description
  #String score
  -int id
  +createLevel()
  +createPhone()
  +validateAddress()
}
class Card {
  -boolean code
  -boolean price
  #Date address
  +getDuration()
  +setEmail()
}
class Transfer {
  -Date description
  -int quantity
  +int note
  +boolean total
  +getAddress()
  +updateNote()
  +sendPrice()
}
Deposit --|> Transfer
Transaction ..|> Deposit
note right of Transaction : Banking domain
@enduml