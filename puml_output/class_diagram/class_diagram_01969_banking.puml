@startuml
skinparam monochrome true
class Transaction {
  +Date phone
  -String address
  +cancelAmount()
  +processLevel()
  +cancelStatus()
  +updateStatus()
}
abstract class Deposit {
  #Date duration
  #Date code
  +float total
  +getActive()
  +calculateDuration()
}
class Card {
  -int quantity
  -long name
  +createAmount()
  +validateDuration()
  +calculateName()
}
class Transfer {
  -boolean code
  -boolean price
  #Date address
  +processCode()
  +updateScore()
}
Card --* Deposit
Deposit --o Transfer
@enduml