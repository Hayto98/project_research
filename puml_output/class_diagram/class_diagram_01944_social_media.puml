@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
interface Follower {
  +long active
  #Date amount
  #Date quantity
  +deleteType()
}
class Report {
  #float active
  +long duration
  -Date code
  +validateQuantity()
}
class Message {
  +float code
  #Date type
  +updateStatus()
  +validatePrice()
}
abstract class Comment {
  #double id
  +int note
  -boolean address
  #Date active
  +deleteDuration()
  +savePrice()
  +createPrice()
  +cancelCode()
}
Report --|> Follower
Message --* Comment
Report --* Comment
note right of Follower : Social Media domain
@enduml