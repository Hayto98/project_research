@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
interface Follower {
  +long active
  #Date amount
  #Date quantity
  +saveAddress()
}
abstract class Report {
  #Date level
  +float score
  #float description
  +long active
  +saveDescription()
  +updateName()
  +calculateCreatedat()
}
class Message {
  #Date id
  #Date code
  #boolean type
  #int name
  +validateId()
  +updateTotal()
}
abstract class Comment {
  +int email
  -boolean id
  #Date note
  -int address
  #float price
  +createQuantity()
  +createDuration()
  +processId()
  +setQuantity()
}
Comment ..|> Message
Follower ..> Comment : "1..*"
@enduml