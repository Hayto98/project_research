@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
interface CheckIn {
  #long createdAt
  -String type
  +String email
  #double price
  -double amount
  +processAmount()
  +updateCreatedat()
}
abstract class Room {
  -long updatedAt
  #int total
  +sendId()
  +cancelEmail()
}
interface Invoice {
  -double address
  -String note
  -Date name
  #Date total
  +updateDescription()
  +calculatePhone()
  +validateStatus()
}
class Guest {
  -long level
  +Date amount
  +Date address
  +validateActive()
  +updatePrice()
}
Invoice --o CheckIn
Room ..|> Invoice
Guest ..|> Room
note right of CheckIn : Hotel domain
@enduml