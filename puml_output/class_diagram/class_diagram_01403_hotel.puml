@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
interface CheckIn {
  #long createdAt
  -String type
  +String email
  #double price
  -double amount
  +createName()
  +deleteScore()
}
class Room {
  -double type
  -float name
  #int updatedAt
  +updateNote()
  +sendDuration()
}
class Invoice {
  +double duration
  -double email
  -String address
  -Date note
  +processPrice()
  +createLevel()
  +saveQuantity()
}
abstract class Guest {
  #float phone
  +long status
  -long createdAt
  +Date updatedAt
  +updatePhone()
  +createCreatedat()
}
Room --* Guest
Invoice --o CheckIn
Room ..|> Invoice
@enduml