@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Assignment {
  -String duration
  +long quantity
  +validateAmount()
  +setScore()
  +saveId()
  +processLevel()
}
class Attendance {
  +float quantity
  #Date amount
  -int createdAt
  -boolean code
  +createStatus()
  +processScore()
  +calculateDuration()
}
interface Exam {
  +long total
  #String address
  -float active
  -String price
  -float status
  +getEmail()
  +updateType()
  +getId()
}
class Department {
  +Date status
  #String note
  #String type
  +findScore()
  +updateTotal()
  +processDescription()
  +createLevel()
}
class Book {
  #long description
  #long note
  -long active
  -long createdAt
  #float score
  +saveTotal()
}
Attendance --|> Book
@enduml