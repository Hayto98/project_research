@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Assignment {
  -String duration
  +long quantity
  +createName()
  +calculateQuantity()
  +validateQuantity()
  +deleteCreatedat()
}
class Attendance {
  +long level
  #float address
  +sendScore()
  +sendNote()
  +saveTotal()
}
class Exam {
  -String status
  -float description
  -int phone
  +double id
  #long total
  +setNote()
  +processUpdatedat()
}
class Department {
  -long duration
  -Date price
  +saveScore()
  +calculateDescription()
}
abstract class Book {
  -long createdAt
  -long email
  #float phone
  +deleteDescription()
}
Assignment ..|> Attendance
Book --> Exam : "1..*"
note right of Assignment : Education domain
@enduml