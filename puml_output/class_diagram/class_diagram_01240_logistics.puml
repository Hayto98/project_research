@startuml
skinparam ArrowColor #555555
interface Route {
  #String address
  +float updatedAt
  +double name
  +saveActive()
  +getName()
  +saveNote()
}
class DeliveryNote {
  -Date total
  #boolean quantity
  -boolean createdAt
  +getPrice()
  +createType()
  +calculateQuantity()
  +deleteDuration()
}
class Warehouse {
  #int type
  -Date description
  -Date duration
  +processType()
  +saveType()
  +setCreatedat()
  +createCreatedat()
}
class Shipment {
  +double createdAt
  +long address
  +setAmount()
  +saveActive()
}
Shipment --> Warehouse : "1..*"
Shipment --|> Route
DeliveryNote ..> Route : "1..*"
@enduml