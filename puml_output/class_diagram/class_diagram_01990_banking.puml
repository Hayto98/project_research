@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Card {
  +int status
  #boolean email
  +calculateActive()
  +createDuration()
  +setNote()
  +calculateType()
}
class Account {
  #float duration
  -float type
  -double id
  -Date code
  +savePhone()
  +findLevel()
  +cancelDuration()
  +createScore()
}
class Beneficiary {
  +String amount
  #boolean total
  #Date active
  #Date id
  +updatePhone()
  +updateAmount()
  +sendEmail()
  +createAddress()
}
class Teller {
  +double status
  +String address
  +String note
  #int score
  +updateTotal()
  +setDuration()
  +saveTotal()
}
class Customer {
  +double createdAt
  #long amount
  -float description
  +createNote()
  +saveLevel()
  +updateQuantity()
}
class Withdrawal {
  -boolean score
  +int total
  +float code
  +int email
  +saveId()
  +sendTotal()
  +updateUpdatedat()
}
Customer --o Withdrawal
Teller --* Customer
Beneficiary --> Customer : "1..*"
Beneficiary --* Withdrawal
Card --> Teller : "0..1"
note right of Card : Banking domain
@enduml