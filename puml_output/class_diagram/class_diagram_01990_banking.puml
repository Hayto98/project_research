@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Card {
  +int status
  #boolean email
  +setNote()
  +calculateType()
  +updateQuantity()
  +getScore()
}
class Account {
  #double note
  -boolean total
  +sendActive()
  +deleteLevel()
  +validateName()
}
class Beneficiary {
  -double price
  #Date duration
  +processNote()
  +sendPhone()
  +validateTotal()
  +saveDuration()
}
interface Teller {
  #int score
  -boolean status
  +String active
  +boolean quantity
  +processDuration()
  +saveScore()
  +createScore()
  +updateAmount()
}
class Customer {
  +long email
  #double address
  -int duration
  -float quantity
  +setDescription()
  +cancelTotal()
}
class Withdrawal {
  +boolean email
  #Date updatedAt
  -String total
  +sendEmail()
  +createCode()
}
Account ..> Teller : "1..*"
Teller --* Beneficiary
Withdrawal ..> Teller : "0..1"
@enduml