@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
abstract class Review {
  +double phone
  -double description
  +findNote()
  +getStatus()
  +setDuration()
}
abstract class Category {
  +int createdAt
  -Date id
  +validateId()
  +createPrice()
}
class Coupon {
  -double total
  #String updatedAt
  +findUpdatedat()
  +cancelTotal()
  +cancelDuration()
}
interface Shipment {
  -int id
  #double amount
  -boolean updatedAt
  -long total
  +createType()
  +cancelAddress()
}
class Supplier {
  -Date address
  -long createdAt
  +double id
  #long email
  #int updatedAt
  +findEmail()
  +findScore()
}
interface Warehouse {
  #long quantity
  +long price
  -long phone
  #boolean amount
  -long updatedAt
  +saveNote()
  +createName()
}
class Product {
  -boolean type
  -long status
  #int description
  +setScore()
}
Shipment --> Review : "*"
Category --* Shipment
Shipment ..> Product : "0..1"
Review --|> Warehouse
Review ..|> Coupon
Coupon ..|> Supplier
@enduml