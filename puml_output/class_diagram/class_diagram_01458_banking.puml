@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
abstract class Withdrawal {
  #Date duration
  +Date price
  #int id
  +boolean type
  #int total
  +setDuration()
}
class Statement {
  #Date id
  #String level
  +cancelType()
  +createStatus()
  +deleteQuantity()
}
abstract class Teller {
  #String active
  -int email
  +String id
  -String status
  +sendLevel()
  +saveType()
  +findName()
}
interface Branch {
  #double score
  +String address
  +float description
  -int note
  +updateNote()
  +calculateEmail()
  +sendDescription()
}
abstract class Deposit {
  #boolean phone
  #String id
  +long address
  +createActive()
  +deleteDuration()
  +cancelDescription()
}
interface Interest {
  #long quantity
  -Date updatedAt
  +int amount
  +validateEmail()
  +saveTotal()
  +createStatus()
}
Branch --o Withdrawal
Interest --> Deposit : "1"
Deposit --|> Teller
@enduml