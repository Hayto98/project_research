@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
abstract class Amenity {
  -long level
  #double updatedAt
  -float price
  -String name
  +calculateName()
  +calculateNote()
}
class Restaurant {
  +String phone
  +float active
  -double name
  +String price
  #int total
  +processUpdatedat()
  +processTotal()
  +validateEmail()
  +sendQuantity()
}
class Room {
  -long email
  #boolean quantity
  +String level
  -boolean description
  -long code
  +findCreatedat()
  +cancelPrice()
  +setStatus()
  +getDuration()
}
class Housekeeping {
  #float score
  -float status
  +getNote()
}
interface Payment {
  #long email
  +boolean score
  +int address
  +boolean duration
  +deleteCode()
  +saveActive()
  +sendName()
  +setLevel()
}
abstract class Reservation {
  #Date address
  #int level
  +int amount
  -Date score
  +boolean phone
  +savePrice()
  +deleteActive()
}
Housekeeping ..|> Reservation
Housekeeping --> Payment : "0..1"
note right of Amenity : Hotel domain
@enduml