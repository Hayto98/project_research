@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Shelf {
  +double active
  +float status
  +double address
  +updateId()
  +processName()
}
interface Fine {
  #String active
  -long address
  +validateId()
}
interface Reservation {
  #Date description
  +boolean updatedAt
  -Date createdAt
  +processName()
  +saveStatus()
}
interface Member {
  #float updatedAt
  #boolean level
  #Date phone
  +int createdAt
  +saveNote()
  +processQuantity()
}
Member --|> Reservation
Reservation ..> Shelf : "0..1"
@enduml