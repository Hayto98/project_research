skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Shelf {
  +double active
  +float status
  +double address
  +findId()
  +cancelId()
}
interface Fine {
  +boolean id
  #Date note
  #boolean quantity
  +int code
