@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Tracking {
  +long status
  +String amount
  +long id
  -int name
  +processAmount()
  +saveAddress()
  +createLevel()
  +findAmount()
}
abstract class Driver {
  +double total
  +Date code
  -float level
  +deleteStatus()
}
abstract class Shipment {
  -String score
  +float status
  +saveTotal()
  +processId()
}
class Route {
  #String quantity
  #int type
  +float level
  +sendName()
  +cancelAddress()
  +createCode()
}
class DeliveryNote {
  #double duration
  +double createdAt
  +saveActive()
  +cancelAmount()
}
class Inventory {
  -String email
  #long active
  -String level
  -Date price
  #String type
  +cancelAddress()
  +getCreatedat()
  +validateActive()
}
abstract class Package {
  #long status
  #String duration
  #long id
  +updateEmail()
  +setTotal()
  +sendPrice()
  +cancelLevel()
}
Route ..|> Inventory
Tracking --o Shipment
Route --o Package
Package --o Inventory
@enduml