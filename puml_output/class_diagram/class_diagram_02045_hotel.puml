@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Restaurant {
  #String code
  #float type
  -boolean quantity
  +setAmount()
}
interface Staff {
  -float active
  #String note
  #Date email
  +sendPhone()
  +createId()
}
class Housekeeping {
  +float phone
  #Date description
  +createAmount()
}
class Service {
  +Date note
  +Date id
  +Date duration
  -Date name
  #int type
  +deleteTotal()
  +validatePhone()
  +getDescription()
}
Restaurant ..> Staff : "*"
Housekeeping --> Restaurant : "0..1"
note right of Restaurant : Hotel domain
@enduml