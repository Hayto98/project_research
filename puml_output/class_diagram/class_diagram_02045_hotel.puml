@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Restaurant {
  #String code
  #float type
  -boolean quantity
  +findNote()
}
class Staff {
  -float active
  #String note
  #Date email
  +findDuration()
  +saveScore()
}
class Housekeeping {
  -int quantity
  +float status
  +sendType()
}
class Service {
  +Date status
  -boolean type
  +double note
  +createType()
  +getType()
}
Housekeeping ..> Service : "0..1"
Housekeeping ..> Restaurant : "*"
@enduml