@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Cart {
  #float duration
  +long name
  #int phone
  +validateQuantity()
  +saveScore()
  +cancelName()
  +cancelEmail()
}
class Invoice {
  +boolean quantity
  -boolean name
  +long amount
  +updateQuantity()
  +findDescription()
}
class Order {
  #long phone
  #int score
  #float price
  #long active
  -int name
  +deleteCreatedat()
  +processAmount()
  +deleteLevel()
}
class Return {
  +double amount
  #long total
  -float price
  -String email
  +Date score
  +calculateTotal()
  +saveUpdatedat()
  +setDuration()
  +sendDescription()
}
abstract class Supplier {
  -float level
  -double phone
  +String amount
  -int description
  #int total
  +findUpdatedat()
  +processEmail()
  +cancelDuration()
}
class Warehouse {
  #boolean amount
  -boolean quantity
  #Date note
  -Date price
  +boolean score
  +createDescription()
  +setAmount()
  +saveTotal()
  +validateAddress()
}
interface Shipment {
  -boolean level
  -int status
  +long phone
  +updateStatus()
}
Shipment --|> Cart
Return --o Order
Shipment --|> Return
@enduml