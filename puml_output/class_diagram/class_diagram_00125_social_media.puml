@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Story {
  -boolean type
  +double description
  +findTotal()
  +setStatus()
}
abstract class Like {
  +int type
  #boolean quantity
  #float active
  +saveName()
}
class Post {
  +Date level
  #float name
  +Date amount
  +calculateCode()
}
interface Follower {
  -boolean duration
  #double level
  +boolean status
  #int score
  #boolean phone
  +calculateActive()
  +validateEmail()
}
class Profile {
  -String name
  +float level
  -float email
  -float duration
  +updateType()
  +updateActive()
}
class Report {
  +float code
  #String description
  +boolean id
  +updateAddress()
}
Follower --|> Profile
Post ..> Story : "1..*"
Follower --|> Post
Story ..|> Profile
note right of Story : Social Media domain
@enduml