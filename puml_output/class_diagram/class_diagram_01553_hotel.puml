@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Restaurant {
  -double code
  -int phone
  -double name
  +findId()
  +saveAddress()
  +setId()
  +createPhone()
}
class Booking {
  +Date active
  #int duration
  #double level
  +cancelStatus()
}
class Housekeeping {
  #boolean email
  #long name
  -float type
  +long quantity
  +updateCreatedat()
}
interface Staff {
  -int address
  -double price
  +processUpdatedat()
}
interface Amenity {
  -double status
  #Date updatedAt
  +boolean level
  -String active
  +sendType()
  +validateType()
}
Booking ..|> Amenity
Amenity ..|> Booking
Housekeeping --* Amenity
@enduml