@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Profile {
  -float type
  +double address
  +sendEmail()
}
class Hashtag {
  -Date duration
  -double id
  +boolean price
  +createAmount()
  +createCreatedat()
  +findAmount()
}
class Like {
  #long phone
  -boolean id
  #int score
  +validateCreatedat()
  +saveUpdatedat()
  +sendName()
}
class Post {
  -String type
  -boolean total
  +boolean note
  -Date score
  +updateNote()
  +calculateAmount()
}
Post ..|> Profile
Profile ..|> Hashtag
@enduml