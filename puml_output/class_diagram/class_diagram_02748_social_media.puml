@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Profile {
  -float type
  +double address
  +updateDescription()
}
class Hashtag {
  #double price
  -float duration
  +cancelDuration()
  +validatePhone()
}
class Like {
  -boolean updatedAt
  #int description
  -int phone
  #double id
  -long email
  +calculateNote()
  +processAddress()
  +setPhone()
  +cancelId()
}
interface Post {
  -String updatedAt
  +String active
  -int note
  #double price
  +cancelAddress()
}
Post ..> Like : "0..1"
Profile ..|> Post
Like ..> Post : "*"
note right of Profile : Social Media domain
@enduml