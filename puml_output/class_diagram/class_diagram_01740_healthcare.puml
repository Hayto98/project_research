@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
abstract class Hospital {
  -float total
  -double id
  +calculateUpdatedat()
}
class Appointment {
  +double level
  +long type
  #double quantity
  #long code
  +sendId()
}
class Treatment {
  #boolean score
  -long email
  -Date description
  +createScore()
}
class Patient {
  +double createdAt
  #String active
  #double email
  -int code
  #float total
  +getPrice()
}
Hospital --o Treatment
Appointment --|> Hospital
Patient --|> Hospital
@enduml