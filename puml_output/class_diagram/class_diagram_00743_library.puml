@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
abstract class Catalog {
  +double duration
  #int active
  -int name
  +createActive()
  +processScore()
  +getPrice()
  +processQuantity()
}
abstract class Loan {
  +Date amount
  -int id
  +int price
  +String description
  +deleteCode()
  +saveId()
}
class Fine {
  #String description
  #int updatedAt
  +double quantity
  +long id
  +cancelType()
  +deleteAddress()
  +setId()
}
interface Publisher {
  +String type
  -double amount
  -Date total
  #double active
  +deleteCreatedat()
  +calculateTotal()
  +deleteUpdatedat()
  +sendAmount()
}
Loan ..|> Catalog
Fine --* Catalog
note right of Catalog : Library domain
@enduml