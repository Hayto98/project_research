@startuml
skinparam monochrome true
skinparam defaultFontSize 11
abstract class Grade {
  +Date quantity
  #Date email
  #float status
  #Date updatedAt
  -int type
  +calculateDuration()
}
abstract class Department {
  +String duration
  +float active
  +deleteActive()
  +updateCreatedat()
  +setUpdatedat()
  +calculateTotal()
}
interface Book {
  #double phone
  +int description
  +updateStatus()
  +deleteAddress()
  +updateScore()
  +calculateTotal()
}
class Teacher {
  +long type
  -boolean quantity
  +String status
  -boolean duration
  +saveCode()
}
class Library {
  -long price
  -float active
  +double createdAt
  +deleteDuration()
}
abstract class Exam {
  #Date updatedAt
  -long price
  +calculateDescription()
  +deleteNote()
  +cancelCode()
  +updateStatus()
}
abstract class Classroom {
  +int phone
  -float score
  +sendAmount()
}
Teacher --* Exam
Book --* Classroom
Exam --> Department : "1..*"
Department ..|> Book
note right of Grade : Education domain
@enduml