@startuml
skinparam monochrome true
skinparam defaultFontSize 11
abstract class Grade {
  +Date quantity
  #Date email
  #float status
  #Date updatedAt
  -int type
  +deleteAmount()
}
interface Department {
  +float score
  -int status
  #int active
  +String id
  +double name
  +setId()
  +updatePrice()
  +getPrice()
  +setPrice()
}
class Book {
  +double duration
  +String note
  +long name
  +getPrice()
  +getCreatedat()
}
abstract class Teacher {
  -int amount
  -long address
  #float type
  +String quantity
  -boolean status
  +cancelScore()
}
class Library {
  -long amount
  -float price
  +double active
  +int createdAt
  +savePhone()
  +setCode()
  +findStatus()
  +validateNote()
}
abstract class Exam {
  +double email
  #String level
  +String note
  -float total
  +long description
  +validateNote()
}
abstract class Classroom {
  -double score
  #long amount
  +validateScore()
  +findCode()
  +getActive()
}
Library ..|> Book
Book --|> Department
Book ..> Classroom : "*"
@enduml