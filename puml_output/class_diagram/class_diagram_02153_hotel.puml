@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
abstract class Reservation {
  #float description
  #float phone
  +findScore()
}
interface Amenity {
  +Date createdAt
  +Date amount
  +cancelStatus()
}
abstract class Invoice {
  +String createdAt
  +double amount
  +cancelDescription()
  +cancelPrice()
  +sendDuration()
  +calculateNote()
}
class Booking {
  #int amount
  +long updatedAt
  #long type
  +boolean id
  +processTotal()
}
class Staff {
  #double code
  -int address
  +sendName()
}
class Payment {
  +float quantity
  #int type
  +validateType()
  +processAddress()
}
Booking --* Reservation
Amenity ..|> Reservation
Amenity ..|> Payment
Reservation ..|> Payment
@enduml