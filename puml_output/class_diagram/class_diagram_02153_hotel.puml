@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
abstract class Reservation {
  #float description
  #float phone
  +createLevel()
}
class Amenity {
  #Date amount
  +String description
  -Date status
  +updateAmount()
}
class Invoice {
  -Date status
  #Date note
  +getEmail()
  +deleteUpdatedat()
}
abstract class Booking {
  -boolean updatedAt
  -int amount
  +processPhone()
}
class Staff {
  -int address
  +double total
  +setQuantity()
  +processCreatedat()
}
interface Payment {
  -String amount
  -float score
  +String quantity
  +updateAmount()
  +deleteName()
}
Amenity ..> Invoice : "0..1"
Reservation ..|> Payment
note right of Reservation : Hotel domain
@enduml