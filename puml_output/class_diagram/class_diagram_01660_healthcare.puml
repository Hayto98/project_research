@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Treatment {
  +double updatedAt
  #Date createdAt
  +sendUpdatedat()
}
class Insurance {
  -float description
  #float createdAt
  #float id
  +getStatus()
  +updateStatus()
  +updateLevel()
  +findAddress()
}
class Nurse {
  -Date price
  -double quantity
  #float name
  +createPhone()
  +validateAddress()
}
abstract class LabTest {
  #String total
  +String duration
  -long quantity
  #boolean score
  +Date address
  +saveDuration()
  +cancelDescription()
}
class Diagnosis {
  -long amount
  +boolean status
  +double price
  +sendQuantity()
  +updateUpdatedat()
  +calculateActive()
}
interface Hospital {
  +int total
  #double description
  #boolean name
  +findQuantity()
  +processNote()
}
interface Ward {
  #long email
  #String type
  +long duration
  +float amount
  +createStatus()
}
Nurse --> Diagnosis : "1"
Diagnosis ..> LabTest : "1"
Ward ..|> Insurance
Treatment --|> Insurance
Hospital --|> Insurance
LabTest ..|> Hospital
note right of Treatment : Healthcare domain
@enduml