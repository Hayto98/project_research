@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Treatment {
  +double updatedAt
  #Date createdAt
  +calculatePrice()
}
class Insurance {
  +long amount
  #float description
  #float createdAt
  +sendTotal()
  +updateName()
  +getTotal()
  +deleteQuantity()
}
class Nurse {
  +long code
  #double updatedAt
  -float price
  #float quantity
  +deleteName()
  +sendPrice()
}
class LabTest {
  -long address
  -float note
  #long total
  #String score
  +getLevel()
  +saveTotal()
}
class Diagnosis {
  #boolean score
  #float active
  +float id
  +boolean updatedAt
  +updateScore()
  +processUpdatedat()
}
class Hospital {
  -long price
  #long quantity
  +int code
  -boolean active
  #int amount
  +validateCode()
  +calculateId()
  +validatePhone()
  +processUpdatedat()
}
abstract class Ward {
  #long quantity
  #float type
  -float note
  +validateAddress()
  +deleteScore()
  +findUpdatedat()
  +sendPhone()
}
Treatment ..|> Nurse
Ward --> Hospital : "1"
@enduml