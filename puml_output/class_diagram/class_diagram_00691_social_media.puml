@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
interface Story {
  -double code
  +Date note
  #String duration
  +setActive()
}
abstract class Hashtag {
  #long updatedAt
  #double status
  -boolean amount
  -String total
  +saveActive()
  +sendCode()
  +setDuration()
  +createAddress()
}
class Comment {
  +long description
  #int updatedAt
  -Date duration
  +boolean createdAt
  +createCreatedat()
  +sendEmail()
  +createPrice()
  +setEmail()
}
class Group {
  #float duration
  -float status
  #double createdAt
  +int active
  -float total
  +updateDescription()
  +findNote()
  +findName()
}
abstract class Profile {
  +long duration
  #float id
  +sendUpdatedat()
  +findName()
  +createDescription()
  +processNote()
}
class Album {
  +int score
  -int amount
  +processDescription()
  +deleteEmail()
  +createPrice()
  +deleteEmail()
}
interface User {
  #int note
  #int type
  +String amount
  #boolean updatedAt
  +setScore()
  +getId()
}
Comment --|> Hashtag
User ..> Hashtag : "*"
Story --* Comment
Album --|> Hashtag
Hashtag ..|> Group
Profile --* User
note right of Story : Social Media domain
@enduml