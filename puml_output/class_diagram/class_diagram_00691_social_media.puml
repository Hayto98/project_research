@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
interface Story {
  -double code
  +Date note
  #String duration
  +getDescription()
}
class Hashtag {
  #long email
  #double updatedAt
  -boolean status
  -String amount
  #Date total
  +updatePhone()
  +sendType()
  +createUpdatedat()
  +calculateActive()
}
class Comment {
  -int duration
  -float email
  +updateStatus()
  +setLevel()
}
interface Group {
  -Date status
  +boolean address
  #double updatedAt
  +processActive()
  +findType()
  +saveActive()
}
class Profile {
  #double price
  #String status
  +boolean email
  #boolean amount
  +saveUpdatedat()
  +getDuration()
  +setNote()
  +getUpdatedat()
}
interface Album {
  #int updatedAt
  #double createdAt
  #String price
  -String address
  #Date level
  +saveAddress()
}
class User {
  -double active
  #String updatedAt
  #String name
  #boolean email
  #int description
  +validateCreatedat()
  +saveAmount()
}
User --> Profile : "*"
Group ..|> Hashtag
Album --* Comment
@enduml