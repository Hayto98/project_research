@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
interface Renewal {
  +int email
  -long phone
  +int name
  +cancelNote()
  +saveType()
  +cancelType()
  +findEmail()
}
class Member {
  +long address
  +boolean type
  +saveAmount()
}
abstract class Fine {
  +int name
  +boolean quantity
  -Date active
  #Date score
  -int address
  +updatePhone()
  +cancelActive()
}
class Publisher {
  #boolean description
  +float phone
  #long status
  +float level
  +double name
  +validateUpdatedat()
  +setLevel()
  +calculateNote()
  +calculatePrice()
}
class Librarian {
  #double price
  +double quantity
  +float total
  -String level
  +updateEmail()
  +getScore()
  +updateQuantity()
}
class Reservation {
  #long duration
  #int active
  +processAddress()
}
class Loan {
  -long amount
  +double level
  +boolean note
  -boolean address
  -int price
  +validateTotal()
  +createNote()
}
Renewal ..> Member : "0..1"
Renewal --o Fine
Fine --* Publisher
Member --o Loan
Publisher --> Librarian : "*"
Fine --> Member : "1..*"
@enduml