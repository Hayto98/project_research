@startuml
skinparam defaultFontSize 13
class Coupon {
  -long note
  +float createdAt
  -float type
  #String quantity
  -Date updatedAt
  +deleteAmount()
  +findPhone()
  +getType()
}
interface Product {
  #Date code
  -Date level
  +setName()
}
abstract class Customer {
  -boolean email
  -String level
  #float active
  +sendId()
  +setNote()
}
interface Review {
  -float level
  +Date price
  +Date duration
  +String name
  -float code
  +getType()
  +getCreatedat()
  +processPrice()
  +getCode()
}
class Return {
  -float score
  -boolean duration
  +cancelScore()
  +getAddress()
}
Product --> Coupon : "1..*"
note right of Coupon : Ecommerce domain
@enduml