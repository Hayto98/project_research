@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Treatment {
  #long quantity
  -String address
  +validateCode()
  +updatePrice()
  +updateUpdatedat()
}
class Appointment {
  #boolean description
  -String note
  -double createdAt
  +validateId()
  +setPhone()
  +getCreatedat()
}
class LabTest {
  +Date quantity
  #boolean description
  +Date updatedAt
  +saveName()
}
abstract class MedicalRecord {
  +int score
  #float id
  +boolean code
  +createAmount()
  +validateDescription()
}
class Insurance {
  +boolean name
  -Date code
  +boolean updatedAt
  #Date score
  +cancelQuantity()
  +deleteUpdatedat()
  +createDescription()
}
Insurance ..|> MedicalRecord
Treatment --o LabTest
Appointment ..|> Insurance
Appointment ..|> MedicalRecord
@enduml