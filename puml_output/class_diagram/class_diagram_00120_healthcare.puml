@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Treatment {
  #long quantity
  -String address
  +deleteId()
  +setPhone()
  +sendAmount()
}
class Appointment {
  -long createdAt
  +boolean level
  #float address
  +Date name
  +long type
  +updateDescription()
  +saveActive()
}
interface LabTest {
  +boolean id
  +Date price
  #String total
  +deleteDescription()
  +cancelDescription()
}
class MedicalRecord {
  +Date address
  +float name
  +boolean code
  +findCreatedat()
  +cancelPhone()
  +processLevel()
}
interface Insurance {
  #Date amount
  +int status
  +float quantity
  -int price
  -float duration
  +findNote()
  +setScore()
  +calculateDuration()
  +saveDescription()
}
Treatment ..> Insurance : "*"
Insurance ..|> Appointment
note right of Treatment : Healthcare domain
@enduml