@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
interface Reservation {
  +Date name
  -Date price
  -boolean createdAt
  +sendScore()
  +createStatus()
}
class Payment {
  +Date quantity
  -long status
  +long updatedAt
  +double score
  +calculatePhone()
  +createDuration()
}
class Housekeeping {
  -float amount
  +boolean updatedAt
  +int createdAt
  #double description
  +cancelId()
  +deleteLevel()
  +processDescription()
  +sendUpdatedat()
}
class Service {
  #double score
  -long level
  #boolean phone
  #float quantity
  -String createdAt
  +validateTotal()
  +cancelTotal()
  +cancelCode()
}
abstract class Invoice {
  #String status
  -Date description
  +int level
  +saveActive()
  +findCreatedat()
  +getId()
  +getId()
}
Housekeeping ..|> Reservation
Payment ..|> Invoice
note right of Reservation : Hotel domain
@enduml