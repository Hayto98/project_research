@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
interface Reservation {
  +Date name
  -Date price
  -boolean createdAt
  +updateNote()
  +calculateDuration()
}
class Payment {
  -float quantity
  +int duration
  +sendId()
  +deleteType()
}
class Housekeeping {
  #int createdAt
  -Date address
  -long code
  #String price
  +sendStatus()
  +setScore()
  +findId()
}
class Service {
  #String description
  +boolean email
  -double createdAt
  +findPhone()
}
interface Invoice {
  #boolean description
  #long active
  -Date updatedAt
  #int id
  #double price
  +updateLevel()
  +setAddress()
  +savePrice()
}
Service ..> Reservation : "1..*"
Housekeeping --> Service : "*"
Invoice --o Reservation
Payment ..> Reservation : "0..1"
@enduml