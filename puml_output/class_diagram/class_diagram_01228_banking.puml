@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
interface Beneficiary {
  -String status
  +double level
  +float quantity
  +Date updatedAt
  +Date amount
  +deleteCreatedat()
  +deleteStatus()
  +cancelUpdatedat()
}
class Card {
  -int note
  -double phone
  +int id
  #int name
  -int code
  +setTotal()
}
interface Transaction {
  +int type
  #double code
  #long email
  +int createdAt
  +updateName()
}
class Deposit {
  -double name
  -boolean price
  #double amount
  -int description
  +long quantity
  +sendActive()
  +cancelCreatedat()
  +deleteTotal()
}
class Branch {
  -double level
  -double duration
  -int updatedAt
  #String email
  +updateId()
}
class Loan {
  +int id
  #boolean total
  -String quantity
  -Date name
  +calculateQuantity()
  +cancelAmount()
}
class Transfer {
  #double active
  #int address
  +cancelPrice()
  +setLevel()
}
Transaction --o Beneficiary
Beneficiary --o Card
note right of Beneficiary : Banking domain
@enduml