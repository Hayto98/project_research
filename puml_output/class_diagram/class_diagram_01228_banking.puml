@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
interface Beneficiary {
  -String status
  +double level
  +float quantity
  +Date updatedAt
  +Date amount
  +deleteScore()
  +cancelNote()
  +getDuration()
}
class Card {
  -double level
  #float updatedAt
  +deleteCode()
  +processCode()
  +calculateId()
  +validatePhone()
}
abstract class Transaction {
  +Date price
  +double type
  +String status
  +sendType()
}
abstract class Deposit {
  +int type
  #double code
  #long email
  +int createdAt
  +processDuration()
}
class Branch {
  #float price
  #float name
  +Date duration
  -double amount
  +cancelId()
  +createStatus()
  +validatePrice()
  +deleteDuration()
}
abstract class Loan {
  #Date description
  #boolean phone
  -float active
  +calculateAddress()
  +setNote()
}
class Transfer {
  -double level
  -double duration
  -int updatedAt
  #String email
  +sendId()
}
Transaction ..> Transfer : "1"
Deposit --|> Transaction
@enduml