@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Review {
  -long updatedAt
  -String type
  -long phone
  -boolean total
  -long note
  +deleteCode()
  +validateName()
  +validateQuantity()
  +setUpdatedat()
}
abstract class Category {
  #double type
  +String name
  #long price
  +Date createdAt
  -boolean level
  +validateCreatedat()
  +getStatus()
  +setScore()
}
class Return {
  #float score
  -String duration
  -Date price
  +updateDescription()
  +findCode()
  +createName()
  +updatePhone()
}
class Warehouse {
  #double level
  +boolean id
  -long note
  +float type
  +sendPhone()
  +cancelTotal()
  +validateDuration()
  +deleteId()
}
abstract class Shipment {
  -float name
  +boolean amount
  -Date level
  +double phone
  +deleteActive()
}
interface Customer {
  #float total
  #Date id
  #String active
  #double duration
  #String level
  +saveCode()
  +calculateUpdatedat()
  +getUpdatedat()
}
interface Wishlist {
  +float score
  -Date active
  -Date level
  #boolean email
  #Date total
  +cancelTotal()
  +deleteEmail()
}
Warehouse --* Wishlist
Shipment --|> Category
Shipment --|> Review
@enduml