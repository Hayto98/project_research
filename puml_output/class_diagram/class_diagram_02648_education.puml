@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
abstract class Library {
  #String status
  +float phone
  -float code
  +float createdAt
  #boolean name
  +deleteScore()
  +setQuantity()
}
class Assignment {
  -double address
  -Date name
  +calculateQuantity()
}
class Student {
  -double score
  #double level
  #float quantity
  +updateScore()
}
interface Teacher {
  #String description
  -float phone
  +String active
  #boolean updatedAt
  #Date score
  +saveDescription()
  +validateNote()
  +validateActive()
  +calculateLevel()
}
class Enrollment {
  -String price
  -long quantity
  #double phone
  +updateQuantity()
  +updateUpdatedat()
  +sendAmount()
}
class Department {
  #long name
  -int code
  +saveScore()
}
interface Attendance {
  #Date note
  +Date phone
  -Date code
  +saveQuantity()
  +cancelQuantity()
  +updateUpdatedat()
  +sendPhone()
}
Teacher ..|> Enrollment
Department --o Teacher
Department --|> Assignment
note right of Library : Education domain
@enduml