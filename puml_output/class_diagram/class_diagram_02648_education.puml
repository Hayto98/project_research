@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
abstract class Library {
  #String status
  +float phone
  -float code
  +float createdAt
  #boolean name
  +sendLevel()
  +saveAddress()
}
interface Assignment {
  +long quantity
  +long amount
  +findType()
  +processStatus()
  +setCreatedat()
  +saveType()
}
class Student {
  -boolean quantity
  -Date email
  +int updatedAt
  #boolean duration
  #boolean price
  +setLevel()
  +setAmount()
  +updateAddress()
  +deleteStatus()
}
class Teacher {
  -float duration
  +String updatedAt
  #boolean status
  +processNote()
  +validateCode()
  +saveScore()
  +cancelQuantity()
}
class Enrollment {
  -long level
  +long updatedAt
  -Date duration
  -Date price
  #Date quantity
  +saveNote()
  +deleteTotal()
  +updateLevel()
}
class Department {
  +String active
  +Date amount
  -double quantity
  +validatePrice()
  +findNote()
}
interface Attendance {
  #Date note
  +Date phone
  -Date code
  +findStatus()
  +createType()
  +calculatePhone()
  +getQuantity()
}
Assignment --> Attendance : "1..*"
Attendance --o Assignment
Enrollment ..> Assignment : "*"
Teacher ..|> Department
@enduml