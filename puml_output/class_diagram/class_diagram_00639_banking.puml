@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
abstract class Statement {
  -float level
  -double duration
  +int active
  -boolean email
  -double score
  +getDescription()
  +sendActive()
  +calculateUpdatedat()
}
class Teller {
  -float duration
  +int note
  #long email
  #long type
  -String level
  +getQuantity()
  +createId()
}
class Account {
  #float createdAt
  +boolean status
  +String level
  +cancelTotal()
  +deleteType()
  +validateLevel()
  +calculateNote()
}
class Card {
  #int description
  -float type
  -float code
  +findAddress()
  +saveQuantity()
  +calculateType()
  +validatePhone()
}
class Transfer {
  #float price
  -Date amount
  +float score
  +long description
  +long phone
  +getNote()
}
Statement --* Account
Card --|> Statement
note right of Statement : Banking domain
@enduml