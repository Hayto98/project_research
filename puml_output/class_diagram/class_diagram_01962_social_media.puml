@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
interface Message {
  #String amount
  #double name
  +Date total
  -Date code
  +deleteActive()
  +calculateUpdatedat()
  +saveLevel()
  +deleteActive()
}
abstract class Album {
  #int description
  +String createdAt
  +deleteNote()
  +getDescription()
}
class Profile {
  -boolean active
  #String total
  -Date type
  -double score
  +calculateQuantity()
  +cancelQuantity()
}
class Like {
  +float level
  -boolean note
  +double amount
  +boolean duration
  -boolean createdAt
  +processName()
  +createAddress()
  +updateQuantity()
}
interface Comment {
  +String code
  #double total
  #long quantity
  -boolean type
  +processPrice()
  +createPrice()
}
class Hashtag {
  #int name
  +Date score
  -int updatedAt
  +cancelTotal()
  +createScore()
  +setAmount()
  +deleteType()
}
Hashtag ..> Album : "1"
Message ..|> Profile
Profile --> Like : "1"
Album ..> Profile : "1..*"
note right of Message : Social Media domain
@enduml