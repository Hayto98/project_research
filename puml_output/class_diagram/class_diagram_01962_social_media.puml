@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
interface Message {
  #String amount
  #double name
  +Date total
  -Date code
  +validateCode()
  +calculateActive()
  +processType()
  +findAddress()
}
interface Album {
  +float active
  +boolean type
  +int code
  +createType()
}
interface Profile {
  +long description
  -boolean note
  -Date name
  +cancelActive()
  +setAddress()
  +calculatePrice()
  +getUpdatedat()
}
abstract class Like {
  +double active
  -boolean name
  -int note
  -float quantity
  #boolean type
  +saveDescription()
  +getDescription()
  +updateType()
  +saveAmount()
}
class Comment {
  -float email
  +boolean active
  -boolean amount
  +sendCode()
  +processQuantity()
  +deleteCreatedat()
}
class Hashtag {
  +double quantity
  -double level
  +String phone
  +findLevel()
  +validatePrice()
  +setEmail()
  +saveScore()
}
Like --* Hashtag
Like ..|> Album
Message ..|> Comment
@enduml