@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class FuelLog {
  -int duration
  -long status
  #boolean level
  -int price
  +getId()
}
interface Vehicle {
  #long amount
  -String createdAt
  +getActive()
  +calculateAddress()
  +createName()
}
abstract class Manifest {
  +long phone
  +long name
  +deleteScore()
  +saveNote()
  +calculateLevel()
  +deleteScore()
}
class Customer {
  #Date description
  +float active
  -double id
  #boolean createdAt
  #String type
  +calculateStatus()
  +deleteDuration()
  +calculateAmount()
}
class DeliveryNote {
  +String active
  +int createdAt
  -long email
  +boolean status
  +setUpdatedat()
  +setNote()
  +getTotal()
}
abstract class Tracking {
  #Date quantity
  #float name
  +double createdAt
  -int phone
  -Date id
  +sendDuration()
  +validateName()
  +getName()
  +saveCreatedat()
}
Manifest --|> DeliveryNote
DeliveryNote --* Tracking
FuelLog --> Tracking : "1..*"
note right of FuelLog : Logistics domain
@enduml