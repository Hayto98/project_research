@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class FuelLog {
  -int duration
  -long status
  #boolean level
  -int price
  +sendTotal()
}
class Vehicle {
  #long amount
  -String createdAt
  +updateActive()
  +sendQuantity()
  +setPrice()
}
abstract class Manifest {
  -String quantity
  +long name
  +long price
  #Date code
  +findPhone()
  +createStatus()
  +getStatus()
  +saveUpdatedat()
}
abstract class Customer {
  +boolean level
  +boolean amount
  +Date score
  -float description
  #Date total
  +getPrice()
}
abstract class DeliveryNote {
  +boolean active
  -int id
  -long phone
  #Date total
  +long status
  +saveQuantity()
}
class Tracking {
  +boolean updatedAt
  #long address
  +int phone
  +createName()
}
Customer --> Tracking : "*"
Manifest ..|> FuelLog
@enduml