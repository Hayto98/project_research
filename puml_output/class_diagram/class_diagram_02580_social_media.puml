@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Notification {
  #Date note
  +long id
  +setId()
  +deleteAddress()
  +deleteQuantity()
  +saveStatus()
}
class Comment {
  -float duration
  +int price
  -Date active
  +getId()
  +createDescription()
  +setId()
  +deleteEmail()
}
class User {
  #long score
  +float address
  #String phone
  +updateCode()
  +sendName()
}
class Group {
  +float type
  #boolean description
  +validateUpdatedat()
  +findLevel()
}
interface Profile {
  -Date price
  +double name
  +validateNote()
  +setPhone()
  +calculateAmount()
  +deleteDuration()
}
class Report {
  -boolean updatedAt
  #float duration
  +cancelCode()
  +sendId()
  +getScore()
}
class Follower {
  +double code
  #long address
  +long name
  #double type
  -float duration
  +saveActive()
  +deleteStatus()
}
User --> Notification : "*"
Notification --> Group : "*"
User ..|> Follower
Profile --* Follower
@enduml