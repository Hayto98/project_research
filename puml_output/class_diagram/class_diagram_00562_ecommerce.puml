@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Cart {
  #int level
  +String updatedAt
  #long score
  +boolean description
  +int address
  +setEmail()
  +deletePhone()
  +updateCreatedat()
  +setCode()
}
abstract class Customer {
  -boolean duration
  #Date quantity
  +findCreatedat()
  +findLevel()
  +validateScore()
  +validateCreatedat()
}
class Wishlist {
  -Date updatedAt
  #long note
  +updateId()
  +setActive()
}
class Payment {
  #int price
  -float level
  -int id
  +processUpdatedat()
  +deleteAddress()
}
class Invoice {
  +long code
  -Date id
  +long level
  -String score
  +cancelActive()
  +deleteCode()
  +validateId()
}
Payment ..> Cart : "1"
Invoice ..> Cart : "1..*"
note right of Cart : Ecommerce domain
@enduml