@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Report {
  -String amount
  #double email
  +processPhone()
}
abstract class Hashtag {
  #long phone
  #Date description
  +sendId()
  +calculateEmail()
}
interface Profile {
  #boolean createdAt
  -double status
  #int code
  +updateActive()
  +getPhone()
  +deleteActive()
}
class Post {
  +boolean price
  #double duration
  #float updatedAt
  -boolean name
  +getAmount()
  +findEmail()
  +calculateName()
}
Post ..|> Report
Report ..> Hashtag : "1..*"
@enduml