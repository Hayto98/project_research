@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Report {
  -String amount
  #double email
  +processId()
}
class Hashtag {
  +String address
  #int active
  +String amount
  +findActive()
}
abstract class Profile {
  -Date duration
  +long createdAt
  #double quantity
  -float id
  +float total
  +getLevel()
}
interface Post {
  #boolean type
  #boolean level
  -String email
  +String address
  -Date status
  +setScore()
  +cancelName()
  +setCreatedat()
}
Hashtag --o Profile
Post --|> Report
Post --> Hashtag : "*"
note right of Report : Social Media domain
@enduml