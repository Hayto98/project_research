@startuml
skinparam monochrome true
skinparam defaultFontSize 13
interface Renewal {
  +long createdAt
  #int type
  -boolean active
  #double name
  -int note
  +calculateDescription()
}
class Librarian {
  -float description
  +int address
  -Date status
  -long createdAt
  +setAddress()
  +findId()
  +setCreatedat()
  +deleteDuration()
}
abstract class Branch {
  -Date score
  -float name
  +sendCode()
  +validateAddress()
  +calculateCreatedat()
}
class Loan {
  #boolean name
  +double level
  #double duration
  -long id
  +validateScore()
  +updateScore()
}
abstract class Member {
  -double phone
  #long address
  #double quantity
  -double type
  -boolean level
  +updateDescription()
}
abstract class Publisher {
  #float code
  -String createdAt
  -String amount
  +calculateId()
  +cancelDescription()
  +cancelNote()
  +setTotal()
}
class Catalog {
  #double quantity
  +long address
  +int score
  +updateCode()
  +validateDescription()
}
Publisher --> Renewal : "*"
Publisher ..> Member : "0..1"
Member --o Librarian
@enduml