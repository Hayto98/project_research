@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Notification {
  +int address
  #int quantity
  +deleteType()
  +validateId()
}
class Like {
  #float status
  #String code
  +saveName()
  +cancelCode()
}
class Comment {
  +boolean code
  #int address
  -double name
  +cancelCreatedat()
}
class Profile {
  +float quantity
  #long total
  +double amount
  -double note
  -long name
  +findDescription()
  +sendNote()
  +sendCreatedat()
}
abstract class Group {
  +long price
  #double email
  +float note
  +updateActive()
  +savePrice()
  +createLevel()
  +processLevel()
}
class Album {
  #int status
  -long email
  -float address
  +long phone
  #double code
  +cancelStatus()
}
class Story {
  #double active
  #int address
  +String phone
  +float duration
  -boolean email
  +processEmail()
  +cancelDuration()
  +processActive()
  +calculateId()
}
Comment --* Story
Like --> Notification : "1..*"
Comment ..|> Profile
Profile --o Album
note right of Notification : Social Media domain
@enduml