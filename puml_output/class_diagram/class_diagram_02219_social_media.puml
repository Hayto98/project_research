@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Notification {
  +int address
  #int quantity
  +updateType()
  +updateScore()
}
abstract class Like {
  +Date id
  #String duration
  +Date code
  +boolean status
  +validateCreatedat()
}
interface Comment {
  +boolean code
  #int address
  -double name
  +setId()
}
class Profile {
  -int note
  -String quantity
  +findTotal()
  +updateAddress()
}
class Group {
  -double type
  -long phone
  +setAddress()
  +saveAmount()
}
interface Album {
  #long type
  #double amount
  +long price
  +saveEmail()
  +calculateLevel()
  +getAddress()
  +updateStatus()
}
interface Story {
  +float quantity
  -long level
  -float type
  #String status
  #int score
  +deleteId()
  +processDescription()
  +createPrice()
}
Comment --o Album
Notification --|> Group
@enduml