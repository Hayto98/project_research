@startuml
skinparam ArrowColor #555555
interface Prescription {
  -double active
  #String note
  +String type
  #double id
  +validateActive()
  +getAmount()
  +createAddress()
}
interface LabTest {
  #Date type
  +boolean updatedAt
  +deleteStatus()
  +updateAmount()
  +sendQuantity()
}
abstract class Hospital {
  #double address
  #double price
  +calculateType()
  +saveCode()
  +cancelPrice()
}
class Nurse {
  #String price
  #Date score
  -long amount
  #int level
  +deleteLevel()
  +createAddress()
  +validatePrice()
}
abstract class Diagnosis {
  -long quantity
  -int duration
  #Date updatedAt
  -long id
  +createStatus()
  +validateNote()
}
class Treatment {
  -String createdAt
  -double updatedAt
  -float name
  #Date code
  #long amount
  +updateCode()
  +deleteScore()
}
interface Doctor {
  -int active
  +int level
  -float duration
  +int amount
  -int id
  +deleteDuration()
  +saveNote()
  +findAddress()
}
Diagnosis ..> Prescription : "1..*"
LabTest --* Diagnosis
LabTest --o Hospital
Hospital --> Diagnosis : "1..*"
@enduml