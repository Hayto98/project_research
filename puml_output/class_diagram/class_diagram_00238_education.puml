@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Student {
  -int score
  -int active
  +String description
  +saveAmount()
  +validateActive()
  +deleteCreatedat()
  +deleteName()
}
interface Attendance {
  +Date total
  #double status
  +float duration
  +createScore()
  +updateId()
  +createName()
}
class Department {
  +Date type
  -String code
  +String total
  +sendUpdatedat()
  +sendAmount()
  +sendPrice()
  +validatePrice()
}
abstract class Course {
  #int description
  #boolean status
  +String level
  #long active
  #boolean duration
  +setLevel()
}
Course --> Department : "1"
Attendance --> Student : "*"
Course --> Attendance : "*"
@enduml