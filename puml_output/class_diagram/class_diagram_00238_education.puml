@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Student {
  -int score
  -int active
  +String description
  +processDuration()
  +createEmail()
  +sendAmount()
  +calculateStatus()
}
interface Attendance {
  +Date createdAt
  -int active
  +double total
  #String amount
  -float email
  +savePrice()
  +setStatus()
}
class Department {
  +boolean score
  #int price
  #int note
  #boolean description
  +String status
  +cancelLevel()
  +findName()
  +deletePhone()
}
abstract class Course {
  #double description
  -double id
  +deleteAmount()
  +validateAmount()
  +calculateId()
  +getActive()
}
Course ..> Attendance : "0..1"
Department ..|> Attendance
note right of Student : Education domain
@enduml