@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Manifest {
  -Date note
  +String description
  #Date createdAt
  #long code
  +String level
  +updateUpdatedat()
  +validateQuantity()
  +processActive()
  +validateCreatedat()
}
class Route {
  +String score
  +String updatedAt
  +createLevel()
  +createCode()
  +saveCreatedat()
}
class Customer {
  +String id
  #int createdAt
  +int duration
  #Date type
  #Date phone
  +sendUpdatedat()
  +getPhone()
}
class DeliveryNote {
  -int quantity
  #String description
  -int price
  +getLevel()
  +saveAmount()
}
class Warehouse {
  -String status
  +String score
  -long level
  +savePhone()
  +saveAmount()
  +deleteAddress()
  +sendLevel()
}
Manifest ..|> DeliveryNote
Route --* DeliveryNote
@enduml