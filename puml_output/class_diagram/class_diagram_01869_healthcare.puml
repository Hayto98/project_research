@startuml

class MedicalRecord {
  +double duration
  #boolean name
  -Date description
  #boolean phone
  -Date level
  +createActive()
  +updatePrice()
}
class Insurance {
  -long phone
  +boolean note
  #float level
  -int id
  #int score
  +setAddress()
  +validateDescription()
}
class Patient {
  #String duration
  +long note
  +updateName()
  +findDuration()
  +saveScore()
}
abstract class Treatment {
  #float note
  #String createdAt
  #boolean description
  +processPrice()
  +validateAmount()
  +processDescription()
}
class Diagnosis {
  #boolean price
  #String phone
  +getPhone()
  +createScore()
  +deleteType()
  +processName()
}
class LabTest {
  -double price
  +String duration
  +double code
  #int score
  -String type
  +createName()
  +setActive()
  +getDuration()
  +sendUpdatedat()
}
abstract class Appointment {
  +boolean status
  +double description
  +cancelStatus()
}
Patient --* Diagnosis
MedicalRecord --o LabTest
MedicalRecord --* Diagnosis
@enduml