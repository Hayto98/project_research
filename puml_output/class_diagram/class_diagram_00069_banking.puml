@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
interface Interest {
  -float email
  #float updatedAt
  +cancelLevel()
  +sendStatus()
  +findPhone()
  +findQuantity()
}
abstract class Transfer {
  -Date duration
  -float level
  #float quantity
  +boolean address
  +updateAmount()
  +calculateTotal()
  +calculateDescription()
}
class Teller {
  #int amount
  -float code
  +String updatedAt
  +String score
  +validateUpdatedat()
  +deleteName()
}
class Customer {
  +long active
  -Date total
  #Date address
  -float createdAt
  #long amount
  +validateAmount()
}
class Withdrawal {
  +long type
  #boolean name
  +getCode()
  +processCode()
  +findId()
}
Teller ..> Withdrawal : "*"
Teller ..> Interest : "*"
@enduml