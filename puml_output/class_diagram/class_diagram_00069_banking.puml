@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
interface Interest {
  -float email
  #float updatedAt
  +deleteAddress()
  +calculateScore()
  +validateDuration()
  +findLevel()
}
class Transfer {
  #String type
  -float email
  +Date updatedAt
  #String address
  +updateCreatedat()
  +validateCreatedat()
}
class Teller {
  -Date id
  #float createdAt
  -boolean type
  +saveActive()
  +calculateAddress()
  +updateAmount()
  +setEmail()
}
class Customer {
  +boolean quantity
  +double score
  #Date status
  #String email
  +validateScore()
}
interface Withdrawal {
  -long level
  #float id
  #Date amount
  -float status
  +findId()
  +findTotal()
  +saveLevel()
}
Customer --|> Teller
Withdrawal --> Interest : "0..1"
note right of Interest : Banking domain
@enduml