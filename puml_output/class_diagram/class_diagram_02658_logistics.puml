@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
abstract class Driver {
  +long updatedAt
  #int id
  #Date address
  +updateScore()
  +setDuration()
  +saveName()
  +processScore()
}
class Package {
  #int email
  +boolean status
  +String total
  +deleteActive()
}
interface FuelLog {
  #int createdAt
  #String name
  #Date updatedAt
  -int email
  +findCreatedat()
}
class Warehouse {
  #Date name
  #long phone
  -long updatedAt
  #float price
  +setLevel()
  +findPhone()
}
Package --o FuelLog
Driver --* FuelLog
@enduml