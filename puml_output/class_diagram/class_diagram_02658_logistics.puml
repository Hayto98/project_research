@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
abstract class Driver {
  +long updatedAt
  #int id
  #Date address
  +findPrice()
  +deleteCreatedat()
  +saveEmail()
  +findStatus()
}
abstract class Package {
  +double status
  #boolean amount
  -float id
  +getDuration()
  +updateEmail()
}
interface FuelLog {
  +boolean score
  +long id
  +float note
  +getPhone()
  +saveUpdatedat()
  +calculateQuantity()
}
abstract class Warehouse {
  +float score
  +Date createdAt
  -String description
  #long duration
  +findNote()
  +cancelPrice()
  +savePrice()
}
Package --o Driver
Warehouse ..|> FuelLog
note right of Driver : Logistics domain
@enduml