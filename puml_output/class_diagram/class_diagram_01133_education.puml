@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Grade {
  +boolean note
  +int active
  +saveActive()
  +createType()
  +deleteUpdatedat()
}
class Library {
  +double name
  +int amount
  +int address
  -String code
  -int level
  +updateTotal()
  +setUpdatedat()
  +processScore()
  +sendId()
}
class Student {
  +double description
  +double address
  -float type
  +createCreatedat()
  +processStatus()
  +cancelScore()
}
class Exam {
  #float amount
  -boolean address
  +boolean total
  -int quantity
  +double createdAt
  +updateDuration()
  +findType()
  +deleteLevel()
}
abstract class Assignment {
  +double note
  -float updatedAt
  -int id
  #long amount
  +findPhone()
}
Assignment ..> Student : "0..1"
Exam ..> Grade : "*"
note right of Grade : Education domain
@enduml