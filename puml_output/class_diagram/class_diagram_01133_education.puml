@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Grade {
  +boolean note
  +int active
  +calculateUpdatedat()
  +validateDescription()
  +deletePhone()
}
interface Library {
  -String type
  +long amount
  #float updatedAt
  #String address
  +sendId()
  +deleteActive()
}
class Student {
  +double id
  +double description
  +double type
  +updateStatus()
}
abstract class Exam {
  +long status
  #double description
  +setNote()
  +deleteScore()
}
abstract class Assignment {
  #boolean phone
  +double quantity
  +long createdAt
  -long note
  +boolean status
  +getCreatedat()
  +getPrice()
  +deleteScore()
}
Exam --|> Library
Exam ..|> Student
Assignment ..|> Exam
@enduml