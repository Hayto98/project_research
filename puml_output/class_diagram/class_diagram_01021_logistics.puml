@startuml
skinparam shadowing true
interface DeliveryNote {
  -float description
  #boolean level
  +createDuration()
  +calculateEmail()
}
class FuelLog {
  #double id
  +float description
  #int type
  #boolean createdAt
  +validateActive()
}
class Shipment {
  +String status
  -long price
  #int level
  +findUpdatedat()
}
class Warehouse {
  #long amount
  +boolean updatedAt
  -int code
  -int status
  +int createdAt
  +validateQuantity()
  +getCode()
  +getPhone()
}
Warehouse --o FuelLog
FuelLog --* Shipment
@enduml