@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class User {
  -float status
  +boolean note
  +String createdAt
  #boolean type
  -int active
  +setName()
  +cancelQuantity()
  +sendUpdatedat()
  +updateTotal()
}
class Album {
  -long description
  #long code
  +int amount
  +cancelStatus()
  +deleteScore()
  +findPhone()
}
class Notification {
  #double code
  +double note
  +saveCode()
  +cancelActive()
}
interface Follower {
  #long type
  #Date name
  #double level
  #String status
  +deleteDescription()
  +setPhone()
  +setScore()
}
class Story {
  +double score
  #float phone
  +Date code
  +setAmount()
  +createDescription()
  +saveType()
}
class Report {
  -long score
  -boolean level
  +saveId()
  +updatePhone()
  +sendAmount()
  +updateName()
}
class Group {
  +double total
  -double createdAt
  #long code
  +findUpdatedat()
  +saveNote()
  +setNote()
}
Follower --|> Group
Group ..|> User
User --|> Group
User --o Album
Report --* User
@enduml