@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Like {
  +String address
  +Date price
  -double active
  +saveName()
  +cancelTotal()
  +deleteCode()
}
class Profile {
  #float duration
  -double name
  +boolean updatedAt
  #float id
  +cancelCode()
  +processLevel()
  +updateActive()
  +deleteId()
}
class Follower {
  +Date status
  #int code
  +long note
  #double email
  +sendAmount()
  +updateTotal()
  +sendActive()
  +processStatus()
}
class Album {
  -boolean name
  +Date quantity
  +createCreatedat()
}
class Story {
  #String status
  +long note
  +deleteQuantity()
  +validateType()
  +deleteEmail()
  +sendScore()
}
abstract class Notification {
  #boolean code
  -String total
  -double duration
  -double active
  +validatePrice()
  +setPhone()
  +cancelAmount()
  +setTotal()
}
class Report {
  +Date note
  +Date updatedAt
  +double code
  -long quantity
  +long amount
  +calculatePrice()
  +setTotal()
  +deleteCreatedat()
}
Follower --> Notification : "1..*"
Album --|> Profile
Story --|> Notification
Notification --* Story
Profile ..> Report : "0..1"
Report --o Like
@enduml