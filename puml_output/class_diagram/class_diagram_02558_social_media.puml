@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Like {
  +String address
  +Date price
  -double active
  +calculateId()
  +validateStatus()
  +createDuration()
}
class Profile {
  +boolean id
  #float email
  -double price
  +getAmount()
  +validateStatus()
  +setNote()
  +saveEmail()
}
class Follower {
  -double amount
  #long quantity
  #long score
  +findId()
}
class Album {
  +float phone
  +String score
  +double code
  #String level
  +createPrice()
}
class Story {
  #String price
  #boolean level
  #long quantity
  +long code
  -float total
  +processTotal()
  +saveDuration()
  +sendQuantity()
}
class Notification {
  +Date note
  +Date updatedAt
  +double code
  -long quantity
  +long amount
  +sendQuantity()
  +createScore()
  +createDuration()
}
class Report {
  +int description
  #int name
  +double score
  #boolean level
  -float phone
  +deleteType()
}
Like ..> Album : "1..*"
Story --> Follower : "*"
note right of Like : Social Media domain
@enduml