@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Branch {
  #int quantity
  #String description
  +double email
  +cancelStatus()
  +deletePrice()
  +sendActive()
  +validateDuration()
}
class Interest {
  #Date duration
  #String address
  +long description
  +boolean level
  #float updatedAt
  +cancelScore()
  +createPrice()
  +processPhone()
  +deletePrice()
}
class Loan {
  +Date type
  +Date status
  -double score
  +long updatedAt
  -boolean createdAt
  +findCreatedat()
  +validateCode()
  +updatePhone()
  +setCode()
}
class Customer {
  #boolean id
  #String status
  #float total
  +deleteTotal()
  +sendActive()
  +findDescription()
}
class Withdrawal {
  #int address
  #boolean name
  +updateScore()
  +updateLevel()
  +sendCode()
  +calculateActive()
}
class Statement {
  -long id
  -long duration
  +validateCreatedat()
  +createAmount()
}
Interest --|> Withdrawal
Interest --o Branch
note right of Branch : Banking domain
@enduml