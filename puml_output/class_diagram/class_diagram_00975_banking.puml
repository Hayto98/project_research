@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Branch {
  #int quantity
  #String description
  +double email
  +savePrice()
  +updateName()
  +processUpdatedat()
  +sendScore()
}
interface Interest {
  +boolean duration
  -boolean quantity
  +Date price
  #boolean address
  +updateCode()
}
class Loan {
  -double updatedAt
  -float score
  +double price
  #int quantity
  +createId()
  +calculateDescription()
  +getStatus()
  +validateUpdatedat()
}
class Customer {
  #String duration
  #double createdAt
  -String code
  +validateName()
  +createDescription()
  +getDescription()
}
abstract class Withdrawal {
  -String phone
  +int code
  #float createdAt
  +sendTotal()
  +validateEmail()
}
abstract class Statement {
  -boolean phone
  #Date amount
  +updateUpdatedat()
  +getLevel()
}
Branch ..> Interest : "*"
Interest ..|> Withdrawal
Withdrawal --|> Statement
Customer ..|> Withdrawal
@enduml