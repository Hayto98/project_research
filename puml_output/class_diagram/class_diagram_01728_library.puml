@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Loan {
  #boolean id
  -double type
  #double address
  +calculateLevel()
  +saveStatus()
  +updateEmail()
}
class Renewal {
  #Date email
  -Date amount
  #boolean total
  #Date note
  -float description
  +updateAmount()
  +savePrice()
  +findStatus()
  +deleteActive()
}
class Publisher {
  -String total
  #float phone
  -boolean email
  +getActive()
  +setStatus()
  +sendId()
  +sendType()
}
class Book {
  #float description
  +double phone
  +updateNote()
  +setQuantity()
  +getUpdatedat()
  +setCode()
}
Publisher ..|> Loan
Loan ..|> Renewal
@enduml