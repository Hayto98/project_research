@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
abstract class Patient {
  #int quantity
  -boolean address
  +Date type
  +cancelAmount()
  +sendQuantity()
  +createType()
}
interface Diagnosis {
  #Date code
  -long amount
  #double status
  +calculateDuration()
  +getQuantity()
  +cancelTotal()
  +saveEmail()
}
class Ward {
  +double description
  +double id
  +sendStatus()
  +processUpdatedat()
}
class Nurse {
  -double address
  -int total
  +sendLevel()
  +updateCode()
}
class Doctor {
  -float updatedAt
  -String createdAt
  +Date quantity
  +sendDescription()
  +setNote()
}
abstract class Prescription {
  -double createdAt
  +Date amount
  #boolean name
  -int score
  -String duration
  +processTotal()
}
class Appointment {
  +long note
  +String createdAt
  -boolean code
  -double id
  +int status
  +deleteNote()
  +sendName()
  +validateType()
}
Appointment --> Ward : "1"
Patient --> Prescription : "1..*"
Ward ..|> Prescription
Appointment --* Patient
@enduml