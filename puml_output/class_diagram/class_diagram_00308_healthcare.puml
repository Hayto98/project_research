@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
abstract class Patient {
  #int quantity
  -boolean address
  +Date type
  +sendActive()
  +saveScore()
  +updateCode()
}
class Diagnosis {
  #double email
  #float duration
  +sendDuration()
  +getName()
  +deleteId()
  +findDescription()
}
class Ward {
  -int type
  +long updatedAt
  +validateTotal()
}
class Nurse {
  +int note
  -double createdAt
  -String updatedAt
  +Date code
  +float score
  +saveTotal()
  +processCreatedat()
  +deleteName()
  +findName()
}
class Doctor {
  +double price
  +String description
  -float score
  -boolean total
  +processCreatedat()
  +setId()
  +sendStatus()
  +getPhone()
}
class Prescription {
  -double type
  +int level
  +getType()
  +saveEmail()
  +createActive()
}
interface Appointment {
  #long id
  -Date score
  +setAddress()
  +setActive()
}
Patient --> Prescription : "1"
Prescription ..> Ward : "0..1"
note right of Patient : Healthcare domain
@enduml