@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Staff {
  #int price
  +int address
  #String level
  #double name
  +calculateCode()
  +saveDescription()
}
abstract class Invoice {
  +boolean duration
  +int quantity
  +long createdAt
  -long amount
  +updateCreatedat()
  +updateName()
}
interface Guest {
  #float type
  -long id
  -double price
  +validateUpdatedat()
  +updateEmail()
}
class Room {
  -boolean duration
  -String phone
  #int price
  -boolean note
  +processActive()
  +createCode()
  +sendNote()
  +setPrice()
}
Staff --o Guest
Staff ..> Room : "0..1"
Invoice --o Staff
@enduml