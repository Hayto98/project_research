@startuml
skinparam monochrome true
skinparam defaultFontSize 13
interface Driver {
  +Date active
  #int address
  -String level
  +validatePhone()
}
class FuelLog {
  -float address
  +int status
  +Date level
  +calculateTotal()
}
class Shipment {
  +double id
  -boolean email
  +findQuantity()
  +updateLevel()
  +calculateDescription()
  +calculatePhone()
}
class Manifest {
  #double description
  #float price
  #long type
  #String id
  +calculateId()
  +calculatePhone()
}
class Tracking {
  -double quantity
  -boolean description
  #int phone
  -String price
  +findCreatedat()
}
Manifest --|> Tracking
FuelLog --|> Driver
note right of Driver : Logistics domain
@enduml