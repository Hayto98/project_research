@startuml
skinparam monochrome true
skinparam defaultFontSize 13
interface Driver {
  +Date active
  #int address
  -String level
  +saveCreatedat()
}
class FuelLog {
  +String amount
  -float address
  +cancelNote()
}
class Shipment {
  +String price
  +long total
  +calculateQuantity()
  +sendCode()
}
interface Manifest {
  -float quantity
  #String createdAt
  -int price
  -boolean description
  -String total
  +setScore()
  +createEmail()
  +validateActive()
  +calculateTotal()
}
class Tracking {
  +double description
  -float total
  +setPhone()
  +findCreatedat()
}
FuelLog --o Shipment
Shipment --* Manifest
Tracking --* FuelLog
@enduml