@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class FuelLog {
  +String status
  #float createdAt
  +boolean quantity
  +updateStatus()
  +calculateQuantity()
  +savePrice()
  +setPhone()
}
interface Vehicle {
  +boolean name
  #int amount
  +cancelScore()
  +getStatus()
}
class Warehouse {
  +int name
  +long active
  #int note
  +long email
  #String score
  +processEmail()
  +processNote()
  +cancelDescription()
}
interface Depot {
  +long score
  -double updatedAt
  +int total
  +float phone
  +setId()
  +setDescription()
}
Warehouse --* Depot
Vehicle --> Warehouse : "1"
note right of FuelLog : Logistics domain
@enduml