@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class FuelLog {
  +String status
  #float createdAt
  +boolean quantity
  +getStatus()
  +processPrice()
  +validateId()
  +calculateCode()
}
class Vehicle {
  +boolean status
  #int phone
  +float code
  #boolean name
  +String amount
  +setQuantity()
  +findActive()
  +calculateEmail()
}
interface Warehouse {
  -boolean email
  +String note
  -Date updatedAt
  +Date description
  #long createdAt
  +findTotal()
  +deleteTotal()
  +calculateScore()
  +sendCreatedat()
}
abstract class Depot {
  +double active
  -int email
  -long score
  +setLevel()
  +saveAddress()
  +getLevel()
  +saveLevel()
}
FuelLog --|> Depot
Vehicle --> Warehouse : "0..1"
@enduml