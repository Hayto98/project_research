@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Depot {
  +long quantity
  +float code
  +int status
  #Date updatedAt
  +saveDuration()
  +calculateLevel()
  +validatePrice()
}
class Shipment {
  -String code
  #float createdAt
  +cancelCode()
  +calculatePhone()
  +findNote()
}
class Manifest {
  -Date email
  +long phone
  +validateAddress()
  +calculateType()
}
interface Warehouse {
  #float updatedAt
  +double price
  #float total
  #Date type
  +deletePhone()
  +saveNote()
  +updateScore()
  +validateStatus()
}
Manifest --> Depot : "0..1"
Depot --|> Shipment
@enduml