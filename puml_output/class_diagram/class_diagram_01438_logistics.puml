@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Depot {
  +long quantity
  +float code
  +int status
  #Date updatedAt
  +cancelStatus()
  +getCode()
  +updateType()
}
class Shipment {
  #String type
  #float quantity
  #long code
  -double email
  +validateDescription()
  +createScore()
}
interface Manifest {
  #float updatedAt
  +double price
  #float total
  #Date type
  +updateDuration()
  +processLevel()
  +createDescription()
  +cancelAmount()
}
class Warehouse {
  #double status
  -boolean address
  +boolean duration
  +createLevel()
}
Shipment --|> Depot
Manifest --|> Warehouse
Warehouse ..|> Shipment
note right of Depot : Logistics domain
@enduml