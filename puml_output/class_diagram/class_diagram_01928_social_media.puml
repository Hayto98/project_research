@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class User {
  #String note
  -long updatedAt
  +double amount
  +double id
  +savePhone()
  +calculateStatus()
  +sendType()
}
class Notification {
  -boolean createdAt
  -long phone
  +String price
  +String total
  +deleteAddress()
  +findDuration()
  +createUpdatedat()
}
class Story {
  -boolean amount
  +long email
  #String note
  #String type
  +processEmail()
  +setPrice()
}
class Follower {
  +int level
  -long email
  +int amount
  #String updatedAt
  +String duration
  +setType()
  +setTotal()
  +deleteQuantity()
}
Story ..|> Notification
Follower --|> Notification
note right of User : Social Media domain
@enduml