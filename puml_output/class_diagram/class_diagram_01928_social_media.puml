@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class User {
  #String note
  -long updatedAt
  +double amount
  +double id
  +processNote()
  +deleteId()
  +sendDuration()
}
class Notification {
  +float status
  -double score
  -long type
  #double quantity
  -String address
  +createCreatedat()
}
class Story {
  -boolean description
  -Date address
  +long quantity
  #double updatedAt
  +createQuantity()
  +savePrice()
  +setType()
  +findCreatedat()
}
class Follower {
  -String description
  -Date note
  +validateName()
  +cancelActive()
  +deleteName()
}
Notification --|> Follower
@enduml