@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Route {
  #float note
  #long name
  #double price
  #String email
  -String duration
  +updateName()
  +cancelActive()
}
class Warehouse {
  #Date type
  #long score
  -long active
  +savePrice()
  +setName()
  +validateAddress()
}
interface DeliveryNote {
  +double description
  -String level
  -double quantity
  #double status
  +processCreatedat()
}
class Inventory {
  +Date duration
  +double phone
  +calculateCode()
  +sendActive()
  +findPhone()
  +findUpdatedat()
}
class Package {
  -String active
  #String duration
  +float quantity
  +String type
  +saveLevel()
  +deletePhone()
  +findDescription()
  +calculateQuantity()
}
abstract class Shipment {
  #float createdAt
  +boolean updatedAt
  #int email
  -Date type
  +double description
  +findCreatedat()
  +setActive()
  +createLevel()
  +cancelNote()
}
Inventory --|> Route
Inventory --> Warehouse : "*"
note right of Route : Logistics domain
@enduml