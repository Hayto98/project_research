@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Route {
  #float note
  #long name
  #double price
  #String email
  -String duration
  +sendId()
  +validatePrice()
}
class Warehouse {
  #Date description
  #long type
  -long score
  -Date active
  +setStatus()
  +calculateId()
  +setEmail()
  +cancelLevel()
}
class DeliveryNote {
  +double description
  -String level
  -double quantity
  #double status
  +deleteDuration()
}
class Inventory {
  #long score
  +Date level
  +double active
  #float status
  +processLevel()
  +processPhone()
  +sendType()
  +setDescription()
}
interface Package {
  #boolean updatedAt
  #long id
  -long active
  +boolean phone
  +getLevel()
}
class Shipment {
  +Date total
  -Date level
  +saveName()
  +calculatePhone()
}
Inventory ..|> Warehouse
DeliveryNote ..|> Inventory
Shipment --> Warehouse : "0..1"
Inventory ..> Shipment : "0..1"
@enduml