@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Shipment {
  #float quantity
  #long updatedAt
  +String id
  -boolean amount
  +cancelDescription()
  +saveNote()
}
class Warehouse {
  +int createdAt
  +String phone
  +processActive()
  +updateCreatedat()
  +sendPrice()
  +processTotal()
}
interface Review {
  #double quantity
  -double name
  +findNote()
}
class Product {
  +boolean createdAt
  #double level
  #float code
  +String updatedAt
  +updateStatus()
  +calculateLevel()
  +updateActive()
  +saveCode()
}
abstract class Customer {
  +long level
  +String total
  +findTotal()
  +processUpdatedat()
}
class Cart {
  +long score
  -double amount
  +cancelCode()
  +validateEmail()
  +validateScore()
}
Review ..> Warehouse : "0..1"
Customer ..> Product : "0..1"
note right of Shipment : Ecommerce domain
@enduml