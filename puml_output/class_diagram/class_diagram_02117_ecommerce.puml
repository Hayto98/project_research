@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Shipment {
  #float quantity
  #long updatedAt
  +String id
  -boolean amount
  +processId()
  +getEmail()
}
abstract class Warehouse {
  -int score
  +int status
  +boolean createdAt
  +deleteActive()
  +updateNote()
  +createId()
  +saveNote()
}
class Review {
  #double note
  -double total
  +Date name
  -float quantity
  +boolean score
  +getName()
  +sendType()
  +getTotal()
}
interface Product {
  #Date updatedAt
  -boolean name
  +saveId()
}
abstract class Customer {
  #Date status
  #String price
  -String createdAt
  +saveLevel()
  +cancelNote()
  +validateLevel()
  +processDescription()
}
class Cart {
  -int updatedAt
  #long total
  +sendAmount()
}
Warehouse --* Review
Product --> Review : "1"
Review --* Cart
@enduml