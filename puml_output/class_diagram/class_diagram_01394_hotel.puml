@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Guest {
  #boolean phone
  -double score
  +processPhone()
  +processPhone()
  +calculateEmail()
  +validatePrice()
}
class Housekeeping {
  #float email
  #int total
  #float quantity
  +validatePhone()
  +calculateCode()
  +deletePhone()
}
class Reservation {
  #Date name
  #long status
  #double duration
  +String active
  +createQuantity()
  +getCreatedat()
  +saveCode()
}
class CheckOut {
  #double duration
  #long amount
  +setScore()
  +findNote()
}
CheckOut ..|> Guest
Reservation ..|> CheckOut
Guest --> CheckOut : "*"
note right of Guest : Hotel domain
@enduml