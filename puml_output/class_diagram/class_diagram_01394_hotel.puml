@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Guest {
  #boolean phone
  -double score
  +sendCreatedat()
  +getDuration()
  +calculateTotal()
  +sendPhone()
}
abstract class Housekeeping {
  +int total
  #long email
  -long address
  #float price
  +findEmail()
  +calculateLevel()
}
interface Reservation {
  +long phone
  +long duration
  +Date total
  +String code
  +sendDuration()
  +cancelCreatedat()
  +findId()
}
class CheckOut {
  #String email
  +Date quantity
  #String id
  #int createdAt
  +getName()
  +findDuration()
  +calculatePhone()
  +findEmail()
}
Guest ..> Reservation : "*"
CheckOut --o Reservation
@enduml