@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
interface Librarian {
  -Date code
  -long address
  -float amount
  #double name
  +int note
  +calculateDescription()
  +setQuantity()
}
class Fine {
  -long description
  -double type
  +String note
  -int price
  +boolean phone
  +sendStatus()
  +calculatePrice()
  +findCreatedat()
}
class Reservation {
  +boolean quantity
  +float updatedAt
  +String duration
  -boolean description
  -float phone
  +calculateActive()
}
class Catalog {
  #float active
  -int phone
  #double description
  +boolean type
  +float note
  +getId()
}
class Branch {
  -long total
  -long id
  #boolean email
  +Date phone
  -boolean level
  +createId()
  +validateStatus()
  +saveUpdatedat()
}
Fine --o Catalog
Catalog ..|> Librarian
Branch --o Catalog
@enduml