@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
interface Librarian {
  -Date code
  -long address
  -float amount
  #double name
  +int note
  +findEmail()
  +processDescription()
}
abstract class Fine {
  -int price
  +double phone
  +String total
  #long quantity
  #long level
  +calculateQuantity()
  +saveUpdatedat()
  +saveQuantity()
}
class Reservation {
  +float id
  -boolean level
  -float duration
  #String updatedAt
  +sendScore()
  +cancelNote()
  +sendPhone()
}
class Catalog {
  #String note
  #String duration
  -long description
  -double price
  #String score
  +cancelPhone()
  +getQuantity()
  +createNote()
}
class Branch {
  +Date note
  -float address
  -double total
  +updateActive()
}
Catalog --o Librarian
Fine --> Reservation : "*"
Branch --* Fine
note right of Librarian : Library domain
@enduml