@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
interface Renewal {
  -Date price
  +double level
  +double description
  +float updatedAt
  +Date score
  +deleteNote()
  +cancelId()
}
class Reservation {
  #long email
  -String quantity
  #float updatedAt
  +processName()
  +processCreatedat()
  +processPhone()
  +setStatus()
}
abstract class Book {
  +Date duration
  -Date price
  +boolean level
  +getCode()
}
class Fine {
  +float id
  -String name
  +double address
  +float email
  -boolean price
  +deletePhone()
  +validateQuantity()
  +createNote()
  +findActive()
}
class Loan {
  +boolean phone
  +String description
  +calculateQuantity()
  +getPrice()
}
interface Branch {
  +Date total
  #String quantity
  #String description
  +findUpdatedat()
  +updateQuantity()
  +saveName()
}
Fine --|> Branch
Reservation --* Branch
Renewal ..> Fine : "1"
Book --* Fine
Book ..|> Loan
@enduml