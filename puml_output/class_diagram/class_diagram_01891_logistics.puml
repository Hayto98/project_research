@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Route {
  #double address
  +String updatedAt
  -int type
  #boolean score
  +deleteCreatedat()
  +saveStatus()
  +setUpdatedat()
  +saveEmail()
}
class Tracking {
  +long email
  +boolean note
  -int total
  +Date duration
  #String status
  +calculateDuration()
  +validatePrice()
  +validateAmount()
}
interface Customer {
  -long duration
  -String level
  #boolean name
  #int code
  +int updatedAt
  +saveCode()
}
interface Driver {
  -double duration
  +Date type
  +double address
  +double createdAt
  +sendTotal()
  +sendNote()
  +setTotal()
  +setName()
}
Driver --> Tracking : "*"
Customer --o Driver
note right of Route : Logistics domain
@enduml