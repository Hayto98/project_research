@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Route {
  #double address
  +String updatedAt
  -int type
  #boolean score
  +processPhone()
  +createCreatedat()
  +processAddress()
  +saveDescription()
}
class Tracking {
  #long status
  -boolean updatedAt
  +cancelPhone()
  +updateId()
  +calculateAmount()
  +calculateDescription()
}
interface Customer {
  +boolean level
  -int email
  +Date status
  #String createdAt
  #long phone
  +findDescription()
  +updateTotal()
  +processType()
  +validateDuration()
}
class Driver {
  -long duration
  -String level
  #boolean name
  #int code
  +int updatedAt
  +getAmount()
}
Customer --o Driver
@enduml