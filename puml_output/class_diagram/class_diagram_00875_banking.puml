@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
interface Teller {
  +Date quantity
  +double phone
  +String name
  +Date type
  #int createdAt
  +createPhone()
  +cancelUpdatedat()
  +validateDuration()
  +cancelAmount()
}
interface Card {
  -int level
  -String price
  +createTotal()
  +findActive()
  +findDuration()
  +cancelNote()
}
abstract class Account {
  -int type
  -Date description
  -String level
  +sendTotal()
  +findId()
  +createLevel()
  +createScore()
}
class Transfer {
  -String score
  +boolean name
  +long note
  +setAmount()
}
abstract class Loan {
  #int quantity
  -int amount
  -double name
  +validateQuantity()
}
class Customer {
  -double code
  +int note
  -long amount
  #float level
  #double email
  +calculateTotal()
}
interface Statement {
  +boolean address
  -Date type
  #double updatedAt
  -boolean score
  +boolean note
  +validateAddress()
}
Customer --|> Account
Account --|> Teller
Statement --> Customer : "1"
Statement --o Card
note right of Teller : Banking domain
@enduml