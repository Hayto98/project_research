@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
interface Teller {
  +Date quantity
  +double phone
  +String name
  +Date type
  #int createdAt
  +setTotal()
  +updateTotal()
  +saveDuration()
  +deleteAddress()
}
class Card {
  #float duration
  -double level
  +double id
  +getPrice()
}
abstract class Account {
  +double total
  +boolean active
  #int note
  -int score
  +calculateTotal()
  +findStatus()
  +createAmount()
}
class Transfer {
  #int active
  #int total
  #float id
  +double quantity
  -String email
  +sendAmount()
  +updateAmount()
}
class Loan {
  +long id
  +String code
  #int amount
  -int price
  +calculateAmount()
  +validateEmail()
  +processStatus()
  +validateStatus()
}
class Customer {
  -long type
  -double code
  +int note
  -long amount
  +getStatus()
  +sendUpdatedat()
  +cancelStatus()
  +getAddress()
}
abstract class Statement {
  +boolean address
  -Date type
  #double updatedAt
  -boolean score
  +boolean note
  +setEmail()
}
Statement ..> Account : "1..*"
Teller --|> Account
Statement ..> Teller : "1"
Statement --o Card
@enduml