@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Depot {
  #int id
  +String description
  #int amount
  #double level
  +sendId()
  +deleteUpdatedat()
  +getType()
}
class Package {
  +double total
  -boolean name
  #Date active
  +saveUpdatedat()
  +setCreatedat()
  +updateQuantity()
}
class Shipment {
  -boolean active
  +double code
  -double note
  +cancelAddress()
  +getType()
}
class Customer {
  +String code
  +Date active
  -Date note
  +String level
  +validateAddress()
  +deleteType()
  +cancelType()
  +findNote()
}
class Warehouse {
  -long active
  +long amount
  -boolean id
  +boolean score
  #float total
  +saveLevel()
  +createPrice()
  +deleteAddress()
  +findDescription()
}
class Route {
  +int status
  #String code
  +boolean note
  +setEmail()
  +findPrice()
  +processEmail()
}
class FuelLog {
  #float email
  +Date level
  -double address
  +setId()
  +calculateDuration()
}
Route ..|> Customer
Route ..> FuelLog : "*"
Depot --> Warehouse : "1..*"
Route --> Shipment : "0..1"
Package --* FuelLog
@enduml