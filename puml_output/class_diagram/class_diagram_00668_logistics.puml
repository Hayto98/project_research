@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Depot {
  #int id
  +String description
  #int amount
  #double level
  +updateLevel()
  +setName()
  +deleteTotal()
}
class Package {
  #boolean total
  #long address
  +cancelUpdatedat()
}
interface Shipment {
  #float note
  +double email
  +processUpdatedat()
  +createCode()
  +setEmail()
  +setActive()
}
abstract class Customer {
  #double id
  #float duration
  +getTotal()
}
class Warehouse {
  #int phone
  +String price
  +processQuantity()
  +deleteEmail()
  +validateLevel()
  +deleteActive()
}
interface Route {
  +float price
  -String updatedAt
  +Date email
  +String createdAt
  #long status
  +sendLevel()
  +validateAmount()
  +createLevel()
}
class FuelLog {
  #float total
  +boolean duration
  +findTotal()
  +updateTotal()
  +setActive()
  +cancelPhone()
}
FuelLog ..|> Warehouse
Package --* FuelLog
Depot ..> Route : "1..*"
FuelLog --|> Route
note right of Depot : Logistics domain
@enduml