@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Teller {
  #long quantity
  #String code
  -Date address
  #int total
  +getPhone()
  +calculateCreatedat()
}
class Transaction {
  #float amount
  #Date description
  -Date code
  -Date type
  +calculateNote()
  +validateUpdatedat()
  +deleteQuantity()
}
class Withdrawal {
  -String id
  +boolean code
  +getUpdatedat()
  +getCode()
  +deleteLevel()
}
class Customer {
  +float createdAt
  #double name
  -float address
  +sendPhone()
  +validateType()
  +setEmail()
  +getLevel()
}
class Beneficiary {
  +boolean phone
  -float quantity
  +float duration
  -Date amount
  +double active
  +calculateUpdatedat()
  +getType()
}
class Deposit {
  -Date phone
  #boolean price
  #double description
  +String score
  +Date type
  +createDuration()
  +createScore()
  +calculatePhone()
}
Beneficiary --> Deposit : "1"
Customer ..|> Beneficiary
note right of Teller : Banking domain
@enduml