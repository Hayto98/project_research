@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Teller {
  #long quantity
  #String code
  -Date address
  #int total
  +processQuantity()
  +deleteCode()
}
abstract class Transaction {
  +Date quantity
  +String level
  -Date address
  +updateId()
  +validateAddress()
  +cancelPrice()
}
class Withdrawal {
  +float note
  +String address
  +long updatedAt
  +float description
  +boolean quantity
  +sendTotal()
  +processPrice()
  +deleteNote()
}
class Customer {
  +int level
  +long status
  +float score
  +processStatus()
  +findTotal()
  +sendCode()
  +createUpdatedat()
}
class Beneficiary {
  #Date type
  #int code
  -Date email
  -Date name
  +cancelId()
  +findType()
  +setAddress()
}
class Deposit {
  +float description
  -Date score
  +double quantity
  +processLevel()
  +createScore()
}
Customer --o Withdrawal
Withdrawal --> Customer : "0..1"
@enduml