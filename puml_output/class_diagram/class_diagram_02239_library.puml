@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Publisher {
  #Date name
  +boolean phone
  #String duration
  +float email
  #float type
  +findNote()
  +cancelName()
  +getLevel()
  +updateId()
}
class Member {
  +String score
  #String email
  +float type
  +boolean status
  #int createdAt
  +getId()
  +validateEmail()
  +sendName()
}
class Shelf {
  +long name
  #long quantity
  #long description
  +deleteCreatedat()
  +sendStatus()
  +deleteId()
}
abstract class Librarian {
  +Date duration
  +long code
  +cancelQuantity()
  +getStatus()
  +findAddress()
  +getId()
}
interface Book {
  +int score
  #long active
  +updateActive()
}
Shelf --o Librarian
Member ..> Shelf : "1"
Librarian --* Publisher
@enduml