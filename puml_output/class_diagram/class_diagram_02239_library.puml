@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Publisher {
  #Date name
  +boolean phone
  #String duration
  +float email
  #float type
  +setCode()
  +findId()
  +findTotal()
  +findScore()
}
class Member {
  #String status
  +float level
  +boolean createdAt
  #int description
  -double name
  +processCode()
}
class Shelf {
  +long quantity
  #long description
  +saveScore()
  +validateEmail()
  +calculateLevel()
}
class Librarian {
  -double name
  -int updatedAt
  +saveLevel()
  +getScore()
  +sendDescription()
  +deleteLevel()
}
class Book {
  -Date id
  #float phone
  +processUpdatedat()
  +validateStatus()
  +calculateCode()
  +createUpdatedat()
}
Member --o Book
Book --* Publisher
Shelf ..> Librarian : "0..1"
Shelf ..> Publisher : "*"
note right of Publisher : Library domain
@enduml