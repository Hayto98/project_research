@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
interface Department {
  +Date createdAt
  +double type
  #float duration
  +String active
  +calculateCode()
  +saveNote()
  +validatePrice()
}
abstract class Exam {
  #double name
  +String description
  #boolean phone
  +validateLevel()
  +sendTotal()
  +calculateAmount()
}
class Teacher {
  +float price
  -boolean note
  +deleteEmail()
}
abstract class Attendance {
  +double note
  -float quantity
  -boolean name
  +String type
  +createCode()
}
class Classroom {
  -String level
  -int amount
  +long duration
  -float updatedAt
  +boolean quantity
  +setLevel()
  +updateAddress()
  +processType()
}
class Schedule {
  -String phone
  #float code
  +calculateNote()
  +saveTotal()
  +cancelAmount()
}
Teacher --> Department : "*"
Schedule ..|> Attendance
@enduml