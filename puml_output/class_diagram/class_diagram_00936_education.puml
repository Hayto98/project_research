@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
interface Department {
  +Date createdAt
  +double type
  #float duration
  +String active
  +calculateCreatedat()
  +saveType()
  +saveDescription()
}
class Exam {
  +String phone
  #boolean level
  #long price
  +processAddress()
}
class Teacher {
  -boolean note
  -double amount
  -boolean type
  #Date active
  +double code
  +processType()
  +calculateActive()
}
class Attendance {
  -double name
  #float amount
  +deleteUpdatedat()
  +findScore()
}
class Classroom {
  -long id
  +boolean address
  -int amount
  #double description
  +sendScore()
}
class Schedule {
  +boolean code
  #Date total
  #String name
  -float email
  +sendNote()
}
Exam ..|> Schedule
Schedule --o Exam
Teacher --* Exam
Department --> Exam : "0..1"
Classroom --* Schedule
note right of Department : Education domain
@enduml