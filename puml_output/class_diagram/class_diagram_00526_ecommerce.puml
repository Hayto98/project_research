@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Cart {
  #String amount
  +Date quantity
  -Date level
  +saveScore()
  +updateQuantity()
  +processUpdatedat()
}
abstract class Review {
  -float name
  #double level
  +validateCode()
  +calculateAmount()
  +processPrice()
  +calculateDescription()
}
class Product {
  +boolean amount
  -boolean email
  #Date name
  +processPhone()
}
class Order {
  #String duration
  -long status
  +updateTotal()
  +saveTotal()
  +processPhone()
  +validateDuration()
}
interface Warehouse {
  -Date active
  -String email
  +deletePrice()
  +cancelPhone()
  +calculateStatus()
}
Review --* Cart
note right of Cart : Ecommerce domain
@enduml