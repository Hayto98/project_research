@startuml

class Hashtag {
  +float code
  +String active
  -Date name
  -int total
  -int phone
  +calculateStatus()
}
interface Group {
  -Date id
  -String status
  #long price
  +Date phone
  -double address
  +cancelTotal()
  +validateDuration()
  +cancelCode()
  +processCreatedat()
}
class Album {
  +Date score
  -float code
  #float id
  +findCode()
  +cancelTotal()
  +calculatePrice()
}
class Comment {
  #Date score
  +float updatedAt
  -int price
  +createName()
}
class User {
  #boolean score
  #int createdAt
  +calculateEmail()
  +saveCode()
  +cancelAmount()
  +updateScore()
}
class Like {
  +Date code
  -float type
  +int status
  +long phone
  -boolean updatedAt
  +deleteNote()
  +calculateType()
}
Hashtag --> User : "1..*"
User --* Group
User ..|> Album
Album ..|> Group
@enduml