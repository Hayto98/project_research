@startuml

class Hashtag {
  +float code
  +String active
  -Date name
  -int total
  -int phone
  +findScore()
}
abstract class Group {
  -long status
  -Date price
  +setLevel()
  +validateCreatedat()
  +findType()
  +calculateType()
}
class Album {
  +String type
  #double phone
  #float createdAt
  -long code
  +sendUpdatedat()
}
class Comment {
  +String price
  -long createdAt
  #boolean phone
  +sendCreatedat()
}
interface User {
  -String level
  #Date note
  #float name
  +processCode()
}
interface Like {
  +int status
  +long phone
  -boolean updatedAt
  #int duration
  +float total
  +setLevel()
  +cancelAddress()
  +sendAmount()
}
User ..|> Album
Album ..|> Group
Comment ..|> Group
Album --* Like
note right of Hashtag : Social Media domain
@enduml