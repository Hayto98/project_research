@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class FuelLog {
  #float updatedAt
  -Date email
  +Date active
  +deleteActive()
}
abstract class Tracking {
  #boolean address
  -float price
  +updatePrice()
  +calculateDescription()
  +createLevel()
  +cancelPrice()
}
class Inventory {
  #float active
  +Date code
  +calculateQuantity()
}
class Warehouse {
  +String id
  +long level
  +setScore()
  +saveType()
}
interface Package {
  -int amount
  #boolean createdAt
  -double total
  -int id
  +findTotal()
  +deleteId()
  +findQuantity()
  +getQuantity()
}
class Route {
  #Date price
  #String score
  #Date id
  -boolean active
  +processScore()
  +validateTotal()
  +updateId()
  +getAmount()
}
interface Driver {
  -Date total
  -float type
  #int address
  +boolean phone
  +saveTotal()
  +setLevel()
  +setAmount()
}
FuelLog ..|> Warehouse
Warehouse --> Route : "1..*"
FuelLog ..> Route : "1..*"
@enduml