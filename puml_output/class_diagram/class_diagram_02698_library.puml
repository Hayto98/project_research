@startuml
skinparam shadowing true
class Librarian {
  +Date email
  -float level
  +String duration
  +getDuration()
  +validateNote()
  +cancelLevel()
  +saveLevel()
}
class Catalog {
  +boolean id
  +String level
  -Date total
  +findUpdatedat()
  +sendCreatedat()
  +getName()
}
class Author {
  -boolean price
  #double amount
  +long code
  +Date createdAt
  +validateAddress()
  +processPhone()
}
class Branch {
  -Date phone
  +long status
  -boolean id
  +deleteNote()
  +setDuration()
  +updateCode()
  +cancelScore()
}
class Book {
  +boolean email
  +String type
  +validateDescription()
  +deleteNote()
}
class Publisher {
  #Date description
  #double code
  +cancelDescription()
  +sendDescription()
  +deleteCode()
  +setPrice()
}
interface Renewal {
  #Date id
  #long email
  -float active
  +calculateAmount()
  +deleteUpdatedat()
}
Author --> Publisher : "0..1"
Catalog --* Librarian
note right of Librarian : Library domain
@enduml