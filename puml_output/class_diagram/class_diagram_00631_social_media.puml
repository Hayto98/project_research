@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Comment {
  -boolean address
  #Date createdAt
  -float price
  +processPhone()
}
interface Follower {
  #boolean email
  #String phone
  #long active
  +saveCreatedat()
  +validateStatus()
  +setAddress()
  +calculateId()
}
class Profile {
  #Date phone
  -Date type
  +boolean code
  #boolean description
  -String total
  +getId()
  +updateStatus()
  +createPhone()
  +sendQuantity()
}
class Group {
  -Date updatedAt
  +int amount
  -Date note
  +validateLevel()
  +updateStatus()
  +setDescription()
  +saveCode()
}
interface User {
  +String updatedAt
  -long createdAt
  -int duration
  +cancelType()
}
class Hashtag {
  -float level
  +boolean quantity
  -double code
  -int phone
  +saveCreatedat()
  +cancelLevel()
  +calculateDuration()
  +calculateAmount()
}
Comment --|> Hashtag
Group --o User
Hashtag ..|> Comment
@enduml