@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Comment {
  -boolean address
  #Date createdAt
  -float price
  +sendDescription()
}
class Follower {
  #long active
  #double level
  -float score
  #String id
  +saveScore()
  +saveNote()
  +validateType()
}
class Profile {
  #int score
  #boolean total
  #float type
  +setLevel()
  +processType()
  +updateStatus()
  +sendStatus()
}
class Group {
  #int amount
  +float note
  -Date type
  +updateCode()
  +calculateActive()
  +findAmount()
  +updateCreatedat()
}
interface User {
  -long code
  +String status
  -long phone
  +saveCode()
  +saveScore()
  +validateType()
}
class Hashtag {
  #double price
  +String note
  +String createdAt
  -boolean type
  -Date address
  +updateTotal()
}
Hashtag --o Follower
User --o Profile
Hashtag --* Comment
note right of Comment : Social Media domain
@enduml