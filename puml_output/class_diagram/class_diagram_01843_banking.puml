@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
interface Transaction {
  #int phone
  #float status
  +updatePhone()
  +calculatePrice()
  +processNote()
}
abstract class Transfer {
  -String createdAt
  -Date name
  -Date address
  -Date level
  +saveAmount()
}
class Beneficiary {
  +long score
  +double name
  -long address
  +deleteEmail()
  +calculateUpdatedat()
}
class Customer {
  #long createdAt
  +double duration
  #double type
  +float note
  -boolean level
  +validateAmount()
}
interface Deposit {
  -Date email
  #Date type
  -double phone
  +createName()
  +saveEmail()
  +saveCode()
}
class Teller {
  #Date id
  -boolean level
  -double status
  +setCode()
  +findTotal()
  +deletePhone()
  +saveDescription()
}
interface Statement {
  #Date quantity
  +Date id
  +updateUpdatedat()
}
Transaction --|> Customer
Transaction --o Statement
@enduml