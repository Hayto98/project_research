@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Card {
  -long note
  -float createdAt
  +Date description
  -double status
  #double active
  +getEmail()
  +setPrice()
  +updateAmount()
}
abstract class Customer {
  -Date status
  -float type
  +getPrice()
}
abstract class Statement {
  +int id
  +long name
  +getAddress()
}
class Beneficiary {
  +boolean phone
  +int id
  +int type
  #boolean level
  +long score
  +findId()
  +sendAddress()
  +updateAmount()
  +setQuantity()
}
class Transfer {
  #double status
  +int level
  -double createdAt
  +double duration
  -Date code
  +saveType()
}
Card ..|> Statement
Card --> Beneficiary : "0..1"
Statement --* Customer
@enduml