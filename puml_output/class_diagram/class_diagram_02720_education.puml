@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
abstract class Assignment {
  -float name
  -Date email
  +saveName()
  +createCode()
}
interface Grade {
  +float createdAt
  #double name
  +deleteType()
  +getEmail()
  +sendDuration()
  +updateNote()
}
class Classroom {
  -Date price
  +Date active
  +saveType()
  +getCode()
}
class Enrollment {
  #long createdAt
  +boolean level
  -String quantity
  #int address
  #String description
  +processDescription()
  +sendId()
  +findStatus()
}
Assignment --* Classroom
Assignment ..> Enrollment : "1"
Enrollment ..|> Classroom
note right of Assignment : Education domain
@enduml