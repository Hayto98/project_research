@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
abstract class Assignment {
  -float name
  -Date email
  +cancelPrice()
  +deleteEmail()
}
class Grade {
  +float code
  +float score
  #double name
  -int createdAt
  +updatePrice()
  +sendAddress()
  +sendQuantity()
  +getQuantity()
}
class Classroom {
  #String status
  #int name
  #double price
  +float active
  #Date note
  +validateQuantity()
}
interface Enrollment {
  #long createdAt
  +boolean level
  -String quantity
  #int address
  #String description
  +validateName()
  +findPhone()
  +saveActive()
}
Assignment --> Grade : "1"
Classroom --> Enrollment : "1"
@enduml