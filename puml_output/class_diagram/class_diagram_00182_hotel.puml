@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
interface Service {
  #boolean id
  #String name
  +String total
  -boolean note
  +cancelPrice()
  +findLevel()
  +updateType()
}
class Payment {
  +String score
  +double quantity
  #String active
  +Date note
  #double type
  +updateQuantity()
  +cancelUpdatedat()
  +calculateScore()
  +deleteNote()
}
class Guest {
  -String score
  -boolean address
  -int description
  +savePrice()
  +deleteDescription()
  +updateType()
}
class Invoice {
  #Date price
  #int createdAt
  -int active
  +createEmail()
  +sendType()
}
class Housekeeping {
  -double price
  -String type
  -boolean createdAt
  +long amount
  +processUpdatedat()
  +processId()
  +cancelScore()
  +processAddress()
}
abstract class Reservation {
  +String code
  -String createdAt
  #String name
  +boolean active
  +sendType()
  +setPhone()
  +cancelEmail()
}
Reservation --* Payment
Housekeeping ..> Reservation : "1..*"
Guest ..> Housekeeping : "*"
Housekeeping --* Service
Housekeeping --o Invoice
@enduml