@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
interface Deposit {
  +double active
  -boolean id
  -float address
  -long type
  #float email
  +saveScore()
  +validateCode()
  +getName()
}
class Withdrawal {
  +long active
  -String type
  +float amount
  +cancelPhone()
  +getQuantity()
}
abstract class Teller {
  +Date level
  -boolean amount
  +sendAmount()
  +updateStatus()
  +saveTotal()
  +validateStatus()
}
class Branch {
  +double createdAt
  -int score
  -boolean updatedAt
  +savePrice()
  +cancelName()
}
class Loan {
  #boolean quantity
  +boolean name
  +createPhone()
  +processType()
  +updatePhone()
}
interface Transaction {
  -double duration
  #boolean score
  +String status
  +validateCreatedat()
}
Loan --* Withdrawal
Withdrawal --* Transaction
note right of Deposit : Banking domain
@enduml