@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
interface Deposit {
  +double active
  -boolean id
  -float address
  -long type
  #float email
  +cancelPrice()
  +calculatePrice()
  +processStatus()
}
class Withdrawal {
  +boolean name
  -int status
  +findEmail()
  +createActive()
}
abstract class Teller {
  #long createdAt
  +float amount
  +validateUpdatedat()
  +processCode()
  +saveDuration()
}
class Branch {
  #Date address
  +int active
  +Date note
  +createAmount()
  +validateEmail()
  +setQuantity()
  +findCreatedat()
}
class Loan {
  -long score
  +double updatedAt
  #int amount
  +savePrice()
  +setUpdatedat()
  +findTotal()
  +cancelAddress()
}
class Transaction {
  -float name
  -double code
  -int active
  -float email
  +createTotal()
  +validateActive()
}
Teller --> Branch : "1"
Deposit --* Transaction
@enduml