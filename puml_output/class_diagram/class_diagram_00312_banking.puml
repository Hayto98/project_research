@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Transaction {
  #float email
  +Date status
  -boolean id
  +updateCreatedat()
  +setPhone()
}
class Interest {
  #double price
  #boolean score
  -String type
  #Date duration
  -double phone
  +getTotal()
  +cancelStatus()
}
class Withdrawal {
  -long duration
  -int level
  +processPrice()
  +deleteUpdatedat()
  +processStatus()
}
abstract class Deposit {
  +long description
  -Date status
  +Date amount
  +processName()
  +sendNote()
  +createTotal()
  +calculateDescription()
}
Interest --|> Deposit
@enduml