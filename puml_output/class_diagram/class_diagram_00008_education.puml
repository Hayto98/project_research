@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Teacher {
  +double level
  +Date total
  +Date amount
  +findName()
  +createType()
}
class Book {
  +long status
  +boolean phone
  -int email
  +deleteScore()
  +findDescription()
  +validateLevel()
}
abstract class Enrollment {
  +float score
  #String name
  +Date total
  -float description
  +setAmount()
}
class Department {
  #int email
  -int total
  #int price
  -double score
  +saveTotal()
  +getEmail()
}
interface Classroom {
  +Date code
  -String type
  +createActive()
  +saveAmount()
  +validateScore()
  +processCode()
}
Enrollment --* Classroom
Department --|> Enrollment
note right of Teacher : Education domain
@enduml