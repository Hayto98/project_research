@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Coupon {
  #Date description
  -float total
  #long email
  -long phone
  +updateActive()
  +getPrice()
  +setDuration()
  +updateEmail()
}
abstract class Customer {
  #String price
  -String phone
  #Date note
  +int quantity
  +double score
  +createNote()
  +calculateCreatedat()
  +calculateDescription()
  +getNote()
}
class Category {
  #int amount
  +String description
  +long quantity
  +createCreatedat()
}
class Payment {
  -float description
  +Date score
  -boolean level
  +long code
  +updateAddress()
  +saveLevel()
  +getId()
  +processDescription()
}
abstract class Shipment {
  -double active
  -Date status
  +long quantity
  +Date level
  +long price
  +getQuantity()
  +calculateQuantity()
  +createCreatedat()
  +cancelEmail()
}
interface Cart {
  -double id
  -String status
  +setType()
  +findScore()
}
Coupon ..|> Category
Payment ..> Category : "1..*"
@enduml