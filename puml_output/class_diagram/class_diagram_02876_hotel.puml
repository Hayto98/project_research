@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
interface Booking {
  #long note
  +Date updatedAt
  #boolean type
  -double address
  #String level
  +cancelStatus()
  +findDuration()
}
interface Housekeeping {
  -Date email
  +double amount
  +findId()
  +processAmount()
}
class Amenity {
  #double code
  +float email
  #boolean quantity
  -long phone
  +setStatus()
  +sendCode()
  +setActive()
  +validateDuration()
}
abstract class Guest {
  #double status
  #double id
  +getDuration()
  +cancelScore()
  +validateId()
}
abstract class Invoice {
  -float name
  #Date type
  #double score
  +findScore()
  +processDuration()
  +sendName()
  +setNote()
}
class Reservation {
  #double updatedAt
  +boolean id
  +createDuration()
  +calculateCode()
  +createCode()
}
interface Room {
  -String email
  -int duration
  +boolean amount
  +cancelUpdatedat()
}
Booking ..> Guest : "*"
Room ..> Reservation : "1"
Amenity --> Room : "0..1"
Room --* Booking
Room ..> Invoice : "1..*"
@enduml