@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
interface Route {
  +String price
  -Date level
  -int email
  #float total
  +createCode()
  +findEmail()
  +updateName()
}
abstract class Tracking {
  -boolean email
  #double code
  +findCode()
  +findScore()
  +setDescription()
  +calculateActive()
}
class Vehicle {
  +boolean duration
  -int note
  #Date type
  +createEmail()
  +setActive()
  +sendPhone()
  +validateType()
}
abstract class Inventory {
  -boolean level
  -Date phone
  -int note
  -long duration
  #long createdAt
  +findCode()
  +updateTotal()
  +sendAmount()
}
abstract class Customer {
  -long email
  -long active
  -double quantity
  +Date createdAt
  -boolean duration
  +processScore()
}
class DeliveryNote {
  #Date name
  #int type
  +deletePrice()
  +deleteDescription()
  +calculateEmail()
  +saveUpdatedat()
}
abstract class Depot {
  #long updatedAt
  #float description
  +calculateActive()
  +getPrice()
}
Inventory ..|> Route
DeliveryNote ..|> Depot
Tracking ..> Vehicle : "0..1"
@enduml