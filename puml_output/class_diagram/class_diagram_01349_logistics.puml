@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
interface Route {
  +String price
  -Date level
  -int email
  #float total
  +deleteStatus()
  +calculateName()
  +createCode()
}
class Tracking {
  +float total
  #double phone
  -String quantity
  #long code
  +boolean score
  +validatePrice()
  +calculateLevel()
  +validateNote()
  +validateActive()
}
class Vehicle {
  -long duration
  #long phone
  -long address
  -boolean updatedAt
  +calculateEmail()
  +sendDuration()
  +createScore()
  +updateEmail()
}
abstract class Inventory {
  +Date email
  -boolean phone
  +float note
  +String price
  +processScore()
}
class Customer {
  +boolean note
  -Date name
  +boolean type
  -double status
  +int updatedAt
  +deleteQuantity()
  +saveLevel()
}
class DeliveryNote {
  -Date createdAt
  +long active
  +long score
  +processAmount()
  +validateUpdatedat()
}
abstract class Depot {
  -double updatedAt
  +boolean id
  +int amount
  +cancelAddress()
  +cancelScore()
  +saveTotal()
  +calculateDuration()
}
Route --> Tracking : "*"
Depot ..|> Inventory
Tracking ..> Route : "1"
note right of Route : Logistics domain
@enduml