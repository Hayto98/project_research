@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Comment {
  #String email
  -int address
  #int id
  +String updatedAt
  +findAddress()
  +updateAddress()
}
abstract class Like {
  +float createdAt
  +Date description
  +double score
  +updateDuration()
}
class User {
  -String price
  +boolean total
  +cancelActive()
  +calculatePrice()
  +deleteTotal()
}
class Group {
  #long quantity
  #String level
  +calculateId()
  +validateId()
  +cancelStatus()
  +updatePhone()
}
interface Hashtag {
  -double description
  -long code
  -int score
  +updatePrice()
  +saveType()
  +deleteType()
}
interface Report {
  #boolean duration
  #String note
  +double updatedAt
  +updateEmail()
  +findAmount()
}
abstract class Notification {
  #boolean updatedAt
  #Date address
  +calculateId()
}
Hashtag ..|> Report
Report --> Notification : "1..*"
Comment --> Report : "1..*"
Group --* Notification
User --|> Like
@enduml