@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Payment {
  -double quantity
  +Date status
  +deleteScore()
}
class Invoice {
  +float level
  -String status
  -boolean address
  -long phone
  +float amount
  +sendTotal()
  +findCreatedat()
}
class Guest {
  #String email
  #boolean price
  +deleteUpdatedat()
  +updateTotal()
  +saveType()
}
interface Room {
  #double name
  -int description
  #String amount
  #double active
  #String total
  +updateName()
  +setName()
  +sendId()
}
abstract class Service {
  #long updatedAt
  #int active
  -float score
  +Date phone
  -long type
  +createLevel()
  +setAddress()
}
interface CheckIn {
  -boolean status
  -Date active
  +boolean level
  #Date description
  +findEmail()
  +createDuration()
  +getEmail()
}
interface Amenity {
  +long amount
  -long note
  +Date type
  #boolean active
  +Date duration
  +validateId()
  +getAddress()
}
Guest --> Service : "0..1"
CheckIn --> Guest : "1"
Guest ..|> Room
Invoice --* Amenity
Invoice ..|> Payment
Guest ..|> Payment
@enduml