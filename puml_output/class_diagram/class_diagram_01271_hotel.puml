@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Payment {
  -double quantity
  +Date status
  +deleteId()
}
interface Invoice {
  +float level
  -String status
  -boolean address
  -long phone
  +float amount
  +getEmail()
  +getName()
}
class Guest {
  +float status
  +Date level
  +Date phone
  #double score
  #double total
  +updateDuration()
  +getTotal()
  +findCode()
}
class Room {
  -double id
  +boolean createdAt
  +processScore()
  +createAmount()
  +calculateUpdatedat()
}
class Service {
  +Date updatedAt
  #boolean score
  #boolean active
  #boolean quantity
  +validateLevel()
  +processUpdatedat()
}
interface CheckIn {
  +double price
  -boolean description
  #boolean active
  +String duration
  +createPhone()
  +deleteActive()
  +getUpdatedat()
}
class Amenity {
  #String score
  -double quantity
  +int active
  +long amount
  +String phone
  +validateName()
  +updateScore()
}
Guest --o Payment
Invoice ..|> Guest
Service --|> Invoice
note right of Payment : Hotel domain
@enduml