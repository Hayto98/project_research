@startuml
skinparam monochrome true
skinparam shadowing true
class Ward {
  -float price
  +long createdAt
  #boolean address
  -float status
  +calculateTotal()
}
interface Treatment {
  -boolean score
  +boolean total
  +deleteAmount()
}
abstract class Appointment {
  +float duration
  +String level
  -int type
  -long active
  #Date score
  +validateType()
  +savePrice()
}
interface Hospital {
  #float price
  -Date phone
  +updateAddress()
  +setPrice()
  +createAddress()
  +getId()
}
Appointment --* Hospital
Hospital --o Treatment
Appointment ..|> Treatment
note right of Ward : Healthcare domain
@enduml