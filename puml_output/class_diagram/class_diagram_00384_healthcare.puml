@startuml
skinparam monochrome true
skinparam shadowing true
class Ward {
  -float price
  +long createdAt
  #boolean address
  -float status
  +createPrice()
}
abstract class Treatment {
  -boolean score
  +boolean total
  +processUpdatedat()
}
class Appointment {
  +float type
  +String level
  -int duration
  -long active
  #Date score
  +validateScore()
  +calculateLevel()
}
abstract class Hospital {
  #Date duration
  #float status
  -int price
  -String phone
  -long note
  +deleteNote()
  +deleteStatus()
  +updateDuration()
}
Appointment --* Hospital
Hospital --o Treatment
Appointment ..|> Treatment
@enduml