@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
abstract class Loan {
  -int updatedAt
  -int type
  +sendId()
}
class Renewal {
  +int active
  +Date amount
  -boolean price
  #float quantity
  +boolean createdAt
  +getDuration()
  +cancelId()
}
interface Shelf {
  #int name
  #boolean address
  +boolean email
  +long level
  +sendQuantity()
  +getId()
  +deleteTotal()
  +validateName()
}
class Member {
  #int createdAt
  -Date address
  #boolean level
  +updateScore()
  +deleteActive()
}
class Author {
  #int name
  -boolean address
  -double phone
  -float score
  #long active
  +findStatus()
  +setNote()
  +cancelTotal()
}
Loan --|> Member
Loan --* Renewal
Shelf ..|> Loan
Renewal --* Member
@enduml