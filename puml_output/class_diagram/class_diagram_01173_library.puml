@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
abstract class Loan {
  -int updatedAt
  -int type
  +updatePhone()
}
abstract class Renewal {
  +int price
  +Date quantity
  -boolean createdAt
  +cancelLevel()
  +saveScore()
}
interface Shelf {
  #Date phone
  -long duration
  -Date name
  +sendScore()
  +getDuration()
}
class Member {
  -String active
  #float type
  +int duration
  #boolean level
  +validateDescription()
  +calculateActive()
  +cancelUpdatedat()
}
abstract class Author {
  #long type
  -long name
  #int address
  +sendTotal()
  +processType()
  +sendPhone()
}
Shelf --|> Member
Loan --|> Member
Loan --* Renewal
Shelf ..|> Loan
note right of Loan : Library domain
@enduml