@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Customer {
  +Date active
  #float createdAt
  #String level
  #float quantity
  +findEmail()
}
abstract class Order {
  -boolean description
  -String name
  -float quantity
  -long code
  +processLevel()
  +getDescription()
  +sendUpdatedat()
  +setDescription()
}
class Supplier {
  +long price
  +float amount
  #String updatedAt
  +long email
  #double quantity
  +calculateActive()
  +validateId()
  +processCode()
  +validateDuration()
}
abstract class Product {
  #long status
  #float updatedAt
  +getCode()
  +updateQuantity()
}
class Cart {
  #Date address
  #float code
  #double status
  +sendCode()
  +validateId()
}
Supplier --* Product
Supplier --o Order
Order --|> Product
@enduml