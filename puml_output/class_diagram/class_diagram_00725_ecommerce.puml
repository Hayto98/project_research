@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Customer {
  +Date active
  #float createdAt
  #String level
  #float quantity
  +processQuantity()
}
class Order {
  +long level
  #double quantity
  +createType()
}
class Supplier {
  #float total
  +float code
  #int quantity
  #long type
  -String price
  +setScore()
  +setName()
  +createActive()
}
abstract class Product {
  +String active
  +float status
  #long id
  #float address
  +boolean total
  +updateAddress()
  +setStatus()
}
interface Cart {
  -long createdAt
  +double note
  -double status
  +double phone
  +int type
  +processDuration()
  +calculatePhone()
}
Order --> Product : "*"
Customer --* Supplier
Product --|> Supplier
Supplier ..|> Product
note right of Customer : Ecommerce domain
@enduml