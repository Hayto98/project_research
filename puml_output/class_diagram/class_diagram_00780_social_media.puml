@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
interface Message {
  +String level
  -long address
  -long quantity
  +float createdAt
  +boolean score
  +sendCode()
  +findPhone()
  +cancelStatus()
}
class Notification {
  -String code
  -double note
  +double type
  #double updatedAt
  #double duration
  +sendDescription()
  +updateActive()
}
class Album {
  +Date total
  #long active
  #int description
  -double level
  #float duration
  +deleteDuration()
  +saveCode()
  +updateCode()
  +cancelQuantity()
}
interface Group {
  -long note
  -String total
  -String phone
  +updateUpdatedat()
  +setNote()
  +cancelName()
}
class User {
  #Date amount
  -double address
  #boolean createdAt
  +double status
  #int description
  +createEmail()
  +sendUpdatedat()
  +saveNote()
  +getCreatedat()
}
class Like {
  #String createdAt
  -String status
  +String code
  -long duration
  #Date score
  +saveEmail()
  +sendType()
  +deleteType()
  +getAmount()
}
abstract class Comment {
  -String score
  #Date total
  +boolean status
  #double phone
  #boolean type
  +getScore()
  +processStatus()
}
Notification --> Message : "*"
Message --|> Notification
Message ..> Comment : "1"
note right of Message : Social Media domain
@enduml