@startuml
skinparam monochrome true
skinparam ArrowColor #555555
interface Student {
  #Date price
  +boolean address
  +getCode()
  +setAmount()
}
class Assignment {
  #int createdAt
  +int active
  #int score
  -double total
  +boolean id
  +cancelUpdatedat()
  +saveCreatedat()
  +getPhone()
  +calculateStatus()
}
class Exam {
  -double name
  +Date id
  #int score
  -double phone
  +createLevel()
  +deleteActive()
  +createAddress()
  +createActive()
}
interface Book {
  -Date duration
  #String phone
  +createPhone()
  +setDuration()
  +cancelLevel()
  +deleteEmail()
}
abstract class Library {
  +boolean quantity
  -double amount
  -Date note
  +findCreatedat()
  +saveId()
  +setPrice()
}
class Teacher {
  +Date type
  #int code
  +int id
  +boolean note
  +int updatedAt
  +saveLevel()
  +findCreatedat()
  +getId()
}
Book --> Library : "0..1"
Exam --* Student
Student --* Assignment
note right of Student : Education domain
@enduml