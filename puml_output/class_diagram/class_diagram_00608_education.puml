@startuml
skinparam monochrome true
skinparam ArrowColor #555555
interface Student {
  #Date price
  +boolean address
  +savePhone()
  +validatePhone()
}
class Assignment {
  #float phone
  #float note
  #boolean createdAt
  +calculateUpdatedat()
  +createDescription()
  +processName()
  +cancelAmount()
}
class Exam {
  -double updatedAt
  +boolean duration
  +sendActive()
  +sendNote()
  +setActive()
  +sendStatus()
}
class Book {
  +String phone
  #float total
  +calculateEmail()
  +validateLevel()
  +cancelDuration()
}
class Library {
  -double price
  -long type
  #boolean updatedAt
  +boolean createdAt
  +saveCreatedat()
  +deleteCreatedat()
  +sendQuantity()
}
interface Teacher {
  -Date duration
  #String phone
  +processDescription()
  +processStatus()
  +sendLevel()
  +deleteLevel()
}
Library --> Teacher : "0..1"
Exam ..> Book : "0..1"
@enduml