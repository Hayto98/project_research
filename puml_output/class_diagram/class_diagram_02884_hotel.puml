@startuml
skinparam defaultFontSize 13
abstract class Booking {
  -String phone
  +double description
  -float price
  -Date amount
  +int level
  +deleteLevel()
  +createQuantity()
}
class Staff {
  -int createdAt
  -Date updatedAt
  +processCreatedat()
  +processId()
  +setPrice()
}
class Restaurant {
  #boolean status
  #long email
  -float address
  +int createdAt
  +double name
  +cancelId()
  +saveCreatedat()
  +updateId()
}
class Service {
  +boolean note
  #Date id
  -long email
  +getCode()
}
interface Guest {
  -long email
  #double price
  +double address
  +String updatedAt
  +calculateTotal()
  +getStatus()
}
Booking --> Service : "1"
Restaurant --o Booking
Guest ..|> Booking
Restaurant --> Service : "*"
@enduml