@startuml

interface Message {
  #double price
  +Date createdAt
  -int code
  +deleteAddress()
  +setAmount()
  +cancelEmail()
  +saveStatus()
}
class Report {
  -long email
  +double phone
  +cancelActive()
}
class Comment {
  #String name
  #int amount
  +cancelType()
  +validateType()
  +findPhone()
}
class Notification {
  -long createdAt
  +boolean note
  +String type
  -float level
  +setEmail()
  +sendPhone()
  +findPhone()
}
Notification --> Comment : "0..1"
Report ..|> Notification
Notification ..> Message : "0..1"
@enduml