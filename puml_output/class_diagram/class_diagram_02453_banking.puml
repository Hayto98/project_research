@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
abstract class Deposit {
  -float quantity
  +String score
  -boolean price
  +double description
  #Date duration
  +deleteCode()
  +deleteAmount()
}
class Card {
  #double quantity
  +int name
  -boolean price
  -Date address
  -Date active
  +createAmount()
}
interface Transfer {
  #int duration
  -double createdAt
  -int updatedAt
  +savePrice()
  +processAddress()
}
class Statement {
  #long updatedAt
  +boolean code
  #int address
  #boolean total
  +double score
  +deleteId()
  +cancelName()
  +getPhone()
}
class Branch {
  +double name
  #String phone
  #Date status
  -boolean code
  +updateQuantity()
  +validateQuantity()
  +createCreatedat()
  +saveActive()
}
Transfer --|> Branch
Branch ..> Card : "1..*"
Branch ..> Deposit : "1..*"
Statement --* Branch
@enduml