@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
abstract class Deposit {
  -float quantity
  +String score
  -boolean price
  +double description
  #Date duration
  +validatePrice()
  +updateNote()
}
class Card {
  #long price
  #double address
  +updateQuantity()
  +sendPrice()
}
abstract class Transfer {
  +boolean phone
  +int level
  +createNote()
  +createDescription()
}
class Statement {
  -boolean price
  #Date updatedAt
  -Date code
  -float address
  +sendCreatedat()
}
interface Branch {
  #double price
  -long email
  +validateLevel()
}
Deposit --o Branch
Deposit --> Transfer : "*"
note right of Deposit : Banking domain
@enduml