@startuml
skinparam defaultFontSize 13
abstract class Invoice {
  #double active
  +double total
  -String createdAt
  -double price
  -long email
  +cancelCode()
  +sendQuantity()
  +saveDuration()
  +validateType()
}
class Booking {
  +long price
  #Date active
  +double duration
  -boolean status
  +calculateTotal()
}
abstract class CheckOut {
  -float createdAt
  #String quantity
  +Date note
  +int score
  -int level
  +createPhone()
  +createCreatedat()
  +saveName()
  +deleteType()
}
class CheckIn {
  #double id
  +boolean active
  +boolean name
  #int price
  +long createdAt
  +getPhone()
  +validateName()
}
Invoice --> Booking : "*"
Booking --|> CheckOut
@enduml