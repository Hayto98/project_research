@startuml
skinparam defaultFontSize 13
interface Route {
  +String price
  +String updatedAt
  +saveDescription()
  +getCode()
  +getUpdatedat()
  +findId()
}
class Vehicle {
  -String email
  -float duration
  +int createdAt
  +double status
  -double id
  +deleteAmount()
  +findCode()
  +cancelNote()
}
class Warehouse {
  #float price
  #long phone
  +boolean updatedAt
  #float note
  +saveName()
  +setQuantity()
}
abstract class Shipment {
  -float description
  +String price
  #double status
  +updateAddress()
  +setStatus()
  +sendUpdatedat()
}
Warehouse ..> Vehicle : "*"
Vehicle --> Route : "*"
@enduml