@startuml
skinparam defaultFontSize 13
interface Route {
  +String price
  +String updatedAt
  +findLevel()
  +deleteDescription()
  +cancelPrice()
  +findEmail()
}
class Vehicle {
  +double status
  +int id
  +double type
  +processPhone()
  +calculatePhone()
  +updateAmount()
  +sendAddress()
}
abstract class Warehouse {
  #float updatedAt
  #float note
  +double phone
  -Date amount
  +findDescription()
  +findPrice()
}
class Shipment {
  #String createdAt
  #int id
  -long type
  #float address
  +deleteName()
  +cancelType()
  +cancelDuration()
  +createCreatedat()
}
Shipment --> Route : "*"
Warehouse --|> Vehicle
Shipment --o Vehicle
note right of Route : Logistics domain
@enduml