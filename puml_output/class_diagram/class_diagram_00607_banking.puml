@startuml
skinparam ArrowColor #555555
class Beneficiary {
  #boolean code
  #Date createdAt
  -long description
  #boolean amount
  +updateDuration()
}
interface Customer {
  -String status
  #int amount
  +processCreatedat()
  +sendTotal()
}
interface Branch {
  +double level
  #float active
  +updateNote()
  +validateCode()
  +findName()
  +setCreatedat()
}
interface Teller {
  +float phone
  -double price
  -double quantity
  #long note
  +saveScore()
  +deleteCreatedat()
  +validateTotal()
  +processPrice()
}
class Deposit {
  #double active
  #long name
  #double code
  -int id
  +String updatedAt
  +processAddress()
  +updateName()
  +processPhone()
}
interface Card {
  +double amount
  -float updatedAt
  -long email
  +validatePhone()
  +calculateQuantity()
  +processStatus()
}
Deposit --o Customer
Deposit --o Beneficiary
Beneficiary --> Branch : "1..*"
@enduml