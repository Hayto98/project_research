@startuml
skinparam ArrowColor #555555
class Beneficiary {
  #boolean code
  #Date createdAt
  -long description
  #boolean amount
  +getLevel()
}
class Customer {
  +boolean amount
  +boolean address
  +getDuration()
  +getLevel()
}
interface Branch {
  +boolean total
  #float price
  #long active
  +calculateQuantity()
  +processCreatedat()
  +validateNote()
}
abstract class Teller {
  #int quantity
  +boolean level
  -boolean type
  +String phone
  #String email
  +sendType()
  +cancelQuantity()
}
abstract class Deposit {
  #Date description
  #float createdAt
  #int status
  #int phone
  +Date score
  +deleteType()
  +processEmail()
  +createAddress()
}
class Card {
  -float phone
  +Date updatedAt
  -boolean createdAt
  -boolean price
  +Date code
  +sendEmail()
}
Card ..> Beneficiary : "1"
Card ..|> Deposit
Customer --> Beneficiary : "*"
note right of Beneficiary : Banking domain
@enduml