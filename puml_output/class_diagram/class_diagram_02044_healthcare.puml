@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Insurance {
  +Date duration
  #float level
  +boolean type
  +validateId()
  +createPhone()
}
class Appointment {
  #String total
  +float name
  #Date note
  -long code
  #long createdAt
  +updateLevel()
}
interface LabTest {
  #float phone
  -long name
  -String createdAt
  +Date quantity
  +boolean duration
  +updateEmail()
}
interface Hospital {
  #Date quantity
  -boolean note
  #Date phone
  +findType()
  +calculateType()
  +saveActive()
}
Hospital --o LabTest
Insurance --> Appointment : "0..1"
note right of Insurance : Healthcare domain
@enduml