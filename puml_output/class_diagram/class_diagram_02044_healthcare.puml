@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Insurance {
  +Date duration
  #float level
  +boolean type
  +sendPhone()
  +getUpdatedat()
}
class Appointment {
  +double phone
  #Date status
  #String price
  +Date total
  +deleteId()
}
class LabTest {
  #boolean address
  #double active
  -String duration
  +long code
  #long createdAt
  +deleteCreatedat()
  +setNote()
  +cancelStatus()
}
class Hospital {
  +long score
  #boolean status
  +createQuantity()
  +deleteDuration()
}
Hospital ..> LabTest : "1..*"
Hospital --o Appointment
Appointment ..> Hospital : "*"
@enduml