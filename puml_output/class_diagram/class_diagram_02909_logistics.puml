@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
interface DeliveryNote {
  -Date duration
  -String status
  +deleteQuantity()
  +createTotal()
  +createPhone()
  +saveName()
}
class Tracking {
  #double updatedAt
  +double address
  +setPrice()
  +deleteDescription()
  +sendCreatedat()
}
abstract class Inventory {
  -float description
  +int email
  #double updatedAt
  +boolean price
  +createNote()
  +cancelCreatedat()
  +sendUpdatedat()
  +createDuration()
}
class Route {
  -int updatedAt
  +float name
  -String type
  -String level
  -float duration
  +processDescription()
  +findDescription()
  +getCreatedat()
}
interface Package {
  -float address
  #Date price
  +boolean description
  -long quantity
  +setPrice()
}
interface Shipment {
  -boolean score
  -boolean active
  +validateId()
  +calculatePrice()
  +createDuration()
  +updateCode()
}
class Driver {
  +String quantity
  +long duration
  +Date address
  -float updatedAt
  -boolean description
  +calculateType()
}
DeliveryNote ..> Driver : "1"
Shipment --o Route
Inventory --* DeliveryNote
Package ..> Driver : "1"
Tracking --* Inventory
note right of DeliveryNote : Logistics domain
@enduml