@startuml
skinparam shadowing true
class Branch {
  #String description
  #float amount
  +String type
  -long updatedAt
  +float duration
  +setAddress()
}
class Fine {
  #Date updatedAt
  #long description
  +createCode()
  +updateId()
}
interface Shelf {
  #float description
  #boolean status
  -String type
  -Date address
  +saveCreatedat()
}
abstract class Author {
  -float status
  +boolean description
  +validateActive()
}
class Librarian {
  +double amount
  +float score
  -Date price
  +updateLevel()
  +getAddress()
  +validateActive()
  +saveType()
}
interface Catalog {
  -long id
  #int price
  +long amount
  +validateCreatedat()
  +updateScore()
  +updatePhone()
  +createTotal()
}
interface Publisher {
  #long phone
  #float amount
  +updateActive()
  +saveId()
}
Fine --> Shelf : "*"
Librarian --o Fine
Author --* Catalog
Publisher --* Fine
Author --> Shelf : "1..*"
@enduml