@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Branch {
  +long level
  +String description
  +calculateActive()
  +processDuration()
  +saveStatus()
}
class Renewal {
  #float price
  #String createdAt
  +sendDescription()
  +getDescription()
  +deleteActive()
  +updateActive()
}
class Reservation {
  #int type
  -float id
  +int level
  +validateLevel()
  +createQuantity()
  +createUpdatedat()
}
interface Author {
  -Date email
  -double id
  #Date description
  -double price
  -float score
  +updateLevel()
  +getId()
}
Author --|> Reservation
Branch --> Renewal : "0..1"
Reservation --> Author : "1"
@enduml