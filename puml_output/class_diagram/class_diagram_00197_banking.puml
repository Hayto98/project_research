@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
abstract class Branch {
  #int createdAt
  #String amount
  +float phone
  +cancelEmail()
  +sendType()
}
class Card {
  -int status
  #Date updatedAt
  +validateName()
  +saveAmount()
  +saveCode()
}
class Teller {
  #Date type
  +int quantity
  +createPhone()
  +calculateScore()
  +getName()
}
interface Customer {
  -int active
  +Date name
  +long type
  #long phone
  -int email
  +cancelTotal()
}
interface Loan {
  -boolean duration
  -float quantity
  #boolean note
  #int name
  +validateScore()
  +deleteLevel()
  +setUpdatedat()
  +setDuration()
}
Card --o Teller
Card --* Customer
@enduml