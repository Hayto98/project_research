@startuml
skinparam defaultFontSize 13
interface Patient {
  +String type
  -Date code
  #long quantity
  -float email
  +cancelStatus()
  +sendScore()
}
class Hospital {
  +String level
  +double total
  +validateQuantity()
  +sendStatus()
  +setAddress()
}
class Doctor {
  -int id
  #long createdAt
  #long description
  #Date duration
  +updateLevel()
  +setDescription()
}
interface Billing {
  #Date score
  -float type
  -double quantity
  #boolean name
  +getNote()
}
Hospital --|> Doctor
Billing ..> Patient : "0..1"
@enduml