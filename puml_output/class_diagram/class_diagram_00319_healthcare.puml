@startuml
skinparam defaultFontSize 13
interface Patient {
  +String type
  -Date code
  #long quantity
  -float email
  +setPrice()
  +createId()
}
interface Hospital {
  +float updatedAt
  #int code
  #Date createdAt
  #long price
  #float address
  +updateDescription()
}
interface Doctor {
  #long total
  #long amount
  +createCode()
  +sendAddress()
}
interface Billing {
  #boolean quantity
  +long name
  +Date price
  +Date phone
  +Date total
  +deleteDescription()
  +getCreatedat()
  +calculatePrice()
  +deleteAmount()
}
Hospital ..> Billing : "*"
Billing --> Hospital : "1..*"
Billing --|> Patient
note right of Patient : Healthcare domain
@enduml