@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
interface CheckOut {
  +Date description
  +Date duration
  +validateLevel()
  +getAmount()
  +validateCode()
  +deleteNote()
}
abstract class Amenity {
  +String level
  +double quantity
  -Date type
  +boolean name
  +calculateScore()
  +processTotal()
}
class Housekeeping {
  -Date updatedAt
  +String active
  +float duration
  -int name
  +sendLevel()
  +createQuantity()
}
class Room {
  +double amount
  +float level
  +sendLevel()
  +saveNote()
  +validatePhone()
}
class Payment {
  -long status
  +String code
  #float score
  +float total
  -Date amount
  +calculateCreatedat()
  +updateCode()
  +calculateType()
}
abstract class Staff {
  -float phone
  #long description
  +long quantity
  +getActive()
  +createCreatedat()
  +calculateType()
  +createLevel()
}
class Service {
  #float address
  +int email
  -String duration
  #String score
  +long createdAt
  +findEmail()
  +getPrice()
  +createAmount()
}
Room --> Amenity : "1..*"
CheckOut --o Amenity
Housekeeping ..|> CheckOut
@enduml