@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Withdrawal {
  #String active
  #int total
  #boolean status
  #int note
  +savePrice()
  +setType()
  +deleteType()
  +createTotal()
}
class Card {
  -int amount
  #double active
  -Date updatedAt
  +cancelPhone()
  +processActive()
  +savePhone()
  +updateStatus()
}
abstract class Customer {
  #boolean phone
  +String updatedAt
  +boolean description
  +boolean type
  +calculatePhone()
  +processType()
}
class Beneficiary {
  +long active
  #String description
  -int total
  #long address
  -int phone
  +deleteQuantity()
}
abstract class Teller {
  -String code
  -int price
  -long amount
  -int status
  +setTotal()
  +processDescription()
  +deleteId()
}
class Deposit {
  #Date id
  +String total
  +float name
  +double amount
  +float status
  +updateId()
}
class Branch {
  -int name
  #float level
  -long total
  #boolean code
  -Date address
  +calculateNote()
  +deleteAmount()
  +deleteDuration()
  +deleteAddress()
}
Branch --|> Card
Beneficiary --o Withdrawal
@enduml