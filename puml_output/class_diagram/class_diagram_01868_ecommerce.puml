@startuml
skinparam defaultFontSize 13
interface Payment {
  -double name
  #Date code
  -String amount
  #float quantity
  #long status
  +validateAddress()
  +createActive()
}
abstract class Supplier {
  -float price
  #String code
  -Date name
  -long duration
  #boolean status
  +setId()
  +findUpdatedat()
  +saveNote()
  +calculateEmail()
}
class Warehouse {
  +double id
  #boolean email
  #String type
  +processNote()
  +validateAddress()
  +calculatePhone()
}
class Review {
  #long address
  #boolean note
  +String active
  +long score
  -boolean description
  +createPrice()
}
class Category {
  #long updatedAt
  -float total
  -boolean note
  -long name
  +updateUpdatedat()
  +calculateActive()
  +processStatus()
}
class Cart {
  #Date updatedAt
  -long total
  #long type
  +long note
  -Date active
  +updateType()
  +findDuration()
  +saveUpdatedat()
  +findStatus()
}
class Product {
  #long phone
  -float createdAt
  -Date email
  +setEmail()
}
Product --|> Category
Category --o Cart
Supplier ..|> Cart
Supplier ..> Product : "*"
@enduml