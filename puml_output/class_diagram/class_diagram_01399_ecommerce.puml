@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Coupon {
  +double level
  -long updatedAt
  #float name
  +Date description
  +saveNote()
  +processDescription()
  +cancelAmount()
}
class Wishlist {
  -Date price
  #boolean score
  +saveUpdatedat()
  +setQuantity()
  +saveActive()
  +validateAddress()
}
class Category {
  +boolean price
  +Date note
  +String status
  +boolean score
  -boolean phone
  +createType()
  +processStatus()
  +deleteStatus()
}
class Order {
  #String note
  #int createdAt
  +String email
  +Date status
  -Date phone
  +findActive()
  +setPrice()
  +findType()
  +setAmount()
}
Order --o Category
Category ..|> Coupon
@enduml