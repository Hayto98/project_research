@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class LabTest {
  +int description
  -int active
  -float code
  +boolean price
  +cancelPrice()
  +createDescription()
  +setEmail()
  +createEmail()
}
interface Insurance {
  #boolean note
  #int phone
  +cancelUpdatedat()
  +cancelEmail()
  +createPrice()
  +cancelPhone()
}
abstract class Hospital {
  +Date id
  #int code
  #long score
  +boolean price
  +Date active
  +createEmail()
  +setAmount()
  +findName()
}
class MedicalRecord {
  -double createdAt
  +int total
  +updateUpdatedat()
  +createId()
}
abstract class Treatment {
  +Date quantity
  -Date active
  +float level
  #boolean name
  #boolean id
  +updatePrice()
  +cancelPhone()
}
interface Diagnosis {
  #float duration
  #int active
  -double score
  +getNote()
  +updateActive()
}
abstract class Billing {
  #Date level
  -int id
  #double name
  #long score
  +cancelName()
}
MedicalRecord ..|> Billing
Diagnosis ..|> Treatment
note right of LabTest : Healthcare domain
@enduml