@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class LabTest {
  +int description
  -int active
  -float code
  +boolean price
  +cancelActive()
  +deleteAmount()
  +findScore()
  +validateCode()
}
class Insurance {
  -boolean email
  #boolean duration
  +double status
  #int note
  +validateAmount()
  +cancelLevel()
  +saveCode()
}
interface Hospital {
  +boolean type
  -double active
  +Date duration
  #int id
  +processActive()
  +getQuantity()
  +validatePhone()
}
class MedicalRecord {
  +String email
  +boolean status
  -long amount
  -String name
  +getPrice()
  +validateCreatedat()
}
class Treatment {
  -long quantity
  #boolean id
  #boolean total
  +findType()
}
interface Diagnosis {
  #int updatedAt
  #boolean total
  +updateDescription()
  +saveCode()
}
interface Billing {
  -double active
  +String updatedAt
  -int duration
  #Date createdAt
  +getCreatedat()
  +processStatus()
  +deleteUpdatedat()
  +setName()
}
Billing --> LabTest : "*"
Insurance --o Diagnosis
@enduml