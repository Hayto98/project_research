@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
abstract class Doctor {
  -boolean note
  -String duration
  +deleteType()
  +findType()
  +createAmount()
  +setAddress()
}
abstract class Treatment {
  #int quantity
  +boolean amount
  +String name
  #String status
  +findDescription()
  +findAddress()
}
interface Nurse {
  #String phone
  #Date price
  -double duration
  #int email
  #boolean level
  +setType()
  +findStatus()
}
interface Diagnosis {
  +Date name
  -int active
  -double createdAt
  #float phone
  #double quantity
  +getType()
  +processAmount()
  +processNote()
}
Diagnosis --> Treatment : "1"
Nurse ..|> Diagnosis
@enduml