@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
abstract class Doctor {
  -boolean note
  -String duration
  +findPhone()
  +sendNote()
  +validateQuantity()
  +deleteName()
}
class Treatment {
  +Date description
  +int active
  #int name
  +savePhone()
  +calculatePhone()
  +findEmail()
  +calculateActive()
}
class Nurse {
  +int note
  #float score
  #boolean updatedAt
  #double active
  +saveDuration()
}
interface Diagnosis {
  #long phone
  +double quantity
  -Date status
  +createCode()
  +setUpdatedat()
  +calculateTotal()
  +cancelName()
}
Treatment --* Diagnosis
Doctor ..> Diagnosis : "1..*"
Doctor --> Nurse : "1"
note right of Doctor : Healthcare domain
@enduml