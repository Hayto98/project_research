@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Shipment {
  #Date address
  #boolean id
  +float total
  -boolean name
  +deleteStatus()
  +setAddress()
  +updateNote()
  +cancelTotal()
}
class Package {
  -boolean amount
  +String createdAt
  #double price
  +updatePrice()
}
class FuelLog {
  +int phone
  +Date name
  +validateCode()
}
class Route {
  +String amount
  #float status
  +cancelScore()
}
class Driver {
  #float level
  +double id
  #Date createdAt
  +String phone
  +findEmail()
  +processQuantity()
  +createNote()
}
class Warehouse {
  #String amount
  +long email
  +saveLevel()
  +cancelNote()
  +cancelPrice()
}
Warehouse --|> Driver
Package --|> Warehouse
@enduml