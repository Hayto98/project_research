@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
interface Product {
  #float total
  +double code
  #Date score
  #float name
  +updateEmail()
}
class Coupon {
  -long duration
  #double level
  +updateAmount()
  +createEmail()
  +calculateNote()
  +processDuration()
}
class Order {
  +long description
  +double address
  -String email
  -String code
  +createDuration()
  +deleteQuantity()
}
class Return {
  #boolean score
  #double status
  #long type
  #double updatedAt
  -boolean code
  +validateType()
  +processQuantity()
  +findPhone()
  +getType()
}
abstract class Warehouse {
  #String address
  -long description
  #double level
  +Date quantity
  -int code
  +setStatus()
}
abstract class Supplier {
  -int type
  -long address
  +validateActive()
  +getNote()
  +setPrice()
}
class Review {
  +long email
  +long duration
  -int description
  #boolean updatedAt
  -int quantity
  +calculateUpdatedat()
}
Supplier ..> Coupon : "1"
Order ..> Warehouse : "1"
@enduml