@startuml
skinparam monochrome true
class DeliveryNote {
  #float status
  #int active
  +Date address
  +calculateUpdatedat()
  +findCreatedat()
  +getCode()
  +findActive()
}
class Inventory {
  +Date id
  +long description
  #Date note
  -long quantity
  -double code
  +processPhone()
  +saveAmount()
  +createPhone()
  +calculateUpdatedat()
}
abstract class Depot {
  #long id
  +float createdAt
  +long code
  #boolean duration
  -String name
  +updateAmount()
  +processPrice()
  +calculateCode()
  +saveTotal()
}
class Route {
  -long price
  +double id
  -float phone
  #double amount
  #float updatedAt
  +cancelName()
  +validateDescription()
  +deleteLevel()
}
class Vehicle {
  -long phone
  -double total
  -String status
  +int id
  +saveId()
  +setDescription()
}
Vehicle --> Route : "*"
DeliveryNote ..> Route : "1..*"
Inventory ..> Route : "1..*"
@enduml