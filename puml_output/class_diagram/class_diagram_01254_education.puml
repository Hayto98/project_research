@startuml
skinparam defaultFontSize 11
interface Library {
  +boolean level
  -int score
  #long phone
  +findPhone()
  +validateQuantity()
}
class Grade {
  #double type
  #String total
  +cancelActive()
}
interface Book {
  +boolean type
  +String phone
  +setAddress()
  +validatePhone()
  +processTotal()
}
class Department {
  -Date amount
  #String phone
  #float name
  +String status
  +cancelScore()
  +saveQuantity()
}
Grade --> Library : "1"
Book --> Library : "1..*"
@enduml