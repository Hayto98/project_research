@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Billing {
  +long status
  #long duration
  #int total
  +boolean updatedAt
  #String quantity
  +deleteType()
  +deleteNote()
}
class Insurance {
  -String total
  #float note
  #Date name
  #String phone
  +processEmail()
  +setCreatedat()
  +processId()
  +getCreatedat()
}
abstract class Diagnosis {
  -long duration
  +boolean score
  #Date updatedAt
  +validateLevel()
  +saveName()
  +setScore()
  +setNote()
}
abstract class Appointment {
  +float price
  -double type
  -long name
  #String status
  +cancelTotal()
  +findDuration()
  +createLevel()
  +validateType()
}
class Doctor {
  -double price
  +double id
  +sendNote()
  +setAddress()
  +setStatus()
  +validateName()
}
class Ward {
  +int active
  +String id
  -int quantity
  +String type
  +processNote()
  +processDescription()
  +deleteDescription()
}
Billing --|> Diagnosis
Ward --> Billing : "1"
Ward ..|> Insurance
Appointment --o Doctor
Ward ..|> Appointment
@enduml