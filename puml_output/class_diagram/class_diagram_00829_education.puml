@startuml
skinparam defaultFontSize 11
abstract class Classroom {
  -int level
  -long duration
  #Date phone
  +Date code
  +double type
  +getPhone()
  +processNote()
}
class Assignment {
  +long phone
  +double id
  #Date quantity
  #long updatedAt
  +processActive()
}
class Attendance {
  +String phone
  -String score
  #double name
  -float status
  +cancelPhone()
  +cancelDuration()
  +sendAmount()
}
class Grade {
  #double note
  #long type
  +float code
  -int phone
  +processCode()
}
Classroom --* Assignment
Assignment --o Grade
Grade --> Classroom : "1..*"
@enduml