@startuml
skinparam defaultFontSize 11
abstract class Classroom {
  -int level
  -long duration
  #Date phone
  +Date code
  +double type
  +calculatePhone()
  +createPhone()
}
class Assignment {
  -Date updatedAt
  #Date id
  -String quantity
  +float amount
  +findActive()
  +validatePhone()
}
interface Attendance {
  +long status
  +Date description
  +createPhone()
  +createScore()
  +createPhone()
  +processType()
}
class Grade {
  +Date note
  #boolean email
  #String createdAt
  +boolean price
  +setPhone()
  +validateScore()
  +updatePhone()
  +processTotal()
}
Attendance --o Classroom
Classroom --* Attendance
note right of Classroom : Education domain
@enduml