@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
abstract class Hospital {
  -String amount
  -float updatedAt
  #float quantity
  +double description
  +deleteLevel()
  +calculateType()
  +sendDescription()
  +processActive()
}
class MedicalRecord {
  #float name
  +Date description
  +boolean type
  +createDuration()
}
class Doctor {
  #Date note
  #int email
  +sendCreatedat()
  +findName()
}
class LabTest {
  +Date createdAt
  +long type
  +float note
  +cancelType()
}
class Diagnosis {
  -double price
  #Date email
  -boolean name
  +setDescription()
  +calculateLevel()
}
Diagnosis ..|> LabTest
Hospital ..> Diagnosis : "1"
MedicalRecord ..|> Diagnosis
@enduml