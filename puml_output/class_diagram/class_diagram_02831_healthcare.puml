@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Ward {
  -long description
  #Date level
  #boolean createdAt
  +String status
  +deleteDuration()
}
abstract class Appointment {
  +String address
  #Date status
  #long name
  +calculateUpdatedat()
  +saveId()
}
class Doctor {
  -boolean code
  #String quantity
  -long createdAt
  -double active
  +createStatus()
  +cancelDescription()
  +sendDuration()
}
interface MedicalRecord {
  #Date updatedAt
  +Date id
  #float status
  +long amount
  +double note
  +calculateScore()
}
class LabTest {
  #long price
  #float type
  +String level
  +String score
  +cancelUpdatedat()
  +getDescription()
}
Ward --o Appointment
LabTest ..|> Doctor
MedicalRecord ..|> Doctor
Appointment --|> Doctor
@enduml