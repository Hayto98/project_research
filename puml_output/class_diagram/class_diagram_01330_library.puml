@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Branch {
  +float description
  -int active
  #long note
  -long email
  #Date total
  +deleteLevel()
  +deleteType()
}
class Shelf {
  #long level
  -Date status
  +float createdAt
  +cancelName()
  +deletePhone()
}
abstract class Reservation {
  #Date phone
  +long email
  -boolean description
  +int updatedAt
  +updateAmount()
}
class Member {
  #boolean updatedAt
  +float id
  +double quantity
  +Date active
  +getAddress()
}
Shelf --* Branch
Member --> Reservation : "0..1"
Member --> Shelf : "*"
note right of Branch : Library domain
@enduml