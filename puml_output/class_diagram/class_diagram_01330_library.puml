@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Branch {
  +float description
  -int active
  #long note
  -long email
  #Date total
  +processUpdatedat()
  +getCode()
}
class Shelf {
  -Date name
  +float amount
  +boolean status
  +int createdAt
  -double phone
  +cancelId()
  +sendAddress()
  +setLevel()
}
class Reservation {
  +int phone
  +float duration
  +int active
  +processDescription()
}
class Member {
  #boolean quantity
  +float active
  +sendCode()
}
Branch --* Member
Reservation --|> Branch
@enduml