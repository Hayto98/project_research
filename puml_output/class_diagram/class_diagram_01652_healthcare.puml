@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Insurance {
  -String status
  +float quantity
  +validateAddress()
  +sendCode()
}
class Ward {
  +double quantity
  -boolean id
  -int name
  +double score
  +Date description
  +validateUpdatedat()
  +sendCreatedat()
  +getUpdatedat()
  +getId()
}
class Hospital {
  +Date updatedAt
  -int amount
  #String quantity
  +createScore()
}
abstract class Doctor {
  #String level
  -Date note
  -float address
  +saveCreatedat()
  +setPhone()
  +updatePhone()
  +setType()
}
Ward ..> Hospital : "1..*"
Doctor ..> Insurance : "0..1"
Doctor --> Ward : "1"
note right of Insurance : Healthcare domain
@enduml