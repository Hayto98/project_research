@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Insurance {
  -String status
  +float quantity
  +saveCreatedat()
  +validateScore()
}
interface Ward {
  -String address
  +Date total
  +cancelScore()
}
class Hospital {
  -int note
  +double quantity
  +Date score
  +calculateCreatedat()
  +processPrice()
  +getCreatedat()
  +sendEmail()
}
class Doctor {
  #int name
  +Date id
  +boolean duration
  +setDescription()
  +getActive()
  +getUpdatedat()
}
Ward --|> Hospital
Insurance --> Ward : "*"
@enduml