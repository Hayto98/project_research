@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
interface Doctor {
  -String id
  +Date description
  #double updatedAt
  -long name
  +calculateUpdatedat()
  +cancelAddress()
}
class Appointment {
  -double phone
  #boolean type
  #int note
  +Date score
  +updateStatus()
  +findType()
  +cancelStatus()
  +cancelDuration()
}
abstract class MedicalRecord {
  -String name
  #double price
  #int address
  -float amount
  -long quantity
  +createDuration()
  +setId()
  +saveCode()
  +setPhone()
}
abstract class Treatment {
  -double email
  #Date price
  #String type
  +int code
  +calculateLevel()
  +setUpdatedat()
}
abstract class Billing {
  -boolean description
  #int level
  #Date id
  +calculateCode()
  +sendDescription()
  +createDescription()
}
Treatment ..|> Billing
Doctor --* Treatment
@enduml