@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
interface Doctor {
  -String id
  +Date description
  #double updatedAt
  -long name
  +saveQuantity()
  +findUpdatedat()
}
class Appointment {
  -float type
  #boolean note
  #int level
  +Date score
  +updateCode()
  +savePrice()
  +saveTotal()
  +saveName()
}
abstract class MedicalRecord {
  +boolean amount
  -boolean active
  +long quantity
  -long price
  +calculateDuration()
  +calculateDuration()
  +processEmail()
  +findEmail()
}
abstract class Treatment {
  +boolean code
  +float address
  +double type
  +int duration
  #boolean description
  +calculateLevel()
}
class Billing {
  -int price
  #Date active
  +float total
  #double note
  +calculateNote()
  +findEmail()
  +validateLevel()
}
Doctor --* MedicalRecord
Billing --* MedicalRecord
Treatment --> Appointment : "*"
note right of Doctor : Healthcare domain
@enduml