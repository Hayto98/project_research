@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
interface Beneficiary {
  #long type
  #double status
  +validateName()
  +cancelDescription()
}
class Deposit {
  +float price
  +long quantity
  +cancelCreatedat()
  +validatePhone()
  +cancelPrice()
  +updateDescription()
}
class Transaction {
  -int type
  -float level
  +long duration
  #String phone
  +getActive()
}
class Teller {
  +Date active
  -int status
  +updateTotal()
  +validateUpdatedat()
  +cancelActive()
}
class Interest {
  -boolean active
  -double id
  -double phone
  +float score
  #boolean email
  +cancelNote()
  +setDescription()
  +calculateActive()
  +deleteName()
}
class Branch {
  #boolean name
  +boolean active
  -float total
  +findUpdatedat()
  +createType()
  +updatePhone()
}
Beneficiary ..|> Transaction
Branch --* Transaction
@enduml