@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
interface Beneficiary {
  #long type
  #double status
  +processQuantity()
  +cancelName()
}
abstract class Deposit {
  -String updatedAt
  #int id
  +boolean email
  -Date total
  +saveLevel()
  +processPhone()
  +processUpdatedat()
  +validateCreatedat()
}
class Transaction {
  #String code
  #String createdAt
  +findTotal()
  +updateScore()
}
class Teller {
  #boolean type
  +long level
  -long id
  -boolean duration
  +processAddress()
  +calculateCode()
  +findActive()
  +processCreatedat()
}
class Interest {
  #double quantity
  #boolean amount
  +boolean name
  -float active
  +cancelId()
  +getPhone()
  +updateAddress()
}
class Branch {
  #int type
  -float score
  +Date createdAt
  +cancelCode()
  +updateUpdatedat()
}
Branch --o Beneficiary
Interest ..|> Teller
note right of Beneficiary : Banking domain
@enduml