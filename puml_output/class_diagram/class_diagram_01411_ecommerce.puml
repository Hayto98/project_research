@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Product {
  -boolean duration
  +Date total
  #float status
  #Date address
  +getActive()
  +getId()
  +setDuration()
  +sendAmount()
}
class Customer {
  -float type
  -String status
  #boolean code
  +long createdAt
  +sendAmount()
  +createQuantity()
}
class Shipment {
  +boolean code
  +String status
  -float id
  -double updatedAt
  -int note
  +createQuantity()
  +sendQuantity()
}
abstract class Category {
  #double address
  +double email
  -double type
  +cancelLevel()
}
interface Order {
  +int level
  +int updatedAt
  +String amount
  -double phone
  +sendName()
  +setAmount()
  +setQuantity()
  +findActive()
}
Category --* Order
Product ..> Order : "0..1"
Customer ..|> Order
Order --o Shipment
@enduml