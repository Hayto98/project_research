@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Product {
  -boolean duration
  +Date total
  #float status
  #Date address
  +findType()
  +sendCode()
  +validateType()
  +setCode()
}
class Customer {
  -Date type
  +boolean name
  -String active
  -String id
  +getUpdatedat()
}
abstract class Shipment {
  +double level
  -double updatedAt
  +deleteDuration()
  +deleteQuantity()
  +sendTotal()
  +deleteAddress()
}
class Category {
  -float score
  #boolean price
  #String status
  #long level
  #Date total
  +deletePhone()
  +deleteUpdatedat()
}
class Order {
  -double createdAt
  -float status
  -Date email
  +findDuration()
  +processPhone()
  +getCode()
  +findUpdatedat()
}
Customer ..> Order : "1..*"
Category --* Shipment
note right of Product : Ecommerce domain
@enduml