@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Product {
  -String quantity
  +String email
  -double description
  +Date note
  -String type
  +setTotal()
}
class Return {
  #double code
  #boolean total
  #boolean address
  +long status
  +calculateCode()
}
class Review {
  +long amount
  #float status
  +processUpdatedat()
}
class Category {
  -boolean phone
  -float id
  -double description
  -String address
  +boolean amount
  +getStatus()
  +validateUpdatedat()
  +calculateName()
  +cancelStatus()
}
class Payment {
  #String address
  -String createdAt
  +createId()
  +sendType()
  +sendAddress()
  +getQuantity()
}
abstract class Shipment {
  -Date phone
  +float note
  #int code
  #long level
  +deleteName()
}
class Wishlist {
  -int total
  #boolean type
  +validateAddress()
  +validateEmail()
}
Review --* Return
Product --o Payment
Wishlist --> Review : "1"
Review --|> Category
Return --> Shipment : "*"
Wishlist --|> Return
@enduml