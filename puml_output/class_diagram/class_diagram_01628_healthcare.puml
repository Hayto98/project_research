@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
interface Patient {
  +float email
  #boolean level
  +findDescription()
  +updateAddress()
  +sendDescription()
  +getStatus()
}
class Doctor {
  -float phone
  #int status
  #int score
  +saveStatus()
  +updatePrice()
}
class Ward {
  +Date phone
  #double createdAt
  -long total
  +cancelNote()
  +findAmount()
}
class LabTest {
  +float status
  -float type
  #String code
  +cancelEmail()
}
Ward ..|> LabTest
Patient --o Doctor
@enduml