@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Withdrawal {
  +long quantity
  +boolean address
  +boolean score
  +processDuration()
  +processStatus()
}
class Account {
  #boolean price
  +long code
  +int description
  -long name
  +long address
  +deleteNote()
  +getId()
  +validateUpdatedat()
}
class Interest {
  -boolean description
  #String amount
  -boolean address
  +createLevel()
}
abstract class Customer {
  +float duration
  -float quantity
  +Date status
  -double amount
  -int email
  +processCreatedat()
  +calculateLevel()
  +getAddress()
}
class Card {
  #Date quantity
  #float code
  #double name
  -boolean duration
  +cancelName()
}
interface Loan {
  #float address
  -Date level
  #String price
  #int name
  #long quantity
  +findUpdatedat()
  +setEmail()
}
Customer --o Loan
Loan --|> Withdrawal
@enduml