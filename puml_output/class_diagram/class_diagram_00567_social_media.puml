@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
abstract class Post {
  #boolean status
  +boolean description
  +sendDescription()
  +sendType()
}
class User {
  +int active
  #boolean quantity
  +createPhone()
  +processNote()
  +processTotal()
}
abstract class Follower {
  +double address
  +int id
  +deleteCreatedat()
}
interface Story {
  #int score
  +long code
  -long note
  -long quantity
  +cancelLevel()
  +deleteActive()
  +calculateTotal()
  +cancelPrice()
}
interface Report {
  -String level
  #float note
  +boolean type
  +saveName()
  +findAmount()
  +updatePhone()
  +findEmail()
}
class Group {
  -float updatedAt
  #boolean createdAt
  +int id
  +getActive()
}
Story --|> User
Report ..> Post : "*"
User ..|> Report
Story --* Post
note right of Post : Social Media domain
@enduml