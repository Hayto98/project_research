@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
abstract class Post {
  #boolean status
  +boolean description
  +saveActive()
  +validateCreatedat()
}
interface User {
  +boolean code
  #Date status
  -long active
  -double quantity
  -double name
  +createPrice()
  +cancelDescription()
  +processAmount()
  +saveCreatedat()
}
class Follower {
  +int price
  +boolean updatedAt
  -Date amount
  +cancelQuantity()
}
class Story {
  -long id
  -float address
  -boolean email
  +sendQuantity()
  +findAmount()
}
abstract class Report {
  +boolean duration
  +boolean createdAt
  #boolean note
  -Date type
  #String price
  +updateStatus()
  +deleteStatus()
}
class Group {
  #boolean description
  +long duration
  #boolean updatedAt
  +int createdAt
  +updateActive()
}
Story --|> User
Report ..> Post : "*"
User ..|> Report
Story --* Post
@enduml