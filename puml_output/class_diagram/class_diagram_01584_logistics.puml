@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Manifest {
  #double status
  +long createdAt
  #Date active
  +createPrice()
  +deleteUpdatedat()
  +validateDescription()
}
class Driver {
  -String email
  -String quantity
  +Date total
  +Date updatedAt
  +saveDuration()
}
abstract class Inventory {
  #String updatedAt
  #long amount
  +String name
  +findUpdatedat()
  +sendName()
}
class Shipment {
  +int amount
  -Date type
  -boolean address
  #int total
  -Date name
  +updateTotal()
  +findAmount()
  +deleteDuration()
  +calculatePhone()
}
Inventory ..> Manifest : "1"
Shipment ..|> Manifest
@enduml