@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Manifest {
  #double status
  +long createdAt
  #Date active
  +calculateLevel()
  +createQuantity()
  +createDuration()
}
class Driver {
  +int duration
  #String updatedAt
  #float note
  #float id
  +boolean price
  +saveDescription()
  +updateAmount()
  +cancelName()
  +findId()
}
interface Inventory {
  #float updatedAt
  -float name
  -int amount
  -long type
  +cancelName()
  +getUpdatedat()
  +createType()
  +sendLevel()
}
class Shipment {
  -String type
  -String phone
  #float total
  +double note
  +updateActive()
}
Shipment --o Driver
Driver ..> Inventory : "1"
Driver --o Manifest
note right of Manifest : Logistics domain
@enduml