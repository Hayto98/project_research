@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Like {
  -Date level
  -float phone
  +float description
  +sendScore()
  +processUpdatedat()
  +createType()
  +calculatePhone()
}
class Comment {
  +String total
  +boolean createdAt
  +findActive()
  +calculatePrice()
  +findQuantity()
  +updatePhone()
}
interface Follower {
  -String status
  +Date note
  +boolean quantity
  +sendTotal()
}
class Story {
  #double id
  +int note
  +calculateId()
  +findUpdatedat()
  +setCreatedat()
  +validateAmount()
}
Story --* Follower
Follower --|> Story
note right of Like : Social Media domain
@enduml