@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Like {
  -Date level
  -float phone
  +float description
  +calculatePrice()
  +sendAmount()
  +setQuantity()
  +setPrice()
}
abstract class Comment {
  -int quantity
  #String type
  -int total
  +deletePhone()
}
class Follower {
  -float score
  -Date type
  -int active
  +cancelActive()
  +saveAddress()
  +setStatus()
}
abstract class Story {
  #String type
  #double name
  #float amount
  +String status
  +processTotal()
}
Comment --o Like
Story ..> Like : "0..1"
Like --* Story
@enduml