@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
abstract class Order {
  +int updatedAt
  #int status
  +createScore()
  +calculateAddress()
}
class Coupon {
  +double note
  #float level
  +processId()
  +saveDuration()
  +saveLevel()
  +validateCreatedat()
}
class Shipment {
  #int email
  #Date phone
  +boolean level
  -float address
  #float type
  +sendPhone()
}
class Wishlist {
  #double quantity
  -int duration
  +double total
  #double email
  +processId()
  +createAmount()
  +calculateEmail()
}
abstract class Invoice {
  -boolean code
  #long level
  -float name
  #double total
  -double duration
  +getScore()
  +processAddress()
}
class Category {
  +int level
  +String description
  -Date total
  +boolean active
  +long code
  +createDescription()
  +findAmount()
  +processCreatedat()
  +validateStatus()
}
Coupon --* Order
Invoice --* Wishlist
@enduml