@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Payment {
  #long phone
  #Date active
  -long level
  -String type
  +processCreatedat()
  +cancelTotal()
  +sendPhone()
  +findLevel()
}
class Booking {
  +double phone
  +boolean amount
  -double description
  #boolean id
  +findActive()
  +deleteAddress()
  +processLevel()
  +validateAmount()
}
class Invoice {
  +String description
  #double score
  +double amount
  +double createdAt
  +validateQuantity()
  +deleteLevel()
  +setCreatedat()
  +sendPhone()
}
class Reservation {
  -long quantity
  #Date description
  +processNote()
  +calculateUpdatedat()
}
class CheckOut {
  #double name
  #double description
  +savePhone()
  +createAmount()
  +sendCreatedat()
}
Payment ..|> Booking
Payment --* Invoice
@enduml