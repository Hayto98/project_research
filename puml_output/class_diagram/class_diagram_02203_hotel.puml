@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Payment {
  #long phone
  #Date active
  -long level
  -String type
  +getPhone()
  +validateQuantity()
  +validateAmount()
  +findDescription()
}
class Booking {
  -double type
  #boolean amount
  -double active
  +calculateEmail()
  +createPhone()
}
class Invoice {
  +boolean duration
  -String createdAt
  -float updatedAt
  +calculateNote()
  +deletePhone()
}
class Reservation {
  -long quantity
  #Date description
  +saveCode()
  +getName()
}
class CheckOut {
  +String price
  +int quantity
  #String name
  -long phone
  #Date type
  +cancelQuantity()
}
CheckOut --|> Payment
Invoice --* CheckOut
note right of Payment : Hotel domain
@enduml