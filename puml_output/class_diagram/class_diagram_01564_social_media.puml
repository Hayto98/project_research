@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
abstract class Story {
  #boolean note
  -long price
  +boolean updatedAt
  #float duration
  #boolean score
  +validateType()
}
abstract class Comment {
  #String createdAt
  #double type
  -boolean total
  +int name
  +saveActive()
  +cancelAddress()
}
abstract class Profile {
  +String score
  -int phone
  +processLevel()
  +cancelActive()
  +getUpdatedat()
}
abstract class User {
  -double description
  -long price
  -double createdAt
  -double score
  +cancelType()
}
interface Post {
  -Date id
  +String name
  #int active
  #long description
  -float phone
  +saveId()
  +setQuantity()
  +sendDuration()
}
class Message {
  -int level
  +float phone
  -boolean total
  #String description
  -float status
  +calculateQuantity()
  +processStatus()
  +processAddress()
}
Profile ..> User : "1..*"
User --o Profile
@enduml