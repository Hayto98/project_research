@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
abstract class Story {
  #boolean note
  -long price
  +boolean updatedAt
  #float duration
  #boolean score
  +calculateQuantity()
}
class Comment {
  #String total
  +int name
  #long level
  #double duration
  +boolean email
  +updateCode()
  +processDescription()
  +createTotal()
}
interface Profile {
  -double phone
  -long description
  -double price
  -double createdAt
  +float active
  +getName()
  +findDuration()
  +sendDescription()
  +validatePhone()
}
class User {
  -double description
  -String active
  +calculateLevel()
}
class Post {
  -boolean description
  #String status
  -float quantity
  #float createdAt
  #long active
  +validateDuration()
  +setAddress()
  +calculateEmail()
  +processPhone()
}
abstract class Message {
  #int updatedAt
  +float note
  +updateType()
  +setId()
  +saveTotal()
  +setNote()
}
User --|> Post
Profile ..|> Comment
User --* Comment
Profile ..|> User
note right of Story : Social Media domain
@enduml