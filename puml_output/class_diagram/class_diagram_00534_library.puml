@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Author {
  #Date score
  #float type
  #String amount
  #float level
  #double email
  +getPrice()
  +processCode()
}
class Branch {
  #Date description
  -double email
  +calculatePrice()
  +cancelActive()
  +processPhone()
}
class Librarian {
  +long type
  +float note
  -Date phone
  +Date name
  -boolean email
  +sendPrice()
  +sendCode()
  +setStatus()
}
interface Book {
  #float updatedAt
  +boolean id
  +getDuration()
  +getAmount()
  +createCode()
}
class Loan {
  #long quantity
  +long note
  +cancelPrice()
  +saveCreatedat()
  +cancelCode()
}
Author --|> Librarian
Loan ..|> Author
Book ..|> Branch
Branch --o Author
note right of Author : Library domain
@enduml