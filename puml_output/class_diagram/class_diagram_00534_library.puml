@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Author {
  #Date score
  #float type
  #String amount
  #float level
  #double email
  +savePhone()
  +sendScore()
}
abstract class Branch {
  +Date createdAt
  #long id
  +cancelQuantity()
  +calculateStatus()
  +updateTotal()
}
abstract class Librarian {
  #double duration
  -double active
  #float type
  -float phone
  +long level
  +processDescription()
}
class Book {
  #Date createdAt
  +String address
  +boolean email
  +Date active
  +String price
  +updateNote()
  +setEmail()
}
class Loan {
  +float amount
  +String quantity
  +calculateAmount()
  +calculateStatus()
  +updateTotal()
}
Librarian --> Loan : "*"
Branch ..> Author : "1"
@enduml