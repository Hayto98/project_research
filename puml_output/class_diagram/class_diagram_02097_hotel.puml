@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Amenity {
  -Date id
  #int level
  #float score
  -String type
  +createStatus()
}
class CheckIn {
  +boolean level
  #int phone
  -double type
  -Date score
  #float note
  +findNote()
  +validateAddress()
  +calculateName()
}
interface Booking {
  +String description
  #String duration
  #double price
  #int amount
  -boolean active
  +createUpdatedat()
  +processQuantity()
}
class Room {
  #Date id
  -Date type
  +cancelScore()
  +deleteId()
  +deletePhone()
  +calculateCreatedat()
}
Room --> Amenity : "1"
CheckIn ..|> Amenity
@enduml