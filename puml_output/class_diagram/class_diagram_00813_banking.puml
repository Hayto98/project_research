@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Customer {
  +String amount
  +String id
  -boolean score
  #Date active
  +cancelStatus()
  +cancelDuration()
  +saveAddress()
  +cancelDuration()
}
class Card {
  -Date status
  -boolean price
  #int description
  +findUpdatedat()
  +createType()
}
class Deposit {
  +boolean note
  +int total
  +double id
  +long createdAt
  +getDuration()
  +createType()
  +cancelDuration()
  +updateAmount()
}
class Account {
  +int level
  #boolean email
  +calculateStatus()
  +updateCreatedat()
  +getName()
  +getUpdatedat()
}
abstract class Transaction {
  #int description
  #boolean id
  #String score
  +String updatedAt
  +validateUpdatedat()
  +deletePhone()
}
Deposit --|> Transaction
Deposit ..> Customer : "0..1"
Deposit --|> Account
note right of Customer : Banking domain
@enduml