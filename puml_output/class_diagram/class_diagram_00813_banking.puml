@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Customer {
  +String amount
  +String id
  -boolean score
  #Date active
  +findDescription()
  +cancelEmail()
  +getCode()
  +getQuantity()
}
class Card {
  -boolean amount
  #int status
  +deleteStatus()
  +deleteCreatedat()
  +processCreatedat()
}
interface Deposit {
  -long updatedAt
  -double duration
  -String quantity
  +saveQuantity()
  +findDuration()
}
class Account {
  -double description
  +boolean total
  -Date updatedAt
  +processEmail()
  +sendUpdatedat()
  +findUpdatedat()
  +updateStatus()
}
class Transaction {
  -String id
  +boolean level
  +processType()
  +createPhone()
  +findAddress()
  +cancelNote()
}
Customer ..|> Transaction
Account ..|> Deposit
@enduml