@startuml
skinparam shadowing true
abstract class Category {
  -String active
  #float id
  #double amount
  #int status
  +getCode()
}
class Wishlist {
  +int phone
  +Date name
  +boolean note
  -long updatedAt
  +processId()
  +setCode()
  +cancelUpdatedat()
}
class Payment {
  -Date score
  -boolean note
  #float address
  -Date quantity
  +calculateDuration()
  +createAmount()
  +findTotal()
  +deleteScore()
}
interface Coupon {
  #boolean total
  +float status
  #long type
  #Date address
  +sendPrice()
  +createScore()
  +getDescription()
  +createQuantity()
}
interface Return {
  +int type
  #long score
  +processUpdatedat()
  +cancelCreatedat()
  +calculateNote()
  +saveCode()
}
class Cart {
  -float createdAt
  +boolean code
  -int note
  -boolean name
  -boolean updatedAt
  +saveDescription()
  +createQuantity()
  +calculateDescription()
  +cancelDescription()
}
Return ..> Cart : "1..*"
Cart --|> Coupon
Wishlist ..> Category : "1..*"
Wishlist --* Cart
Cart --|> Return
@enduml