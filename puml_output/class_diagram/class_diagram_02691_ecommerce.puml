@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
interface Supplier {
  -double total
  +double price
  +float amount
  +processTotal()
  +findId()
  +updateType()
  +calculateCode()
}
class Cart {
  +Date level
  +String phone
  +long id
  #long note
  +sendDuration()
}
class Shipment {
  +boolean duration
  #String id
  +getName()
  +calculateEmail()
}
class Payment {
  -Date name
  #Date total
  +double address
  +boolean quantity
  -Date createdAt
  +createLevel()
  +createUpdatedat()
}
class Product {
  #long type
  +float duration
  +findPhone()
  +cancelTotal()
  +calculateTotal()
}
class Category {
  +long quantity
  -String note
  #long price
  +calculateCreatedat()
  +calculatePhone()
  +processEmail()
  +findDuration()
}
class Coupon {
  -int type
  +double duration
  +createCreatedat()
  +deleteDescription()
  +getCreatedat()
}
Payment ..> Product : "0..1"
Product ..> Coupon : "1..*"
Coupon ..> Cart : "0..1"
Shipment --> Category : "0..1"
@enduml