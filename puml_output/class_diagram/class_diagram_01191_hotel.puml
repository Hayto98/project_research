@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Guest {
  -int score
  -String description
  +long level
  -String duration
  +deleteDescription()
  +processPhone()
  +validateEmail()
  +setAmount()
}
class Reservation {
  -boolean phone
  #double score
  +String price
  #double name
  +float type
  +updateType()
  +sendName()
}
class Housekeeping {
  +long note
  -int active
  #boolean price
  +deleteDescription()
  +saveId()
}
abstract class CheckOut {
  -String active
  +double type
  -int updatedAt
  #float quantity
  +setCreatedat()
  +createLevel()
  +sendTotal()
  +getUpdatedat()
}
class Booking {
  -boolean level
  +Date updatedAt
  #boolean name
  +double price
  +int id
  +calculateQuantity()
  +calculatePrice()
  +findNote()
}
class Amenity {
  +double score
  +Date amount
  #double code
  #float price
  +processQuantity()
  +getNote()
  +calculateNote()
  +validateCreatedat()
}
Housekeeping --|> Booking
Booking --|> CheckOut
Reservation --* Amenity
note right of Guest : Hotel domain
@enduml