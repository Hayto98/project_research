@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Guest {
  -int score
  -String description
  +long level
  -String duration
  +deleteScore()
  +validateCreatedat()
  +processTotal()
  +processStatus()
}
class Reservation {
  #long status
  #double amount
  +double id
  -boolean type
  +validateType()
  +calculateNote()
  +updateActive()
  +createType()
}
abstract class Housekeeping {
  -boolean amount
  +float createdAt
  +sendId()
  +cancelQuantity()
  +cancelDuration()
}
interface CheckOut {
  +int amount
  #String quantity
  -boolean address
  -boolean createdAt
  -int active
  +saveLevel()
  +processTotal()
  +setStatus()
}
class Booking {
  -boolean type
  #double createdAt
  +int duration
  -double code
  #int level
  +sendScore()
}
interface Amenity {
  +Date email
  #boolean score
  +saveAmount()
}
Reservation --* Booking
CheckOut --o Housekeeping
CheckOut ..> Amenity : "1..*"
@enduml