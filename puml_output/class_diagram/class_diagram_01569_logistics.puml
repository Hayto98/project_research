@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Inventory {
  #boolean score
  #String quantity
  #String status
  #long amount
  +updateName()
}
class DeliveryNote {
  +float id
  -float score
  #int phone
  +sendName()
  +cancelAddress()
  +calculateNote()
  +sendEmail()
}
class Shipment {
  +String quantity
  -double score
  #boolean updatedAt
  -boolean type
  +sendNote()
  +saveStatus()
  +deleteUpdatedat()
}
class Customer {
  +int duration
  +float price
  +long phone
  #boolean quantity
  -long updatedAt
  +updateNote()
  +cancelCode()
}
Customer ..> DeliveryNote : "0..1"
Inventory --> DeliveryNote : "*"
note right of Inventory : Logistics domain
@enduml