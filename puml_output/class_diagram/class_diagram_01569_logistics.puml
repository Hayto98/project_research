@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Inventory {
  #boolean score
  #String quantity
  #String status
  #long amount
  +createScore()
}
class DeliveryNote {
  #long level
  +float amount
  -float id
  +setAddress()
  +getDuration()
}
abstract class Shipment {
  -Date level
  -float address
  +createAmount()
  +findQuantity()
  +createNote()
}
class Customer {
  -double type
  #boolean code
  -boolean level
  +calculatePrice()
  +validatePrice()
  +saveAmount()
}
DeliveryNote ..|> Inventory
Customer ..> Shipment : "*"
@enduml