@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Profile {
  -double note
  #Date price
  #float status
  +Date code
  +double description
  +calculateAmount()
  +getCode()
  +saveUpdatedat()
}
class Group {
  +boolean total
  #int amount
  -Date id
  -double note
  +double code
  +updateDescription()
  +setQuantity()
  +validateCreatedat()
}
class Hashtag {
  +float active
  #String total
  +sendName()
  +calculateUpdatedat()
}
abstract class User {
  #String duration
  -int quantity
  +int note
  #float phone
  #Date id
  +getCreatedat()
  +calculateActive()
  +validateCreatedat()
}
Hashtag ..> Profile : "1..*"
