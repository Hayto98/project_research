@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Profile {
  -double note
  #Date price
  #float status
  +Date code
  +double description
  +setNote()
  +deleteScore()
  +deleteNote()
}
class Group {
  -int phone
  +double level
  +String total
  +createName()
  +getAmount()
}
abstract class Hashtag {
  +float id
  +long note
  -int active
  -String address
  #double updatedAt
  +validateDescription()
}
interface User {
  +double createdAt
  #int active
  +sendDescription()
  +deleteDuration()
  +setPhone()
  +calculatePhone()
}
Hashtag --> Profile : "1"
Group ..> Profile : "1..*"
@enduml