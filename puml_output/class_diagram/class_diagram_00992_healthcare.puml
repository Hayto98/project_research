@startuml
skinparam defaultFontSize 11
class Ward {
  #String quantity
  #float level
  +setStatus()
  +createActive()
  +calculateScore()
}
abstract class Billing {
  -double amount
  +boolean quantity
  +setAddress()
}
interface Treatment {
  #Date name
  -long email
  -String createdAt
  +sendUpdatedat()
  +deleteTotal()
  +cancelUpdatedat()
}
interface Diagnosis {
  -double address
  +double createdAt
  +int quantity
  +double email
  -long level
  +validateUpdatedat()
}
interface Nurse {
  +String amount
  #float price
  +long active
  +setScore()
  +deleteDescription()
  +findTotal()
  +findNote()
}
class Prescription {
  -double createdAt
  #Date price
  +long id
  +deleteTotal()
}
class LabTest {
  #boolean total
  #boolean address
  +Date type
  +setUpdatedat()
  +cancelAddress()
}
LabTest --* Nurse
Treatment ..> Ward : "1..*"
note right of Ward : Healthcare domain
@enduml