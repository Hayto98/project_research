@startuml
skinparam defaultFontSize 11
class Ward {
  #String quantity
  #float level
  +sendType()
  +updateName()
  +updateCreatedat()
}
class Billing {
  +int active
  -long total
  -String score
  #float level
  +updateName()
}
class Treatment {
  #Date name
  -long email
  -String createdAt
  +cancelAmount()
  +findAddress()
  +validateCode()
}
abstract class Diagnosis {
  -float active
  #int duration
  #long type
  +setCreatedat()
  +saveTotal()
  +createEmail()
}
interface Nurse {
  -int address
  +String note
  -float createdAt
  +createQuantity()
  +cancelDescription()
  +deleteTotal()
  +setName()
}
class Prescription {
  +double duration
  #boolean score
  #String createdAt
  +getCode()
}
class LabTest {
  +float total
  #double code
  #double score
  -int description
  +createDuration()
  +updateActive()
}
Diagnosis ..> Nurse : "0..1"
Treatment --|> Nurse
Billing --|> Diagnosis
Nurse --o Billing
Treatment --o Prescription
@enduml