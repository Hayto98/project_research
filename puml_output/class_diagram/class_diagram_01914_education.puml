@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Assignment {
  +double createdAt
  #boolean id
  #long updatedAt
  -Date price
  +processPrice()
  +setTotal()
  +setActive()
}
abstract class Enrollment {
  +float phone
  -String price
  +Date updatedAt
  #float description
  +sendCode()
  +findType()
}
interface Schedule {
  #long status
  -String address
  +calculateAddress()
  +validateName()
}
class Classroom {
  #boolean description
  -Date score
  +calculateActive()
  +deleteName()
  +getDuration()
  +getActive()
}
Schedule --|> Classroom
Classroom --* Schedule
@enduml