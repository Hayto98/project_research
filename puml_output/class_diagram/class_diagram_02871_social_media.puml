@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Message {
  #float price
  -boolean id
  #boolean address
  #String email
  -String updatedAt
  +deleteActive()
  +sendPrice()
  +validateScore()
}
class Notification {
  #boolean amount
  #Date active
  #boolean createdAt
  +long email
  #String status
  +sendPhone()
  +processEmail()
  +validateEmail()
}
class Group {
  +boolean score
  +double phone
  #boolean duration
  +int description
  +updateQuantity()
  +sendUpdatedat()
}
class Hashtag {
  #Date status
  +int duration
  +boolean code
  +long createdAt
  +boolean active
  +deleteAmount()
  +deleteAmount()
  +setLevel()
  +getCode()
}
interface Album {
  -int note
  #boolean email
  -long address
  #boolean type
  +createDuration()
  +setDescription()
  +createCode()
}
abstract class Follower {
  +long quantity
  +int price
  #double note
  +sendAmount()
}
interface User {
  #long phone
  #Date score
  +saveActive()
}
Message ..|> User
Message --> Notification : "1..*"
Hashtag ..|> Notification
Message ..|> Follower
note right of Message : Social Media domain
@enduml