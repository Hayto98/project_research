@startuml

class Teacher {
  -double phone
  #Date status
  #double code
  +sendScore()
  +validateUpdatedat()
  +findNote()
}
interface Department {
  #String phone
  -float duration
  #double price
  -String updatedAt
  +boolean code
  +processCreatedat()
  +processQuantity()
  +saveLevel()
  +deleteType()
}
class Exam {
  +Date address
  +long status
  #Date quantity
  +Date phone
  -String total
  +getId()
}
class Assignment {
  -boolean amount
  -String code
  +saveAmount()
}
class Student {
  +float quantity
  #String total
  -int duration
  +cancelDuration()
}
Assignment ..|> Department
Exam --* Teacher
note right of Teacher : Education domain
@enduml