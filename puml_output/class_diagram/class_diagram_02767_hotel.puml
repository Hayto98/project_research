@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Booking {
  +float address
  #double duration
  -boolean type
  +sendId()
}
class Service {
  #String email
  -long name
  -float phone
  #int duration
  +processId()
  +sendNote()
}
class Housekeeping {
  +long amount
  +double type
  +findEmail()
  +processScore()
  +processCode()
  +calculateAddress()
}
interface CheckIn {
  #boolean level
  -double score
  #float quantity
  #double code
  -long email
  +setName()
  +processActive()
  +updateQuantity()
}
Booking --* Service
Housekeeping --|> Service
note right of Booking : Hotel domain
@enduml