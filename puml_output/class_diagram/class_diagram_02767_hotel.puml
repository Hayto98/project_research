@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Booking {
  +float address
  #double duration
  -boolean type
  +findDuration()
}
class Service {
  -Date duration
  +long address
  +getDescription()
  +sendActive()
  +setUpdatedat()
}
abstract class Housekeeping {
  +boolean address
  #float updatedAt
  -long level
  #String note
  +sendCreatedat()
  +setDescription()
}
class CheckIn {
  -boolean type
  -String duration
  -float email
  +setPrice()
  +deleteUpdatedat()
  +validateName()
}
Booking --* Housekeeping
CheckIn --> Service : "*"
@enduml