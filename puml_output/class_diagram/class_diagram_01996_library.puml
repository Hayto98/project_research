@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
abstract class Book {
  -Date updatedAt
  #int note
  +double name
  +saveUpdatedat()
  +setType()
  +setCode()
}
class Catalog {
  #float phone
  -long email
  +double level
  +processDuration()
  +findTotal()
}
class Shelf {
  +String createdAt
  #float name
  +calculateEmail()
  +sendStatus()
  +updateDescription()
  +calculateDuration()
}
abstract class Branch {
  #float description
  +float level
  #Date name
  +validateNote()
}
class Author {
  +int address
  #Date duration
  #float updatedAt
  #int quantity
  +int note
  +deleteCode()
  +saveStatus()
}
Branch --> Shelf : "*"
Branch ..> Author : "1..*"
Shelf ..> Author : "1"
Branch --> Catalog : "0..1"
@enduml