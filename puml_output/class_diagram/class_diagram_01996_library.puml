@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
abstract class Book {
  -Date updatedAt
  #int note
  +double name
  +saveDescription()
  +findPhone()
  +deletePhone()
}
class Catalog {
  -float duration
  +int address
  #long email
  #String updatedAt
  +saveName()
  +setStatus()
}
interface Shelf {
  #Date name
  +Date createdAt
  #String score
  #float type
  +float description
  +updateCreatedat()
}
abstract class Branch {
  +int address
  #Date updatedAt
  #float quantity
  #int note
  +deleteDuration()
}
class Author {
  #double duration
  #double type
  #long address
  -long note
  +processDescription()
}
Catalog ..> Shelf : "0..1"
Book ..> Branch : "0..1"
Shelf --> Catalog : "*"
Author --* Shelf
note right of Book : Library domain
@enduml