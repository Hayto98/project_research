@startuml
skinparam shadowing true
class Member {
  -long active
  +String email
  +boolean description
  -int duration
  +getCode()
  +findScore()
}
interface Branch {
  -double type
  +double quantity
  +updateType()
}
abstract class Publisher {
  #Date createdAt
  #long active
  +validateDescription()
}
abstract class Reservation {
  #int description
  -double address
  -Date updatedAt
  -int phone
  +boolean duration
  +sendTotal()
  +createPrice()
  +createEmail()
  +saveId()
}
Publisher ..|> Reservation
note right of Member : Library domain
@enduml