@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Exam {
  #float updatedAt
  +float active
  +double duration
  +int status
  #Date type
  +updateUpdatedat()
  +getAddress()
  +validateQuantity()
}
class Library {
  #int description
  #float status
  #double updatedAt
  #double quantity
  -long score
  +findType()
  +getPrice()
  +calculatePhone()
  +validateUpdatedat()
}
class Attendance {
  -boolean id
  +boolean type
  +calculateEmail()
  +getAddress()
  +calculatePhone()
  +findUpdatedat()
}
class Assignment {
  +Date createdAt
  -long status
  +long phone
  +getAmount()
  +savePrice()
  +validateQuantity()
}
interface Student {
  +float amount
  +Date email
  #String score
  -boolean quantity
  +int active
  +getEmail()
  +deleteActive()
  +sendActive()
}
Library --o Exam
Student --|> Library
Assignment --* Library
Attendance ..|> Library
@enduml