@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Exam {
  #float updatedAt
  +float active
  +double duration
  +int status
  #Date type
  +setTotal()
  +deleteQuantity()
  +processDescription()
}
class Library {
  #int quantity
  #float score
  #double updatedAt
  +createAddress()
  +calculateQuantity()
  +processAmount()
  +setId()
}
abstract class Attendance {
  +double active
  -boolean name
  +int duration
  +String note
  +getPhone()
  +createCreatedat()
  +validateActive()
}
class Assignment {
  #long score
  #long total
  #long amount
  +deleteCode()
}
abstract class Student {
  -int description
  -boolean score
  +getTotal()
  +saveActive()
}
Exam ..|> Assignment
Attendance ..|> Student
note right of Exam : Education domain
@enduml