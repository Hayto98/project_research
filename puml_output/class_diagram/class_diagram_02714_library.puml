@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Publisher {
  -float updatedAt
  -Date amount
  #Date type
  +double duration
  +deleteUpdatedat()
  +validatePrice()
}
interface Reservation {
  #long score
  +int status
  -double email
  +boolean quantity
  +deleteQuantity()
  +findAmount()
  +cancelPhone()
  +sendName()
}
class Catalog {
  +double updatedAt
  -String phone
  +sendLevel()
  +createTotal()
  +setScore()
  +saveCreatedat()
}
interface Fine {
  -Date type
  +long duration
  +updateNote()
}
abstract class Book {
  -String createdAt
  +String email
  +long active
  #String quantity
  +setActive()
  +validateQuantity()
  +deleteQuantity()
}
Book --|> Catalog
Fine --|> Catalog
Publisher ..> Reservation : "1"
Reservation --* Catalog
@enduml