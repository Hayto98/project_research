@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Customer {
  +boolean updatedAt
  -double amount
  +double score
  +boolean active
  +sendCreatedat()
  +saveLevel()
}
class Manifest {
  -String price
  -int email
  +saveAddress()
}
interface Shipment {
  -float phone
  #float total
  #int name
  -double type
  +createCreatedat()
  +setEmail()
  +deleteLevel()
}
class Package {
  -double quantity
  -float type
  +sendType()
  +cancelPhone()
  +deletePhone()
  +saveEmail()
}
class FuelLog {
  #boolean level
  #int description
  #double active
  #double duration
  #String type
  +cancelEmail()
}
Manifest --> FuelLog : "*"
Manifest ..> Package : "*"
Shipment ..|> FuelLog
note right of Customer : Logistics domain
@enduml