@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Customer {
  +boolean updatedAt
  -double amount
  +double score
  +boolean active
  +createUpdatedat()
  +sendDescription()
}
class Manifest {
  -long level
  +float name
  -int price
  +findLevel()
}
class Shipment {
  -float phone
  #float total
  #int name
  -double type
  +validateAddress()
  +sendId()
  +validateEmail()
}
class Package {
  -double level
  -double createdAt
  -float name
  +setAddress()
  +findTotal()
  +validateName()
  +findName()
}
class FuelLog {
  -boolean phone
  +boolean email
  #float address
  +findActive()
  +calculateUpdatedat()
}
FuelLog ..> Manifest : "*"
FuelLog --> Package : "1"
Customer --o Shipment
Manifest --> FuelLog : "*"
@enduml