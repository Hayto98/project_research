@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
abstract class Package {
  +Date code
  #long id
  +calculateCode()
  +getCode()
  +findStatus()
}
class Manifest {
  +boolean createdAt
  -float price
  #long phone
  -float amount
  +updatePrice()
}
class Customer {
  #double quantity
  +double name
  -boolean code
  +boolean total
  +deleteCreatedat()
  +processPhone()
  +sendDescription()
  +calculateActive()
}
abstract class DeliveryNote {
  -String price
  -Date address
  #int email
  -int name
  +float code
  +deleteActive()
  +processDuration()
  +validateLevel()
}
interface Shipment {
  +Date phone
  #long amount
  #float level
  +saveQuantity()
  +updateCreatedat()
}
Manifest --* Package
Package --o DeliveryNote
DeliveryNote --|> Package
@enduml