@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
abstract class Package {
  +Date code
  #long id
  +calculateLevel()
  +saveId()
  +findEmail()
}
class Manifest {
  #long phone
  -float amount
  #String updatedAt
  +String active
  -long email
  +findCode()
}
abstract class Customer {
  #boolean amount
  -long type
  #double price
  -Date active
  #double description
  +createName()
  +cancelCode()
  +calculateCode()
}
class DeliveryNote {
  #long quantity
  -int amount
  #int id
  +deleteAmount()
  +updateAddress()
  +cancelAmount()
}
class Shipment {
  #Date updatedAt
  -double name
  #double phone
  +String id
  +saveTotal()
  +getTotal()
  +validateDuration()
}
DeliveryNote ..|> Manifest
DeliveryNote --* Shipment
note right of Package : Logistics domain
@enduml