@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Appointment {
  -long level
  #Date active
  #float note
  +long duration
  +int quantity
  +calculateAddress()
  +processStatus()
}
abstract class LabTest {
  #boolean price
  +double quantity
  +setName()
  +setId()
  +calculateCode()
  +sendScore()
}
class Patient {
  #boolean email
  #Date createdAt
  +savePrice()
}
class Insurance {
  #String score
  -int createdAt
  +getEmail()
}
LabTest --> Patient : "0..1"
Insurance ..|> Appointment
Patient --* LabTest
@enduml