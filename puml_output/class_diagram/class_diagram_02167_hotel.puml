@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
interface Restaurant {
  +int address
  +long createdAt
  +double active
  +String status
  -long type
  +calculateName()
  +setDuration()
  +setUpdatedat()
  +setPhone()
}
class Invoice {
  #boolean description
  -long duration
  -float email
  +float note
  +Date phone
  +setEmail()
}
class Payment {
  -long id
  #long duration
  #boolean updatedAt
  +saveName()
  +deleteActive()
  +cancelEmail()
  +cancelDescription()
}
class Staff {
  -int name
  -long total
  -Date description
  +String phone
  -String type
  +sendDescription()
  +sendEmail()
  +processActive()
}
interface Booking {
  +long amount
  #float phone
  -float status
  +long quantity
  +updateType()
  +getAddress()
}
interface Reservation {
  -boolean price
  -int type
  +long note
  -long description
  +findScore()
  +saveDuration()
  +updateTotal()
}
interface Room {
  +int amount
  #float active
  +calculateEmail()
  +getEmail()
}
Reservation ..|> Staff
Booking --o Restaurant
@enduml