@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Enrollment {
  #float note
  #float price
  +int id
  +int quantity
  +sendType()
  +processScore()
  +deletePhone()
  +saveAmount()
}
class Assignment {
  -long name
  #boolean score
  +Date duration
  +Date level
  -long description
  +validateQuantity()
}
class Classroom {
  #int phone
  #Date active
  #String price
  +calculateQuantity()
  +calculateEmail()
}
abstract class Student {
  #long duration
  #float active
  +float name
  #long quantity
  +boolean updatedAt
  +processNote()
  +validatePrice()
  +findScore()
}
abstract class Department {
  +boolean score
  -double level
  +setEmail()
  +getActive()
  +sendAmount()
}
Student --> Enrollment : "1"
Enrollment ..|> Assignment
note right of Enrollment : Education domain
@enduml