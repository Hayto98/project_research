@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Enrollment {
  #float note
  #float price
  +int id
  +int quantity
  +calculatePrice()
  +findActive()
  +cancelAmount()
  +setType()
}
class Assignment {
  #String updatedAt
  +Date note
  +long name
  +cancelDuration()
  +getQuantity()
  +saveId()
}
class Classroom {
  #float quantity
  +long status
  #double phone
  #int duration
  #Date id
  +findName()
}
interface Student {
  -Date price
  -float quantity
  #double total
  +validatePrice()
}
interface Department {
  #long updatedAt
  +boolean score
  -double quantity
  #double duration
  +saveName()
  +sendUpdatedat()
  +sendAmount()
}
Enrollment --> Assignment : "1..*"
Student --|> Classroom
Classroom --> Enrollment : "0..1"
@enduml