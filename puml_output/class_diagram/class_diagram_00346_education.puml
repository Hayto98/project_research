@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
abstract class Course {
  #double createdAt
  +String code
  #String address
  #float name
  +deleteQuantity()
  +saveAmount()
}
interface Assignment {
  #Date email
  #boolean duration
  +validateActive()
  +validateUpdatedat()
}
abstract class Student {
  -String note
  -boolean createdAt
  #String status
  +createPrice()
  +setNote()
  +processAmount()
  +validateAmount()
}
interface Book {
  #float duration
  +String note
  +cancelType()
  +validateType()
}
interface Library {
  #long amount
  +boolean email
  +boolean level
  -double note
  +saveDuration()
  +calculateCreatedat()
  +createDescription()
  +findTotal()
}
class Attendance {
  #int price
  -long score
  +float status
  -double createdAt
  +String note
  +calculatePrice()
  +setDescription()
}
Book ..|> Attendance
Library --> Course : "*"
note right of Course : Education domain
@enduml