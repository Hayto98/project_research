@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
abstract class Course {
  #double createdAt
  +String code
  #String address
  #float name
  +createCreatedat()
  +createEmail()
}
class Assignment {
  -Date duration
  #boolean status
  #int email
  +saveType()
  +getScore()
  +deleteLevel()
}
class Student {
  +String note
  -String amount
  -boolean duration
  +deleteActive()
}
class Book {
  +boolean code
  #Date note
  #String type
  #Date amount
  -Date phone
  +getLevel()
}
class Library {
  -long phone
  -Date type
  -String score
  #int duration
  #long amount
  +calculateQuantity()
  +calculateType()
  +calculateUpdatedat()
  +getDuration()
}
interface Attendance {
  -double createdAt
  #boolean quantity
  +int description
  -boolean total
  +float address
  +calculateName()
  +processUpdatedat()
  +deleteLevel()
}
Book --|> Assignment
Assignment --o Book
Course --|> Assignment
Book ..|> Attendance
Library --> Course : "*"
@enduml