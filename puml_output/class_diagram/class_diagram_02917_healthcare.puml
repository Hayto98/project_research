@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Hospital {
  #int email
  +float price
  -int note
  +boolean amount
  +processDuration()
}
abstract class Prescription {
  -double note
  #boolean total
  #boolean code
  -Date email
  -float address
  +updateName()
  +saveName()
  +deleteName()
  +setEmail()
}
class Doctor {
  #Date email
  +String createdAt
  -String score
  +findName()
  +createDescription()
  +saveNote()
  +setStatus()
}
class Diagnosis {
  -float amount
  #Date total
  +createEmail()
  +updateId()
  +deleteTotal()
  +saveQuantity()
}
class Insurance {
  +boolean price
  +boolean total
  +boolean phone
  +processName()
}
class MedicalRecord {
  +double active
  #double amount
  -Date phone
  +deleteDuration()
  +getScore()
  +calculateEmail()
}
class LabTest {
  #long quantity
  #String phone
  #float price
  -boolean amount
  +float note
  +saveName()
  +processCode()
  +createAddress()
  +createType()
}
Doctor ..|> MedicalRecord
Hospital --o Insurance
@enduml