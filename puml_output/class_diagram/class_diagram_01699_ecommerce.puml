@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
abstract class Supplier {
  +float quantity
  +long code
  +getType()
  +cancelTotal()
  +updateQuantity()
  +updateQuantity()
}
interface Coupon {
  -Date description
  -long active
  +saveEmail()
  +createName()
  +processAddress()
  +validateQuantity()
}
class Wishlist {
  +int type
  +String createdAt
  +Date id
  +updateDescription()
}
abstract class Invoice {
  +boolean createdAt
  +String status
  -boolean duration
  -String address
  +boolean code
  +processNote()
  +getAddress()
  +updateDescription()
}
Coupon --* Wishlist
Coupon --> Invoice : "0..1"
Wishlist ..|> Invoice
note right of Supplier : Ecommerce domain
@enduml