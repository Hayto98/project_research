@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
abstract class Supplier {
  +float quantity
  +long code
  +sendTotal()
  +validateUpdatedat()
  +getCode()
  +findAmount()
}
class Coupon {
  #double updatedAt
  #long quantity
  -double id
  #long description
  +processQuantity()
  +deleteDuration()
  +saveStatus()
}
class Wishlist {
  #Date quantity
  +String createdAt
  +int amount
  +String type
  +sendPrice()
}
interface Invoice {
  -double createdAt
  +String description
  +createActive()
  +deleteEmail()
}
Supplier ..|> Wishlist
Supplier --> Coupon : "*"
@enduml