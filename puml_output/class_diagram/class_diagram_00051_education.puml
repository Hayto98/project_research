@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Exam {
  +int code
  -int price
  -float name
  +processEmail()
}
class Attendance {
  +float active
  #String note
  -long amount
  +calculateNote()
  +cancelAddress()
  +setEmail()
}
interface Classroom {
  +boolean level
  -int address
  +validateCreatedat()
  +findDescription()
}
class Course {
  #long phone
  +boolean type
  +setId()
  +cancelUpdatedat()
  +createDuration()
}
abstract class Assignment {
  #Date price
  +Date createdAt
  #double status
  +cancelQuantity()
  +calculateNote()
  +getAddress()
  +deleteEmail()
}
abstract class Student {
  +String level
  #Date updatedAt
  +setActive()
}
Student ..|> Course
Attendance --* Course
Exam ..> Attendance : "0..1"
Assignment ..> Course : "*"
@enduml