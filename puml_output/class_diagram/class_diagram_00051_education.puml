@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Exam {
  +int code
  -int price
  -float name
  +cancelUpdatedat()
}
class Attendance {
  -int amount
  -long updatedAt
  #float id
  #float address
  +boolean active
  +setLevel()
  +processCreatedat()
  +deleteDescription()
}
interface Classroom {
  #double status
  #long phone
  +sendPhone()
}
interface Course {
  #Date note
  +Date description
  #double price
  -double createdAt
  +double status
  +setLevel()
  +updateAmount()
  +setScore()
  +findName()
}
class Assignment {
  +Date createdAt
  +boolean duration
  -Date type
  -Date email
  +int status
  +createAddress()
  +getTotal()
  +deleteActive()
  +deleteUpdatedat()
}
abstract class Student {
  #double note
  -long score
  +findEmail()
  +deleteTotal()
  +createId()
  +updateStatus()
}
Assignment --o Student
Student ..> Classroom : "1"
Course ..> Student : "0..1"
note right of Exam : Education domain
@enduml