@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
interface Shelf {
  +String level
  #boolean updatedAt
  -boolean duration
  #boolean total
  +updateCreatedat()
  +cancelName()
}
abstract class Branch {
  #long active
  #long note
  -int createdAt
  -long email
  -Date amount
  +validateName()
}
class Reservation {
  #Date description
  #String createdAt
  +Date phone
  -float price
  +String email
  +calculateCode()
  +calculateNote()
  +calculateStatus()
}
class Librarian {
  #double phone
  -double amount
  +calculateDuration()
}
class Book {
  +double email
  #double address
  #boolean updatedAt
  +calculatePrice()
  +sendDuration()
}
class Author {
  -long price
  -String note
  +processAddress()
}
class Publisher {
  -String name
  +int description
  +getActive()
  +deleteScore()
  +validateCode()
  +saveDescription()
}
Book --* Author
Author --o Shelf
Librarian ..> Publisher : "*"
Publisher --* Reservation
@enduml