@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Member {
  -String active
  +Date price
  -String note
  +setAddress()
}
class Loan {
  -double status
  +double note
  +calculateLevel()
  +getAddress()
  +processDuration()
  +setEmail()
}
class Librarian {
  -int duration
  #boolean email
  #long price
  #Date description
  +float quantity
  +findTotal()
}
class Renewal {
  #Date description
  #float status
  -double code
  -float updatedAt
  +updateAmount()
  +calculateAddress()
}
interface Branch {
  +long quantity
  -long price
  +savePrice()
  +sendPhone()
  +deleteUpdatedat()
}
Member --> Renewal : "*"
Branch --* Loan
Renewal --* Member
@enduml