@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Member {
  -String active
  +Date price
  -String note
  +sendAmount()
}
interface Loan {
  -double status
  +double note
  +calculateUpdatedat()
  +validateDescription()
  +calculateDuration()
  +saveEmail()
}
abstract class Librarian {
  #boolean quantity
  #long total
  #Date createdAt
  +getEmail()
  +createDescription()
}
class Renewal {
  #boolean updatedAt
  -double active
  +deleteAmount()
  +saveScore()
  +cancelCode()
}
class Branch {
  #long id
  #double address
  +boolean email
  #double phone
  #double level
  +validateNote()
  +getPhone()
}
Librarian ..> Renewal : "1..*"
Branch --o Loan
note right of Member : Library domain
@enduml