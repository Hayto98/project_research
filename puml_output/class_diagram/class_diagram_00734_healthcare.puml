@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Appointment {
  +long status
  -int duration
  +saveCode()
  +updateCode()
  +sendCode()
}
class LabTest {
  +float createdAt
  +String amount
  +setCreatedat()
  +saveTotal()
  +findQuantity()
  +calculateName()
}
interface Treatment {
  +String score
  +int updatedAt
  +boolean price
  +cancelType()
}
class Diagnosis {
  #String price
  #Date createdAt
  +Date code
  #String description
  +float phone
  +findAddress()
  +processDescription()
  +calculateAddress()
}
class Prescription {
  #long code
  +double price
  #String level
  +sendScore()
  +sendType()
  +findScore()
  +validatePhone()
}
Treatment ..> Appointment : "1..*"
Diagnosis --> Prescription : "0..1"
LabTest ..> Diagnosis : "1..*"
Diagnosis --* LabTest
@enduml