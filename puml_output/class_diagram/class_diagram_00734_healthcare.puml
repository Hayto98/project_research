@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Appointment {
  +long status
  -int duration
  +calculateNote()
  +savePhone()
  +setCreatedat()
}
class LabTest {
  #double createdAt
  #long name
  +sendScore()
  +updateScore()
  +updatePrice()
}
class Treatment {
  +boolean name
  +float createdAt
  +calculatePrice()
  +findCreatedat()
}
class Diagnosis {
  #Date level
  +Date phone
  #String name
  +saveQuantity()
  +updateQuantity()
}
class Prescription {
  #double level
  #Date updatedAt
  #double code
  +setTotal()
  +cancelCode()
  +findTotal()
}
Treatment ..> Appointment : "1..*"
Appointment --o Treatment
Diagnosis ..|> LabTest
note right of Appointment : Healthcare domain
@enduml