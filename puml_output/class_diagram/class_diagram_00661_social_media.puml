@startuml
skinparam monochrome true
class Message {
  +float score
  +long id
  -int status
  +boolean address
  #long note
  +saveDescription()
  +findPhone()
  +setType()
  +deleteUpdatedat()
}
interface Notification {
  -float createdAt
  +Date score
  #float phone
  #long status
  #String total
  +deleteQuantity()
  +saveCreatedat()
  +sendDescription()
  +cancelCreatedat()
}
class Report {
  -double total
  #boolean phone
  #String status
  +saveNote()
  +sendCode()
  +sendQuantity()
}
class Comment {
  -float level
  -long updatedAt
  #double note
  +cancelTotal()
  +validateName()
  +getPrice()
  +setScore()
}
Message ..|> Report
Message --> Comment : "1..*"
@enduml