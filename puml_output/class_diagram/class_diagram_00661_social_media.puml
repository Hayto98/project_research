@startuml
skinparam monochrome true
class Message {
  +float score
  +long id
  -int status
  +boolean address
  #long note
  +findDescription()
  +deleteLevel()
  +cancelType()
  +updateScore()
}
class Notification {
  +Date total
  #float note
  +sendStatus()
  +saveType()
  +setAddress()
}
abstract class Report {
  #long description
  #String total
  +calculateLevel()
  +cancelScore()
  +getEmail()
  +updateNote()
}
interface Comment {
  +Date level
  #int duration
  +processPrice()
  +validateType()
  +processId()
  +processActive()
}
Message ..|> Report
Message --> Comment : "1..*"
note right of Message : Social Media domain
@enduml