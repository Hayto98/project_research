@startuml
skinparam defaultFontSize 11
interface Manifest {
  #long price
  +String name
  #boolean email
  +createDescription()
  +updateDescription()
  +calculatePhone()
  +getScore()
}
class DeliveryNote {
  +String description
  +String note
  #float id
  +sendActive()
  +createDescription()
  +processLevel()
  +getDescription()
}
class Warehouse {
  #boolean price
  #int description
  -Date note
  #Date address
  +saveScore()
}
class Vehicle {
  +double phone
  +long level
  #long email
  -Date name
  -Date total
  +getEmail()
}
DeliveryNote --* Manifest
DeliveryNote ..> Vehicle : "0..1"
Vehicle --o Warehouse
@enduml