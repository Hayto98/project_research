@startuml
skinparam defaultFontSize 11
interface Manifest {
  #long price
  +String name
  #boolean email
  +sendCreatedat()
  +createActive()
  +saveUpdatedat()
  +findCreatedat()
}
class DeliveryNote {
  #float id
  -boolean status
  #double name
  +Date updatedAt
  -double score
  +processAddress()
  +findScore()
}
class Warehouse {
  -boolean score
  #boolean code
  -String phone
  -int id
  -int total
  +cancelEmail()
  +createQuantity()
  +saveName()
}
class Vehicle {
  -Date updatedAt
  #int amount
  -Date address
  -Date description
  +createAmount()
  +deleteLevel()
}
Manifest --|> DeliveryNote
Warehouse ..|> Manifest
note right of Manifest : Logistics domain
@enduml