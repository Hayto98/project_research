@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
interface Product {
  -String active
  #long score
  #double description
  #String id
  +boolean email
  +getQuantity()
  +setAddress()
}
interface Cart {
  -Date type
  #long note
  +createDuration()
}
abstract class Customer {
  +String duration
  +boolean amount
  #boolean active
  +deleteType()
  +validateEmail()
  +validateQuantity()
  +cancelName()
}
interface Invoice {
  #long description
  +boolean price
  +processUpdatedat()
  +processActive()
}
class Payment {
  -long quantity
  +boolean note
  -long address
  -long type
  -String id
  +findDescription()
}
class Category {
  -boolean active
  #String type
  +cancelDescription()
  +updateNote()
}
Product ..> Invoice : "1..*"
Payment --* Invoice
@enduml