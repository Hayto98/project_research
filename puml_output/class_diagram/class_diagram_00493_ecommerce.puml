@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
interface Product {
  -String active
  #long score
  #double description
  #String id
  +boolean email
  +cancelScore()
  +cancelDuration()
}
interface Cart {
  -Date type
  #long note
  +calculateType()
}
class Customer {
  +boolean active
  #boolean amount
  -Date name
  +deleteLevel()
}
class Invoice {
  #float price
  +int phone
  +String name
  +createNote()
  +cancelAddress()
  +findLevel()
  +processDuration()
}
class Payment {
  -long quantity
  -String updatedAt
  +boolean score
  +float type
  +boolean address
  +createScore()
  +sendId()
  +deleteActive()
  +getName()
}
abstract class Category {
  #Date level
  +long type
  #int phone
  +String duration
  +getUpdatedat()
  +sendDescription()
  +cancelScore()
  +deleteEmail()
}
Payment ..> Invoice : "0..1"
Customer ..> Product : "0..1"
Category --|> Payment
Product --> Invoice : "1"
note right of Product : Ecommerce domain
@enduml