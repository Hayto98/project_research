@startuml
skinparam defaultFontSize 11
abstract class Report {
  #Date address
  #float level
  #boolean name
  +long quantity
  +findStatus()
  +processDuration()
  +savePrice()
}
class Story {
  +int phone
  #String level
  #boolean price
  -double status
  #long description
  +calculateStatus()
  +validateLevel()
  +calculateCode()
  +saveScore()
}
abstract class Comment {
  +Date code
  #int updatedAt
  #long score
  +String note
  +sendPrice()
  +updateAddress()
}
class User {
  -long createdAt
  +Date description
  +getActive()
}
User --|> Story
Report ..|> Comment
note right of Report : Social Media domain
@enduml