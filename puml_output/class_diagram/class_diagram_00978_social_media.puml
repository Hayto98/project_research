@startuml
skinparam defaultFontSize 11
abstract class Report {
  #Date address
  #float level
  #boolean name
  +long quantity
  +processPhone()
  +updateId()
  +setStatus()
}
abstract class Story {
  #boolean code
  +String total
  +Date phone
  +Date price
  #double status
  +processCreatedat()
  +updateQuantity()
  +cancelActive()
  +getStatus()
}
class Comment {
  #Date price
  #double status
  #Date phone
  -String total
  +boolean code
  +processUpdatedat()
  +cancelPrice()
  +setId()
  +calculateAddress()
}
class User {
  #double name
  +long amount
  +findNote()
  +calculateNote()
}
Comment ..|> Story
Report --> User : "0..1"
@enduml