@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Treatment {
  #String createdAt
  -Date address
  -int status
  -Date active
  -boolean amount
  +calculateCreatedat()
  +savePrice()
}
abstract class Billing {
  +Date email
  #Date status
  +long updatedAt
  -int createdAt
  +findCode()
  +findEmail()
}
class Hospital {
  #double id
  -long code
  +deleteDescription()
}
abstract class Diagnosis {
  -long level
  -Date name
  +long address
  +Date status
  -double quantity
  +setAmount()
  +getPhone()
}
interface MedicalRecord {
  #double duration
  +float email
  #float code
  #boolean score
  +findStatus()
}
Billing --|> Hospital
Diagnosis ..|> Treatment
Diagnosis --o Hospital
@enduml