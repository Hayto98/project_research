@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
interface Supplier {
  #int score
  -int total
  +setUpdatedat()
}
abstract class Cart {
  +boolean code
  -double duration
  +float quantity
  +boolean address
  +deleteStatus()
  +getPhone()
}
interface Warehouse {
  #double email
  -String score
  +updateType()
  +validateName()
  +updateEmail()
  +calculateType()
}
class Return {
  +int phone
  -float updatedAt
  #boolean price
  -String code
  #double address
  +cancelTotal()
  +setQuantity()
}
interface Payment {
  #int code
  +boolean amount
  -String phone
  -String name
  +int price
  +processLevel()
}
abstract class Order {
  -Date price
  +int duration
  +createStatus()
}
Cart --|> Return
Payment --* Return
Payment --* Cart
Return --|> Payment
note right of Supplier : Ecommerce domain
@enduml