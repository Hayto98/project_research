@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
interface Supplier {
  #int score
  -int total
  +validatePhone()
}
class Cart {
  +boolean address
  -double code
  +float level
  +boolean quantity
  +int duration
  +cancelType()
}
class Warehouse {
  -boolean active
  #double score
  -String level
  -float id
  +sendDescription()
  +sendName()
}
class Return {
  -Date updatedAt
  #double email
  +saveDuration()
  +processTotal()
  +updateTotal()
}
class Payment {
  #boolean code
  -String address
  #double id
  +boolean updatedAt
  -String total
  +findUpdatedat()
  +saveUpdatedat()
  +setNote()
}
class Order {
  #int phone
  +boolean name
  -String price
  +validateEmail()
  +saveTotal()
  +processActive()
}
Supplier --> Return : "*"
Order --> Payment : "1"
Return --o Order
@enduml