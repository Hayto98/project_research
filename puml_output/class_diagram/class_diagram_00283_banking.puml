@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Teller {
  +Date note
  #double address
  -long description
  +double email
  -double active
  +processPhone()
}
abstract class Statement {
  -boolean status
  -int description
  +String quantity
  +double level
  -long note
  +sendType()
}
class Branch {
  +int email
  +boolean score
  +double createdAt
  +deleteCreatedat()
  +sendScore()
  +calculateCode()
}
class Customer {
  #int phone
  -long id
  +saveNote()
  +updateCreatedat()
  +setEmail()
  +savePhone()
}
class Interest {
  +double description
  -long id
  -double name
  -long createdAt
  +calculatePrice()
  +getAmount()
  +setPrice()
  +setScore()
}
Branch ..|> Customer
Interest ..|> Customer
note right of Teller : Banking domain
@enduml