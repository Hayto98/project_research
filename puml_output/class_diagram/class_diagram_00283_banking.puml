@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Teller {
  +Date note
  #double address
  -long description
  +double email
  -double active
  +cancelCode()
}
class Statement {
  -double note
  #long status
  +String description
  +int quantity
  -double score
  +validateDescription()
  +updateActive()
  +findDuration()
}
abstract class Branch {
  #int amount
  +int email
  +setPhone()
}
class Customer {
  +float address
  #String description
  -Date createdAt
  +Date total
  +double code
  +setNote()
  +processScore()
  +cancelPrice()
}
abstract class Interest {
  #long createdAt
  -long code
  +String email
  +cancelNote()
}
Customer --* Branch
Branch --o Customer
@enduml