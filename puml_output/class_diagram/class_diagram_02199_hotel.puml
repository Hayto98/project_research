@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Service {
  +Date active
  -String amount
  +deleteAmount()
}
class Staff {
  +long address
  +double score
  +String phone
  +cancelScore()
  +findName()
}
class Amenity {
  #double score
  #double status
  +sendActive()
  +calculateAmount()
}
abstract class Payment {
  +float name
  +double score
  +long description
  -String total
  -String code
  +sendPhone()
}
abstract class Guest {
  #Date description
  +Date phone
  -double quantity
  +float updatedAt
  +String active
  +processDuration()
}
abstract class Booking {
  -String note
  #int createdAt
  #int updatedAt
  +validatePhone()
  +setEmail()
  +createTotal()
}
class Reservation {
  #String note
  +String description
  +boolean level
  +deleteName()
  +deleteCreatedat()
  +calculatePhone()
}
Reservation --> Service : "1..*"
Service ..|> Amenity
Booking --* Service
@enduml