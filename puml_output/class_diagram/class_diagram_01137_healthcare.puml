@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Hospital {
  #int updatedAt
  -boolean active
  +saveStatus()
}
class Ward {
  #Date status
  #int quantity
  #int phone
  +int email
  +processId()
  +createDescription()
  +validateScore()
  +validateDuration()
}
interface LabTest {
  -int type
  -int updatedAt
  +int id
  #boolean price
  +deleteAddress()
  +setNote()
}
class Prescription {
  #float phone
  #String score
  #long type
  -Date amount
  +getTotal()
  +sendCreatedat()
  +calculateUpdatedat()
}
class MedicalRecord {
  -float description
  -boolean note
  #float total
  +long address
  +Date name
  +cancelUpdatedat()
  +saveAddress()
}
interface Doctor {
  +Date level
  +Date code
  +double note
  +boolean score
  +Date active
  +cancelDescription()
}
class Patient {
  -boolean id
  #float address
  #Date status
  +double updatedAt
  +updateLevel()
  +findPhone()
  +processCreatedat()
  +findCreatedat()
}
Doctor --> MedicalRecord : "1"
Ward --|> Doctor
MedicalRecord --> Doctor : "0..1"
Ward ..|> Prescription
Patient ..|> Prescription
note right of Hospital : Healthcare domain
@enduml