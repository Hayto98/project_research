@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Hospital {
  #int updatedAt
  -boolean active
  +updateAddress()
}
class Ward {
  -Date email
  #long status
  #Date quantity
  +sendPrice()
  +validateCode()
}
class LabTest {
  -int note
  -boolean type
  -boolean id
  +validateUpdatedat()
  +getQuantity()
  +updateStatus()
}
class Prescription {
  +boolean total
  #int description
  +long note
  +double updatedAt
  +long level
  +deleteEmail()
  +cancelDuration()
  +calculateDuration()
}
abstract class MedicalRecord {
  -Date score
  -float name
  +double email
  +createId()
  +updateAmount()
}
abstract class Doctor {
  -Date code
  -long type
  +long description
  +deleteUpdatedat()
  +updateCode()
  +cancelTotal()
  +setDuration()
}
class Patient {
  #long updatedAt
  #double level
  #Date duration
  +sendCode()
}
Prescription ..> Ward : "0..1"
Doctor --o Hospital
Hospital ..|> MedicalRecord
MedicalRecord ..|> Ward
@enduml