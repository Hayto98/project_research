@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
abstract class Prescription {
  +int level
  -boolean total
  -boolean amount
  -Date address
  +updateStatus()
  +validateEmail()
  +cancelType()
}
interface Appointment {
  +boolean amount
  +float score
  -float quantity
  -String description
  #boolean active
  +deleteName()
  +sendTotal()
  +updateLevel()
  +setScore()
}
interface Billing {
  -boolean status
  #Date code
  -int phone
  -String note
  +updateCode()
}
class Insurance {
  -boolean phone
  #Date updatedAt
  #String status
  -boolean code
  +Date duration
  +findTotal()
  +findPhone()
  +findDescription()
  +saveStatus()
}
abstract class Patient {
  +long createdAt
  #boolean id
  +Date level
  +processStatus()
  +cancelAmount()
  +createScore()
}
interface Nurse {
  #int description
  -boolean note
  -long phone
  +long status
  +cancelActive()
}
Prescription --|> Billing
Nurse --|> Patient
Prescription ..|> Patient
@enduml