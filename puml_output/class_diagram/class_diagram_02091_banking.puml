@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Account {
  #String description
  #float type
  +cancelNote()
  +cancelAmount()
  +createCode()
}
class Transfer {
  -float score
  -int note
  +sendDuration()
  +findActive()
  +getDuration()
  +setEmail()
}
abstract class Deposit {
  +float createdAt
  #long address
  +long price
  -Date quantity
  -boolean description
  +sendTotal()
  +deleteScore()
  +createType()
  +getType()
}
class Loan {
  #Date status
  -String price
  #int quantity
  #Date description
  #long total
  +createType()
  +createQuantity()
}
class Interest {
  +int code
  #boolean phone
  #String id
  +getPhone()
}
Account --o Loan
Account ..|> Transfer
note right of Account : Banking domain
@enduml