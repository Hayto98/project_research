@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Ward {
  +long address
  +double duration
  +double createdAt
  #float name
  #int updatedAt
  +calculateStatus()
  +updateAddress()
  +createScore()
  +setStatus()
}
interface Patient {
  +float price
  #boolean createdAt
  +int email
  #long score
  -Date note
  +deleteUpdatedat()
  +processNote()
  +sendId()
  +sendNote()
}
interface Appointment {
  #String id
  #long score
  -float active
  #float quantity
  -boolean updatedAt
  +setNote()
}
interface Treatment {
  -String level
  +int quantity
  #long type
  +getType()
  +sendPhone()
  +cancelUpdatedat()
}
class Diagnosis {
  -int description
  -float address
  +long price
  #float total
  +deleteCode()
  +calculateCreatedat()
  +deleteActive()
}
class Insurance {
  #int phone
  #long code
  #long id
  +String total
  +sendLevel()
  +getId()
}
Diagnosis --> Patient : "0..1"
Ward --o Insurance
Insurance ..> Ward : "0..1"
Treatment --|> Appointment
@enduml