@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Ward {
  +long address
  +double duration
  +double createdAt
  #float name
  #int updatedAt
  +findUpdatedat()
  +setScore()
  +calculatePrice()
  +updateEmail()
}
class Patient {
  -Date status
  -boolean score
  #int updatedAt
  +Date level
  #float phone
  +getScore()
  +sendQuantity()
  +cancelUpdatedat()
  +findStatus()
}
interface Appointment {
  -Date quantity
  #float duration
  +boolean score
  -Date name
  +validateName()
  +getCreatedat()
  +saveAddress()
  +createCode()
}
class Treatment {
  -double email
  -double description
  +calculateDescription()
  +createDuration()
}
class Diagnosis {
  -String address
  +Date type
  -boolean id
  +boolean quantity
  +findEmail()
  +setId()
  +saveUpdatedat()
}
abstract class Insurance {
  +double duration
  #String description
  #int createdAt
  -long status
  +validateType()
}
Insurance --|> Treatment
Ward ..> Insurance : "1"
Diagnosis --> Treatment : "1..*"
note right of Ward : Healthcare domain
@enduml