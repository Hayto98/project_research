@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
abstract class Insurance {
  +boolean note
  +boolean score
  -float level
  +validateStatus()
  +updateStatus()
  +saveAmount()
  +validateUpdatedat()
}
class MedicalRecord {
  #boolean status
  +float level
  +saveName()
  +getType()
}
abstract class Hospital {
  +double email
  #long duration
  #long quantity
  +boolean score
  +updateName()
  +calculateName()
}
class Treatment {
  -long address
  -float name
  +cancelNote()
  +validateQuantity()
}
class Billing {
  #double email
  #boolean duration
  +long type
  +double code
  +validateUpdatedat()
  +sendUpdatedat()
  +createEmail()
}
class LabTest {
  -boolean updatedAt
  +double active
  +setTotal()
  +updateEmail()
  +getNote()
}
Insurance --o MedicalRecord
Billing ..> MedicalRecord : "1"
Billing --* Insurance
LabTest ..> Insurance : "1"
@enduml