@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
abstract class Insurance {
  +boolean note
  +boolean score
  -float level
  +updateNote()
  +processPhone()
  +setStatus()
  +cancelScore()
}
interface MedicalRecord {
  -String active
  #float createdAt
  +sendEmail()
  +createEmail()
  +createQuantity()
  +getType()
}
interface Hospital {
  +String duration
  -String quantity
  +float name
  #long active
  +calculateAddress()
}
class Treatment {
  #Date createdAt
  #long amount
  -long code
  +setActive()
  +processActive()
  +cancelUpdatedat()
  +validateId()
}
abstract class Billing {
  #double type
  #float amount
  +double code
  -long updatedAt
  +createPrice()
  +setUpdatedat()
  +calculateActive()
  +updateStatus()
}
interface LabTest {
  #boolean address
  +Date id
  +updatePrice()
}
Billing ..|> Insurance
Billing --o Treatment
Insurance --> LabTest : "*"
Insurance ..> Hospital : "1..*"
note right of Insurance : Healthcare domain
@enduml