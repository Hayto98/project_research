@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
interface Service {
  -Date level
  #float status
  #int quantity
  #double note
  #float type
  +findPrice()
  +processDescription()
  +updateName()
  +calculateActive()
}
class Payment {
  #double type
  -int total
  +setCode()
  +updateNote()
  +saveEmail()
}
class Housekeeping {
  #String duration
  +Date email
  #String status
  +cancelUpdatedat()
  +processAmount()
  +updateStatus()
}
class Staff {
  -float type
  -int description
  -int note
  +Date createdAt
  +cancelDescription()
  +saveActive()
  +processEmail()
}
class CheckIn {
  #float description
  #double status
  -long score
  -int id
  +getCreatedat()
  +findAddress()
}
Staff ..|> Payment
Housekeeping --|> CheckIn
@enduml