@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Exam {
  #boolean type
  #int amount
  +long active
  +long quantity
  +createLevel()
  +saveNote()
  +getDuration()
}
class Schedule {
  -double total
  +float email
  +calculateCode()
  +calculateAddress()
  +findDuration()
}
class Course {
  #long note
  #int quantity
  +createAmount()
  +validateCreatedat()
  +sendAmount()
  +updateEmail()
}
class Department {
  -int price
  #double createdAt
  #long description
  #float note
  -Date quantity
  +processType()
}
class Book {
  #double email
  #Date score
  +long phone
  -String code
  -float note
  +deleteName()
  +getEmail()
  +validateDescription()
}
class Enrollment {
  +Date note
  +double code
  +updateAddress()
  +cancelStatus()
}
class Assignment {
  +int email
  -long duration
  +processId()
  +getAmount()
  +deleteCreatedat()
  +updateType()
}
Assignment ..> Schedule : "1"
Course --|> Exam
Department ..> Enrollment : "1..*"
Assignment ..|> Exam
note right of Exam : Education domain
@enduml