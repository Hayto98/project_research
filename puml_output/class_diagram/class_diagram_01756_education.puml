@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Exam {
  #boolean type
  #int amount
  +long active
  +long quantity
  +deleteEmail()
  +findScore()
  +cancelActive()
}
abstract class Schedule {
  +double duration
  -float phone
  +getAddress()
  +findId()
  +setActive()
  +saveCreatedat()
}
abstract class Course {
  #boolean total
  #long address
  +deletePrice()
}
class Department {
  +long active
  +boolean updatedAt
  +int note
  -String quantity
  +processType()
  +updatePhone()
  +saveNote()
  +findEmail()
}
interface Book {
  +float note
  #double quantity
  #long level
  +deleteStatus()
  +updateActive()
  +sendCode()
  +saveType()
}
abstract class Enrollment {
  +double type
  #double email
  #Date score
  +long phone
  +validateId()
  +sendName()
  +findLevel()
  +processStatus()
}
class Assignment {
  -float name
  +int email
  +createName()
}
Exam ..|> Enrollment
Department ..|> Enrollment
@enduml