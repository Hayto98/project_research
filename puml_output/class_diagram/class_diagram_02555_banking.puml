@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
interface Withdrawal {
  #String status
  #double email
  +float id
  +findAmount()
  +cancelAddress()
  +getUpdatedat()
}
interface Teller {
  -double code
  #boolean type
  -String createdAt
  #boolean note
  +Date name
  +updateEmail()
}
class Loan {
  #boolean active
  -boolean id
  +validateName()
}
class Customer {
  #boolean amount
  -Date price
  #float duration
  -String code
  #String updatedAt
  +saveQuantity()
}
class Account {
  +long updatedAt
  -String status
  -String score
  +findScore()
  +calculateName()
}
Teller --* Account
Loan --o Customer
Account --|> Teller
@enduml