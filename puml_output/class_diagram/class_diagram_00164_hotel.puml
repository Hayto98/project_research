@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Service {
  -int id
  -boolean createdAt
  +String updatedAt
  -String price
  #float duration
  +sendCreatedat()
  +saveQuantity()
  +getActive()
  +validateUpdatedat()
}
class Amenity {
  +long price
  -int active
  -long phone
  -long amount
  -double score
  +saveCode()
}
interface Invoice {
  +int quantity
  -boolean score
  +double description
  -Date duration
  +savePhone()
  +calculateScore()
}
abstract class Housekeeping {
  -double quantity
  +Date code
  +float description
  +getType()
  +createPhone()
  +sendStatus()
  +sendLevel()
}
Invoice ..> Service : "1"
Housekeeping --o Amenity
@enduml