@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Service {
  -int id
  -boolean createdAt
  +String updatedAt
  -String price
  #float duration
  +processDescription()
  +findType()
  +createNote()
  +calculateActive()
}
class Amenity {
  -int phone
  -long code
  -long duration
  +processName()
  +calculateLevel()
  +createQuantity()
  +sendDescription()
}
interface Invoice {
  +double code
  -Date updatedAt
  +String note
  -double active
  +findQuantity()
  +saveCode()
}
class Housekeeping {
  +float type
  +long id
  +Date code
  #String total
  -double score
  +calculateUpdatedat()
  +calculateEmail()
  +updateAmount()
  +findDuration()
}
Invoice ..|> Amenity
note right of Service : Hotel domain
@enduml