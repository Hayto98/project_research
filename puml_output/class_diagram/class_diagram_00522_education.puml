@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
interface Student {
  -int status
  #Date note
  +boolean level
  #int email
  +processUpdatedat()
  +cancelLevel()
  +sendDuration()
  +findPhone()
}
abstract class Enrollment {
  -boolean id
  +int description
  +savePhone()
  +saveName()
  +processNote()
  +createActive()
}
abstract class Teacher {
  +float email
  #int status
  +cancelLevel()
}
interface Classroom {
  -int name
  +long createdAt
  -float amount
  +sendName()
}
class Schedule {
  +boolean code
  +String price
  +String updatedAt
  -String address
  #String duration
  +calculateTotal()
  +updateTotal()
  +findDuration()
  +validateTotal()
}
class Library {
  #float name
  #Date note
  +boolean updatedAt
  -boolean address
  +deleteCode()
}
class Grade {
  #int address
  -Date email
  #double amount
  +getCode()
  +deleteDescription()
  +deleteCreatedat()
  +setEmail()
}
Teacher ..> Grade : "1..*"
Student --> Grade : "1"
Grade --> Schedule : "1"
Classroom ..|> Enrollment
Classroom --|> Schedule
@enduml