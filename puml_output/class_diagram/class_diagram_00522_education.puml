@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
interface Student {
  -int status
  #Date note
  +boolean level
  #int email
  +deleteDescription()
  +findTotal()
  +getId()
  +deleteType()
}
interface Enrollment {
  +double description
  #long active
  #double price
  +saveEmail()
}
class Teacher {
  #boolean active
  +String description
  +int code
  +updateAmount()
  +validateAddress()
  +cancelName()
  +processCreatedat()
}
abstract class Classroom {
  -float price
  +int updatedAt
  +setId()
  +setAddress()
}
class Schedule {
  #Date type
  +Date phone
  +saveName()
  +processUpdatedat()
  +validateCreatedat()
}
interface Library {
  #long score
  -int id
  #int phone
  -Date amount
  #double updatedAt
  +cancelDuration()
  +createAddress()
  +cancelPhone()
  +validateAddress()
}
class Grade {
  #boolean score
  +double id
  +deleteQuantity()
  +validateType()
}
Student ..|> Grade
Teacher --o Schedule
Schedule --|> Library
Teacher ..|> Classroom
Student --* Classroom
Classroom --|> Enrollment
note right of Student : Education domain
@enduml