@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Service {
  -float price
  #int name
  #int active
  +setDuration()
  +findUpdatedat()
  +deleteStatus()
  +cancelName()
}
interface Restaurant {
  #double duration
  #Date id
  #long total
  -String note
  +findNote()
  +validateCode()
}
interface Reservation {
  +boolean price
  +long score
  +boolean status
  #boolean amount
  #long address
  +createDuration()
  +sendDuration()
  +calculateStatus()
  +deleteCode()
}
interface Amenity {
  #Date total
  #int price
  +String score
  +validateTotal()
  +processDescription()
}
interface Housekeeping {
  +long amount
  +long description
  -int name
  +float quantity
  #double code
  +deleteDuration()
  +updatePhone()
  +setDuration()
}
class Booking {
  +Date duration
  +long amount
  +String createdAt
  +int description
  +String total
  +processLevel()
  +cancelType()
}
class Guest {
  -Date email
  #int duration
  +getAmount()
  +deleteActive()
}
Guest --* Amenity
Restaurant --* Housekeeping
Service --* Amenity
note right of Service : Hotel domain
@enduml