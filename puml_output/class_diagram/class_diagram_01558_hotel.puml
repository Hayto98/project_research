@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Service {
  -float price
  #int name
  #int active
  +findNote()
  +validateActive()
  +deleteType()
  +createScore()
}
class Restaurant {
  #long level
  #float name
  +setAmount()
}
abstract class Reservation {
  +Date price
  -long active
  +boolean phone
  -double note
  #String status
  +saveLevel()
  +saveCreatedat()
}
class Amenity {
  #Date email
  #float createdAt
  +processTotal()
  +saveTotal()
  +deleteCreatedat()
}
interface Housekeeping {
  #float status
  #double description
  #Date code
  #boolean amount
  +String total
  +createStatus()
}
class Booking {
  #int total
  +float note
  +long description
  #String level
  +processStatus()
  +cancelStatus()
}
class Guest {
  #float amount
  +float name
  -String total
  #int address
  #double duration
  +getTotal()
  +setType()
}
Service ..|> Booking
Reservation --|> Service
Service ..|> Restaurant
Amenity --> Housekeeping : "*"
@enduml