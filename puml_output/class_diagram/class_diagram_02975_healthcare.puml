@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Ward {
  -int id
  +float price
  -Date level
  -String note
  +sendId()
}
interface LabTest {
  #long amount
  +double updatedAt
  #int createdAt
  #long description
  +setId()
  +calculateAmount()
}
class Patient {
  #int duration
  -int note
  -long level
  #boolean active
  #long amount
  +validateType()
  +getTotal()
}
class Insurance {
  +boolean price
  +String score
  -long email
  +double id
  +createNote()
  +deletePrice()
  +validateAddress()
  +cancelEmail()
}
Insurance ..|> LabTest
Ward --> Insurance : "1..*"
note right of Ward : Healthcare domain
@enduml