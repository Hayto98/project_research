@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Ward {
  -int id
  +float price
  -Date level
  -String note
  +saveActive()
}
class LabTest {
  #long amount
  +double updatedAt
  #int createdAt
  #long description
  +validateId()
  +setName()
}
abstract class Patient {
  -boolean address
  +Date type
  +float note
  +saveNote()
  +deleteDuration()
  +setEmail()
  +cancelDescription()
}
interface Insurance {
  -long createdAt
  #float phone
  -double type
  #long name
  +sendId()
}
Ward --* LabTest
@enduml