@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Beneficiary {
  #Date email
  #boolean address
  -String phone
  +setDescription()
}
interface Statement {
  -boolean phone
  -double level
  -Date duration
  +cancelAddress()
  +calculateQuantity()
  +findUpdatedat()
}
class Teller {
  +float status
  -double type
  +updateQuantity()
  +cancelAmount()
  +cancelType()
  +getActive()
}
class Loan {
  #String status
  -float phone
  #Date quantity
  +cancelStatus()
  +cancelAmount()
  +setId()
}
Beneficiary --|> Teller
Beneficiary --> Statement : "1"
note right of Beneficiary : Banking domain
@enduml