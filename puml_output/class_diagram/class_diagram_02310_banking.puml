@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Beneficiary {
  #Date email
  #boolean address
  -String phone
  +deleteLevel()
}
class Statement {
  #long duration
  -boolean updatedAt
  -double phone
  +setPrice()
  +updateAddress()
  +deleteCode()
}
interface Teller {
  +String price
  -String quantity
  -double updatedAt
  -int amount
  +findName()
  +getName()
  +calculateAddress()
}
interface Loan {
  -float id
  -Date active
  +double email
  #Date createdAt
  -boolean status
  +savePrice()
}
Beneficiary --|> Loan
Beneficiary --|> Teller
@enduml