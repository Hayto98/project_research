@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Loan {
  #long description
  -double duration
  #int status
  +getCode()
  +findScore()
  +validateQuantity()
  +sendAmount()
}
abstract class Shelf {
  #float createdAt
  +long code
  +String total
  -boolean note
  -String level
  +setPrice()
  +processDescription()
  +calculateNote()
  +getUpdatedat()
}
class Book {
  #int total
  -double type
  #int amount
  +setNote()
  +findTotal()
  +processName()
}
abstract class Librarian {
  -String quantity
  #int amount
  +createScore()
  +findType()
}
interface Renewal {
  +boolean updatedAt
  -int amount
  -int description
  +processLevel()
  +saveAmount()
  +saveAddress()
}
interface Author {
  +String email
  -int type
  +sendDescription()
  +calculateNote()
  +setCode()
  +cancelType()
}
Loan --|> Shelf
Renewal --|> Author
Author --> Book : "1"
@enduml