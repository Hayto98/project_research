@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Loan {
  #long description
  -double duration
  #int status
  +cancelQuantity()
  +deleteScore()
  +calculateNote()
  +findCreatedat()
}
class Shelf {
  +double note
  #long code
  +Date name
  #boolean phone
  -long id
  +deleteDescription()
  +calculateType()
}
class Book {
  #long address
  -float type
  +double description
  +createAmount()
}
class Librarian {
  #float score
  #int amount
  +cancelDescription()
  +updateAmount()
}
class Renewal {
  +long score
  +long note
  +processAmount()
  +sendName()
  +saveEmail()
  +processId()
}
class Author {
  +String updatedAt
  #float type
  #String createdAt
  #float amount
  -boolean code
  +cancelLevel()
}
Renewal ..|> Book
Loan --> Book : "1"
Book --> Author : "1"
Librarian --* Book
Book --* Loan
note right of Loan : Library domain
@enduml