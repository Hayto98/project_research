@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Assignment {
  +float name
  #Date duration
  +saveAddress()
}
class Grade {
  +Date status
  #float duration
  -double address
  #long email
  +processType()
  +updateName()
}
class Library {
  -boolean address
  +String id
  +setDescription()
  +createScore()
  +setQuantity()
}
class Book {
  +float createdAt
  #int status
  #boolean quantity
  +findCode()
  +updatePhone()
  +saveDuration()
}
class Enrollment {
  +double status
  -boolean score
  #Date code
  -Date description
  +updateCode()
}
abstract class Department {
  -boolean updatedAt
  -Date phone
  +int email
  +getActive()
  +getType()
}
Grade --o Department
Department --* Assignment
Assignment ..> Grade : "0..1"
Grade ..> Library : "1..*"
@enduml