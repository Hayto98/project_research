@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Assignment {
  +float name
  #Date duration
  +deleteAddress()
}
class Grade {
  -String status
  #boolean address
  +calculateQuantity()
  +deletePrice()
  +setDescription()
}
class Library {
  +float id
  #long type
  +int active
  +int duration
  +setQuantity()
  +deleteDuration()
}
class Book {
  +boolean phone
  +int level
  +double id
  -boolean address
  +saveName()
  +calculateCreatedat()
  +updatePhone()
}
class Enrollment {
  #String active
  -int email
  +double status
  #String description
  -String updatedAt
  +findActive()
  +deleteUpdatedat()
}
class Department {
  +float duration
  -float email
  -boolean createdAt
  #Date quantity
  +getCreatedat()
}
Grade ..> Enrollment : "1"
Assignment --o Library
Library --> Book : "1..*"
Book ..> Enrollment : "*"
Enrollment ..|> Department
note right of Assignment : Education domain
@enduml