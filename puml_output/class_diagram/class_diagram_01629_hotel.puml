@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Payment {
  +double description
  -String createdAt
  #float score
  +setActive()
  +sendNote()
  +getQuantity()
  +processUpdatedat()
}
class CheckIn {
  -int quantity
  -float email
  +cancelQuantity()
  +validateDescription()
  +createStatus()
}
abstract class Reservation {
  #boolean total
  +Date duration
  +calculateLevel()
}
class Invoice {
  -long score
  +float email
  +findDescription()
  +validateCode()
  +processStatus()
}
Reservation --> CheckIn : "1"
CheckIn --> Invoice : "0..1"
@enduml