@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Account {
  -int price
  #double type
  +double name
  +setNote()
  +deleteAmount()
}
class Teller {
  #float email
  #int price
  +calculateDescription()
}
class Branch {
  #int duration
  -boolean amount
  +validatePhone()
  +deleteScore()
}
abstract class Loan {
  +long price
  -Date amount
  #Date total
  #long phone
  +saveActive()
}
Loan --|> Account
@enduml