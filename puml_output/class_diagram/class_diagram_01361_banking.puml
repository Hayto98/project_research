@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Account {
  -int price
  #double type
  +double name
  +calculatePrice()
  +deleteName()
}
class Teller {
  #int createdAt
  -boolean name
  #int phone
  +int level
  #double amount
  +calculateDuration()
  +deleteTotal()
  +validateId()
}
class Branch {
  #Date score
  +Date phone
  -int duration
  +double name
  +deleteCode()
}
class Loan {
  +long updatedAt
  +long code
  +saveQuantity()
}
Account ..> Branch : "0..1"
Branch --o Account
note right of Account : Banking domain
@enduml