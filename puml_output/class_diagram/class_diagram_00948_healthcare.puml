@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
interface Appointment {
  #String updatedAt
  #boolean amount
  +boolean type
  #Date createdAt
  +createCode()
  +getPhone()
  +validateTotal()
  +getType()
}
abstract class Prescription {
  -int level
  #Date status
  -String updatedAt
  +findName()
  +sendId()
}
abstract class Doctor {
  -int score
  +long description
  #String address
  +sendScore()
  +processCode()
  +getTotal()
}
abstract class Diagnosis {
  -String amount
  +boolean status
  #boolean note
  +boolean address
  +saveEmail()
  +processType()
}
class Insurance {
  +float type
  -double email
  +double duration
  -long score
  #Date updatedAt
  +findQuantity()
}
interface MedicalRecord {
  -long duration
  +double updatedAt
  +deleteLevel()
  +deleteId()
  +updateEmail()
}
class Ward {
  -int updatedAt
  +Date score
  #int amount
  +int code
  +deleteCreatedat()
  +saveStatus()
  +setName()
}
Appointment --> Diagnosis : "1"
Diagnosis --|> Doctor
Prescription ..> Ward : "0..1"
@enduml