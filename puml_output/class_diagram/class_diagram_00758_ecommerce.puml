@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Shipment {
  +long code
  +double description
  +long status
  #boolean id
  +calculateCode()
  +sendEmail()
  +calculatePrice()
  +validateDescription()
}
abstract class Invoice {
  +float description
  +int note
  #int phone
  #float updatedAt
  #Date total
  +deleteId()
  +calculateCode()
  +savePrice()
}
class Wishlist {
  +int description
  -float amount
  -String status
  -String address
  +saveTotal()
  +updateEmail()
}
class Category {
  #String active
  +long quantity
  +saveStatus()
  +getActive()
  +setDuration()
}
abstract class Return {
  -float duration
  -double email
  +getNote()
  +calculateTotal()
  +deleteCode()
}
interface Customer {
  #double status
  #float duration
  -boolean updatedAt
  +savePrice()
}
class Order {
  #long total
  +Date email
  +boolean score
  #String active
  +String createdAt
  +getEmail()
}
Wishlist --o Invoice
Category ..> Invoice : "1"
Category --> Order : "1"
@enduml