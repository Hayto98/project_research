@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Warehouse {
  +Date id
  -double description
  +getName()
  +calculateAmount()
}
class Wishlist {
  +double active
  -boolean total
  +sendName()
  +calculateName()
  +validateDuration()
  +calculateStatus()
}
interface Category {
  #String updatedAt
  +long note
  -String address
  +int status
  +int quantity
  +createDuration()
  +setDuration()
  +deleteUpdatedat()
}
interface Coupon {
  -Date phone
  +long duration
  -Date active
  +cancelCreatedat()
  +createUpdatedat()
  +processDescription()
  +updateTotal()
}
interface Supplier {
  +int amount
  +String active
  +Date name
  +setCreatedat()
  +deleteActive()
  +deleteDescription()
  +getStatus()
}
class Invoice {
  +Date phone
  +int active
  +saveCode()
  +cancelNote()
}
Wishlist --|> Coupon
Supplier ..|> Category
Warehouse --|> Wishlist
@enduml