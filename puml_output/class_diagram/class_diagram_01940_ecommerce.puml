@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Warehouse {
  +Date id
  -double description
  +processUpdatedat()
  +sendId()
}
interface Wishlist {
  -long createdAt
  #boolean note
  -int phone
  -Date total
  -String type
  +cancelId()
  +updateAddress()
  +validateId()
}
class Category {
  -boolean description
  #float updatedAt
  #float quantity
  +validateDuration()
  +validateActive()
}
class Coupon {
  #double phone
  -boolean total
  +validateScore()
  +deleteAmount()
  +sendName()
}
class Supplier {
  #float updatedAt
  -Date id
  -boolean amount
  +getPhone()
}
interface Invoice {
  -int description
  #int amount
  +float updatedAt
  +setScore()
  +createDescription()
  +setAmount()
  +setType()
}
Warehouse ..> Category : "1"
Wishlist --o Coupon
Coupon --* Wishlist
Warehouse --o Supplier
note right of Warehouse : Ecommerce domain
@enduml