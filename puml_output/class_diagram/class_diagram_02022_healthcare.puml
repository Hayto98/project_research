@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Insurance {
  #Date phone
  #String createdAt
  +long updatedAt
  +long status
  +sendAmount()
  +cancelPhone()
  +setDescription()
}
class Appointment {
  #int active
  -int type
  #String createdAt
  +processTotal()
  +calculateDescription()
  +validateScore()
}
abstract class LabTest {
  #float description
  #float phone
  -Date address
  +updateType()
  +validateId()
}
abstract class MedicalRecord {
  #boolean quantity
  -boolean id
  +cancelLevel()
  +sendUpdatedat()
  +validateAmount()
  +updateCreatedat()
}
class Hospital {
  #String type
  -Date address
  +validateAmount()
  +updateEmail()
}
class Nurse {
  -Date updatedAt
  #double name
  +cancelTotal()
  +saveDescription()
  +getScore()
  +validateDuration()
}
Appointment --|> Insurance
Hospital ..> Insurance : "*"
Hospital --* Nurse
MedicalRecord --> Nurse : "0..1"
@enduml