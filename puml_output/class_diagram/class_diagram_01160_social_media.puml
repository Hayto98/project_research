@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Post {
  #double score
  #long code
  #String phone
  +calculateCreatedat()
  +setAddress()
}
class Story {
  -Date quantity
  +String status
  +int phone
  #float duration
  #Date address
  +validateTotal()
}
class Comment {
  +String type
  +long note
  +deleteName()
  +calculateActive()
  +getTotal()
}
abstract class Hashtag {
  #Date quantity
  #String phone
  -float price
  #Date score
  -float status
  +sendAddress()
}
abstract class Report {
  #int description
  +float active
  #Date createdAt
  -Date price
  +int phone
  +cancelUpdatedat()
  +updateEmail()
}
interface User {
  -long type
  +String name
  +updateStatus()
  +updateActive()
  +createStatus()
  +updateDescription()
}
Comment ..> User : "0..1"
Post ..|> Hashtag
note right of Post : Social Media domain
@enduml