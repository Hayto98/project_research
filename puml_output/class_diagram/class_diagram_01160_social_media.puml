@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Post {
  #double score
  #long code
  #String phone
  +calculateCode()
  +updateDescription()
}
class Story {
  -float email
  -long price
  -Date quantity
  +String status
  +deleteScore()
}
interface Comment {
  +Date address
  #String total
  +cancelUpdatedat()
  +createTotal()
  +saveAmount()
  +createCode()
}
class Hashtag {
  +String email
  -Date phone
  +updateEmail()
}
abstract class Report {
  #Date quantity
  #String phone
  -float price
  #Date score
  -float status
  +updateNote()
}
class User {
  -boolean type
  +float description
  +float active
  #Date createdAt
  -Date price
  +getEmail()
  +processUpdatedat()
}
Story --> Comment : "1"
Hashtag --o Post
Comment --|> Post
@enduml