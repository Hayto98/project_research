@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Shipment {
  +double id
  -int status
  #double code
  +validateNote()
  +getEmail()
  +sendAddress()
}
class Supplier {
  -Date email
  -double quantity
  -Date type
  +sendQuantity()
  +cancelDuration()
  +createName()
  +findAddress()
}
abstract class Invoice {
  #boolean amount
  #double id
  +getActive()
  +cancelEmail()
  +getAmount()
  +deleteUpdatedat()
}
abstract class Product {
  -boolean total
  +Date duration
  +double active
  +saveStatus()
  +getCode()
}
class Return {
  -boolean status
  #int createdAt
  -int id
  +Date quantity
  -float note
  +sendTotal()
  +cancelLevel()
  +getId()
  +sendPhone()
}
Shipment ..> Invoice : "0..1"
Invoice ..> Product : "0..1"
@enduml