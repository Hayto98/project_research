@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Shipment {
  +double id
  -int status
  #double code
  +updateDescription()
  +createName()
  +updateEmail()
}
class Supplier {
  #Date total
  -int note
  -float level
  +int address
  +boolean duration
  +sendDuration()
  +calculateStatus()
  +saveLevel()
  +calculateDescription()
}
abstract class Invoice {
  #int level
  -Date active
  +float email
  #long duration
  -Date updatedAt
  +updateId()
}
class Product {
  +Date type
  -float active
  -String createdAt
  -long quantity
  +float updatedAt
  +validateDescription()
}
class Return {
  +int score
  +long updatedAt
  -double type
  +Date phone
  -double id
  +deleteDuration()
  +createLevel()
  +validateAmount()
  +sendPrice()
}
Return --* Product
Supplier --|> Return
Product ..|> Supplier
note right of Shipment : Ecommerce domain
@enduml