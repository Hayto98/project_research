@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
abstract class Manifest {
  #long total
  -String name
  #boolean updatedAt
  +updateTotal()
  +getType()
}
class Driver {
  #boolean quantity
  -String phone
  #Date active
  +getStatus()
  +getEmail()
}
abstract class Vehicle {
  +long phone
  #int type
  +updateDescription()
  +deleteCreatedat()
  +findEmail()
}
class Route {
  +Date code
  +double id
  +validateCreatedat()
  +calculateDescription()
  +deleteActive()
}
class Shipment {
  #String address
  -String description
  +calculateAmount()
  +calculateType()
  +validateQuantity()
}
Driver ..> Vehicle : "*"
Driver --|> Route
@enduml