@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
interface Teacher {
  +double note
  #Date email
  -double level
  +saveAmount()
  +processStatus()
}
class Student {
  -float score
  -int amount
  #Date description
  #String type
  #boolean id
  +deleteAddress()
  +findType()
}
abstract class Book {
  -long note
  +float email
  #String quantity
  #double level
  +saveActive()
  +cancelQuantity()
  +deleteEmail()
  +findDuration()
}
class Attendance {
  -String code
  +long status
  +createPhone()
}
abstract class Classroom {
  #Date status
  +String type
  +setType()
}
abstract class Department {
  +float code
  -Date status
  -boolean active
  +validateScore()
  +saveLevel()
}
Book ..|> Student
Attendance ..|> Teacher
Teacher --|> Classroom
note right of Teacher : Education domain
@enduml