@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
interface Teacher {
  +double note
  #Date email
  -double level
  +getAmount()
  +findId()
}
abstract class Student {
  #int phone
  #int note
  +calculateUpdatedat()
  +processName()
  +findTotal()
  +processStatus()
}
abstract class Book {
  +Date status
  -Date score
  -float createdAt
  +cancelScore()
  +createLevel()
  +updateCode()
  +deleteLevel()
}
class Attendance {
  +float email
  #String quantity
  #double duration
  #double total
  #boolean phone
  +findPhone()
  +cancelPhone()
  +validateTotal()
}
interface Classroom {
  #String score
  +long status
  +findId()
}
class Department {
  -String quantity
  +double phone
  +updateUpdatedat()
}
Teacher --o Attendance
Department --|> Student
@enduml