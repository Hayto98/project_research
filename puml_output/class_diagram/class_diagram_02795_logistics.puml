@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
interface Manifest {
  -Date code
  +String total
  +float email
  +deleteAddress()
  +deleteLevel()
}
class Depot {
  +Date level
  -boolean description
  +int active
  +findPrice()
  +setAddress()
  +calculateType()
  +deleteActive()
}
class Warehouse {
  #float address
  #int level
  -Date description
  +sendDescription()
  +validateScore()
}
abstract class DeliveryNote {
  +boolean total
  +long type
  +long active
  -String score
  +calculateId()
  +cancelDescription()
  +updateQuantity()
  +createPhone()
}
interface Customer {
  -float total
  +String createdAt
  +long name
  -float status
  #long note
  +processStatus()
}
class Inventory {
  #float level
  +String total
  +calculateAmount()
  +setDuration()
}
Depot ..> Warehouse : "1"
Depot ..> DeliveryNote : "0..1"
Inventory ..|> Customer
Depot --o Manifest
@enduml