@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
interface Manifest {
  -Date code
  +String total
  +float email
  +updateAddress()
  +deleteLevel()
}
class Depot {
  +int note
  -boolean score
  +getUpdatedat()
  +validateLevel()
  +deleteScore()
  +updatePhone()
}
class Warehouse {
  #boolean type
  +boolean email
  +long total
  +long duration
  +getScore()
  +processName()
  +findStatus()
  +sendNote()
}
abstract class DeliveryNote {
  -float name
  +String status
  +long note
  +findQuantity()
  +getPhone()
  +deleteDuration()
  +setLevel()
}
abstract class Customer {
  +double id
  -int level
  -Date active
  +updateTotal()
}
interface Inventory {
  +Date score
  +double updatedAt
  -Date active
  +validateType()
  +getId()
}
DeliveryNote --> Depot : "*"
Manifest --o Warehouse
Customer ..> Inventory : "1..*"
Depot --o Manifest
note right of Manifest : Logistics domain
@enduml