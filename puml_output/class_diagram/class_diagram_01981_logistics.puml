@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Shipment {
  -boolean name
  +Date level
  +Date createdAt
  +String code
  +processAmount()
}
class Vehicle {
  #int score
  #Date code
  -String total
  -double name
  +updateDuration()
  +calculateScore()
}
interface Depot {
  +long quantity
  #long amount
  -int duration
  +validateId()
  +saveNote()
}
class Driver {
  +int level
  +boolean score
  +deleteActive()
}
Shipment --|> Depot
@enduml