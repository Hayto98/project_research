@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Shipment {
  -boolean name
  +Date level
  +Date createdAt
  +String code
  +setCreatedat()
}
class Vehicle {
  +float total
  #int level
  +getAddress()
  +processUpdatedat()
  +getEmail()
}
interface Depot {
  +long quantity
  #long amount
  -int duration
  +setCreatedat()
  +savePhone()
}
class Driver {
  -String createdAt
  +boolean name
  +String id
  +setUpdatedat()
}
Vehicle ..> Driver : "1..*"
Driver ..> Vehicle : "1..*"
note right of Shipment : Logistics domain
@enduml