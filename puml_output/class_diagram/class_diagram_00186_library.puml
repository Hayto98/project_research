@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Catalog {
  #double code
  -long level
  +float score
  +double amount
  +deleteId()
  +findQuantity()
  +saveCreatedat()
  +getType()
}
class Shelf {
  +int quantity
  -boolean type
  #String total
  +findLevel()
  +deleteStatus()
}
class Publisher {
  -double createdAt
  -Date level
  #int score
  +deleteStatus()
  +setCreatedat()
  +cancelNote()
}
abstract class Renewal {
  #String phone
  -boolean price
  #long total
  +long code
  -String email
  +processNote()
  +processAddress()
  +cancelPrice()
  +createPrice()
}
class Branch {
  -float description
  -boolean email
  +boolean score
  +sendDescription()
  +processUpdatedat()
  +validateNote()
  +cancelLevel()
}
class Reservation {
  #float description
  +int address
  +sendLevel()
  +cancelNote()
  +processEmail()
}
interface Author {
  +String level
  #String status
  +int type
  -int address
  +setUpdatedat()
  +setType()
  +updateCreatedat()
  +calculateScore()
}
Reservation --* Author
Catalog --o Publisher
Branch --* Author
Author ..|> Renewal
note right of Catalog : Library domain
@enduml