@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Catalog {
  #double code
  -long level
  +float score
  +double amount
  +findPhone()
  +updateDuration()
  +cancelDescription()
  +deleteStatus()
}
class Shelf {
  +long name
  -double type
  +int amount
  +processId()
  +getCreatedat()
  +createPhone()
  +processDuration()
}
interface Publisher {
  +Date status
  #boolean address
  -double createdAt
  +saveDescription()
  +calculateStatus()
  +getTotal()
}
class Renewal {
  #Date status
  #double duration
  -Date createdAt
  +createAmount()
  +setQuantity()
  +sendDuration()
  +calculateStatus()
}
abstract class Branch {
  +long code
  -String email
  -double id
  #double price
  -Date level
  +cancelActive()
  +updateAddress()
  +validateDescription()
}
abstract class Reservation {
  -float price
  #float amount
  -float updatedAt
  -boolean description
  +calculatePrice()
  +processLevel()
}
interface Author {
  -boolean note
  #long updatedAt
  +int phone
  +findType()
  +findDescription()
  +findLevel()
}
Shelf --> Publisher : "*"
Author ..> Renewal : "1..*"
Branch --> Publisher : "1"
@enduml