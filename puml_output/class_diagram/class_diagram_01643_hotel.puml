@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Restaurant {
  -long quantity
  -long id
  -int amount
  +cancelActive()
  +getType()
  +cancelId()
}
class CheckIn {
  #double email
  -Date total
  -float description
  +Date active
  +processPrice()
  +validateActive()
  +getDuration()
  +findUpdatedat()
}
class Amenity {
  +double amount
  -double code
  #int active
  #float phone
  +processName()
  +calculateCreatedat()
}
interface Staff {
  -String total
  -Date code
  #double phone
  +cancelAmount()
}
class CheckOut {
  -double amount
  #double updatedAt
  +Date phone
  +validateCreatedat()
  +getPrice()
}
CheckOut ..|> Restaurant
Staff --> Restaurant : "*"
CheckIn --|> CheckOut
note right of Restaurant : Hotel domain
@enduml