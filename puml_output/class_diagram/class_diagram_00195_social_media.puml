@startuml
skinparam shadowing true
class Like {
  +String address
  #boolean quantity
  +validateId()
}
abstract class Story {
  +long email
  #float price
  +int name
  -int createdAt
  -int total
  +deleteName()
  +sendNote()
  +deleteQuantity()
  +findDescription()
}
interface Notification {
  -float active
  #Date status
  #boolean phone
  +String updatedAt
  +validatePhone()
  +createActive()
  +deleteScore()
}
class Comment {
  -double amount
  -Date duration
  +createPrice()
}
class Group {
  +boolean quantity
  -Date note
  -long code
  +getId()
}
class Message {
  +float score
  +Date active
  #Date type
  +findUpdatedat()
  +calculateQuantity()
  +cancelStatus()
  +deleteDuration()
}
Like --|> Comment
Notification --o Group
Story ..|> Group
Notification --* Message
note right of Like : Social Media domain
@enduml