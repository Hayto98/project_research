@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
interface Vehicle {
  #boolean quantity
  -float updatedAt
  +setUpdatedat()
}
class Manifest {
  -Date note
  -long price
  #String quantity
  -boolean description
  -double email
  +createType()
  +cancelScore()
  +calculateDuration()
}
class Tracking {
  -double name
  +double createdAt
  +calculateId()
  +findStatus()
  +validateCreatedat()
}
class Shipment {
  -double amount
  #boolean type
  #boolean email
  #String level
  #String duration
  +deleteName()
  +validateNote()
  +getId()
}
Vehicle --> Manifest : "1..*"
Shipment ..|> Tracking
Tracking ..> Manifest : "*"
note right of Vehicle : Logistics domain
@enduml