@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
interface Vehicle {
  #boolean quantity
  -float updatedAt
  +validatePhone()
}
class Manifest {
  -int total
  #Date note
  -float price
  +validateTotal()
  +calculatePhone()
  +saveCreatedat()
  +findDescription()
}
class Tracking {
  #long active
  -double quantity
  #boolean total
  -boolean duration
  +validateId()
  +savePhone()
  +getName()
}
class Shipment {
  -String type
  #String id
  -int total
  +boolean address
  +processUpdatedat()
  +createEmail()
  +findUpdatedat()
  +validateName()
}
Shipment --o Vehicle
Shipment --> Tracking : "1"
Vehicle ..|> Manifest
@enduml