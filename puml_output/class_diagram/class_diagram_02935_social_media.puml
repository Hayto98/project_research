@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
abstract class Story {
  -long type
  -long email
  -Date score
  +sendType()
  +findAddress()
  +processStatus()
}
abstract class Report {
  +int type
  +String active
  -boolean createdAt
  -boolean duration
  +sendCreatedat()
}
class Hashtag {
  +Date price
  -String name
  +saveCreatedat()
  +cancelType()
  +sendCreatedat()
}
class Profile {
  +double code
  -int updatedAt
  +Date phone
  #boolean total
  +int quantity
  +createId()
  +findStatus()
  +saveTotal()
}
abstract class User {
  #boolean status
  -String description
  -boolean id
  +Date amount
  -int phone
  +calculateDuration()
  +findTotal()
  +createDescription()
}
interface Message {
  #float note
  +Date active
  #int score
  +setActive()
  +setPrice()
  +validateCode()
  +getAmount()
}
abstract class Post {
  #Date description
  -float note
  -boolean phone
  #String updatedAt
  #String email
  +deleteCreatedat()
  +updateLevel()
  +calculateActive()
}
Hashtag --|> Message
Hashtag --|> Profile
Post --> User : "1"
@enduml