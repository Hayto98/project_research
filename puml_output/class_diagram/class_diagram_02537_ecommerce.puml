@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Warehouse {
  -long score
  #boolean status
  +sendEmail()
  +savePrice()
  +findScore()
}
class Order {
  -Date description
  +long total
  -float type
  +createTotal()
  +updateAmount()
}
abstract class Supplier {
  -int duration
  +Date email
  -double id
  -float updatedAt
  +createAddress()
  +processTotal()
  +getPrice()
  +getEmail()
}
class Wishlist {
  #Date phone
  #boolean code
  #float total
  +float level
  +int updatedAt
  +cancelCreatedat()
}
Wishlist --> Order : "1"
Warehouse --|> Wishlist
note right of Warehouse : Ecommerce domain
@enduml