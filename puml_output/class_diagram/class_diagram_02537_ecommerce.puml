@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Warehouse {
  -long score
  #boolean status
  +cancelAmount()
  +deleteName()
  +setScore()
}
abstract class Order {
  -Date updatedAt
  -double description
  +sendPhone()
}
abstract class Supplier {
  +double email
  -float total
  #long updatedAt
  +savePrice()
}
class Wishlist {
  -float createdAt
  -long description
  -double phone
  -float note
  +saveName()
}
Supplier ..> Order : "*"
Supplier ..> Warehouse : "*"
@enduml