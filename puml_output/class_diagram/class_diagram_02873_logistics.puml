@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class FuelLog {
  -String description
  -double createdAt
  -float total
  +double active
  +calculateAmount()
}
class Route {
  #int description
  -float code
  -int price
  +calculateUpdatedat()
}
class Shipment {
  #long score
  +boolean description
  -String active
  +findPrice()
  +setName()
  +getName()
  +calculateNote()
}
interface Inventory {
  -long amount
  +double createdAt
  +processDuration()
  +calculateName()
  +updateName()
}
Shipment ..|> Route
Route ..> Shipment : "1..*"
@enduml