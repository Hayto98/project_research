@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class FuelLog {
  -String description
  -double createdAt
  -float total
  +double active
  +processCode()
}
class Route {
  -float code
  -int price
  +Date updatedAt
  +updateScore()
  +deleteActive()
  +saveEmail()
}
class Shipment {
  #String id
  +int note
  -long active
  +double duration
  -int createdAt
  +setDescription()
  +createAddress()
  +deleteUpdatedat()
}
class Inventory {
  +double amount
  #boolean score
  -float updatedAt
  +calculateActive()
}
Shipment ..> Inventory : "*"
Inventory --* Shipment
note right of FuelLog : Logistics domain
@enduml