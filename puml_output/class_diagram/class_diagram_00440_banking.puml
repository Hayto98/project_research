@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Statement {
  -float note
  #double updatedAt
  +getDescription()
}
abstract class Branch {
  -double type
  -String level
  -float code
  +getType()
  +calculateCreatedat()
  +validateAmount()
  +setCode()
}
class Loan {
  -double score
  +long active
  -Date createdAt
  +String phone
  -String type
  +saveTotal()
  +findActive()
}
class Deposit {
  +int score
  +long quantity
  +processCreatedat()
  +findPrice()
  +validateAddress()
  +setActive()
}
class Transaction {
  +double updatedAt
  -double name
  +Date email
  +Date amount
  +saveCode()
  +updateActive()
  +setPhone()
  +createStatus()
}
Branch --|> Transaction
Statement --* Branch
@enduml