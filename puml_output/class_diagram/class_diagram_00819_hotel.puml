@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
abstract class Restaurant {
  -boolean total
  #float amount
  -int quantity
  +boolean type
  +createPhone()
  +findCode()
  +validateName()
}
abstract class Guest {
  #String type
  +Date quantity
  #long amount
  -double score
  #int phone
  +cancelEmail()
}
class Amenity {
  -Date code
  +Date note
  -Date type
  +float email
  +saveStatus()
  +cancelCreatedat()
}
abstract class Invoice {
  -float score
  #boolean price
  +Date id
  +validateName()
  +processType()
  +processPhone()
  +findPrice()
}
Amenity --|> Guest
Restaurant --|> Guest
note right of Restaurant : Hotel domain
@enduml