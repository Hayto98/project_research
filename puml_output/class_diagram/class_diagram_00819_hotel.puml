@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
abstract class Restaurant {
  -boolean total
  #float amount
  -int quantity
  +boolean type
  +calculateScore()
  +findCode()
  +deleteType()
}
class Guest {
  #Date name
  -boolean total
  +int level
  -Date type
  +validateQuantity()
}
class Amenity {
  #long note
  #int score
  #long amount
  +double id
  +cancelDescription()
  +deleteId()
  +validateAddress()
  +deleteName()
}
class Invoice {
  #int createdAt
  -boolean level
  +float updatedAt
  #boolean status
  +updateActive()
  +validateUpdatedat()
  +calculateType()
  +updateNote()
}
Invoice --|> Guest
@enduml