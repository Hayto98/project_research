@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Inventory {
  -float updatedAt
  #boolean active
  +getStatus()
  +validateNote()
}
class Warehouse {
  +int code
  +int updatedAt
  -boolean amount
  -float description
  #long email
  +getDescription()
  +deleteCode()
}
class Depot {
  +long score
  +boolean updatedAt
  -int address
  -double total
  +createCode()
  +getNote()
  +validateName()
  +sendStatus()
}
interface Manifest {
  -long note
  -Date total
  #String code
  +boolean quantity
  +createNote()
}
class Tracking {
  +int quantity
  #long description
  +saveLevel()
  +cancelCode()
  +calculatePhone()
  +cancelStatus()
}
abstract class DeliveryNote {
  #String price
  #String id
  #int code
  +createDescription()
  +saveCode()
}
interface FuelLog {
  -int active
  #String address
  +double description
  +deleteCode()
  +calculateQuantity()
  +createId()
  +validateCode()
}
Depot ..> Inventory : "0..1"
Tracking --* FuelLog
FuelLog --o Warehouse
DeliveryNote ..> Inventory : "1"
Tracking --> Manifest : "*"
@enduml