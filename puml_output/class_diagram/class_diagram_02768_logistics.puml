@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Warehouse {
  +Date amount
  -double note
  +boolean address
  #int updatedAt
  +cancelAmount()
  +sendLevel()
  +sendStatus()
  +deleteCreatedat()
}
class FuelLog {
  +String duration
  +float address
  #long price
  +updateEmail()
  +saveId()
  +updateAmount()
  +updateUpdatedat()
}
class Driver {
  #double active
  #double status
  -String email
  -int description
  +getCode()
}
class Customer {
  -boolean phone
  +double level
  #String description
  +setActive()
  +findActive()
  +findUpdatedat()
  +setUpdatedat()
}
interface Vehicle {
  -boolean status
  -boolean name
  +double type
  +cancelStatus()
  +processCreatedat()
  +processId()
}
class Tracking {
  -Date address
  #Date score
  #double duration
  -float quantity
  +calculateQuantity()
  +updateName()
  +deleteQuantity()
  +calculateNote()
}
Driver ..|> Tracking
Driver --* Customer
Customer --> Vehicle : "0..1"
Customer --o Driver
Tracking --|> Vehicle
note right of Warehouse : Logistics domain
@enduml