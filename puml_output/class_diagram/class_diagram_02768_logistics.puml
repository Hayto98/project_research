@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Warehouse {
  +Date amount
  -double note
  +boolean address
  #int updatedAt
  +cancelActive()
  +cancelPrice()
  +processUpdatedat()
  +processCreatedat()
}
interface FuelLog {
  +int description
  #boolean createdAt
  +validatePrice()
  +calculateCode()
  +sendStatus()
}
class Driver {
  -Date createdAt
  -int score
  +cancelScore()
  +deleteLevel()
  +setName()
}
class Customer {
  -Date createdAt
  #Date updatedAt
  +long id
  +findUpdatedat()
  +sendCode()
}
abstract class Vehicle {
  +int status
  #int type
  -boolean description
  +float code
  -boolean name
  +getAddress()
  +processEmail()
}
class Tracking {
  #int code
  #int active
  +String level
  #double updatedAt
  -boolean status
  +saveDuration()
  +setDescription()
  +sendScore()
  +validateAmount()
}
Customer --o FuelLog
Warehouse --* Driver
@enduml