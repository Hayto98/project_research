@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
abstract class Customer {
  -String status
  #double price
  +findActive()
  +updatePhone()
  +updateDescription()
  +processStatus()
}
abstract class Withdrawal {
  -String name
  #String level
  +createType()
  +updateQuantity()
  +findUpdatedat()
  +createDescription()
}
class Transaction {
  +int name
  +Date active
  -double phone
  -Date updatedAt
  +float total
  +saveAddress()
  +calculatePrice()
}
abstract class Beneficiary {
  +long description
  +int phone
  +setUpdatedat()
  +cancelDuration()
  +validateDuration()
  +setType()
}
abstract class Loan {
  #boolean type
  +boolean quantity
  #float description
  -Date code
  -long status
  +findCode()
  +setEmail()
  +processDuration()
  +calculateQuantity()
}
Loan --* Customer
Customer --|> Loan
Transaction ..|> Customer
@enduml