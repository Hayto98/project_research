@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
abstract class Customer {
  -String status
  #double price
  +processCreatedat()
  +validatePrice()
  +findId()
  +getLevel()
}
abstract class Withdrawal {
  -Date active
  #boolean id
  +calculateName()
}
interface Transaction {
  +Date updatedAt
  -double total
  -Date amount
  +float description
  +deleteScore()
  +processScore()
}
class Beneficiary {
  +int phone
  -String createdAt
  #long email
  +deletePrice()
  +processType()
  +createDescription()
}
interface Loan {
  #String status
  #boolean active
  +saveTotal()
  +createLevel()
  +calculatePhone()
  +validateUpdatedat()
}
Loan --* Customer
Customer --|> Loan
Transaction ..|> Customer
note right of Customer : Banking domain
@enduml