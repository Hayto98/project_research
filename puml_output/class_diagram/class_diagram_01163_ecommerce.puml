@startuml
skinparam monochrome true
skinparam ArrowColor #555555
interface Product {
  -double note
  +long updatedAt
  +long total
  -Date code
  +sendEmail()
  +sendDescription()
  +sendDuration()
}
class Invoice {
  #String total
  -String id
  +getType()
  +calculateLevel()
  +calculatePrice()
}
class Warehouse {
  #float score
  #int code
  #float id
  #int email
  -float description
  +processQuantity()
  +saveActive()
  +validateStatus()
}
class Order {
  #float duration
  -String address
  +Date note
  +boolean updatedAt
  +calculateType()
  +calculateAmount()
  +getUpdatedat()
}
class Return {
  +Date updatedAt
  -long description
  +validateLevel()
  +updateActive()
}
abstract class Cart {
  -double id
  +float phone
  #Date active
  -Date email
  +Date status
  +updateNote()
  +setDescription()
  +updateAmount()
  +calculateEmail()
}
Invoice --o Product
Cart ..> Product : "1"
@enduml