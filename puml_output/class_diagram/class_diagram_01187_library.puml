@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
interface Librarian {
  #int total
  #float status
  #float duration
  +createCreatedat()
  +validateStatus()
  +updateName()
  +sendAddress()
}
abstract class Catalog {
  -int quantity
  +float total
  +getCode()
  +createQuantity()
  +setId()
  +calculateQuantity()
}
class Member {
  +double id
  -double email
  +validateScore()
  +getNote()
  +findActive()
  +calculatePhone()
}
abstract class Author {
  -String active
  #float quantity
  +double updatedAt
  -boolean phone
  -float score
  +validateCode()
}
Librarian ..> Member : "*"
Catalog ..|> Librarian
Member --|> Catalog
@enduml