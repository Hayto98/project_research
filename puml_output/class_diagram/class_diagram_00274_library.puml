@startuml

abstract class Publisher {
  -Date updatedAt
  #Date createdAt
  #int address
  -float code
  +findCode()
  +validateCreatedat()
  +validateActive()
}
class Author {
  +Date status
  #int total
  +long address
  -Date score
  -long description
  +calculateEmail()
  +getName()
}
class Librarian {
  #int address
  +float code
  -double createdAt
  +getAmount()
  +deleteNote()
  +createNote()
  +processAddress()
}
class Loan {
  -String status
  +long note
  +deleteNote()
}
Publisher ..> Author : "1"
Librarian ..> Loan : "*"
@enduml