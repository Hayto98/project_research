@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
abstract class Customer {
  #String active
  -double name
  +deletePhone()
  +getCode()
}
class Teller {
  +Date updatedAt
  -long note
  #long price
  +int quantity
  -boolean active
  +deleteActive()
  +processDuration()
}
abstract class Loan {
  #int quantity
  +Date score
  +validateAddress()
  +findPrice()
  +processQuantity()
}
class Account {
  +float note
  #float email
  +createStatus()
  +updateStatus()
  +validatePrice()
  +sendCreatedat()
}
class Beneficiary {
  #double code
  -String phone
  +long level
  +int name
  +createDescription()
  +saveScore()
  +getActive()
}
class Interest {
  #int phone
  +double name
  +Date amount
  +saveNote()
  +updateEmail()
}
Customer ..> Account : "0..1"
Loan --|> Teller
Interest --o Account
@enduml