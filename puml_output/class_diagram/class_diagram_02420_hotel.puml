@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Booking {
  #long type
  -int score
  -double description
  +float address
  +getDescription()
}
class Restaurant {
  +String total
  -int email
  +saveId()
}
class CheckOut {
  #Date note
  #float name
  +getPhone()
  +createActive()
  +createDuration()
  +createType()
}
class Service {
  -float updatedAt
  -Date phone
  +calculateStatus()
  +sendEmail()
  +updateName()
}
Booking --o Service
Booking ..|> Restaurant
Booking ..|> CheckOut
note right of Booking : Hotel domain
@enduml