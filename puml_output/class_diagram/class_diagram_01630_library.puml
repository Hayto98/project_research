@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Loan {
  #double code
  +Date active
  #boolean createdAt
  -double amount
  +getScore()
  +updatePrice()
}
abstract class Author {
  -Date quantity
  #int duration
  #boolean total
  -double note
  +cancelActive()
  +deleteName()
  +processPhone()
  +updateAddress()
}
class Reservation {
  +float duration
  -double price
  #String createdAt
  -String address
  +saveName()
  +savePrice()
  +sendCreatedat()
  +updateId()
}
interface Librarian {
  +Date name
  #int address
  +createQuantity()
}
class Branch {
  +float status
  -boolean description
  -float code
  +updateDescription()
  +sendLevel()
  +saveNote()
  +setPrice()
}
abstract class Fine {
  +boolean amount
  +float description
  #long price
  +double id
  +setDuration()
  +createCode()
  +setEmail()
}
Author ..> Reservation : "1..*"
Loan --* Reservation
Author --o Loan
Librarian ..|> Loan
Librarian --|> Fine
note right of Loan : Library domain
@enduml