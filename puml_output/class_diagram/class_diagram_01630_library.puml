@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Loan {
  #double code
  +Date active
  #boolean createdAt
  -double amount
  +processCode()
  +saveStatus()
}
interface Author {
  -float price
  -double note
  #double quantity
  +validateTotal()
  +sendUpdatedat()
  +processDuration()
}
interface Reservation {
  +double note
  -int score
  -String type
  -boolean active
  -float description
  +setAmount()
  +validateScore()
}
class Librarian {
  #String type
  #float id
  #double duration
  #int level
  +String price
  +setUpdatedat()
}
class Branch {
  #String duration
  -long description
  +sendLevel()
  +createId()
}
class Fine {
  +float description
  -boolean code
  +getDescription()
  +calculateQuantity()
  +createScore()
}
Branch ..> Fine : "*"
Loan ..> Librarian : "*"
Reservation ..|> Author
@enduml