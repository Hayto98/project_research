@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
abstract class Statement {
  +long updatedAt
  #int duration
  +boolean createdAt
  +String amount
  +deleteTotal()
  +getPhone()
}
abstract class Card {
  +int phone
  +double address
  -String email
  -float code
  +double quantity
  +deleteTotal()
  +saveNote()
  +createScore()
}
interface Loan {
  -long level
  +boolean note
  +calculateName()
}
class Deposit {
  -float type
  +long status
  #double description
  +findPhone()
}
class Customer {
  -String price
  #Date address
  +Date description
  +double createdAt
  #float name
  +createCode()
}
Customer ..> Statement : "0..1"
Customer ..|> Deposit
Deposit ..> Customer : "*"
Customer --|> Card
note right of Statement : Banking domain
@enduml