@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Loan {
  +int quantity
  -long email
  +long price
  +saveUpdatedat()
  +cancelEmail()
  +calculateScore()
  +sendCreatedat()
}
class Publisher {
  +float score
  -String address
  -Date price
  +findTotal()
  +processName()
  +findLevel()
  +calculateActive()
}
interface Reservation {
  -Date address
  -float name
  -String amount
  -boolean code
  #double note
  +saveId()
}
class Book {
  -int score
  #int price
  +Date active
  #Date id
  +validateTotal()
  +getScore()
}
abstract class Author {
  +Date address
  -float type
  -boolean id
  #Date level
  #double active
  +calculatePrice()
}
Loan ..> Book : "0..1"
Book ..|> Publisher
Publisher --o Author
Book ..> Reservation : "*"
@enduml