@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Loan {
  +int quantity
  -long email
  +long price
  +saveStatus()
  +createType()
  +deleteDescription()
  +sendAddress()
}
abstract class Publisher {
  -Date price
  #float id
  +getActive()
  +cancelNote()
  +validateName()
  +cancelAmount()
}
class Reservation {
  #boolean phone
  -String address
  +String level
  #long name
  #Date price
  +sendId()
  +processDescription()
  +sendDescription()
  +getScore()
}
interface Book {
  -float active
  #double price
  +Date total
  +processDescription()
  +findPhone()
  +validateDuration()
  +sendPrice()
}
class Author {
  #double price
  #boolean amount
  +updateDescription()
  +deleteTotal()
}
Reservation ..> Book : "*"
Loan --|> Book
Book --o Reservation
note right of Loan : Library domain
@enduml