@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
abstract class Patient {
  #String updatedAt
  -long amount
  #int quantity
  -double description
  +setPhone()
  +calculateType()
  +saveAddress()
}
class Appointment {
  +int phone
  #String active
  -String address
  +long email
  +validateName()
  +processUpdatedat()
  +getType()
}
class Diagnosis {
  -float note
  #boolean address
  +saveCreatedat()
  +cancelType()
  +getCode()
  +setScore()
}
class Billing {
  +Date type
  +double description
  +int email
  +saveDescription()
}
class Ward {
  +float createdAt
  +float status
  +processLevel()
}
Diagnosis --> Ward : "1..*"
Ward --o Patient
Billing ..> Diagnosis : "1..*"
note right of Patient : Healthcare domain
@enduml