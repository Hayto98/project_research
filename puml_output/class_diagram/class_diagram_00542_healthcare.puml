@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
abstract class Patient {
  #String updatedAt
  -long amount
  #int quantity
  -double description
  +setPrice()
  +cancelStatus()
  +processStatus()
}
abstract class Appointment {
  #long address
  +int quantity
  #String duration
  -String phone
  +long score
  +findQuantity()
  +deleteTotal()
  +calculateType()
}
class Diagnosis {
  -long updatedAt
  -float id
  #boolean type
  #double createdAt
  #float status
  +deleteDescription()
  +getId()
}
class Billing {
  +float status
  +double score
  +deleteCreatedat()
  +getEmail()
}
class Ward {
  +int updatedAt
  +int createdAt
  +float name
  +double description
  #long status
  +deleteName()
  +findUpdatedat()
  +sendStatus()
}
Diagnosis --o Patient
Billing ..> Diagnosis : "1..*"
Billing ..> Ward : "1"
Diagnosis --> Ward : "1..*"
@enduml