@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Doctor {
  -boolean createdAt
  -Date phone
  +double quantity
  #double id
  +boolean active
  +createAmount()
  +setQuantity()
  +getAddress()
}
class Insurance {
  +boolean name
  +String phone
  #double total
  +saveAddress()
}
abstract class Treatment {
  +long id
  -Date duration
  -float level
  -long address
  +createCode()
}
abstract class Appointment {
  +float total
  #Date code
  +setActive()
  +updateDuration()
  +saveScore()
}
interface LabTest {
  #long quantity
  -float code
  -Date total
  +boolean type
  +int amount
  +setEmail()
}
Treatment --o LabTest
Insurance ..|> Appointment
LabTest --> Treatment : "1..*"
Treatment --* Appointment
@enduml