@startuml
skinparam defaultFontSize 13
class Customer {
  -Date name
  -float createdAt
  -boolean type
  #long id
  +validateDescription()
}
class Tracking {
  #Date status
  -double code
  +processName()
}
class Inventory {
  #boolean duration
  -float updatedAt
  +createAddress()
}
abstract class FuelLog {
  -int score
  -double id
  +boolean level
  -long type
  +cancelCode()
  +findScore()
  +getCode()
}
abstract class Warehouse {
  -String duration
  -long type
  +createTotal()
  +validateNote()
  +findLevel()
  +processStatus()
}
interface Route {
  +Date id
  #long description
  +long quantity
  #boolean total
  +deletePrice()
  +setType()
  +deleteAddress()
  +calculateDescription()
}
abstract class Manifest {
  -int name
  +double email
  -float total
  #Date level
  -int type
  +createPrice()
  +sendAddress()
}
Tracking --|> Warehouse
Inventory --> Manifest : "0..1"
FuelLog --* Customer
Manifest --> Warehouse : "1..*"
note right of Customer : Logistics domain
@enduml