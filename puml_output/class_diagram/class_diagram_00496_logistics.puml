@startuml
skinparam defaultFontSize 13
class Customer {
  -Date name
  -float createdAt
  -boolean type
  #long id
  +processStatus()
}
class Tracking {
  -String code
  -String status
  +String duration
  #float quantity
  +cancelActive()
  +validateActive()
}
abstract class Inventory {
  -long quantity
  #String address
  +sendStatus()
}
abstract class FuelLog {
  -long amount
  #String quantity
  #boolean price
  +String createdAt
  -boolean score
  +sendActive()
}
abstract class Warehouse {
  #boolean name
  -long total
  -float email
  -double active
  +deleteQuantity()
  +sendQuantity()
  +calculateCreatedat()
  +cancelTotal()
}
class Route {
  -Date total
  #double code
  +Date phone
  -String status
  +createCode()
  +createId()
  +findQuantity()
  +sendScore()
}
class Manifest {
  #double price
  -int name
  +double email
  -float total
  #Date score
  +validateNote()
  +updateDescription()
  +validateAddress()
  +createDuration()
}
Route --* Inventory
Tracking --|> Warehouse
Inventory --> Manifest : "0..1"
FuelLog --* Customer
Manifest --> Warehouse : "1..*"
Customer --o FuelLog
@enduml