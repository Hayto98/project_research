@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Appointment {
  #String quantity
  +double phone
  +String active
  +processAmount()
  +saveUpdatedat()
  +updateUpdatedat()
}
interface Patient {
  #double createdAt
  #Date type
  +Date quantity
  -int updatedAt
  +cancelQuantity()
  +getEmail()
}
abstract class Insurance {
  #String code
  -double score
  +saveLevel()
  +validateLevel()
  +setId()
}
interface Nurse {
  #boolean active
  -float phone
  +Date address
  +findActive()
}
abstract class Hospital {
  +boolean email
  #long name
  -double level
  +setDuration()
  +sendAddress()
  +validateNote()
  +createCode()
}
class Ward {
  #String updatedAt
  +double active
  -float code
  #Date amount
  +findCode()
  +validatePrice()
  +findPrice()
  +updateType()
}
class Doctor {
  #String duration
  #double id
  +String score
  +int description
  +int createdAt
  +updateDuration()
  +updateActive()
  +createLevel()
}
Patient --> Insurance : "0..1"
Nurse ..> Ward : "1..*"
note right of Appointment : Healthcare domain
@enduml