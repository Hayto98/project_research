@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Appointment {
  #String quantity
  +double phone
  +String active
  +getId()
  +findId()
  +validateLevel()
}
class Patient {
  #double updatedAt
  -int phone
  #double createdAt
  +saveUpdatedat()
  +processDescription()
}
class Insurance {
  -double duration
  +String quantity
  #Date id
  +saveScore()
}
abstract class Nurse {
  #boolean level
  +float address
  #long code
  #long id
  +calculateLevel()
  +deleteLevel()
  +validateLevel()
  +updatePrice()
}
class Hospital {
  #float createdAt
  #long email
  -double name
  -String score
  #boolean amount
  +calculateName()
  +deletePrice()
  +cancelPhone()
}
class Ward {
  +Date address
  +int updatedAt
  -long active
  #Date code
  +findType()
  +calculateDescription()
  +getLevel()
  +setEmail()
}
abstract class Doctor {
  #Date updatedAt
  #Date type
  +boolean description
  +boolean price
  +boolean id
  +processQuantity()
  +setQuantity()
  +setDescription()
  +processUpdatedat()
}
Patient --* Hospital
Doctor --> Patient : "0..1"
Hospital ..> Insurance : "1"
@enduml