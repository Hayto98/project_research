@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Tracking {
  +long code
  -int id
  +updateAddress()
  +validateCreatedat()
}
class FuelLog {
  -boolean level
  #double id
  +Date type
  -boolean address
  +saveUpdatedat()
  +saveQuantity()
  +setQuantity()
  +cancelTotal()
}
abstract class Customer {
  #String type
  +String duration
  +validateCreatedat()
  +validatePhone()
  +deleteAddress()
  +savePhone()
}
abstract class Depot {
  #String address
  -String id
  -long level
  +cancelStatus()
  +validateUpdatedat()
  +setAmount()
}
Depot --> Customer : "1"
Tracking --* FuelLog
@enduml