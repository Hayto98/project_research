@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Insurance {
  +boolean code
  #String price
  #double status
  -double duration
  +createEmail()
  +validateNote()
  +setName()
  +createDescription()
}
class Hospital {
  -boolean level
  +long amount
  +int description
  -boolean createdAt
  +float updatedAt
  +validateCreatedat()
}
class Appointment {
  #double status
  +Date updatedAt
  #int email
  -Date total
  #float duration
  +updatePhone()
  +processEmail()
  +sendType()
  +createPhone()
}
class Patient {
  +Date active
  +String quantity
  #long id
  #String createdAt
  +sendType()
}
abstract class Billing {
  #int level
  #float createdAt
  +int type
  +createDescription()
  +calculateNote()
}
Appointment ..> Billing : "1"
Insurance --o Patient
Patient ..|> Appointment
@enduml