@startuml
skinparam defaultFontSize 13
class Shelf {
  #float address
  -boolean description
  +long duration
  -float quantity
  #double status
  +getAmount()
  +sendQuantity()
}
class Catalog {
  -Date id
  #Date score
  +setUpdatedat()
  +sendUpdatedat()
  +validateTotal()
  +calculatePhone()
}
class Renewal {
  #boolean phone
  #long id
  -int address
  +cancelType()
  +updatePhone()
  +processAmount()
  +validateUpdatedat()
}
class Book {
  -Date code
  +float address
  -boolean amount
  +findPrice()
  +cancelDescription()
}
interface Member {
  +double type
  #String duration
  +cancelAmount()
  +updateAddress()
  +getDuration()
  +sendDescription()
}
class Publisher {
  -float phone
  #double code
  -double updatedAt
  #double description
  -boolean type
  +updateName()
  +setActive()
  +calculateTotal()
  +createActive()
}
Catalog --> Book : "*"
Publisher --|> Renewal
Shelf --* Member
@enduml