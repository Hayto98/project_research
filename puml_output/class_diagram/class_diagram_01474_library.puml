@startuml
skinparam defaultFontSize 13
class Shelf {
  #float address
  -boolean description
  +long duration
  -float quantity
  #double status
  +saveActive()
  +deleteId()
}
class Catalog {
  #int level
  -String price
  #Date name
  -boolean quantity
  #Date score
  +createDescription()
  +findScore()
  +saveNote()
}
class Renewal {
  -Date name
  +float description
  -boolean code
  #int address
  #Date amount
  +saveType()
}
abstract class Book {
  -boolean type
  #float id
  +calculatePhone()
}
class Member {
  #double description
  -double type
  #double phone
  +sendLevel()
  +cancelNote()
  +setAddress()
}
class Publisher {
  #float note
  -Date level
  -String score
  +cancelEmail()
}
Renewal --o Shelf
Publisher --o Shelf
note right of Shelf : Library domain
@enduml