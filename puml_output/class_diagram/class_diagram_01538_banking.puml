@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Deposit {
  #float email
  -String amount
  +String updatedAt
  +String duration
  +cancelTotal()
}
abstract class Loan {
  #boolean updatedAt
  -int address
  +saveQuantity()
  +calculateName()
}
class Account {
  -double code
  #double level
  -long status
  #Date active
  +updateQuantity()
  +sendScore()
  +updateAddress()
  +sendPhone()
}
abstract class Transfer {
  #float address
  #int active
  +deleteStatus()
  +createDescription()
}
class Interest {
  +boolean description
  #double updatedAt
  #float email
  +cancelNote()
}
Deposit --* Interest
Transfer --* Loan
Transfer --> Interest : "1"
@enduml