@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Deposit {
  #float email
  -String amount
  +String updatedAt
  +String duration
  +getPrice()
}
interface Loan {
  #boolean updatedAt
  -int address
  +deleteAddress()
  +updatePhone()
}
class Account {
  -boolean active
  -double phone
  +sendDuration()
  +processPrice()
  +savePhone()
}
abstract class Transfer {
  #float address
  #int active
  +saveActive()
  +createActive()
}
class Interest {
  #boolean updatedAt
  -float email
  #float id
  +updateActive()
}
Deposit --o Account
Interest --* Loan
note right of Deposit : Banking domain
@enduml