@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
abstract class Reservation {
  #boolean type
  -int id
  -String address
  #Date name
  +validateAddress()
  +updateStatus()
  +validateActive()
  +cancelCode()
}
class Fine {
  #Date code
  #int level
  +boolean quantity
  +int note
  -double name
  +cancelAddress()
  +cancelPrice()
  +setPrice()
  +updateUpdatedat()
}
abstract class Member {
  -boolean id
  -boolean code
  +int amount
  +processType()
  +saveAmount()
  +saveId()
}
class Author {
  +boolean type
  -int total
  #int email
  -Date description
  +processPhone()
  +sendUpdatedat()
  +validateScore()
  +findAddress()
}
class Renewal {
  #String email
  +int phone
  -Date duration
  +getPhone()
  +updateLevel()
  +sendUpdatedat()
  +validateCreatedat()
}
class Publisher {
  +boolean score
  -boolean quantity
  #long description
  +createLevel()
  +calculateLevel()
  +setAmount()
}
Reservation ..> Member : "*"
Member ..|> Reservation
Publisher --> Member : "*"
Reservation --* Fine
Fine --|> Publisher
@enduml