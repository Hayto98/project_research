@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Loan {
  -long amount
  +int address
  #Date note
  -boolean id
  +cancelAddress()
}
class Shelf {
  #int code
  +long amount
  -int status
  #int address
  +validateLevel()
}
interface Publisher {
  +double duration
  #int address
  +setEmail()
}
class Librarian {
  +double price
  -String updatedAt
  +boolean amount
  +int active
  +cancelDescription()
  +setCreatedat()
  +validateStatus()
  +setStatus()
}
Librarian ..> Shelf : "*"
@enduml