@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Loan {
  -long amount
  +int address
  #Date note
  -boolean id
  +createCode()
}
class Shelf {
  -Date amount
  +int status
  +createCreatedat()
  +sendCreatedat()
  +getLevel()
}
class Publisher {
  #String amount
  -long type
  -Date score
  -int description
  +sendDescription()
  +calculatePhone()
}
class Librarian {
  +float duration
  #boolean status
  +findStatus()
  +updateScore()
  +calculateNote()
  +saveLevel()
}
Librarian ..|> Shelf
Shelf --o Loan
Librarian --o Publisher
note right of Loan : Library domain
@enduml