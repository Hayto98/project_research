@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
interface Customer {
  #float quantity
  +String email
  -double status
  +String createdAt
  +cancelPrice()
  +findType()
  +processAmount()
}
abstract class Shipment {
  -boolean updatedAt
  +Date amount
  -boolean note
  +cancelName()
  +findType()
  +setDescription()
  +saveId()
}
class Inventory {
  #long active
  #Date id
  -boolean email
  #boolean description
  #double price
  +setId()
}
class Depot {
  +boolean amount
  +long createdAt
  +Date id
  -double score
  #float updatedAt
  +getCode()
  +calculateLevel()
  +cancelPrice()
}
Depot --|> Customer
Shipment --|> Inventory
@enduml