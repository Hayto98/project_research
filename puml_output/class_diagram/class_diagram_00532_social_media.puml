@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Group {
  #long quantity
  +boolean id
  +updateNote()
  +calculateNote()
}
class Hashtag {
  -String updatedAt
  -float active
  -boolean email
  +validateEmail()
}
class Like {
  +Date active
  #String score
  +String note
  +boolean duration
  +updateCode()
}
interface Profile {
  -float createdAt
  #boolean amount
  -long updatedAt
  +String level
  +deleteActive()
  +validateUpdatedat()
  +findUpdatedat()
}
abstract class Report {
  -Date createdAt
  -Date duration
  #float description
  #boolean type
  -double status
  +setCreatedat()
}
class Post {
  +long description
  +String duration
  +validateTotal()
  +calculateLevel()
  +setActive()
  +getDescription()
}
Like --o Hashtag
Hashtag --* Profile
Like ..|> Profile
note right of Group : Social Media domain
@enduml