@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Group {
  #long quantity
  +boolean id
  +updateDescription()
  +saveAmount()
}
abstract class Hashtag {
  -String description
  -float duration
  -boolean updatedAt
  #String active
  -Date email
  +updatePhone()
  +findScore()
  +validateDuration()
}
interface Like {
  +boolean active
  +int name
  #float level
  +boolean id
  -int code
  +processScore()
  +setDuration()
}
class Profile {
  +String quantity
  -float price
  +boolean address
  +sendNote()
  +setCreatedat()
  +createScore()
}
abstract class Report {
  -Date createdAt
  -Date duration
  #float description
  #boolean type
  -double status
  +processAmount()
}
class Post {
  +int status
  -String description
  +getScore()
}
Like --o Profile
Report --> Group : "1"
Hashtag ..|> Report
Like --o Hashtag
Hashtag --* Profile
@enduml