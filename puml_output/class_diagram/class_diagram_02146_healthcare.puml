@startuml
skinparam monochrome true
skinparam defaultFontSize 11
abstract class Billing {
  +float price
  -boolean updatedAt
  +sendLevel()
  +updateType()
  +getPrice()
}
class MedicalRecord {
  #boolean price
  +int level
  +calculateTotal()
  +deleteCode()
  +findQuantity()
  +deleteEmail()
}
class Doctor {
  -int price
  +Date code
  +cancelUpdatedat()
  +createAmount()
}
abstract class Diagnosis {
  #Date id
  #float quantity
  +Date description
  +validateDescription()
}
class Treatment {
  -long description
  +String level
  #String phone
  +long address
  +getTotal()
  +setName()
}
Doctor --* Billing
Treatment --* Diagnosis
@enduml