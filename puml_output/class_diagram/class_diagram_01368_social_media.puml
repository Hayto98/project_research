@startuml
skinparam defaultFontSize 11
abstract class Profile {
  -int createdAt
  #int address
  #boolean note
  +double level
  +String duration
  +setUpdatedat()
  +deleteAmount()
  +calculateName()
}
interface Notification {
  #float id
  +Date type
  +validateUpdatedat()
  +setActive()
  +updateQuantity()
  +deleteAmount()
}
class Album {
  #boolean updatedAt
  -boolean createdAt
  #String code
  +deleteStatus()
}
abstract class Post {
  #String description
  -Date type
  -String updatedAt
  #int id
  #boolean email
  +updateCode()
  +sendAddress()
}
interface Hashtag {
  #double createdAt
  -double status
  #boolean updatedAt
  -int phone
  +validateQuantity()
}
class Message {
  #int createdAt
  +Date name
  +float quantity
  +processQuantity()
}
class Follower {
  -boolean total
  +boolean level
  +getScore()
  +cancelActive()
  +updateScore()
}
Album --|> Post
Profile ..|> Album
Notification --> Album : "1"
@enduml