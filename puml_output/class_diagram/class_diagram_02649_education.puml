@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Book {
  -float createdAt
  #long score
  #Date address
  #Date code
  #String status
  +sendEmail()
}
class Teacher {
  -int score
  +Date phone
  -float total
  -long amount
  -float updatedAt
  +cancelStatus()
  +updateCode()
  +getId()
}
class Schedule {
  -boolean description
  #int score
  -float address
  -int phone
  +cancelType()
  +getLevel()
}
class Classroom {
  +Date quantity
  +long description
  -float duration
  #boolean total
  +int price
  +calculateLevel()
  +deleteName()
  +cancelScore()
  +updateName()
}
class Student {
  +long description
  -double amount
  +double id
  +getDescription()
  +validateTotal()
}
Schedule --|> Classroom
Schedule --> Book : "1..*"
Teacher --* Classroom
note right of Book : Education domain
@enduml