@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Book {
  -float createdAt
  #long score
  #Date address
  #Date code
  #String status
  +updateNote()
}
class Teacher {
  -int note
  +double score
  +int phone
  +validateLevel()
  +findType()
  +sendCreatedat()
}
class Schedule {
  +String score
  +long duration
  -int address
  #Date status
  #long createdAt
  +calculateCreatedat()
  +savePrice()
  +saveDuration()
}
class Classroom {
  #Date quantity
  +double amount
  #long createdAt
  #int type
  #long id
  +createPrice()
  +setQuantity()
  +getEmail()
  +setCode()
}
class Student {
  -boolean phone
  +String id
  #float createdAt
  #int type
  +cancelEmail()
}
Teacher ..> Student : "1"
Teacher --o Schedule
@enduml