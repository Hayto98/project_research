@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Shipment {
  -Date level
  -String type
  -double price
  #Date createdAt
  -float quantity
  +setQuantity()
  +findUpdatedat()
  +createPrice()
  +cancelAmount()
}
class Inventory {
  -float code
  +float type
  #Date createdAt
  +boolean duration
  +int phone
  +cancelNote()
}
class FuelLog {
  +Date email
  #long active
  #long amount
  +findStatus()
}
interface Customer {
  +double updatedAt
  #Date active
  -Date phone
  +sendUpdatedat()
}
class Route {
  #long name
  +Date level
  +float type
  #float score
  #int updatedAt
  +cancelNote()
}
Route ..|> Inventory
Route --> Customer : "1..*"
Shipment --> Customer : "0..1"
Inventory ..> Shipment : "*"
@enduml