@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
abstract class Prescription {
  +int price
  +long score
  -boolean total
  +validateStatus()
  +createUpdatedat()
  +updateCreatedat()
  +processDuration()
}
abstract class Doctor {
  -int name
  #float description
  -Date score
  #Date updatedAt
  +deletePhone()
}
abstract class Treatment {
  +int description
  #int phone
  #float price
  #long level
  #String email
  +findStatus()
  +getType()
}
abstract class Insurance {
  #String email
  +double address
  +getQuantity()
  +updateCode()
  +deleteTotal()
}
abstract class Ward {
  +long duration
  -String createdAt
  +String description
  +getPhone()
  +sendActive()
  +updateTotal()
}
class MedicalRecord {
  -Date score
  #Date phone
  -String note
  +float duration
  +createPhone()
  +updatePhone()
}
class Hospital {
  -String status
  -float createdAt
  -boolean price
  +double total
  #int level
  +updateNote()
  +calculateStatus()
}
Ward --|> Insurance
Hospital ..> Insurance : "*"
Hospital ..|> Ward
Insurance --* Doctor
@enduml