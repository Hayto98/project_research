@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Category {
  #Date level
  -String score
  +float duration
  +String name
  +validateCode()
  +createName()
}
interface Return {
  +long updatedAt
  -Date level
  +double createdAt
  +calculateName()
  +saveActive()
  +updateAddress()
}
class Warehouse {
  +long createdAt
  +boolean price
  -int type
  +boolean updatedAt
  -String level
  +cancelEmail()
  +setScore()
  +validateName()
}
interface Wishlist {
  #String level
  #Date amount
  +int note
  +String type
  +String code
  +processAddress()
  +sendId()
  +updateTotal()
  +updateActive()
}
Category --> Warehouse : "0..1"
Wishlist --> Return : "1..*"
@enduml