@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Category {
  #Date level
  -String score
  +float duration
  +String name
  +deleteNote()
  +sendUpdatedat()
}
class Return {
  #String updatedAt
  -Date quantity
  #long total
  +sendQuantity()
  +saveNote()
  +updatePrice()
}
abstract class Warehouse {
  +long active
  +boolean duration
  -int price
  +sendQuantity()
  +getDuration()
}
class Wishlist {
  -boolean type
  #Date level
  +saveLevel()
  +saveNote()
}
Category --|> Warehouse
Return --|> Category
Category --|> Wishlist
note right of Category : Ecommerce domain
@enduml