@startuml
skinparam monochrome true
skinparam ArrowColor #555555
abstract class Warehouse {
  +Date description
  -String amount
  +long duration
  #int name
  +double type
  +processAddress()
}
class Product {
  -Date status
  #int duration
  +boolean address
  +getPrice()
}
interface Customer {
  #int score
  #boolean status
  #Date duration
  -String phone
  +processId()
  +findAddress()
  +processScore()
  +processTotal()
}
class Cart {
  #String score
  -float total
  +updateEmail()
  +findCreatedat()
}
class Return {
  #String duration
  +long address
  #int total
  +String email
  +calculatePrice()
  +validateId()
}
Warehouse --* Product
Cart ..|> Customer
Customer --> Product : "*"
@enduml