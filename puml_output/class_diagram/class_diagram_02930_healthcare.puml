@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Diagnosis {
  #Date phone
  #double name
  +cancelQuantity()
}
interface Treatment {
  -double amount
  -long phone
  -String updatedAt
  +sendEmail()
}
class Appointment {
  -long address
  -long email
  +getCreatedat()
  +sendStatus()
  +createCode()
}
class Hospital {
  -boolean duration
  +String level
  #float active
  +Date amount
  +boolean note
  +updateDescription()
}
interface Nurse {
  +long createdAt
  #boolean description
  +validateStatus()
}
Nurse --* Treatment
Appointment --* Diagnosis
Appointment ..|> Nurse
Nurse ..> Hospital : "*"
@enduml