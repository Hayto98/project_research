@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
abstract class Customer {
  +long price
  #String score
  +boolean name
  +findName()
  +deleteActive()
  +sendName()
}
class FuelLog {
  -double createdAt
  #String total
  +deleteUpdatedat()
  +deleteDuration()
  +createAddress()
  +calculateDuration()
}
class Package {
  +String createdAt
  -boolean email
  #int price
  -long note
  #Date phone
  +updateDuration()
  +validateAmount()
  +processDuration()
}
interface DeliveryNote {
  #long updatedAt
  +Date level
  +double id
  -float score
  +Date email
  +getCreatedat()
}
interface Warehouse {
  -double description
  #double email
  +float amount
  +double name
  +sendDuration()
  +findPhone()
  +updateTotal()
}
class Manifest {
  #double description
  +String score
  +int amount
  #double price
  +createEmail()
  +calculateScore()
  +sendLevel()
  +validateCreatedat()
}
FuelLog ..> Manifest : "*"
DeliveryNote --> Manifest : "1..*"
note right of Customer : Logistics domain
@enduml