@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
abstract class Customer {
  +long price
  #String score
  +boolean name
  +setCode()
  +savePhone()
  +updateType()
}
interface FuelLog {
  +double createdAt
  -double code
  +sendStatus()
}
interface Package {
  -boolean description
  +double updatedAt
  +long duration
  -boolean email
  -long address
  +processAmount()
  +createDuration()
}
interface DeliveryNote {
  #long price
  +boolean quantity
  -int score
  +setPhone()
  +getQuantity()
  +cancelQuantity()
  +saveUpdatedat()
}
class Warehouse {
  #long id
  +Date email
  +validateUpdatedat()
}
class Manifest {
  #float code
  #long id
  +long createdAt
  +deleteNote()
  +createQuantity()
}
Manifest ..|> DeliveryNote
Customer --* DeliveryNote
Warehouse ..> Manifest : "1..*"
FuelLog ..|> DeliveryNote
Package --> FuelLog : "0..1"
@enduml