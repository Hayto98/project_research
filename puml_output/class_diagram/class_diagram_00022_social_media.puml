skinparam classBorderColor #455A64
skinparam ArrowColor #555555
abstract class Comment {
  -Date code
  #int active
  +cancelTotal()
  +calculateTotal()
  +saveAmount()
  +findDuration()
}
class Story {
  #float level
  -int name
  +validateDescription()
  +cancelEmail()
}
class Like {
