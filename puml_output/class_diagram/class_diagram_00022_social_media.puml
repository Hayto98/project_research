@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
abstract class Comment {
  -Date code
  #int active
  +getNote()
  +sendCreatedat()
  +cancelName()
  +findLevel()
}
class Story {
  -float updatedAt
  -boolean amount
  +boolean status
  #boolean email
  +saveScore()
  +findPrice()
  +findCode()
  +saveAmount()
}
class Like {
  -double address
  #String status
  #long name
  #long id
  +Date amount
  +updateCreatedat()
  +processType()
  +updateActive()
}
abstract class User {
  #boolean address
  -String email
  +long level
  +long name
  +createNote()
  +getDuration()
  +validateAmount()
  +sendTotal()
}
class Group {
  #String name
  +boolean address
  +getEmail()
  +deleteScore()
  +calculateEmail()
  +processEmail()
}
Like --o Comment
Comment --o User
note right of Comment : Social Media domain
@enduml