@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
interface Deposit {
  +float phone
  #float email
  +calculateQuantity()
}
class Transfer {
  +Date phone
  #boolean price
  #double description
  +float score
  +Date address
  +validateType()
  +cancelDuration()
  +createType()
}
class Loan {
  #double price
  -double score
  +String amount
  +validateUpdatedat()
  +calculateNote()
}
class Branch {
  #String code
  -Date updatedAt
  -int createdAt
  -int address
  +processUpdatedat()
  +cancelUpdatedat()
}
class Withdrawal {
  #long note
  +int amount
  #boolean price
  +deleteCode()
  +getStatus()
}
class Beneficiary {
  -long level
  -double score
  +deleteType()
  +cancelStatus()
}
class Account {
  #float quantity
  -boolean createdAt
  +validateAddress()
}
Transfer ..|> Withdrawal
Deposit ..|> Withdrawal
Withdrawal ..|> Transfer
@enduml