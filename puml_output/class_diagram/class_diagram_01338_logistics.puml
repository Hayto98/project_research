@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Route {
  #boolean createdAt
  +long total
  #Date amount
  +String type
  +getEmail()
  +setAddress()
  +calculatePhone()
  +updatePhone()
}
class Inventory {
  #double duration
  -Date quantity
  +deleteCreatedat()
}
interface Package {
  #double duration
  #Date createdAt
  #float id
  +updateQuantity()
  +saveCreatedat()
  +updateScore()
}
interface FuelLog {
  -String status
  #double note
  +boolean duration
  +float description
  +String amount
  +deleteCreatedat()
  +createDuration()
  +setCreatedat()
  +calculateTotal()
}
Route ..> FuelLog : "1"
FuelLog ..> Route : "0..1"
@enduml