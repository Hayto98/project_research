@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Route {
  #boolean createdAt
  +long total
  #Date amount
  +String type
  +deleteScore()
  +createDescription()
  +setDuration()
  +createNote()
}
abstract class Inventory {
  +boolean email
  +float active
  +cancelTotal()
}
interface Package {
  -Date address
  +int active
  +long price
  +boolean status
  +getLevel()
  +setDescription()
  +setTotal()
  +createPrice()
}
class FuelLog {
  -float id
  +float status
  +updateDescription()
  +cancelAmount()
}
Inventory --> Route : "*"
FuelLog --* Route
note right of Route : Logistics domain
@enduml