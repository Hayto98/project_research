@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Shipment {
  -long price
  +long active
  #Date level
  +validateType()
  +setDuration()
}
class FuelLog {
  +boolean price
  -String amount
  +processCode()
  +createTotal()
}
class Driver {
  #Date updatedAt
  +String description
  +int level
  +updatePrice()
  +findUpdatedat()
}
class Manifest {
  +boolean id
  +String duration
  +calculateStatus()
  +updateScore()
  +cancelLevel()
}
abstract class Route {
  +boolean email
  #long id
  +Date level
  +int amount
  +setAmount()
  +sendEmail()
  +deleteActive()
}
Driver --* Manifest
Shipment ..|> Manifest
@enduml