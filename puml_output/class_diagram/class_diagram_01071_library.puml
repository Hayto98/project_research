@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Branch {
  +Date updatedAt
  -int phone
  -int description
  #double createdAt
  +deleteCreatedat()
  +deleteLevel()
  +calculateScore()
}
class Catalog {
  #float updatedAt
  #Date level
  -double address
  +long price
  +Date score
  +updateActive()
  +getId()
  +getId()
  +findEmail()
}
class Member {
  +String id
  +float type
  +double active
  #long price
  +calculateQuantity()
  +createAddress()
}
class Librarian {
  #String duration
  +Date address
  +sendPhone()
}
abstract class Author {
  +boolean name
  #boolean email
  +int level
  #float status
  +cancelCreatedat()
  +cancelTotal()
  +calculateType()
  +getStatus()
}
interface Book {
  +double quantity
  +double duration
  -boolean level
  -Date price
  -float note
  +getLevel()
  +updateAmount()
}
Branch --> Book : "1"
Member --* Branch
Catalog --* Branch
note right of Branch : Library domain
@enduml