@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Branch {
  +Date updatedAt
  -int phone
  -int description
  #double createdAt
  +saveLevel()
  +validateCode()
  +deleteLevel()
}
class Catalog {
  +double level
  +boolean price
  -double score
  +updateScore()
  +saveType()
  +setDuration()
}
class Member {
  #String createdAt
  +String address
  +float duration
  #long note
  -long score
  +saveType()
}
abstract class Librarian {
  #long code
  +double status
  #Date description
  #float id
  -long total
  +calculateEmail()
  +processAmount()
  +sendActive()
}
class Author {
  #long code
  -boolean status
  +calculateId()
  +cancelPhone()
  +deleteCreatedat()
}
class Book {
  +Date score
  -boolean duration
  +boolean updatedAt
  +findAmount()
  +sendDescription()
  +sendCreatedat()
  +setUpdatedat()
}
Author --> Book : "*"
Book ..> Member : "1..*"
@enduml