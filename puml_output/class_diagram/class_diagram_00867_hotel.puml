@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Invoice {
  #float level
  +float code
  +updateStatus()
  +calculateQuantity()
  +deleteStatus()
}
class Amenity {
  #long amount
  +Date description
  +calculateLevel()
}
interface Restaurant {
  #double description
  +double status
  -double email
  #Date updatedAt
  +saveUpdatedat()
  +cancelActive()
}
abstract class CheckOut {
  #float email
  -long description
  -float status
  +int code
  +createEmail()
  +getName()
  +createUpdatedat()
  +calculateStatus()
}
class Service {
  -double price
  #long phone
  +setQuantity()
  +updateLevel()
  +processNote()
  +setNote()
}
class Housekeeping {
  +long code
  -String active
  +findType()
  +setId()
  +getUpdatedat()
}
class Payment {
  +long quantity
  +long phone
  +getAmount()
}
Service --> Invoice : "0..1"
Payment ..|> Invoice
@enduml