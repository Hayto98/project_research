@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Invoice {
  #float level
  +float code
  +updateTotal()
  +saveStatus()
  +getAmount()
}
class Amenity {
  +float status
  -int code
  #double address
  +double description
  +calculateLevel()
  +saveCreatedat()
  +saveLevel()
  +calculateAddress()
}
class Restaurant {
  -long status
  +int code
  #double type
  +setPrice()
  +validateType()
}
abstract class CheckOut {
  #String note
  +boolean quantity
  +long total
  -String amount
  +cancelStatus()
  +getQuantity()
  +validateId()
}
class Service {
  #Date email
  +boolean status
  +cancelCreatedat()
}
class Housekeeping {
  #String id
  +int type
  -Date status
  +calculateStatus()
  +setScore()
  +sendNote()
}
class Payment {
  +long active
  #String phone
  +sendType()
  +updateUpdatedat()
  +processId()
  +getTotal()
}
CheckOut --* Amenity
Service ..> Housekeeping : "0..1"
Invoice --|> Payment
Amenity --> Restaurant : "1..*"
Restaurant --* Invoice
Invoice ..> Service : "0..1"
note right of Invoice : Hotel domain
@enduml