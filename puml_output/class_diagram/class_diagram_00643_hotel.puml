@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Amenity {
  +String phone
  -double updatedAt
  +Date id
  -int code
  +updateDuration()
  +setTotal()
  +setAddress()
}
class Payment {
  -double name
  -float description
  -int updatedAt
  #Date createdAt
  +deleteAmount()
  +createUpdatedat()
  +calculateEmail()
}
class Reservation {
  #String amount
  -int active
  +calculateCreatedat()
  +processAmount()
}
class Service {
  +int status
  -boolean createdAt
  +sendPhone()
  +deleteActive()
}
class Housekeeping {
  -int email
  -double amount
  #boolean createdAt
  #long level
  -float description
  +updateAddress()
  +getDuration()
  +validateType()
  +createDescription()
}
class CheckIn {
  #String score
  -float id
  +String address
  #boolean level
  #float quantity
  +getNote()
  +cancelEmail()
  +validateCreatedat()
}
Reservation ..|> Amenity
CheckIn --> Service : "1..*"
Amenity --o CheckIn
Reservation ..> Service : "1..*"
note right of Amenity : Hotel domain
@enduml