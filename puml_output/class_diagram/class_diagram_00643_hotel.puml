@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Amenity {
  +String phone
  -double updatedAt
  +Date id
  -int code
  +getUpdatedat()
  +updateDescription()
  +setId()
}
class Payment {
  #String status
  +int address
  +double email
  -double active
  -int score
  +findPhone()
  +calculateAddress()
  +processCreatedat()
}
class Reservation {
  +int total
  #boolean email
  +long code
  +createLevel()
  +validateLevel()
}
class Service {
  #String createdAt
  +String note
  +long amount
  #Date email
  +float code
  +findId()
  +saveDescription()
  +createDescription()
}
class Housekeeping {
  -int email
  -double amount
  #boolean createdAt
  #long level
  -float description
  +processActive()
  +findQuantity()
  +sendTotal()
  +getQuantity()
}
class CheckIn {
  #float quantity
  +long description
  #String status
  -boolean active
  +long total
  +savePhone()
  +deleteType()
}
Amenity --> Service : "1..*"
Reservation --* Payment
Reservation ..|> Amenity
CheckIn --> Service : "1..*"
@enduml