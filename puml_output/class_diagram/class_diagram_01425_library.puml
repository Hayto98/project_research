@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Branch {
  #Date duration
  -int total
  #float price
  +calculateAmount()
  +cancelActive()
}
interface Reservation {
  -long id
  +Date email
  -Date quantity
  +long createdAt
  +validateStatus()
}
abstract class Loan {
  -Date quantity
  +float level
  #String id
  +Date name
  #boolean status
  +setName()
  +createCode()
  +createStatus()
  +processTotal()
}
class Author {
  -float description
  -String price
  +processPrice()
  +processAddress()
}
class Shelf {
  +int note
  +String total
  +deleteAmount()
  +setId()
}
abstract class Member {
  #long duration
  +Date address
  +findAddress()
  +saveDescription()
  +processName()
}
class Book {
  +boolean status
  -float level
  +setName()
  +setAmount()
}
Loan --|> Reservation
Book --* Member
Member --o Branch
Member --* Loan
Reservation --> Loan : "1..*"
Reservation ..> Branch : "1..*"
@enduml