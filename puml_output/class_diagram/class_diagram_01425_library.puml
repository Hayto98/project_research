@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Branch {
  #Date duration
  -int total
  #float price
  +processLevel()
  +saveScore()
}
class Reservation {
  +long email
  -int quantity
  +findCode()
  +createName()
  +calculateType()
}
class Loan {
  -Date name
  +float status
  +setLevel()
}
interface Author {
  +int id
  -float amount
  -float score
  -String note
  +int phone
  +getNote()
}
abstract class Shelf {
  #float amount
  +double updatedAt
  #double code
  +cancelAddress()
}
interface Member {
  +Date description
  +String address
  #int updatedAt
  #float id
  +deleteId()
  +saveScore()
  +createDescription()
}
class Book {
  +long name
  #long note
  +String phone
  #float quantity
  +calculateActive()
  +deleteActive()
  +getNote()
}
Loan --> Author : "0..1"
Loan --|> Reservation
note right of Branch : Library domain
@enduml