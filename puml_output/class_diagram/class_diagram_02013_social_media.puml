@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Report {
  +String duration
  -float phone
  #long amount
  +long score
  +createUpdatedat()
  +sendQuantity()
  +saveUpdatedat()
  +processName()
}
class Group {
  +float createdAt
  +boolean type
  -long status
  -int active
  -Date name
  +createDuration()
  +sendAmount()
}
class Album {
  +boolean type
  #boolean note
  #Date amount
  +String createdAt
  +getLevel()
}
interface Profile {
  +boolean price
  #boolean address
  +setName()
}
class Comment {
  -boolean description
  #boolean score
  #float duration
  -Date address
  +getCode()
}
interface Follower {
  -boolean address
  -float description
  +createScore()
}
Profile --* Album
Report ..|> Group
@enduml