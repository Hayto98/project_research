@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
abstract class Nurse {
  -float note
  #double email
  -float status
  -Date name
  +double score
  +sendDuration()
  +getCode()
  +deleteScore()
  +calculateType()
}
abstract class Hospital {
  +double price
  #int type
  #Date updatedAt
  #Date phone
  +updateLevel()
}
abstract class Ward {
  #int code
  +int name
  +int amount
  +updateLevel()
  +updateActive()
  +setId()
  +createAmount()
}
class MedicalRecord {
  -boolean type
  -double duration
  +validateLevel()
  +getName()
  +setDescription()
  +setAmount()
}
class Diagnosis {
  +double code
  +boolean email
  -boolean address
  +setUpdatedat()
  +getCode()
  +saveQuantity()
  +savePrice()
}
interface Prescription {
  #Date createdAt
  +float quantity
  +Date note
  -long type
  #int email
  +createActive()
}
Diagnosis ..> Hospital : "0..1"
Ward ..|> MedicalRecord
@enduml