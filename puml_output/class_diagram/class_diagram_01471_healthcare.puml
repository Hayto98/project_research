@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
abstract class Nurse {
  -float note
  #double email
  -float status
  -Date name
  +double score
  +saveLevel()
  +deletePrice()
  +validatePrice()
  +processUpdatedat()
}
class Hospital {
  -double price
  +String createdAt
  +float id
  +cancelDescription()
  +deleteCreatedat()
}
class Ward {
  #long price
  #Date quantity
  +String id
  +processTotal()
  +sendPrice()
  +processPrice()
  +setEmail()
}
class MedicalRecord {
  +double email
  +boolean address
  +sendType()
  +getLevel()
  +deleteLevel()
}
interface Diagnosis {
  #Date createdAt
  +float quantity
  +Date note
  -long type
  #int email
  +validateStatus()
}
interface Prescription {
  +float description
  #int address
  #String type
  +calculateLevel()
  +getCode()
  +sendType()
  +findPhone()
}
Prescription --* Diagnosis
Prescription ..|> Nurse
note right of Nurse : Healthcare domain
@enduml