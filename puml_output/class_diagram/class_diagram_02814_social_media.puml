@startuml
skinparam monochrome true
skinparam ArrowColor #555555
abstract class Hashtag {
  -double level
  #double price
  #int createdAt
  +updatePhone()
}
class Report {
  -long level
  #boolean address
  +long phone
  +int price
  +processEmail()
}
class Message {
  -String level
  +int code
  #int score
  +cancelLevel()
  +sendStatus()
}
class Post {
  #Date status
  +Date email
  -float createdAt
  #boolean amount
  +getName()
}
class Comment {
  #float createdAt
  #long code
  -float total
  #double updatedAt
  -long id
  +findStatus()
}
class Story {
  #int address
  -boolean active
  #boolean quantity
  -Date status
  +createType()
  +saveTotal()
}
interface Profile {
  -long level
  +float email
  -boolean score
  #String updatedAt
  #float total
  +deleteDuration()
  +getScore()
  +validateActive()
}
Comment --|> Message
Story --|> Comment
Report ..> Story : "1"
Story ..> Profile : "0..1"
Hashtag ..|> Comment
Profile --* Report
note right of Hashtag : Social Media domain
@enduml