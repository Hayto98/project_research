@startuml
skinparam monochrome true
skinparam ArrowColor #555555
abstract class Hashtag {
  -double level
  #double price
  #int createdAt
  +validateNote()
}
class Report {
  -boolean score
  -Date active
  +saveCode()
  +processDescription()
  +findQuantity()
}
interface Message {
  #Date phone
  +double createdAt
  -Date level
  +processDuration()
}
interface Post {
  +int score
  +Date email
  +deletePhone()
  +updateType()
}
interface Comment {
  +long description
  +float phone
  +getName()
  +findPrice()
}
class Story {
  -Date active
  +String code
  -int id
  +Date name
  #long updatedAt
  +getDescription()
  +sendDescription()
  +deleteEmail()
  +findDescription()
}
abstract class Profile {
  -long phone
  #long level
  #String status
  #int score
  -boolean duration
  +cancelName()
  +saveAddress()
  +findCreatedat()
}
Story --> Post : "*"
Comment --> Message : "0..1"
Post --* Profile
Profile --* Report
Comment --|> Profile
@enduml