@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Classroom {
  +Date phone
  +double amount
  +cancelCreatedat()
}
interface Department {
  #String total
  -float name
  -float code
  -int createdAt
  #int phone
  +cancelScore()
  +processAddress()
}
class Schedule {
  -boolean active
  -boolean address
  #boolean createdAt
  +createNote()
  +getLevel()
  +sendScore()
}
class Attendance {
  #boolean updatedAt
  -Date amount
  -boolean price
  +createQuantity()
  +updateName()
  +calculateId()
  +processDescription()
}
class Student {
  -double updatedAt
  -String status
  #float total
  +int note
  +cancelTotal()
  +processCode()
  +validateNote()
  +sendDescription()
}
class Course {
  #float total
  #Date updatedAt
  +Date code
  +setPhone()
  +deleteName()
}
class Assignment {
  -double type
  #int status
  -float address
  +setActive()
  +setEmail()
  +getDuration()
  +sendTotal()
}
Classroom --* Student
Classroom --> Assignment : "1..*"
Assignment --o Attendance
Department --* Student
Schedule --o Assignment
Schedule --o Department
@enduml