@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Classroom {
  +Date phone
  +double amount
  +calculateActive()
}
abstract class Department {
  -float name
  -float code
  -int createdAt
  #int phone
  #boolean id
  +saveEmail()
  +cancelActive()
}
class Schedule {
  #boolean createdAt
  #boolean type
  -String total
  -int active
  +updateAmount()
  +calculateLevel()
}
class Attendance {
  -long level
  -int type
  #String quantity
  -double status
  -double name
  +getDuration()
  +deleteCreatedat()
  +calculateId()
  +getUpdatedat()
}
class Student {
  #float total
  #Date updatedAt
  +Date code
  +cancelEmail()
  +setUpdatedat()
}
abstract class Course {
  -Date address
  +double total
  +validateId()
  +sendName()
  +sendPhone()
  +setId()
}
interface Assignment {
  -long note
  -float total
  -long amount
  +double active
  +updateActive()
}
Attendance ..> Department : "0..1"
Attendance --> Assignment : "1..*"
Course --o Department
Attendance --* Classroom
note right of Classroom : Education domain
@enduml