@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Publisher {
  -Date id
  -boolean score
  -float name
  +long note
  +processId()
  +saveCode()
  +saveStatus()
}
class Branch {
  #boolean email
  #boolean quantity
  +double duration
  +String note
  -int type
  +findId()
}
class Fine {
  -int type
  #int email
  +updateDescription()
}
class Shelf {
  #float level
  -long code
  -String email
  -boolean phone
  #long id
  +getUpdatedat()
  +cancelUpdatedat()
  +setType()
}
Branch --* Publisher
Fine --> Shelf : "1"
Publisher --* Branch
@enduml