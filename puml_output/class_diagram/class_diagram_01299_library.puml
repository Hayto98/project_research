@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Publisher {
  -Date id
  -boolean score
  -float name
  +long note
  +cancelPrice()
  +createTotal()
  +saveEmail()
}
class Branch {
  -String note
  +double type
  +String score
  +long amount
  +processEmail()
}
abstract class Fine {
  +Date description
  #double name
  #Date createdAt
  +createPhone()
}
class Shelf {
  -float email
  #int quantity
  #float status
  -boolean price
  +float level
  +validateEmail()
}
Publisher --* Branch
Fine --o Branch
note right of Publisher : Library domain
@enduml