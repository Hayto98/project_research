@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
abstract class Guest {
  -boolean duration
  +int type
  +updateQuantity()
  +findId()
  +findStatus()
  +setStatus()
}
class Room {
  #String phone
  #String updatedAt
  -float active
  -boolean createdAt
  +findPhone()
  +setUpdatedat()
}
class CheckIn {
  #boolean price
  #float duration
  -double total
  -int amount
  #long type
  +calculateAmount()
}
abstract class Amenity {
  #long active
  +long phone
  +setActive()
  +createCode()
  +getCreatedat()
  +getTotal()
}
Room --> Guest : "0..1"
Guest ..> Amenity : "0..1"
Amenity --> Guest : "1"
@enduml