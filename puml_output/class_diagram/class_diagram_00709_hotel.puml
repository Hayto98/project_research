@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
abstract class Guest {
  -boolean duration
  +int type
  +deleteStatus()
  +createAddress()
  +validateUpdatedat()
  +findActive()
}
class Room {
  -boolean status
  +int total
  +saveQuantity()
}
abstract class CheckIn {
  -long price
  +Date total
  -String amount
  -double type
  +boolean level
  +findQuantity()
  +deleteEmail()
  +processAmount()
}
interface Amenity {
  #boolean email
  +boolean description
  +String status
  +calculateAmount()
  +sendName()
}
Guest --> Amenity : "1"
CheckIn ..> Guest : "0..1"
note right of Guest : Hotel domain
@enduml