@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
abstract class Like {
  -double type
  -boolean name
  -boolean description
  +validateEmail()
}
interface Profile {
  #int email
  -float quantity
  +double type
  +saveAddress()
}
abstract class User {
  #Date code
  #float name
  +int type
  +float status
  #boolean phone
  +updateActive()
}
class Story {
  +Date description
  #String type
  +saveType()
}
User --* Profile
Like --* User
@enduml