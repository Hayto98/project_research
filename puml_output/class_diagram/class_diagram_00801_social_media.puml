@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
abstract class Like {
  -double type
  -boolean name
  -boolean description
  +setLevel()
}
class Profile {
  +double quantity
  +int type
  -boolean amount
  -String phone
  +findType()
}
class User {
  +float score
  #boolean duration
  #String id
  +long description
  +deleteType()
}
class Story {
  -long code
  -String name
  +processId()
  +createScore()
  +findAddress()
}
Story --> Profile : "0..1"
Profile ..> User : "0..1"
Like --> User : "0..1"
note right of Like : Social Media domain
@enduml