@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Loan {
  +long amount
  -long id
  #int level
  +String name
  +getName()
  +calculateActive()
  +deleteActive()
  +calculateEmail()
}
class Interest {
  +boolean total
  -Date type
  +boolean note
  +createType()
}
class Transaction {
  #long total
  -int type
  -float level
  -float score
  -int note
  +updateName()
  +deleteId()
}
abstract class Account {
  #String total
  #boolean quantity
  +long note
  +String id
  +createCreatedat()
  +saveActive()
}
class Teller {
  +double amount
  +String updatedAt
  +savePhone()
  +updateCode()
  +cancelAddress()
  +processAddress()
}
Transaction --> Interest : "1"
Transaction --* Account
@enduml