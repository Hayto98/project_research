@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Loan {
  +long amount
  -long id
  #int level
  +String name
  +sendType()
  +getPhone()
  +updateTotal()
  +processNote()
}
class Interest {
  -double name
  -double active
  -boolean id
  -long code
  +double total
  +createCreatedat()
  +updateStatus()
  +calculateEmail()
  +calculateQuantity()
}
abstract class Transaction {
  +long code
  +String active
  +deleteScore()
  +saveCode()
}
class Account {
  +String updatedAt
  -String duration
  -float total
  +saveEmail()
}
interface Teller {
  -double duration
  -Date score
  +double code
  +setId()
  +getTotal()
  +setScore()
  +updateCreatedat()
}
Interest --o Teller
Account --* Interest
Loan ..|> Interest
Account --> Transaction : "1"
note right of Loan : Banking domain
@enduml