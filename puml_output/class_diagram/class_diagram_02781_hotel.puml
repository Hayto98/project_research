@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
interface Booking {
  -double price
  #int quantity
  +saveDuration()
  +validateType()
}
abstract class CheckOut {
  -float amount
  #long id
  -long code
  +updateCreatedat()
  +calculateDuration()
  +deleteAddress()
  +cancelQuantity()
}
abstract class Housekeeping {
  -Date updatedAt
  #double score
  #int id
  +deleteEmail()
  +findLevel()
}
interface Amenity {
  +float note
  #String phone
  +cancelUpdatedat()
  +processActive()
  +validateAddress()
}
Housekeeping --* Amenity
CheckOut --|> Booking
@enduml