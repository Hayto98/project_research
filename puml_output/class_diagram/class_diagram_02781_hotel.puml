@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
interface Booking {
  -double price
  #int quantity
  +cancelType()
  +cancelUpdatedat()
}
class CheckOut {
  #long code
  -long note
  +sendUpdatedat()
  +processType()
  +updateUpdatedat()
  +sendId()
}
abstract class Housekeeping {
  -int score
  #String updatedAt
  -Date createdAt
  +long name
  -boolean note
  +sendPhone()
  +sendDescription()
  +deleteStatus()
}
class Amenity {
  #float level
  #int updatedAt
  +int duration
  -long quantity
  +findAmount()
  +findNote()
  +findActive()
}
Housekeeping --> Amenity : "1"
Booking --o Amenity
Booking --|> CheckOut
note right of Booking : Hotel domain
@enduml