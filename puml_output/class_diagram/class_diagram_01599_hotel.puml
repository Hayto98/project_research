@startuml
skinparam ArrowColor #555555
class Booking {
  -double quantity
  -String email
  -int price
  +Date duration
  +deleteAddress()
}
interface Room {
  #Date phone
  +int duration
  +float type
  +findName()
  +setType()
  +validateUpdatedat()
  +sendLevel()
}
abstract class Staff {
  +String phone
  -String active
  #String code
  -String note
  -long createdAt
  +processDescription()
  +getUpdatedat()
  +createActive()
  +saveDuration()
}
class CheckIn {
  -Date total
  #String quantity
  +double amount
  +cancelPrice()
}
Room --> Staff : "1"
Staff ..> CheckIn : "1"
@enduml