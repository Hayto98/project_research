@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Treatment {
  -Date quantity
  #double updatedAt
  +getDescription()
  +createType()
  +processActive()
}
class Hospital {
  -boolean quantity
  -int note
  #long phone
  +processQuantity()
  +getPrice()
  +findNote()
}
abstract class Insurance {
  #long note
  #boolean status
  #double updatedAt
  #double name
  #int id
  +saveNote()
}
abstract class Diagnosis {
  +long amount
  -float updatedAt
  +double price
  +String type
  #int createdAt
  +processDuration()
  +getAmount()
}
class Ward {
  #int email
  #double note
  +cancelStatus()
}
class MedicalRecord {
  -Date duration
  +long address
  -boolean email
  -String amount
  +cancelAddress()
  +processDuration()
}
Ward --|> MedicalRecord
Diagnosis ..> Ward : "1"
@enduml