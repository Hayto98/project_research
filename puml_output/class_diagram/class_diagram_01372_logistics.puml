@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Vehicle {
  +Date quantity
  -long score
  #double price
  +float type
  +cancelTotal()
  +updatePrice()
}
class Customer {
  -float type
  #int total
  +processId()
  +getEmail()
}
class Inventory {
  #boolean id
  +Date createdAt
  #float type
  -Date code
  -Date email
  +sendEmail()
  +findQuantity()
  +sendLevel()
  +cancelCode()
}
class Tracking {
  #boolean code
  +Date score
  #boolean name
  -double createdAt
  +calculateEmail()
  +sendActive()
  +validateUpdatedat()
}
class Depot {
  -Date phone
  #boolean duration
  #int quantity
  +saveActive()
}
class Shipment {
  -int quantity
  +boolean code
  -double createdAt
  #int phone
  +deleteAddress()
}
interface Route {
  #Date code
  +int createdAt
  -double phone
  +Date note
  #boolean address
  +createType()
  +cancelName()
}
Inventory --|> Customer
Depot --o Inventory
Shipment --* Customer
Vehicle --* Route
@enduml