@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Schedule {
  +Date description
  #String duration
  #Date phone
  +deleteCreatedat()
  +calculateName()
}
abstract class Student {
  +double phone
  #double note
  #float email
  #boolean score
  +double description
  +calculateCreatedat()
}
class Enrollment {
  -int code
  -float phone
  -long type
  +float quantity
  -String duration
  +saveUpdatedat()
  +calculateAmount()
  +setAddress()
  +processPhone()
}
class Attendance {
  #float type
  -String phone
  +Date email
  #Date address
  +getEmail()
  +findLevel()
  +calculateAddress()
  +deleteName()
}
abstract class Book {
  -Date note
  -int price
  +double createdAt
  +createNote()
  +cancelUpdatedat()
}
class Grade {
  +boolean createdAt
  #boolean address
  #int id
  +cancelType()
  +updateDuration()
}
Attendance ..> Enrollment : "1"
Student --o Grade
Book --|> Grade
Enrollment --> Student : "1"
note right of Schedule : Education domain
@enduml