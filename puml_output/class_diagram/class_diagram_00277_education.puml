@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Schedule {
  +Date description
  #String duration
  #Date phone
  +validateType()
  +updateCreatedat()
}
class Student {
  #double total
  -double name
  -long type
  +setLevel()
  +createName()
}
interface Enrollment {
  +float level
  +boolean id
  -String note
  #long status
  #float total
  +updateLevel()
  +processScore()
  +getLevel()
  +setTotal()
}
class Attendance {
  -Date quantity
  #int phone
  -int description
  +long address
  -long code
  +updateLevel()
  +getId()
  +createAmount()
}
class Book {
  #boolean score
  #boolean address
  -float code
  +long id
  +createActive()
  +findId()
  +savePhone()
  +cancelCode()
}
interface Grade {
  -Date note
  -int price
  +double createdAt
  +getUpdatedat()
  +deleteCreatedat()
}
Book ..> Student : "1"
Student --* Grade
Schedule --> Grade : "0..1"
Student --o Book
@enduml