@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Album {
  -double name
  #long duration
  -float status
  +getNote()
  +deleteScore()
  +calculateUpdatedat()
  +cancelQuantity()
}
interface User {
  #long total
  #String quantity
  #boolean note
  +boolean description
  #long code
  +deleteScore()
  +createCode()
}
abstract class Hashtag {
  +long note
  +boolean quantity
  #long amount
  +sendPrice()
  +calculateUpdatedat()
  +createDescription()
}
class Like {
  #double type
  -float createdAt
  +createAddress()
  +deleteCreatedat()
}
class Follower {
  -double name
  +double code
  +validateActive()
  +updateDuration()
  +sendActive()
  +setEmail()
}
User --> Like : "1..*"
Hashtag --o Album
@enduml