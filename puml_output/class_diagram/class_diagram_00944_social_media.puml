@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Album {
  -double name
  #long duration
  -float status
  +createAmount()
  +saveNote()
  +cancelTotal()
  +calculateQuantity()
}
abstract class User {
  #String duration
  #boolean code
  +boolean quantity
  +deleteAmount()
  +deleteType()
  +saveCreatedat()
}
abstract class Hashtag {
  #float amount
  #long status
  #boolean address
  -Date name
  +setType()
  +updateActive()
}
abstract class Like {
  #String amount
  +String code
  -double email
  +double level
  +cancelId()
  +cancelAddress()
  +deleteDescription()
  +findDuration()
}
abstract class Follower {
  -float phone
  #String code
  -long price
  #String level
  +getPhone()
  +saveScore()
  +findName()
}
User --* Follower
Hashtag --> User : "1..*"
Like --o Album
note right of Album : Social Media domain
@enduml