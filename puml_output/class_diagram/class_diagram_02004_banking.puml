@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Teller {
  #String price
  #long description
  #long status
  -boolean quantity
  +findStatus()
  +calculateActive()
  +sendEmail()
  +validateCreatedat()
}
abstract class Deposit {
  -double note
  #int quantity
  #boolean phone
  -int id
  -double status
  +getScore()
  +processName()
  +createAddress()
  +processType()
}
interface Loan {
  -Date address
  +double price
  +calculateId()
  +findAmount()
  +cancelEmail()
}
interface Branch {
  +String level
  #float email
  +processScore()
}
Loan ..> Branch : "0..1"
Deposit --o Loan
Teller --|> Branch
@enduml