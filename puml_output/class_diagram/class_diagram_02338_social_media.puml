@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Message {
  #float address
  #float name
  -boolean id
  -Date type
  +calculateCode()
}
abstract class Story {
  +double amount
  #boolean updatedAt
  #String quantity
  -String active
  +createType()
}
class Album {
  +float createdAt
  #int description
  -double score
  +getDuration()
  +sendId()
  +savePhone()
  +updateEmail()
}
class Follower {
  -double id
  -long duration
  #boolean note
  +findPrice()
  +getTotal()
  +validateActive()
}
class Notification {
  -float status
  #int score
  -int code
  -float name
  -Date email
  +createCreatedat()
  +findUpdatedat()
}
class Report {
  +float level
  -float updatedAt
  #Date total
  #boolean description
  #double name
  +calculateActive()
  +savePhone()
  +updateActive()
}
class Group {
  -long total
  +boolean createdAt
  +setTotal()
  +validateQuantity()
  +calculateDuration()
}
Story ..> Report : "1"
Notification ..> Group : "1..*"
Notification --|> Report
Follower --o Notification
note right of Message : Social Media domain
@enduml