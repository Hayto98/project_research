@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Message {
  #float address
  #float name
  -boolean id
  -Date type
  +saveName()
}
class Story {
  -boolean quantity
  #float amount
  #String updatedAt
  -String duration
  #String id
  +sendCreatedat()
  +updateActive()
  +updateType()
}
class Album {
  -double score
  -String id
  #boolean createdAt
  +createType()
}
class Follower {
  +String email
  #double phone
  -double description
  +createAmount()
  +calculateActive()
  +savePrice()
}
class Notification {
  #Date name
  -String total
  #String address
  +boolean active
  -double id
  +saveType()
  +sendDescription()
}
class Report {
  -int quantity
  #int total
  +Date description
  +processId()
  +findStatus()
  +findAddress()
  +getPhone()
}
class Group {
  #Date description
  #boolean address
  +validateScore()
  +updateQuantity()
  +createDuration()
  +createDescription()
}
Story --* Notification
Message ..|> Follower
Follower --|> Album
Notification --> Group : "1..*"
@enduml