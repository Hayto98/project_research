@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Wishlist {
  +boolean quantity
  +boolean duration
  #double address
  +findActive()
  +createScore()
  +updateScore()
  +updateDescription()
}
class Invoice {
  #String address
  #long description
  #String note
  #long score
  +sendName()
  +saveQuantity()
}
interface Return {
  -Date updatedAt
  #int phone
  +int level
  -Date email
  #float active
  +setQuantity()
}
interface Warehouse {
  #boolean code
  #String amount
  +Date updatedAt
  #double name
  #int type
  +deleteName()
  +validateAddress()
  +findName()
}
class Order {
  -Date updatedAt
  -int status
  +createCode()
  +getId()
  +createId()
}
abstract class Payment {
  #float score
  #String createdAt
  +createStatus()
}
class Customer {
  #Date duration
  -double phone
  +int active
  +double level
  +Date score
  +updateStatus()
  +deleteScore()
  +deleteAddress()
  +sendDuration()
}
Wishlist --* Return
Return --* Wishlist
Customer --o Payment
Wishlist ..> Order : "1..*"
Warehouse ..|> Wishlist
@enduml