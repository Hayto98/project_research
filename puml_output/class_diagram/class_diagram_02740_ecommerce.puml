@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Wishlist {
  +boolean quantity
  +boolean duration
  #double address
  +processUpdatedat()
  +findCreatedat()
  +setAddress()
  +validateDescription()
}
abstract class Invoice {
  #long duration
  +double code
  +Date active
  #double email
  #float status
  +findPhone()
  +cancelPhone()
}
interface Return {
  +double email
  #boolean note
  +float updatedAt
  #boolean amount
  +setAmount()
  +findUpdatedat()
  +saveName()
  +processActive()
}
interface Warehouse {
  #int id
  -long note
  +cancelPhone()
  +setUpdatedat()
  +setEmail()
}
abstract class Order {
  -float level
  -String address
  #int amount
  +getScore()
}
class Payment {
  #Date duration
  -double phone
  +int active
  +double level
  +Date score
  +updateAmount()
  +updatePrice()
  +getEmail()
  +validateAddress()
}
class Customer {
  -String note
  +Date name
  -int score
  #float email
  +processEmail()
  +validateScore()
  +cancelActive()
}
Warehouse ..|> Invoice
Warehouse --> Order : "1"
note right of Wishlist : Ecommerce domain
@enduml