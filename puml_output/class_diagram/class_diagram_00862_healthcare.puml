@startuml
skinparam shadowing true
interface MedicalRecord {
  +String code
  #Date address
  +String score
  +processScore()
  +cancelId()
  +sendAmount()
}
class Insurance {
  -long note
  -boolean createdAt
  +float email
  +validateUpdatedat()
}
class Diagnosis {
  #boolean address
  #float id
  +double email
  +boolean phone
  +String amount
  +cancelPrice()
  +validatePhone()
  +updateEmail()
  +getAmount()
}
abstract class Patient {
  +Date updatedAt
  +long createdAt
  +deleteType()
  +findDuration()
  +updateScore()
  +cancelId()
}
class Prescription {
  +double name
  #double phone
  #boolean note
  +setTotal()
  +getAmount()
  +calculateActive()
  +findAddress()
}
class Billing {
  #long phone
  +String id
  -long email
  #boolean price
  #String total
  +updateActive()
}
Insurance --> Diagnosis : "*"
MedicalRecord --|> Patient
Patient --> Billing : "1..*"
Prescription --> MedicalRecord : "*"
@enduml