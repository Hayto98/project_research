@startuml
skinparam shadowing true
interface MedicalRecord {
  +String code
  #Date address
  +String score
  +validateScore()
  +getUpdatedat()
  +processCreatedat()
}
class Insurance {
  +double email
  -String price
  -long id
  +boolean code
  #boolean type
  +calculateId()
  +cancelUpdatedat()
}
class Diagnosis {
  +int code
  +Date total
  +long price
  -Date active
  #Date name
  +updateDescription()
  +getPhone()
  +processUpdatedat()
}
abstract class Patient {
  +float active
  -long score
  #String price
  -float quantity
  -double updatedAt
  +getName()
  +processEmail()
  +cancelScore()
}
interface Prescription {
  -float id
  +long duration
  +getNote()
  +setNote()
  +calculateLevel()
  +createActive()
}
class Billing {
  +int score
  +boolean type
  #Date level
  -String price
  -Date duration
  +createQuantity()
  +saveQuantity()
  +cancelType()
  +cancelDescription()
}
Prescription --|> Patient
Billing ..> Prescription : "1..*"
note right of MedicalRecord : Healthcare domain
@enduml