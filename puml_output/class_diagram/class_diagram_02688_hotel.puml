@startuml
skinparam defaultFontSize 11
class Room {
  #long price
  #float description
  #float level
  +findActive()
  +validateName()
}
abstract class Restaurant {
  -Date duration
  +Date level
  -String name
  +double code
  #boolean updatedAt
  +sendEmail()
}
class CheckOut {
  #long email
  +Date code
  -Date id
  -float active
  -float score
  +sendAddress()
  +getId()
}
interface Invoice {
  +long code
  -double id
  #boolean phone
  #String note
  +String name
  +createUpdatedat()
  +saveName()
  +createLevel()
}
interface Amenity {
  #long note
  #boolean description
  -Date email
  -float updatedAt
  +int status
  +getStatus()
  +sendId()
}
CheckOut ..|> Room
CheckOut ..> Invoice : "1"
Invoice --* Restaurant
@enduml