@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
abstract class Amenity {
  -int level
  #double phone
  -int name
  +long email
  +deleteTotal()
  +setDuration()
  +processType()
  +calculateId()
}
class Guest {
  -boolean address
  +String type
  -double code
  +String note
  #int updatedAt
  +findCode()
}
abstract class Staff {
  #boolean duration
  -int code
  +setLevel()
  +sendType()
  +findTotal()
}
class Payment {
  #double description
  +float phone
  +double note
  #boolean createdAt
  +processType()
  +createAddress()
  +sendUpdatedat()
  +createPrice()
}
interface Restaurant {
  #long phone
  +Date note
  -float description
  #long email
  +updatePhone()
  +calculateDuration()
}
Restaurant --|> Amenity
Staff --o Payment
Payment --|> Amenity
Staff --* Amenity
note right of Amenity : Hotel domain
@enduml