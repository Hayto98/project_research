@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Room {
  +long active
  +double amount
  -boolean level
  -boolean note
  -double address
  +saveLevel()
  +createActive()
  +deleteEmail()
  +updateNote()
}
abstract class CheckIn {
  #String total
  +int amount
  -int type
  -long createdAt
  +saveAmount()
  +sendTotal()
  +validateCode()
  +getDescription()
}
interface Booking {
  #String code
  +String status
  +int level
  #long phone
  #boolean name
  +processTotal()
  +cancelDescription()
  +findCode()
  +validateCode()
}
class Amenity {
  -long active
  #float type
  +updateDescription()
  +getEmail()
}
interface CheckOut {
  #boolean type
  #Date phone
  +createEmail()
  +cancelAddress()
  +cancelQuantity()
}
class Service {
  #long type
  +int description
  #boolean name
  -float total
  #Date createdAt
  +sendTotal()
}
Booking --> Amenity : "0..1"
Amenity ..> CheckIn : "0..1"
CheckIn --> CheckOut : "1..*"
@enduml