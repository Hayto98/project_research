@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
abstract class Amenity {
  -long createdAt
  -int type
  +Date duration
  -boolean description
  +deleteId()
}
abstract class CheckOut {
  #String name
  +long code
  +double level
  -String address
  -double type
  +saveType()
  +getAddress()
}
class Restaurant {
  #long note
  #int type
  +validateScore()
}
class Reservation {
  #long name
  #int updatedAt
  +float total
  +createName()
  +createQuantity()
  +findNote()
}
class Booking {
  -double email
  -double score
  -boolean updatedAt
  #float level
  +long status
  +createLevel()
  +calculateDuration()
  +saveQuantity()
}
interface Housekeeping {
  -String amount
  #String total
  +String id
  +validateQuantity()
}
class Payment {
  #int quantity
  -int name
  +float id
  #double updatedAt
  +deleteScore()
  +sendCode()
}
Housekeeping --* Restaurant
Housekeeping --|> CheckOut
Payment ..> Booking : "*"
CheckOut --> Amenity : "1"
@enduml