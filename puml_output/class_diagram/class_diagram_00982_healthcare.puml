@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Appointment {
  #boolean type
  +long level
  -long name
  +processDescription()
  +processQuantity()
  +updateQuantity()
  +validateDescription()
}
class Treatment {
  +double price
  #int quantity
  -double code
  +sendScore()
  +processName()
  +updateDescription()
}
class Doctor {
  #String phone
  +float score
  +sendType()
  +processAmount()
}
class Hospital {
  #Date note
  -long id
  +updateId()
}
class Patient {
  +double status
  +double amount
  +float id
  +cancelPhone()
}
class MedicalRecord {
  -String id
  -Date total
  +deleteNote()
  +findCode()
  +processCreatedat()
  +validateDescription()
}
abstract class Diagnosis {
  -String quantity
  +String total
  +calculateUpdatedat()
  +cancelUpdatedat()
}
Doctor --o Hospital
MedicalRecord ..|> Doctor
Hospital --|> Treatment
Treatment ..> Appointment : "*"
Hospital --|> Appointment
Treatment --o Doctor
@enduml