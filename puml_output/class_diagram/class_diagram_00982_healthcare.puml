@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Appointment {
  #boolean type
  +long level
  -long name
  +createName()
  +createDescription()
  +calculateQuantity()
  +cancelCode()
}
class Treatment {
  -String score
  +String updatedAt
  +float address
  -boolean price
  #String duration
  +cancelUpdatedat()
}
class Doctor {
  -String code
  #int note
  #int id
  +float quantity
  +getId()
  +calculateCode()
}
abstract class Hospital {
  -String duration
  #String code
  +saveTotal()
}
class Patient {
  #float price
  #double score
  +validateType()
}
class MedicalRecord {
  +int total
  #Date email
  #long code
  -double score
  +updateTotal()
  +deleteStatus()
  +deleteCode()
}
interface Diagnosis {
  -String note
  -long id
  -String code
  -double createdAt
  +boolean address
  +processType()
  +calculateActive()
  +createDescription()
}
MedicalRecord --o Hospital
Appointment ..|> Hospital
note right of Appointment : Healthcare domain
@enduml