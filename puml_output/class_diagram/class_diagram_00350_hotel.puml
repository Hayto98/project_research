@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class CheckIn {
  #float score
  #boolean price
  +savePhone()
  +findCode()
  +updateCreatedat()
  +deleteTotal()
}
class Service {
  -Date duration
  #long name
  +long updatedAt
  +cancelCreatedat()
  +findId()
}
class Reservation {
  -String email
  +long active
  +createType()
  +updateQuantity()
  +sendDuration()
}
abstract class Restaurant {
  +float email
  #float quantity
  #String level
  +deleteDuration()
}
class Amenity {
  #Date code
  #boolean id
  -Date price
  +sendLevel()
  +validateNote()
  +calculateStatus()
}
class Payment {
  -String price
  -String note
  -int amount
  -Date address
  +String type
  +getId()
  +updateTotal()
}
class Staff {
  #boolean code
  #boolean createdAt
  +deleteName()
}
Service --o Restaurant
Restaurant --> Payment : "0..1"
Restaurant ..|> Staff
CheckIn --|> Restaurant
Payment --* Reservation
@enduml