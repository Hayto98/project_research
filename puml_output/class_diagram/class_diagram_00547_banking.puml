@startuml
skinparam defaultFontSize 11
abstract class Transfer {
  -boolean code
  -int updatedAt
  +validateAmount()
  +validateCreatedat()
  +setActive()
  +findPrice()
}
class Beneficiary {
  #Date description
  -String code
  -Date level
  -boolean email
  +sendUpdatedat()
}
class Loan {
  -long quantity
  -float active
  +savePrice()
  +validateTotal()
  +calculateName()
}
class Statement {
  -float description
  +int active
  #int score
  +double address
  #long type
  +setDuration()
  +deleteId()
  +processQuantity()
}
class Teller {
  #double total
  #int type
  #Date createdAt
  +float note
  #String score
  +deleteQuantity()
}
Beneficiary ..> Statement : "*"
Teller --|> Statement
Loan ..|> Teller
Teller ..|> Beneficiary
@enduml