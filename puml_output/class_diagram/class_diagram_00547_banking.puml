@startuml
skinparam defaultFontSize 11
abstract class Transfer {
  -boolean code
  -int updatedAt
  +createDescription()
  +sendName()
  +cancelPhone()
  +deleteCode()
}
class Beneficiary {
  #Date total
  +Date status
  +String email
  -boolean score
  +createNote()
  +createLevel()
  +findAddress()
  +validateDuration()
}
abstract class Loan {
  #float active
  #float score
  -float address
  +getCreatedat()
  +saveCreatedat()
  +getNote()
}
interface Statement {
  -double active
  #double address
  +double name
  +float email
  +sendAmount()
  +findId()
  +findId()
  +sendStatus()
}
class Teller {
  -String note
  -long total
  +boolean active
  +updatePhone()
  +processCreatedat()
}
Teller ..> Statement : "0..1"
Beneficiary --o Transfer
Loan ..> Statement : "1..*"
note right of Transfer : Banking domain
@enduml