@startuml
skinparam ArrowColor #555555
class Account {
  -int createdAt
  +String score
  -float updatedAt
  +float description
  +setLevel()
  +validateDuration()
}
class Teller {
  +long active
  +double score
  -String address
  -long duration
  +sendCode()
  +setAmount()
  +sendPrice()
  +updateUpdatedat()
}
class Interest {
  #int price
  #Date duration
  +long name
  +float total
  +findCreatedat()
}
abstract class Loan {
  -float quantity
  -int note
  -double price
  +processCreatedat()
  +calculateName()
}
class Withdrawal {
  +int status
  #float amount
  +cancelUpdatedat()
  +cancelName()
  +processDescription()
}
Teller ..|> Interest
Teller --|> Loan
Account --|> Teller
Loan ..|> Withdrawal
note right of Account : Banking domain
@enduml