@startuml
skinparam ArrowColor #555555
class Account {
  -int createdAt
  +String score
  -float updatedAt
  +float description
  +updateName()
  +saveStatus()
}
interface Teller {
  #float duration
  -float createdAt
  #boolean phone
  +long active
  +createDuration()
  +sendName()
}
class Interest {
  +boolean address
  -int note
  +int score
  -double code
  #float status
  +getDescription()
  +processEmail()
  +savePhone()
  +validatePrice()
}
abstract class Loan {
  +float status
  #int quantity
  -int id
  +getStatus()
  +saveAmount()
  +cancelType()
}
abstract class Withdrawal {
  -int address
  -float description
  #Date email
  #String type
  -String amount
  +validateQuantity()
}
Teller --> Interest : "0..1"
Withdrawal --o Account
@enduml