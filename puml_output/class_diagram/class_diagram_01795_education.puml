@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Grade {
  -String active
  #boolean code
  +long level
  +setLevel()
  +findAmount()
  +processAmount()
}
class Book {
  #long address
  -double note
  #Date score
  +float description
  +double email
  +sendLevel()
}
interface Department {
  +double type
  -int price
  #double status
  -Date description
  -long code
  +setActive()
  +sendPrice()
  +deleteQuantity()
}
class Exam {
  #int type
  #double total
  #long code
  #float address
  #Date note
  +saveDuration()
  +cancelId()
}
class Teacher {
  #Date id
  +int price
  -long score
  +float quantity
  -Date duration
  +saveId()
  +updatePhone()
  +cancelId()
  +findScore()
}
Grade --|> Book
Book --|> Department
Book --> Teacher : "0..1"
Teacher --> Department : "*"
@enduml