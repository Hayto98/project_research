@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Grade {
  -String active
  #boolean code
  +long level
  +deleteTotal()
  +setAmount()
  +processAddress()
}
abstract class Book {
  -double email
  #Date active
  +float phone
  +calculateName()
}
interface Department {
  +double type
  -int price
  #double status
  -Date description
  -long code
  +saveStatus()
  +validateTotal()
  +processTotal()
}
class Exam {
  #float note
  #Date description
  +boolean duration
  -int address
  +findId()
  +calculateScore()
  +createActive()
  +getScore()
}
class Teacher {
  -Date price
  -String email
  #long amount
  +sendCode()
  +updateStatus()
  +updateEmail()
}
Book --> Teacher : "0..1"
Teacher --> Department : "*"
note right of Grade : Education domain
@enduml