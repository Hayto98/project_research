@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
interface Book {
  -long code
  -int name
  #String note
  +sendPhone()
  +validateAddress()
  +processId()
  +sendTotal()
}
class Loan {
  -boolean amount
  -double address
  #String level
  -boolean name
  #String phone
  +getTotal()
  +createEmail()
}
abstract class Reservation {
  #Date note
  #double price
  +boolean level
  #boolean total
  +saveName()
  +findId()
  +getNote()
  +deleteName()
}
class Branch {
  #boolean address
  +long type
  -long status
  #double score
  +deleteCode()
  +setDescription()
  +validateDuration()
  +validateId()
}
abstract class Publisher {
  -boolean score
  #Date amount
  +Date phone
  -String active
  +updateAmount()
  +createPrice()
}
Book ..> Reservation : "1"
Publisher ..|> Loan
Reservation ..|> Loan
Loan ..> Reservation : "0..1"
note right of Book : Library domain
@enduml