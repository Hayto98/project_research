@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
interface Book {
  -long code
  -int name
  #String note
  +saveTotal()
  +calculateLevel()
  +createStatus()
  +sendPhone()
}
class Loan {
  +double type
  +long id
  #long score
  #String total
  +setEmail()
  +setId()
  +saveType()
}
class Reservation {
  +float score
  #double id
  -float type
  -double name
  #long amount
  +sendScore()
  +createLevel()
  +setAmount()
  +getActive()
}
abstract class Branch {
  #String level
  #String score
  +Date total
  -float status
  +Date price
  +deleteNote()
}
class Publisher {
  -long type
  -float status
  #double level
  -int amount
  +setStatus()
}
Reservation --|> Publisher
Branch ..> Reservation : "0..1"
@enduml