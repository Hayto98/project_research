@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Booking {
  -boolean createdAt
  +String score
  +Date updatedAt
  +int phone
  +int email
  +saveCode()
  +setCreatedat()
  +setPrice()
  +findEmail()
}
abstract class Invoice {
  -long code
  #float score
  +setNote()
  +createAmount()
}
class Housekeeping {
  -boolean note
  +long level
  +int address
  +updateActive()
}
abstract class CheckIn {
  -int createdAt
  -boolean id
  #double price
  #long type
  #double updatedAt
  +createStatus()
  +getType()
  +processNote()
}
class Reservation {
  #long id
  -boolean address
  #double description
  +Date updatedAt
  #long duration
  +setTotal()
  +saveEmail()
}
class CheckOut {
  -int active
  #float level
  #Date code
  +double total
  #boolean score
  +setCreatedat()
  +setQuantity()
  +setType()
  +setCode()
}
class Payment {
  #float total
  +String updatedAt
  #long name
  +boolean active
  +validateName()
}
CheckIn --|> Invoice
Booking --> Housekeeping : "1"
Reservation ..|> CheckIn
Payment --o CheckOut
@enduml