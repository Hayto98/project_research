@startuml
skinparam monochrome true
skinparam shadowing true
abstract class Payment {
  -String id
  +Date description
  -float active
  +int total
  +setDuration()
}
abstract class CheckOut {
  -boolean score
  #long amount
  -boolean updatedAt
  +sendType()
}
class Reservation {
  +String note
  +float level
  +int id
  +double duration
  +deleteQuantity()
  +getNote()
  +processDescription()
}
class Room {
  +String note
  -String score
  +String price
  +setStatus()
}
class Invoice {
  +Date level
  #double email
  #int active
  +boolean duration
  +calculateUpdatedat()
}
class Amenity {
  +long email
  -int status
  -int id
  +Date price
  +sendDescription()
  +saveId()
  +createCode()
  +updateId()
}
class Booking {
  +int amount
  +boolean quantity
  -String description
  -int updatedAt
  +createDuration()
  +findScore()
  +validateAmount()
}
Invoice --|> Reservation
Reservation --* Room
CheckOut ..> Amenity : "1"
@enduml