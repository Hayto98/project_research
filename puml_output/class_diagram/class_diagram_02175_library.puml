@startuml
skinparam defaultFontSize 13
interface Member {
  +double amount
  #long active
  -float updatedAt
  #int price
  +processStatus()
}
class Shelf {
  #long amount
  #String name
  +updateAddress()
  +findEmail()
  +sendType()
  +getDuration()
}
class Loan {
  #String duration
  #String total
  -float updatedAt
  +int address
  +sendPhone()
  +cancelName()
  +sendAmount()
}
abstract class Fine {
  -boolean email
  -long amount
  +getEmail()
  +deleteNote()
  +updatePhone()
  +deleteScore()
}
class Publisher {
  -float description
  -double duration
  #int phone
  -float id
  -long score
  +deleteLevel()
  +validatePhone()
  +sendLevel()
}
Publisher --|> Shelf
Loan --* Member
Member --> Shelf : "0..1"
@enduml