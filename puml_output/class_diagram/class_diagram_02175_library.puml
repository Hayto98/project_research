@startuml
skinparam defaultFontSize 13
interface Member {
  +double amount
  #long active
  -float updatedAt
  #int price
  +validateEmail()
}
interface Shelf {
  #long amount
  #String name
  +saveCreatedat()
  +cancelEmail()
  +findDuration()
  +calculateUpdatedat()
}
class Loan {
  +int code
  #long note
  +findScore()
  +processId()
  +createAmount()
}
class Fine {
  +Date quantity
  -float price
  #int description
  +long name
  #float amount
  +findPhone()
}
abstract class Publisher {
  -float total
  +long updatedAt
  #boolean type
  +String address
  -String active
  +getCreatedat()
  +cancelScore()
  +updateScore()
}
Loan --|> Shelf
Shelf --|> Member
Loan --o Publisher
note right of Member : Library domain
@enduml