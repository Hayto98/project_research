@startuml
skinparam shadowing true
class Fine {
  +long price
  -Date quantity
  #Date address
  -float note
  +saveUpdatedat()
  +saveId()
  +processNote()
  +saveQuantity()
}
class Loan {
  #String type
  +boolean note
  +deleteScore()
}
abstract class Reservation {
  -Date description
  -Date quantity
  #double createdAt
  +deleteDuration()
  +sendNote()
  +sendScore()
}
class Librarian {
  +boolean duration
  #Date amount
  #float address
  #String note
  +cancelLevel()
  +updateStatus()
  +findEmail()
  +validateTotal()
}
Loan --> Librarian : "*"
Fine --o Reservation
@enduml