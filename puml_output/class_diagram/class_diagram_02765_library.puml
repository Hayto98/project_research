@startuml
skinparam shadowing true
class Fine {
  +long price
  -Date quantity
  #Date address
  -float note
  +saveName()
  +saveDescription()
  +findDescription()
  +getType()
}
abstract class Loan {
  +int createdAt
  -Date score
  +deleteQuantity()
  +updateQuantity()
}
abstract class Reservation {
  #long address
  #float note
  +long updatedAt
  -int price
  #Date status
  +processUpdatedat()
}
class Librarian {
  #double address
  +double total
  #int status
  +createAddress()
  +findAddress()
}
Fine --|> Reservation
Librarian --|> Reservation
Loan ..> Reservation : "*"
note right of Fine : Library domain
@enduml