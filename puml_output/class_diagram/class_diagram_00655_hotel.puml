@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Reservation {
  +String updatedAt
  +int duration
  +updateStatus()
}
class Booking {
  +String amount
  -String name
  +sendType()
}
interface CheckIn {
  -long score
  -String amount
  +processActive()
  +calculateEmail()
  +updateScore()
  +cancelTotal()
}
class Guest {
  #Date id
  +long address
  #int quantity
  +getId()
}
class Payment {
  #boolean createdAt
  #boolean updatedAt
  +boolean amount
  #double status
  #Date type
  +validateAmount()
  +updateUpdatedat()
  +createCreatedat()
  +findActive()
}
interface Amenity {
  -Date amount
  +int quantity
  #boolean phone
  -int price
  -Date active
  +createUpdatedat()
  +processTotal()
}
Amenity --* Payment
Reservation --> Guest : "0..1"
Booking --|> Amenity
CheckIn --o Payment
@enduml