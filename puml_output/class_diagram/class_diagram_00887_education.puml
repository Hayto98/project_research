@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
abstract class Classroom {
  #double updatedAt
  -Date total
  #double description
  #Date type
  +cancelName()
  +cancelId()
}
interface Exam {
  +float phone
  +boolean createdAt
  +boolean price
  +deleteStatus()
  +updateActive()
  +sendNote()
}
abstract class Course {
  -double address
  -float phone
  +findDescription()
  +calculatePhone()
}
class Assignment {
  +long status
  #boolean amount
  -Date type
  #long total
  +createActive()
}
Assignment ..|> Course
Assignment ..> Classroom : "*"
note right of Classroom : Education domain
@enduml