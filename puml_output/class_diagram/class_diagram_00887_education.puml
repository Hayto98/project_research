@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
abstract class Classroom {
  #double updatedAt
  -Date total
  #double description
  #Date type
  +getQuantity()
  +cancelType()
}
class Exam {
  +long score
  +double duration
  +deleteLevel()
}
class Course {
  +int active
  #boolean email
  #double description
  +findNote()
  +createLevel()
  +calculateCreatedat()
  +validatePrice()
}
class Assignment {
  -int type
  -String address
  +boolean createdAt
  -double description
  +long total
  +createTotal()
  +cancelName()
  +deleteName()
}
Course --|> Assignment
Assignment ..|> Course
@enduml