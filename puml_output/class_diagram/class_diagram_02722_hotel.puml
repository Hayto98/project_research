@startuml
skinparam monochrome true
skinparam shadowing true
class Housekeeping {
  -double phone
  -double price
  #double description
  #long amount
  #int address
  +cancelDuration()
  +cancelType()
  +processCode()
  +cancelEmail()
}
abstract class Amenity {
  #int duration
  +String amount
  +float price
  +long level
  +getDuration()
}
class CheckOut {
  -boolean amount
  #boolean type
  #String description
  +int name
  +processAddress()
  +findPhone()
}
abstract class Service {
  +double note
  -boolean phone
  #boolean price
  +String createdAt
  -int type
  +validateDuration()
  +validateEmail()
  +setPhone()
}
abstract class Reservation {
  +long id
  -String phone
  #boolean createdAt
  -boolean amount
  +deleteCreatedat()
  +sendDescription()
  +getUpdatedat()
  +processNote()
}
Amenity ..> Housekeeping : "0..1"
Housekeeping --o Reservation
@enduml