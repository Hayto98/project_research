@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Service {
  +int price
  -double level
  +createEmail()
  +getTotal()
  +setEmail()
  +getAddress()
}
abstract class Restaurant {
  #long level
  -int createdAt
  +String description
  -int duration
  +calculateName()
  +createDuration()
}
interface Staff {
  +float price
  -int active
  -String note
  +Date description
  #boolean phone
  +calculateActive()
}
class Guest {
  -double duration
  -boolean updatedAt
  -float total
  +deleteTotal()
  +findScore()
  +sendTotal()
}
interface Amenity {
  -Date address
  #int id
  +double description
  +processEmail()
}
class CheckIn {
  #Date duration
  -double status
  +int name
  +processDescription()
  +processAddress()
}
CheckIn --o Restaurant
Staff ..|> Restaurant
Staff --o Guest
note right of Service : Hotel domain
@enduml