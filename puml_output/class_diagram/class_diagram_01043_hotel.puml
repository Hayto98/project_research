@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Service {
  +int price
  -double level
  +calculateScore()
  +calculateId()
  +findAmount()
  +updateName()
}
class Restaurant {
  -float address
  #float note
  +sendActive()
  +processScore()
}
class Staff {
  +String address
  -int note
  +double updatedAt
  +setQuantity()
}
class Guest {
  +float price
  -int active
  -String note
  +Date description
  #boolean phone
  +findAmount()
}
interface Amenity {
  -long amount
  #float updatedAt
  -float total
  -int quantity
  +calculateStatus()
  +findTotal()
  +saveActive()
  +sendQuantity()
}
abstract class CheckIn {
  -Date address
  #int id
  +double description
  +validateUpdatedat()
}
Restaurant --> CheckIn : "1"
Service ..> Amenity : "1..*"
Guest ..|> Restaurant
Amenity ..|> CheckIn
@enduml