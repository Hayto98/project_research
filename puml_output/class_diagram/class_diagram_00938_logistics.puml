@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Vehicle {
  +float total
  -double note
  +saveAddress()
}
abstract class Manifest {
  +boolean amount
  +double updatedAt
  +double createdAt
  #long type
  -String quantity
  +saveUpdatedat()
  +updateScore()
  +savePrice()
  +getTotal()
}
class Inventory {
  +float status
  -boolean code
  #float duration
  -String type
  -long email
  +deleteDuration()
  +findDescription()
}
abstract class FuelLog {
  #float phone
  #int updatedAt
  +int email
  +boolean id
  #double duration
  +findAddress()
  +setAddress()
}
abstract class Shipment {
  #String createdAt
  -long updatedAt
  -double address
  -String name
  +int note
  +findCode()
  +deletePrice()
}
Shipment --* Vehicle
Inventory --|> Shipment
Inventory --* FuelLog
@enduml