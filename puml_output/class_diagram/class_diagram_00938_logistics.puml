@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Vehicle {
  +float total
  -double note
  +deleteNote()
}
abstract class Manifest {
  #long updatedAt
  +boolean createdAt
  +double type
  +processLevel()
}
class Inventory {
  +String code
  +Date total
  -long createdAt
  +float description
  -boolean price
  +setEmail()
  +validateAmount()
  +processDuration()
}
abstract class FuelLog {
  #float phone
  #int updatedAt
  +int email
  +boolean id
  #double duration
  +updateScore()
  +processType()
}
class Shipment {
  #Date address
  #Date name
  -Date active
  +validatePhone()
}
FuelLog --|> Shipment
Vehicle --> Manifest : "0..1"
Inventory ..> FuelLog : "1"
note right of Vehicle : Logistics domain
@enduml