@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
abstract class Reservation {
  #String price
  +boolean total
  #String level
  +Date note
  +long name
  +createNote()
  +createActive()
  +getEmail()
  +deleteNote()
}
class Fine {
  #float email
  -int createdAt
  +Date address
  +setAmount()
}
class Book {
  +boolean duration
  -String type
  #Date email
  -float description
  +validateEmail()
}
class Librarian {
  #float quantity
  +float duration
  -boolean score
  +calculateNote()
  +deleteEmail()
  +setDuration()
  +findLevel()
}
class Loan {
  #int quantity
  -double price
  -boolean duration
  +float active
  +findName()
  +validateName()
}
class Catalog {
  -float phone
  -double email
  +Date duration
  -String createdAt
  +cancelStatus()
  +saveName()
}
class Author {
  -Date phone
  +double active
  -int quantity
  #double name
  +double description
  +processDescription()
  +setActive()
  +findNote()
  +processEmail()
}
Book ..|> Catalog
Reservation ..|> Fine
Author ..|> Loan
@enduml