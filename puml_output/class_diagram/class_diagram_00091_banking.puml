@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Beneficiary {
  -String name
  #double type
  #double note
  +validateNote()
  +findQuantity()
  +deleteEmail()
}
abstract class Withdrawal {
  -boolean score
  -String duration
  -boolean quantity
  +cancelId()
  +setCode()
  +cancelName()
}
interface Loan {
  -Date code
  +float price
  #long name
  +createEmail()
  +saveCode()
}
interface Branch {
  -double address
  -float id
  +findAddress()
  +processDescription()
}
Beneficiary --* Branch
@enduml