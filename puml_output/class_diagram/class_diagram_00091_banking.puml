@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Beneficiary {
  -String name
  #double type
  #double note
  +updateAddress()
  +calculateAmount()
  +sendScore()
}
class Withdrawal {
  -Date active
  #boolean price
  +Date id
  +double total
  +float quantity
  +saveCode()
  +findPhone()
  +deletePrice()
  +cancelStatus()
}
class Loan {
  -float phone
  +int total
  +sendActive()
  +cancelId()
  +getName()
}
class Branch {
  +Date status
  #int description
  +createNote()
  +deleteScore()
  +findPhone()
}
Branch --> Withdrawal : "*"
Withdrawal --> Branch : "1..*"
note right of Beneficiary : Banking domain
@enduml