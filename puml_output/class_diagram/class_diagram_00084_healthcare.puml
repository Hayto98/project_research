@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Hospital {
  +boolean email
  -double score
  +sendTotal()
}
abstract class Billing {
  +String createdAt
  +double level
  -int code
  #long updatedAt
  -boolean note
  +findActive()
  +updateActive()
}
abstract class Nurse {
  #Date score
  +Date status
  -double address
  #int type
  +String note
  +getId()
  +saveQuantity()
}
class Prescription {
  -boolean score
  -double active
  +long type
  +saveStatus()
  +updateCode()
  +createName()
  +findEmail()
}
Prescription --|> Billing
Billing ..> Hospital : "1..*"
@enduml