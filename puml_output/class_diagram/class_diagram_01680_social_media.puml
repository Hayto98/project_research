@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Album {
  #double price
  #boolean amount
  #boolean description
  +getActive()
  +calculateLevel()
}
class Profile {
  #float score
  -double total
  #double phone
  -long type
  +deleteDescription()
  +processDescription()
  +cancelScore()
  +cancelCode()
}
class Hashtag {
  +Date phone
  -int email
  +double status
  #String note
  +cancelAmount()
  +processUpdatedat()
}
interface Like {
  #String quantity
  #boolean description
  +float name
  +calculateAmount()
  +sendQuantity()
  +deleteTotal()
  +sendPrice()
}
class Group {
  #Date total
  -Date id
  +getCreatedat()
  +calculateNote()
  +getAmount()
}
interface Follower {
  #boolean id
  +boolean code
  #Date description
  +calculateType()
}
class Story {
  -float email
  -Date name
  -int price
  +double createdAt
  +boolean amount
  +sendPrice()
  +updateEmail()
}
Profile --> Album : "0..1"
Like ..|> Album
Follower --|> Group
Story --|> Profile
Hashtag --|> Group
Story --|> Album
@enduml