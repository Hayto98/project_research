@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Album {
  #double price
  #boolean amount
  #boolean description
  +findAddress()
  +createScore()
}
abstract class Profile {
  -long type
  #double price
  #long note
  #double score
  +findEmail()
}
class Hashtag {
  +String status
  -boolean note
  +float id
  #int total
  +sendAmount()
  +findQuantity()
}
class Like {
  +float name
  -double score
  +getTotal()
  +getEmail()
}
class Group {
  +int active
  #boolean createdAt
  +boolean id
  +findAddress()
}
abstract class Follower {
  -float name
  -Date price
  -int createdAt
  +double amount
  +sendCreatedat()
}
abstract class Story {
  -String id
  +Date score
  #float description
  +updateName()
}
Group --|> Album
Album --> Story : "1"
Follower --o Hashtag
Like --|> Story
note right of Album : Social Media domain
@enduml