@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
abstract class Library {
  -int id
  #float createdAt
  #double level
  +int price
  +deleteDuration()
  +sendDuration()
  +createTotal()
  +createNote()
}
class Attendance {
  -long status
  #long id
  +String score
  +double note
  -boolean createdAt
  +setName()
  +processDescription()
  +calculateLevel()
  +processQuantity()
}
class Schedule {
  #boolean type
  -long status
  -int amount
  #long name
  #String level
  +createEmail()
  +setTotal()
  +setTotal()
  +setStatus()
}
abstract class Student {
  +int total
  #double code
  +boolean note
  +String name
  +setStatus()
}
class Classroom {
  -boolean createdAt
  +Date code
  +sendNote()
}
class Teacher {
  +boolean amount
  +Date address
  -String id
  #float score
  +updateStatus()
  +setUpdatedat()
  +validateAmount()
  +findPhone()
}
Student ..|> Teacher
Attendance ..|> Student
Schedule --> Library : "*"
note right of Library : Education domain
@enduml