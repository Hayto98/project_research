@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
abstract class Library {
  -int id
  #float createdAt
  #double level
  +int price
  +deleteScore()
  +findDescription()
  +createDescription()
  +findUpdatedat()
}
class Attendance {
  #Date email
  +boolean note
  #double duration
  #float type
  #boolean status
  +updateCreatedat()
  +saveCreatedat()
}
class Schedule {
  -boolean name
  -float code
  +String id
  -float type
  +calculateCode()
  +findEmail()
}
interface Student {
  +String quantity
  +boolean name
  #float note
  -long type
  -int status
  +cancelName()
  +updatePrice()
  +sendPrice()
}
abstract class Classroom {
  #float email
  -String code
  +double total
  -double status
  +deleteDuration()
}
class Teacher {
  -int amount
  #int active
  +processCreatedat()
}
Library ..> Teacher : "0..1"
Library --|> Attendance
@enduml