@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class FuelLog {
  -String level
  +float note
  +boolean duration
  +createQuantity()
}
class Vehicle {
  +int address
  +String name
  +long active
  +sendNote()
  +calculateAddress()
}
class Depot {
  -long id
  -int level
  -String address
  +int note
  +double phone
  +saveDuration()
  +calculateActive()
  +createLevel()
}
class Route {
  -double price
  +double level
  +Date createdAt
  -int id
  +double amount
  +createNote()
}
Vehicle ..> FuelLog : "1..*"
Route --|> Vehicle
@enduml