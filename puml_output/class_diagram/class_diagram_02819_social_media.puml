@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
abstract class Notification {
  #boolean level
  #String active
  +float total
  +int type
  +String quantity
  +calculateAmount()
  +updateCode()
}
abstract class Story {
  +boolean total
  +long price
  +double code
  #Date amount
  -float note
  +createTotal()
}
class Report {
  -double total
  +String score
  -boolean type
  #boolean amount
  -Date status
  +createQuantity()
  +sendUpdatedat()
  +setDuration()
  +calculateCreatedat()
}
class User {
  -float address
  +String active
  +getUpdatedat()
}
Report --* Story
Story --* Report
@enduml