@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Book {
  #int total
  +float type
  +findPhone()
}
class Branch {
  #double active
  #int price
  +sendDescription()
  +updateId()
}
class Loan {
  #long quantity
  -double address
  -boolean phone
  +float updatedAt
  -double note
  +validateScore()
  +validateNote()
  +getStatus()
}
interface Author {
  -double total
  +double code
  -boolean amount
  +String score
  +double email
  +processLevel()
}
Loan --* Book
Loan ..|> Author
Loan ..> Branch : "0..1"
@enduml