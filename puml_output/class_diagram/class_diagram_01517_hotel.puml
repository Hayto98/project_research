@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Payment {
  -float total
  +double status
  -double updatedAt
  +processType()
  +createType()
  +saveAmount()
  +setScore()
}
class Reservation {
  -boolean createdAt
  #double name
  -boolean updatedAt
  #boolean description
  +Date quantity
  +validateNote()
}
interface Restaurant {
  -int createdAt
  #boolean level
  #Date total
  #float name
  +validateStatus()
}
interface CheckIn {
  #boolean amount
  +int email
  +long score
  -double id
  #boolean note
  +saveTotal()
  +calculateQuantity()
  +processStatus()
  +setAmount()
}
class Housekeeping {
  -long amount
  #int type
  +setQuantity()
}
class Booking {
  +float active
  -int updatedAt
  +int score
  #int price
  #double phone
  +setQuantity()
  +setDuration()
  +savePhone()
  +getEmail()
}
class Staff {
  -double price
  +int phone
  +sendAmount()
  +setNote()
  +validateTotal()
  +setCreatedat()
}
Housekeeping ..|> Restaurant
Reservation ..> CheckIn : "0..1"
@enduml