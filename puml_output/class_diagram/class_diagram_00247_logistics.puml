@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
interface Package {
  -double code
  +String score
  +updateStatus()
  +processPrice()
}
interface Vehicle {
  +int description
  +Date note
  +setPhone()
  +cancelPrice()
  +validateLevel()
}
class Manifest {
  +int active
  #int updatedAt
  -long note
  +boolean type
  +findTotal()
  +processAmount()
}
class Shipment {
  #double type
  +Date code
  -float phone
  -int status
  #double createdAt
  +updateId()
  +updateUpdatedat()
  +processDescription()
  +processUpdatedat()
}
class Tracking {
  #String note
  +String name
  #String createdAt
  #long id
  +int email
  +getAmount()
  +findQuantity()
  +cancelName()
}
Shipment ..> Manifest : "1"
Shipment ..|> Tracking
Package --> Tracking : "*"
note right of Package : Logistics domain
@enduml