@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
interface Package {
  -double code
  +String score
  +createScore()
  +updateName()
}
abstract class Vehicle {
  +int score
  #long name
  +long description
  #float note
  -long id
  +createType()
  +saveScore()
}
interface Manifest {
  +Date note
  +long type
  -int name
  +updateId()
  +processCreatedat()
}
abstract class Shipment {
  #boolean amount
  -String createdAt
  +boolean price
  -String type
  #float code
  +getStatus()
  +setAmount()
  +sendCreatedat()
}
class Tracking {
  -Date total
  +double createdAt
  +String id
  -double updatedAt
  #float active
  +sendActive()
}
Package --> Manifest : "1"
Vehicle --> Package : "1"
@enduml