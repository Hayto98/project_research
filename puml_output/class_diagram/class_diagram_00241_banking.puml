@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
interface Account {
  +int active
  -Date id
  -String type
  +getLevel()
  +setDuration()
  +getDuration()
  +calculateAddress()
}
interface Transfer {
  #String description
  #long amount
  +double status
  +processTotal()
}
class Interest {
  +float phone
  +double total
  +cancelPhone()
  +deleteStatus()
}
interface Card {
  -String phone
  -int score
  -float status
  +validateType()
  +createScore()
}
class Beneficiary {
  #long phone
  -Date status
  +updateNote()
  +validatePhone()
  +cancelEmail()
}
Account --> Card : "1..*"
Card ..> Transfer : "0..1"
Card --> Account : "0..1"
note right of Account : Banking domain
@enduml