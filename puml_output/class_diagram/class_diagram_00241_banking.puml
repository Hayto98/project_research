@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
interface Account {
  +int active
  -Date id
  -String type
  +setActive()
  +updatePrice()
  +saveDuration()
  +updateUpdatedat()
}
interface Transfer {
  -Date duration
  #int total
  +createType()
  +processUpdatedat()
}
class Interest {
  -String quantity
  -double description
  +saveId()
}
class Card {
  +String createdAt
  #Date updatedAt
  +long type
  #String level
  -String phone
  +processDuration()
  +setTotal()
  +findType()
}
class Beneficiary {
  #boolean type
  +long email
  +Date score
  -double amount
  +findType()
  +saveNote()
  +processTotal()
}
Interest --* Beneficiary
Account --> Card : "1..*"
Card ..> Transfer : "0..1"
@enduml