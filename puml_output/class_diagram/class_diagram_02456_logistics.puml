@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
interface Customer {
  -String name
  #long updatedAt
  +float quantity
  +cancelActive()
  +processQuantity()
  +saveNote()
}
class Vehicle {
  #double quantity
  +String level
  +sendNote()
  +deleteUpdatedat()
  +calculateDescription()
  +cancelId()
}
class Driver {
  +int quantity
  #double level
  +Date updatedAt
  -double price
  #long total
  +validateId()
  +deleteEmail()
  +saveScore()
}
class Route {
  +Date updatedAt
  +double level
  -double note
  #int email
  +cancelDuration()
}
interface Manifest {
  -double code
  -Date active
  +sendPrice()
  +updateCreatedat()
  +setNote()
  +updateName()
}
Customer --> Route : "1"
Vehicle ..|> Customer
note right of Customer : Logistics domain
@enduml