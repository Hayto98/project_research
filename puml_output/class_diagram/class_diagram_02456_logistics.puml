@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
interface Customer {
  -String name
  #long updatedAt
  +float quantity
  +deleteDescription()
  +updateAddress()
  +findPrice()
}
abstract class Vehicle {
  #Date note
  -int quantity
  +double code
  #double level
  +createNote()
  +validateNote()
}
abstract class Driver {
  #double duration
  -boolean id
  +double amount
  +calculateAddress()
  +findAddress()
  +sendQuantity()
  +calculateCode()
}
class Route {
  +int note
  -float email
  #boolean level
  +Date phone
  +findAddress()
  +getCode()
  +updateCode()
}
abstract class Manifest {
  -Date updatedAt
  +String description
  #boolean price
  #String score
  +updateNote()
}
Route ..> Driver : "*"
Manifest ..|> Route
Vehicle --o Customer
@enduml