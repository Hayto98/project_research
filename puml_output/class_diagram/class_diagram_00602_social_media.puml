@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Comment {
  +long phone
  +long note
  -int id
  +updateDuration()
  +createStatus()
  +updateScore()
}
class Post {
  -float email
  #boolean id
  +float quantity
  +processLevel()
}
class Message {
  -int duration
  #long address
  #double level
  -String price
  +boolean createdAt
  +sendQuantity()
  +findNote()
  +deleteAddress()
}
class Notification {
  #long name
  +long phone
  #long note
  +float status
  +Date createdAt
  +updatePhone()
}
interface Hashtag {
  #double status
  #long note
  #long createdAt
  #long level
  -int code
  +sendAddress()
}
Comment ..> Message : "*"
Post --o Comment
Hashtag ..|> Message
Notification ..> Message : "*"
note right of Comment : Social Media domain
@enduml