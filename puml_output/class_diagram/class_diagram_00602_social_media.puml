@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Comment {
  +long phone
  +long note
  -int id
  +calculateNote()
  +findDescription()
  +calculateScore()
}
class Post {
  -float score
  +Date updatedAt
  -float amount
  +createId()
  +getName()
  +calculateStatus()
}
interface Message {
  #long status
  -Date type
  +calculateCreatedat()
  +saveCode()
  +updateNote()
}
class Notification {
  +String amount
  #long email
  #long note
  #float level
  +cancelType()
  +findPhone()
  +validateDuration()
  +saveStatus()
}
class Hashtag {
  #long name
  +long phone
  #long note
  +float status
  +Date createdAt
  +saveNote()
}
Hashtag --|> Notification
Notification ..> Post : "*"
Comment --> Notification : "1..*"
@enduml