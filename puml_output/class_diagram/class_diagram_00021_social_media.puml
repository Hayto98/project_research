@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
abstract class Comment {
  +String quantity
  -long level
  -double name
  -int createdAt
  +saveAddress()
  +processNote()
  +updateScore()
}
class Notification {
  -String description
  -float type
  #long note
  +double name
  +sendPrice()
  +calculateStatus()
  +deletePhone()
}
class Album {
  #long total
  -long type
  #boolean phone
  +calculateNote()
  +processUpdatedat()
  +updateNote()
  +cancelStatus()
}
abstract class Profile {
  -double email
  +boolean name
  #int active
  +sendLevel()
  +sendName()
  +setName()
}
interface Like {
  #String name
  -boolean phone
  +boolean updatedAt
  #String quantity
  +processTotal()
  +createEmail()
}
abstract class Story {
  #boolean level
  -Date price
  +Date duration
  -float type
  +boolean code
  +getDuration()
  +getPrice()
  +getCode()
}
Notification --* Comment
Notification --o Profile
note right of Comment : Social Media domain
@enduml