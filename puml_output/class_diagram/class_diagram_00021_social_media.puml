@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
abstract class Comment {
  +String quantity
  -long level
  -double name
  -int createdAt
  +cancelPrice()
  +createNote()
  +setCode()
}
class Notification {
  +double note
  -String createdAt
  -String score
  -float description
  #long phone
  +deleteId()
}
abstract class Album {
  +long score
  +int price
  -float total
  -float status
  +updateScore()
  +updateLevel()
  +deleteAmount()
}
class Profile {
  #double total
  #String note
  -int type
  -String updatedAt
  #boolean createdAt
  +sendCode()
  +findNote()
  +calculatePrice()
  +findPrice()
}
class Like {
  +Date score
  +boolean level
  #Date duration
  #boolean name
  +processQuantity()
  +saveScore()
  +processDuration()
}
class Story {
  +boolean price
  #String level
  +updateQuantity()
  +createName()
}
Album --o Story
Story --> Profile : "*"
Profile --|> Story
Like --* Story
Story ..> Notification : "*"
@enduml