@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
abstract class Fine {
  +float description
  -Date amount
  #Date quantity
  #float createdAt
  +calculateStatus()
  +processCreatedat()
}
class Loan {
  +float code
  +boolean updatedAt
  +String type
  #Date email
  +long total
  +cancelUpdatedat()
  +cancelCode()
  +saveAddress()
}
class Renewal {
  #String name
  -int email
  +getPhone()
  +deleteType()
  +validatePhone()
}
abstract class Publisher {
  -float score
  +float total
  +findAmount()
  +updateNote()
  +sendAddress()
}
class Reservation {
  +long createdAt
  -float status
  +String description
  +float level
  #long email
  +processUpdatedat()
  +saveDuration()
  +updateDescription()
  +validateActive()
}
class Book {
  #String email
  +double active
  +float id
  +validateType()
  +processId()
  +sendScore()
  +getQuantity()
}
class Branch {
  -long id
  +String note
  +saveLevel()
  +calculateAmount()
  +processDuration()
  +sendAmount()
}
Reservation --o Branch
Branch --> Loan : "1..*"
Renewal --> Branch : "1..*"
note right of Fine : Library domain
@enduml