@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
abstract class Fine {
  +float description
  -Date amount
  #Date quantity
  #float createdAt
  +setNote()
  +updateUpdatedat()
}
abstract class Loan {
  +double description
  -double price
  +float code
  +findUpdatedat()
}
class Renewal {
  -boolean createdAt
  +boolean phone
  +processAddress()
}
class Publisher {
  #String code
  -int name
  -String email
  +deleteScore()
  +sendName()
  +createActive()
}
class Reservation {
  +float level
  -float active
  #int name
  +double total
  #long note
  +validateTotal()
}
abstract class Book {
  -String status
  -long description
  +String duration
  +saveStatus()
  +saveLevel()
}
class Branch {
  #float note
  #int updatedAt
  +Date level
  -Date description
  #String phone
  +validateCreatedat()
}
Fine --o Book
Renewal --o Publisher
Fine ..> Reservation : "1"
Renewal --* Book
@enduml