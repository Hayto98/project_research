@startuml
skinparam monochrome true
skinparam shadowing true
class Transfer {
  +int price
  -long email
  +processDuration()
}
class Deposit {
  -long score
  -double code
  #String type
  +double amount
  -int email
  +deletePhone()
}
class Beneficiary {
  -double total
  +long name
  +Date phone
  -long updatedAt
  +boolean code
  +saveEmail()
}
class Loan {
  #boolean score
  +float type
  #int phone
  #int address
  +getCreatedat()
  +validateType()
  +cancelNote()
  +updateScore()
}
Beneficiary --|> Transfer
Deposit ..|> Loan
Deposit --> Transfer : "1..*"
note right of Transfer : Banking domain
@enduml