@startuml
skinparam monochrome true
skinparam shadowing true
class Transfer {
  +int price
  -long email
  +deletePrice()
}
interface Deposit {
  -int type
  -long score
  -long code
  +calculateActive()
  +getLevel()
  +getEmail()
  +updateAmount()
}
abstract class Beneficiary {
  #double amount
  -float name
  #boolean duration
  #String phone
  -boolean id
  +sendDescription()
  +cancelDuration()
}
class Loan {
  #long type
  -float createdAt
  +boolean address
  #float level
  +validatePrice()
}
Beneficiary --> Loan : "1..*"
Loan --* Deposit
Deposit ..|> Beneficiary
@enduml