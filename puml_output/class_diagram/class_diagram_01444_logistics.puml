@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
abstract class Route {
  +float phone
  #float createdAt
  +cancelNote()
  +cancelLevel()
}
class Inventory {
  -boolean active
  +Date quantity
  +double total
  #double amount
  +findDescription()
}
abstract class Manifest {
  -Date code
  +float duration
  +createActive()
  +cancelAmount()
  +validateLevel()
}
class Package {
  +long name
  #long amount
  +updateId()
  +createLevel()
  +processUpdatedat()
}
class FuelLog {
  -Date address
  -int amount
  +cancelNote()
  +deleteType()
  +updateTotal()
}
Manifest --|> Route
Route --o Package
Package --* Manifest
note right of Route : Logistics domain
@enduml