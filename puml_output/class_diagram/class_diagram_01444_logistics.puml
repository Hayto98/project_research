@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
abstract class Route {
  +float phone
  #float createdAt
  +processEmail()
  +sendCode()
}
interface Inventory {
  -double address
  #int active
  +processEmail()
  +validatePhone()
  +sendDuration()
}
class Manifest {
  #Date total
  +String level
  +double name
  #float description
  +float type
  +calculateTotal()
  +deleteCreatedat()
  +saveUpdatedat()
}
interface Package {
  +String phone
  +int level
  -float name
  +processAddress()
  +getCode()
  +cancelDescription()
}
interface FuelLog {
  +float createdAt
  +Date id
  +long quantity
  +double type
  +saveTotal()
  +findPhone()
  +updateCreatedat()
  +saveScore()
}
Package --o Inventory
Inventory --* Package
Manifest --|> Route
Route --o Package
@enduml