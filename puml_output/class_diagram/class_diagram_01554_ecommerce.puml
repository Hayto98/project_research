@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
interface Invoice {
  #Date level
  #float total
  -boolean duration
  #boolean note
  +cancelType()
  +getNote()
  +updateEmail()
  +getType()
}
class Category {
  +int active
  -long score
  -int address
  +float note
  +double type
  +savePhone()
  +getActive()
}
abstract class Shipment {
  -boolean createdAt
  -double type
  -long address
  +updateEmail()
  +cancelUpdatedat()
  +cancelTotal()
  +saveQuantity()
}
interface Cart {
  -int email
  #Date price
  -boolean quantity
  +calculateId()
  +setNote()
  +processTotal()
  +sendQuantity()
}
class Coupon {
  -Date active
  -boolean createdAt
  +sendNote()
  +cancelName()
}
class Warehouse {
  -Date description
  #float note
  -String name
  +cancelCreatedat()
  +setPhone()
  +deleteType()
}
Shipment --> Cart : "1..*"
Shipment --|> Invoice
Category ..> Cart : "*"
@enduml