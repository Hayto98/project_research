@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Product {
  +double createdAt
  -double status
  +saveEmail()
  +saveNote()
  +getAddress()
}
class Cart {
  +int amount
  #String updatedAt
  #int score
  #int active
  +findEmail()
  +createTotal()
  +validateType()
  +createEmail()
}
class Coupon {
  -int level
  +String createdAt
  -String description
  -int quantity
  -long code
  +sendActive()
  +processActive()
  +deletePhone()
  +validateName()
}
interface Customer {
  -String duration
  -long note
  #Date quantity
  #String id
  -long description
  +sendEmail()
}
class Warehouse {
  +int code
  -double updatedAt
  +Date duration
  #String level
  +saveEmail()
  +findLevel()
  +sendDescription()
  +cancelAmount()
}
Warehouse --> Cart : "0..1"
Coupon --o Product
Coupon --|> Customer
@enduml