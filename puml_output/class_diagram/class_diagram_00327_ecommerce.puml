@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Product {
  +double createdAt
  -double status
  +getCreatedat()
  +calculateId()
  +findQuantity()
}
class Cart {
  +boolean score
  +float active
  #int description
  +calculateEmail()
  +calculateLevel()
}
class Coupon {
  +String quantity
  +double code
  +long phone
  +calculateQuantity()
  +cancelType()
}
interface Customer {
  #double type
  -Date active
  +float duration
  +validateStatus()
  +createQuantity()
}
interface Warehouse {
  +int type
  -long phone
  +updateDuration()
}
Cart ..|> Warehouse
Customer ..|> Warehouse
note right of Product : Ecommerce domain
@enduml