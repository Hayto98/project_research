@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
interface Staff {
  -double level
  +Date description
  +String name
  +long id
  +saveDescription()
}
abstract class Housekeeping {
  #boolean note
  -float email
  +cancelPrice()
  +updateEmail()
  +calculateQuantity()
}
class Guest {
  +long status
  #boolean type
  -boolean email
  #Date name
  +float id
  +getDuration()
  +processQuantity()
}
class Booking {
  #float total
  -String name
  -Date email
  #int type
  +validateTotal()
}
Booking ..> Housekeeping : "0..1"
Guest --* Housekeeping
Booking --o Guest
note right of Staff : Hotel domain
@enduml