@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
interface Staff {
  -double level
  +Date description
  +String name
  +long id
  +sendDuration()
}
class Housekeeping {
  #double status
  +float note
  -double email
  -long score
  -Date quantity
  +deleteActive()
}
class Guest {
  -boolean id
  #long createdAt
  +sendStatus()
}
class Booking {
  -long duration
  #long note
  +saveId()
  +calculateScore()
  +findStatus()
  +calculateUpdatedat()
}
Booking --* Staff
Housekeeping --* Staff
Booking --o Housekeeping
@enduml