@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Like {
  -double name
  #String price
  -double note
  +Date email
  +Date score
  +deleteTotal()
  +deleteAmount()
}
abstract class Story {
  +long phone
  #Date level
  -String quantity
  #String note
  #Date price
  +setUpdatedat()
  +calculateAmount()
  +cancelDescription()
  +saveTotal()
}
interface User {
  +double duration
  -long id
  -boolean email
  +Date address
  +updateAmount()
  +deleteDuration()
}
class Report {
  #double quantity
  #String description
  +String updatedAt
  +sendNote()
}
class Album {
  #boolean total
  +float note
  #double id
  +validateStatus()
}
Like ..|> Album
Report --o User
Report ..|> Album
@enduml