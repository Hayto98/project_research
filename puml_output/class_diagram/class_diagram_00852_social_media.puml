@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Like {
  -double name
  #String price
  -double note
  +Date email
  +Date score
  +calculatePrice()
  +processPhone()
}
interface Story {
  #Date note
  -String price
  #String createdAt
  #Date phone
  +getNote()
  +findActive()
  +validateDuration()
  +getEmail()
}
class User {
  -boolean note
  +Date phone
  +double quantity
  +findUpdatedat()
}
class Report {
  +int updatedAt
  +float total
  +int active
  +cancelCreatedat()
  +calculateNote()
  +getActive()
}
interface Album {
  +String total
  +Date status
  -Date email
  +calculateTotal()
  +cancelNote()
  +deleteUpdatedat()
}
Album ..> Story : "*"
Story --|> Album
note right of Like : Social Media domain
@enduml