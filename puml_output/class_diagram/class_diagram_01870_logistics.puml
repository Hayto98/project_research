@startuml
skinparam defaultFontSize 11
class Route {
  +String level
  +int quantity
  -Date code
  #String duration
  +deleteName()
}
interface Shipment {
  #long address
  +long duration
  +double total
  -double quantity
  +sendQuantity()
  +findTotal()
  +getDuration()
  +cancelCreatedat()
}
class Driver {
  -boolean status
  #float description
  #double active
  #Date total
  +calculateCode()
}
class Inventory {
  -double address
  +long note
  +Date phone
  -Date code
  +saveAddress()
}
class FuelLog {
  +boolean duration
  -boolean note
  -Date code
  #int active
  +cancelDuration()
  +updateCreatedat()
}
FuelLog --|> Driver
Inventory --> Shipment : "1"
Driver --* Shipment
@enduml