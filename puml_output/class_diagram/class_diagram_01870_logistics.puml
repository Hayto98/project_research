@startuml
skinparam defaultFontSize 11
class Route {
  +String level
  +int quantity
  -Date code
  #String duration
  +createScore()
}
interface Shipment {
  #long address
  +long duration
  +double total
  -double quantity
  +sendTotal()
  +findAmount()
  +cancelPhone()
  +setDuration()
}
class Driver {
  -String total
  #long active
  -double level
  -String type
  -double status
  +validateCreatedat()
  +saveEmail()
}
class Inventory {
  +boolean code
  +boolean address
  -boolean note
  +saveAmount()
  +deletePhone()
  +saveActive()
}
class FuelLog {
  #String total
  -float amount
  +validateCreatedat()
  +calculateEmail()
}
Inventory --* Route
Inventory ..|> Driver
note right of Route : Logistics domain
@enduml