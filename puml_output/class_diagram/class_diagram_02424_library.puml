@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
interface Author {
  +int name
  #int amount
  +processCreatedat()
  +calculateEmail()
  +setId()
}
interface Loan {
  +float active
  -String total
  #Date address
  +validateUpdatedat()
  +deleteCode()
  +saveCode()
}
class Publisher {
  -long address
  -boolean note
  #boolean level
  +boolean score
  +processCode()
  +cancelScore()
  +sendId()
}
interface Book {
  +String description
  -Date type
  -int email
  -float status
  #String active
  +processName()
}
class Shelf {
  #double code
  -Date amount
  +long email
  +updateTotal()
  +saveId()
  +cancelName()
}
Loan --|> Author
Publisher --|> Loan
Shelf --> Publisher : "1..*"
note right of Author : Library domain
@enduml