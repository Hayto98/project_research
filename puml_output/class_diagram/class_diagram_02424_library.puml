@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
interface Author {
  +int name
  #int amount
  +deleteActive()
  +validateStatus()
  +updateDescription()
}
abstract class Loan {
  -Date code
  #float id
  -String amount
  -String active
  +cancelId()
  +deleteAddress()
  +calculateType()
}
class Publisher {
  -long code
  -double amount
  +cancelCreatedat()
  +setEmail()
  +deleteName()
  +setId()
}
interface Book {
  +boolean level
  #boolean email
  #String type
  +setType()
  +deleteActive()
  +findCreatedat()
  +setStatus()
}
class Shelf {
  +long id
  #String total
  #String note
  +setPrice()
  +deleteEmail()
  +calculateId()
  +createScore()
}
Author --* Loan
Book ..> Publisher : "0..1"
Publisher ..|> Shelf
Book --> Author : "1"
@enduml