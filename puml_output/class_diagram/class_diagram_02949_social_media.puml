@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
interface Notification {
  #boolean address
  +int email
  +long note
  #String total
  +setEmail()
  +getActive()
  +deleteName()
}
abstract class Hashtag {
  -long note
  +Date createdAt
  +float total
  +validateScore()
  +setDuration()
  +createScore()
  +getUpdatedat()
}
interface Group {
  +long id
  +boolean name
  +double type
  -int createdAt
  -Date status
  +findLevel()
}
class User {
  -float active
  #int level
  -float status
  -double email
  +getAmount()
}
class Report {
  #int amount
  #String email
  +cancelEmail()
}
abstract class Like {
  #Date address
  -String quantity
  +int status
  +String score
  #int description
  +calculatePhone()
  +updateQuantity()
  +getDuration()
  +deleteEmail()
}
class Comment {
  +String email
  #float amount
  #long quantity
  +cancelAmount()
  +processName()
  +calculateCode()
  +saveActive()
}
Hashtag ..> Like : "0..1"
Comment --o Group
Like ..|> Notification
User --|> Like
@enduml