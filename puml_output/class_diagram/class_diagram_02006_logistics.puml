@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Route {
  -int description
  +boolean note
  #int updatedAt
  +validateName()
}
abstract class DeliveryNote {
  +Date id
  -Date name
  +double duration
  +double email
  #float note
  +setDuration()
}
class Inventory {
  +boolean level
  +Date email
  #String code
  -double id
  +Date description
  +cancelId()
  +processQuantity()
  +findAmount()
  +createId()
}
class Depot {
  +float score
  +Date price
  +calculateType()
}
interface FuelLog {
  +long quantity
  -float code
  #float phone
  #Date active
  +setType()
  +cancelActive()
  +updateLevel()
}
class Shipment {
  +String code
  -long duration
  +updateName()
  +cancelActive()
  +calculateUpdatedat()
  +updatePhone()
}
FuelLog --* DeliveryNote
Shipment --o Depot
FuelLog --* Inventory
Depot --> Route : "0..1"
@enduml