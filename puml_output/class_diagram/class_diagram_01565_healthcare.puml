@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Nurse {
  -double email
  +int type
  #String name
  +findUpdatedat()
  +cancelStatus()
  +cancelTotal()
  +deleteType()
}
class Diagnosis {
  -String status
  -boolean active
  #float phone
  +createId()
}
class Hospital {
  #boolean email
  -int status
  +Date name
  -long updatedAt
  +long amount
  +setDuration()
  +cancelLevel()
  +findPrice()
}
class Billing {
  #Date code
  -double email
  +Date quantity
  +sendPrice()
  +deleteDuration()
  +sendName()
}
class MedicalRecord {
  #String name
  #double total
  +savePhone()
  +processType()
  +saveCreatedat()
}
class Appointment {
  -double id
  -int duration
  +float price
  +setNote()
  +setId()
  +setId()
}
class LabTest {
  +float code
  -int name
  +sendCreatedat()
}
Diagnosis --o LabTest
Nurse --> LabTest : "*"
MedicalRecord --|> LabTest
Hospital --* Appointment
Appointment ..> MedicalRecord : "1"
MedicalRecord --* Billing
note right of Nurse : Healthcare domain
@enduml