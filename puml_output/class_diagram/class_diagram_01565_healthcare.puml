@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Nurse {
  -double email
  +int type
  #String name
  +createLevel()
  +processPrice()
  +findName()
  +sendDuration()
}
class Diagnosis {
  #long description
  -String type
  -boolean phone
  #float duration
  +long status
  +updateStatus()
}
abstract class Hospital {
  #boolean status
  -int name
  +Date updatedAt
  -long amount
  +processStatus()
}
class Billing {
  #Date duration
  -String level
  +createType()
  +getType()
}
class MedicalRecord {
  #double email
  +Date type
  #boolean amount
  +int address
  +calculateEmail()
}
abstract class Appointment {
  #long price
  -float email
  +cancelDuration()
  +saveNote()
  +processNote()
  +cancelPrice()
}
class LabTest {
  -double id
  -int duration
  +float price
  +validateEmail()
  +updateCode()
  +cancelQuantity()
}
Nurse --|> LabTest
@enduml