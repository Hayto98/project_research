@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Review {
  -String phone
  -float status
  +Date description
  #String price
  +setUpdatedat()
}
class Payment {
  -float type
  #boolean status
  +String note
  +setName()
  +setLevel()
  +deleteAddress()
}
class Product {
  #int quantity
  #boolean duration
  #int name
  #Date code
  +saveDuration()
  +setDuration()
}
class Warehouse {
  #double duration
  +String total
  +boolean phone
  -boolean quantity
  -float address
  +processAmount()
  +calculateDuration()
  +setCreatedat()
  +validateCode()
}
abstract class Cart {
  +float address
  +long description
  +int duration
  +getAddress()
  +sendId()
  +findTotal()
}
Warehouse ..> Payment : "1..*"
Payment --o Product
Cart --|> Product
Review --* Warehouse
@enduml