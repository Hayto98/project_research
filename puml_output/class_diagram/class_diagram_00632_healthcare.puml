@startuml
skinparam shadowing true
class Prescription {
  #Date createdAt
  +Date total
  +findEmail()
}
interface Billing {
  #long active
  #double address
  +createQuantity()
}
abstract class Appointment {
  -int code
  #boolean amount
  -String score
  +sendId()
  +getAddress()
  +processStatus()
  +sendQuantity()
}
class Hospital {
  #Date type
  +Date amount
  -double phone
  -long level
  -float code
  +getCode()
  +setQuantity()
}
class Insurance {
  #float address
  #String total
  +int type
  +cancelTotal()
}
interface Nurse {
  -Date updatedAt
  -double score
  +findId()
  +sendScore()
  +updateAddress()
}
Prescription --|> Nurse
Billing --* Prescription
Nurse ..> Billing : "1..*"
Nurse ..|> Appointment
@enduml