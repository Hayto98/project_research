@startuml
skinparam monochrome true
skinparam defaultFontSize 11
abstract class Interest {
  +double description
  #String name
  +sendDescription()
}
abstract class Branch {
  +long name
  #float createdAt
  +float quantity
  #float phone
  +validateAddress()
  +setNote()
  +validateCreatedat()
}
abstract class Transaction {
  #String phone
  +boolean name
  #boolean description
  +processTotal()
  +setCode()
  +sendPrice()
  +saveDescription()
}
class Statement {
  #int id
  #int status
  +long address
  #String type
  +int email
  +updateScore()
  +cancelQuantity()
  +cancelTotal()
  +deleteAddress()
}
abstract class Customer {
  -float amount
  -Date quantity
  -long email
  +calculatePhone()
}
class Withdrawal {
  -boolean updatedAt
  +int total
  +int score
  +double quantity
  +setEmail()
}
class Deposit {
  -long email
  +double id
  #Date score
  +Date updatedAt
  +sendType()
  +findAddress()
  +deleteTotal()
}
Interest --o Transaction
Transaction --o Statement
Customer ..|> Withdrawal
Interest --|> Withdrawal
Interest --* Deposit
note right of Interest : Banking domain
@enduml