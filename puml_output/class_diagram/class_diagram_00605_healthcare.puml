@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Diagnosis {
  #int amount
  +boolean description
  +double createdAt
  -String level
  #boolean score
  +processEmail()
  +calculateAddress()
}
class Patient {
  +int type
  -long duration
  +deleteQuantity()
}
class Treatment {
  +String status
  +int price
  -double name
  #Date score
  +createDescription()
  +createUpdatedat()
  +findAddress()
  +getScore()
}
interface Billing {
  +Date id
  +double duration
  +sendId()
  +cancelId()
}
abstract class Insurance {
  #long type
  +double updatedAt
  -Date duration
  +cancelName()
  +updateAmount()
}
class Hospital {
  +long score
  #double price
  +calculateStatus()
  +setPhone()
}
abstract class LabTest {
  +boolean phone
  +Date status
  #double email
  #int price
  +getId()
  +saveDescription()
  +updateCreatedat()
  +validateStatus()
}
Insurance --o Patient
Billing ..> Treatment : "1..*"
Insurance --* Hospital
Diagnosis --|> Insurance
Treatment ..> LabTest : "*"
LabTest --> Patient : "*"
@enduml