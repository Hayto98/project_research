@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Diagnosis {
  #int amount
  +boolean description
  +double createdAt
  -String level
  #boolean score
  +cancelAmount()
  +findStatus()
}
class Patient {
  +String type
  -Date name
  #long updatedAt
  +Date total
  -Date email
  +getUpdatedat()
}
class Treatment {
  -boolean description
  #double type
  +sendScore()
  +getId()
}
class Billing {
  +int amount
  -double note
  +processDuration()
  +updateType()
}
class Insurance {
  +Date price
  +String address
  #double score
  +createPrice()
}
class Hospital {
  +boolean address
  +Date phone
  #double status
  #int email
  #double price
  +findScore()
  +cancelCreatedat()
  +processTotal()
  +createQuantity()
}
interface LabTest {
  -Date id
  #double active
  +boolean status
  -double address
  +savePhone()
  +validateId()
  +cancelAmount()
}
LabTest --o Patient
Patient ..> Billing : "0..1"
Diagnosis ..> Hospital : "0..1"
Hospital ..|> Diagnosis
Diagnosis ..> Insurance : "*"
note right of Diagnosis : Healthcare domain
@enduml