@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
interface LabTest {
  #int id
  +long active
  #int address
  #double level
  +saveNote()
}
class Billing {
  #double active
  +String note
  +sendStatus()
}
class Treatment {
  -String email
  #String code
  #String score
  +processScore()
  +calculateQuantity()
  +saveNote()
}
abstract class Prescription {
  -float createdAt
  +double price
  -float note
  -String level
  #double description
  +createUpdatedat()
}
class Insurance {
  +double description
  -long active
  +findLevel()
  +updatePrice()
  +processDuration()
  +getUpdatedat()
}
class MedicalRecord {
  -long code
  #long address
  -float name
  +setStatus()
}
interface Hospital {
  -float active
  #double quantity
  -double level
  +deleteAmount()
}
Billing --* Prescription
Billing ..> MedicalRecord : "1..*"
Insurance ..|> Hospital
MedicalRecord --|> Insurance
Hospital ..> Treatment : "*"
@enduml