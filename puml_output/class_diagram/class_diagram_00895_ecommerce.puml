@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
interface Payment {
  #String type
  +String email
  +float id
  +Date updatedAt
  -Date duration
  +deleteAddress()
  +getDescription()
  +setPhone()
  +setId()
}
class Order {
  #boolean type
  +int email
  #float updatedAt
  +String note
  +updateActive()
  +updateDuration()
  +saveScore()
  +validateName()
}
class Warehouse {
  +Date createdAt
  -int id
  +int status
  +sendStatus()
  +findAddress()
  +getDescription()
}
abstract class Return {
  #long total
  #double updatedAt
  #float name
  +setUpdatedat()
  +sendUpdatedat()
  +deleteCode()
  +deleteStatus()
}
interface Shipment {
  -int email
  -boolean active
  +float code
  +sendActive()
  +saveId()
  +getNote()
  +validateDescription()
}
class Review {
  +boolean total
  #String level
  #double note
  -double phone
  +cancelActive()
  +calculateStatus()
}
abstract class Supplier {
  +Date status
  -boolean score
  #double note
  -String description
  +int total
  +findNote()
  +setLevel()
  +createActive()
}
Review --o Order
Shipment --* Warehouse
Payment ..|> Return
Shipment --o Review
Payment --> Supplier : "1..*"
@enduml