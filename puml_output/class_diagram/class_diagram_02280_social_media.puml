@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
abstract class Like {
  -Date name
  #Date active
  #int code
  +setPhone()
  +saveAmount()
  +findName()
  +validateDescription()
}
class Album {
  +String email
  -boolean description
  +boolean address
  -Date price
  +calculateAmount()
  +saveStatus()
  +updateDuration()
  +deleteLevel()
}
class Message {
  #Date total
  +String id
  -String note
  +deleteQuantity()
  +calculateActive()
  +sendName()
}
abstract class Profile {
  #float description
  +double level
  +int note
  +double amount
  +cancelPrice()
  +deleteTotal()
  +processPhone()
  +processActive()
}
class Follower {
  +double code
  +boolean createdAt
  +calculateUpdatedat()
  +processStatus()
  +cancelAmount()
}
Like --o Profile
Follower --* Album
Follower ..|> Profile
@enduml