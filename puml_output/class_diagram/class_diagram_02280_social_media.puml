@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
abstract class Like {
  -Date name
  #Date active
  #int code
  +cancelNote()
  +cancelAddress()
  +validateEmail()
  +findDescription()
}
class Album {
  #double status
  -float name
  +float email
  -float duration
  #int score
  +cancelId()
  +processId()
  +setEmail()
  +getEmail()
}
class Message {
  #float price
  +double quantity
  +int description
  +double note
  -Date amount
  +validateCode()
  +findCode()
}
class Profile {
  #long note
  #long code
  +getPrice()
  +processLevel()
  +deletePhone()
  +cancelPrice()
}
class Follower {
  #String price
  #Date updatedAt
  -boolean type
  -float description
  +calculateStatus()
  +deleteEmail()
  +createNote()
}
Like --> Profile : "0..1"
Profile --|> Album
Profile --o Message
note right of Like : Social Media domain
@enduml