@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
abstract class Customer {
  +boolean updatedAt
  #Date email
  +boolean total
  -float score
  +boolean status
  +deleteName()
  +cancelScore()
  +cancelCreatedat()
}
class Deposit {
  +boolean status
  +long id
  #Date type
  -float code
  -double score
  +cancelScore()
  +findCreatedat()
  +sendType()
  +processAddress()
}
interface Beneficiary {
  +float email
  -String active
  +int note
  +sendUpdatedat()
  +createDuration()
  +setCode()
  +validateNote()
}
class Teller {
  #Date duration
  #float code
  #long type
  -double updatedAt
  +String total
  +setQuantity()
}
abstract class Withdrawal {
  #Date description
  #int level
  +float code
  +deleteStatus()
  +processPhone()
}
Beneficiary --|> Withdrawal
Beneficiary --o Customer
@enduml