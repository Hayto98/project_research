@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Review {
  +double code
  +long quantity
  #float updatedAt
  +long price
  #float createdAt
  +validateCode()
}
interface Cart {
  -double quantity
  #float level
  #boolean type
  +Date note
  +validateActive()
  +setActive()
  +validateLevel()
  +findCreatedat()
}
class Category {
  #long duration
  -boolean description
  +setName()
  +getPhone()
  +cancelNote()
}
class Order {
  -double score
  #long description
  +setDuration()
}
class Product {
  #int updatedAt
  +String type
  +sendPhone()
  +saveStatus()
  +createPrice()
}
class Supplier {
  -boolean score
  +boolean total
  +double active
  +saveName()
}
interface Payment {
  +String code
  -String description
  +double score
  +setScore()
}
Supplier --|> Review
Supplier --> Cart : "0..1"
Category ..|> Cart
@enduml