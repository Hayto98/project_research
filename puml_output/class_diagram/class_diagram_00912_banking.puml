@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
interface Interest {
  -double amount
  -String createdAt
  +int email
  +deleteStatus()
  +getStatus()
  +findDuration()
}
abstract class Branch {
  +String active
  -Date id
  -Date note
  #long score
  +deletePhone()
  +cancelActive()
  +calculateId()
  +deleteName()
}
abstract class Statement {
  #Date score
  -boolean quantity
  #String code
  +validateLevel()
}
class Withdrawal {
  +boolean id
  -float code
  +getCode()
}
class Account {
  -double name
  #String level
  +processStatus()
  +validateTotal()
}
Statement --o Branch
Interest ..|> Statement
Interest --* Branch
note right of Interest : Banking domain
@enduml