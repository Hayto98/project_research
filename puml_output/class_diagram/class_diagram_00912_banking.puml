@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
interface Interest {
  -double amount
  -String createdAt
  +int email
  +createCreatedat()
  +setStatus()
  +updatePrice()
}
class Branch {
  +String phone
  -Date active
  -Date id
  #long note
  #float level
  +saveQuantity()
  +deletePhone()
  +cancelId()
  +findName()
}
interface Statement {
  #long id
  +boolean amount
  #long name
  #Date type
  +String description
  +findName()
  +setType()
  +calculateId()
}
class Withdrawal {
  +String status
  +int address
  +saveStatus()
}
class Account {
  -double price
  -long code
  +double updatedAt
  +long type
  +Date status
  +calculateTotal()
}
Statement --|> Account
Branch --> Statement : "1..*"
@enduml