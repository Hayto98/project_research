@startuml
skinparam defaultFontSize 13
class Loan {
  #long total
  #boolean price
  +calculateId()
  +processName()
  +calculateStatus()
  +deleteUpdatedat()
}
abstract class Publisher {
  -Date status
  +float createdAt
  -Date name
  +createNote()
  +sendPhone()
  +cancelQuantity()
}
class Author {
  +boolean level
  -float status
  +double phone
  +updateNote()
  +setLevel()
  +saveCreatedat()
}
class Renewal {
  -float score
  #boolean amount
  +Date status
  #String description
  +calculateLevel()
  +cancelTotal()
  +validateEmail()
  +cancelStatus()
}
interface Librarian {
  #String amount
  #long duration
  #String price
  +double score
  +sendDescription()
  +setActive()
  +validatePhone()
  +createCode()
}
abstract class Book {
  -double name
  +String quantity
  +float price
  -long phone
  #long active
  +findCode()
  +cancelId()
  +processNote()
  +setUpdatedat()
}
class Catalog {
  -float type
  #int createdAt
  +processQuantity()
}
Loan --|> Publisher
Librarian ..|> Publisher
Catalog ..|> Librarian
Catalog --o Renewal
@enduml