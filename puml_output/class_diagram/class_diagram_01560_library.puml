@startuml
skinparam defaultFontSize 13
class Loan {
  #long total
  #boolean price
  +getId()
  +findLevel()
  +calculateCreatedat()
  +setCreatedat()
}
class Publisher {
  -String amount
  +boolean type
  #String quantity
  #Date phone
  +setDuration()
  +validateAmount()
  +processAddress()
}
interface Author {
  #Date address
  #float updatedAt
  +String duration
  +createDuration()
  +sendStatus()
}
class Renewal {
  #int id
  -double status
  #String code
  #long phone
  #String amount
  +calculateType()
}
class Librarian {
  -Date price
  -long type
  #float name
  +calculateTotal()
  +deleteCode()
  +setPhone()
}
class Book {
  -String total
  -Date phone
  +long level
  #int name
  +getQuantity()
}
class Catalog {
  +float status
  #int active
  -double updatedAt
  +validateCreatedat()
  +setStatus()
}
Loan --o Catalog
Publisher --> Book : "1"
Author ..|> Loan
Renewal ..> Loan : "*"
note right of Loan : Library domain
@enduml