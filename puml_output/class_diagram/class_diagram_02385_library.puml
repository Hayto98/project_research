@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
abstract class Shelf {
  -Date email
  -boolean level
  +validateAddress()
  +validateNote()
}
class Publisher {
  #Date code
  +long duration
  #double active
  -int phone
  +deleteQuantity()
  +validateName()
  +calculateCode()
  +saveNote()
}
class Librarian {
  -int total
  -int description
  +savePhone()
  +validateName()
  +cancelCode()
}
class Member {
  -double amount
  #Date status
  +float duration
  +deleteQuantity()
  +setPhone()
}
class Branch {
  #double quantity
  +long type
  +String name
  +String amount
  +double note
  +setDuration()
  +updatePrice()
  +processCreatedat()
  +getType()
}
Member ..|> Librarian
Publisher ..> Member : "*"
Branch --|> Librarian
note right of Shelf : Library domain
@enduml