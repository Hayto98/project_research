@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
abstract class Shelf {
  -Date email
  -boolean level
  +findCode()
  +processCreatedat()
}
class Publisher {
  +Date note
  #Date createdAt
  -boolean address
  #int code
  +findPrice()
  +calculateCode()
  +updateAmount()
}
class Librarian {
  -String total
  -String description
  #float quantity
  +cancelStatus()
  +cancelActive()
  +findNote()
  +saveLevel()
}
abstract class Member {
  +float address
  #long updatedAt
  #long email
  +calculateId()
  +processEmail()
  +sendDuration()
}
class Branch {
  +int level
  +float active
  +cancelCode()
  +saveAmount()
}
Shelf ..|> Publisher
Librarian ..> Shelf : "1..*"
Shelf ..> Member : "1..*"
Member ..> Shelf : "0..1"
@enduml