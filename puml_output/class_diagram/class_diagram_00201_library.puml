@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Loan {
  #float name
  +String amount
  #Date price
  #String updatedAt
  +calculateCode()
  +setPhone()
  +sendCode()
}
class Author {
  #double email
  #int code
  #long createdAt
  +getCode()
  +deletePhone()
  +createType()
  +deletePhone()
}
abstract class Fine {
  #Date amount
  #boolean total
  +calculatePrice()
}
class Book {
  -boolean updatedAt
  -double description
  #double type
  +boolean quantity
  +cancelDescription()
  +saveCode()
  +cancelQuantity()
  +createId()
}
class Branch {
  -boolean level
  -float price
  -int phone
  +String active
  -String type
  +sendAmount()
  +saveCreatedat()
  +findId()
  +validateNote()
}
abstract class Publisher {
  -double address
  #long type
  +boolean status
  -int total
  -Date createdAt
  +validateNote()
}
Book --* Publisher
Publisher ..> Book : "0..1"
Fine ..|> Publisher
Loan ..|> Publisher
note right of Loan : Library domain
@enduml