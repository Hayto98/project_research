@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Loan {
  #float name
  +String amount
  #Date price
  #String updatedAt
  +deleteEmail()
  +deleteAmount()
  +processAmount()
}
class Author {
  -String score
  #float code
  +Date createdAt
  -boolean description
  +calculatePrice()
  +cancelPhone()
}
abstract class Fine {
  #long code
  -double description
  +findCode()
  +saveUpdatedat()
}
abstract class Book {
  #Date amount
  #boolean total
  +setActive()
}
abstract class Branch {
  -double id
  #float email
  -double updatedAt
  #double description
  +boolean type
  +getCode()
  +createCreatedat()
  +processNote()
  +getLevel()
}
interface Publisher {
  #float quantity
  -Date id
  -boolean duration
  #boolean total
  +getId()
  +saveActive()
  +sendLevel()
  +saveTotal()
}
Book --|> Author
Loan --|> Book
Book ..|> Branch
Publisher ..> Author : "1"
Fine --o Book
@enduml