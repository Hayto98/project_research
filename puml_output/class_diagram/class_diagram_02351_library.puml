@startuml
skinparam monochrome true
skinparam ArrowColor #555555
interface Fine {
  #String status
  +int name
  -boolean note
  +sendCode()
  +cancelStatus()
  +getDuration()
  +saveUpdatedat()
}
abstract class Shelf {
  #boolean phone
  -Date note
  -long id
  +Date duration
  +long price
  +setStatus()
  +calculateCreatedat()
}
class Reservation {
  -String score
  -float level
  -String name
  -Date amount
  +float address
  +setLevel()
  +updateAmount()
}
class Member {
  -Date status
  -int email
  +cancelName()
  +deleteQuantity()
  +updateDuration()
}
class Catalog {
  #long type
  -double createdAt
  -long status
  +Date duration
  #double address
  +cancelDescription()
  +deleteCode()
  +cancelNote()
  +deleteDuration()
}
Fine --* Shelf
Catalog --* Fine
Member --o Shelf
note right of Fine : Library domain
@enduml