@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
interface Hashtag {
  #double duration
  #Date price
  +boolean updatedAt
  +validateAmount()
  +saveActive()
}
abstract class Story {
  #boolean updatedAt
  +float email
  #int code
  +createPrice()
  +findPrice()
  +processAmount()
  +findTotal()
}
abstract class Group {
  -boolean type
  +int id
  +calculateId()
  +savePrice()
}
abstract class Post {
  +boolean duration
  #Date description
  +updateAmount()
  +cancelLevel()
}
abstract class Like {
  #double email
  #int name
  +setAddress()
}
Group --o Story
Hashtag ..|> Story
Story --|> Hashtag
note right of Hashtag : Social Media domain
@enduml