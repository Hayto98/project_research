@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
interface Hashtag {
  #double duration
  #Date price
  +boolean updatedAt
  +findQuantity()
  +findId()
}
interface Story {
  #int updatedAt
  -long duration
  -Date email
  -double code
  +Date description
  +sendCode()
  +cancelStatus()
  +findStatus()
  +getAmount()
}
abstract class Group {
  +int total
  #float active
  +getPhone()
  +setName()
}
abstract class Post {
  +boolean name
  #Date description
  -float code
  +Date updatedAt
  -String createdAt
  +findTotal()
  +getCreatedat()
  +processUpdatedat()
  +validatePrice()
}
interface Like {
  #long status
  +double address
  +createCode()
  +validateEmail()
  +saveDescription()
}
Story --|> Like
Hashtag ..> Story : "0..1"
@enduml