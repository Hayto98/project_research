@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Hashtag {
  +String id
  -float price
  +boolean total
  +setScore()
  +sendDuration()
  +cancelCreatedat()
  +setUpdatedat()
}
class User {
  #Date id
  #long price
  -String createdAt
  +updateCreatedat()
}
class Follower {
  -String phone
  #double name
  #Date updatedAt
  +boolean level
  +findStatus()
}
interface Report {
  #double price
  +String address
  #boolean score
  -Date createdAt
  +long description
  +setAddress()
  +createCreatedat()
  +saveActive()
  +setStatus()
}
interface Profile {
  -float email
  -int code
  -double quantity
  -float createdAt
  +deletePhone()
  +cancelActive()
  +cancelNote()
  +sendId()
}
class Post {
  +double phone
  -int updatedAt
  -Date email
  #long active
  -Date score
  +createTotal()
}
User --* Hashtag
Profile ..> Follower : "*"
@enduml