@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Hashtag {
  +String id
  -float price
  +boolean total
  +saveTotal()
  +getUpdatedat()
  +findCreatedat()
  +findId()
}
abstract class User {
  +String level
  #int quantity
  -long phone
  +updateName()
}
class Follower {
  #Date active
  +boolean price
  +saveDuration()
}
interface Report {
  #double price
  +String address
  #boolean score
  -Date createdAt
  +long description
  +sendDescription()
  +sendStatus()
  +cancelPhone()
  +saveEmail()
}
class Profile {
  -double createdAt
  -float type
  -boolean quantity
  +int updatedAt
  +processPhone()
}
class Post {
  -double active
  +long duration
  #boolean email
  -float status
  +saveName()
  +findStatus()
  +deleteStatus()
  +createLevel()
}
Post --> Report : "1"
Follower --o Profile
Report --> Hashtag : "*"
Hashtag --> Report : "1"
note right of Hashtag : Social Media domain
@enduml