@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Product {
  #double name
  #double updatedAt
  #String address
  #boolean level
  +validateType()
  +setId()
  +validateAddress()
}
interface Invoice {
  +boolean price
  #int code
  +float duration
  #long level
  #Date name
  +updateDuration()
  +updateType()
  +sendCode()
}
interface Category {
  #boolean id
  #Date amount
  +Date quantity
  -float createdAt
  +getEmail()
  +getName()
  +saveTotal()
  +setDuration()
}
abstract class Customer {
  -int id
  -double email
  #boolean total
  +float address
  +int description
  +processId()
  +calculateStatus()
  +setAddress()
}
Product --|> Customer
Category ..> Customer : "*"
Category ..> Product : "1..*"
note right of Product : Ecommerce domain
@enduml