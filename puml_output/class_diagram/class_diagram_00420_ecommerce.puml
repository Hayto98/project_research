@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Product {
  #double name
  #double updatedAt
  #String address
  #boolean level
  +setEmail()
  +validateDescription()
  +saveLevel()
}
abstract class Invoice {
  -Date id
  #double phone
  +getType()
  +createPrice()
  +createAddress()
  +deleteUpdatedat()
}
class Category {
  +float duration
  #long level
  #Date updatedAt
  +setAmount()
  +cancelLevel()
  +setActive()
}
class Customer {
  #long type
  +int score
  -Date code
  +createEmail()
  +setCreatedat()
}
Customer --|> Invoice
Category --|> Product
@enduml