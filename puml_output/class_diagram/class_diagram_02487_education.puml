@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
interface Student {
  +double address
  +long total
  -double createdAt
  +cancelUpdatedat()
}
class Teacher {
  +String email
  -long name
  +double code
  +updateDuration()
}
class Enrollment {
  #String total
  +float level
  -boolean quantity
  #Date amount
  +processId()
  +deletePrice()
  +getScore()
  +setNote()
}
class Library {
  +double code
  #Date updatedAt
  +int id
  +updateCreatedat()
  +setAmount()
  +sendCreatedat()
}
class Book {
  +Date code
  +int active
  +createCreatedat()
  +validateTotal()
}
interface Assignment {
  -boolean name
  -String id
  -int description
  +deleteName()
}
interface Classroom {
  +boolean updatedAt
  -boolean address
  +createPhone()
  +setActive()
  +processCreatedat()
}
Assignment --o Classroom
Teacher --* Enrollment
Enrollment --o Library
Student --|> Classroom
Enrollment ..|> Classroom
Student --o Enrollment
note right of Student : Education domain
@enduml