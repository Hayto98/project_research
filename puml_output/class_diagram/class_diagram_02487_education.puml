@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
interface Student {
  +double address
  +long total
  -double createdAt
  +findUpdatedat()
}
class Teacher {
  #String updatedAt
  +String email
  -long name
  +getId()
}
class Enrollment {
  -boolean duration
  #long code
  +boolean email
  +calculateAddress()
}
class Library {
  #boolean type
  +float id
  -float amount
  #Date price
  +int level
  +sendNote()
}
class Book {
  -int total
  +String code
  +float amount
  +saveTotal()
  +calculateAddress()
}
class Assignment {
  #String active
  +int amount
  +getTotal()
  +deleteCode()
  +processLevel()
}
interface Classroom {
  -boolean name
  -String id
  -int description
  +createCode()
}
Book ..|> Student
Enrollment --> Teacher : "1..*"
@enduml