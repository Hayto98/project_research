@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
interface Housekeeping {
  #boolean note
  +float id
  +updateStatus()
}
class Payment {
  +long phone
  +Date score
  #long note
  +calculateAddress()
  +sendType()
  +cancelType()
  +cancelAmount()
}
class Service {
  #int duration
  +double active
  #String email
  -String id
  -boolean level
  +calculateUpdatedat()
  +findScore()
  +cancelEmail()
  +saveCreatedat()
}
class CheckIn {
  +int address
  #int type
  +calculateStatus()
}
abstract class Restaurant {
  -long address
  +float level
  +createAmount()
  +deleteLevel()
}
CheckIn --o Payment
Restaurant --> Housekeeping : "1..*"
Payment --|> Housekeeping
note right of Housekeeping : Hotel domain
@enduml