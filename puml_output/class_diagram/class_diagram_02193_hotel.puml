@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
interface Housekeeping {
  #boolean note
  +float id
  +updateDescription()
}
class Payment {
  -int description
  -float phone
  +Date score
  +sendScore()
  +createPrice()
  +getDuration()
}
class Service {
  #float level
  #boolean type
  -String amount
  +boolean phone
  +String total
  +createLevel()
  +calculateEmail()
  +calculateCreatedat()
  +setUpdatedat()
}
class CheckIn {
  -Date price
  #String updatedAt
  -double score
  +int email
  #int createdAt
  +deleteAmount()
}
class Restaurant {
  #int id
  -int address
  +boolean total
  -double quantity
  +float amount
  +sendStatus()
  +saveTotal()
  +validateStatus()
  +sendAmount()
}
Restaurant ..|> Service
Housekeeping ..|> Restaurant
@enduml