@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Depot {
  #Date type
  -Date name
  -double level
  +Date email
  +createName()
  +processCreatedat()
  +saveQuantity()
  +saveLevel()
}
interface Shipment {
  +double score
  #int phone
  -int createdAt
  +double total
  +deleteStatus()
  +validateType()
  +saveCode()
}
abstract class DeliveryNote {
  -int duration
  #String updatedAt
  -int status
  -float note
  -long name
  +cancelDescription()
}
class Driver {
  -String phone
  +boolean type
  -String code
  +long note
  +Date total
  +cancelPrice()
  +getStatus()
}
interface Customer {
  +String level
  +long score
  #boolean updatedAt
  +String code
  +updateCreatedat()
}
Customer ..|> DeliveryNote
DeliveryNote --|> Depot
Customer ..|> Depot
@enduml