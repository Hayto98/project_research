@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
abstract class Publisher {
  +boolean type
  +float email
  +String price
  +findDuration()
}
abstract class Fine {
  #int name
  +Date level
  #double duration
  #String amount
  +validateQuantity()
  +updateAmount()
  +saveUpdatedat()
}
class Shelf {
  -boolean updatedAt
  +boolean quantity
  #String active
  #long price
  +deleteDescription()
  +getActive()
  +saveTotal()
  +getScore()
}
class Librarian {
  -int createdAt
  +int active
  -boolean amount
  #boolean email
  +double level
  +sendId()
  +calculatePhone()
  +calculateUpdatedat()
}
class Renewal {
  -String quantity
  -double name
  -float status
  -long email
  -int level
  +calculateQuantity()
  +sendQuantity()
  +setNote()
}
class Catalog {
  #boolean phone
  -Date id
  +String amount
  +deleteEmail()
  +validateStatus()
}
class Reservation {
  -long level
  #int id
  -boolean total
  +setCreatedat()
  +getScore()
}
Shelf ..> Librarian : "*"
Fine --> Shelf : "1..*"
Publisher ..> Catalog : "0..1"
Shelf ..> Renewal : "1..*"
Librarian --> Renewal : "*"
@enduml