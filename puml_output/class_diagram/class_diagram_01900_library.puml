@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
abstract class Publisher {
  +boolean type
  +float email
  +String price
  +sendNote()
}
class Fine {
  +Date level
  +int name
  +sendName()
  +createAmount()
  +saveName()
  +createUpdatedat()
}
class Shelf {
  -boolean phone
  #boolean level
  +boolean status
  #double score
  +boolean address
  +findEmail()
  +cancelEmail()
}
class Librarian {
  #Date name
  #int updatedAt
  -long address
  +createCreatedat()
  +cancelType()
}
class Renewal {
  +long status
  +float email
  +processQuantity()
  +calculateAddress()
  +createAmount()
}
class Catalog {
  +float active
  +boolean total
  #double address
  #int createdAt
  +int phone
  +updateLevel()
  +getTotal()
}
class Reservation {
  #int active
  #boolean description
  -long address
  -Date duration
  +deleteAddress()
  +sendEmail()
  +getUpdatedat()
  +createDuration()
}
Librarian --> Renewal : "*"
Fine --o Librarian
Renewal --> Fine : "1..*"
Fine --|> Catalog
note right of Publisher : Library domain
@enduml