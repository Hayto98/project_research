@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Grade {
  #int score
  -String quantity
  +validateAddress()
  +sendTotal()
  +createQuantity()
  +cancelAddress()
}
class Assignment {
  #float id
  #long name
  +int duration
  -boolean code
  #boolean active
  +processName()
  +getActive()
}
class Student {
  -double updatedAt
  +int status
  -float id
  +int note
  +getStatus()
  +processType()
  +saveCode()
}
interface Classroom {
  +float id
  -float description
  -int code
  #double total
  +deleteAmount()
}
abstract class Library {
  #float score
  -long status
  -double type
  -float amount
  +cancelActive()
  +deleteQuantity()
}
interface Attendance {
  #String note
  -Date active
  #Date duration
  +updateId()
  +deleteLevel()
  +processQuantity()
  +processPrice()
}
Grade ..> Assignment : "*"
Attendance --> Student : "1..*"
Classroom --> Assignment : "1..*"
Assignment ..> Grade : "0..1"
Attendance --* Grade
@enduml