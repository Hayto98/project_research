@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Grade {
  #int score
  -String quantity
  +createId()
  +createQuantity()
  +createPrice()
  +getName()
}
class Assignment {
  +int code
  -boolean address
  +getPhone()
  +sendAddress()
}
class Student {
  -double id
  -int score
  +validateDescription()
  +updateEmail()
}
abstract class Classroom {
  -String active
  -float email
  -int id
  #double description
  #float code
  +calculateType()
}
class Library {
  #float type
  -long amount
  +processPhone()
  +deleteLevel()
  +setLevel()
}
class Attendance {
  #float active
  +int note
  -String id
  +float type
  #double total
  +sendQuantity()
  +calculateUpdatedat()
  +cancelQuantity()
}
Grade ..> Assignment : "1"
Student --> Attendance : "1..*"
Student --* Library
note right of Grade : Education domain
@enduml