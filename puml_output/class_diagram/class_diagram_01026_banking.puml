@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Teller {
  -String address
  #double status
  +deleteId()
  +deleteName()
  +createDescription()
}
abstract class Deposit {
  +double amount
  #boolean active
  +processDescription()
  +calculateEmail()
  +calculatePrice()
  +getAddress()
}
class Account {
  #double email
  -String quantity
  -int updatedAt
  #Date phone
  +setTotal()
  +sendStatus()
}
interface Withdrawal {
  -float status
  #String email
  +findCreatedat()
  +cancelPrice()
  +setAmount()
}
class Interest {
  -long type
  +long email
  +deleteNote()
}
interface Transaction {
  -boolean note
  -double name
  +cancelQuantity()
  +cancelActive()
}
Withdrawal --|> Deposit
Transaction --* Withdrawal
@enduml