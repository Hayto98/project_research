@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Library {
  +Date status
  -int type
  -long createdAt
  +Date note
  +saveActive()
  +cancelNote()
  +savePhone()
  +cancelTotal()
}
class Assignment {
  +long createdAt
  +int address
  #boolean active
  #String score
  +validatePhone()
}
class Enrollment {
  +long score
  -long address
  #String code
  #Date phone
  +setQuantity()
}
abstract class Attendance {
  #Date description
  #int address
  #double status
  +int code
  -float total
  +getName()
  +getDuration()
  +cancelQuantity()
  +getScore()
}
interface Department {
  -int createdAt
  +long level
  -String active
  +getUpdatedat()
  +validateQuantity()
}
class Grade {
  -long quantity
  #String type
  -int description
  #boolean id
  +processStatus()
  +updateType()
  +setQuantity()
}
Department ..|> Grade
Grade ..> Enrollment : "0..1"
Grade --> Department : "0..1"
@enduml