@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Library {
  +Date status
  -int type
  -long createdAt
  +Date note
  +sendCreatedat()
  +getId()
  +getAddress()
  +updateAddress()
}
interface Assignment {
  #boolean address
  #String status
  #String description
  +getDuration()
}
class Enrollment {
  -double duration
  -boolean code
  +float phone
  #Date description
  +calculateDuration()
}
interface Attendance {
  #Date description
  #int address
  #double status
  +int code
  -float total
  +processActive()
  +saveActive()
  +deleteCreatedat()
  +cancelActive()
}
class Department {
  +int amount
  +long quantity
  #long email
  +processDescription()
  +getPhone()
  +validateActive()
}
class Grade {
  +float amount
  #boolean active
  #int address
  #Date phone
  +saveQuantity()
  +saveUpdatedat()
}
Assignment --* Enrollment
Assignment --* Grade
Enrollment ..|> Library
note right of Library : Education domain
@enduml