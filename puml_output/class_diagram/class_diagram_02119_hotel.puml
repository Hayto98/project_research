@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
abstract class Reservation {
  +boolean id
  -boolean description
  #long amount
  -Date level
  #Date note
  +findName()
  +findStatus()
}
class Service {
  #boolean score
  -double amount
  +int duration
  #boolean quantity
  #int total
  +processDuration()
  +validateLevel()
  +findQuantity()
  +calculateUpdatedat()
}
class Invoice {
  #float status
  +double createdAt
  +findStatus()
  +sendLevel()
  +updateNote()
  +createScore()
}
class Staff {
  +long status
  #double active
  -long amount
  +long level
  -long updatedAt
  +cancelAddress()
}
interface Amenity {
  +double name
  -boolean score
  +calculateName()
  +getDescription()
  +createStatus()
  +processPrice()
}
class Booking {
  +double total
  -boolean name
  -long level
  +validateNote()
  +deletePhone()
}
Staff --|> Booking
Reservation --> Booking : "1"
@enduml