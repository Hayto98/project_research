@startuml
skinparam monochrome true
skinparam shadowing true
class Transaction {
  +float email
  #String score
  -double price
  +saveCode()
  +processQuantity()
}
class Account {
  #boolean level
  +double id
  #Date total
  +calculateCode()
  +updateQuantity()
  +deleteAddress()
}
abstract class Transfer {
  -String code
  #float total
  +double email
  +validateAmount()
  +findDescription()
  +createNote()
}
class Customer {
  +double createdAt
  +Date level
  -Date phone
  +long duration
  +validateUpdatedat()
}
class Branch {
  #int name
  #int createdAt
  -float code
  +long phone
  +float email
  +validateCreatedat()
}
abstract class Interest {
  -Date status
  -Date address
  +updateScore()
  +updateCreatedat()
  +deletePrice()
}
Account ..> Customer : "*"
Account ..> Interest : "*"
note right of Transaction : Banking domain
@enduml