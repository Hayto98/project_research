@startuml
skinparam monochrome true
skinparam shadowing true
class Transaction {
  +float email
  #String score
  -double price
  +setScore()
  +updateAddress()
}
class Account {
  #boolean quantity
  +double amount
  #Date level
  -double id
  +int total
  +updateCreatedat()
  +getPrice()
  +setLevel()
}
class Transfer {
  +Date createdAt
  +double code
  -long total
  +Date email
  #int score
  +cancelType()
  +cancelQuantity()
  +validateCode()
}
interface Customer {
  +double createdAt
  +Date level
  -Date phone
  +long duration
  +calculateName()
}
class Branch {
  +String note
  #float name
  +deleteId()
  +validatePrice()
  +calculateScore()
}
class Interest {
  +float price
  +long status
  +double phone
  +createPhone()
}
Transfer ..> Interest : "1..*"
Account ..|> Branch
Account --o Interest
Interest ..|> Transaction
@enduml