@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
interface Hashtag {
  +long description
  #String type
  +boolean updatedAt
  +getTotal()
  +processPhone()
}
interface Message {
  -Date phone
  #Date name
  +float status
  #double note
  +processTotal()
  +createUpdatedat()
}
class Report {
  -float amount
  -int updatedAt
  -Date name
  +long id
  +sendEmail()
}
class Album {
  -long level
  #String address
  -long note
  +float duration
  #int status
  +sendType()
}
abstract class Comment {
  -String id
  -float duration
  +boolean code
  -int type
  +getTotal()
}
Album --o Report
Message --> Report : "*"
Album ..|> Message
@enduml