@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
interface Hashtag {
  +long description
  #String type
  +boolean updatedAt
  +updateLevel()
  +sendQuantity()
}
class Message {
  -Date status
  #Date note
  +saveType()
  +cancelCreatedat()
}
abstract class Report {
  +String phone
  +double amount
  +deleteType()
  +findStatus()
  +validateActive()
}
class Album {
  -Date address
  -boolean total
  +double duration
  +saveCode()
  +calculateAddress()
  +deleteAmount()
}
class Comment {
  -double duration
  +double email
  +boolean id
  -int score
  +int code
  +processAddress()
  +calculateUpdatedat()
  +createScore()
}
Comment --o Album
Message --* Comment
Comment ..|> Report
note right of Hashtag : Social Media domain
@enduml