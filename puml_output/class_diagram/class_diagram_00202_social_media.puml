@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
interface Notification {
  +boolean email
  -int createdAt
  -long note
  #Date type
  +findPhone()
  +cancelAmount()
  +processUpdatedat()
}
abstract class User {
  #double name
  -float type
  +saveDescription()
  +getLevel()
  +sendId()
}
class Group {
  +boolean id
  -int phone
  +long type
  +boolean email
  -long code
  +processUpdatedat()
  +createAmount()
  +validateId()
}
class Post {
  #String createdAt
  +double address
  -Date quantity
  +sendName()
}
class Hashtag {
  -Date score
  -boolean status
  +String createdAt
  #double level
  +boolean active
  +deleteQuantity()
  +updateQuantity()
  +saveType()
  +calculateEmail()
}
interface Comment {
  +String status
  -String id
  +setType()
  +deleteName()
  +processTotal()
  +sendName()
}
Comment --> Group : "1..*"
Group ..> Notification : "1..*"
User ..> Post : "*"
@enduml