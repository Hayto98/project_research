@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
interface Notification {
  +boolean email
  -int createdAt
  -long note
  #Date type
  +deleteScore()
  +deletePrice()
  +setName()
}
abstract class User {
  -String note
  #long address
  -boolean code
  -boolean createdAt
  #float status
  +getLevel()
}
class Group {
  #double status
  -Date address
  #long duration
  +validateStatus()
  +setCreatedat()
}
class Post {
  -Date quantity
  +double status
  +Date amount
  -boolean price
  +updateDuration()
}
class Hashtag {
  #int address
  +Date price
  +setActive()
  +processStatus()
  +getScore()
  +getStatus()
}
class Comment {
  +Date code
  -int quantity
  +processType()
  +saveCreatedat()
  +savePhone()
}
Group ..> Notification : "1..*"
User ..> Post : "*"
Notification --|> Group
Notification ..|> Post
note right of Notification : Social Media domain
@enduml