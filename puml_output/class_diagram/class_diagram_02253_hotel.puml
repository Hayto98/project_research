@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class CheckOut {
  -long name
  +float quantity
  -boolean description
  +validateEmail()
  +findTotal()
}
class Room {
  -boolean total
  -boolean active
  -boolean type
  +String id
  +String score
  +cancelLevel()
  +processId()
  +processType()
  +validatePrice()
}
class Booking {
  -double active
  -float createdAt
  -boolean phone
  -long address
  +processDuration()
  +getNote()
}
class Invoice {
  -double createdAt
  #double quantity
  -long total
  +double note
  -double active
  +createQuantity()
}
class Reservation {
  #boolean createdAt
  -Date quantity
  #int note
  -Date level
  #Date description
  +calculateDescription()
  +findScore()
}
interface Payment {
  +String status
  -Date price
  -boolean score
  +long quantity
  +createAmount()
  +validateStatus()
  +sendName()
}
Payment --|> Booking
CheckOut ..> Invoice : "1..*"
Booking --> Room : "1"
Invoice ..|> Booking
Payment --* CheckOut
@enduml