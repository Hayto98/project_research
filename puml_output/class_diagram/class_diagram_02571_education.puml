@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Attendance {
  +int level
  #int code
  +Date phone
  +findPhone()
  +findNote()
  +updatePhone()
}
class Classroom {
  +boolean level
  -int price
  -double description
  +double id
  +createPhone()
  +processNote()
  +saveAmount()
  +createLevel()
}
class Schedule {
  +String email
  #double quantity
  +getEmail()
  +calculateScore()
  +updateName()
  +saveAddress()
}
class Department {
  +double name
  #long active
  +sendActive()
  +processAddress()
  +saveAddress()
  +saveAmount()
}
class Exam {
  #float name
  +int score
  -boolean duration
  -String phone
  +cancelActive()
  +cancelDescription()
  +calculateDuration()
}
Schedule ..|> Attendance
Department --o Classroom
@enduml