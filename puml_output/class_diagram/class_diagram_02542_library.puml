@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
abstract class Renewal {
  -int quantity
  #String type
  -Date note
  +Date price
  +double email
  +updateCreatedat()
}
class Shelf {
  #String email
  +String description
  -boolean score
  +double status
  -boolean id
  +cancelEmail()
}
class Branch {
  +float id
  +int phone
  -int total
  +setCreatedat()
  +updateActive()
  +validateCreatedat()
  +saveDuration()
}
abstract class Reservation {
  -Date total
  -boolean createdAt
  #double id
  -int updatedAt
  +findEmail()
  +findAddress()
  +findPrice()
}
Renewal ..> Reservation : "1"
Branch --> Reservation : "1"
Reservation --|> Shelf
@enduml