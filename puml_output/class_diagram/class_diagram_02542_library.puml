@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
abstract class Renewal {
  -int quantity
  #String type
  -Date note
  +Date price
  +double email
  +getType()
}
class Shelf {
  +Date score
  +int status
  +double active
  +calculateQuantity()
}
interface Branch {
  +String status
  -Date duration
  +getDescription()
  +deleteAddress()
  +deleteType()
  +findId()
}
class Reservation {
  -Date quantity
  -boolean total
  #double createdAt
  -int id
  -int updatedAt
  +getCode()
  +saveCode()
  +createScore()
}
Reservation --|> Shelf
Branch --* Reservation
note right of Renewal : Library domain
@enduml