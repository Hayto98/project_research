@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Reservation {
  #long note
  +boolean createdAt
  #String duration
  #float quantity
  +updateScore()
}
class Restaurant {
  -long quantity
  #long address
  +sendNote()
  +processDescription()
}
class Guest {
  +Date createdAt
  +boolean phone
  #int active
  +findName()
  +updatePrice()
}
class Room {
  -String name
  -Date email
  +findTotal()
  +validateEmail()
}
class Booking {
  +int code
  -boolean quantity
  +boolean name
  -int status
  #long active
  +findLevel()
  +updateScore()
}
class Invoice {
  +Date status
  +double type
  +int name
  +findAmount()
}
class Amenity {
  +float email
  -float address
  #int amount
  #String duration
  +updateDescription()
  +processPrice()
  +getTotal()
  +findDescription()
}
Amenity --* Room
Amenity ..|> Booking
Reservation --o Amenity
Booking --o Invoice
@enduml