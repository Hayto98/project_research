@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Reservation {
  #long note
  +boolean createdAt
  #String duration
  #float quantity
  +findUpdatedat()
}
interface Restaurant {
  -long quantity
  #long address
  +updateQuantity()
  +validateAmount()
}
class Guest {
  #boolean active
  +boolean id
  +Date updatedAt
  +String createdAt
  +cancelEmail()
}
abstract class Room {
  +int email
  -Date amount
  +createName()
}
class Booking {
  -boolean name
  +boolean amount
  +updateLevel()
  +validateAmount()
  +findAddress()
  +updateStatus()
}
abstract class Invoice {
  -int name
  +float updatedAt
  +calculateUpdatedat()
}
class Amenity {
  +float address
  -float amount
  #int score
  #String email
  +updateUpdatedat()
  +updateDuration()
  +processTotal()
  +createDuration()
}
Amenity --|> Room
Reservation --> Room : "*"
note right of Reservation : Hotel domain
@enduml