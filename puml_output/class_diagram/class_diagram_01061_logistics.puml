@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
interface DeliveryNote {
  -String duration
  -Date level
  -float createdAt
  +double quantity
  +boolean note
  +findCreatedat()
}
interface Vehicle {
  #Date address
  #boolean code
  +String status
  +String total
  +cancelCode()
  +saveQuantity()
}
abstract class Package {
  #int email
  +long phone
  #boolean score
  +Date note
  -Date id
  +deleteName()
}
interface Customer {
  #Date quantity
  +boolean description
  #Date status
  #String type
  #long level
  +getStatus()
  +validateLevel()
  +setAddress()
  +saveQuantity()
}
class Inventory {
  #int total
  -int address
  -float code
  +float duration
  +deleteTotal()
  +getUpdatedat()
}
class FuelLog {
  #boolean id
  #int email
  +getPhone()
  +processTotal()
}
class Manifest {
  -float email
  +String id
  +calculateId()
  +cancelScore()
  +updateAddress()
}
Vehicle --> Package : "0..1"
FuelLog --o Customer
Inventory --* DeliveryNote
Package --> Inventory : "1"
Inventory --> Package : "1"
DeliveryNote ..> Customer : "1..*"
note right of DeliveryNote : Logistics domain
@enduml