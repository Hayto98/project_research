@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
interface DeliveryNote {
  -String duration
  -Date level
  -float createdAt
  +double quantity
  +boolean note
  +validateTotal()
}
class Vehicle {
  #Date address
  #boolean code
  +String status
  +String total
  +findUpdatedat()
  +createAddress()
}
class Package {
  #int type
  +long email
  #boolean phone
  +Date note
  -Date id
  +setType()
}
class Customer {
  #Date quantity
  +boolean description
  #Date status
  #String type
  #long level
  +updateDuration()
  +setStatus()
  +setEmail()
  +cancelActive()
}
class Inventory {
  #Date quantity
  #long email
  +double address
  #int total
  +setType()
  +processAddress()
  +getNote()
}
class FuelLog {
  +long description
  #boolean total
  #Date id
  +updatePrice()
}
class Manifest {
  -double createdAt
  +String id
  -Date phone
  +calculateCode()
}
DeliveryNote --o Package
DeliveryNote --> Inventory : "0..1"
Manifest --> Package : "0..1"
@enduml