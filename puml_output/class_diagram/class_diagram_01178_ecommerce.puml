@startuml
skinparam ArrowColor #555555
class Shipment {
  -int address
  #float price
  +cancelCreatedat()
}
class Coupon {
  +float amount
  #double email
  +setDuration()
}
abstract class Product {
  -int phone
  -long code
  #int duration
  +processDescription()
  +findDescription()
}
abstract class Category {
  #long address
  #int phone
  #Date type
  #String email
  +Date code
  +sendId()
}
abstract class Supplier {
  #double type
  -int score
  +calculateDuration()
  +saveCode()
  +cancelNote()
  +processAmount()
}
interface Warehouse {
  #float email
  -double active
  +findEmail()
  +findDuration()
}
Supplier --|> Product
Supplier --> Coupon : "0..1"
note right of Shipment : Ecommerce domain
@enduml