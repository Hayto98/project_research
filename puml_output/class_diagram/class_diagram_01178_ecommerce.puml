@startuml
skinparam ArrowColor #555555
class Shipment {
  -int address
  #float price
  +getCode()
}
class Coupon {
  -String name
  #double amount
  +getType()
}
interface Product {
  +double updatedAt
  -float phone
  #int code
  +double level
  #int quantity
  +deletePrice()
  +processType()
}
class Category {
  #int type
  #Date email
  #String code
  +Date quantity
  +findPrice()
}
class Supplier {
  +boolean id
  -double type
  #Date score
  +boolean note
  -double phone
  +createUpdatedat()
  +saveStatus()
}
class Warehouse {
  #float active
  -Date phone
  #String type
  #float createdAt
  +findNote()
  +validateDescription()
  +sendActive()
}
Supplier --|> Coupon
Warehouse --* Supplier
Shipment ..> Supplier : "*"
@enduml