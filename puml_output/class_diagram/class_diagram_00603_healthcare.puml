@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Ward {
  -long price
  +int note
  -long score
  +String type
  +Date status
  +validateQuantity()
  +processDescription()
}
class Treatment {
  #boolean status
  +Date level
  +updateDuration()
}
abstract class Doctor {
  #float active
  +boolean amount
  +boolean createdAt
  #long duration
  #boolean name
  +calculateScore()
  +setTotal()
}
class Insurance {
  +double amount
  -float createdAt
  +String total
  #String note
  -int active
  +updateScore()
  +cancelNote()
  +setName()
}
class Patient {
  #Date updatedAt
  -int phone
  -long createdAt
  #Date description
  #float address
  +validateCode()
  +updateActive()
  +saveAmount()
}
abstract class Prescription {
  +long createdAt
  -Date address
  +deletePrice()
  +setDescription()
  +updateLevel()
  +setCreatedat()
}
abstract class Billing {
  -double id
  #long duration
  #int level
  -int address
  -float description
  +saveDescription()
  +processAddress()
  +sendCreatedat()
  +calculateDuration()
}
Doctor --|> Billing
Ward ..|> Prescription
@enduml