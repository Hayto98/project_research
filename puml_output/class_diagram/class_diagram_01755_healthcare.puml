@startuml

class Appointment {
  -long address
  -String amount
  -String name
  +calculateEmail()
  +saveDescription()
}
interface Billing {
  +boolean phone
  #long updatedAt
  -float code
  -float createdAt
  +int price
  +cancelUpdatedat()
}
abstract class Treatment {
  -float amount
  -double active
  +saveId()
  +findPhone()
}
class Ward {
  -int description
  #String phone
  +int name
  +deleteQuantity()
  +processPhone()
  +cancelNote()
}
Appointment --|> Billing
Billing --o Treatment
@enduml