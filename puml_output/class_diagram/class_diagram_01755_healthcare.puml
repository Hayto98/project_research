@startuml

class Appointment {
  -long address
  -String amount
  -String name
  +getScore()
  +calculatePhone()
}
class Billing {
  +boolean createdAt
  #long price
  +processName()
  +updateId()
  +findType()
  +findStatus()
}
class Treatment {
  +long note
  #Date price
  +int updatedAt
  -float name
  +processDescription()
}
class Ward {
  +float description
  +Date email
  #String status
  +setCreatedat()
  +saveNote()
  +validateDescription()
  +processType()
}
Ward --* Treatment
Treatment --|> Ward
Ward ..> Billing : "0..1"
note right of Appointment : Healthcare domain
@enduml