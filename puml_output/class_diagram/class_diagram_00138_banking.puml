@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Deposit {
  +boolean email
  -int quantity
  +updateUpdatedat()
  +findUpdatedat()
}
class Transfer {
  #Date name
  #double updatedAt
  +boolean level
  #long address
  +processAddress()
  +updateCode()
  +processLevel()
  +setNote()
}
class Customer {
  -boolean status
  #Date code
  -boolean total
  +validateCode()
  +cancelCode()
  +validateType()
}
interface Beneficiary {
  +double phone
  +int duration
  -boolean price
  +findActive()
  +updateId()
  +cancelScore()
}
Beneficiary --|> Transfer
Transfer --* Customer
@enduml