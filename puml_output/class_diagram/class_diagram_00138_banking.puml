@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Deposit {
  +boolean email
  -int quantity
  +setDuration()
  +createAddress()
}
class Transfer {
  #Date updatedAt
  -String address
  #boolean score
  +processTotal()
  +calculateCode()
  +deleteStatus()
}
class Customer {
  -float price
  #boolean score
  +long total
  -double quantity
  +double description
  +deleteType()
  +sendAddress()
}
abstract class Beneficiary {
  +Date price
  -boolean phone
  -double status
  +findStatus()
  +sendCreatedat()
  +saveAddress()
  +saveDescription()
}
Beneficiary --> Customer : "1..*"
Customer --> Transfer : "1"
note right of Deposit : Banking domain
@enduml