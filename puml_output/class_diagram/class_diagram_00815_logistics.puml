@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Depot {
  #Date address
  -boolean level
  -float status
  +int updatedAt
  #Date note
  +validateAmount()
  +createPrice()
  +saveEmail()
}
abstract class Tracking {
  +boolean level
  +int score
  +float name
  +findNote()
  +createScore()
}
interface Inventory {
  -Date amount
  -double description
  +getTotal()
  +cancelDuration()
  +createStatus()
}
abstract class Driver {
  #long active
  -boolean level
  #Date address
  #String amount
  -long email
  +validateScore()
  +deleteId()
  +deleteType()
  +getUpdatedat()
}
interface Package {
  -float status
  +long score
  +deleteEmail()
  +createScore()
  +setPrice()
}
class Customer {
  #boolean score
  #float description
  +validateDuration()
  +sendScore()
  +setType()
}
class Vehicle {
  #float address
  -float code
  -boolean name
  #Date amount
  +findType()
  +setEmail()
  +validatePrice()
  +createEmail()
}
Inventory --> Package : "1"
Customer --> Depot : "1"
Package ..|> Driver
Package --> Customer : "1..*"
Tracking --|> Driver
note right of Depot : Logistics domain
@enduml