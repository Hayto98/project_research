@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Depot {
  #Date address
  -boolean level
  -float status
  +int updatedAt
  #Date note
  +validateDuration()
  +validateQuantity()
  +cancelPhone()
}
abstract class Tracking {
  +boolean price
  +int amount
  +float score
  +Date name
  +findCreatedat()
  +calculatePrice()
  +calculateLevel()
  +cancelName()
}
interface Inventory {
  -Date amount
  -double description
  +sendTotal()
  +cancelScore()
  +getAddress()
}
interface Driver {
  #long status
  +Date price
  -float note
  #long active
  +findPrice()
  +setId()
  +deleteStatus()
  +getAmount()
}
class Package {
  +int email
  -String type
  +Date address
  #Date amount
  +getName()
}
class Customer {
  #long updatedAt
  -boolean email
  +double level
  -String description
  +setPhone()
  +deleteEmail()
}
interface Vehicle {
  -long phone
  -long active
  +String score
  +boolean status
  +getStatus()
  +cancelType()
  +validateAmount()
}
Package ..> Customer : "*"
Customer --o Vehicle
Depot --* Inventory
Customer --* Driver
Inventory --o Customer
Inventory --> Package : "1"
@enduml