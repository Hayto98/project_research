@startuml
skinparam defaultFontSize 11
class Exam {
  +int id
  -Date address
  +String level
  #float duration
  -boolean active
  +savePrice()
  +setQuantity()
  +sendCreatedat()
  +saveCreatedat()
}
interface Department {
  +float quantity
  -boolean email
  +float description
  +getLevel()
  +processLevel()
  +saveQuantity()
}
abstract class Library {
  #float active
  +boolean phone
  +createPrice()
}
class Teacher {
  -Date address
  +long createdAt
  -String email
  +Date quantity
  #Date name
  +updateDuration()
  +findUpdatedat()
}
abstract class Assignment {
  #boolean note
  +int createdAt
  -boolean total
  +double price
  +findQuantity()
  +getName()
  +updateQuantity()
  +getLevel()
}
Teacher ..> Library : "1..*"
Exam --o Assignment
Exam ..|> Department
note right of Exam : Education domain
@enduml