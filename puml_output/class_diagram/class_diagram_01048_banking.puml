@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Deposit {
  -int quantity
  +Date type
  -double price
  +float email
  +updateStatus()
}
class Card {
  #boolean active
  -Date status
  #String code
  +calculateTotal()
  +createActive()
}
interface Beneficiary {
  +long phone
  #Date createdAt
  -String level
  #float note
  +setStatus()
  +setCreatedat()
  +findUpdatedat()
}
abstract class Transaction {
  #int id
  #Date updatedAt
  -float phone
  +String email
  +setId()
  +deleteTotal()
  +deleteStatus()
}
class Transfer {
  #Date email
  +double createdAt
  -long amount
  +findActive()
  +cancelNote()
  +findDescription()
  +validateType()
}
Deposit ..|> Transaction
Deposit --* Beneficiary
note right of Deposit : Banking domain
@enduml