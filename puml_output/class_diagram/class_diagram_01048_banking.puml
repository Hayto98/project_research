@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Deposit {
  -int quantity
  +Date type
  -double price
  +float email
  +sendNote()
}
class Card {
  +Date updatedAt
  #long active
  #boolean status
  +findAddress()
}
abstract class Beneficiary {
  #float quantity
  +int active
  -int level
  -boolean address
  #double phone
  +updateScore()
}
class Transaction {
  +Date status
  +float code
  +findDescription()
  +calculateName()
  +findTotal()
  +findLevel()
}
class Transfer {
  #int phone
  #Date score
  -float email
  +processQuantity()
}
Deposit ..|> Transfer
Transaction --|> Card
Beneficiary ..> Card : "1..*"
@enduml