@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Exam {
  #Date status
  +double amount
  +double id
  #Date email
  -int price
  +saveUpdatedat()
  +saveStatus()
  +getPrice()
  +deleteTotal()
}
abstract class Assignment {
  #int score
  +boolean duration
  +int name
  -String level
  +findScore()
  +validatePhone()
}
class Book {
  -long amount
  +double level
  +getStatus()
  +findUpdatedat()
  +saveType()
}
class Student {
  +String address
  #long total
  +getCode()
  +setPhone()
}
class Department {
  -long phone
  -boolean level
  +findTotal()
  +setDuration()
  +createId()
  +getQuantity()
}
Exam --|> Book
Department --> Exam : "*"
Department --|> Book
@enduml