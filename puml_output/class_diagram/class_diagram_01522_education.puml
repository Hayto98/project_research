@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Exam {
  #Date status
  +double amount
  +double id
  #Date email
  -int price
  +saveTotal()
  +validateScore()
  +sendName()
  +getAmount()
}
class Assignment {
  +float createdAt
  #int email
  +setStatus()
  +findStatus()
  +deleteLevel()
}
class Book {
  +long name
  -float type
  +String quantity
  #long status
  +cancelDuration()
  +getCode()
}
class Student {
  -String phone
  #String type
  #double total
  #long score
  +boolean status
  +findActive()
  +processNote()
}
class Department {
  +boolean id
  +int phone
  +validateLevel()
}
Exam --* Assignment
Exam --* Department
Student --o Book
note right of Exam : Education domain
@enduml