@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Service {
  #Date score
  #String level
  +boolean email
  +deleteName()
  +validateEmail()
  +calculateCode()
  +setAmount()
}
class CheckOut {
  #Date phone
  #float createdAt
  +cancelActive()
  +deleteStatus()
}
class CheckIn {
  -String phone
  -boolean quantity
  -Date amount
  +float duration
  +updateCode()
  +cancelType()
  +updateUpdatedat()
  +cancelDescription()
}
interface Guest {
  +boolean updatedAt
  +double price
  -boolean score
  +String createdAt
  +setScore()
  +cancelNote()
  +deleteCreatedat()
  +getType()
}
abstract class Staff {
  #int quantity
  -long code
  -double total
  +float updatedAt
  +Date id
  +validatePhone()
  +saveNote()
  +cancelAddress()
  +processLevel()
}
class Housekeeping {
  +Date description
  +float level
  #Date quantity
  #double address
  +calculateActive()
}
Staff ..|> Guest
Staff ..|> Housekeeping
CheckOut ..|> Staff
note right of Service : Hotel domain
@enduml