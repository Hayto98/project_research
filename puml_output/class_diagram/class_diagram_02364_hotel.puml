@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Service {
  #Date score
  #String level
  +boolean email
  +setLevel()
  +calculateEmail()
  +findCode()
  +calculateUpdatedat()
}
class CheckOut {
  #long code
  #int duration
  #Date amount
  #float description
  +boolean status
  +createPhone()
  +findTotal()
}
class CheckIn {
  -String phone
  -boolean quantity
  -Date amount
  +float duration
  +updateStatus()
  +getDescription()
  +setDescription()
  +getQuantity()
}
abstract class Guest {
  #long updatedAt
  +double level
  #int description
  +setId()
}
class Staff {
  +Date email
  #float level
  #float status
  -int id
  +String type
  +sendUpdatedat()
  +createEmail()
  +saveCode()
  +findActive()
}
class Housekeeping {
  +Date total
  +long updatedAt
  +createAmount()
  +sendName()
  +getDescription()
}
Service --* Guest
CheckIn --> Guest : "1..*"
@enduml