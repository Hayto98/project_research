@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Shelf {
  #long status
  #double name
  -float email
  -String code
  +long total
  +setUpdatedat()
}
interface Reservation {
  -int id
  +float total
  +int email
  #long price
  +cancelTotal()
  +sendUpdatedat()
  +calculateEmail()
  +sendId()
}
class Member {
  -int quantity
  +long amount
  #float duration
  +findStatus()
  +deleteEmail()
}
class Branch {
  -double createdAt
  +int description
  -Date total
  +int status
  +double type
  +getScore()
  +updateType()
}
class Publisher {
  +int id
  +long phone
  +double duration
  +boolean address
  -String amount
  +validateDuration()
  +deletePhone()
  +calculateLevel()
}
class Catalog {
  -boolean active
  -float name
  +deleteAddress()
  +processCode()
  +calculateNote()
  +setLevel()
}
Catalog --> Publisher : "1..*"
Member ..|> Catalog
@enduml