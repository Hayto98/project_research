@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Shelf {
  #long status
  #double name
  -float email
  -String code
  +long total
  +getDuration()
}
class Reservation {
  -long total
  +int email
  +updateQuantity()
  +sendNote()
}
class Member {
  +long createdAt
  +long address
  +deleteId()
  +validateScore()
  +deleteCreatedat()
}
abstract class Branch {
  -double description
  -String total
  +long status
  +deleteCreatedat()
  +calculateUpdatedat()
}
interface Publisher {
  #float id
  +long active
  #String total
  +sendAmount()
  +getAmount()
  +getEmail()
}
class Catalog {
  -float code
  +String level
  #boolean email
  #float name
  +double address
  +processUpdatedat()
  +getCreatedat()
  +deleteLevel()
  +saveActive()
}
Catalog --> Publisher : "1..*"
Member ..|> Catalog
note right of Shelf : Library domain
@enduml