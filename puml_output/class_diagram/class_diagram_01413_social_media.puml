@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Follower {
  -boolean name
  +long code
  +String duration
  +Date email
  #Date id
  +updateQuantity()
  +createDuration()
}
class Album {
  -Date id
  +Date status
  #double amount
  #long type
  #String quantity
  +createDescription()
  +updateId()
  +sendUpdatedat()
}
abstract class Story {
  -int name
  #String amount
  -boolean note
  #long phone
  +float email
  +sendScore()
}
interface Like {
  -Date amount
  -boolean level
  +setLevel()
  +validateCode()
  +updateScore()
  +processStatus()
}
class Message {
  +long quantity
  #String total
  +findUpdatedat()
  +sendEmail()
  +findEmail()
}
Follower --o Album
Like --|> Album
note right of Follower : Social Media domain
@enduml