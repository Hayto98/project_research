@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Amenity {
  -int code
  +String total
  -Date address
  #long id
  +processLevel()
}
class Service {
  -double status
  +long createdAt
  #long phone
  -float type
  +validateCreatedat()
  +setNote()
  +deleteStatus()
}
abstract class Housekeeping {
  #double type
  -String note
  #int name
  +String amount
  +validateEmail()
}
class Booking {
  #float duration
  +String createdAt
  +deleteUpdatedat()
}
Housekeeping --> Amenity : "*"
Housekeeping --|> Service
@enduml