@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Statement {
  +long id
  -boolean phone
  #double updatedAt
  -long total
  +findDescription()
}
class Card {
  #String updatedAt
  #float email
  +calculateEmail()
}
class Branch {
  -long quantity
  +long phone
  +float active
  #boolean email
  +Date description
  +findCode()
  +calculateActive()
}
interface Interest {
  +float total
  +double note
  -float code
  +createEmail()
  +calculateName()
  +createPrice()
  +processCode()
}
class Transfer {
  +boolean description
  #int total
  +long type
  +float amount
  #long active
  +validateId()
  +sendPrice()
  +findDescription()
  +createCreatedat()
}
Statement --o Card
Card --> Interest : "1..*"
Transfer ..|> Statement
Card ..> Branch : "*"
note right of Statement : Banking domain
@enduml