@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Statement {
  +long id
  -boolean phone
  #double updatedAt
  -long total
  +cancelUpdatedat()
}
class Card {
  #String id
  #float updatedAt
  #Date email
  +setNote()
}
class Branch {
  -boolean level
  -int type
  -long quantity
  +createQuantity()
  +getType()
}
interface Interest {
  #boolean amount
  #boolean code
  #Date price
  +getAddress()
  +cancelQuantity()
}
interface Transfer {
  -long description
  #float name
  +sendAddress()
  +validateAmount()
  +calculateQuantity()
  +calculateId()
}
Interest --|> Transfer
Statement ..|> Interest
Transfer --o Interest
@enduml