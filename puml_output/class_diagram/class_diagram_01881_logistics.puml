@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
abstract class Inventory {
  -long createdAt
  -long status
  +float email
  +Date note
  +updateQuantity()
  +getId()
}
interface Driver {
  #float name
  #long amount
  #float score
  +setDescription()
}
class Shipment {
  -float price
  #int code
  -int createdAt
  +boolean updatedAt
  #int amount
  +calculateNote()
  +deleteLevel()
}
class Customer {
  #String quantity
  -float type
  #double status
  +calculateAddress()
  +updateAddress()
}
interface FuelLog {
  +int note
  #boolean id
  +calculateType()
  +sendDescription()
  +createActive()
}
class Tracking {
  +String updatedAt
  +double id
  +setQuantity()
  +createPhone()
}
Inventory ..|> FuelLog
FuelLog ..> Driver : "0..1"
Customer --o Shipment
@enduml