@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
abstract class Inventory {
  -long createdAt
  -long status
  +float email
  +Date note
  +processLevel()
  +updateName()
}
class Driver {
  -String status
  +int code
  +long email
  #int price
  +deleteUpdatedat()
  +sendUpdatedat()
  +saveDescription()
}
class Shipment {
  -String description
  #String quantity
  +cancelPrice()
  +updateAmount()
  +saveScore()
}
class Customer {
  -String id
  +int updatedAt
  +String description
  +float active
  +double phone
  +setUpdatedat()
  +getDuration()
}
class FuelLog {
  -int updatedAt
  #int total
  -int address
  +findType()
}
abstract class Tracking {
  #double name
  #Date score
  +saveId()
  +getEmail()
  +saveTotal()
}
Shipment ..> FuelLog : "*"
FuelLog --|> Tracking
Shipment ..|> Tracking
Driver ..> Customer : "0..1"
Tracking --> FuelLog : "0..1"
note right of Inventory : Logistics domain
@enduml