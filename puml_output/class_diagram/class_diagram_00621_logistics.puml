@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Manifest {
  +boolean name
  -boolean type
  -float amount
  -long duration
  +processStatus()
  +setCreatedat()
  +findCode()
}
class Package {
  +int score
  #String level
  -long total
  -boolean quantity
  -boolean price
  +createNote()
  +calculateLevel()
  +calculateDuration()
  +calculateQuantity()
}
class Route {
  +Date createdAt
  #long level
  #Date status
  +boolean description
  +getTotal()
  +updateUpdatedat()
}
class Shipment {
  #Date amount
  -float code
  +processId()
  +calculateQuantity()
  +createCode()
}
interface Customer {
  #int amount
  +String level
  -long address
  -long type
  +processLevel()
  +deleteDuration()
  +getEmail()
}
Customer --|> Package
Route ..> Shipment : "*"
Route --> Customer : "*"
@enduml