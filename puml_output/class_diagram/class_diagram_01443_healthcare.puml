@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Hospital {
  +boolean active
  +boolean quantity
  -float code
  +calculateQuantity()
}
class Nurse {
  -long duration
  +long quantity
  -float code
  #long price
  +calculateNote()
  +cancelCode()
  +cancelDuration()
  +sendPrice()
}
class Doctor {
  -int phone
  +String level
  +long score
  +cancelUpdatedat()
  +processTotal()
}
interface LabTest {
  #Date duration
  +int note
  -long active
  +getName()
  +saveDuration()
  +getEmail()
}
class Appointment {
  +String name
  #Date active
  +long level
  -int code
  +deleteNote()
}
class Prescription {
  -double status
  -int amount
  -String active
  +saveStatus()
  +saveScore()
  +deleteEmail()
}
abstract class Diagnosis {
  #long address
  -int amount
  +updateDuration()
}
Hospital --> Nurse : "0..1"
Appointment --> Doctor : "1"
note right of Hospital : Healthcare domain
@enduml