@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Hospital {
  +boolean active
  +boolean quantity
  -float code
  +processType()
}
class Nurse {
  #boolean phone
  -long quantity
  -String code
  +updateLevel()
  +validateDescription()
  +validateTotal()
}
class Doctor {
  +int price
  -boolean note
  #double code
  +int active
  +int duration
  +updateDescription()
  +findDescription()
  +createScore()
}
abstract class LabTest {
  +float active
  -long updatedAt
  #long note
  +String duration
  #boolean description
  +calculateScore()
}
class Appointment {
  +String name
  #Date active
  +long level
  -int code
  +createCreatedat()
}
abstract class Prescription {
  #float updatedAt
  -double status
  -int amount
  +processCode()
  +cancelId()
  +calculateUpdatedat()
  +updateName()
}
interface Diagnosis {
  #long email
  +Date total
  -long name
  +saveEmail()
  +sendEmail()
}
Hospital ..|> Diagnosis
Appointment --> Nurse : "1..*"
Appointment --o Hospital
LabTest --|> Nurse
Doctor --o Hospital
@enduml