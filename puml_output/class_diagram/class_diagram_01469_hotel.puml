@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
abstract class Service {
  -long type
  -float score
  +setUpdatedat()
  +findDuration()
  +setNote()
}
class Staff {
  -int code
  -long price
  #double active
  #Date status
  +createEmail()
  +getStatus()
  +createQuantity()
  +getType()
}
class Housekeeping {
  #long address
  +long email
  +findName()
}
class Guest {
  +Date level
  +float name
  #long price
  #float total
  +float description
  +deleteTotal()
  +findDuration()
  +processAddress()
  +validatePhone()
}
Staff --> Housekeeping : "1..*"
Housekeeping --o Service
@enduml