@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Classroom {
  #boolean score
  #double id
  +findType()
  +setDescription()
  +deleteCode()
  +deleteDuration()
}
class Attendance {
  +boolean active
  -float score
  -String phone
  +Date name
  #double id
  +updateName()
  +cancelAmount()
}
class Book {
  -double active
  #float amount
  #long total
  #boolean score
  -float quantity
  +calculateLevel()
  +deleteName()
}
class Exam {
  +long price
  #int quantity
  +String id
  -long updatedAt
  +double duration
  +findNote()
}
abstract class Library {
  -boolean total
  -String level
  +setType()
}
abstract class Enrollment {
  +Date name
  +float amount
  +float createdAt
  #int price
  -boolean phone
  +sendName()
  +sendName()
}
Attendance --|> Classroom
Classroom ..> Library : "1..*"
Library ..> Exam : "0..1"
note right of Classroom : Education domain
@enduml