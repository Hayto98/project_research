@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Classroom {
  #boolean score
  #double id
  +setCreatedat()
  +validateUpdatedat()
  +validateEmail()
  +validateCreatedat()
}
class Attendance {
  -boolean amount
  #boolean id
  +validateTotal()
  +setUpdatedat()
  +calculateStatus()
}
class Book {
  -String level
  +Date price
  +processActive()
  +saveEmail()
  +findTotal()
  +getQuantity()
}
class Exam {
  #float price
  -Date active
  -long amount
  +setNote()
  +validateType()
  +updateScore()
  +findType()
}
interface Library {
  -boolean level
  +String score
  -double email
  -long updatedAt
  +findLevel()
}
class Enrollment {
  +long updatedAt
  -String quantity
  -Date score
  +Date duration
  -double name
  +setNote()
}
Library --|> Exam
Library --|> Classroom
Exam --o Enrollment
Classroom ..|> Attendance
@enduml