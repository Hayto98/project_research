@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
abstract class Diagnosis {
  +int updatedAt
  +int id
  -float address
  +processPhone()
  +cancelUpdatedat()
}
abstract class MedicalRecord {
  #Date score
  +int address
  -int quantity
  #double createdAt
  +updatePrice()
  +setAddress()
  +saveAddress()
}
class Doctor {
  -boolean name
  +float quantity
  +float phone
  #String amount
  #double level
  +saveScore()
  +calculateTotal()
}
class Patient {
  -Date level
  #double email
  -Date score
  +deleteTotal()
  +createDuration()
}
class Insurance {
  +boolean quantity
  -long level
  +createStatus()
}
Diagnosis ..|> Patient
Doctor --> Patient : "1"
Patient ..|> MedicalRecord
Doctor --> Diagnosis : "0..1"
note right of Diagnosis : Healthcare domain
@enduml