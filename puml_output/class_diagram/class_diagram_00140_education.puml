@startuml
skinparam defaultFontSize 11
class Teacher {
  #String duration
  -double code
  +Date updatedAt
  +long status
  +createLevel()
  +calculateDescription()
  +findActive()
}
class Assignment {
  +double id
  -long phone
  +boolean score
  +double active
  +updateTotal()
}
class Book {
  -long address
  #long id
  +double status
  +boolean type
  +cancelName()
  +sendDuration()
  +saveAmount()
}
interface Schedule {
  +Date id
  -long updatedAt
  #String total
  +sendName()
  +processLevel()
  +calculateAddress()
  +setAddress()
}
class Classroom {
  -long level
  +int duration
  -String note
  +float email
  #int active
  +cancelEmail()
}
interface Grade {
  -double duration
  +float email
  +createCreatedat()
  +updateNote()
}
Assignment --o Book
Classroom --o Schedule
Teacher --> Book : "0..1"
note right of Teacher : Education domain
@enduml