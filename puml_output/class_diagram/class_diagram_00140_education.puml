@startuml
skinparam defaultFontSize 11
class Teacher {
  #String duration
  -double code
  +Date updatedAt
  +long status
  +deleteEmail()
  +updateLevel()
  +deleteUpdatedat()
}
abstract class Assignment {
  #float active
  +long email
  #boolean phone
  +calculateAmount()
}
abstract class Book {
  +int amount
  -Date level
  +long duration
  -Date note
  +updateName()
}
abstract class Schedule {
  #boolean quantity
  -boolean address
  #String code
  #boolean total
  #Date score
  +calculateDuration()
  +setCreatedat()
}
class Classroom {
  +Date updatedAt
  -long total
  +cancelDuration()
}
abstract class Grade {
  -Date type
  -String level
  +createCreatedat()
  +sendCreatedat()
  +sendUpdatedat()
}
Book --o Grade
Book ..|> Teacher
Assignment ..|> Classroom
Classroom ..> Grade : "1"
@enduml