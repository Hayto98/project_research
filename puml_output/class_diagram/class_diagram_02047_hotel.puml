@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
interface Reservation {
  #int total
  +double address
  #float score
  #String email
  +cancelUpdatedat()
}
abstract class Payment {
  +boolean price
  #boolean email
  #double address
  #long level
  +cancelType()
  +deleteCreatedat()
}
class Service {
  +String updatedAt
  #Date description
  +boolean type
  +saveQuantity()
  +updateLevel()
}
class Booking {
  +float total
  +float name
  -Date updatedAt
  +createNote()
  +createName()
}
interface Amenity {
  +int phone
  -boolean code
  +float amount
  #Date address
  +calculateQuantity()
  +saveEmail()
  +cancelActive()
  +calculateLevel()
}
Booking --* Service
Service ..> Booking : "*"
Booking --o Payment
@enduml