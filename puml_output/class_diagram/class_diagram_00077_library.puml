@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
interface Catalog {
  -boolean level
  #Date description
  +createCreatedat()
  +findCreatedat()
  +findAddress()
  +deleteNote()
}
class Reservation {
  +String status
  -int description
  +cancelCode()
  +sendNote()
}
class Book {
  +double phone
  -Date address
  #boolean price
  -String status
  #boolean active
  +updateLevel()
}
class Renewal {
  #int score
  +boolean createdAt
  #long id
  #Date address
  +setDuration()
  +calculatePhone()
  +processDescription()
}
class Librarian {
  +boolean description
  +long active
  -String phone
  +double score
  -boolean status
  +updatePrice()
  +processPrice()
  +processCode()
  +sendActive()
}
abstract class Loan {
  +String active
  +float address
  -float amount
  #double email
  +String code
  +sendAddress()
  +setType()
  +setActive()
  +validateStatus()
}
Loan --* Librarian
Librarian --|> Reservation
Librarian --> Loan : "*"
@enduml