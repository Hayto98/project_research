@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
interface Nurse {
  -long status
  -int total
  -int phone
  #float address
  -float score
  +sendAddress()
  +createQuantity()
  +deleteEmail()
}
class Patient {
  -long phone
  #double total
  #double duration
  -int price
  #long address
  +validateDescription()
  +cancelActive()
  +calculatePrice()
  +cancelCode()
}
class MedicalRecord {
  +long total
  -Date address
  +findAmount()
  +cancelCode()
  +processTotal()
}
class Doctor {
  #double id
  +long updatedAt
  +updateActive()
  +deleteUpdatedat()
}
interface Diagnosis {
  #boolean code
  +String note
  +String createdAt
  -float address
  #boolean name
  +calculatePhone()
  +updateDescription()
  +saveScore()
}
class Billing {
  #float amount
  +String duration
  +int score
  -Date code
  +double quantity
  +createDescription()
  +saveQuantity()
}
Billing ..> MedicalRecord : "1..*"
Nurse ..> MedicalRecord : "1"
Doctor ..> Diagnosis : "*"
MedicalRecord ..|> Nurse
Diagnosis ..|> Billing
@enduml