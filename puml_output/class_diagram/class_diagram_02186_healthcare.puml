@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
interface Nurse {
  -long status
  -int total
  -int phone
  #float address
  -float score
  +createQuantity()
  +findName()
  +processPhone()
}
abstract class Patient {
  -Date price
  -Date active
  -double address
  +boolean email
  +processLevel()
  +sendType()
  +validateId()
}
abstract class MedicalRecord {
  -double id
  -float phone
  +float address
  +String email
  +sendPrice()
  +setQuantity()
}
class Doctor {
  -Date level
  #String score
  +updateAddress()
  +getScore()
  +sendStatus()
  +getName()
}
class Diagnosis {
  -int active
  -float phone
  +int quantity
  #Date createdAt
  +createAmount()
}
class Billing {
  -float amount
  #int note
  #int createdAt
  +savePhone()
  +saveQuantity()
  +setPhone()
  +saveActive()
}
Doctor ..> Diagnosis : "*"
MedicalRecord ..|> Nurse
note right of Nurse : Healthcare domain
@enduml