@startuml
skinparam defaultFontSize 11
class Depot {
  -int level
  -Date price
  -long email
  -String active
  #long score
  +validateAmount()
  +calculatePhone()
  +createId()
  +validateScore()
}
abstract class Vehicle {
  #Date updatedAt
  #Date score
  #long description
  +deleteStatus()
}
class Route {
  +double score
  #long email
  +boolean id
  +String address
  +setNote()
  +validateCode()
  +calculateStatus()
  +updateLevel()
}
abstract class Manifest {
  +String address
  +float status
  -double email
  +float name
  +setPrice()
  +calculateCode()
  +createStatus()
  +createLevel()
}
interface Tracking {
  +long address
  +double name
  #String code
  -int description
  #float price
  +createUpdatedat()
  +sendPrice()
}
abstract class Driver {
  -int quantity
  #float status
  +setCode()
  +updateUpdatedat()
}
Manifest --o Tracking
Route --o Depot
Driver --|> Manifest
note right of Depot : Logistics domain
@enduml