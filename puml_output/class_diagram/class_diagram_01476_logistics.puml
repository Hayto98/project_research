@startuml
skinparam defaultFontSize 11
class Depot {
  -int level
  -Date price
  -long email
  -String active
  #long score
  +validateDuration()
  +createCode()
  +getPhone()
  +cancelId()
}
class Vehicle {
  -boolean address
  +int score
  +calculateDuration()
  +cancelName()
}
interface Route {
  #long name
  #Date amount
  #long status
  #Date updatedAt
  +findQuantity()
}
class Manifest {
  #double address
  +double status
  -String score
  -String description
  +boolean name
  +getNote()
  +deletePhone()
  +validateScore()
  +setId()
}
class Tracking {
  -double name
  +float duration
  -String status
  -double id
  +validateAddress()
}
class Driver {
  +String level
  #boolean active
  +float type
  -String address
  +cancelEmail()
  +getId()
  +processPhone()
}
Route --> Vehicle : "0..1"
@enduml