@startuml
skinparam monochrome true
skinparam shadowing true
class Category {
  -Date updatedAt
  +Date code
  +createType()
}
class Order {
  +Date createdAt
  #int quantity
  -double price
  +float duration
  +float code
  +getCreatedat()
  +calculateQuantity()
}
class Warehouse {
  -long description
  -float amount
  +float name
  -double email
  -float code
  +validateAmount()
  +findQuantity()
}
class Wishlist {
  +Date level
  #float updatedAt
  +calculateName()
  +getUpdatedat()
  +updateScore()
  +getDescription()
}
class Invoice {
  +String address
  -boolean duration
  #float note
  +validateType()
  +saveQuantity()
}
class Shipment {
  +double phone
  #Date code
  -String duration
  +validateId()
}
interface Cart {
  #float phone
  +long email
  #Date price
  #boolean score
  #String total
  +sendUpdatedat()
}
Warehouse ..> Invoice : "1..*"
Invoice ..|> Cart
Cart ..|> Category
Category --* Order
Category --* Invoice
@enduml