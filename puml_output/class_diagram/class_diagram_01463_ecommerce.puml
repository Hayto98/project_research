@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
interface Coupon {
  #float type
  +String address
  +double id
  #float name
  #boolean description
  +saveType()
  +cancelType()
}
class Payment {
  #int updatedAt
  -boolean active
  #boolean type
  +int duration
  +String amount
  +processAmount()
  +calculateDescription()
  +saveDuration()
  +setAddress()
}
class Invoice {
  +float code
  +long email
  +float updatedAt
  +long type
  +int score
  +getAddress()
  +updateDuration()
  +updateDescription()
}
class Order {
  -boolean total
  #boolean phone
  -double amount
  -String code
  #boolean status
  +getStatus()
  +saveName()
  +saveTotal()
}
interface Return {
  -float price
  +long quantity
  +long createdAt
  +int score
  #double active
  +calculateUpdatedat()
  +validateDuration()
  +calculateStatus()
  +calculateCode()
}
class Wishlist {
  -String amount
  +Date code
  #Date quantity
  +cancelDuration()
  +validatePhone()
  +processNote()
}
Invoice ..> Coupon : "1"
Payment --> Order : "0..1"
@enduml