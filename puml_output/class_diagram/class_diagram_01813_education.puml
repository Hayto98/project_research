@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Schedule {
  -double status
  #boolean total
  +boolean duration
  #int type
  +findActive()
  +updateType()
  +createStatus()
}
class Exam {
  #float description
  #double level
  +validateStatus()
  +getNote()
  +sendDescription()
  +cancelStatus()
}
interface Book {
  #String email
  -boolean description
  -double duration
  +long score
  #double updatedAt
  +updateNote()
  +cancelEmail()
  +saveDuration()
}
class Assignment {
  -boolean description
  #boolean note
  +boolean active
  -boolean id
  +processCreatedat()
  +cancelDuration()
  +sendPhone()
  +getScore()
}
Exam --|> Book
Book ..|> Assignment
@enduml