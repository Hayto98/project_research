@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Schedule {
  -double status
  #boolean total
  +boolean duration
  #int type
  +processAmount()
  +sendQuantity()
  +saveId()
}
class Exam {
  +long total
  -Date quantity
  +Date code
  +long note
  #long email
  +deleteEmail()
  +cancelNote()
  +createActive()
  +setLevel()
}
class Book {
  -boolean description
  #boolean note
  +boolean active
  -boolean id
  +savePhone()
  +saveActive()
  +deleteUpdatedat()
  +findCode()
}
interface Assignment {
  #Date duration
  #String updatedAt
  +Date quantity
  #long total
  +processType()
  +findAmount()
  +processDescription()
}
Assignment --> Exam : "0..1"
Book ..> Exam : "1..*"
note right of Schedule : Education domain
@enduml