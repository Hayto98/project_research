@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
interface Amenity {
  #String phone
  +Date address
  -double type
  -long duration
  +cancelStatus()
}
interface CheckIn {
  +double email
  #long updatedAt
  #int createdAt
  #int amount
  +deleteNote()
  +setDuration()
}
class Invoice {
  +long duration
  -String code
  +setLevel()
  +findNote()
}
abstract class Reservation {
  +double level
  -int code
  +long type
  #Date quantity
  +cancelType()
  +updateScore()
  +sendPhone()
}
interface Guest {
  +double score
  #boolean duration
  #boolean code
  -int quantity
  +validateEmail()
}
Guest ..> Invoice : "1"
Invoice --> Amenity : "*"
Amenity ..> Invoice : "0..1"
@enduml