@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
abstract class Restaurant {
  -Date description
  -boolean code
  #Date id
  #double note
  +getStatus()
  +sendTotal()
  +findName()
  +sendDuration()
}
interface CheckOut {
  -Date active
  +int address
  +boolean price
  #float name
  #float description
  +processType()
  +cancelStatus()
  +updateAddress()
}
abstract class Staff {
  +int status
  #int amount
  #double note
  #double name
  -float score
  +deleteDescription()
  +saveTotal()
}
class Housekeeping {
  -boolean level
  #double email
  -long name
  #float amount
  +updateAmount()
  +cancelDuration()
  +saveTotal()
  +sendPrice()
}
class Reservation {
  -double quantity
  #long createdAt
  -float code
  +setNote()
  +setAmount()
  +deleteCreatedat()
}
class CheckIn {
  +String createdAt
  #Date phone
  -float note
  +createUpdatedat()
  +calculateDuration()
  +setCode()
}
Restaurant ..|> Reservation
CheckIn ..|> Reservation
Restaurant ..> Housekeeping : "0..1"
Reservation ..|> Housekeeping
Reservation --o CheckIn
@enduml