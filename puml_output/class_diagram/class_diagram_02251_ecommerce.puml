@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Payment {
  -double id
  +double createdAt
  +calculateType()
  +findName()
  +processPrice()
  +cancelQuantity()
}
class Customer {
  -long quantity
  -long createdAt
  -double active
  +String type
  #long address
  +findDuration()
  +findScore()
  +updateNote()
}
class Return {
  +float note
  -long total
  -double name
  +long code
  +getCreatedat()
  +processLevel()
  +updateNote()
}
class Shipment {
  #Date status
  #String updatedAt
  +deleteUpdatedat()
  +setDuration()
}
class Order {
  #boolean duration
  -float note
  -boolean level
  #long price
  +calculateLevel()
  +getUpdatedat()
}
class Wishlist {
  -double email
  -Date type
  -String code
  +calculateLevel()
  +setEmail()
  +updatePhone()
  +getUpdatedat()
}
interface Coupon {
  +boolean updatedAt
  -int active
  +int code
  +Date amount
  +updateCreatedat()
  +findAddress()
  +deletePrice()
  +sendCode()
}
Wishlist --|> Order
Customer --* Shipment
Order --* Customer
note right of Payment : Ecommerce domain
@enduml