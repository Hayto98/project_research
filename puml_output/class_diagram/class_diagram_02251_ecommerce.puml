@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Payment {
  -double id
  +double createdAt
  +updateEmail()
  +validateUpdatedat()
  +cancelDescription()
  +calculateEmail()
}
abstract class Customer {
  +boolean level
  -float quantity
  -double email
  -long total
  -double duration
  +saveQuantity()
  +updateName()
  +getScore()
  +deleteName()
}
class Return {
  -Date note
  -String code
  +int email
  +cancelPhone()
  +createAmount()
  +calculateQuantity()
  +setType()
}
class Shipment {
  -String id
  +float createdAt
  +int note
  #Date level
  +findPhone()
}
class Order {
  #double code
  -Date amount
  -Date phone
  +updateCode()
  +validateName()
  +sendLevel()
  +cancelAmount()
}
interface Wishlist {
  -float updatedAt
  +long total
  #double id
  +long duration
  +calculateCreatedat()
  +createTotal()
  +saveCode()
  +updateActive()
}
abstract class Coupon {
  +int level
  #long status
  +boolean email
  +int updatedAt
  +boolean phone
  +calculateAddress()
  +setDescription()
  +processActive()
}
Wishlist --o Coupon
Customer ..> Coupon : "1..*"
@enduml