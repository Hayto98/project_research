@startuml
skinparam monochrome true
abstract class Billing {
  +long total
  #int quantity
  +calculatePrice()
  +processDuration()
  +findStatus()
  +sendActive()
}
class Prescription {
  #Date active
  #long status
  +double total
  +int quantity
  +createName()
  +calculateDescription()
}
abstract class MedicalRecord {
  +double phone
  #boolean address
  -double updatedAt
  -long name
  #String duration
  +createStatus()
}
abstract class Diagnosis {
  #boolean total
  +Date id
  #String status
  +calculateNote()
  +deleteAddress()
}
class LabTest {
  #int phone
  +String code
  +Date type
  +setScore()
  +getCode()
  +getType()
}
abstract class Appointment {
  -long description
  +long duration
  +boolean status
  #String id
  #double name
  +getEmail()
  +sendType()
}
interface Hospital {
  #float duration
  +boolean score
  +String price
  +processLevel()
}
MedicalRecord --* Hospital
Hospital --* Prescription
Billing --* LabTest
Prescription --o LabTest
@enduml