@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
abstract class Shipment {
  +long total
  #int email
  +String createdAt
  +getDuration()
  +calculateScore()
}
class Supplier {
  #float name
  -double phone
  +saveLevel()
  +validateAddress()
  +findScore()
}
interface Order {
  #double email
  +double name
  +float id
  #String address
  +sendPrice()
}
class Coupon {
  +Date note
  -long active
  +validateUpdatedat()
}
abstract class Cart {
  -int description
  -int type
  +sendCreatedat()
  +deleteScore()
  +createQuantity()
  +setScore()
}
interface Payment {
  +String quantity
  #String email
  -long createdAt
  -int level
  #float duration
  +createActive()
  +createScore()
  +saveStatus()
}
Supplier ..|> Coupon
Shipment --o Payment
@enduml