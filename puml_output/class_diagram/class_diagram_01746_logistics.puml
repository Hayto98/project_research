@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
abstract class Depot {
  -long type
  -long phone
  +cancelCreatedat()
  +calculateId()
  +createId()
  +validateActive()
}
class Package {
  -long active
  +boolean createdAt
  +double name
  +double code
  +findScore()
  +validateLevel()
}
interface Inventory {
  -float duration
  -Date price
  #long email
  +calculateCreatedat()
}
class Warehouse {
  -int id
  #int createdAt
  #double type
  #double status
  +boolean total
  +findUpdatedat()
  +sendActive()
  +processQuantity()
}
class Driver {
  -int createdAt
  #double amount
  -int quantity
  -String id
  +double active
  +getCreatedat()
  +processStatus()
  +validateDescription()
}
class Customer {
  #long code
  #int status
  #String createdAt
  +createTotal()
}
abstract class Manifest {
  #int total
  +boolean type
  +long note
  +cancelStatus()
  +cancelDescription()
  +createDescription()
}
Inventory --> Driver : "1"
Driver --|> Manifest
note right of Depot : Logistics domain
@enduml