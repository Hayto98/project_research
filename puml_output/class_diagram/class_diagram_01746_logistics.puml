@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
abstract class Depot {
  -long type
  -long phone
  +sendActive()
  +updateDescription()
  +findAmount()
  +cancelTotal()
}
class Package {
  +long phone
  #int active
  +processCreatedat()
}
class Inventory {
  -String address
  -int id
  #boolean active
  -boolean status
  +setQuantity()
  +setPhone()
}
abstract class Warehouse {
  -float address
  +float type
  #String duration
  #float code
  +setName()
  +sendId()
  +createEmail()
  +saveDuration()
}
abstract class Driver {
  +boolean total
  +boolean duration
  +calculateActive()
  +deleteActive()
  +findAddress()
  +getScore()
}
class Customer {
  -int active
  -int duration
  +long note
  +saveStatus()
}
interface Manifest {
  #double note
  -int createdAt
  +calculateEmail()
  +createCode()
  +saveAmount()
}
Inventory ..> Depot : "0..1"
Warehouse --* Depot
Customer --* Package
Package --|> Customer
Depot --> Package : "1..*"
Driver ..> Package : "1"
@enduml