@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Amenity {
  +boolean phone
  +double id
  +setPrice()
  +deleteCreatedat()
  +processNote()
  +cancelScore()
}
class Reservation {
  +double score
  #double price
  +boolean duration
  -float type
  +getPhone()
  +sendTotal()
  +savePrice()
  +cancelName()
}
abstract class Payment {
  -long code
  +Date note
  -String amount
  -float total
  #String phone
  +saveQuantity()
}
class CheckOut {
  #float phone
  -long address
  #float email
  #boolean type
  #Date id
  +deleteId()
  +updateUpdatedat()
}
abstract class Staff {
  +String status
  -int quantity
  +updatePrice()
  +updateAmount()
}
Payment --> Staff : "1..*"
Payment --o CheckOut
@enduml