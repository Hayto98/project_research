@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Shelf {
  +String amount
  -int duration
  +boolean status
  +updatePhone()
  +getQuantity()
  +cancelName()
}
class Publisher {
  #long status
  #double quantity
  +boolean score
  +updateStatus()
}
class Loan {
  +int address
  -String name
  +Date score
  +calculateActive()
  +createNote()
  +saveType()
}
class Author {
  +Date phone
  -long active
  -String total
  -String createdAt
  +setId()
}
class Book {
  -int updatedAt
  #int price
  +int total
  -double type
  +updateId()
  +setPhone()
  +deleteAmount()
}
Book --o Publisher
Shelf ..|> Publisher
@enduml