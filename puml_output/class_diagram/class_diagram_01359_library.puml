@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Shelf {
  +String amount
  -int duration
  +boolean status
  +saveDuration()
  +findAddress()
  +updateStatus()
}
class Publisher {
  +Date note
  -int amount
  -String active
  #boolean code
  +deletePrice()
}
class Loan {
  -long address
  #boolean active
  -Date duration
  +deleteNote()
  +createEmail()
}
class Author {
  #int status
  -double id
  #float quantity
  -long score
  +saveAmount()
  +updateCreatedat()
}
abstract class Book {
  #String address
  #boolean price
  +int id
  +Date createdAt
  +String type
  +validateStatus()
  +createScore()
  +validateName()
  +deletePrice()
}
Loan --|> Publisher
Loan --|> Author
note right of Shelf : Library domain
@enduml