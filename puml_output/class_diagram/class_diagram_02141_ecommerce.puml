@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
abstract class Customer {
  +float id
  -int description
  +findDescription()
  +sendScore()
}
interface Return {
  #float level
  -double active
  #Date email
  +updateStatus()
  +setPhone()
  +processAddress()
  +saveQuantity()
}
class Product {
  #String description
  -String status
  +double type
  +cancelQuantity()
  +sendId()
}
abstract class Coupon {
  -float duration
  #long id
  #boolean active
  +Date quantity
  +saveId()
  +processUpdatedat()
  +updateUpdatedat()
}
abstract class Shipment {
  +String price
  #double id
  #double code
  +cancelAmount()
  +saveCreatedat()
}
class Warehouse {
  +double address
  #long code
  +int phone
  #int price
  +validateId()
  +createDuration()
}
Warehouse --o Product
Customer --> Return : "0..1"
Coupon ..|> Product
Product --* Shipment
@enduml