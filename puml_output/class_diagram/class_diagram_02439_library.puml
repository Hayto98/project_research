@startuml
skinparam monochrome true
class Author {
  -float createdAt
  #double amount
  #double quantity
  +updateStatus()
  +findType()
  +saveQuantity()
  +cancelDuration()
}
class Librarian {
  +int price
  #boolean amount
  -float email
  #String duration
  +setNote()
  +sendCode()
  +sendId()
  +deleteDuration()
}
class Member {
  -Date name
  +int id
  +double description
  -long type
  +sendId()
  +saveTotal()
  +findQuantity()
  +sendStatus()
}
class Shelf {
  -Date createdAt
  -double code
  #String email
  +validateId()
  +deleteName()
  +setPhone()
}
class Catalog {
  #double id
  #long active
  +sendLevel()
  +cancelUpdatedat()
}
abstract class Fine {
  -long address
  #int phone
  #Date note
  +validateId()
  +validateAddress()
}
class Book {
  #long note
  +double quantity
  -long level
  #double score
  -boolean id
  +deleteAmount()
}
Librarian --o Member
Shelf ..> Member : "1..*"
note right of Author : Library domain
@enduml