@startuml
skinparam monochrome true
class Author {
  -float createdAt
  #double amount
  #double quantity
  +saveNote()
  +updateName()
  +getActive()
  +sendCreatedat()
}
class Librarian {
  #long quantity
  -int price
  +Date amount
  +findType()
  +findDescription()
  +setDescription()
}
abstract class Member {
  +boolean note
  +int active
  +findEmail()
  +sendPhone()
}
class Shelf {
  -float description
  -Date level
  +sendNote()
  +getEmail()
}
abstract class Catalog {
  #long address
  #String price
  -int score
  +String id
  -float total
  +cancelPrice()
  +saveCode()
  +validateName()
  +deleteType()
}
class Fine {
  +long phone
  -String id
  #Date amount
  +boolean name
  +validateActive()
  +calculateName()
  +sendId()
  +getCreatedat()
}
interface Book {
  #long note
  -double amount
  -Date address
  +updatePhone()
  +cancelUpdatedat()
}
Member --|> Fine
Member --* Book
Shelf --* Book
@enduml