@startuml
skinparam monochrome true
class Publisher {
  #Date address
  -long name
  -int code
  -double id
  #float email
  +cancelId()
}
abstract class Reservation {
  +String total
  #String createdAt
  #Date level
  +saveUpdatedat()
  +validateCreatedat()
  +getDuration()
}
interface Shelf {
  -String phone
  +int level
  #String quantity
  -double active
  +validatePrice()
  +validateCreatedat()
}
class Renewal {
  -boolean email
  #String status
  +validateCreatedat()
  +getDuration()
}
interface Loan {
  #long id
  -long active
  #String type
  +boolean status
  +processDescription()
}
Renewal --o Shelf
Reservation --o Publisher
note right of Publisher : Library domain
@enduml