@startuml
skinparam monochrome true
class Publisher {
  #Date address
  -long name
  -int code
  -double id
  #float email
  +findDescription()
}
class Reservation {
  +Date amount
  +boolean total
  #boolean createdAt
  #long score
  #int code
  +updateDescription()
  +cancelLevel()
  +processName()
}
interface Shelf {
  -String phone
  +int level
  #String quantity
  -double active
  +cancelId()
  +deleteAmount()
}
class Renewal {
  +double code
  #float id
  #String email
  +findCode()
  +sendId()
}
class Loan {
  #long id
  -long active
  #String type
  +boolean status
  +deleteActive()
}
Reservation ..> Renewal : "1..*"
Renewal --> Reservation : "1"
@enduml