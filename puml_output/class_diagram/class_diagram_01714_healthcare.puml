@startuml
skinparam shadowing true
class Billing {
  #String score
  #String phone
  #double code
  #boolean email
  -double quantity
  +validateId()
  +createScore()
}
interface LabTest {
  -float total
  -String code
  +processLevel()
  +saveDescription()
  +createAddress()
}
class Appointment {
  #boolean address
  +boolean level
  +Date email
  +findActive()
}
class Insurance {
  #boolean level
  +int name
  +int active
  -boolean id
  -int score
  +findActive()
}
class Nurse {
  +float type
  -Date level
  +long phone
  -float active
  -long description
  +getPhone()
  +findTotal()
  +setUpdatedat()
}
LabTest --> Billing : "1"
LabTest --> Nurse : "1"
Appointment --|> Nurse
Appointment ..|> Insurance
note right of Billing : Healthcare domain
@enduml