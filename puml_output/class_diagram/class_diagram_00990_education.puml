@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
abstract class Assignment {
  +Date updatedAt
  -int note
  +findId()
}
class Course {
  +boolean level
  #Date updatedAt
  -String amount
  +cancelName()
  +createName()
}
class Book {
  #double phone
  -double quantity
  +boolean address
  +validateNote()
  +sendName()
  +calculateName()
}
interface Grade {
  #float amount
  +double status
  +double duration
  -double level
  +updateName()
  +deleteCode()
  +findCreatedat()
  +validateDuration()
}
class Schedule {
  #Date amount
  +long duration
  #int price
  -String type
  +calculateAddress()
  +saveAmount()
  +deleteScore()
}
interface Library {
  -long phone
  +boolean id
  #double createdAt
  +getName()
}
interface Exam {
  #double updatedAt
  -long total
  #String level
  +cancelName()
  +savePrice()
}
Course --|> Exam
Book --|> Grade
Library ..|> Assignment
Grade --o Library
@enduml