@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
abstract class Assignment {
  +Date updatedAt
  -int note
  +deleteUpdatedat()
}
interface Course {
  +boolean level
  #Date updatedAt
  -String amount
  +findNote()
  +getDescription()
}
class Book {
  -String address
  #boolean level
  -int price
  -long duration
  +deleteStatus()
  +deleteScore()
  +setUpdatedat()
}
abstract class Grade {
  #Date total
  #double type
  +long duration
  +validateAmount()
  +validateAmount()
  +cancelAmount()
}
abstract class Schedule {
  -String level
  -int description
  -int phone
  #int active
  -float createdAt
  +saveCreatedat()
}
class Library {
  #Date description
  #float active
  #int note
  #Date status
  +calculateTotal()
  +cancelType()
}
abstract class Exam {
  +String status
  -double description
  +Date email
  +int createdAt
  +saveNote()
  +savePhone()
  +updateType()
  +deleteDuration()
}
Library --o Book
Library ..> Assignment : "0..1"
note right of Assignment : Education domain
@enduml