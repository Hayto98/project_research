@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
interface Tracking {
  #int total
  #boolean updatedAt
  +findCode()
}
class Package {
  -double description
  +String code
  -float price
  #boolean quantity
  +getAddress()
}
class Depot {
  #int name
  -int description
  +boolean duration
  -long phone
  +boolean amount
  +calculateLevel()
  +updateNote()
}
interface Warehouse {
  #long name
  +int active
  -long score
  +saveScore()
  +validateActive()
}
class Inventory {
  +String id
  -boolean active
  #Date status
  +calculateQuantity()
  +sendDescription()
}
Depot --o Package
Package ..|> Tracking
@enduml