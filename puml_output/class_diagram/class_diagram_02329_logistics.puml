@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
interface Tracking {
  #int total
  #boolean updatedAt
  +validateCreatedat()
}
interface Package {
  -double description
  +String code
  -float price
  #boolean quantity
  +calculateAmount()
}
abstract class Depot {
  -Date description
  #int name
  +validateDescription()
  +updateLevel()
}
abstract class Warehouse {
  #int amount
  +boolean level
  #boolean createdAt
  -String active
  +calculateAddress()
  +sendDescription()
}
class Inventory {
  +String description
  +double id
  #boolean active
  +calculatePhone()
  +validateUpdatedat()
}
Package ..|> Tracking
note right of Tracking : Logistics domain
@enduml