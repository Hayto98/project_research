@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
abstract class Loan {
  #float id
  +double price
  #float description
  +findUpdatedat()
  +findEmail()
  +cancelActive()
  +updateDescription()
}
interface Teller {
  +int id
  -boolean quantity
  +boolean amount
  -int createdAt
  +Date type
  +saveCode()
}
class Statement {
  +long phone
  +long address
  +validatePrice()
  +sendDescription()
  +createQuantity()
}
interface Withdrawal {
  #String duration
  +Date id
  +float phone
  +findActive()
}
Withdrawal --* Statement
Statement ..> Withdrawal : "*"
note right of Loan : Banking domain
@enduml