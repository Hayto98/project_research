@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Treatment {
  #String updatedAt
  +long email
  #boolean duration
  +updateActive()
}
class Ward {
  #double createdAt
  #int score
  -int id
  +float description
  +double note
  +setQuantity()
  +findDuration()
}
interface Nurse {
  #boolean id
  -int active
  -boolean type
  +getScore()
  +calculateName()
}
class Hospital {
  -Date total
  #boolean code
  +Date price
  -int type
  -boolean quantity
  +updateNote()
  +updateDuration()
  +processId()
}
class Diagnosis {
  -double amount
  -double createdAt
  +setAddress()
  +validateUpdatedat()
  +deleteName()
  +getAddress()
}
interface Prescription {
  +long active
  #float note
  -long description
  -float type
  +validateUpdatedat()
}
class Patient {
  #long type
  #boolean score
  +String updatedAt
  -int amount
  +createQuantity()
}
Diagnosis --> Treatment : "0..1"
Patient --|> Diagnosis
@enduml