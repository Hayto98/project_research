@startuml
skinparam monochrome true
skinparam defaultFontSize 13
abstract class CheckIn {
  -String description
  -int status
  #boolean amount
  #double duration
  +cancelId()
  +validateCode()
  +updatePhone()
}
class Restaurant {
  +int score
  -Date address
  +processTotal()
  +validateId()
}
abstract class Room {
  -float code
  -String type
  +int status
  +sendDuration()
  +sendAddress()
}
interface Payment {
  +double phone
  #float updatedAt
  +String email
  +String price
  +findPhone()
  +sendLevel()
  +processName()
}
class Booking {
  +String total
  #boolean duration
  +double active
  +saveDuration()
  +sendLevel()
  +processEmail()
  +calculateCode()
}
class Guest {
  +int level
  +boolean id
  +processLevel()
  +saveId()
  +getCreatedat()
  +createDuration()
}
interface Staff {
  -boolean id
  +Date email
  #float level
  -float address
  +cancelQuantity()
  +updatePhone()
  +updateEmail()
}
Booking ..> Room : "1"
Guest --> Room : "*"
Room --o Restaurant
CheckIn --* Restaurant
Booking ..> CheckIn : "1"
@enduml