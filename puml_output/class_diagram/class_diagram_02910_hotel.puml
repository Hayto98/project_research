@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
abstract class CheckIn {
  #String total
  #boolean id
  #boolean price
  -double description
  +getEmail()
  +validateNote()
  +processCode()
  +validatePhone()
}
interface Staff {
  #long quantity
  #String amount
  -float note
  #long price
  +boolean type
  +getPhone()
  +findScore()
}
class Amenity {
  +double active
  +String phone
  -boolean name
  +deleteUpdatedat()
  +deleteId()
}
class Reservation {
  +double note
  #double phone
  +long score
  +getCode()
}
class CheckOut {
  +boolean score
  #int id
  #String amount
  #long description
  -String code
  +deleteTotal()
  +setDescription()
  +findStatus()
  +findAddress()
}
CheckIn --> Staff : "*"
Reservation --|> CheckOut
CheckOut ..|> Staff
Reservation --o Staff
@enduml