@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
abstract class Customer {
  +double phone
  #long name
  +findPrice()
  +updateName()
  +calculateNote()
  +createActive()
}
abstract class Invoice {
  #int type
  -boolean description
  -boolean amount
  +processDuration()
  +getStatus()
  +cancelStatus()
  +validatePrice()
}
class Supplier {
  #float level
  +long email
  +boolean name
  +String note
  +getPhone()
  +createAddress()
}
interface Coupon {
  #float level
  #long updatedAt
  +float phone
  #int active
  +cancelCreatedat()
  +updateUpdatedat()
}
class Shipment {
  #Date active
  -double updatedAt
  #long score
  -float note
  -double level
  +saveActive()
  +findLevel()
  +findCode()
  +getAmount()
}
interface Cart {
  -double id
  -double description
  -double note
  +cancelDescription()
  +calculateLevel()
}
Shipment ..> Cart : "1"
Cart --o Invoice
Coupon --> Cart : "1..*"
@enduml