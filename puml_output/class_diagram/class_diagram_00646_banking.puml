@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Loan {
  -boolean amount
  -float name
  -long quantity
  +calculateId()
  +validateLevel()
}
class Deposit {
  +float total
  #boolean id
  +updatePrice()
  +cancelStatus()
  +getScore()
  +findActive()
}
abstract class Transaction {
  -float id
  +boolean price
  +Date score
  +deleteCreatedat()
  +saveQuantity()
}
interface Branch {
  +double email
  -boolean amount
  -boolean phone
  #Date updatedAt
  +Date active
  +updateTotal()
  +updatePhone()
  +cancelType()
}
Transaction --o Loan
Transaction ..|> Deposit
@enduml