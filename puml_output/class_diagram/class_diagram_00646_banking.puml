@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Loan {
  -boolean amount
  -float name
  -long quantity
  +getName()
  +getTotal()
}
class Deposit {
  +String duration
  #double score
  #double note
  +getPrice()
  +sendTotal()
}
class Transaction {
  +boolean createdAt
  -float email
  +deletePhone()
  +updateUpdatedat()
  +updateTotal()
}
abstract class Branch {
  -Date duration
  +long score
  +float updatedAt
  -float active
  -double phone
  +validateActive()
  +setScore()
}
Transaction --> Deposit : "*"
Deposit --* Loan
note right of Loan : Banking domain
@enduml