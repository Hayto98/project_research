@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
interface Teller {
  -String amount
  -boolean createdAt
  +sendAddress()
}
class Statement {
  +boolean address
  #Date note
  +int active
  #String phone
  -int updatedAt
  +validateType()
  +deleteDuration()
}
abstract class Transaction {
  #Date note
  -Date total
  #double email
  #long code
  +double name
  +findAmount()
  +sendNote()
  +saveAddress()
}
class Card {
  +double score
  +float address
  -Date description
  #Date active
  +saveUpdatedat()
  +cancelAddress()
  +processAddress()
  +getDuration()
}
Transaction --o Card
Teller --* Transaction
note right of Teller : Banking domain
@enduml