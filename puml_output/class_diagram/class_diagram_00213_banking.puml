@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
interface Teller {
  -String amount
  -boolean createdAt
  +saveActive()
}
class Statement {
  -int type
  +boolean address
  #Date note
  +int active
  +findCode()
}
class Transaction {
  #double phone
  -double type
  -float description
  +findNote()
  +saveEmail()
  +calculatePrice()
}
abstract class Card {
  #double phone
  #long status
  +long note
  #long quantity
  +boolean amount
  +findActive()
  +getUpdatedat()
}
Transaction ..> Card : "*"
Statement ..> Transaction : "1..*"
@enduml