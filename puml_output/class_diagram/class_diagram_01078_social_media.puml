@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Post {
  -Date type
  -String createdAt
  -String phone
  #Date email
  -long note
  +saveName()
}
class Message {
  -int description
  -int level
  #boolean name
  +findActive()
  +processTotal()
}
class Like {
  #float description
  #long level
  +validateTotal()
  +deletePhone()
}
class Album {
  +Date price
  -boolean code
  +double duration
  +processTotal()
  +updatePrice()
  +processScore()
  +saveEmail()
}
class Group {
  +long price
  -int level
  +deleteScore()
  +deleteUpdatedat()
}
class Report {
  +int amount
  -long note
  #Date name
  #float createdAt
  -boolean code
  +validateCreatedat()
  +updateAmount()
  +cancelDuration()
}
interface Profile {
  #int total
  +long active
  -float phone
  +saveCreatedat()
  +processScore()
  +deleteAddress()
  +cancelTotal()
}
Message --|> Report
Profile --o Report
@enduml