@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Post {
  -Date type
  -String createdAt
  -String phone
  #Date email
  -long note
  +calculateUpdatedat()
}
class Message {
  +long level
  +boolean name
  #float email
  +processNote()
  +setStatus()
}
class Like {
  +double updatedAt
  +Date quantity
  -boolean amount
  +double price
  +processId()
  +getName()
  +saveDuration()
  +setPrice()
}
interface Album {
  +Date address
  #int phone
  +cancelId()
  +calculateAmount()
}
abstract class Group {
  +int createdAt
  -long code
  +cancelEmail()
  +deleteDuration()
  +cancelActive()
}
class Report {
  -double active
  -long phone
  +String score
  +int amount
  #String status
  +sendQuantity()
  +saveNote()
  +findCode()
  +sendScore()
}
class Profile {
  #String total
  -int score
  -float active
  #float duration
  +validateAddress()
}
Report --|> Message
Post --o Profile
note right of Post : Social Media domain
@enduml