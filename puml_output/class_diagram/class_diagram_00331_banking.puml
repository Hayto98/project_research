@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Deposit {
  -double email
  #String address
  +createDescription()
  +getCreatedat()
  +processScore()
  +getId()
}
abstract class Interest {
  -String total
  +int id
  -float updatedAt
  #double level
  -double amount
  +findLevel()
  +updateId()
  +getEmail()
  +updateEmail()
}
interface Loan {
  +int updatedAt
  -int level
  +Date note
  #String code
  +String amount
  +calculateLevel()
  +sendScore()
  +sendLevel()
  +validateDescription()
}
class Withdrawal {
  #int total
  -int updatedAt
  +float price
  +updateDescription()
}
class Teller {
  -Date total
  +boolean email
  +getActive()
  +calculateCreatedat()
}
abstract class Transaction {
  -double type
  +long name
  #boolean note
  -Date duration
  +Date price
  +calculateTotal()
}
class Account {
  +int score
  #boolean price
  #String type
  +processAmount()
  +cancelDescription()
  +cancelDescription()
  +calculatePrice()
}
Account --|> Loan
Withdrawal --* Account
note right of Deposit : Banking domain
@enduml