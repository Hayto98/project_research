@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Deposit {
  -double email
  #String address
  +createQuantity()
  +validateCreatedat()
  +deleteNote()
  +saveNote()
}
abstract class Interest {
  -double id
  +int total
  +createLevel()
}
class Loan {
  -double status
  #boolean createdAt
  -Date description
  #int quantity
  +String total
  +processActive()
  +calculateDescription()
  +cancelUpdatedat()
}
class Withdrawal {
  +int updatedAt
  -int level
  +Date note
  #String code
  +String amount
  +validateType()
  +findType()
  +deleteTotal()
  +deleteAmount()
}
interface Teller {
  +double description
  #int name
  -int updatedAt
  +float total
  +validateNote()
}
class Transaction {
  -double active
  #int name
  #int total
  +createUpdatedat()
}
abstract class Account {
  +double price
  -double duration
  -double type
  +calculatePhone()
  +findName()
}
Loan --|> Transaction
Transaction --o Deposit
Withdrawal ..|> Interest
Transaction --o Teller
Account --|> Withdrawal
Interest --> Teller : "1"
@enduml