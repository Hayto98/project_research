@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Department {
  #String duration
  +String address
  -boolean total
  #boolean status
  -Date code
  +getActive()
  +findLevel()
}
class Classroom {
  #int quantity
  +boolean level
  +boolean description
  +sendPhone()
}
class Exam {
  -double address
  +Date active
  #float id
  -boolean type
  +updateCreatedat()
}
class Attendance {
  #int amount
  -String name
  +calculateDescription()
}
abstract class Teacher {
  +boolean name
  +boolean duration
  #Date address
  -String code
  #double createdAt
  +sendId()
  +findPhone()
  +updateQuantity()
  +sendCode()
}
class Course {
  -Date createdAt
  +int code
  #float total
  +findTotal()
}
Exam --|> Attendance
Exam ..|> Department
Department --* Teacher
@enduml