@startuml
skinparam monochrome true
class User {
  -int description
  #Date duration
  +setStatus()
  +saveQuantity()
  +deleteType()
}
interface Report {
  -Date score
  +float quantity
  #double name
  +boolean email
  #long amount
  +updateStatus()
}
class Like {
  #Date address
  +String createdAt
  +findQuantity()
}
interface Album {
  -float type
  -Date total
  #double status
  -long id
  #double address
  +getNote()
  +sendNote()
}
abstract class Notification {
  #float total
  -float price
  +int code
  #Date address
  #long id
  +findType()
  +deleteDescription()
}
class Group {
  +long updatedAt
  #Date phone
  +Date note
  +int level
  +updateStatus()
  +createEmail()
  +sendDuration()
}
class Profile {
  +double type
  -double status
  +createEmail()
}
User --|> Profile
Like --o Notification
Profile --o Like
Group --|> User
Notification --o Profile
User --|> Report
@enduml