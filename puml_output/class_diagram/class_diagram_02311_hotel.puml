@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
interface Guest {
  #int price
  +double quantity
  #String status
  #int address
  +getDuration()
}
class Reservation {
  +boolean amount
  +String price
  +long email
  +createAmount()
  +calculateAddress()
}
class CheckIn {
  +String type
  #Date amount
  -boolean note
  +deleteAddress()
  +deleteAmount()
  +setPhone()
  +getScore()
}
interface Payment {
  +double code
  +boolean description
  -Date score
  -Date email
  -long total
  +processActive()
  +deleteActive()
  +deleteCreatedat()
  +calculateAmount()
}
class Amenity {
  #Date name
  +String note
  #float createdAt
  #float phone
  +calculateCreatedat()
}
abstract class Booking {
  +long note
  #float status
  #long active
  #Date email
  +cancelNote()
  +getActive()
  +findActive()
  +calculateLevel()
}
Guest ..|> Booking
CheckIn ..> Guest : "0..1"
CheckIn --o Reservation
Payment ..> Booking : "1"
Amenity --|> Payment
@enduml