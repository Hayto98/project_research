@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
abstract class CheckOut {
  +String quantity
  +boolean id
  +double updatedAt
  +saveAddress()
  +saveId()
}
interface Amenity {
  -long active
  +int phone
  +createUpdatedat()
  +sendPrice()
}
class Reservation {
  +long code
  #float score
  #String status
  -long note
  +setDuration()
  +findStatus()
  +sendEmail()
  +findPrice()
}
class Room {
  #int note
  #long description
  -long total
  +findUpdatedat()
  +setActive()
  +sendCreatedat()
}
Amenity ..> CheckOut : "1..*"
Reservation --|> Amenity
CheckOut --* Amenity
@enduml