@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Group {
  +String name
  -double quantity
  #String duration
  +deleteCode()
}
class Story {
  -double description
  #String phone
  -Date name
  +processCode()
  +calculateDescription()
  +calculateCreatedat()
}
class Follower {
  #long updatedAt
  -float note
  -boolean name
  #int address
  +sendName()
}
abstract class User {
  +Date email
  #String price
  -boolean type
  #long createdAt
  -String name
  +deleteName()
  +setAddress()
  +findType()
  +saveScore()
}
class Message {
  +float note
  #double description
  #Date updatedAt
  +deleteId()
  +saveCode()
}
Story ..> Message : "1..*"
Message --|> User
Message ..|> Group
@enduml