@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Book {
  #float code
  +boolean level
  #double score
  -Date quantity
  -boolean name
  +sendId()
}
class Exam {
  #String amount
  -int level
  #float type
  +updateCode()
}
class Schedule {
  +long name
  #float phone
  +processAmount()
}
class Department {
  +float createdAt
  -String amount
  +createStatus()
  +saveDuration()
  +updateName()
}
Book --* Exam
Department ..> Exam : "0..1"
note right of Book : Education domain
@enduml