@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Book {
  #float code
  +boolean level
  #double score
  -Date quantity
  -boolean name
  +saveActive()
}
class Exam {
  +double createdAt
  +boolean amount
  +int type
  #float active
  +processPrice()
}
class Schedule {
  -float phone
  #float code
  +validateUpdatedat()
}
class Department {
  +float name
  -String createdAt
  -long amount
  +getAmount()
}
Book --|> Exam
Schedule ..> Exam : "*"
@enduml