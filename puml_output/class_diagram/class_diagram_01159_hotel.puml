@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
abstract class Service {
  +boolean note
  #Date updatedAt
  +boolean level
  #long email
  +getAmount()
}
interface Staff {
  -int score
  -long status
  +float description
  -long code
  #Date active
  +updateStatus()
  +cancelCode()
}
class Amenity {
  -long updatedAt
  +int email
  +saveUpdatedat()
  +validateUpdatedat()
}
interface Room {
  #boolean status
  -int duration
  +saveName()
  +setEmail()
  +updateId()
  +createPrice()
}
class Payment {
  +double email
  #boolean code
  -String name
  +deleteType()
  +getNote()
  +validateEmail()
}
class Reservation {
  -double address
  +double status
  +boolean id
  +updateStatus()
  +sendAmount()
  +calculateId()
  +processTotal()
}
Payment ..|> Amenity
Room ..> Amenity : "1"
note right of Service : Hotel domain
@enduml