@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
abstract class Service {
  +boolean note
  #Date updatedAt
  +boolean level
  #long email
  +getDescription()
}
class Staff {
  +Date level
  #int total
  +boolean score
  +deleteCode()
}
class Amenity {
  +String address
  #float amount
  +String price
  +float email
  +long updatedAt
  +cancelAddress()
  +deleteNote()
  +saveQuantity()
}
class Room {
  +String phone
  #boolean updatedAt
  -int code
  +validatePrice()
  +savePhone()
  +validatePhone()
  +findCreatedat()
}
class Payment {
  +int email
  -String price
  +deleteAddress()
}
abstract class Reservation {
  -long status
  -int address
  #int description
  -boolean type
  +Date id
  +saveType()
}
Room --o Staff
Service --> Payment : "*"
Staff --> Service : "0..1"
Room --o Service
Reservation --|> Room
@enduml