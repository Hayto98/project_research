@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Interest {
  -String note
  #long updatedAt
  #boolean quantity
  +double amount
  +validateId()
}
abstract class Statement {
  #float email
  #Date duration
  -String createdAt
  #int note
  -float active
  +calculateId()
}
class Account {
  -float id
  -double score
  #String phone
  -Date createdAt
  #String name
  +processPrice()
  +saveCode()
  +saveEmail()
}
interface Teller {
  -long email
  #float address
  +float name
  -float description
  -String active
  +deletePhone()
  +calculateDuration()
  +cancelScore()
  +findPrice()
}
class Withdrawal {
  +int level
  +boolean phone
  -long note
  +updateAddress()
  +savePhone()
  +validateAddress()
  +findCreatedat()
}
class Transfer {
  +String duration
  #double name
  #double level
  -boolean description
  +getCreatedat()
}
Transfer ..> Withdrawal : "1"
Interest ..> Statement : "1"
Statement --|> Interest
Transfer --|> Statement
note right of Interest : Banking domain
@enduml