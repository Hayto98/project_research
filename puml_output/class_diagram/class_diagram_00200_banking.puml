@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Interest {
  -String note
  #long updatedAt
  #boolean quantity
  +double amount
  +findCode()
}
class Statement {
  -double active
  #float price
  #Date email
  -String score
  #int createdAt
  +setActive()
  +updateDuration()
  +validateType()
}
abstract class Account {
  +boolean address
  -float type
  +calculateEmail()
  +cancelCreatedat()
}
class Teller {
  -double duration
  #String code
  #long quantity
  #boolean id
  #float address
  +cancelPhone()
  +findQuantity()
  +findName()
  +deletePhone()
}
interface Withdrawal {
  -long description
  #float duration
  +saveType()
  +calculateTotal()
}
abstract class Transfer {
  -boolean name
  #boolean total
  #double amount
  +int phone
  +createName()
  +processUpdatedat()
  +validateQuantity()
}
Withdrawal --* Account
Teller --* Statement
Transfer --* Account
@enduml