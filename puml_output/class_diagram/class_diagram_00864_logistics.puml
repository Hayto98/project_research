@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
abstract class Depot {
  +String level
  #boolean type
  -int duration
  -boolean email
  +double status
  +updateId()
}
class Inventory {
  -Date id
  +int price
  -String code
  +getPrice()
}
abstract class Warehouse {
  -double active
  #int total
  #float type
  -int id
  +calculateScore()
  +cancelStatus()
  +saveName()
  +cancelPrice()
}
class Manifest {
  -float note
  -boolean address
  -long duration
  #boolean active
  +processAmount()
  +validateActive()
  +processLevel()
  +createLevel()
}
class Tracking {
  -Date total
  +int level
  +float updatedAt
  #double score
  +String duration
  +findDescription()
  +createLevel()
  +calculateNote()
  +processDuration()
}
Inventory --* Depot
Tracking ..> Inventory : "1"
Inventory --* Manifest
@enduml