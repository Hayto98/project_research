@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
abstract class Depot {
  +String level
  #boolean type
  -int duration
  -boolean email
  +double status
  +findCode()
}
class Inventory {
  -Date price
  +int code
  +setScore()
  +cancelStatus()
  +calculateQuantity()
  +saveActive()
}
abstract class Warehouse {
  #float level
  -int id
  #boolean phone
  -long total
  +double amount
  +validateNote()
  +validateNote()
  +sendNote()
}
abstract class Manifest {
  #double phone
  -boolean total
  +int code
  -double level
  #float updatedAt
  +updateCode()
  +findType()
}
class Tracking {
  +float type
  -int createdAt
  +validateDuration()
}
Depot --> Inventory : "*"
Warehouse --> Depot : "0..1"
note right of Depot : Logistics domain
@enduml