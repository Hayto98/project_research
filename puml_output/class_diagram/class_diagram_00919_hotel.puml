@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Invoice {
  #Date code
  #long note
  +float level
  +int id
  -boolean type
  +updateScore()
  +setPhone()
}
abstract class Staff {
  +String quantity
  #long code
  #String amount
  -Date duration
  +cancelScore()
}
class CheckOut {
  +double code
  #double name
  #boolean active
  +saveAmount()
  +calculateActive()
  +processCreatedat()
  +deletePrice()
}
abstract class Reservation {
  -long code
  -String duration
  +double address
  +processUpdatedat()
  +cancelAddress()
  +saveDescription()
  +setActive()
}
class CheckIn {
  +double email
  +boolean code
  #String description
  +findNote()
  +sendPrice()
  +createLevel()
}
class Booking {
  #float name
  -float note
  #Date id
  +setStatus()
}
CheckIn ..|> Staff
CheckIn ..|> CheckOut
Booking ..|> Reservation
CheckOut --|> Invoice
note right of Invoice : Hotel domain
@enduml