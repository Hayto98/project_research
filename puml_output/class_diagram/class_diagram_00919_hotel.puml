@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Invoice {
  #Date code
  #long note
  +float level
  +int id
  -boolean type
  +sendNote()
  +getPrice()
}
interface Staff {
  #Date phone
  -long type
  +validateLevel()
}
class CheckOut {
  -Date createdAt
  #String name
  #boolean phone
  +float id
  +cancelUpdatedat()
  +getType()
}
class Reservation {
  #boolean note
  -Date active
  +double type
  +updateCode()
  +saveNote()
  +saveAddress()
  +findType()
}
abstract class CheckIn {
  -double createdAt
  +String code
  -Date level
  #double address
  -int note
  +saveUpdatedat()
  +setType()
  +getType()
}
interface Booking {
  #String createdAt
  +String email
  +deleteAddress()
  +createStatus()
  +processPhone()
  +getScore()
}
CheckIn ..> Booking : "1..*"
Booking --> Reservation : "*"
@enduml