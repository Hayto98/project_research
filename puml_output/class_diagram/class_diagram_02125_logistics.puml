@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class FuelLog {
  +String total
  -int description
  +findDuration()
  +cancelDescription()
  +processCreatedat()
}
class Depot {
  -boolean email
  -long status
  #int code
  +cancelAddress()
  +updateEmail()
}
class DeliveryNote {
  #double amount
  #Date type
  +updateScore()
  +deleteAmount()
  +setActive()
  +calculateStatus()
}
abstract class Route {
  #double description
  +double active
  +getStatus()
  +deleteActive()
}
class Customer {
  -double duration
  #boolean description
  +String price
  #Date name
  +boolean note
  +calculateId()
  +updateUpdatedat()
}
class Tracking {
  -boolean duration
  +long level
  +float note
  +deleteType()
}
class Shipment {
  -Date description
  +float email
  +int name
  #boolean note
  -Date createdAt
  +getAmount()
  +processPrice()
  +cancelUpdatedat()
}
Customer ..> Shipment : "0..1"
Depot ..|> Route
FuelLog ..|> Shipment
Shipment ..|> Customer
Route --|> Tracking
@enduml