@startuml
skinparam ArrowColor #555555
class Shipment {
  #String total
  #int email
  +double score
  +getAddress()
}
class Supplier {
  #boolean type
  -String duration
  #String quantity
  +saveCreatedat()
  +validateStatus()
  +updateAddress()
}
interface Return {
  +Date score
  -boolean level
  +processTotal()
}
interface Wishlist {
  #long amount
  #double createdAt
  #Date address
  +deleteStatus()
  +saveId()
  +saveStatus()
}
class Cart {
  +Date phone
  +boolean updatedAt
  #Date score
  #String id
  +calculateName()
}
Shipment ..> Cart : "1"
Return ..> Wishlist : "1..*"
Cart ..|> Shipment
@enduml