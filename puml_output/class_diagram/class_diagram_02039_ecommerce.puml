@startuml
skinparam ArrowColor #555555
class Shipment {
  #String total
  #int email
  +double score
  +calculateCode()
}
class Supplier {
  -long type
  #boolean quantity
  +boolean duration
  #String id
  #float active
  +cancelCode()
  +processScore()
  +deleteAmount()
}
class Return {
  #long active
  #String phone
  +boolean total
  -long duration
  +sendId()
  +deleteCode()
}
interface Wishlist {
  -String code
  +Date address
  +validateTotal()
}
class Cart {
  +boolean description
  -float updatedAt
  +sendDuration()
  +updateDuration()
  +setId()
  +sendName()
}
Return --o Wishlist
Wishlist --|> Cart
Cart --> Supplier : "0..1"
note right of Shipment : Ecommerce domain
@enduml