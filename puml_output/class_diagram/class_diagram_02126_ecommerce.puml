@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Invoice {
  #long email
  +String id
  #double description
  -int type
  +processId()
  +updateName()
  +createAddress()
  +sendPhone()
}
interface Warehouse {
  +String email
  +Date amount
  #float type
  +float phone
  -Date quantity
  +calculateCode()
  +deleteCode()
  +processEmail()
}
class Review {
  +long code
  +float address
  +saveStatus()
  +getTotal()
}
interface Customer {
  #long status
  -int email
  -int active
  +updateEmail()
}
class Wishlist {
  #int createdAt
  -float phone
  -boolean total
  #long duration
  #boolean name
  +calculateActive()
  +sendUpdatedat()
}
abstract class Coupon {
  +int note
  +long active
  +float duration
  -double total
  +int phone
  +createEmail()
}
Coupon --o Wishlist
Coupon --> Review : "*"
Invoice ..> Warehouse : "1..*"
Review --o Coupon
@enduml