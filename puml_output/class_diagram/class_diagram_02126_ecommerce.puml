@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Invoice {
  #long email
  +String id
  #double description
  -int type
  +cancelStatus()
  +setPhone()
  +sendActive()
  +saveType()
}
class Warehouse {
  +String type
  +Date phone
  #float quantity
  +processEmail()
}
abstract class Review {
  -String level
  -String email
  +float id
  +boolean code
  +saveStatus()
  +createActive()
}
class Customer {
  +float createdAt
  #double phone
  +long duration
  #float name
  #boolean total
  +sendCreatedat()
  +findName()
  +findUpdatedat()
  +validateType()
}
interface Wishlist {
  #double score
  -float level
  -float updatedAt
  #Date active
  +saveTotal()
  +findPhone()
  +getCreatedat()
  +deleteEmail()
}
class Coupon {
  #boolean total
  -float name
  #long amount
  #double code
  +int quantity
  +validateEmail()
  +processAmount()
  +cancelEmail()
}
Review --|> Invoice
Invoice ..|> Review
Coupon --> Customer : "1"
Customer ..|> Invoice
Coupon --o Wishlist
note right of Invoice : Ecommerce domain
@enduml