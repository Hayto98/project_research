@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
interface CheckIn {
  -long code
  -Date active
  #double score
  +saveStatus()
  +processDescription()
  +createCreatedat()
  +getCreatedat()
}
class Staff {
  +int updatedAt
  +String id
  +validateAddress()
  +cancelActive()
  +saveStatus()
}
abstract class Guest {
  -boolean active
  #int address
  +double phone
  #Date createdAt
  -int total
  +getCode()
  +setDescription()
  +setCode()
  +setScore()
}
class Housekeeping {
  #int status
  -boolean description
  +createTotal()
  +processQuantity()
}
class CheckOut {
  #double code
  +boolean amount
  -boolean active
  +boolean phone
  +deleteId()
  +sendAddress()
}
Guest --* Housekeeping
Staff --o CheckOut
CheckOut --* CheckIn
note right of CheckIn : Hotel domain
@enduml