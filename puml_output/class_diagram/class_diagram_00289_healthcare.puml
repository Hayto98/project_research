@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
interface Treatment {
  #String note
  -String level
  #long name
  +deletePhone()
}
class MedicalRecord {
  -long quantity
  +boolean createdAt
  #float address
  +updateLevel()
}
class Prescription {
  #float status
  +float total
  +int type
  +double duration
  +validateName()
  +validateUpdatedat()
}
class Appointment {
  +int total
  +boolean email
  +double quantity
  -long level
  +double note
  +sendNote()
  +getLevel()
}
class Patient {
  #long description
  -double code
  +findCreatedat()
  +saveDuration()
  +saveStatus()
  +deletePhone()
}
abstract class Insurance {
  -String level
  #boolean updatedAt
  #double email
  +cancelStatus()
  +calculateStatus()
  +getId()
  +findId()
}
class Diagnosis {
  -boolean status
  +String level
  #Date updatedAt
  +long name
  +calculateAmount()
  +calculateTotal()
  +updateUpdatedat()
}
MedicalRecord --o Prescription
Appointment --o Prescription
@enduml