@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Housekeeping {
  #long status
  #int description
  +String price
  +String id
  +createCreatedat()
  +createActive()
  +findName()
  +updateAmount()
}
class Payment {
  -String name
  +Date description
  +deleteAmount()
  +saveQuantity()
}
class Service {
  +int price
  +boolean description
  +processAddress()
  +findType()
  +processDescription()
}
abstract class Invoice {
  -String name
  -float total
  -String active
  +int createdAt
  #Date code
  +cancelNote()
}
Service ..> Housekeeping : "0..1"
Service --* Invoice
@enduml