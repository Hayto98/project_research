@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Cart {
  +String name
  #double email
  +saveActive()
  +deleteAmount()
}
class Warehouse {
  -boolean id
  +double total
  #String address
  +setCreatedat()
  +processScore()
  +sendPrice()
}
class Review {
  #int phone
  +double price
  #Date active
  +boolean createdAt
  #boolean email
