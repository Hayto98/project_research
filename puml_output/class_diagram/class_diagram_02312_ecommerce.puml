@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Cart {
  +String name
  #double email
  +sendDuration()
  +createUpdatedat()
}
class Warehouse {
  +double createdAt
  -long level
  #int amount
  +createStatus()
  +getType()
  +findCode()
  +setStatus()
}
class Review {
  -float score
  -boolean duration
  #int price
  #long createdAt
  #int total
  +setPrice()
  +processType()
}
class Supplier {
  #long updatedAt
  +int address
  +int quantity
  -int level
  -int score
  +sendCreatedat()
  +processNote()
  +calculateTotal()
  +setDuration()
}
Review --> Supplier : "1"
Supplier --> Review : "1..*"
Supplier ..> Warehouse : "0..1"
@enduml