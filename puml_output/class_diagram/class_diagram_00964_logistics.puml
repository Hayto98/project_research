@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class DeliveryNote {
  +int updatedAt
  #long active
  #boolean note
  #Date price
  +long phone
  +savePrice()
}
class Tracking {
  -long createdAt
  -long quantity
  #long amount
  +float phone
  #int total
  +saveEmail()
  +updateAddress()
}
abstract class Depot {
  -double email
  #long createdAt
  #long code
  +Date address
  +setName()
}
class Warehouse {
  +long score
  #double quantity
  +String note
  +findDuration()
  +processDescription()
  +setScore()
  +deleteTotal()
}
class Vehicle {
  -String status
  #double address
  -boolean price
  +String id
  +double description
  +saveTotal()
  +validateCreatedat()
}
class Driver {
  +boolean phone
  +int address
  #float description
  +findName()
  +createNote()
}
DeliveryNote --|> Warehouse
Vehicle --o DeliveryNote
Depot ..|> DeliveryNote
Tracking --> Driver : "1..*"
@enduml