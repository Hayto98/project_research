@startuml
skinparam defaultFontSize 11
class Reservation {
  +Date level
  -Date updatedAt
  -float email
  -boolean status
  -String createdAt
  +updateNote()
  +createQuantity()
  +createAddress()
}
class Restaurant {
  +String quantity
  +int updatedAt
  +processAmount()
}
class Service {
  +String name
  -float id
  -boolean email
  +double level
  #long note
  +processPhone()
  +setTotal()
  +getType()
}
class CheckIn {
  #int score
  #float code
  +cancelScore()
  +processLevel()
}
class Guest {
  -float description
  +String name
  +calculateEmail()
}
class Housekeeping {
  -int createdAt
  #boolean price
  +cancelDescription()
  +processCreatedat()
}
Reservation --* Housekeeping
Housekeeping --> Restaurant : "0..1"
note right of Reservation : Hotel domain
@enduml