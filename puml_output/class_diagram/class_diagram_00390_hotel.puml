@startuml
skinparam defaultFontSize 11
class Reservation {
  +Date level
  -Date updatedAt
  -float email
  -boolean status
  -String createdAt
  +processDuration()
  +deletePrice()
  +setTotal()
}
class Restaurant {
  +String address
  +int email
  +String code
  -int quantity
  +calculateQuantity()
  +setUpdatedat()
  +sendTotal()
}
class Service {
  +double note
  -boolean name
  +processLevel()
  +getScore()
}
class CheckIn {
  +double type
  +String phone
  #String status
  #int total
  +validateActive()
  +createStatus()
}
abstract class Guest {
  -float status
  +String description
  +double name
  +setAmount()
  +createPhone()
  +setStatus()
}
class Housekeeping {
  -int email
  +String createdAt
  #String active
  -String updatedAt
  +float description
  +savePrice()
  +saveLevel()
}
Guest ..|> Restaurant
Reservation --> Restaurant : "1"
Guest --o Reservation
@enduml