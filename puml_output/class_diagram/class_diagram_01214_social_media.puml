@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Hashtag {
  #int address
  +long description
  +double quantity
  +float price
  -float id
  +deleteEmail()
  +updateAmount()
  +deleteLevel()
}
class Like {
  -Date status
  +String level
  +deleteLevel()
  +cancelNote()
}
class Report {
  #float active
  #int duration
  #String note
  -int updatedAt
  -boolean status
  +deleteQuantity()
}
class Comment {
  +double id
  +String code
  #float address
  +processQuantity()
  +getPhone()
  +saveLevel()
  +findLevel()
}
class Profile {
  #String address
  +Date type
  +double quantity
  -double phone
  +processCreatedat()
}
Report --|> Like
Profile ..|> Comment
@enduml