@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
interface Assignment {
  -boolean total
  #float duration
  +findScore()
  +validateAmount()
  +updateActive()
  +updateNote()
}
class Enrollment {
  #long id
  -long score
  -double createdAt
  +int address
  #double description
  +calculateAmount()
  +findNote()
}
abstract class Teacher {
  -boolean total
  -int score
  +sendCode()
  +setType()
}
class Course {
  -int quantity
  +boolean updatedAt
  +boolean total
  #double level
  +updateId()
  +deleteAddress()
  +updateAmount()
}
interface Attendance {
  +Date name
  +float status
  -boolean phone
  +double id
  +cancelQuantity()
  +setDuration()
}
abstract class Student {
  +double total
  #float quantity
  +saveTotal()
  +savePrice()
}
class Book {
  -float type
  -double description
  #int email
  -Date name
  +findPhone()
  +processCreatedat()
  +cancelType()
  +updateAddress()
}
Enrollment ..|> Assignment
Course --|> Teacher
@enduml