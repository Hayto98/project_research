@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
interface Assignment {
  -boolean total
  #float duration
  +createEmail()
  +getActive()
  +findCreatedat()
  +processId()
}
interface Enrollment {
  +Date score
  -double address
  -long duration
  +setUpdatedat()
  +findTotal()
  +updateNote()
  +setNote()
}
interface Teacher {
  -boolean total
  -int score
  +processDescription()
  +validatePhone()
}
class Course {
  +String total
  #String updatedAt
  #Date quantity
  +sendEmail()
  +findUpdatedat()
  +cancelQuantity()
  +getStatus()
}
class Attendance {
  -boolean createdAt
  +double code
  +processNote()
  +getTotal()
}
class Student {
  #float total
  +Date score
  -double amount
  +createName()
  +createNote()
}
abstract class Book {
  -int email
  #String active
  +String score
  +calculateQuantity()
  +getPhone()
}
Assignment ..|> Course
Teacher --o Assignment
Attendance ..|> Teacher
note right of Assignment : Education domain
@enduml