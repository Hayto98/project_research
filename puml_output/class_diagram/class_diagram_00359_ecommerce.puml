@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
interface Product {
  #double email
  +Date price
  -String name
  +cancelAmount()
  +deleteNote()
}
abstract class Supplier {
  -double quantity
  -boolean updatedAt
  +saveScore()
}
interface Return {
  #Date total
  +float active
  +updateStatus()
  +setNote()
  +setName()
}
class Category {
  -Date level
  #Date updatedAt
  +processUpdatedat()
  +processEmail()
  +updateNote()
}
class Customer {
  #int status
  +String phone
  +Date id
  +createNote()
}
Customer --* Supplier
Return ..|> Product
note right of Product : Ecommerce domain
@enduml