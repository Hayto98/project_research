@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
interface Product {
  #double email
  +Date price
  -String name
  +processId()
  +findId()
}
class Supplier {
  -double type
  #String code
  #Date quantity
  #boolean updatedAt
  +double total
  +getUpdatedat()
}
class Return {
  +Date status
  +long duration
  #String note
  +processTotal()
  +saveUpdatedat()
}
interface Category {
  +double note
  #String updatedAt
  +String duration
  -String email
  +createPhone()
  +calculateEmail()
}
class Customer {
  +boolean email
  #int note
  +calculateUpdatedat()
  +updateLevel()
  +deleteNote()
}
Category --o Customer
Return --o Product
@enduml