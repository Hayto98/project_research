@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Transfer {
  +int type
  +Date code
  +findAmount()
  +calculatePrice()
  +updateTotal()
}
class Loan {
  #int level
  -double score
  -int createdAt
  -long email
  +sendPrice()
  +processQuantity()
  +deleteType()
  +createCode()
}
class Card {
  #float email
  #int code
  +float level
  #boolean amount
  +cancelLevel()
  +setType()
  +createLevel()
}
class Customer {
  -String amount
  #boolean status
  +boolean duration
  +processStatus()
}
Loan --> Card : "*"
Customer --o Card
note right of Transfer : Banking domain
@enduml