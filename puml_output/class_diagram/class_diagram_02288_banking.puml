@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Transfer {
  +int type
  +Date code
  +validateTotal()
  +deleteScore()
  +validateType()
}
abstract class Loan {
  -boolean updatedAt
  +long total
  -double email
  +double address
  -double createdAt
  +deleteDuration()
  +findScore()
  +calculateAddress()
  +sendName()
}
class Card {
  -String email
  +float address
  +setPhone()
  +updateQuantity()
}
interface Customer {
  #Date amount
  #String score
  -long quantity
  +saveAddress()
}
Transfer --o Customer
Transfer --> Card : "0..1"
@enduml