@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
interface Album {
  +long name
  -float price
  -float note
  +saveEmail()
  +validateUpdatedat()
  +processActive()
  +sendStatus()
}
abstract class Group {
  +double total
  -double score
  +long quantity
  +processNote()
  +sendActive()
  +setPhone()
  +updateTotal()
}
interface Report {
  #double active
  #String amount
  +deleteStatus()
}
abstract class User {
  -String id
  -Date price
  -boolean status
  -String note
  +getDuration()
  +processNote()
}
interface Hashtag {
  -String address
  #float type
  -double updatedAt
  +validatePrice()
}
class Message {
  +double total
  +Date price
  #boolean address
  -boolean duration
  +findEmail()
  +saveId()
  +getScore()
}
Group ..|> Message
Group --o Report
User --* Album
User --o Report
Report ..> Album : "1"
note right of Album : Social Media domain
@enduml