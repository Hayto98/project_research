@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
interface Album {
  +long name
  -float price
  -float note
  +findStatus()
  +validateAmount()
  +cancelId()
  +updateAmount()
}
class Group {
  -boolean active
  -String score
  -double status
  -int total
  -double createdAt
  +saveAmount()
  +findPrice()
  +calculateStatus()
  +calculateActive()
}
class Report {
  +boolean createdAt
  -boolean total
  +boolean status
  +int active
  +deleteAmount()
}
class User {
  +double duration
  -String price
  +saveDescription()
  +setTotal()
  +deleteDescription()
  +deleteTotal()
}
abstract class Hashtag {
  #double createdAt
  -boolean id
  +getDuration()
  +validateDuration()
}
abstract class Message {
  -String price
  -double id
  +long quantity
  +getPrice()
  +sendType()
  +saveCode()
  +createId()
}
User --o Album
Group --o Hashtag
Hashtag --* Message
Message ..> Report : "1"
@enduml