@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
abstract class Classroom {
  -double phone
  +int name
  +validateCreatedat()
  +setActive()
  +updateAddress()
}
class Exam {
  +Date phone
  +int type
  +validatePhone()
  +cancelDescription()
  +processNote()
}
abstract class Library {
  #boolean phone
  +boolean score
  +validateStatus()
  +getDuration()
  +savePrice()
}
class Schedule {
  #boolean name
  -String amount
  -boolean price
  +saveTotal()
}
class Book {
  +boolean duration
  #int createdAt
  -double address
  +updateAmount()
}
abstract class Grade {
  -boolean description
  #long duration
  #long status
  +processLevel()
  +cancelActive()
  +deleteName()
  +sendEmail()
}
class Attendance {
  #Date address
  #int description
  +double createdAt
  #Date name
  +deleteDuration()
  +createActive()
  +sendStatus()
}
Exam ..|> Book
Exam ..|> Attendance
Book --|> Exam
Attendance --o Library
Library ..|> Attendance
@enduml