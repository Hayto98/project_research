@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
abstract class Classroom {
  -double phone
  +int name
  +deleteUpdatedat()
  +setPhone()
  +processId()
}
class Exam {
  #String quantity
  -boolean code
  #boolean note
  +sendAddress()
  +cancelPhone()
}
interface Library {
  #boolean name
  -String amount
  -boolean price
  +setUpdatedat()
}
interface Schedule {
  #int address
  -double description
  +double active
  +deleteDescription()
  +setEmail()
}
interface Book {
  #long duration
  +int quantity
  -long type
  #int total
  +getActive()
  +saveDuration()
}
class Grade {
  -float type
  -int email
  #int note
  +deleteCreatedat()
  +sendAmount()
}
class Attendance {
  -long price
  +boolean phone
  +float email
  #int description
  +setPhone()
  +processAddress()
}
Attendance ..> Exam : "1"
Exam --o Schedule
Book --> Grade : "0..1"
Attendance --|> Library
Schedule --|> Attendance
Exam ..> Classroom : "*"
note right of Classroom : Education domain
@enduml