@startuml
skinparam defaultFontSize 11
abstract class Supplier {
  +boolean quantity
  +double name
  #float amount
  -Date description
  #boolean address
  +findPrice()
}
abstract class Wishlist {
  #int quantity
  #Date address
  +float id
  #String description
  +saveAddress()
  +sendUpdatedat()
  +getAddress()
  +validateType()
}
class Warehouse {
  -boolean duration
  +float active
  #int updatedAt
  #String amount
  -String level
  +getPrice()
  +calculateType()
  +sendCreatedat()
  +calculateId()
}
class Coupon {
  #float type
  #float level
  -Date createdAt
  #float updatedAt
  +getType()
  +sendAddress()
  +findDescription()
  +setAddress()
}
class Invoice {
  -boolean score
  -Date amount
  -long name
  +float id
  +deleteAmount()
}
Supplier ..|> Invoice
Invoice --|> Supplier
Supplier --|> Warehouse
@enduml