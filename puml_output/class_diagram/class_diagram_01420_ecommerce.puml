@startuml
skinparam defaultFontSize 11
abstract class Supplier {
  +boolean quantity
  +double name
  #float amount
  -Date description
  #boolean address
  +sendType()
}
interface Wishlist {
  #int quantity
  #Date address
  +float id
  #String description
  +deleteTotal()
  +saveStatus()
  +saveType()
  +cancelActive()
}
class Warehouse {
  +float amount
  #int email
  #String score
  +getPrice()
  +processName()
  +getEmail()
  +processLevel()
}
class Coupon {
  -String duration
  -boolean note
  #Date active
  +validateScore()
}
interface Invoice {
  #long name
  #long id
  -String phone
  +calculatePrice()
}
Supplier ..> Wishlist : "1"
Supplier --* Invoice
note right of Supplier : Ecommerce domain
@enduml