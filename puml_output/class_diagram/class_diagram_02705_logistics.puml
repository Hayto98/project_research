@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Shipment {
  #boolean description
  #boolean total
  +int note
  +findScore()
  +findCreatedat()
  +deleteDescription()
}
class Route {
  +boolean email
  #long score
  -double phone
  +boolean price
  +deleteDuration()
  +setPrice()
  +cancelCode()
}
class Manifest {
  #int score
  #double description
  +cancelPhone()
  +savePhone()
  +findNote()
  +setAddress()
}
class Driver {
  +String description
  -String score
  +double status
  -double duration
  #long total
  +cancelId()
}
class Depot {
  +boolean name
  #boolean email
  +boolean id
  +updateName()
  +setTotal()
  +createName()
}
class DeliveryNote {
  -String type
  -String email
  +float createdAt
  +setCreatedat()
  +saveScore()
}
class Customer {
  +double quantity
  -int address
  -float phone
  +validateEmail()
  +setName()
  +sendEmail()
}
Shipment --|> Route
Route --> Depot : "*"
note right of Shipment : Logistics domain
@enduml