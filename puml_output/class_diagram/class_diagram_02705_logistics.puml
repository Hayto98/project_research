@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Shipment {
  #boolean description
  #boolean total
  +int note
  +sendUpdatedat()
  +getCreatedat()
  +validateTotal()
}
class Route {
  -boolean description
  #long createdAt
  -float quantity
  +findDescription()
}
interface Manifest {
  +boolean quantity
  +double price
  #String createdAt
  #long email
  +setAddress()
}
class Driver {
  #Date total
  -float note
  #float phone
  +setDescription()
  +findStatus()
  +validateScore()
  +cancelPhone()
}
abstract class Depot {
  -String score
  +double status
  +float description
  +calculateAmount()
}
class DeliveryNote {
  +boolean quantity
  -Date status
  +int id
  #boolean amount
  #String description
  +createScore()
  +updateCode()
  +processQuantity()
}
class Customer {
  -long quantity
  +long name
  +long id
  +int active
  +String updatedAt
  +validatePrice()
  +calculateDuration()
}
Route --* Manifest
Manifest --o Shipment
@enduml