@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Restaurant {
  +String name
  +long duration
  +Date description
  -int id
  +findId()
  +getAddress()
}
interface Invoice {
  -Date phone
  +boolean quantity
  -long description
  -double duration
  +deleteDescription()
  +calculateDescription()
  +deleteName()
  +createActive()
}
interface Payment {
  +String quantity
  +String code
  -boolean note
  #Date score
  +processCreatedat()
  +saveStatus()
  +cancelDuration()
  +sendUpdatedat()
}
class Guest {
  +long updatedAt
  +int active
  +Date createdAt
  +createStatus()
}
class Room {
  #long level
  -String active
  +cancelCode()
}
class Housekeeping {
  +String note
  -double createdAt
  -boolean total
  +saveNote()
  +cancelDescription()
  +findQuantity()
}
class Service {
  +int amount
  #long type
  +boolean phone
  #int quantity
  +processAddress()
  +findName()
}
Service ..|> Room
Housekeeping ..> Payment : "0..1"
Housekeeping --> Service : "1..*"
@enduml