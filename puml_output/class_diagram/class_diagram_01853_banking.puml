@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Customer {
  -Date type
  -long score
  #String createdAt
  -String status
  -double quantity
  +findPhone()
  +getName()
}
interface Branch {
  -String total
  #Date code
  +getId()
}
class Account {
  #Date address
  #boolean code
  +setStatus()
}
interface Beneficiary {
  -double duration
  #long email
  +cancelCreatedat()
  +createEmail()
}
interface Loan {
  +long email
  #double createdAt
  +validateAddress()
  +getEmail()
  +processScore()
  +sendActive()
}
class Transfer {
  -float code
  #float status
  +String note
  #int description
  -int duration
  +createTotal()
  +cancelActive()
}
class Interest {
  #long duration
  +int createdAt
  +float email
  +sendQuantity()
  +calculateCreatedat()
}
Transfer --o Beneficiary
Loan --o Branch
Customer --* Interest
Customer --|> Loan
Beneficiary --|> Account
note right of Customer : Banking domain
@enduml