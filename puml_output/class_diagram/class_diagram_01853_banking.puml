@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Customer {
  -Date type
  -long score
  #String createdAt
  -String status
  -double quantity
  +createNote()
  +cancelName()
}
class Branch {
  #String name
  -String level
  +setPrice()
  +setDescription()
  +savePrice()
}
class Account {
  +long id
  +Date amount
  +cancelEmail()
}
class Beneficiary {
  -double duration
  #long email
  +validateActive()
  +processActive()
}
class Loan {
  +long score
  #double status
  -float email
  -long createdAt
  +findType()
}
class Transfer {
  +float score
  +Date duration
  -int active
  +double name
  #float type
  +cancelEmail()
  +saveUpdatedat()
}
class Interest {
  #boolean amount
  +int score
  #int description
  -Date quantity
  -int total
  +validateCode()
  +getUpdatedat()
}
Loan --o Account
Branch ..> Loan : "*"
Beneficiary ..|> Loan
@enduml