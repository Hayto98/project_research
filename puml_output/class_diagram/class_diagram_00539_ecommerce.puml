@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
abstract class Category {
  -int updatedAt
  +Date quantity
  +cancelType()
  +saveAddress()
}
abstract class Coupon {
  +Date level
  #int phone
  #boolean duration
  #boolean description
  -long quantity
  +deleteDescription()
}
class Shipment {
  +boolean createdAt
  +float type
  +double code
  +processQuantity()
  +cancelUpdatedat()
}
interface Wishlist {
  -boolean address
  #Date email
  -float status
  +createType()
  +getLevel()
  +cancelUpdatedat()
  +updateEmail()
}
interface Payment {
  -Date duration
  -Date quantity
  -double level
  +int total
  +validateUpdatedat()
  +calculateUpdatedat()
  +calculateNote()
  +findDescription()
}
class Return {
  +String updatedAt
  #long name
  +String price
  #int type
  +findStatus()
  +validateCode()
}
Payment --|> Category
Coupon --* Return
@enduml