@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
interface Fine {
  +long amount
  +boolean quantity
  +Date description
  +float score
  +getActive()
  +setCode()
  +cancelName()
}
class Renewal {
  -boolean status
  -long level
  +long updatedAt
  +sendActive()
}
class Librarian {
  -Date duration
  -boolean code
  +getNote()
  +validatePhone()
}
class Reservation {
  +int quantity
  +float level
  -int type
  -String code
  +boolean note
  +updateLevel()
  +createStatus()
}
abstract class Author {
  #String email
  -long name
  #String code
  #boolean duration
  -boolean createdAt
  +processStatus()
  +validateStatus()
  +updatePrice()
}
abstract class Publisher {
  -long duration
  -boolean updatedAt
  +int createdAt
  #boolean status
  +findStatus()
}
interface Loan {
  #double phone
  +String createdAt
  #Date updatedAt
  -long type
  +processCode()
}
Fine ..|> Loan
Librarian --|> Renewal
note right of Fine : Library domain
@enduml