@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
interface Fine {
  +long amount
  +boolean quantity
  +Date description
  +float score
  +saveEmail()
  +calculateActive()
  +findNote()
}
class Renewal {
  +Date createdAt
  +boolean active
  +deletePrice()
  +findPrice()
}
class Librarian {
  #Date code
  +String email
  #String id
  -Date active
  +setPhone()
  +cancelDuration()
  +cancelScore()
  +findStatus()
}
class Reservation {
  #Date note
  #Date address
  +updateLevel()
  +processTotal()
  +setCreatedat()
}
class Author {
  -int code
  -String note
  +boolean description
  #int score
  +boolean name
  +validateId()
  +saveAmount()
  +processId()
}
abstract class Publisher {
  #String name
  -long code
  #String email
  #boolean createdAt
  +deleteUpdatedat()
  +findCreatedat()
  +saveAmount()
  +cancelDuration()
}
class Loan {
  #long status
  #Date createdAt
  +int price
  +long total
  +calculateLevel()
  +deleteLevel()
  +sendCode()
}
Loan ..|> Renewal
Publisher --|> Author
Publisher ..> Fine : "1..*"
Librarian ..|> Author
Publisher --o Renewal
Loan --o Publisher
@enduml