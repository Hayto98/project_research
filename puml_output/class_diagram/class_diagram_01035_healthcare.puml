@startuml

interface Nurse {
  #float description
  -long total
  +boolean phone
  +float email
  +cancelDuration()
  +validateQuantity()
  +processName()
}
class Treatment {
  #float price
  #long score
  +double duration
  #String quantity
  #float name
  +getStatus()
}
class LabTest {
  #long code
  +boolean amount
  +int updatedAt
  -long active
  +float price
  +deleteName()
  +processActive()
  +getDescription()
  +createPhone()
}
class MedicalRecord {
  #float duration
  -int status
  +String level
  +long price
  +int email
  +updatePrice()
  +findPrice()
}
MedicalRecord --|> LabTest
Treatment ..> Nurse : "*"
note right of Nurse : Healthcare domain
@enduml