@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Group {
  +int createdAt
  +int name
  -double email
  #boolean address
  +boolean quantity
  +calculateCreatedat()
}
class Comment {
  +String name
  +long quantity
  #float total
  +updateStatus()
  +cancelType()
  +createPhone()
  +updateTotal()
}
class User {
  -Date address
  -String phone
  #double total
  +calculateCode()
  +calculateScore()
}
abstract class Story {
  +String updatedAt
  +double quantity
  -long id
  +boolean active
  +int description
  +deleteCode()
  +processQuantity()
}
class Album {
  +int status
  #boolean code
  #float email
  #double note
  #String type
  +getTotal()
}
interface Message {
  +int amount
  +String active
  +processScore()
}
class Like {
  +String phone
  +long duration
  -boolean score
  +float name
  +sendCreatedat()
  +updateScore()
  +sendName()
  +cancelTotal()
}
Message --o Album
Story ..> Like : "1"
Comment ..|> Message
Album --> User : "1"
Like --|> Group
Comment --o Like
@enduml