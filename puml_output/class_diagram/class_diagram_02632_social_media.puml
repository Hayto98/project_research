@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Group {
  +int createdAt
  +int name
  -double email
  #boolean address
  +boolean quantity
  +validateUpdatedat()
}
class Comment {
  +String quantity
  +long total
  +updateStatus()
  +validateId()
  +sendDescription()
  +saveAddress()
}
class User {
  -long note
  -double address
  +Date id
  -String duration
  #int updatedAt
  +setCreatedat()
  +calculateAddress()
}
class Story {
  #int duration
  -String status
  -double description
  +setEmail()
}
interface Album {
  #Date type
  +int amount
  #boolean level
  +int note
  #int code
  +deleteStatus()
  +cancelCode()
}
class Message {
  +String phone
  +long duration
  -boolean score
  +float name
  +processType()
  +getActive()
  +saveScore()
  +processTotal()
}
abstract class Like {
  #long description
  #String amount
  +setDescription()
}
Story --|> Comment
Comment --> Story : "*"
note right of Group : Social Media domain
@enduml