@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Wishlist {
  #double id
  +double code
  +Date note
  +deleteType()
  +setType()
}
interface Customer {
  #int type
  -float code
  +boolean amount
  -boolean active
  #Date description
  +findEmail()
  +calculateDescription()
  +validateAddress()
}
class Supplier {
  #double createdAt
  +Date phone
  +float total
  -boolean amount
  -float duration
  +validateUpdatedat()
  +saveAddress()
  +calculateType()
}
class Invoice {
  -String email
  #float code
  +double score
  #int note
  #String id
  +createName()
  +createLevel()
  +createQuantity()
}
interface Coupon {
  -boolean address
  #double phone
  #long note
  #double price
  +processQuantity()
  +deleteDuration()
  +findStatus()
}
class Order {
  +float active
  #String description
  +String address
  -boolean duration
  +createScore()
  +validateUpdatedat()
}
abstract class Category {
  +Date description
  +long name
  -Date type
  +Date active
  +createDuration()
}
Coupon --o Order
Customer --o Coupon
note right of Wishlist : Ecommerce domain
@enduml