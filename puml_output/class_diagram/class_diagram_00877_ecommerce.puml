@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Wishlist {
  #double id
  +double code
  +Date note
  +processAddress()
  +cancelType()
}
class Customer {
  +Date code
  #int type
  #int total
  -float level
  +boolean duration
  +setPhone()
  +deleteUpdatedat()
  +getActive()
  +setActive()
}
class Supplier {
  -Date price
  #double description
  +long phone
  -int address
  +setId()
  +sendScore()
}
class Invoice {
  -float phone
  +float price
  #long duration
  +validateName()
  +setTotal()
  +processType()
  +validateType()
}
class Coupon {
  -String level
  -String score
  +createPrice()
  +calculateDuration()
}
class Order {
  +long address
  #long quantity
  +processAddress()
  +sendQuantity()
  +cancelLevel()
}
class Category {
  #boolean phone
  -Date note
  -Date price
  -long total
  +processDescription()
  +getName()
  +calculateAddress()
  +getQuantity()
}
Supplier --> Category : "0..1"
Supplier ..|> Coupon
@enduml