@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
interface Depot {
  -String score
  #boolean note
  +long description
  +Date active
  +cancelName()
  +cancelQuantity()
  +cancelCode()
  +validateDuration()
}
class Vehicle {
  -Date phone
  #long updatedAt
  #boolean code
  #String price
  +boolean status
  +deleteId()
  +getName()
  +updateDuration()
}
class Driver {
  #double description
  +boolean createdAt
  +saveLevel()
  +processEmail()
  +deleteActive()
  +cancelUpdatedat()
}
class Route {
  -float note
  -boolean price
  +int quantity
  +processId()
}
class Customer {
  #boolean code
  -boolean score
  #int note
  #long id
  #String amount
  +getCode()
  +saveType()
  +sendAddress()
  +validateAddress()
}
class Inventory {
  +float price
  #int code
  +Date amount
  +Date note
  +cancelLevel()
}
Inventory --* Route
Customer ..> Route : "1"
note right of Depot : Logistics domain
@enduml