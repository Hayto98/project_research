@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
interface Depot {
  -String score
  #boolean note
  +long description
  +Date active
  +sendActive()
  +processQuantity()
  +setId()
  +updateLevel()
}
interface Vehicle {
  -float phone
  #long quantity
  +sendDescription()
  +sendStatus()
}
class Driver {
  +boolean status
  -int note
  +String phone
  +int active
  #Date code
  +processCreatedat()
  +calculateType()
}
class Route {
  +boolean createdAt
  -Date level
  #double type
  +getEmail()
  +getScore()
  +sendActive()
}
class Customer {
  -float description
  -boolean note
  +int price
  #boolean quantity
  +validateName()
}
class Inventory {
  +int score
  #boolean total
  -boolean code
  #int note
  +createTotal()
  +updatePrice()
  +deleteActive()
}
Depot --> Route : "1..*"
Driver --|> Inventory
@enduml