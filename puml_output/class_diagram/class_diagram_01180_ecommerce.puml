@startuml
skinparam shadowing true
class Wishlist {
  -float score
  #long quantity
  +processDuration()
  +cancelCode()
  +setTotal()
}
class Payment {
  -float code
  -Date type
  +Date name
  -boolean score
  +getName()
  +createStatus()
  +updateDuration()
  +deleteCreatedat()
}
class Warehouse {
  -String score
  -long duration
  -Date type
  +double active
  +boolean name
  +calculateNote()
  +setId()
  +createStatus()
  +updateStatus()
}
class Return {
  +boolean updatedAt
  -Date price
  +processPrice()
  +cancelActive()
}
abstract class Product {
  #int description
  +String score
  +getScore()
}
abstract class Cart {
  -int level
  #float id
  +deleteAmount()
  +calculateDescription()
}
interface Coupon {
  #String price
  +boolean duration
  +findCode()
  +setCode()
}
Warehouse --|> Product
Cart --o Coupon
Wishlist --> Product : "1"
Payment --|> Return
Cart ..|> Warehouse
Wishlist ..> Return : "1"
@enduml