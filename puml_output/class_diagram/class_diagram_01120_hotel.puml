@startuml
skinparam monochrome true
class Amenity {
  +String phone
  -String code
  +double email
  #Date type
  +validateActive()
  +updateName()
}
interface Service {
  +String phone
  #double name
  -String active
  -boolean type
  #float email
  +calculateId()
}
class Payment {
  -double note
  +long active
  +cancelTotal()
  +calculateActive()
  +calculateNote()
  +calculateEmail()
}
abstract class Booking {
  -int price
  -int address
  +findStatus()
  +findType()
  +cancelQuantity()
  +cancelPhone()
}
interface Housekeeping {
  -Date total
  -double score
  -Date price
  +findDuration()
}
class Restaurant {
  +Date id
  -boolean updatedAt
  +float status
  +savePhone()
  +calculateId()
  +findDuration()
  +validateScore()
}
Payment --* Booking
Housekeeping --* Service
Restaurant ..|> Amenity
Restaurant --> Housekeeping : "0..1"
@enduml