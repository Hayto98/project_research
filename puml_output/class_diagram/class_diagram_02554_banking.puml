@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Account {
  #float type
  #String score
  #Date email
  +double quantity
  +setActive()
  +sendUpdatedat()
  +calculateId()
}
class Customer {
  +String code
  #float id
  #String type
  +deleteNote()
  +updateCode()
  +setAddress()
}
class Beneficiary {
  #boolean createdAt
  -String duration
  +String code
  -Date note
  +validateActive()
  +sendDuration()
  +sendAddress()
  +processLevel()
}
abstract class Interest {
  +boolean note
  -boolean level
  -float type
  +int name
  +calculateScore()
  +deleteAmount()
  +sendNote()
}
class Deposit {
  +boolean quantity
  +float note
  +createType()
  +getCreatedat()
  +setType()
}
abstract class Card {
  -Date level
  +String active
  +validateLevel()
  +createNote()
}
Customer --o Interest
Customer --> Card : "*"
@enduml