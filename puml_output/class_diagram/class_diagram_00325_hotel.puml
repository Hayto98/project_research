@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
interface Service {
  +String description
  +double email
  -float active
  +double name
  +String note
  +updateName()
}
class Room {
  -long total
  #double price
  -String phone
  -Date updatedAt
  +Date note
  +processName()
  +createStatus()
  +validateLevel()
}
class Amenity {
  +int score
  #double code
  +int id
  +findDuration()
  +findStatus()
  +updateCreatedat()
  +calculateName()
}
class CheckOut {
  #long score
  +long description
  #double code
  +processDescription()
  +findCode()
}
class Restaurant {
  #Date description
  +double duration
  -long name
  +saveCode()
  +setAddress()
}
Room --* Amenity
Restaurant ..|> CheckOut
note right of Service : Hotel domain
@enduml