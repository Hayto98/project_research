@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
interface Service {
  +String description
  +double email
  -float active
  +double name
  +String note
  +processDuration()
}
class Room {
  -long price
  +float total
  +calculateScore()
  +createActive()
  +findName()
  +processType()
}
class Amenity {
  #boolean price
  -double description
  +deleteName()
}
class CheckOut {
  +int level
  +boolean quantity
  -String updatedAt
  +double code
  +validateNote()
}
class Restaurant {
  #long name
  +long status
  #double updatedAt
  +double description
  +Date code
  +deleteCode()
}
Room --|> Restaurant
Room --o CheckOut
@enduml