@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Department {
  -long level
  +boolean id
  +cancelNote()
  +setScore()
  +getNote()
  +createId()
}
abstract class Course {
  -boolean amount
  #boolean active
  +saveScore()
}
class Attendance {
  +long duration
  +Date score
  #boolean type
  +cancelEmail()
  +processAddress()
  +setTotal()
}
class Book {
  -String id
  #float description
  +saveQuantity()
  +deleteStatus()
}
abstract class Assignment {
  -int description
  #long duration
  +long phone
  +findAmount()
  +cancelNote()
  +createCreatedat()
  +sendCode()
}
class Enrollment {
  +long id
  -Date amount
  +cancelAddress()
  +getDuration()
  +processName()
}
abstract class Library {
  -double quantity
  +float id
  +getLevel()
  +getType()
  +deleteId()
  +deleteCode()
}
Library --o Department
Library --> Assignment : "0..1"
Enrollment ..> Book : "1"
Attendance --* Book
Department ..> Attendance : "1"
@enduml