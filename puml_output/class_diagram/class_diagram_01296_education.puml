@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Department {
  -long level
  +boolean id
  +updateQuantity()
  +findPrice()
  +setAmount()
  +sendPhone()
}
interface Course {
  #int phone
  #boolean email
  +getEmail()
  +updateActive()
  +createStatus()
  +createName()
}
class Attendance {
  +Date description
  +int address
  +updateDescription()
  +deletePhone()
  +calculateDescription()
  +cancelAddress()
}
class Book {
  +double score
  +Date note
  +String total
  +String createdAt
  +calculateLevel()
  +saveQuantity()
  +createId()
}
abstract class Assignment {
  -double quantity
  +float id
  +setCode()
  +validateDuration()
  +getPrice()
  +sendDuration()
}
class Enrollment {
  -String name
  -float quantity
  #String price
  -float phone
  +boolean active
  +createScore()
  +validateStatus()
}
interface Library {
  +long id
  #float active
  -boolean score
  +String createdAt
  -Date price
  +findLevel()
  +sendQuantity()
  +setStatus()
  +calculateType()
}
Course ..|> Assignment
Library --o Course
Library --o Enrollment
Course --* Book
Assignment --* Attendance
Assignment ..> Library : "0..1"
note right of Department : Education domain
@enduml