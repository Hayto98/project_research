@startuml
skinparam defaultFontSize 13
interface Customer {
  #String id
  -String quantity
  #float total
  #float updatedAt
  +saveType()
  +updateNote()
  +validateNote()
  +validateTotal()
}
class Vehicle {
  +String code
  +double address
  +validateDuration()
  +sendLevel()
  +validatePrice()
}
class Route {
  #String price
  +String amount
  +String updatedAt
  #long duration
  #boolean status
  +savePhone()
  +saveCode()
}
abstract class Depot {
  +boolean createdAt
  -Date type
  #boolean description
  +validateAddress()
}
Depot --o Route
Depot ..> Customer : "1..*"
@enduml