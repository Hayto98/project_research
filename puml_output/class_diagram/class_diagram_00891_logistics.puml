@startuml
skinparam defaultFontSize 13
interface Customer {
  #String id
  -String quantity
  #float total
  #float updatedAt
  +sendUpdatedat()
  +findName()
  +getCode()
  +validateCreatedat()
}
class Vehicle {
  #long note
  -double address
  +int level
  +sendScore()
  +saveStatus()
  +saveCode()
  +deleteId()
}
class Route {
  +String quantity
  -double active
  +updateType()
  +findDescription()
}
class Depot {
  -long active
  #float duration
  -float level
  #float code
  +processName()
  +saveQuantity()
  +calculateCode()
  +sendDescription()
}
Route --> Vehicle : "1"
Depot ..> Route : "*"
Depot --* Vehicle
note right of Customer : Logistics domain
@enduml