@startuml
skinparam ArrowColor #555555
interface Account {
  #String duration
  #boolean id
  #float note
  +deleteUpdatedat()
  +calculateActive()
}
interface Statement {
  +int email
  #double level
  +long description
  +long quantity
  -long phone
  +setName()
  +findTotal()
  +calculatePrice()
}
class Transaction {
  +long score
  -double duration
  -String level
  -float description
  +setQuantity()
  +updateUpdatedat()
}
interface Branch {
  +boolean score
  #boolean active
  #float type
  +Date level
  +setEmail()
}
Branch --o Statement
Account --> Transaction : "*"
note right of Account : Banking domain
@enduml