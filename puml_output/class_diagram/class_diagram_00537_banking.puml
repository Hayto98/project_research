@startuml
skinparam ArrowColor #555555
interface Account {
  #String duration
  #boolean id
  #float note
  +updateType()
  +validateNote()
}
abstract class Statement {
  +int email
  #double level
  +long description
  +long quantity
  -long phone
  +setDescription()
  +saveId()
  +deleteType()
}
abstract class Transaction {
  -double price
  -long id
  +long address
  +String description
  #long status
  +createNote()
  +validateStatus()
}
class Branch {
  +boolean score
  #boolean active
  #float type
  +Date level
  +validatePhone()
}
Transaction --o Branch
Transaction ..> Statement : "1"
Branch ..> Transaction : "*"
@enduml