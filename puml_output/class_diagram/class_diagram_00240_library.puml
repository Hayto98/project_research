@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
interface Branch {
  #long level
  -float duration
  -int status
  #Date total
  -String phone
  +calculateTotal()
  +saveCode()
  +setDescription()
  +validateId()
}
class Shelf {
  #long id
  +double score
  -float email
  +updateId()
  +cancelQuantity()
  +saveName()
}
class Member {
  #boolean phone
  #int address
  +boolean updatedAt
  +saveAddress()
  +sendDuration()
  +saveQuantity()
  +processScore()
}
class Librarian {
  -String name
  -Date quantity
  +boolean active
  +findPhone()
  +processDescription()
  +processTotal()
}
abstract class Renewal {
  #float level
  -long active
  +processId()
  +getType()
  +updateId()
  +findCode()
}
class Book {
  #boolean createdAt
  -double quantity
  +processPhone()
  +savePhone()
  +calculateAmount()
  +updateTotal()
}
Book --o Renewal
Book --* Shelf
Librarian --> Book : "1..*"
Member --> Shelf : "0..1"
@enduml