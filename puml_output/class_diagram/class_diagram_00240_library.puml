@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
interface Branch {
  #long level
  -float duration
  -int status
  #Date total
  -String phone
  +calculateCode()
  +setId()
  +updateId()
  +sendEmail()
}
class Shelf {
  -Date note
  -double duration
  +deletePhone()
  +validateUpdatedat()
  +findActive()
}
class Member {
  #int score
  #Date note
  -int amount
  +createActive()
}
class Librarian {
  #long phone
  +long name
  +processCode()
  +findLevel()
  +sendLevel()
  +calculateEmail()
}
abstract class Renewal {
  #String phone
  +float email
  +findActive()
  +calculatePrice()
  +findType()
}
class Book {
  -double name
  -float phone
  #boolean email
  -long total
  +boolean createdAt
  +deleteLevel()
  +setStatus()
}
Shelf --|> Renewal
Shelf ..|> Branch
Librarian ..> Member : "1..*"
note right of Branch : Library domain
@enduml