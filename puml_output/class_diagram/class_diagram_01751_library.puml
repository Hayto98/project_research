@startuml
skinparam ArrowColor #555555
class Librarian {
  #long updatedAt
  +String type
  -Date price
  #float total
  +sendTotal()
  +findUpdatedat()
  +setActive()
  +findQuantity()
}
interface Publisher {
  +long active
  +long description
  +deleteId()
  +setStatus()
}
class Book {
  -String id
  #Date address
  -double code
  +cancelType()
  +createUpdatedat()
}
class Shelf {
  -boolean address
  #float score
  +processAmount()
  +findLevel()
  +sendPhone()
}
class Member {
  +boolean updatedAt
  -long score
  +validateActive()
}
interface Reservation {
  -long email
  +boolean score
  -double description
  -int quantity
  +savePhone()
  +findPhone()
}
Librarian --o Reservation
Shelf --o Member
Shelf --|> Librarian
Shelf ..> Reservation : "1..*"
Member ..|> Shelf
@enduml