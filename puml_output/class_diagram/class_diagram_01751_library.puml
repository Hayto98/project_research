@startuml
skinparam ArrowColor #555555
class Librarian {
  #long updatedAt
  +String type
  -Date price
  #float total
  +getDuration()
  +validateScore()
  +getActive()
  +deleteCreatedat()
}
class Publisher {
  +boolean address
  #Date updatedAt
  +float status
  +validateCode()
}
class Book {
  -int score
  #String type
  +validateScore()
}
class Shelf {
  +boolean code
  +boolean phone
  -long name
  +boolean status
  +saveEmail()
  +findScore()
  +findDescription()
}
class Member {
  +int quantity
  +int createdAt
  #Date type
  -String price
  +double duration
  +sendNote()
  +calculateId()
  +setNote()
  +calculateLevel()
}
interface Reservation {
  #long score
  +boolean price
  #String createdAt
  +float phone
  +validateStatus()
  +updateStatus()
  +createUpdatedat()
}
Shelf --|> Book
Reservation --> Shelf : "1..*"
Librarian --|> Book
note right of Librarian : Library domain
@enduml