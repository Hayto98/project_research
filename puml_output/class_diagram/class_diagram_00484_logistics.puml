@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Warehouse {
  #float updatedAt
  +float quantity
  #long id
  +getCreatedat()
  +validateAmount()
  +deleteTotal()
  +calculateLevel()
}
class Depot {
  +String amount
  +int updatedAt
  #int email
  #int code
  +setTotal()
  +updateScore()
}
interface Package {
  #boolean duration
  #boolean price
  #int id
  #float active
  +calculatePhone()
  +validateScore()
  +findStatus()
  +updateType()
}
class Route {
  +boolean id
  +double createdAt
  #int total
  -long amount
  -boolean level
  +setName()
  +processScore()
  +deleteLevel()
  +validateId()
}
interface Driver {
  -String code
  #boolean status
  -boolean amount
  +sendScore()
  +findName()
  +sendNote()
}
Driver ..> Depot : "*"
Package --o Driver
Route --|> Package
@enduml