@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
abstract class Customer {
  +String status
  +int updatedAt
  +boolean total
  +boolean quantity
  +deleteUpdatedat()
}
interface Shipment {
  -double quantity
  -boolean createdAt
  +int description
  +int address
  +sendActive()
  +cancelName()
}
interface Package {
  #Date quantity
  #boolean description
  -int type
  -long updatedAt
  #double note
  +setDuration()
  +calculateDescription()
  +getQuantity()
  +sendScore()
}
class FuelLog {
  +long total
  +String updatedAt
  +saveCreatedat()
  +createScore()
  +cancelEmail()
  +getAddress()
}
class Manifest {
  -boolean email
  -float id
  +saveAddress()
  +calculateTotal()
  +updateUpdatedat()
}
Customer --* FuelLog
Manifest --> Customer : "*"
Shipment --|> FuelLog
@enduml