@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Comment {
  -boolean name
  #long email
  -int id
  #double total
  +validateEmail()
  +setActive()
}
class Report {
  -Date note
  -Date active
  +Date id
  #long phone
  +updateDuration()
  +calculateCreatedat()
}
abstract class Hashtag {
  +long createdAt
  -double price
  +cancelScore()
  +saveCode()
}
abstract class Story {
  +float status
  #long price
  +getActive()
  +deletePhone()
  +sendUpdatedat()
  +cancelQuantity()
}
class Notification {
  #String updatedAt
  +String level
  +findType()
  +findTotal()
  +getEmail()
}
class Group {
  +int id
  -boolean status
  -int quantity
  #double note
  +calculateActive()
  +setCreatedat()
  +saveEmail()
}
interface Post {
  +double code
  -boolean amount
  +processAddress()
  +createEmail()
}
Comment ..> Report : "1"
Notification --* Group
Group --* Story
Notification --* Story
@enduml