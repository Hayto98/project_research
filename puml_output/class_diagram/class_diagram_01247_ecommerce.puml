@startuml
skinparam defaultFontSize 11
class Payment {
  -String updatedAt
  #float duration
  -long level
  +findPhone()
}
class Shipment {
  +double code
  +int description
  #Date duration
  #float type
  #Date score
  +deletePhone()
  +sendQuantity()
  +createName()
}
class Return {
  +boolean description
  -int address
  +createNote()
}
class Supplier {
  -boolean email
  -boolean id
  +calculateQuantity()
  +createActive()
  +calculateEmail()
}
class Warehouse {
  #float amount
  #Date total
  #boolean name
  #int address
  +float note
  +validateUpdatedat()
  +savePrice()
}
interface Category {
  +double price
  +double active
  +updateScore()
}
Return --* Category
Return ..|> Shipment
Category ..|> Shipment
note right of Payment : Ecommerce domain
@enduml