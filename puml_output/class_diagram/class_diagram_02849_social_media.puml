@startuml
skinparam monochrome true
skinparam defaultFontSize 11
abstract class Like {
  +String name
  -String updatedAt
  +double address
  -int type
  +cancelAmount()
}
class Album {
  -float score
  -double price
  +sendAddress()
  +cancelCreatedat()
  +processStatus()
  +calculatePrice()
}
class Report {
  -double name
  +boolean score
  +long type
  -String duration
  +findUpdatedat()
  +cancelQuantity()
}
abstract class Hashtag {
  -int address
  +int status
  #long email
  +deleteEmail()
}
interface Post {
  -boolean price
  #Date level
  +long address
  #int code
  +cancelPhone()
}
class Follower {
  +double createdAt
  #long description
  +setTotal()
  +calculateStatus()
  +saveStatus()
}
Like --> Album : "*"
Follower ..|> Post
Post --o Album
note right of Like : Social Media domain
@enduml