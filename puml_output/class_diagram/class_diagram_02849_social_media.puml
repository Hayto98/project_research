@startuml
skinparam monochrome true
skinparam defaultFontSize 11
abstract class Like {
  +String name
  -String updatedAt
  +double address
  -int type
  +calculateType()
}
interface Album {
  -long address
  -double name
  -boolean score
  +cancelActive()
  +getUpdatedat()
  +cancelNote()
}
abstract class Report {
  -boolean price
  -String duration
  +cancelLevel()
  +processQuantity()
  +setEmail()
  +processTotal()
}
class Hashtag {
  +boolean quantity
  #int phone
  +processId()
  +saveUpdatedat()
}
class Post {
  +int updatedAt
  +boolean address
  -Date status
  #boolean email
  +int level
  +createTotal()
  +calculateLevel()
  +processEmail()
}
interface Follower {
  -boolean price
  #Date level
  +long address
  #int code
  +cancelActive()
}
Album ..|> Like
Album --o Follower
Post --* Report
Like --o Hashtag
@enduml