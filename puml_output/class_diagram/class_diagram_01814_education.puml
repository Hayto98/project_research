@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
interface Course {
  -double status
  -boolean name
  +cancelDuration()
  +calculateLevel()
  +sendStatus()
  +sendTotal()
}
class Library {
  -double amount
  #String code
  +float name
  #float quantity
  +Date score
  +createType()
  +findScore()
}
interface Exam {
  +int score
  +double level
  #Date id
  -double address
  +deleteDescription()
}
class Assignment {
  +double level
  #String quantity
  +int duration
  +long amount
  +findType()
  +validateDescription()
  +deleteCode()
  +updateActive()
}
Course --o Assignment
Assignment --* Library
Course ..> Library : "1..*"
@enduml