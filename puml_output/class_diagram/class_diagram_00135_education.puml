@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
interface Book {
  -String phone
  +int total
  #float active
  #long quantity
  -double score
  +deleteUpdatedat()
  +findCode()
  +validateCode()
}
class Classroom {
  -double duration
  -String price
  #String updatedAt
  +int type
  +int amount
  +validatePrice()
}
class Exam {
  +double total
  -float updatedAt
  +getDescription()
  +processName()
  +getDescription()
}
class Attendance {
  #double score
  +String description
  +Date updatedAt
  +int email
  +cancelName()
  +sendAddress()
  +getStatus()
  +createUpdatedat()
}
class Library {
  +double price
  -int level
  +int address
  +sendUpdatedat()
  +saveName()
  +validateAddress()
}
Library --* Attendance
Classroom --|> Attendance
note right of Book : Education domain
@enduml