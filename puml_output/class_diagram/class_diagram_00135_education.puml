@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
interface Book {
  -String phone
  +int total
  #float active
  #long quantity
  -double score
  +calculateAddress()
  +sendPrice()
  +findAddress()
}
class Classroom {
  +double code
  +long duration
  -float total
  -String price
  +sendTotal()
}
class Exam {
  -double description
  -String name
  +findAddress()
  +deleteQuantity()
  +deleteAmount()
  +deletePrice()
}
class Attendance {
  +float description
  +int type
  +findCreatedat()
  +cancelDuration()
}
interface Library {
  +String updatedAt
  +Date email
  +int note
  +findUpdatedat()
  +cancelPrice()
  +savePhone()
  +getScore()
}
Book --* Library
Classroom --> Exam : "0..1"
Attendance --|> Exam
@enduml