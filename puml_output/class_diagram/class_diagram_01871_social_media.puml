@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Group {
  -boolean type
  -String status
  +Date description
  -double code
  +boolean active
  +deleteCode()
}
class Report {
  +float phone
  #String quantity
  #Date id
  -String updatedAt
  +cancelActive()
  +saveCreatedat()
}
class Like {
  #float id
  +int name
  -Date createdAt
  #Date duration
  -boolean code
  +cancelUpdatedat()
  +createLevel()
  +sendLevel()
}
abstract class Post {
  -float email
  +String code
  +int phone
  +int amount
  #Date updatedAt
  +cancelScore()
  +findTotal()
  +getActive()
  +getEmail()
}
class Story {
  +boolean level
  -boolean quantity
  #double address
  +processAmount()
  +setId()
  +sendName()
  +updateLevel()
}
Group --> Report : "1"
Story ..> Group : "*"
Report --|> Story
Report --> Like : "1"
@enduml