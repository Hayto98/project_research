@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Group {
  -boolean type
  -String status
  +Date description
  -double code
  +boolean active
  +validateCode()
}
class Report {
  #String quantity
  #Date id
  -String updatedAt
  +boolean score
  +updateScore()
  +processId()
  +saveName()
}
class Like {
  +double code
  #Date createdAt
  +sendAddress()
  +findTotal()
  +processEmail()
  +findDuration()
}
class Post {
  +String amount
  +int updatedAt
  +Date note
  #float createdAt
  +saveDescription()
  +setLevel()
  +deleteLevel()
  +createAddress()
}
class Story {
  #double active
  -Date level
  #float note
  #String price
  #int code
  +sendId()
}
Post ..|> Report
Group --* Report
Story --o Group
Story --> Post : "1..*"
note right of Group : Social Media domain
@enduml