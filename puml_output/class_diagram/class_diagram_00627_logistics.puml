@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Depot {
  -int updatedAt
  -Date score
  -float email
  +Date note
  -int amount
  +setName()
  +getId()
  +saveAmount()
  +cancelPhone()
}
class Driver {
  #long status
  +long active
  #long level
  -long createdAt
  +sendUpdatedat()
}
class Inventory {
  +Date description
  +int duration
  +validateType()
  +findDuration()
  +saveAddress()
  +saveCode()
}
class Customer {
  +boolean amount
  +boolean address
  #double note
  +boolean email
  +validateNote()
}
Inventory --|> Customer
Customer --o Depot
@enduml