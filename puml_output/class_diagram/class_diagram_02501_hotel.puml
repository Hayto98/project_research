@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Amenity {
  -String email
  #boolean duration
  -String address
  +saveDuration()
  +findStatus()
  +sendUpdatedat()
  +calculateDescription()
}
class Staff {
  +String score
  +String level
  +getAmount()
}
class CheckIn {
  -double email
  -double code
  -double duration
  +float note
  +float status
  +saveDescription()
  +findType()
  +createName()
  +calculateTotal()
}
interface Room {
  -boolean description
  +boolean createdAt
  +getPhone()
}
class Booking {
  -long name
  #float active
  +findStatus()
  +sendScore()
  +cancelDescription()
  +deletePrice()
}
class Invoice {
  -int score
  +float code
  +deleteAddress()
  +updateActive()
  +savePhone()
}
class Reservation {
  #boolean name
  #Date address
  +int email
  -Date description
  +sendName()
}
Staff --|> Room
Staff --* Amenity
Amenity --> Staff : "*"
@enduml