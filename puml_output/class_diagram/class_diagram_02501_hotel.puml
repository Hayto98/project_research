@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Amenity {
  -String email
  #boolean duration
  -String address
  +cancelEmail()
  +cancelName()
  +findScore()
  +cancelUpdatedat()
}
class Staff {
  #String id
  #float active
  #Date name
  +createCode()
  +createNote()
  +setAddress()
  +processPrice()
}
abstract class CheckIn {
  #String total
  +int id
  -boolean amount
  +boolean note
  +double active
  +setName()
}
interface Room {
  #double quantity
  #int level
  +boolean total
  +double price
  +updateLevel()
  +createUpdatedat()
}
class Booking {
  -String name
  -float score
  +deleteActive()
  +sendId()
  +deleteType()
}
class Invoice {
  +long description
  +int duration
  #double type
  +String name
  -float amount
  +createTotal()
}
class Reservation {
  #float price
  +Date name
  +double type
  -long active
  +setTotal()
  +updateStatus()
}
Reservation --|> Invoice
Invoice --|> Staff
note right of Amenity : Hotel domain
@enduml