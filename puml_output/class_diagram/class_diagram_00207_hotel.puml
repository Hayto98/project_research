@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Booking {
  +long updatedAt
  +int createdAt
  +boolean active
  #int address
  +int phone
  +createCode()
  +validateCode()
}
class Invoice {
  #Date phone
  -boolean id
  #double amount
  +findQuantity()
  +saveStatus()
  +cancelActive()
  +sendQuantity()
}
interface CheckIn {
  #long duration
  -String level
  +boolean name
  -float email
  +sendCode()
  +createUpdatedat()
}
abstract class Housekeeping {
  -float name
  #float note
  #float status
  -long level
  +float score
  +calculateActive()
  +processQuantity()
  +deletePhone()
}
Booking --o Housekeeping
Housekeeping --> CheckIn : "1"
CheckIn --o Housekeeping
@enduml