@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
abstract class Diagnosis {
  +long code
  #double duration
  -boolean price
  +findUpdatedat()
  +setPhone()
  +deleteId()
}
class Treatment {
  +boolean email
  +int level
  -int price
  -String type
  #Date description
  +calculateName()
  +getCreatedat()
  +saveScore()
  +updateActive()
}
interface Billing {
  +double score
  #float price
  #float address
  +setTotal()
}
abstract class Nurse {
  -float amount
  -String quantity
  #Date duration
  +calculateScore()
  +sendCode()
}
Treatment --o Billing
Diagnosis --|> Treatment
Treatment --> Nurse : "0..1"
@enduml