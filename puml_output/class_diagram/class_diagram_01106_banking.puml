@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Loan {
  -int description
  +double status
  +validateName()
  +findQuantity()
  +calculateUpdatedat()
}
class Account {
  -Date level
  -String price
  +Date phone
  -double duration
  +sendCode()
  +deleteAddress()
  +deletePhone()
  +saveCreatedat()
}
class Statement {
  #long description
  #String phone
  -String name
  +long total
  +boolean quantity
  +findPhone()
}
class Card {
  -Date score
  -float duration
  +boolean id
  +String type
  +createDuration()
  +saveQuantity()
  +updateUpdatedat()
}
class Branch {
  +int description
  #double name
  #boolean code
  +processStatus()
  +validateScore()
  +updateCreatedat()
}
interface Beneficiary {
  +long id
  +double amount
  +boolean description
  #boolean name
  #long phone
  +getQuantity()
  +setScore()
  +sendId()
}
Loan --|> Account
Beneficiary --o Statement
Loan --o Card
Branch --* Beneficiary
note right of Loan : Banking domain
@enduml