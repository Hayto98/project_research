@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Loan {
  -int description
  +double status
  +saveScore()
  +cancelPrice()
  +calculateEmail()
}
class Account {
  -double updatedAt
  #long createdAt
  +String phone
  #double price
  -boolean score
  +getScore()
  +cancelStatus()
  +deleteScore()
  +processPhone()
}
class Statement {
  -int phone
  -String createdAt
  -long name
  +setQuantity()
  +cancelDescription()
  +createPhone()
}
class Card {
  +boolean id
  #float phone
  +cancelDescription()
}
class Branch {
  #String email
  -double score
  +saveLevel()
  +getStatus()
  +cancelTotal()
  +deleteDescription()
}
class Beneficiary {
  #Date quantity
  -int email
  +cancelLevel()
  +processQuantity()
}
Account --|> Loan
Account --> Beneficiary : "*"
Branch --* Beneficiary
@enduml