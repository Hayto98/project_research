@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Hashtag {
  #String email
  #String amount
  -boolean status
  -boolean createdAt
  +deleteCreatedat()
  +getEmail()
}
interface Group {
  #long quantity
  -int description
  +findCreatedat()
}
abstract class Notification {
  #int description
  -long score
  +updateLevel()
  +findAddress()
}
abstract class Profile {
  +String email
  +int phone
  +findPhone()
  +validateDuration()
  +calculateNote()
}
class Album {
  +double note
  #float price
  +boolean status
  -Date level
  +updateName()
  +sendAmount()
}
Profile --o Hashtag
Profile --* Group
Album ..|> Hashtag
@enduml