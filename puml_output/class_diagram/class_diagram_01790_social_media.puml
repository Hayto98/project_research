@startuml
skinparam defaultFontSize 11
abstract class Follower {
  -Date quantity
  #double total
  +double duration
  -Date updatedAt
  #String type
  +updateCode()
  +calculateName()
}
class Like {
  #Date level
  #String total
  #String note
  -Date duration
  -long amount
  +sendNote()
  +calculatePhone()
  +findNote()
  +processAddress()
}
class Album {
  +boolean score
  -float phone
  -boolean description
  +double email
  +getActive()
  +processNote()
}
class Post {
  #float updatedAt
  +double code
  #String active
  +Date type
  +calculateTotal()
}
class Report {
  +float active
  #long createdAt
  +String phone
  +int quantity
  +int total
  +sendDescription()
  +createCode()
  +validateAddress()
}
Post ..> Album : "1..*"
Album --o Report
note right of Follower : Social Media domain
@enduml