@startuml
skinparam defaultFontSize 11
abstract class Follower {
  -Date quantity
  #double total
  +double duration
  -Date updatedAt
  #String type
  +findAddress()
  +saveLevel()
}
class Like {
  -int name
  #Date amount
  #String note
  #String total
  -Date score
  +calculateScore()
  +deletePhone()
  +getAddress()
}
interface Album {
  -long total
  #long phone
  +long note
  +boolean score
  -float address
  +calculateTotal()
  +deleteUpdatedat()
  +getEmail()
}
abstract class Post {
  -long name
  -int active
  +Date type
  +processScore()
  +sendDescription()
  +deleteDescription()
  +createEmail()
}
class Report {
  -double code
  #Date updatedAt
  +long status
  -double total
  +float active
  +saveLevel()
  +processDuration()
  +calculateEmail()
}
Like ..|> Follower
Report --> Album : "0..1"
@enduml