@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
abstract class Staff {
  +String duration
  -String quantity
  +findEmail()
  +calculateScore()
}
class Amenity {
  -String address
  -double description
  +validateNote()
  +setDescription()
  +findNote()
}
class Reservation {
  #String price
  -String code
  +Date level
  +double total
  #boolean email
  +sendAddress()
  +getCreatedat()
  +findPrice()
}
class Payment {
  #float status
  -long code
  +int updatedAt
  +calculateLevel()
  +savePrice()
}
Payment --|> Amenity
Payment --o Reservation
@enduml