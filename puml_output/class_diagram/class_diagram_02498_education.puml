@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
interface Assignment {
  +int level
  #double status
  +int active
  -double duration
  +calculateQuantity()
}
class Exam {
  -long total
  -long level
  -float name
  +long code
  +calculateActive()
  +setName()
  +validateUpdatedat()
}
class Schedule {
  +String duration
  +double type
  #double amount
  +long note
  #float id
  +calculatePhone()
  +saveName()
  +findUpdatedat()
  +saveNote()
}
class Course {
  +int duration
  #float updatedAt
  #Date name
  +String code
  +String price
  +cancelActive()
}
class Library {
  -String id
  +int type
  #long price
  +deleteName()
  +cancelName()
}
interface Student {
  +int description
  -long name
  #boolean phone
  -long createdAt
  #int updatedAt
  +validatePrice()
  +calculateId()
  +findNote()
}
class Teacher {
  +String quantity
  -float address
  #long updatedAt
  -String level
  +sendCreatedat()
  +validateDescription()
  +saveQuantity()
  +saveDescription()
}
Library --|> Teacher
Student --o Assignment
Assignment --> Teacher : "1..*"
Schedule ..|> Assignment
@enduml