@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Route {
  #long total
  -Date description
  +findType()
}
interface Inventory {
  -String active
  -double code
  #float note
  -boolean id
  +calculateUpdatedat()
  +findAmount()
  +createNote()
  +setStatus()
}
abstract class Depot {
  -Date active
  +float type
  +createNote()
  +findId()
  +calculateLevel()
}
class FuelLog {
  +String level
  -float id
  +Date updatedAt
  -long active
  +findScore()
  +sendCreatedat()
  +validateAmount()
  +validateActive()
}
interface DeliveryNote {
  #long name
  +double code
  +findType()
  +deleteUpdatedat()
  +createPrice()
}
class Driver {
  -boolean updatedAt
  +int level
  #boolean score
  -float active
  +double email
  +calculateCode()
  +createPhone()
  +updateCreatedat()
}
interface Warehouse {
  -double level
  +double code
  -String createdAt
  +sendCode()
  +deletePhone()
  +cancelCreatedat()
  +sendScore()
}
Warehouse ..|> Inventory
DeliveryNote --|> Route
note right of Route : Logistics domain
@enduml