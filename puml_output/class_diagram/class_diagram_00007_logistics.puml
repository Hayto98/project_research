@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Route {
  #long total
  -Date description
  +saveTotal()
}
abstract class Inventory {
  -String active
  -double code
  #float note
  -boolean id
  +setNote()
  +findAddress()
  +updateScore()
  +findEmail()
}
class Depot {
  +boolean note
  -double code
  #int status
  #boolean total
  +deleteCreatedat()
  +calculateAmount()
  +cancelName()
}
class FuelLog {
  #int level
  +double amount
  +Date phone
  -long id
  #float updatedAt
  +cancelDescription()
  +saveActive()
  +calculateActive()
  +calculateNote()
}
class DeliveryNote {
  #String phone
  +float active
  #long code
  +calculateAmount()
  +processStatus()
}
abstract class Driver {
  -double updatedAt
  +float email
  #boolean price
  +cancelId()
  +getQuantity()
  +updateDescription()
}
class Warehouse {
  +long id
  #long price
  +float email
  +boolean total
  +calculateUpdatedat()
  +findName()
}
Inventory --o FuelLog
@enduml