@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Withdrawal {
  +float duration
  -String address
  -long active
  #boolean note
  +cancelId()
  +createPrice()
  +cancelLevel()
  +getLevel()
}
class Deposit {
  +String price
  +double name
  +long phone
  +sendPrice()
  +getEmail()
  +getName()
}
class Loan {
  -double phone
  -boolean active
  +sendAmount()
  +findPrice()
  +calculateName()
}
class Account {
  #String amount
  -float description
  +calculateLevel()
}
Loan --* Account
Account --|> Withdrawal
@enduml