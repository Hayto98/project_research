@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Withdrawal {
  +float duration
  -String address
  -long active
  #boolean note
  +validatePrice()
  +setCode()
  +deletePrice()
  +getPhone()
}
class Deposit {
  +long status
  -Date total
  +getCode()
  +validateActive()
}
abstract class Loan {
  #float phone
  #float score
  +Date duration
  +int active
  #int address
  +createStatus()
}
class Account {
  +double email
  +double score
  +boolean price
  -int name
  +findCreatedat()
  +calculateStatus()
  +deletePrice()
}
Deposit --o Withdrawal
Withdrawal --* Loan
note right of Withdrawal : Banking domain
@enduml