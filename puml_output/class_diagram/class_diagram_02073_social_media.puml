@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Message {
  #String phone
  +float duration
  -double price
  -float id
  +getStatus()
  +getPrice()
}
abstract class Comment {
  +double phone
  #float updatedAt
  -double name
  +sendPrice()
  +validateDescription()
}
class Report {
  -Date level
  #float phone
  -double code
  -float id
  +validateNote()
  +setLevel()
  +validateDuration()
  +cancelType()
}
class Album {
  #String note
  +double address
  +deleteCode()
  +processLevel()
  +createCode()
  +setType()
}
Message ..|> Album
Comment ..|> Album
@enduml