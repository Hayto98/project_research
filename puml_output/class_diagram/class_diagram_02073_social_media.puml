@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Message {
  #String phone
  +float duration
  -double price
  -float id
  +calculateUpdatedat()
  +validateUpdatedat()
}
class Comment {
  -double note
  #boolean level
  +saveCode()
  +findQuantity()
}
interface Report {
  -double code
  -int id
  +long total
  +float address
  +processAddress()
}
class Album {
  -int type
  +int duration
  -boolean phone
  +updateDescription()
}
Report ..|> Message
Report --|> Comment
note right of Message : Social Media domain
@enduml