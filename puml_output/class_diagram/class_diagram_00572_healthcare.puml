@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
interface Hospital {
  +long updatedAt
  #float type
  #double duration
  +boolean id
  +float status
  +cancelName()
  +saveDuration()
  +createPrice()
}
abstract class Ward {
  #long createdAt
  +long phone
  #Date score
  #double duration
  #Date address
  +createDescription()
}
class Billing {
  +float price
  #long address
  +double level
  +findEmail()
  +createPrice()
}
class LabTest {
  -float id
  -Date score
  -Date quantity
  +createQuantity()
}
class Appointment {
  +long active
  #double duration
  +Date email
  -boolean name
  +updateScore()
  +deleteName()
  +deleteType()
  +processName()
}
class Diagnosis {
  #Date active
  +long email
  -double description
  +String duration
  #long note
  +processId()
  +sendPhone()
  +deleteScore()
  +getQuantity()
}
LabTest ..> Billing : "1"
Diagnosis --> Ward : "1"
Diagnosis ..> Billing : "1"
@enduml