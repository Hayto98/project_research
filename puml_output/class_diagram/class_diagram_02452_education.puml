@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
interface Book {
  #Date description
  +int status
  +saveType()
  +deleteId()
  +setPrice()
  +validateDuration()
}
interface Course {
  #String status
  #String amount
  #long score
  +boolean description
  +cancelDescription()
  +cancelType()
  +setLevel()
  +processId()
}
interface Library {
  +float active
  #float status
  +getId()
  +getPrice()
  +sendAddress()
}
class Teacher {
  -long note
  #boolean quantity
  +float level
  #double updatedAt
  +calculateQuantity()
  +deleteCode()
  +cancelPhone()
}
class Exam {
  -int email
  #boolean active
  -Date id
  +Date createdAt
  -int amount
  +updateNote()
}
Exam --> Library : "0..1"
Book ..|> Exam
Library --* Exam
@enduml