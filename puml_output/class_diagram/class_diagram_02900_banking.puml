@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Card {
  +double code
  #int note
  +validateName()
  +sendActive()
  +saveCreatedat()
  +sendLevel()
}
class Loan {
  +float level
  +Date phone
  +boolean status
  #long createdAt
  +sendPhone()
  +findScore()
  +sendScore()
}
abstract class Branch {
  -Date level
  -String phone
  +Date note
  #float status
  -String address
  +processLevel()
  +calculateActive()
  +deleteAddress()
  +saveLevel()
}
abstract class Transfer {
  +long name
  -boolean code
  +int active
  +double amount
  +createCode()
}
Card --o Transfer
Card --|> Branch
Branch ..|> Transfer
@enduml