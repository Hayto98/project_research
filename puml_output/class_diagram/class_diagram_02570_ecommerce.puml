@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Wishlist {
  #long id
  -Date name
  +Date type
  #Date quantity
  +validateAmount()
  +saveEmail()
}
class Category {
  -double level
  -float address
  #Date duration
  -boolean status
  +processTotal()
}
abstract class Warehouse {
  -double total
  +Date updatedAt
  +Date email
  +double createdAt
  +cancelAddress()
  +getTotal()
}
class Invoice {
  +int phone
  #boolean code
  -double total
  +setScore()
}
interface Supplier {
  #long price
  #float active
  -String email
  +String quantity
  +calculateNote()
  +saveScore()
  +validateName()
  +sendUpdatedat()
}
abstract class Review {
  +float id
  +Date email
  +updatePhone()
}
Invoice --o Wishlist
Category --* Wishlist
Category --* Review
Wishlist ..|> Supplier
@enduml