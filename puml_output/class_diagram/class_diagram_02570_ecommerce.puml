@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Wishlist {
  #long id
  -Date name
  +Date type
  #Date quantity
  +createName()
  +setQuantity()
}
interface Category {
  -long level
  #Date address
  -boolean status
  +double email
  +createTotal()
  +findUpdatedat()
  +cancelEmail()
  +updateTotal()
}
abstract class Warehouse {
  +long id
  +long code
  +long type
  +cancelTotal()
}
class Invoice {
  #Date active
  +Date email
  #boolean type
  +calculateActive()
  +createQuantity()
  +sendAddress()
}
interface Supplier {
  +long status
  -Date amount
  -String code
  +long price
  +updateName()
}
class Review {
  +int id
  -String total
  #int description
  +Date name
  +String address
  +cancelAddress()
  +sendActive()
}
Category --> Review : "1..*"
Invoice --|> Supplier
note right of Wishlist : Ecommerce domain
@enduml