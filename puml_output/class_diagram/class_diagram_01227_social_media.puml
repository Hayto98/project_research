@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Hashtag {
  #long type
  -Date note
  +sendLevel()
  +setActive()
}
class Message {
  -int total
  -float address
  +cancelDuration()
  +sendCreatedat()
}
class Report {
  -int id
  -boolean type
  +float quantity
  +double total
  +getEmail()
}
class Story {
  #long duration
  #double updatedAt
  #boolean status
  #String description
  +boolean email
  +findCreatedat()
  +calculateEmail()
  +processCode()
}
class Profile {
  #String status
  +String updatedAt
  +String active
  +getScore()
  +findDescription()
}
class Notification {
  #String duration
  #String description
  #long level
  +double total
  +setCreatedat()
  +updateId()
}
Notification --|> Hashtag
Message --* Story
Notification --* Report
Hashtag ..> Story : "0..1"
@enduml