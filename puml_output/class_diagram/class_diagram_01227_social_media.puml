@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Hashtag {
  #long type
  -Date note
  +updateName()
  +findTotal()
}
class Message {
  -long description
  +double note
  #long createdAt
  -double type
  +calculateScore()
  +deleteStatus()
}
abstract class Report {
  -boolean description
  +float code
  +findDescription()
}
class Story {
  #Date note
  -long score
  +String id
  -float status
  +setUpdatedat()
  +sendName()
}
class Profile {
  +boolean updatedAt
  #int code
  +cancelDescription()
  +deleteTotal()
  +findName()
}
class Notification {
  #Date amount
  -float type
  #String active
  +int duration
  +validateAddress()
  +createCode()
  +findType()
  +saveUpdatedat()
}
Story --|> Message
Notification --* Report
note right of Hashtag : Social Media domain
@enduml