@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
interface Billing {
  -int quantity
  #int email
  #long type
  -float price
  -long amount
  +saveDuration()
}
abstract class Hospital {
  -Date note
  #float active
  -boolean id
  -float quantity
  -double level
  +createDescription()
  +processPrice()
  +findId()
}
interface LabTest {
  -double phone
  +boolean updatedAt
  -String description
  +sendUpdatedat()
}
class Nurse {
  +boolean createdAt
  -float updatedAt
  -Date address
  #float level
  +Date score
  +validateTotal()
  +createUpdatedat()
  +processQuantity()
}
Billing ..|> LabTest
Hospital ..> Nurse : "0..1"
note right of Billing : Healthcare domain
@enduml