@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
interface Billing {
  -int quantity
  #int email
  #long type
  -float price
  -long amount
  +calculateType()
}
interface Hospital {
  -long level
  -Date total
  #float note
  -boolean active
  -float id
  +deleteAmount()
  +createDescription()
  +deleteLevel()
  +updateId()
}
class LabTest {
  #int description
  #float note
  -int price
  +long id
  +processQuantity()
  +savePrice()
  +sendScore()
  +updateUpdatedat()
}
class Nurse {
  +int description
  -int level
  #long total
  +sendActive()
  +updateLevel()
}
Hospital --> LabTest : "1..*"
LabTest --* Hospital
Hospital --* Nurse
@enduml