@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
abstract class Group {
  -double type
  #boolean email
  #boolean name
  #String price
  +validateCreatedat()
  +calculateDescription()
}
class Notification {
  -String address
  +boolean quantity
  +long phone
  +sendLevel()
}
interface Follower {
  #boolean level
  #String email
  +getName()
}
class Profile {
  +int level
  -float id
  +double code
  -boolean score
  +setEmail()
  +setQuantity()
  +deleteTotal()
  +getDescription()
}
interface Comment {
  -String note
  +long total
  #double id
  +float name
  +createAddress()
  +findDuration()
}
class Album {
  -double duration
  #boolean type
  +saveName()
  +deleteTotal()
  +validateQuantity()
}
Comment ..|> Album
Album --* Group
@enduml