@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
abstract class Group {
  -double type
  #boolean email
  #boolean name
  #String price
  +deleteCode()
  +deleteAddress()
}
class Notification {
  -String email
  #float name
  +boolean status
  -float code
  +getCode()
}
class Follower {
  +int code
  -float duration
  +calculateNote()
  +sendType()
}
class Profile {
  -String note
  +long total
  #double id
  +float name
  +setActive()
  +setCode()
}
interface Comment {
  #int quantity
  #boolean total
  +Date phone
  +long price
  #Date amount
  +sendLevel()
  +processTotal()
}
class Album {
  -float note
  #String active
  -float email
  +cancelUpdatedat()
  +cancelQuantity()
}
Group --|> Follower
Follower --o Profile
Notification --o Profile
Album --|> Notification
note right of Group : Social Media domain
@enduml