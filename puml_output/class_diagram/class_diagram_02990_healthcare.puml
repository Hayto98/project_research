@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Treatment {
  -long name
  +long address
  +setQuantity()
}
interface Ward {
  +Date createdAt
  +long level
  +processActive()
}
class LabTest {
  -float quantity
  +float price
  +boolean score
  -Date total
  +int id
  +setType()
  +findEmail()
  +createAmount()
  +cancelTotal()
}
abstract class Hospital {
  #long status
  +boolean quantity
  +validateCreatedat()
  +saveTotal()
  +processActive()
}
class Insurance {
  -String code
  +Date status
  #int phone
  +processId()
  +getName()
  +calculateScore()
}
class Doctor {
  -String price
  +double duration
  +double email
  +saveScore()
  +processDuration()
  +sendStatus()
}
abstract class Billing {
  -Date code
  #String status
  +String name
  +float total
  #double score
  +deletePrice()
  +createDescription()
}
Treatment --> Hospital : "1..*"
Billing --> Insurance : "0..1"
Billing ..> Hospital : "0..1"
LabTest --o Insurance
LabTest ..|> Doctor
@enduml