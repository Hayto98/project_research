@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Treatment {
  -long name
  +long address
  +sendDuration()
}
interface Ward {
  +Date createdAt
  +long level
  +updateId()
}
abstract class LabTest {
  -float price
  +float score
  +boolean total
  -Date id
  +deleteType()
}
class Hospital {
  #Date id
  #Date note
  #long status
  #long score
  +sendAddress()
  +deleteCreatedat()
}
class Insurance {
  -String code
  +Date status
  #int phone
  +cancelEmail()
  +updateDescription()
  +calculatePrice()
}
class Doctor {
  -long code
  -int updatedAt
  -float price
  -Date status
  +findStatus()
}
class Billing {
  +float name
  +float email
  #double score
  +double code
  #Date id
  +getNote()
  +sendPhone()
  +cancelScore()
  +deleteTotal()
}
Insurance ..|> Billing
LabTest --o Insurance
LabTest ..|> Doctor
Hospital --> Doctor : "0..1"
Doctor --> Billing : "0..1"
Doctor --o Insurance
note right of Treatment : Healthcare domain
@enduml