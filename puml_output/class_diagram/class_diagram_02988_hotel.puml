@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Staff {
  -float updatedAt
  +float phone
  +boolean type
  +savePrice()
}
class Room {
  +double amount
  #double note
  +sendDescription()
  +getCode()
}
class Invoice {
  #Date amount
  +long duration
  #Date code
  +getScore()
  +sendDuration()
  +setName()
}
interface Service {
  #int description
  #double amount
  +String status
  +int active
  +updateEmail()
  +validateStatus()
}
Room ..|> Service
Invoice ..|> Room
@enduml