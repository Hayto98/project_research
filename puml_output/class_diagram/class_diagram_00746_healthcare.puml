@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
interface Ward {
  +double active
  +String createdAt
  -long duration
  +float id
  +double phone
  +validateQuantity()
  +getCreatedat()
  +saveAddress()
}
class Prescription {
  #Date quantity
  +String name
  +calculateCode()
  +saveId()
}
abstract class Billing {
  -boolean phone
  +int updatedAt
  +createQuantity()
  +setUpdatedat()
  +updateId()
}
interface Doctor {
  #long score
  +Date price
  #boolean duration
  +createScore()
}
Billing ..|> Doctor
Doctor ..|> Ward
Prescription --> Ward : "0..1"
@enduml