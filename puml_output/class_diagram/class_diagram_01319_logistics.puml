@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
interface Tracking {
  #long active
  -String phone
  -double name
  +cancelDuration()
  +processStatus()
}
class Manifest {
  +float total
  -float address
  +float updatedAt
  -long type
  +getQuantity()
  +createEmail()
}
class Shipment {
  -double duration
  -long total
  +findAmount()
  +findStatus()
}
abstract class Customer {
  #double createdAt
  -long name
  #Date code
  +cancelName()
  +cancelCode()
  +sendEmail()
}
interface Warehouse {
  +String duration
  #double phone
  #Date quantity
  +long name
  +createActive()
  +cancelAddress()
}
abstract class Route {
  -float phone
  #Date total
  +createNote()
  +sendStatus()
  +createAmount()
}
interface Inventory {
  +boolean address
  -long active
  +long level
  #String quantity
  +sendLevel()
  +findUpdatedat()
  +setPrice()
  +createId()
}
Inventory ..|> Warehouse
Route --> Tracking : "1"
Tracking ..|> Inventory
note right of Tracking : Logistics domain
@enduml