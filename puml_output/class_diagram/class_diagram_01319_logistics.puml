@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
interface Tracking {
  #long active
  -String phone
  -double name
  +getCode()
  +setCode()
}
interface Manifest {
  +Date status
  -String duration
  -float address
  +float total
  -long score
  +savePhone()
  +setTotal()
}
class Shipment {
  -long updatedAt
  -int id
  #int total
  #String quantity
  +deleteLevel()
  +createCode()
  +deleteStatus()
  +getName()
}
class Customer {
  -long code
  #Date note
  +getCode()
  +cancelLevel()
  +cancelPrice()
}
class Warehouse {
  #float score
  -boolean email
  +updateLevel()
  +savePhone()
  +processDuration()
}
class Route {
  #boolean active
  -Date amount
  #double address
  +float level
  -double email
  +updateCreatedat()
  +getDuration()
  +saveActive()
  +validateTotal()
}
class Inventory {
  +Date note
  #long active
  -float status
  #boolean quantity
  +setType()
  +getCreatedat()
  +setDuration()
}
Shipment --* Tracking
Route --o Tracking
Inventory ..> Warehouse : "0..1"
Inventory --o Tracking
@enduml