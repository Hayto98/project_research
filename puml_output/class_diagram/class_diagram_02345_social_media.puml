@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Album {
  +double duration
  -boolean quantity
  -long code
  +boolean amount
  #String name
  +setDuration()
  +calculateCreatedat()
  +deleteEmail()
}
abstract class User {
  +int score
  +Date total
  -double address
  #double status
  +validateDuration()
}
class Profile {
  #String note
  +int id
  +float description
  #String name
  -double total
  +calculateDuration()
  +updateScore()
  +calculatePhone()
}
class Comment {
  #long code
  #Date quantity
  +setEmail()
}
User --* Profile
User --o Album
@enduml