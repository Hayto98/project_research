@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Prescription {
  -boolean score
  -long active
  +setId()
  +cancelStatus()
  +updateDuration()
  +sendLevel()
}
class Treatment {
  -int updatedAt
  +float score
  -long address
  +findCreatedat()
  +cancelUpdatedat()
  +deleteAddress()
  +getUpdatedat()
}
class Hospital {
  #boolean address
  -long name
  +deleteCreatedat()
  +processUpdatedat()
  +findAddress()
  +deleteActive()
}
interface Appointment {
  -int active
  +double address
  #double code
  +createCode()
  +deleteScore()
  +calculatePrice()
  +validateAddress()
}
class MedicalRecord {
  #String active
  #Date quantity
  #String id
  -int score
  -float email
  +deleteQuantity()
  +createActive()
}
class Doctor {
  +double updatedAt
  #int note
  +double email
  #String active
  +validateEmail()
  +validateNote()
  +saveScore()
  +processDuration()
}
class Nurse {
  +boolean createdAt
  -int active
  #double total
  +setCreatedat()
  +validateNote()
  +cancelNote()
  +saveEmail()
}
Prescription --> MedicalRecord : "0..1"
Nurse --|> Doctor
Prescription --|> Doctor
Nurse ..|> Appointment
@enduml