@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Catalog {
  +int updatedAt
  #float type
  +sendNote()
  +calculateLevel()
}
interface Fine {
  #String updatedAt
  -int address
  -double createdAt
  +sendId()
}
abstract class Publisher {
  -boolean updatedAt
  +int note
  +double duration
  #boolean level
  #double phone
  +cancelUpdatedat()
  +findAddress()
  +deleteNote()
}
class Reservation {
  +int price
  #long name
  +double description
  +int active
  +getQuantity()
}
Publisher --* Catalog
Fine ..|> Catalog
Fine --o Publisher
@enduml