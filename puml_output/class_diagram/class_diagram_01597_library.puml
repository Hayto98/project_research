@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Catalog {
  +int updatedAt
  #float type
  +updateScore()
  +sendDescription()
}
class Fine {
  +long createdAt
  -boolean active
  +int id
  -double phone
  +processUpdatedat()
  +processPhone()
}
class Publisher {
  #boolean createdAt
  #double code
  -Date price
  +getId()
  +createPrice()
}
class Reservation {
  #long active
  +double code
  +int updatedAt
  +cancelTotal()
}
Fine ..|> Reservation
Fine --> Catalog : "0..1"
Reservation ..> Publisher : "1..*"
note right of Catalog : Library domain
@enduml