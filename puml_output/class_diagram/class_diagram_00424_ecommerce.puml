@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Wishlist {
  -String updatedAt
  +String duration
  +calculateNote()
  +sendDescription()
  +deleteCreatedat()
  +cancelScore()
}
class Invoice {
  +long quantity
  #double phone
  #double amount
  +processQuantity()
}
abstract class Order {
  #boolean price
  #float code
  -double level
  +calculateTotal()
}
class Customer {
  -long total
  -float score
  +boolean code
  +String email
  +boolean quantity
  +createType()
}
class Coupon {
  -Date email
  #long price
  +validateUpdatedat()
  +getName()
}
class Supplier {
  #boolean id
  -double name
  -float level
  -int score
  +getActive()
  +saveName()
  +findDescription()
}
class Review {
  -int name
  -Date amount
  -boolean updatedAt
  +double status
  +sendActive()
  +calculateTotal()
  +validateAddress()
}
Customer --> Supplier : "0..1"
Wishlist --> Coupon : "1"
Wishlist --* Supplier
Coupon --o Customer
Invoice --* Customer
Review ..> Coupon : "1..*"
@enduml