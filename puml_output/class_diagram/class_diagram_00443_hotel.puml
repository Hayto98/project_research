@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
interface CheckIn {
  +double status
  +boolean note
  #boolean price
  +cancelPrice()
  +sendCode()
}
abstract class Reservation {
  -long createdAt
  -long description
  #long total
  +Date email
  +validatePrice()
}
class Booking {
  #boolean phone
  -Date address
  #double status
  #boolean active
  -float duration
  +updateScore()
}
class Room {
  #boolean note
  #int address
  -String status
  +findCode()
  +cancelNote()
  +cancelDescription()
}
class Housekeeping {
  -double updatedAt
  +boolean email
  #String note
  +updatePhone()
}
interface CheckOut {
  -double status
  #float email
  +calculatePrice()
}
class Service {
  -int id
  -long phone
  -int updatedAt
  +updateStatus()
}
Booking --* CheckOut
Housekeeping --* CheckOut
CheckOut --|> CheckIn
Reservation --o Service
@enduml