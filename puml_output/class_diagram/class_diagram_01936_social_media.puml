@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
abstract class Follower {
  +long status
  -String phone
  +processLevel()
}
class Hashtag {
  +double createdAt
  #int description
  #Date id
  -String level
  #boolean updatedAt
  +updateActive()
}
class Post {
  +float address
  +Date email
  +processCode()
  +deleteQuantity()
  +sendId()
}
class Album {
  +Date price
  #float total
  +cancelAmount()
  +cancelScore()
  +createDescription()
}
class Message {
  +long address
  #double duration
  +long description
  +double id
  +calculateCode()
  +sendId()
  +calculatePrice()
}
abstract class Profile {
  #long note
  +boolean active
  #String description
  +updateUpdatedat()
}
class Like {
  #int createdAt
  #float updatedAt
  #float total
  #int address
  -long active
  +findUpdatedat()
  +getUpdatedat()
  +getDuration()
}
Like --> Album : "*"
Message --|> Profile
Like --> Hashtag : "0..1"
Message ..|> Post
Profile ..|> Message
@enduml