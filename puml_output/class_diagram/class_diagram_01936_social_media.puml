@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
abstract class Follower {
  +long status
  -String phone
  +calculateStatus()
}
abstract class Hashtag {
  #int description
  +double id
  #int duration
  +setLevel()
  +cancelStatus()
  +getName()
}
class Post {
  +String email
  +Date updatedAt
  +String createdAt
  -double phone
  +findPhone()
}
interface Album {
  -float active
  +String phone
  +long address
  +deleteQuantity()
  +setType()
  +createPrice()
  +updateScore()
}
abstract class Message {
  #long note
  +boolean active
  #String description
  +setUpdatedat()
}
abstract class Profile {
  -Date updatedAt
  +boolean total
  #float address
  +calculateQuantity()
  +findPhone()
}
interface Like {
  #int type
  #long duration
  +Date score
  #int code
  -Date description
  +sendCode()
  +getId()
  +processAddress()
  +calculateAmount()
}
Post ..|> Message
Like ..> Post : "1..*"
Like --> Follower : "1"
Profile --|> Message
note right of Follower : Social Media domain
@enduml