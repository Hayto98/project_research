@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Album {
  -long description
  -int score
  -long name
  #String active
  -float updatedAt
  +sendId()
  +deleteQuantity()
}
class Profile {
  #long amount
  #long address
  +updatePrice()
  +sendCreatedat()
  +calculateDuration()
  +createCode()
}
interface Group {
  #int createdAt
  -double active
  +validateEmail()
  +validateId()
}
class Message {
  -Date description
  -long note
  +String amount
  +int type
  #int code
  +saveUpdatedat()
}
class User {
  -Date level
  #Date status
  #boolean price
  -boolean name
  -double quantity
  +getQuantity()
  +processEmail()
  +saveNote()
  +setNote()
}
interface Follower {
  #float quantity
  -double type
  #int id
  +updateAmount()
  +processCreatedat()
  +updateUpdatedat()
  +createTotal()
}
class Notification {
  +double description
  #int level
  +calculateStatus()
  +createDuration()
  +getQuantity()
  +calculateUpdatedat()
}
Profile --* Notification
Follower ..> Profile : "0..1"
Message --> Album : "*"
note right of Album : Social Media domain
@enduml