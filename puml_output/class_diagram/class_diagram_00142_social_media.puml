@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Album {
  -long description
  -int score
  -long name
  #String active
  -float updatedAt
  +calculateActive()
  +updateActive()
}
class Profile {
  -boolean code
  -boolean level
  -float duration
  -int amount
  +updateNote()
  +calculateNote()
  +processLevel()
  +getDescription()
}
interface Group {
  #boolean code
  +long active
  -int status
  -float createdAt
  +saveCreatedat()
  +updateDuration()
  +getType()
}
abstract class Message {
  -String note
  -Date amount
  -long score
  +sendTotal()
}
class User {
  +float amount
  #boolean name
  -boolean updatedAt
  +saveName()
}
interface Follower {
  #Date quantity
  #boolean phone
  +calculateActive()
  +calculateName()
  +processTotal()
  +saveStatus()
}
class Notification {
  -boolean note
  +Date email
  #Date duration
  -float status
  +processAddress()
  +createNote()
  +cancelTotal()
  +getQuantity()
}
Message ..|> Follower
Message ..|> Profile
Profile --* Notification
Message --|> Group
@enduml