@startuml
skinparam shadowing true
interface Statement {
  -long note
  #Date phone
  #int createdAt
  +updatePhone()
  +createPhone()
}
class Teller {
  #String status
  +boolean createdAt
  +setCode()
  +cancelCreatedat()
  +validateStatus()
}
abstract class Loan {
  #int quantity
  +Date name
  +validateDuration()
  +deleteDescription()
  +findAmount()
  +calculateDuration()
}
class Withdrawal {
  -long level
  +boolean name
  -long active
  +int status
  +sendEmail()
  +findLevel()
}
Loan --o Teller
Withdrawal --o Teller
note right of Statement : Banking domain
@enduml