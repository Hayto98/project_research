@startuml
skinparam shadowing true
interface Statement {
  -long note
  #Date phone
  #int createdAt
  +processDuration()
  +deleteCode()
}
class Teller {
  #String code
  +boolean status
  -String level
  +boolean createdAt
  +calculateName()
  +createPhone()
}
abstract class Loan {
  #int quantity
  +Date name
  +findLevel()
  +validateDuration()
  +deleteDescription()
  +createCreatedat()
}
class Withdrawal {
  #String price
  #float updatedAt
  #String phone
  +findCreatedat()
  +saveNote()
  +createStatus()
  +validateScore()
}
Statement ..|> Withdrawal
Loan --> Withdrawal : "0..1"
Loan --o Teller
@enduml