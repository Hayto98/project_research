@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Supplier {
  -int updatedAt
  +int status
  +long code
  +cancelStatus()
  +createDescription()
}
class Review {
  +long createdAt
  +String email
  +boolean address
  -boolean code
  +calculateName()
  +deletePhone()
  +getActive()
}
interface Warehouse {
  +float updatedAt
  -boolean active
  +boolean description
  +validateScore()
  +createQuantity()
  +getName()
  +createAddress()
}
abstract class Return {
  #boolean score
  #int name
  #String createdAt
  #Date total
  +double address
  +getNote()
}
class Cart {
  -int createdAt
  -float name
  #double amount
  +findCode()
}
Review --> Warehouse : "1"
Return ..> Cart : "1"
Supplier --* Return
@enduml