@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Supplier {
  -int updatedAt
  +int status
  +long code
  +setActive()
  +deleteAddress()
}
class Review {
  +String address
  +boolean code
  -boolean level
  -long phone
  +updateActive()
  +cancelLevel()
}
class Warehouse {
  +boolean address
  #double level
  +createCode()
  +calculateTotal()
  +sendName()
}
class Return {
  -float address
  #boolean level
  #String updatedAt
  -String status
  +int name
  +saveLevel()
}
class Cart {
  -Date updatedAt
  +long email
  #Date total
  +double code
  #double phone
  +getTotal()
}
Review --|> Return
Cart --* Review
note right of Supplier : Ecommerce domain
@enduml