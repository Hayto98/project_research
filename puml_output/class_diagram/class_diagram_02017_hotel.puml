@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
abstract class Guest {
  -String phone
  +double total
  -String score
  +calculateScore()
  +saveScore()
}
class Staff {
  +int duration
  +int address
  -long active
  -long level
  +calculateNote()
  +validateId()
}
interface Amenity {
  -Date active
  +int note
  +findDescription()
  +validatePrice()
  +createUpdatedat()
  +processCreatedat()
}
class CheckIn {
  +double quantity
  -float note
  +findPhone()
}
abstract class Service {
  +boolean updatedAt
  +String code
  +String note
  +cancelTotal()
}
CheckIn --|> Service
Service --> CheckIn : "1"
note right of Guest : Hotel domain
@enduml