@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
abstract class Guest {
  -String phone
  +double total
  -String score
  +sendDescription()
  +getAddress()
}
interface Staff {
  +int quantity
  +int address
  -long active
  -long level
  +calculateQuantity()
  +createName()
}
class Amenity {
  +Date active
  #double score
  +cancelName()
  +sendId()
  +findAddress()
  +processPhone()
}
interface CheckIn {
  -int description
  -Date address
  +long price
  -String quantity
  -double updatedAt
  +cancelDescription()
}
class Service {
  #float description
  +String updatedAt
  +String code
  +boolean note
  -float id
  +validateUpdatedat()
  +cancelStatus()
}
Service --> CheckIn : "1"
Staff --> Service : "1..*"
Service ..|> Amenity
Amenity --> Staff : "*"
@enduml