@startuml
skinparam shadowing true
abstract class Staff {
  -float name
  -int updatedAt
  +double note
  -int phone
  +createDescription()
  +calculateId()
  +sendCode()
}
interface Housekeeping {
  +Date active
  #float quantity
  -int id
  +validateDuration()
}
interface Reservation {
  +int email
  +String quantity
  +deleteAddress()
  +cancelTotal()
}
class Guest {
  +Date address
  #String name
  +saveScore()
  +setNote()
  +validateNote()
}
Staff --|> Guest
Guest --o Housekeeping
@enduml