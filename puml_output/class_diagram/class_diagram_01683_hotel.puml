@startuml
skinparam shadowing true
abstract class Staff {
  -float name
  -int updatedAt
  +double note
  -int phone
  +sendName()
  +processDuration()
  +deleteActive()
}
class Housekeeping {
  +String id
  -Date phone
  +createQuantity()
}
class Reservation {
  +String status
  +boolean id
  +long createdAt
  +deleteName()
}
interface Guest {
  #boolean phone
  +int total
  +Date updatedAt
  -double status
  +cancelId()
  +findLevel()
  +calculateDuration()
  +createQuantity()
}
Housekeeping --|> Staff
Staff ..> Reservation : "1..*"
note right of Staff : Hotel domain
@enduml