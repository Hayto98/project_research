@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
interface Card {
  -Date phone
  -boolean name
  +long address
  -int code
  #String amount
  +validateLevel()
  +getPhone()
}
abstract class Teller {
  +String name
  +Date code
  +float score
  -double phone
  +processType()
}
interface Customer {
  -long quantity
  -float amount
  -long price
  +int total
  +deleteAmount()
  +updateDescription()
}
class Interest {
  +long level
  -boolean type
  +long note
  +Date score
  +savePrice()
  +validateScore()
}
class Loan {
  -long type
  #boolean status
  -float note
  #float duration
  +boolean active
  +getActive()
}
Customer --> Teller : "1"
Loan --o Card
@enduml