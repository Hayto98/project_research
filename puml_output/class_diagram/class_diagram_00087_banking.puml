@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
interface Card {
  -Date phone
  -boolean name
  +long address
  -int code
  #String amount
  +calculateType()
  +cancelEmail()
}
class Teller {
  +String score
  +Date phone
  +calculatePrice()
  +setPrice()
}
interface Customer {
  -long quantity
  -float amount
  -long price
  +int total
  +calculateCreatedat()
  +deleteDuration()
}
class Interest {
  #int note
  -int duration
  #Date id
  +boolean email
  -String price
  +processStatus()
  +processType()
  +processEmail()
  +validateActive()
}
abstract class Loan {
  #String level
  -int id
  +cancelStatus()
}
Loan ..|> Teller
Interest --|> Loan
Loan --> Customer : "*"
note right of Card : Banking domain
@enduml