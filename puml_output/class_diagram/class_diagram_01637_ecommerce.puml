@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Payment {
  +int id
  -Date description
  -long type
  #double email
  +boolean total
  +saveDuration()
  +getDuration()
  +getActive()
}
abstract class Order {
  -boolean amount
  -long code
  #Date email
  +deleteQuantity()
  +setTotal()
  +setPhone()
  +saveType()
}
abstract class Review {
  -boolean note
  -double score
  #boolean duration
  +String code
  +createAmount()
  +saveTotal()
}
class Product {
  -int total
  +int updatedAt
  -double code
  -String address
  +double id
  +validateStatus()
}
class Customer {
  -float amount
  #double quantity
  #String description
  +sendScore()
  +calculatePhone()
  +calculateDuration()
  +deleteQuantity()
}
interface Warehouse {
  -double updatedAt
  #Date type
  -long score
  +findCreatedat()
  +calculateQuantity()
  +setActive()
}
Payment --> Review : "1"
Warehouse --> Product : "*"
@enduml