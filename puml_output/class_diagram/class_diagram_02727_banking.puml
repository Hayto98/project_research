@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
interface Branch {
  +boolean price
  #String note
  +deleteNote()
  +validatePhone()
  +deleteAmount()
}
abstract class Account {
  +long phone
  -Date name
  -Date amount
  -Date duration
  +long status
  +processCode()
  +createAmount()
  +saveAmount()
  +validateCode()
}
class Deposit {
  #boolean type
  -boolean note
  +getStatus()
  +validateQuantity()
  +processAmount()
}
class Teller {
  +int price
  -long note
  -long description
  +boolean type
  +validatePhone()
  +validateTotal()
}
interface Customer {
  #long code
  +float total
  +cancelName()
  +findCode()
  +saveTotal()
}
abstract class Transfer {
  #float status
  -boolean phone
  -long updatedAt
  +String address
  #Date quantity
  +saveId()
}
class Statement {
  +long description
  +double note
  +Date level
  #Date email
  +findPhone()
}
Transfer --o Statement
Account ..|> Customer
Statement --> Customer : "1..*"
@enduml