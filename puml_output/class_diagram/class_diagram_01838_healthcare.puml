@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Ward {
  #boolean active
  -boolean createdAt
  +boolean phone
  +processQuantity()
}
class Prescription {
  +float updatedAt
  +int name
  +setLevel()
}
class Insurance {
  -boolean code
  +boolean quantity
  #String type
  +sendName()
  +sendQuantity()
  +processAmount()
  +sendId()
}
interface Patient {
  +float amount
  -String description
  +sendPrice()
  +calculateQuantity()
  +sendType()
}
interface LabTest {
  -double type
  +long id
  #int address
  #boolean duration
  -int quantity
  +validatePrice()
  +calculateType()
  +deleteId()
  +validateTotal()
}
class Treatment {
  -double address
  +String active
  -long quantity
  +sendName()
  +cancelAddress()
  +findName()
  +findCode()
}
LabTest --o Insurance
Insurance ..> Treatment : "*"
Insurance --|> Patient
Prescription ..> Patient : "*"
LabTest ..|> Treatment
@enduml