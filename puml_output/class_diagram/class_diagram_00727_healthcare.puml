@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
interface LabTest {
  +boolean name
  +double phone
  +Date level
  +sendType()
  +getType()
  +deleteNote()
}
class Treatment {
  #long email
  -boolean total
  #double amount
  #double code
  +setCreatedat()
  +createStatus()
}
class Diagnosis {
  #boolean amount
  -int description
  -int address
  +saveScore()
  +sendPhone()
  +createUpdatedat()
  +getAmount()
}
class Nurse {
  +String status
  +int address
  -int level
  #double description
  -boolean score
  +setActive()
  +updateType()
}
class Doctor {
  -String code
  #long email
  #String address
  #float total
  +Date active
  +processId()
  +setStatus()
  +createTotal()
}
Diagnosis --* LabTest
LabTest --* Treatment
Doctor ..> Diagnosis : "1..*"
Doctor --|> Treatment
@enduml