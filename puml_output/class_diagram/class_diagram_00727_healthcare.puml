@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
interface LabTest {
  +boolean name
  +double phone
  +Date level
  +setName()
  +validateAddress()
  +createTotal()
}
class Treatment {
  -boolean level
  #double email
  +updateScore()
  +validateCreatedat()
  +deleteDescription()
  +validateDuration()
}
class Diagnosis {
  -long price
  -boolean createdAt
  #Date active
  +processStatus()
}
class Nurse {
  +int description
  -int address
  #double createdAt
  -boolean status
  +deleteId()
  +findType()
}
class Doctor {
  +float address
  #long total
  #String level
  #float type
  +findAddress()
  +cancelStatus()
}
Doctor --|> Diagnosis
Diagnosis ..|> LabTest
Diagnosis ..> Doctor : "1..*"
Doctor --|> Treatment
note right of LabTest : Healthcare domain
@enduml