@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
interface Report {
  +Date address
  -Date description
  +sendActive()
}
interface Profile {
  +int quantity
  -int status
  -float level
  #String type
  -long total
  +deleteName()
  +processScore()
}
abstract class Message {
  #double price
  +double level
  +float updatedAt
  #String amount
  -float active
  +saveName()
  +updateScore()
  +sendDescription()
}
abstract class Follower {
  -int quantity
  #String code
  +long email
  -Date active
  -boolean duration
  +saveCreatedat()
  +cancelUpdatedat()
  +calculateScore()
}
abstract class Album {
  -boolean duration
  #long type
  +cancelCreatedat()
  +findAmount()
  +getQuantity()
  +calculateDuration()
}
class Story {
  #long status
  -String note
  #float email
  +float score
  +setDescription()
  +deleteCode()
}
abstract class Post {
  +Date updatedAt
  #float total
  #int code
  -float description
  #double type
  +processEmail()
  +sendTotal()
  +validateTotal()
}
Profile ..|> Report
Post --* Report
@enduml