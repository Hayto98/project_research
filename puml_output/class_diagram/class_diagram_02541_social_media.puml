@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
interface Hashtag {
  -long quantity
  +Date address
  #long amount
  #int active
  +saveId()
  +findAmount()
  +getDuration()
  +getCode()
}
interface Notification {
  +boolean active
  +long price
  #double address
  -double amount
  +getCreatedat()
  +createType()
  +setAddress()
}
class Story {
  -Date note
  +boolean type
  +String createdAt
  +deleteQuantity()
  +deletePhone()
}
interface Message {
  -boolean type
  #int email
  -Date createdAt
  -double code
  +boolean note
  +createScore()
  +findEmail()
  +cancelId()
}
Message --o Notification
Hashtag ..> Message : "1..*"
Message --> Hashtag : "*"
@enduml