@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
abstract class Warehouse {
  +String duration
  +int code
  #float email
  -float quantity
  #long price
  +deleteDescription()
  +calculateStatus()
}
class Customer {
  -long type
  +Date price
  +Date updatedAt
  +setCreatedat()
}
class Package {
  -boolean code
  #double level
  #long email
  -long id
  -int note
  +saveCode()
}
abstract class Driver {
  +String note
  -int level
  +double updatedAt
  -float phone
  #float createdAt
  +calculateStatus()
  +findQuantity()
}
interface Tracking {
  -int level
  #float amount
  +updatePhone()
}
class Vehicle {
  #double score
  +String name
  +getCreatedat()
}
class FuelLog {
  -long score
  -double description
  +saveEmail()
  +validatePhone()
  +deletePrice()
}
Customer ..|> Driver
Vehicle ..|> Warehouse
Vehicle ..|> Customer
Warehouse --* Package
@enduml