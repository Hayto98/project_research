@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Tracking {
  +double phone
  #boolean id
  #String createdAt
  +processNote()
  +calculateAmount()
}
class Shipment {
  +long quantity
  +String total
  #long amount
  +double code
  +deleteUpdatedat()
  +createId()
  +deleteEmail()
}
class Package {
  +String address
  +double total
  -float createdAt
  -int active
  +Date phone
  +processEmail()
  +calculateId()
  +sendQuantity()
}
abstract class Driver {
  #float duration
  #Date score
  -String createdAt
  #boolean type
  -long total
  +createNote()
  +findQuantity()
  +setStatus()
  +setCode()
}
class Customer {
  -long email
  -String name
  +updateUpdatedat()
}
interface Manifest {
  #boolean type
  -Date phone
  #int id
  +long amount
  #int active
  +findDuration()
  +createName()
  +deleteName()
}
abstract class Depot {
  -long duration
  -long id
  -float note
  +findTotal()
}
Manifest ..> Package : "*"
Driver --> Manifest : "1..*"
Manifest --> Driver : "*"
@enduml