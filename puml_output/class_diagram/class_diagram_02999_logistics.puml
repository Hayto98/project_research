@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Tracking {
  +double phone
  #boolean id
  #String createdAt
  +saveNote()
  +updatePhone()
}
class Shipment {
  +boolean amount
  -float code
  +double updatedAt
  -boolean email
  -double name
  +calculateCreatedat()
  +sendActive()
  +cancelDuration()
}
class Package {
  -long id
  -int createdAt
  +saveAddress()
}
interface Driver {
  -float active
  #Date type
  +processTotal()
  +findLevel()
}
class Customer {
  -long duration
  -long level
  +findCode()
}
class Manifest {
  +boolean name
  #String note
  +boolean email
  -double score
  +getAmount()
  +sendAmount()
  +cancelScore()
}
class Depot {
  +long updatedAt
  #double address
  -Date score
  +deleteDuration()
  +getLevel()
  +processType()
  +createPrice()
}
Driver ..|> Tracking
Manifest ..> Package : "*"
Driver --> Manifest : "1..*"
Manifest --> Driver : "*"
note right of Tracking : Logistics domain
@enduml