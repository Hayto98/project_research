@startuml
skinparam monochrome true
abstract class Card {
  #boolean price
  #long duration
  -long address
  -int quantity
  +validateNote()
}
class Withdrawal {
  #int id
  +long name
  +updateDescription()
  +validateAmount()
}
class Customer {
  +long active
  +long name
  +calculateName()
  +setType()
  +getNote()
  +sendName()
}
interface Transfer {
  #long address
  +String score
  +createDescription()
  +deleteLevel()
}
interface Branch {
  +String type
  #Date quantity
  #String description
  +cancelId()
  +calculateCode()
  +calculateEmail()
}
interface Teller {
  +String address
  -Date phone
  #int createdAt
  #int duration
  -String quantity
  +cancelName()
  +deletePrice()
  +processId()
}
Customer --> Withdrawal : "1"
Teller --> Transfer : "1..*"
@enduml