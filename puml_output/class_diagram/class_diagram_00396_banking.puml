@startuml
skinparam monochrome true
abstract class Card {
  #boolean price
  #long duration
  -long address
  -int quantity
  +updateQuantity()
}
class Withdrawal {
  +long name
  +int updatedAt
  +createId()
  +sendName()
  +updatePhone()
}
class Customer {
  -boolean type
  #String address
  -boolean description
  #long quantity
  +setDescription()
}
interface Transfer {
  +String type
  #Date quantity
  #String description
  +validatePrice()
  +getDuration()
  +processAddress()
}
class Branch {
  +double address
  #boolean quantity
  +boolean updatedAt
  +createName()
  +validateNote()
}
interface Teller {
  #float phone
  #String createdAt
  +sendQuantity()
  +setScore()
  +validateCode()
  +processNote()
}
Card ..|> Withdrawal
Withdrawal --o Card
Customer --* Transfer
Card --o Branch
note right of Card : Banking domain
@enduml