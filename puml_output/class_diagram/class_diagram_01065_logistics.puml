@startuml

class Route {
  -int code
  +float active
  +updateNote()
  +setTotal()
}
interface Warehouse {
  #boolean email
  #float updatedAt
  +double price
  +validatePrice()
  +updateStatus()
  +saveLevel()
  +updateId()
}
class Package {
  -String score
  #double active
  +findAddress()
  +createTotal()
  +deleteDescription()
}
class Shipment {
  +int phone
  -String type
  +deleteAddress()
}
class FuelLog {
  -String level
  #long name
  -String type
  #String quantity
  +getUpdatedat()
  +cancelScore()
  +processPrice()
  +updateDescription()
}
class Manifest {
  -float id
  #boolean phone
  -boolean createdAt
  +float code
  -int type
  +calculateNote()
  +processLevel()
  +sendPrice()
  +createType()
}
class DeliveryNote {
  -float email
  #Date id
  -String active
  +deleteAmount()
  +cancelTotal()
  +setDescription()
  +createDescription()
}
Package ..> Route : "0..1"
DeliveryNote --|> Package
Shipment ..|> FuelLog
FuelLog --|> Shipment
Warehouse --o Route
@enduml