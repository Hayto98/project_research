@startuml

class Route {
  -int code
  +float active
  +sendQuantity()
  +sendUpdatedat()
}
class Warehouse {
  -double price
  #int score
  #String description
  +sendActive()
}
class Package {
  -int level
  #boolean note
  +setPhone()
  +processName()
}
class Shipment {
  -float name
  #boolean code
  #String updatedAt
  -long address
  +setScore()
  +createTotal()
  +setActive()
  +setPrice()
}
class FuelLog {
  -int address
  +Date price
  #double id
  +cancelDuration()
  +validateLevel()
  +getPhone()
}
class Manifest {
  +boolean createdAt
  -float total
  #Date address
  -String amount
  -double email
  +setActive()
}
interface DeliveryNote {
  -boolean code
  +boolean createdAt
  -float phone
  +int name
  +processLevel()
}
Shipment --o Route
Route --> Warehouse : "0..1"
FuelLog --o Manifest
Route --|> Manifest
note right of Route : Logistics domain
@enduml