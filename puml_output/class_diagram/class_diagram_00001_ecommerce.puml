@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Supplier {
  #String amount
  #boolean address
  -Date quantity
  +double description
  +calculateCreatedat()
}
class Shipment {
  -String code
  +boolean total
  +getType()
  +deleteLevel()
  +saveName()
}
abstract class Category {
  -boolean type
  +boolean note
  #Date total
  +findPhone()
  +setName()
}
interface Coupon {
  +String total
  -double note
  #Date createdAt
  +calculatePhone()
  +findTotal()
  +validateActive()
  +getId()
}
interface Return {
  #Date type
  +float code
  +float email
  +getEmail()
  +setQuantity()
  +processLevel()
}
Shipment ..> Category : "1"
Category --> Coupon : "1"
Coupon --* Return
Shipment --* Return
@enduml