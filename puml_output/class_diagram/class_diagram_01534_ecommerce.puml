@startuml
skinparam ArrowColor #555555
class Shipment {
  #boolean score
  #Date active
  #double total
  #float email
  -String status
  +setName()
}
interface Cart {
  +String address
  #long type
  +Date level
  -boolean amount
  #boolean note
  +savePhone()
}
abstract class Warehouse {
  #float phone
  -String createdAt
  #boolean active
  +Date score
  +validateLevel()
}
class Return {
  -float description
  +boolean duration
  +long phone
  +findType()
}
abstract class Payment {
  -Date amount
  +int active
  +cancelName()
  +getEmail()
  +deleteUpdatedat()
  +sendCreatedat()
}
class Wishlist {
  -double description
  -String score
  +validateNote()
  +cancelEmail()
  +setCode()
  +processCode()
}
class Coupon {
  #float total
  #String status
  +cancelEmail()
  +updateDescription()
}
Payment ..|> Cart
Shipment ..> Cart : "*"
Wishlist --|> Payment
Return --> Payment : "0..1"
@enduml