@startuml
skinparam monochrome true
class Library {
  +float updatedAt
  +Date description
  +float total
  #boolean level
  +int address
  +getTotal()
  +sendStatus()
}
class Book {
  +boolean phone
  -float amount
  +findPhone()
  +findCode()
}
class Classroom {
  -boolean type
  -int price
  -String amount
  -double duration
  #boolean email
  +getPhone()
  +sendStatus()
  +createPhone()
  +sendCode()
}
interface Course {
  -float total
  +int name
  +setAddress()
  +cancelName()
  +setNote()
  +sendStatus()
}
class Attendance {
  #boolean id
  +int score
  +boolean createdAt
  -float total
  -float description
  +validateEmail()
  +setNote()
}
Attendance --* Library
Classroom ..|> Book
Book --|> Classroom
@enduml