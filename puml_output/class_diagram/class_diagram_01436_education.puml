@startuml
skinparam monochrome true
class Library {
  +float updatedAt
  +Date description
  +float total
  #boolean level
  +int address
  +updatePhone()
  +getPhone()
}
class Book {
  +long score
  +boolean quantity
  -double createdAt
  +saveAmount()
  +saveType()
  +createPrice()
  +sendNote()
}
class Classroom {
  #double name
  -float type
  +double total
  #String active
  +findName()
  +createId()
  +updateNote()
  +sendTotal()
}
class Course {
  #boolean id
  +int score
  +boolean createdAt
  -float total
  -float description
  +setTotal()
  +cancelScore()
}
interface Attendance {
  +float quantity
  +boolean email
  +updateDuration()
}
Attendance --|> Classroom
Book ..|> Course
Course --o Library
Classroom ..|> Library
note right of Library : Education domain
@enduml