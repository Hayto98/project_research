@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
abstract class Cart {
  -String code
  +int name
  -long amount
  +deleteStatus()
}
class Shipment {
  -float price
  +boolean name
  -Date active
  +updateQuantity()
  +saveAmount()
  +findPhone()
  +processId()
}
class Invoice {
  -double status
  -float amount
  -float name
  +getId()
  +saveName()
  +saveStatus()
  +setDuration()
}
class Wishlist {
  #int phone
  #float type
  -String updatedAt
  -boolean address
  +cancelDuration()
}
Wishlist --* Cart
Wishlist --> Invoice : "*"
Shipment --|> Invoice
note right of Cart : Ecommerce domain
@enduml