@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
abstract class Cart {
  -String code
  +int name
  -long amount
  +saveAddress()
}
class Shipment {
  #double updatedAt
  +boolean price
  -Date name
  +updateDescription()
  +cancelPrice()
  +createQuantity()
  +processScore()
}
class Invoice {
  +int type
  +long id
  -float phone
  -float amount
  +findType()
  +cancelPrice()
  +findLevel()
  +deleteTotal()
}
abstract class Wishlist {
  #Date id
  +String name
  +validateAddress()
}
Wishlist --* Cart
Shipment --o Invoice
Cart --> Shipment : "1"
@enduml