@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
abstract class Tracking {
  #String total
  #int description
  +float quantity
  #float address
  -String id
  +getType()
}
class Customer {
  +long address
  #float total
  +String active
  +updateTotal()
  +createNote()
  +setTotal()
  +calculateCode()
}
class Driver {
  -double description
  -String email
  +findEmail()
  +getUpdatedat()
}
abstract class Warehouse {
  #double amount
  -float note
  +boolean duration
  +calculateStatus()
  +getQuantity()
  +processEmail()
}
Warehouse --o Tracking
Tracking ..> Driver : "1"
Tracking ..> Warehouse : "1"
@enduml