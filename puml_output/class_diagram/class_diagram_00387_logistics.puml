@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
abstract class Tracking {
  #String total
  #int description
  +float quantity
  #float address
  -String id
  +setCreatedat()
}
class Customer {
  #float total
  +String active
  #boolean amount
  #double address
  +createPrice()
  +findEmail()
  +getDescription()
}
class Driver {
  -boolean price
  #float note
  #float code
  +int amount
  +findAmount()
  +findNote()
  +createCreatedat()
  +sendQuantity()
}
interface Warehouse {
  #Date note
  +float id
  +int duration
  #boolean name
  +saveTotal()
}
Driver ..|> Customer
Tracking --> Warehouse : "0..1"
note right of Tracking : Logistics domain
@enduml