@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Like {
  #Date description
  +Date level
  +calculateAddress()
  +cancelName()
  +findUpdatedat()
}
class Comment {
  -Date score
  -double id
  #long price
  +float type
  +int updatedAt
  +calculateNote()
  +findScore()
  +updateEmail()
}
class Follower {
  -String quantity
  +float level
  +float updatedAt
  -int note
  +deleteEmail()
  +findLevel()
  +sendId()
}
class Group {
  #String level
  #float type
  +cancelStatus()
  +cancelPhone()
  +processPhone()
  +findDuration()
}
abstract class Hashtag {
  #float id
  +String updatedAt
  +double active
  #String phone
  -int description
  +cancelCode()
  +createNote()
}
class Album {
  #boolean code
  +float name
  -String duration
  +validateId()
}
Follower ..|> Like
Group ..> Hashtag : "*"
Comment --o Group
@enduml