@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
interface CheckIn {
  #long status
  #String email
  +long address
  -int code
  #String level
  +cancelCode()
}
class Invoice {
  -long total
  #float amount
  +int duration
  -double code
  +processUpdatedat()
  +calculateCode()
  +validateAmount()
}
interface Payment {
  +double level
  +int description
  -int code
  #int id
  +long quantity
  +createLevel()
  +saveNote()
}
class Booking {
  #long price
  #float type
  #int score
  #boolean active
  #Date quantity
  +deleteAmount()
  +saveAmount()
}
interface Guest {
  -boolean phone
  -long price
  -String note
  -long total
  -float address
  +cancelDuration()
  +findCode()
  +saveTotal()
  +deleteAddress()
}
interface Housekeeping {
  +double updatedAt
  -double level
  -int address
  -String price
  +String code
  +processQuantity()
  +sendAmount()
}
class Restaurant {
  +String quantity
  +boolean code
  +updateNote()
}
CheckIn ..> Guest : "1"
Invoice ..|> Guest
CheckIn --|> Payment
Payment --> CheckIn : "0..1"
Guest --> Payment : "0..1"
Invoice ..> Payment : "1"
@enduml