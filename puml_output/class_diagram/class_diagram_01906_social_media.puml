@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
abstract class Hashtag {
  +Date quantity
  -String price
  #float status
  -double code
  +saveLevel()
  +setId()
  +updateLevel()
  +getPrice()
}
class Comment {
  -float score
  #boolean level
  -Date status
  #int updatedAt
  +cancelType()
  +setId()
  +getType()
  +deleteCode()
}
class Group {
  -double phone
  -Date score
  -Date email
  -String address
  -String createdAt
  +updateId()
  +deletePhone()
  +saveDescription()
}
abstract class User {
  -float price
  -double type
  #long createdAt
  -float description
  -double address
  +cancelName()
  +calculateActive()
}
class Notification {
  +Date amount
  #double createdAt
  -double id
  +calculateAddress()
  +sendNote()
  +processPrice()
  +setNote()
}
Group --* Hashtag
Notification ..> Hashtag : "1"
Comment --* Group
Hashtag ..|> Group
@enduml