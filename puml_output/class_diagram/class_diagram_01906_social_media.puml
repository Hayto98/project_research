@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
abstract class Hashtag {
  +Date quantity
  -String price
  #float status
  -double code
  +cancelQuantity()
  +deletePhone()
  +sendLevel()
  +setLevel()
}
class Comment {
  -long level
  #float price
  -long createdAt
  #long note
  #Date code
  +updateTotal()
  +processTotal()
  +saveQuantity()
}
class Group {
  -Date total
  #double name
  +calculateType()
  +saveCreatedat()
  +deleteActive()
  +cancelAddress()
}
class User {
  -int note
  #boolean address
  +boolean email
  #int duration
  +updateId()
  +getDuration()
}
abstract class Notification {
  +double price
  #float total
  -String amount
  -boolean updatedAt
  +saveId()
}
Group --|> Notification
Group --o Comment
note right of Hashtag : Social Media domain
@enduml