@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
interface Staff {
  #boolean description
  +double name
  -float phone
  -Date code
  +deleteType()
  +getTotal()
}
interface Amenity {
  -int id
  #Date phone
  -boolean email
  +setName()
  +sendCode()
  +sendType()
}
class Room {
  #double duration
  -int note
  #double email
  +createTotal()
  +findTotal()
  +findTotal()
}
class Housekeeping {
  -double createdAt
  +String id
  +calculateScore()
}
Room --|> Housekeeping
Amenity --* Housekeeping
Room --o Staff
note right of Staff : Hotel domain
@enduml