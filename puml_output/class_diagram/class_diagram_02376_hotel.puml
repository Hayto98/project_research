@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
interface Staff {
  #boolean description
  +double name
  -float phone
  -Date code
  +setType()
  +cancelLevel()
}
abstract class Amenity {
  +String total
  -long score
  +findId()
  +setScore()
  +setCode()
  +calculateCreatedat()
}
interface Room {
  #double code
  -int name
  #double active
  -Date duration
  +createDuration()
  +getEmail()
  +setId()
  +cancelQuantity()
}
class Housekeeping {
  +int total
  +float duration
  -double level
  +String email
  +calculateCode()
}
Room --|> Housekeeping
Amenity --* Housekeeping
Room --o Staff
@enduml