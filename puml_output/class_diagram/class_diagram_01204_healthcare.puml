@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
interface Nurse {
  #Date duration
  -long id
  +int note
  #double price
  +sendPhone()
  +processDuration()
}
class Insurance {
  -String updatedAt
  -String type
  -String duration
  +int amount
  +deleteStatus()
  +createTotal()
}
class Prescription {
  -long updatedAt
  -boolean price
  -int duration
  +getQuantity()
  +getStatus()
  +updatePrice()
  +findCode()
}
class Hospital {
  -boolean type
  -boolean code
  -String id
  -boolean phone
  #long level
  +findPrice()
  +sendId()
  +cancelNote()
}
Prescription --> Insurance : "*"
Insurance --> Hospital : "0..1"
Insurance --o Prescription
@enduml