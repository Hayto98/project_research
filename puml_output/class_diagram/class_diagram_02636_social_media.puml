@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
interface Comment {
  -boolean price
  +boolean name
  +cancelPrice()
}
class Follower {
  -Date description
  -double active
  +cancelCode()
  +createAmount()
  +findDuration()
}
class Like {
  +float updatedAt
  -boolean description
  +findName()
  +setId()
  +calculateStatus()
}
interface User {
  #long score
  +int duration
  -Date quantity
  #Date level
  #Date id
  +validateDescription()
  +deleteDuration()
}
class Report {
  #String level
  -float updatedAt
  -long status
  -String amount
  +int createdAt
  +processTotal()
  +deleteTotal()
  +updatePrice()
}
class Hashtag {
  -float type
  #float email
  +createLevel()
  +processScore()
  +processQuantity()
}
abstract class Message {
  -String status
  -Date description
  #int type
  +int createdAt
  +findCode()
}
Comment ..> User : "*"
User ..> Message : "1..*"
Like ..> User : "*"
@enduml