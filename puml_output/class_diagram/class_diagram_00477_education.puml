@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
interface Schedule {
  #double phone
  +int duration
  +String updatedAt
  +Date status
  #int email
  +validateDescription()
  +updateId()
  +processAmount()
  +saveCreatedat()
}
interface Library {
  -long quantity
  -float active
  +calculateUpdatedat()
}
interface Book {
  #double email
  +String active
  +long id
  #String address
  -boolean name
  +getTotal()
  +saveCode()
  +validatePhone()
}
abstract class Enrollment {
  #String level
  #Date total
  +createEmail()
  +createPrice()
}
class Student {
  #String description
  #boolean createdAt
  +long address
  #boolean updatedAt
  +saveNote()
  +sendType()
  +setId()
}
interface Course {
  #double code
  #String type
  +deleteId()
  +validateScore()
  +findEmail()
  +deleteUpdatedat()
}
Schedule ..> Library : "1"
Student ..|> Course
@enduml