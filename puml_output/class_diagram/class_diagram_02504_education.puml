@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Assignment {
  #long status
  #Date total
  -int level
  +saveStatus()
}
abstract class Exam {
  +double active
  -int level
  -String total
  -Date updatedAt
  +processDescription()
}
interface Grade {
  +boolean note
  -boolean active
  +Date duration
  -long phone
  +cancelStatus()
  +createType()
  +createDuration()
}
class Student {
  #double id
  #float duration
  +Date type
  #int code
  +setPhone()
  +sendStatus()
}
class Teacher {
  +Date price
  #int amount
  +getPhone()
  +deletePrice()
  +setDescription()
  +cancelPrice()
}
class Library {
  -Date amount
  +int note
  #float phone
  +Date status
  +createCreatedat()
  +findQuantity()
  +updateUpdatedat()
  +calculateTotal()
}
class Course {
  -double duration
  -double status
  +double description
  #double quantity
  +saveUpdatedat()
  +sendEmail()
  +calculateAddress()
  +getDuration()
}
Teacher --> Library : "0..1"
Grade --o Library
Course --> Assignment : "1..*"
note right of Assignment : Education domain
@enduml