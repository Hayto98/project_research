@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Story {
  -float amount
  +float email
  +calculateQuantity()
  +createQuantity()
}
class Message {
  #Date active
  +float createdAt
  +float email
  +deleteLevel()
  +processScore()
  +saveType()
  +saveDuration()
}
class Post {
  +float score
  #String id
  +double updatedAt
  +saveCreatedat()
  +processPrice()
  +getActive()
  +getCreatedat()
}
interface User {
  +Date name
  #Date score
  +long price
  +boolean code
  +findNote()
  +findPhone()
  +createEmail()
}
abstract class Comment {
  +boolean price
  -double note
  #float id
  +double total
  -double active
  +getNote()
  +validateDuration()
  +calculateUpdatedat()
  +cancelNote()
}
class Like {
  #double level
  -boolean code
  #double email
  +processType()
  +setDuration()
  +getAmount()
}
class Profile {
  #String duration
  #Date amount
  +int email
  -long quantity
  #double note
  +findLevel()
  +deleteStatus()
  +cancelPhone()
}
Message ..|> User
Story --* User
Comment --|> Like
Comment --> User : "1"
Story ..> Post : "1"
note right of Story : Social Media domain
@enduml