@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Story {
  -float amount
  +float email
  +updateAmount()
  +processPhone()
}
abstract class Message {
  #int email
  #Date quantity
  #long phone
  #Date amount
  +saveStatus()
}
class Post {
  +float amount
  #boolean level
  +int type
  +float score
  #String phone
  +deletePrice()
}
abstract class User {
  #String type
  +boolean price
  #float name
  +processQuantity()
  +calculateType()
  +calculatePrice()
}
abstract class Comment {
  -int createdAt
  #Date status
  +updateId()
  +calculateAmount()
  +calculateStatus()
}
class Like {
  -String email
  #float price
  #double total
  -int level
  +saveAmount()
  +cancelScore()
  +updateCreatedat()
  +processScore()
}
class Profile {
  -float quantity
  #double type
  +boolean total
  -long name
  #int note
  +findCreatedat()
}
Post --> Comment : "*"
Like --> Comment : "1..*"
User --|> Profile
Comment ..|> Story
Message --> User : "0..1"
@enduml