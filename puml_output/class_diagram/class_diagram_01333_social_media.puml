@startuml
skinparam monochrome true
skinparam shadowing true
abstract class Album {
  #Date type
  +Date description
  -String note
  +createAddress()
  +getCreatedat()
  +updateNote()
  +calculateAddress()
}
class Profile {
  -double description
  -double id
  +calculateEmail()
  +getActive()
}
class Hashtag {
  -Date description
  +Date quantity
  #boolean updatedAt
  +Date type
  +createUpdatedat()
  +cancelQuantity()
}
class Message {
  -int active
  +Date name
  +String type
  +validateId()
  +processUpdatedat()
  +saveStatus()
}
abstract class Notification {
  -float quantity
  +float duration
  #int id
  -double name
  -String total
  +deleteStatus()
  +validateId()
  +deleteTotal()
}
class Post {
  #float status
  #int quantity
  +double duration
  +boolean price
  #float note
  +deleteAmount()
}
Message ..> Album : "0..1"
Profile ..> Hashtag : "*"
note right of Album : Social Media domain
@enduml