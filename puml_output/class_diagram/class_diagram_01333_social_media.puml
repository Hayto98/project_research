@startuml
skinparam monochrome true
skinparam shadowing true
abstract class Album {
  #Date type
  +Date description
  -String note
  +processAddress()
  +createId()
  +validateAmount()
  +createTotal()
}
class Profile {
  -double createdAt
  -float updatedAt
  +cancelTotal()
  +getEmail()
  +updateActive()
}
class Hashtag {
  +Date note
  #Date price
  +Date updatedAt
  -int level
  -int email
  +deleteName()
  +createTotal()
  +getType()
  +sendDuration()
}
interface Message {
  +boolean description
  #long quantity
  +validateStatus()
  +calculateActive()
}
interface Notification {
  -int active
  +Date name
  +String type
  +findQuantity()
  +sendTotal()
  +createNote()
}
abstract class Post {
  -float status
  -String total
  +double note
  +processAddress()
  +validatePhone()
  +saveStatus()
  +sendPrice()
}
Hashtag --* Message
Album ..|> Hashtag
Post --* Album
@enduml