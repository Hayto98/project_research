@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Statement {
  #boolean id
  -double total
  #Date level
  +findCreatedat()
  +validateStatus()
  +createAddress()
}
interface Transfer {
  #boolean total
  -int score
  +sendAmount()
}
class Teller {
  -long address
  -double amount
  +double duration
  +getUpdatedat()
  +sendTotal()
  +deleteName()
  +cancelCode()
}
abstract class Account {
  +String createdAt
  -float address
  -int active
  +createActive()
}
class Customer {
  #boolean total
  #String createdAt
  +getTotal()
  +processAmount()
  +cancelAmount()
  +sendStatus()
}
class Branch {
  +double score
  #float description
  #double name
  +double type
  +deleteDescription()
  +cancelCreatedat()
  +getStatus()
}
class Loan {
  +Date total
  +long address
  #boolean active
  -String duration
  #double quantity
  +sendDescription()
  +deleteAmount()
  +findDuration()
}
Statement --* Branch
Teller --> Customer : "*"
Branch --> Teller : "0..1"
@enduml