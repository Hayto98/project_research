@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Card {
  #String note
  #long phone
  +setDescription()
  +saveEmail()
  +cancelDescription()
}
class Beneficiary {
  -boolean address
  #boolean code
  #String phone
  #float amount
  +sendNote()
}
interface Withdrawal {
  -double duration
  +Date quantity
  -long updatedAt
  +int phone
  +double id
  +processPhone()
  +processLevel()
}
abstract class Transfer {
  -int name
  +double code
  +float price
  +long address
  +int status
  +saveLevel()
  +cancelLevel()
  +updateEmail()
}
Transfer ..|> Beneficiary
Card --* Beneficiary
note right of Card : Banking domain
@enduml