@startuml
skinparam monochrome true
skinparam defaultFontSize 13
abstract class Hospital {
  #String level
  -long amount
  -String updatedAt
  +int email
  -int price
  +calculateName()
  +deleteNote()
  +calculateScore()
  +saveTotal()
}
interface Diagnosis {
  #Date code
  #Date active
  #long total
  +double quantity
  +sendDescription()
}
interface Billing {
  +String active
  #Date type
  #String level
  +saveCode()
  +getEmail()
}
class Prescription {
  #boolean email
  -double total
  #long score
  #long address
  +boolean id
  +cancelDuration()
  +setCreatedat()
  +updateId()
  +processTotal()
}
class Ward {
  #long amount
  -boolean updatedAt
  +boolean email
  +cancelDuration()
}
Prescription --|> Ward
Billing --* Prescription
note right of Hospital : Healthcare domain
@enduml