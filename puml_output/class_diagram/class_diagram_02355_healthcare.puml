@startuml
skinparam monochrome true
skinparam defaultFontSize 13
abstract class Hospital {
  #String level
  -long amount
  -String updatedAt
  +int email
  -int price
  +saveName()
  +saveEmail()
  +deleteScore()
  +createName()
}
abstract class Diagnosis {
  -boolean active
  #boolean address
  #Date code
  -int duration
  -String total
  +updateQuantity()
  +sendPrice()
}
interface Billing {
  +String active
  #Date type
  #String level
  +updateAddress()
  +saveUpdatedat()
}
class Prescription {
  -float email
  #long status
  +calculateDuration()
  +setEmail()
  +cancelTotal()
  +getPrice()
}
interface Ward {
  #double note
  #boolean email
  +int active
  +String phone
  -double updatedAt
  +setLevel()
  +findTotal()
}
Diagnosis --* Ward
Ward --o Billing
Ward --> Diagnosis : "1"
Ward --o Hospital
@enduml