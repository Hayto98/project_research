@startuml
skinparam monochrome true
abstract class Loan {
  #String quantity
  #Date description
  +findAddress()
}
class Librarian {
  #long status
  +double name
  +Date duration
  #String createdAt
  #Date note
  +setLevel()
  +validateQuantity()
  +cancelCreatedat()
}
class Shelf {
  #long id
  +long phone
  +float createdAt
  +setDuration()
  +getName()
  +calculatePrice()
  +getActive()
}
class Renewal {
  +Date price
  -double updatedAt
  +Date note
  -String level
  +validateEmail()
  +cancelAddress()
}
abstract class Fine {
  +double description
  +float status
  +boolean name
  #Date amount
  +savePrice()
}
Renewal ..|> Loan
Renewal ..> Fine : "0..1"
Loan ..> Fine : "*"
@enduml