@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
abstract class Guest {
  #long duration
  -float active
  #boolean level
  #int updatedAt
  +deletePrice()
  +processPhone()
  +processNote()
  +deleteCreatedat()
}
class Reservation {
  #Date createdAt
  -Date name
  -boolean duration
  #String active
  +sendCode()
  +calculateTotal()
  +cancelCode()
}
class Room {
  #float score
  #int quantity
  +int address
  -Date id
  +long name
  +cancelCreatedat()
  +updateEmail()
  +processPhone()
}
class Restaurant {
  #int updatedAt
  -float status
  +sendId()
}
class Housekeeping {
  -long code
  #long name
  -Date total
  +int duration
  +calculateType()
  +findDescription()
  +findAmount()
}
class Service {
  +boolean description
  -String amount
  +int quantity
  +deleteUpdatedat()
}
Reservation --o Room
Guest ..> Service : "1..*"
@enduml