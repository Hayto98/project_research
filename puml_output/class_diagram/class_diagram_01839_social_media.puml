@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Report {
  -int type
  +int description
  +processCode()
  +setDuration()
  +createLevel()
  +updateCreatedat()
}
interface Story {
  -double duration
  -int price
  #long description
  +double note
  +updateDuration()
}
abstract class Follower {
  #String updatedAt
  #int createdAt
  +setActive()
  +processAmount()
  +cancelStatus()
  +updatePhone()
}
class Album {
  -float email
  +long id
  #double quantity
  -long total
  +validateAmount()
  +sendName()
  +deleteEmail()
}
interface Post {
  #Date note
  -double description
  +boolean level
  #long updatedAt
  +saveDescription()
  +sendId()
}
Album --* Story
Post --|> Album
@enduml