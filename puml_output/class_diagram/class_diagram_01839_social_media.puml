@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Report {
  -int type
  +int description
  +getActive()
  +createDuration()
  +findPrice()
  +deleteScore()
}
abstract class Story {
  +double type
  +String duration
  -float description
  #float email
  +updateCreatedat()
}
interface Follower {
  -float score
  +String createdAt
  +createEmail()
}
class Album {
  #double total
  -long type
  #Date amount
  #long phone
  +processDuration()
  +validateNote()
  +deleteDescription()
}
class Post {
  +float price
  -int description
  -Date quantity
  #boolean updatedAt
  #boolean createdAt
  +setDescription()
  +validateCreatedat()
  +createTotal()
  +findAddress()
}
Story ..> Album : "1"
Story --> Post : "1"
Follower --> Report : "0..1"
note right of Report : Social Media domain
@enduml