@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Reservation {
  +float price
  #String updatedAt
  #long createdAt
  +String active
  +long code
  +calculateDuration()
}
class Restaurant {
  +int phone
  #Date duration
  #Date amount
  +calculateActive()
  +validateDuration()
  +processLevel()
}
class CheckOut {
  #float address
  +float active
  -float type
  +String description
  +updateNote()
}
class Staff {
  -long duration
  -Date active
  +cancelType()
  +createCode()
}
class Amenity {
  #float quantity
  -Date duration
  +boolean type
  #float address
  +saveCreatedat()
}
interface Room {
  +int address
  #float createdAt
  #long amount
  +cancelTotal()
}
Restaurant --|> Amenity
Staff ..|> Reservation
Room --> Restaurant : "0..1"
Restaurant --* Staff
@enduml