@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Like {
  #int createdAt
  #long id
  -long code
  +long score
  +double updatedAt
  +cancelStatus()
  +calculateDuration()
}
interface Follower {
  -String email
  +int level
  -double updatedAt
  +double active
  -double type
  +calculateLevel()
  +savePrice()
  +findLevel()
}
class Message {
  +float name
  +long description
  +validateTotal()
  +calculateId()
  +sendType()
  +cancelScore()
}
class Profile {
  +String address
  -double status
  -boolean description
  -double score
  +processId()
  +getName()
}
Message ..|> Profile
Message ..|> Follower
Like ..> Message : "1..*"
@enduml