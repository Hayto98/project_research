@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Like {
  #int createdAt
  #long id
  -long code
  +long score
  +double updatedAt
  +setScore()
  +cancelNote()
}
class Follower {
  +String active
  +double type
  -String email
  +validateTotal()
  +validateLevel()
  +getName()
  +saveName()
}
class Message {
  -Date code
  +Date phone
  +sendQuantity()
  +validateStatus()
}
class Profile {
  -long description
  #float status
  -double price
  +cancelActive()
  +createQuantity()
}
Message ..|> Follower
Like ..> Message : "1..*"
note right of Like : Social Media domain
@enduml