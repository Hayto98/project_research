@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Driver {
  +Date status
  #int amount
  +String description
  -boolean address
  #int duration
  +getCreatedat()
  +createScore()
  +calculateTotal()
}
class Warehouse {
  -boolean score
  +long createdAt
  -long level
  -Date amount
  +getCode()
  +cancelDescription()
  +savePhone()
}
class Shipment {
  +String createdAt
  -int level
  +cancelQuantity()
}
class Customer {
  -double status
  +boolean updatedAt
  +cancelActive()
  +createDuration()
}
abstract class Vehicle {
  +double description
  -int total
  #double name
  #String amount
  +calculateName()
  +findPrice()
  +updateStatus()
}
class Tracking {
  #int quantity
  -String email
  #boolean total
  #boolean type
  +setUpdatedat()
  +updateName()
}
Driver ..> Warehouse : "*"
Vehicle --> Tracking : "0..1"
Warehouse --* Shipment
Vehicle --* Customer
Shipment ..> Warehouse : "*"
@enduml