@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Driver {
  +Date status
  #int amount
  +String description
  -boolean address
  #int duration
  +sendUpdatedat()
  +setPhone()
  +saveScore()
}
class Warehouse {
  +long amount
  -long note
  -Date score
  +cancelName()
  +deleteStatus()
  +updateLevel()
}
class Shipment {
  +double email
  +boolean description
  +setUpdatedat()
}
class Customer {
  -Date status
  +double level
  #String updatedAt
  +float price
  +double active
  +updateLevel()
  +calculateActive()
  +getDuration()
}
class Vehicle {
  #long active
  -double updatedAt
  #double code
  #int address
  +setLevel()
  +sendLevel()
  +cancelCreatedat()
  +getStatus()
}
abstract class Tracking {
  #boolean createdAt
  #int price
  +findPhone()
  +createLevel()
}
Shipment ..|> Tracking
Tracking --> Customer : "0..1"
Driver --o Customer
Shipment ..|> Vehicle
note right of Driver : Logistics domain
@enduml