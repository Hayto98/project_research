@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
abstract class Grade {
  +double id
  +Date status
  +int address
  #Date score
  -Date note
  +createScore()
  +saveQuantity()
  +validateDescription()
}
class Student {
  -long score
  #boolean status
  +createScore()
  +setCode()
}
abstract class Book {
  #Date id
  #int duration
  +processDescription()
  +updateEmail()
  +setCreatedat()
}
class Classroom {
  -double type
  -String amount
  +getCode()
}
Book --o Student
Student ..> Grade : "0..1"
@enduml