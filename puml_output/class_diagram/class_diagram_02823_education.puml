@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
abstract class Grade {
  +double id
  +Date status
  +int address
  #Date score
  -Date note
  +updateDescription()
  +deleteName()
  +sendStatus()
}
class Student {
  #float level
  -float active
  #String description
  +String updatedAt
  +cancelQuantity()
  +createTotal()
}
class Book {
  -double type
  -String amount
  +cancelName()
}
class Classroom {
  #int total
  +String description
  +String code
  +Date createdAt
  +setLevel()
  +findDuration()
  +updateAddress()
}
Grade --|> Student
Book --> Student : "0..1"
note right of Grade : Education domain
@enduml