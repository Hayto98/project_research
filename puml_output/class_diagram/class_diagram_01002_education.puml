@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Enrollment {
  #boolean code
  +Date type
  #int score
  #boolean total
  #String quantity
  +getStatus()
  +updateTotal()
}
interface Book {
  -Date total
  +long quantity
  -long type
  -Date score
  -boolean amount
  +cancelCode()
  +sendType()
}
class Course {
  +int duration
  #String id
  +setUpdatedat()
  +updateEmail()
  +saveDuration()
  +saveEmail()
}
class Assignment {
  #String note
  -double description
  +long status
  -Date type
  #double createdAt
  +getUpdatedat()
  +setActive()
  +setId()
}
class Teacher {
  -Date level
  #Date quantity
  +boolean active
  +saveTotal()
  +deleteNote()
  +deleteAddress()
  +sendDescription()
}
class Schedule {
  -long total
  +Date updatedAt
  #int note
  +saveEmail()
  +getType()
  +calculatePrice()
}
Teacher ..|> Enrollment
Teacher ..|> Book
Enrollment --> Course : "1..*"
@enduml