@startuml

interface Inventory {
  +boolean email
  -long status
  -float quantity
  +int createdAt
  #long score
  +getActive()
  +processPhone()
  +calculateStatus()
  +sendName()
}
class Warehouse {
  +String code
  #int active
  -long duration
  +setActive()
  +deleteScore()
  +validateLevel()
}
abstract class Vehicle {
  +int address
  #String description
  +saveActive()
  +updateEmail()
  +processCreatedat()
  +createLevel()
}
class Tracking {
  -Date active
  -double score
  -long note
  +double address
  +getName()
}
class Route {
  -double updatedAt
  -float type
  -String code
  +processQuantity()
  +processDuration()
  +saveNote()
  +cancelQuantity()
}
Vehicle --o Inventory
Route --* Vehicle
Route --> Inventory : "1..*"
@enduml