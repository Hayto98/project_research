@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
interface Doctor {
  #Date quantity
  #long duration
  +boolean phone
  +String id
  +cancelId()
  +processName()
  +createPhone()
}
class Appointment {
  #String active
  #int email
  #String name
  -long createdAt
  +cancelActive()
}
interface LabTest {
  +double email
  -int description
  +deleteQuantity()
}
abstract class Billing {
  -long description
  +float address
  -String email
  -double id
  +processPrice()
  +updateDuration()
  +sendId()
  +sendAmount()
}
LabTest ..|> Billing
@enduml