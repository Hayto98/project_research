@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
interface Doctor {
  #Date quantity
  #long duration
  +boolean phone
  +String id
  +validateId()
  +setCode()
  +validateActive()
}
class Appointment {
  +Date createdAt
  +Date level
  +createQuantity()
}
class LabTest {
  +double email
  -int description
  +setType()
}
interface Billing {
  -long description
  +float address
  -String email
  -double id
  +updateId()
  +updateScore()
  +deleteAddress()
  +findUpdatedat()
}
Billing ..> LabTest : "1"
Doctor --o Appointment
LabTest --* Doctor
note right of Doctor : Healthcare domain
@enduml