@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Library {
  #int total
  +int code
  +Date email
  +float quantity
  +cancelQuantity()
  +getDuration()
  +findName()
  +updatePhone()
}
class Enrollment {
  -String createdAt
  #boolean active
  +Date price
  +int status
  +sendStatus()
  +getUpdatedat()
}
interface Classroom {
  +float total
  +float level
  -float type
  -double score
  +Date address
  +sendDuration()
}
class Department {
  +double score
  #double type
  -float email
  +cancelDuration()
  +cancelUpdatedat()
  +validateScore()
  +createName()
}
class Teacher {
  #boolean description
  -float active
  +float duration
  #long total
  +boolean score
  +validateName()
  +sendAmount()
  +updateId()
  +deleteActive()
}
Teacher ..> Department : "1..*"
Department ..|> Enrollment
@enduml