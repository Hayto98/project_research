@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
abstract class Payment {
  -int level
  -Date name
  +createLevel()
  +cancelActive()
  +validateId()
}
abstract class Staff {
  -double createdAt
  #float type
  -float code
  #boolean price
  +float level
  +setEmail()
}
class Restaurant {
  +int code
  #Date score
  #Date name
  +String phone
  #int status
  +getNote()
  +saveUpdatedat()
}
abstract class Booking {
  +float type
  -boolean updatedAt
  +updateQuantity()
  +createTotal()
}
Booking --* Staff
Payment --|> Restaurant
Staff ..|> Booking
@enduml