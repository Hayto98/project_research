@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
abstract class Payment {
  -int level
  -Date name
  +findLevel()
  +setTotal()
  +processCreatedat()
}
abstract class Staff {
  -double duration
  -boolean price
  +saveDuration()
  +getStatus()
  +validateQuantity()
  +sendPrice()
}
class Restaurant {
  +int phone
  #Date status
  +getActive()
}
class Booking {
  +double quantity
  +float type
  +float active
  +sendAmount()
  +findEmail()
  +processPhone()
  +createName()
}
Staff ..|> Booking
Restaurant ..> Staff : "*"
note right of Payment : Hotel domain
@enduml