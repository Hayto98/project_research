@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
interface Manifest {
  +Date active
  -float updatedAt
  #int description
  +String amount
  +setCode()
}
abstract class Warehouse {
  #float duration
  #Date status
  +String active
  +deleteNote()
}
class Route {
  -Date total
  -float duration
  +boolean description
  +int phone
  +boolean active
  +getActive()
  +deleteType()
  +validateNote()
  +findQuantity()
}
abstract class Customer {
  -boolean description
  -String quantity
  +boolean id
  -Date phone
  #double name
  +updateScore()
  +setActive()
  +saveScore()
}
Route --|> Manifest
Warehouse --|> Manifest
@enduml