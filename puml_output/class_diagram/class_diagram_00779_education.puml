@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Student {
  +String address
  +String duration
  #double status
  #Date amount
  -String updatedAt
  +sendActive()
  +calculateTotal()
}
abstract class Classroom {
  #boolean updatedAt
  -String email
  +int total
  #long id
  -Date status
  +updateScore()
  +processEmail()
  +deleteActive()
  +deleteName()
}
class Exam {
  #double level
  +int code
  #Date name
  #boolean email
  +validateQuantity()
}
class Course {
  #long status
  -float id
  #long phone
  +sendAmount()
  +savePrice()
  +deleteNote()
}
class Department {
  #float level
  +double note
  +long total
  -double code
  +float description
  +saveQuantity()
  +getNote()
  +validateTotal()
}
class Enrollment {
  -int id
  -Date address
  #float createdAt
  #double note
  +getId()
  +processType()
}
interface Assignment {
  -Date amount
  -Date phone
  +saveName()
  +deleteName()
  +updateLevel()
}
Assignment --|> Student
Exam --|> Classroom
note right of Student : Education domain
@enduml