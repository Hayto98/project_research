@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Student {
  +String address
  +String duration
  #double status
  #Date amount
  -String updatedAt
  +createUpdatedat()
  +findPrice()
}
abstract class Classroom {
  +float note
  #boolean total
  +boolean updatedAt
  #long email
  +String level
  +createDescription()
  +createQuantity()
}
abstract class Exam {
  #int createdAt
  +long score
  -boolean type
  +String email
  -boolean description
  +validateId()
  +findAddress()
  +validatePrice()
  +sendUpdatedat()
}
interface Course {
  +boolean phone
  #boolean quantity
  +updateName()
  +updateActive()
}
class Department {
  #double price
  +double quantity
  +Date email
  -boolean amount
  +saveDescription()
  +setNote()
  +getLevel()
  +createCreatedat()
}
class Enrollment {
  -Date amount
  -String quantity
  -long phone
  -int type
  #long createdAt
  +sendType()
}
class Assignment {
  -Date note
  #float email
  #double updatedAt
  +calculateType()
  +processName()
}
Course --> Assignment : "1"
Assignment ..|> Enrollment
@enduml