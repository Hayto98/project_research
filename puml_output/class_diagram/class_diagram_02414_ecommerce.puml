@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Cart {
  -boolean description
  +boolean phone
  -boolean total
  #int duration
  +calculateId()
  +createPrice()
  +sendTotal()
}
class Payment {
  -Date active
  #Date total
  -Date quantity
  -boolean phone
  +deleteNote()
}
abstract class Shipment {
  +int amount
  #String code
  #String email
  -boolean duration
  +double id
  +setNote()
}
class Invoice {
  -int createdAt
  #float email
  +getDescription()
  +createTotal()
  +setQuantity()
  +getStatus()
}
interface Return {
  +long code
  -Date status
  +createStatus()
  +findPrice()
  +createDescription()
}
Shipment ..> Return : "*"
Cart ..|> Return
Payment ..|> Return
Shipment ..|> Payment
@enduml