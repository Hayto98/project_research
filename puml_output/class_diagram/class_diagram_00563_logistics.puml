@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Inventory {
  #int total
  #boolean price
  +boolean code
  +updateUpdatedat()
  +deleteCode()
  +cancelId()
}
abstract class Vehicle {
  -long updatedAt
  +double note
  -int name
  +String quantity
  +long price
  +findPrice()
}
class Manifest {
  #long type
  +Date status
  +validateCode()
  +findDuration()
  +updateName()
  +updateCreatedat()
}
class Depot {
  -double type
  -long updatedAt
  #int price
  +int createdAt
  +createType()
  +getLevel()
  +findDescription()
}
interface Route {
  #Date note
  -int updatedAt
  +double address
  #long amount
  +getActive()
  +setDuration()
}
Route --o Manifest
Inventory --o Vehicle
Manifest --o Inventory
Depot --o Vehicle
note right of Inventory : Logistics domain
@enduml