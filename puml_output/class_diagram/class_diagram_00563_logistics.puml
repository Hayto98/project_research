@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Inventory {
  #int total
  #boolean price
  +boolean code
  +processDuration()
  +deleteScore()
  +getType()
}
interface Vehicle {
  +double type
  +long total
  +sendPhone()
  +createAmount()
  +updatePrice()
  +calculateCode()
}
abstract class Manifest {
  -String id
  #double name
  #Date level
  +processName()
}
abstract class Depot {
  #float quantity
  -long updatedAt
  +saveDescription()
}
interface Route {
  -float name
  #Date createdAt
  -double level
  +createPrice()
  +processNote()
}
Depot --o Route
Manifest --|> Vehicle
@enduml