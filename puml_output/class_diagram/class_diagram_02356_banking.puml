@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Card {
  -boolean createdAt
  #int description
  +String code
  +validateAddress()
}
interface Statement {
  #boolean price
  +long type
  +boolean code
  #boolean level
  +String duration
  +createId()
  +getDuration()
  +findStatus()
  +deleteCreatedat()
}
class Account {
  +String description
  +long email
  #Date code
  +double address
  +deleteType()
  +createTotal()
  +processDescription()
}
class Beneficiary {
  #int level
  -float type
  +float email
  +processQuantity()
  +deleteId()
  +calculateName()
}
class Transaction {
  -int note
  #float active
  #String name
  +double code
  +sendCode()
}
Statement ..> Card : "*"
Account --|> Beneficiary
note right of Card : Banking domain
@enduml