@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Card {
  -boolean createdAt
  #int description
  +String code
  +calculateCreatedat()
}
class Statement {
  #boolean price
  +long type
  +boolean code
  #boolean level
  +String duration
  +processDescription()
  +setName()
  +sendTotal()
  +deleteDescription()
}
class Account {
  #int createdAt
  #float address
  -boolean quantity
  +getQuantity()
}
class Beneficiary {
  -boolean code
  #float updatedAt
  +deletePrice()
  +sendAddress()
}
class Transaction {
  +boolean quantity
  -long total
  #int note
  -float description
  +float duration
  +cancelQuantity()
  +cancelAddress()
  +validateLevel()
}
Card --|> Beneficiary
Account --o Transaction
@enduml