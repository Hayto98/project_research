@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
interface Library {
  +String quantity
  +long updatedAt
  +setStatus()
  +saveScore()
}
class Exam {
  #float name
  -long phone
  +calculatePrice()
  +createCreatedat()
  +createStatus()
  +cancelAddress()
}
class Attendance {
  +float level
  #Date status
  #boolean description
  #boolean email
  #double total
  +setActive()
  +findTotal()
  +findNote()
  +sendDuration()
}
class Student {
  #String total
  #boolean email
  -float id
  +updateEmail()
}
abstract class Enrollment {
  -boolean amount
  +Date email
  -boolean note
  -int level
  +String address
  +getAddress()
}
Attendance --o Library
Student --|> Enrollment
@enduml