@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
interface Library {
  +String quantity
  +long updatedAt
  +setPhone()
  +setStatus()
}
class Exam {
  #int score
  #long phone
  +float address
  -boolean price
  +deleteEmail()
}
abstract class Attendance {
  #double level
  #float duration
  +setAddress()
  +deleteTotal()
  +createId()
  +saveName()
}
interface Student {
  +long status
  -long total
  #boolean level
  -double note
  +savePhone()
  +sendPrice()
}
class Enrollment {
  -float id
  -String name
  -long total
  +processTotal()
}
Exam --o Library
Attendance --|> Exam
note right of Library : Education domain
@enduml