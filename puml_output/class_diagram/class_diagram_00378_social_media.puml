@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Follower {
  #double phone
  -long total
  -String createdAt
  +sendId()
  +updateLevel()
}
interface Notification {
  #double address
  #float description
  -float total
  +createId()
  +updateCode()
}
class Post {
  +long updatedAt
  #float active
  -long price
  -float status
  +updateStatus()
  +cancelId()
  +processPrice()
}
class Comment {
  +float type
  +String updatedAt
  -long active
  +String createdAt
  +findType()
}
Follower ..|> Comment
Post --> Comment : "1..*"
@enduml