@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Follower {
  #double phone
  -long total
  -String createdAt
  +updateQuantity()
  +sendCreatedat()
}
class Notification {
  #float total
  -float score
  #int duration
  +createUpdatedat()
  +sendPrice()
}
class Post {
  -float email
  -int address
  -int quantity
  +createType()
  +updateActive()
}
class Comment {
  -long status
  +String duration
  +updateName()
}
Notification --> Comment : "1..*"
Comment --|> Post
note right of Follower : Social Media domain
@enduml