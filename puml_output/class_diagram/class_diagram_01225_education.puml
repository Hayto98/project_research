@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
abstract class Grade {
  -String score
  +float updatedAt
  +String id
  -boolean duration
  +sendLevel()
  +cancelType()
}
class Department {
  -int address
  +Date note
  +float updatedAt
  #boolean id
  +deleteDescription()
}
interface Attendance {
  +double status
  -long level
  -float price
  +long type
  +deleteCreatedat()
  +createName()
  +sendActive()
  +setLevel()
}
interface Classroom {
  #long active
  #String name
  #Date note
  +float address
  +createAmount()
  +deleteCode()
}
class Course {
  +boolean code
  +int id
  +String type
  #String description
  +getTotal()
}
class Library {
  #double score
  #boolean email
  -float phone
  -long updatedAt
  +createAmount()
  +getType()
  +findActive()
}
class Teacher {
  -double quantity
  +String active
  +validateDuration()
  +setTotal()
  +validateUpdatedat()
  +cancelQuantity()
}
Grade --* Attendance
Department --o Course
note right of Grade : Education domain
@enduml