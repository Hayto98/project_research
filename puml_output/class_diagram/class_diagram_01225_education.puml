@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
abstract class Grade {
  -String score
  +float updatedAt
  +String id
  -boolean duration
  +updateNote()
  +setCode()
}
interface Department {
  +String id
  -int active
  +Date email
  +float address
  #boolean note
  +sendLevel()
}
class Attendance {
  #double level
  #double phone
  +double status
  +processDescription()
  +getAddress()
  +updateCode()
}
class Classroom {
  -String score
  #boolean price
  +boolean description
  #long createdAt
  +createName()
}
class Course {
  -int level
  +String code
  +long duration
  #float updatedAt
  +cancelTotal()
}
abstract class Library {
  +String createdAt
  #String status
  #String duration
  +updateEmail()
}
class Teacher {
  #double score
  #boolean email
  -float phone
  -long updatedAt
  +processDescription()
  +calculateAddress()
  +processCode()
}
Library ..|> Course
Library --* Grade
Course --o Classroom
Teacher --|> Grade
Classroom --> Attendance : "1"
@enduml