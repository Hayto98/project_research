@startuml
skinparam defaultFontSize 13
class Nurse {
  #boolean type
  #long score
  +cancelEmail()
}
class Ward {
  #boolean level
  -Date quantity
  -Date type
  #String active
  #float description
  +setDescription()
}
class Prescription {
  -long duration
  +boolean name
  -int id
  +createDescription()
  +cancelPhone()
  +setQuantity()
}
class Doctor {
  #String updatedAt
  #Date createdAt
  -double status
  -int code
  +Date name
  +setCode()
}
class LabTest {
  #double address
  -String level
  #boolean duration
  +findId()
  +findPrice()
  +updateQuantity()
  +updatePrice()
}
class Treatment {
  +String active
  +String quantity
  +Date level
  +updateTotal()
  +validateAmount()
  +cancelDuration()
  +deleteTotal()
}
class Insurance {
  #String note
  #boolean updatedAt
  +String total
  +double address
  +processEmail()
}
Insurance --o LabTest
LabTest --|> Prescription
note right of Nurse : Healthcare domain
@enduml