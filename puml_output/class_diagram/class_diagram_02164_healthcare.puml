@startuml
skinparam defaultFontSize 13
class Nurse {
  #boolean type
  #long score
  +getQuantity()
}
class Ward {
  -double type
  #Date level
  +createType()
  +setPhone()
}
class Prescription {
  +int status
  #String name
  +long code
  -int description
  +validateCode()
  +cancelId()
  +deleteName()
  +getEmail()
}
interface Doctor {
  #int code
  +float quantity
  +String updatedAt
  +boolean type
  +createLevel()
}
class LabTest {
  +Date note
  +Date createdAt
  +long updatedAt
  #long code
  #double active
  +cancelStatus()
  +processScore()
  +findUpdatedat()
}
interface Treatment {
  -String id
  #Date price
  +boolean updatedAt
  -long quantity
  +String score
  +updatePrice()
}
class Insurance {
  -String updatedAt
  #long total
  -int address
  -float amount
  -boolean description
  +getAmount()
}
Ward ..|> Nurse
Doctor --o Nurse
Prescription --> Nurse : "*"
LabTest --|> Prescription
Treatment --* Ward
@enduml