@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
interface Teller {
  -double name
  -String updatedAt
  +updateCreatedat()
  +findName()
}
class Beneficiary {
  -boolean note
  -String type
  +float status
  -int price
  +validatePrice()
  +saveStatus()
  +findCreatedat()
}
class Card {
  +int status
  -int address
  +findLevel()
  +setName()
}
class Withdrawal {
  -double status
  +Date email
  -float code
  +int id
  +int address
  +findTotal()
  +updateCode()
}
abstract class Loan {
  +double price
  +long total
  #Date status
  #Date address
  +cancelActive()
  +processPhone()
  +setPrice()
  +getTotal()
}
class Customer {
  -Date level
  #long createdAt
  #String description
  +Date active
  -boolean updatedAt
  +deleteUpdatedat()
}
interface Account {
  +long active
  #long note
  +double quantity
  +createNote()
  +validatePrice()
}
Teller --|> Loan
Account --* Beneficiary
Withdrawal --* Account
Beneficiary --|> Customer
note right of Teller : Banking domain
@enduml