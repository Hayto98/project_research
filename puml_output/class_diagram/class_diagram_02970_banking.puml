@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
interface Teller {
  -double name
  -String updatedAt
  +saveNote()
  +getTotal()
}
class Beneficiary {
  +double address
  -boolean note
  -String type
  +getName()
}
class Card {
  -Date active
  +Date quantity
  #int phone
  +calculateId()
  +updateUpdatedat()
}
class Withdrawal {
  #int updatedAt
  #boolean address
  +float amount
  +setActive()
}
class Loan {
  -double status
  +Date email
  -float code
  +int id
  +int address
  +findType()
  +updateId()
}
abstract class Customer {
  -Date code
  -String type
  #Date quantity
  +createPhone()
  +sendScore()
  +setLevel()
}
class Account {
  #Date level
  -String active
  -String note
  -Date phone
  #Date code
  +findLevel()
  +saveTotal()
}
Loan --* Beneficiary
Customer --* Loan
Loan --|> Teller
@enduml