@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
abstract class Comment {
  -int updatedAt
  +double duration
  +long level
  #Date status
  +createPhone()
}
interface Report {
  +int description
  #Date price
  -double quantity
  +int phone
  +sendActive()
  +validateCode()
  +updateTotal()
}
class Notification {
  +int email
  +String score
  +createUpdatedat()
  +setDuration()
}
class Profile {
  #String amount
  -long active
  -boolean type
  +processQuantity()
  +saveTotal()
  +validatePhone()
}
class Album {
  #float phone
  +Date total
  +setActive()
}
class User {
  +Date phone
  #String level
  +boolean code
  -float total
  +int quantity
  +updateType()
  +processAddress()
  +validateQuantity()
}
Comment --|> Notification
Notification ..> Album : "*"
Profile --o Album
note right of Comment : Social Media domain
@enduml