@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Book {
  #Date email
  +Date amount
  +float address
  +Date quantity
  #Date phone
  +validateType()
  +processNote()
  +findId()
  +validateQuantity()
}
abstract class Department {
  -Date status
  -int code
  -Date createdAt
  +Date email
  +float updatedAt
  +saveActive()
  +deleteName()
  +createDescription()
  +createAmount()
}
class Enrollment {
  -long code
  +int type
  +int active
  -long id
  +processCreatedat()
}
interface Schedule {
  +boolean email
  +boolean price
  +createPhone()
  +setPrice()
  +calculateQuantity()
  +createActive()
}
class Grade {
  -boolean price
  +int code
  +getStatus()
  +createPrice()
  +processCode()
}
class Library {
  +long id
  #float note
  -Date duration
  -int name
  -float type
  +processScore()
  +createPhone()
  +deleteAmount()
  +createId()
}
abstract class Assignment {
  +boolean code
  +long name
  +boolean address
  +findType()
  +processStatus()
}
Book ..> Schedule : "0..1"
Schedule --|> Enrollment
Grade ..|> Book
Assignment ..> Enrollment : "0..1"
Enrollment --> Schedule : "0..1"
note right of Book : Education domain
@enduml