@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Shelf {
  +int description
  #long type
  +double createdAt
  #int id
  +Date note
  +validateNote()
}
class Author {
  +long type
  -double description
  -Date price
  +Date id
  +saveCreatedat()
}
class Fine {
  +int id
  -double type
  -int address
  #double email
  +validateCode()
}
class Book {
  +boolean amount
  +int price
  +int name
  -boolean description
  -String status
  +validateActive()
  +findAmount()
}
interface Librarian {
  +boolean updatedAt
  #boolean score
  +float phone
  -Date name
  +long code
  +deleteUpdatedat()
}
Librarian --> Fine : "0..1"
Fine ..> Shelf : "1..*"
Author --|> Book
@enduml