@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Shelf {
  +int description
  #long type
  +double createdAt
  #int id
  +Date note
  +updateAmount()
}
class Author {
  -double description
  -Date price
  +Date id
  #String score
  -long quantity
  +getType()
  +saveAddress()
  +cancelEmail()
}
class Fine {
  +Date address
  -String note
  +Date quantity
  +processAmount()
  +calculateName()
}
class Book {
  +int amount
  +int score
  +sendType()
  +setCreatedat()
  +cancelTotal()
}
interface Librarian {
  +boolean updatedAt
  #boolean score
  +float phone
  -Date name
  +long code
  +cancelPrice()
}
Librarian --> Fine : "0..1"
Fine ..> Shelf : "1..*"
Author --|> Book
Fine --> Book : "0..1"
note right of Shelf : Library domain
@enduml