@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Hashtag {
  -int type
  -String address
  +boolean code
  +createCreatedat()
}
abstract class Notification {
  #double total
  +boolean name
  +sendDescription()
  +calculateCode()
  +findPrice()
}
class Story {
  -boolean createdAt
  +boolean score
  -double code
  #long duration
  +calculateScore()
  +validateNote()
  +updateStatus()
}
class Post {
  +float name
  #float quantity
  #double total
  +updateAddress()
  +calculateType()
}
class User {
  +Date note
  #double score
  +Date type
  +sendType()
}
Hashtag ..> User : "1..*"
Story --> Post : "1"
note right of Hashtag : Social Media domain
@enduml