@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Hashtag {
  -int type
  -String address
  +boolean code
  +validateAmount()
}
class Notification {
  #long name
  #float total
  +double duration
  +Date note
  -String code
  +getTotal()
  +updateScore()
  +findLevel()
}
interface Story {
  #int createdAt
  #double address
  +sendPrice()
  +processDescription()
  +calculatePhone()
  +getPhone()
}
interface Post {
  +float note
  +long createdAt
  -int status
  #float address
  +getActive()
  +cancelNote()
  +deleteAddress()
  +calculateName()
}
abstract class User {
  #float createdAt
  #double description
  +Date note
  +boolean type
  -double updatedAt
  +updateDuration()
}
Story --|> Hashtag
Story --> Post : "1"
Post ..> Hashtag : "1..*"
Hashtag --o Notification
@enduml