@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Grade {
  #float quantity
  #double phone
  +double price
  +createName()
  +processScore()
  +cancelLevel()
  +getPrice()
}
interface Department {
  #boolean name
  -String createdAt
  +float code
  -Date quantity
  +String price
  +processDescription()
}
interface Enrollment {
  #double updatedAt
  #long createdAt
  +validatePrice()
}
class Library {
  -Date amount
  #long type
  #boolean level
  #double code
  +findDuration()
}
Enrollment --o Grade
Grade ..> Department : "*"
Library ..|> Department
@enduml