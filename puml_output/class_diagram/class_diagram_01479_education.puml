@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Grade {
  #float quantity
  #double phone
  +double price
  +processLevel()
  +processName()
  +saveCreatedat()
  +setQuantity()
}
abstract class Department {
  +long code
  #String amount
  +float email
  +boolean id
  -boolean status
  +cancelScore()
  +setUpdatedat()
  +validateAmount()
}
abstract class Enrollment {
  +boolean code
  #long quantity
  -String email
  -String active
  -float total
  +calculateType()
  +deleteId()
  +processType()
  +saveAddress()
}
abstract class Library {
  -String createdAt
  #Date updatedAt
  -Date total
  +deleteQuantity()
  +calculateName()
  +validateActive()
  +calculateDescription()
}
Grade --> Enrollment : "1..*"
Enrollment --> Grade : "1"
Department --|> Grade
note right of Grade : Education domain
@enduml