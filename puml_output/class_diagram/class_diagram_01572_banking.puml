@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Interest {
  -long amount
  #float description
  -boolean level
  +long id
  +int status
  +deleteLevel()
  +calculateAmount()
}
class Transfer {
  +float address
  -double id
  +Date createdAt
  -boolean phone
  -long updatedAt
  +validateDuration()
  +findPrice()
  +processNote()
  +setAddress()
}
abstract class Account {
  -float total
  -boolean active
  -int status
  +boolean description
  +processEmail()
  +createEmail()
}
abstract class Teller {
  +boolean note
  -float price
  +createEmail()
  +sendLevel()
  +cancelDescription()
  +validateActive()
}
abstract class Customer {
  +String code
  #String createdAt
  +double duration
  #float email
  +cancelScore()
  +saveEmail()
  +calculateEmail()
}
interface Beneficiary {
  -double active
  -String name
  -String status
  #Date total
  +Date price
  +deleteTotal()
  +processLevel()
  +processQuantity()
}
Customer --o Transfer
Customer --|> Account
@enduml