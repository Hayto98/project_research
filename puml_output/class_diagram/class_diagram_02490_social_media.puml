@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
abstract class Album {
  #String updatedAt
  +String duration
  +double price
  -int quantity
  +float name
  +createQuantity()
}
class Notification {
  -float phone
  #long active
  #float address
  -Date price
  #double description
  +saveEmail()
  +getCode()
}
abstract class Comment {
  #Date quantity
  #long email
  #int amount
  +String status
