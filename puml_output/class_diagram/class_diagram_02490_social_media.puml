}
abstract class Like {
  #boolean status
  -Date address
  +updateDescription()
  +deleteUpdatedat()
  +getCreatedat()
}
class Profile {
  +double price
  #boolean updatedAt
  -String phone
  +updateEmail()
  +findCreatedat()
  +findPrice()
}
class Hashtag {
  +float duration
  #int score
  +Date description
  +sendNote()
  +cancelCode()
