@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Invoice {
  -boolean status
  +int note
  -boolean amount
  +processPrice()
  +createType()
}
abstract class Cart {
  +String type
  +boolean description
  #long note
  +cancelCode()
  +processAmount()
}
abstract class Wishlist {
  #double createdAt
  +long quantity
  #String amount
  +setStatus()
  +sendCode()
  +findPrice()
  +findAddress()
}
interface Review {
  +String duration
  #float description
  +createCode()
  +deletePrice()
}
interface Shipment {
  +boolean duration
  #String score
  +deleteAddress()
  +cancelAddress()
  +getDescription()
}
class Return {
  +String type
  #Date quantity
  +Date amount
  +validateName()
  +createAddress()
  +getAddress()
}
Wishlist --o Shipment
Invoice --* Shipment
@enduml