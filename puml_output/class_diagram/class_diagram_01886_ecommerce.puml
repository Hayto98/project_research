@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Invoice {
  -boolean status
  +int note
  -boolean amount
  +updatePrice()
  +cancelAmount()
}
abstract class Cart {
  +boolean note
  #long createdAt
  +double code
  +processCreatedat()
}
class Wishlist {
  #String amount
  #double note
  +double createdAt
  #int email
  +findDuration()
}
class Review {
  +double code
  #float updatedAt
  +findDuration()
}
interface Shipment {
  +boolean active
  -int duration
  +getCreatedat()
  +processQuantity()
  +deleteUpdatedat()
}
class Return {
  +double address
  +long type
  +getDuration()
  +createCreatedat()
  +findEmail()
  +processDescription()
}
Review --o Wishlist
Cart ..> Return : "1"
Wishlist --> Shipment : "0..1"
note right of Invoice : Ecommerce domain
@enduml