@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
abstract class Group {
  #Date updatedAt
  #long name
  +deleteType()
}
abstract class User {
  -int note
  -boolean description
  +float active
  +updateStatus()
  +cancelAmount()
  +validatePrice()
}
class Report {
  -int duration
  +long description
  +calculateScore()
  +getId()
}
class Like {
  #double code
  -long email
  +float description
  -long createdAt
  #double quantity
  +processCreatedat()
}
interface Follower {
  #int createdAt
  -long note
  +cancelTotal()
  +getUpdatedat()
}
abstract class Notification {
  -float score
  -long quantity
  -String createdAt
  +float total
  +cancelAmount()
  +findType()
  +saveCreatedat()
  +createType()
}
abstract class Post {
  +String status
  +long amount
  -int code
  +processPrice()
  +findId()
}
Notification --o Report
Follower --|> Notification
User --> Post : "*"
note right of Group : Social Media domain
@enduml