@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
abstract class Group {
  #Date updatedAt
  #long name
  +cancelLevel()
}
class User {
  +long note
  #int createdAt
  -int duration
  +float description
  #int quantity
  +processType()
  +processCreatedat()
  +updateType()
}
class Report {
  -int price
  -float createdAt
  #String updatedAt
  +setAmount()
}
class Like {
  #double code
  -long email
  +float description
  -long createdAt
  #double quantity
  +sendCode()
}
class Follower {
  #int createdAt
  -long note
  +cancelActive()
  +saveStatus()
}
abstract class Notification {
  -float updatedAt
  #long type
  +processLevel()
  +processStatus()
}
abstract class Post {
  #int note
  #Date code
  -Date amount
  +long price
  +deleteEmail()
  +sendCode()
  +updateScore()
  +findName()
}
Group --> User : "1"
User --|> Group
Report ..|> Post
@enduml