@startuml
skinparam ArrowColor #555555
class User {
  +float description
  #Date name
  +saveCreatedat()
  +validateLevel()
  +processPrice()
}
abstract class Follower {
  -double description
  +boolean quantity
  -Date level
  +getLevel()
  +deleteCode()
  +processCode()
}
interface Post {
  #boolean phone
  +int address
  -int status
  #long createdAt
  +saveActive()
}
class Hashtag {
  #double id
  -float phone
  +Date type
  #double updatedAt
  -int status
  +getCode()
  +cancelAmount()
  +sendPrice()
  +createDescription()
}
class Notification {
  +float status
  +double note
  -boolean quantity
  +findType()
  +processPrice()
}
interface Message {
  -double level
  -boolean quantity
  #int description
  +boolean price
  +deleteCode()
  +getScore()
}
Follower ..|> Post
User ..|> Post
User --* Notification
@enduml