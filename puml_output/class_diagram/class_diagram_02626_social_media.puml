@startuml
skinparam ArrowColor #555555
class User {
  +float description
  #Date name
  +validateUpdatedat()
  +savePrice()
  +sendCreatedat()
}
class Follower {
  #long quantity
  #boolean note
  #long level
  +long updatedAt
  +cancelEmail()
}
class Post {
  -int status
  #long createdAt
  +boolean name
  #Date amount
  +processId()
  +validateType()
  +updateStatus()
}
interface Hashtag {
  #double note
  #boolean updatedAt
  #boolean price
  +Date email
  +Date description
  +processQuantity()
}
class Notification {
  +float total
  #boolean email
  -boolean createdAt
  +cancelDescription()
  +findLevel()
  +calculateQuantity()
}
abstract class Message {
  #int score
  -boolean duration
  #long updatedAt
  +long description
  +setQuantity()
  +deleteDescription()
}
User --* Notification
Post ..|> Notification
Follower --> Message : "0..1"
User --* Message
note right of User : Social Media domain
@enduml