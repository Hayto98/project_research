@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
abstract class Hashtag {
  #double phone
  #double status
  +updateCode()
  +cancelCreatedat()
}
abstract class Post {
  +boolean createdAt
  +Date updatedAt
  -long type
  #long address
  +deleteDuration()
}
class Group {
  #float phone
  +double total
  #int level
  +processPhone()
  +getTotal()
}
class Album {
  -float updatedAt
  +long level
  +validateCreatedat()
  +validateQuantity()
  +createDescription()
  +deleteDescription()
}
abstract class Report {
  -long amount
  #Date score
  +processTotal()
  +cancelQuantity()
  +setDescription()
  +getType()
}
Album --* Hashtag
Report --o Hashtag
Group ..> Album : "1"
@enduml