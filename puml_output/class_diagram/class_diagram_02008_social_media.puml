@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
abstract class Hashtag {
  #double phone
  #double status
  +calculateTotal()
  +saveQuantity()
}
class Post {
  #int type
  #long address
  -Date code
  +setNote()
  +setAmount()
  +validateTotal()
}
abstract class Group {
  #int total
  +String score
  #String description
  +cancelPhone()
  +updatePhone()
}
interface Album {
  +float description
  #long amount
  -float active
  #Date type
  -double id
  +setCode()
  +findPrice()
  +setQuantity()
  +saveType()
}
class Report {
  -Date type
  +boolean phone
  +saveStatus()
  +saveId()
  +setLevel()
}
Post --o Album
Group --* Post
Album ..|> Hashtag
note right of Hashtag : Social Media domain
@enduml