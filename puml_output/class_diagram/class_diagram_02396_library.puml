@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Author {
  -int quantity
  +boolean updatedAt
  #boolean duration
  #int code
  +double email
  +getAmount()
  +sendQuantity()
}
class Publisher {
  +Date description
  +int score
  #long total
  #float address
  +validateType()
}
abstract class Librarian {
  -double email
  #Date id
  +calculateAmount()
  +setDuration()
  +cancelUpdatedat()
}
class Loan {
  +float address
  +long email
  +getPhone()
  +setEmail()
  +getNote()
}
interface Reservation {
  #double status
  #double total
  +boolean level
  #boolean amount
  +findDescription()
}
Publisher ..|> Author
Librarian --o Loan
Reservation --o Author
note right of Author : Library domain
@enduml