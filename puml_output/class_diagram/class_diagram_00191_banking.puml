@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
interface Teller {
  +double name
  #boolean createdAt
  -double type
  -long updatedAt
  #Date price
  +updateCode()
}
class Loan {
  +double total
  -float type
  +String active
  +calculateCode()
  +validateQuantity()
}
class Account {
  -String address
  #String quantity
  +String updatedAt
  +createLevel()
}
abstract class Customer {
  #long createdAt
  -float description
  +deleteCreatedat()
}
class Transaction {
  #double amount
  #boolean total
  -long id
  +Date code
  +long duration
  +createAmount()
}
Loan --o Teller
Transaction ..> Loan : "1..*"
Account --o Loan
@enduml