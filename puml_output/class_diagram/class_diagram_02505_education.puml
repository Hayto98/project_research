@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
interface Department {
  -float address
  -Date active
  #int name
  +deleteNote()
  +updateActive()
}
interface Classroom {
  +String id
  +float phone
  -boolean email
  #float duration
  #float createdAt
  +processTotal()
  +cancelDescription()
  +updatePhone()
}
class Book {
  -boolean score
  #float id
  #long updatedAt
  +updateUpdatedat()
  +cancelCreatedat()
  +setType()
  +updateLevel()
}
class Enrollment {
  +int level
  #boolean updatedAt
  +double status
  +setDescription()
}
class Schedule {
  -double code
  +float type
  +String email
  +boolean total
  +cancelUpdatedat()
  +setEmail()
}
Classroom ..> Enrollment : "1"
Enrollment --> Department : "*"
@enduml