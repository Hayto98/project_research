@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
interface Department {
  -float address
  -Date active
  #int name
  +getId()
  +cancelTotal()
}
class Classroom {
  +int email
  -boolean id
  #float createdAt
  #float score
  +processAmount()
  +deleteScore()
  +getUpdatedat()
}
class Book {
  -String total
  #int status
  #float duration
  +String description
  +deleteLevel()
}
interface Enrollment {
  +long note
  +float name
  -long code
  +processNote()
  +getStatus()
  +getCreatedat()
  +cancelCreatedat()
}
class Schedule {
  #boolean updatedAt
  +double level
  +boolean note
  +sendStatus()
  +sendCode()
  +sendEmail()
  +processName()
}
Schedule --o Classroom
Classroom --|> Book
Book --> Schedule : "1..*"
Department --o Classroom
note right of Department : Education domain
@enduml