@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
interface MedicalRecord {
  -String amount
  +String code
  #boolean quantity
  #double level
  #Date id
  +cancelDuration()
  +saveUpdatedat()
  +findQuantity()
  +createActive()
}
class Insurance {
  -double code
  +double description
  -boolean phone
  #long amount
  #String level
  +createId()
  +deleteName()
  +deleteDuration()
}
interface Billing {
  -int id
  -boolean code
  +int total
  -int note
  #double level
  +calculateUpdatedat()
  +updateCode()
}
class Hospital {
  +int createdAt
  +Date price
  +long total
  +boolean phone
  +deleteQuantity()
  +saveScore()
  +cancelAddress()
}
abstract class Appointment {
  +double price
  +boolean score
  +Date active
  #float duration
  +validateCode()
}
Appointment --> Hospital : "*"
Insurance --> Hospital : "*"
Insurance --> Billing : "0..1"
note right of MedicalRecord : Healthcare domain
@enduml