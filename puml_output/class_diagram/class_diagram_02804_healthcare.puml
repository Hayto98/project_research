@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
interface MedicalRecord {
  -String amount
  +String code
  #boolean quantity
  #double level
  #Date id
  +validateActive()
  +calculateLevel()
  +setId()
  +updateAddress()
}
class Insurance {
  #float email
  +float active
  +long updatedAt
  +int note
  +validateName()
  +saveNote()
  +createPrice()
  +getQuantity()
}
interface Billing {
  -String level
  +String name
  +boolean score
  #Date email
  +updateActive()
  +getType()
  +updateEmail()
  +sendCode()
}
class Hospital {
  +double amount
  +Date address
  -boolean score
  #int updatedAt
  +validateNote()
  +saveLevel()
  +sendEmail()
  +setDescription()
}
class Appointment {
  +int createdAt
  +Date price
  +long total
  +boolean phone
  +saveLevel()
  +deleteScore()
  +calculatePhone()
}
Appointment --o Billing
Billing --> Hospital : "*"
MedicalRecord ..|> Hospital
Appointment ..> Insurance : "1"
@enduml