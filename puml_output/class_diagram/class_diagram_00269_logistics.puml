@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
abstract class Depot {
  #double phone
  -double updatedAt
  +calculateScore()
  +validateDescription()
}
class Manifest {
  +long score
  -String type
  #boolean address
  #boolean updatedAt
  +createDescription()
  +sendLevel()
  +sendCreatedat()
  +findUpdatedat()
}
class FuelLog {
  #int updatedAt
  -double createdAt
  -long code
  +boolean description
  +double active
  +deleteName()
  +findQuantity()
  +updateAmount()
  +createId()
}
class Customer {
  +Date id
  #long description
  #long name
  #long updatedAt
  +boolean address
  +findCreatedat()
}
FuelLog --> Depot : "1..*"
Customer --* Manifest
Manifest --o Depot
@enduml