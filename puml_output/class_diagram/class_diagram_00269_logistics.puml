@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
abstract class Depot {
  #double phone
  -double updatedAt
  +createStatus()
  +saveAddress()
}
interface Manifest {
  +Date address
  #Date updatedAt
  #double level
  #double duration
  #long quantity
  +updateCreatedat()
  +setDescription()
  +sendDescription()
  +findCreatedat()
}
class FuelLog {
  -long email
  -float address
  #float code
  +boolean status
  #double note
  +deleteName()
}
class Customer {
  +boolean status
  +long email
  -long level
  +boolean quantity
  +calculateNote()
  +createUpdatedat()
  +getTotal()
}
Manifest ..|> Depot
FuelLog --|> Customer
Customer --> FuelLog : "1"
note right of Depot : Logistics domain
@enduml