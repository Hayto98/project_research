@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Fine {
  +String id
  #double email
  -String status
  -int score
  +sendNote()
  +getId()
  +sendPrice()
}
interface Publisher {
  +int note
  -long name
  #double active
  #double code
  +updateTotal()
}
class Renewal {
  +String address
  +int id
  #String price
  #int createdAt
  -String email
  +createUpdatedat()
  +setDescription()
  +validateAmount()
}
interface Author {
  #Date phone
  -int status
  +Date description
  -float quantity
  +saveTotal()
  +getCode()
  +getTotal()
}
class Catalog {
  -long address
  +boolean total
  -double price
  +processType()
  +saveEmail()
}
class Member {
  -double createdAt
  -float status
  +double description
  +boolean total
  #float duration
  +calculateAmount()
  +validateTotal()
  +deleteDescription()
  +deletePhone()
}
class Book {
  #Date score
  -long quantity
  +Date address
  +findDuration()
  +createId()
  +saveActive()
  +cancelUpdatedat()
}
Member ..|> Book
Book --* Author
Author ..> Publisher : "*"
Publisher --o Fine
note right of Fine : Library domain
@enduml