@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Fine {
  +String id
  #double email
  -String status
  -int score
  +sendAmount()
  +sendCode()
  +saveId()
}
class Publisher {
  +int active
  -long address
  #double note
  #double name
  +int code
  +updateType()
  +deleteLevel()
  +getAddress()
  +setActive()
}
class Renewal {
  -int price
  +int createdAt
  +setPhone()
  +setUpdatedat()
}
interface Author {
  -int price
  +int status
  -int email
  +processStatus()
  +createPhone()
  +updateScore()
}
class Catalog {
  #Date address
  -Date description
  #double amount
  +Date quantity
  +setName()
}
abstract class Member {
  -double amount
  -long address
  +getQuantity()
  +getId()
}
abstract class Book {
  +double note
  +String type
  +boolean email
  +sendActive()
  +sendEmail()
  +updateTotal()
  +calculateAmount()
}
Book --o Fine
Publisher --> Catalog : "*"
Author --* Publisher
Book ..|> Author
@enduml