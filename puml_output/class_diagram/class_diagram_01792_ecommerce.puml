@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Supplier {
  #boolean duration
  -Date createdAt
  +int amount
  #float active
  -long total
  +createEmail()
}
abstract class Order {
  +double status
  -float level
  +saveId()
  +saveAddress()
}
class Product {
  +int quantity
  +double type
  +validateNote()
  +processStatus()
  +processQuantity()
  +sendTotal()
}
class Warehouse {
  +int active
  -long createdAt
  #double id
  +boolean type
  +sendQuantity()
  +setQuantity()
}
Order ..> Product : "1"
Warehouse --* Supplier
Supplier ..> Product : "1"
@enduml