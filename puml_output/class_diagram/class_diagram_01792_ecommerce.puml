@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Supplier {
  #boolean duration
  -Date createdAt
  +int amount
  #float active
  -long total
  +processId()
}
class Order {
  +int total
  -boolean quantity
  #String description
  +processId()
  +updateStatus()
  +calculateNote()
}
class Product {
  -float name
  #int id
  +double status
  +int active
  +createType()
  +setLevel()
  +deleteActive()
  +validateDuration()
}
class Warehouse {
  -String price
  #Date id
  +processActive()
}
Product --> Order : "0..1"
note right of Supplier : Ecommerce domain
@enduml