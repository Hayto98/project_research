@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Report {
  #long price
  #float description
  #float status
  -String type
  +deleteLevel()
  +calculatePhone()
}
class Album {
  +double updatedAt
  +Date phone
  +updateScore()
  +processAddress()
}
class Follower {
  #int phone
  #int quantity
  -String active
  -double name
  #Date score
  +cancelEmail()
  +createAmount()
  +updateName()
}
class Group {
  #long description
  +boolean email
  #int total
  +double updatedAt
  +int status
  +processEmail()
  +deleteEmail()
  +getUpdatedat()
  +cancelQuantity()
}
class Message {
  -String active
  +double phone
  -float name
  +getPhone()
}
class Profile {
  #float active
  #Date id
  +Date note
  #float description
  -int quantity
  +validateId()
  +updateId()
  +createActive()
  +validateName()
}
abstract class Like {
  +long level
  +long updatedAt
  -int code
  +int total
  +sendLevel()
  +saveId()
  +updatePhone()
}
Like ..> Report : "0..1"
Follower --> Album : "0..1"
Album --> Report : "1..*"
Follower --o Message
Group ..> Like : "0..1"
Profile --* Report
note right of Report : Social Media domain
@enduml