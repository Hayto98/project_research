@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Report {
  #long price
  #float description
  #float status
  -String type
  +setLevel()
  +savePrice()
}
abstract class Album {
  #long status
  +double level
  +Date code
  +int updatedAt
  +sendDescription()
  +calculateCreatedat()
  +saveQuantity()
  +processLevel()
}
class Follower {
  #int active
  -String name
  -double level
  #Date description
  +processEmail()
  +createId()
  +validateAddress()
}
class Group {
  #float updatedAt
  -float name
  +long createdAt
  +getStatus()
  +saveUpdatedat()
  +deleteAddress()
  +updateName()
}
class Message {
  +double duration
  +int createdAt
  +saveAmount()
  +sendAddress()
  +createId()
  +createCode()
}
class Profile {
  -float updatedAt
  #float quantity
  +createUpdatedat()
  +saveScore()
}
class Like {
  +long name
  -Date amount
  -Date price
  #String type
  -int status
  +saveDuration()
  +findType()
  +createDescription()
}
Profile --* Like
Album --* Group
@enduml