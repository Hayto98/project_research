@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Branch {
  +boolean price
  +Date amount
  #int note
  +calculateLevel()
  +setType()
  +deleteAmount()
}
class Catalog {
  +String description
  +double createdAt
  -String quantity
  #Date type
  +deleteQuantity()
  +getActive()
}
class Loan {
  -Date duration
  -int total
  -int amount
  +Date level
  -boolean active
  +calculateName()
  +deleteTotal()
}
class Member {
  +float type
  -float createdAt
  -double level
  -int price
  #Date description
  +sendDescription()
  +saveId()
}
class Librarian {
  -Date code
  -int score
  -boolean amount
  -boolean createdAt
  +saveStatus()
}
class Renewal {
  +int updatedAt
  -double name
  #float description
  #Date email
  -Date duration
  +saveStatus()
  +getUpdatedat()
}
interface Fine {
  -boolean score
  -int id
  +float note
  +deleteUpdatedat()
  +cancelDescription()
  +createCreatedat()
  +processTotal()
}
Fine --> Loan : "*"
Member ..|> Librarian
Renewal ..|> Branch
@enduml