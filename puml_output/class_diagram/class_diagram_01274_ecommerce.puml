@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Shipment {
  -boolean email
  -float createdAt
  +calculateEmail()
  +processNote()
}
class Cart {
  -int duration
  -String email
  #long total
  #int status
  +calculatePhone()
  +cancelLevel()
  +validateQuantity()
}
class Return {
  #String email
  #long amount
  +double createdAt
  +saveAddress()
}
class Coupon {
  -String total
  -long name
  #int id
  -boolean level
  #boolean score
  +deleteDuration()
  +updateDuration()
  +setAmount()
}
abstract class Payment {
  +double total
  +boolean updatedAt
  +setStatus()
  +calculateAmount()
  +setNote()
  +findTotal()
}
Cart ..> Coupon : "*"
Shipment ..> Cart : "1..*"
Cart --> Return : "1"
@enduml