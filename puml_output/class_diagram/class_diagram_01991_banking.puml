@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Transaction {
  #Date status
  -Date email
  -Date id
  #String score
  +validateId()
  +savePrice()
  +updateUpdatedat()
  +saveDuration()
}
abstract class Loan {
  +Date updatedAt
  +double active
  +cancelDescription()
  +processEmail()
  +deleteActive()
}
class Account {
  -double active
  +float name
  -float description
  +Date total
  +calculateType()
  +validateDuration()
  +createAmount()
}
interface Customer {
  -int amount
  -long level
  #long type
  #Date email
  +long duration
  +cancelPhone()
}
class Teller {
  #double createdAt
  #float email
  +saveActive()
  +calculateCode()
  +sendEmail()
  +updateScore()
}
interface Transfer {
  -Date code
  +String name
  +Date description
  -double email
  +getId()
  +setType()
  +updateCreatedat()
}
Transaction --> Teller : "*"
Loan --> Transaction : "1..*"
Teller ..> Transfer : "1..*"
@enduml