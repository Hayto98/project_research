@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Transaction {
  #Date status
  -Date email
  -Date id
  #String score
  +setLevel()
  +setLevel()
  +saveType()
  +setUpdatedat()
}
interface Loan {
  #boolean status
  -float note
  +long address
  +findDuration()
}
class Account {
  #long phone
  -long price
  #double createdAt
  +boolean level
  -long code
  +processCreatedat()
  +validatePhone()
}
class Customer {
  -boolean address
  +int name
  -boolean email
  +saveNote()
  +sendPrice()
  +updateDuration()
  +validateCode()
}
class Teller {
  #String duration
  +float email
  +Date level
  +calculateScore()
  +createType()
  +deleteCreatedat()
}
class Transfer {
  -boolean amount
  +Date id
  +boolean phone
  +int email
  #long quantity
  +cancelScore()
  +findAddress()
  +calculateCreatedat()
  +saveNote()
}
Customer ..> Transaction : "0..1"
Teller --* Transaction
Account --o Transfer
Transaction --* Customer
Transfer --o Account
note right of Transaction : Banking domain
@enduml