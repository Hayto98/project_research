@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
interface Member {
  -boolean price
  -float amount
  -float name
  #Date code
  +Date status
  +processDescription()
  +calculateDescription()
  +processCreatedat()
}
class Publisher {
  +int code
  -double amount
  #boolean phone
  -double score
  #Date quantity
  +cancelTotal()
  +updateScore()
  +updateUpdatedat()
}
class Branch {
  #String quantity
  #double name
  +calculatePhone()
  +updateQuantity()
}
class Catalog {
  #String email
  -int description
  -float quantity
  -boolean total
  +sendDescription()
  +processCreatedat()
  +createCreatedat()
}
Branch --o Member
Member --o Catalog
note right of Member : Library domain
@enduml