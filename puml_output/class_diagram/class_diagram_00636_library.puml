@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
interface Member {
  -boolean price
  -float amount
  -float name
  #Date code
  +Date status
  +processTotal()
  +findPhone()
  +getPrice()
}
abstract class Publisher {
  -String type
  +long createdAt
  #float phone
  +calculatePhone()
  +createCreatedat()
  +setLevel()
}
abstract class Branch {
  +boolean active
  +int address
  +String type
  -String email
  #String total
  +findId()
  +calculateCode()
  +deleteCode()
  +setQuantity()
}
class Catalog {
  -double email
  #String phone
  -int duration
  -float description
  +cancelAmount()
  +calculateCreatedat()
  +validateCreatedat()
}
Publisher ..> Catalog : "0..1"
@enduml