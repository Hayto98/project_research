@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
interface Album {
  #double active
  -int duration
  #int code
  +Date price
  +double address
  +processPrice()
}
class Hashtag {
  -int quantity
  -double description
  #int updatedAt
  +calculateId()
  +cancelId()
  +cancelDuration()
}
interface Follower {
  +float note
  -String phone
  #long email
  +processTotal()
}
class Profile {
  +String active
  +double type
  #int updatedAt
  +getDescription()
  +saveName()
  +processStatus()
  +processEmail()
}
Hashtag --o Profile
Profile --* Album
@enduml