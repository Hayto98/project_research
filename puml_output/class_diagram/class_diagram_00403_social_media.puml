@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
interface Album {
  #double active
  -int duration
  #int code
  +Date price
  +double address
  +updateAddress()
}
interface Hashtag {
  -int quantity
  -double description
  #int updatedAt
  +getPhone()
  +saveActive()
  +updateNote()
}
class Follower {
  +double description
  +int type
  #double status
  +String email
  +setPrice()
}
class Profile {
  -Date price
  #double phone
  +float description
  -long createdAt
  -long duration
  +createPhone()
  +getDuration()
}
Profile --* Follower
Hashtag ..|> Follower
note right of Album : Social Media domain
@enduml