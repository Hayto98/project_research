@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Course {
  +int level
  +float email
  +calculateDuration()
  +deleteStatus()
  +findAmount()
  +sendNote()
}
interface Library {
  #long total
  +boolean status
  -boolean duration
  -String createdAt
  +getPrice()
  +deleteCode()
  +createEmail()
  +createNote()
}
interface Schedule {
  -long amount
  +String createdAt
  #Date quantity
  #Date phone
  +cancelAddress()
  +calculateAmount()
  +updateType()
}
class Grade {
  -boolean total
  #Date id
  #int quantity
  +findAddress()
}
abstract class Assignment {
  +double name
  +int status
  +long note
  +setPhone()
  +setUpdatedat()
}
Assignment --o Schedule
Assignment --> Grade : "*"
Course --|> Grade
note right of Course : Education domain
@enduml