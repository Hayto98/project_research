@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Course {
  +int level
  +float email
  +deleteAmount()
  +sendPrice()
  +updateCreatedat()
  +deleteEmail()
}
interface Library {
  -boolean status
  #float amount
  -double active
  +findAmount()
}
interface Schedule {
  #double phone
  +boolean createdAt
  -String note
  +createCode()
  +createAddress()
  +deleteName()
  +validateAmount()
}
class Grade {
  -long score
  -String address
  +Date amount
  #boolean createdAt
  #Date quantity
  +getDescription()
  +getCode()
  +calculateCreatedat()
}
abstract class Assignment {
  +Date updatedAt
  -String type
  -long createdAt
  +deleteType()
  +findNote()
}
Schedule --> Grade : "0..1"
Course ..> Assignment : "*"
Library --|> Grade
Library --* Course
@enduml