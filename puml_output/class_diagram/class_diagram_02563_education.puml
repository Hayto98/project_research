@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Teacher {
  +Date name
  #int note
  #String score
  #String total
  -Date amount
  +createDuration()
  +deleteLevel()
}
interface Library {
  +float email
  +int phone
  +validateScore()
  +saveAmount()
  +getActive()
  +updateType()
}
class Department {
  #Date updatedAt
  #Date createdAt
  #long level
  #long active
  +updateName()
}
abstract class Schedule {
  #int duration
  #int createdAt
  -float price
  +deleteUpdatedat()
  +updateDescription()
}
class Assignment {
  -String id
  +String phone
  +boolean score
  -float note
  #int description
  +calculatePrice()
}
Teacher --> Library : "*"
Teacher --> Schedule : "1"
Department --> Assignment : "1..*"
note right of Teacher : Education domain
@enduml