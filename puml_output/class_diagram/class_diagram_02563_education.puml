@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Teacher {
  +Date name
  #int note
  #String score
  #String total
  -Date amount
  +validateAmount()
  +getQuantity()
}
class Library {
  +float email
  +int phone
  +findCode()
  +sendUpdatedat()
  +processPhone()
  +deleteTotal()
}
interface Department {
  -String id
  -Date active
  +int createdAt
  +calculateActive()
  +validateStatus()
}
interface Schedule {
  +double email
  #Date level
  #int status
  #int updatedAt
  +setCode()
  +saveAddress()
  +createDescription()
  +processDuration()
}
abstract class Assignment {
  #float description
  +long updatedAt
  -String createdAt
  +findName()
  +saveActive()
  +sendCode()
}
Schedule ..|> Teacher
Teacher --> Library : "*"
@enduml