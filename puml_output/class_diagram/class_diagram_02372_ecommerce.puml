@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
abstract class Category {
  -boolean phone
  #long status
  -String amount
  +processEmail()
  +calculateStatus()
  +deleteName()
  +createDuration()
}
class Order {
  -long score
  +String description
  #String quantity
  #double address
  -String code
  +getPhone()
  +findCode()
}
class Review {
  #int active
  +Date duration
  +findScore()
  +saveName()
  +cancelAddress()
}
interface Wishlist {
  +boolean address
  #int level
  #boolean createdAt
  +validateName()
}
abstract class Product {
  +boolean score
  #float active
  -Date level
  +updateNote()
  +saveAddress()
  +cancelNote()
}
class Payment {
  -long email
  -float name
  +boolean description
  +sendPrice()
  +saveEmail()
}
Review --|> Product
Order --|> Category
Payment --|> Product
note right of Category : Ecommerce domain
@enduml