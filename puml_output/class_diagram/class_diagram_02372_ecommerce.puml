@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
abstract class Category {
  -boolean phone
  #long status
  -String amount
  +deleteId()
  +saveAmount()
  +validateAddress()
  +updateQuantity()
}
abstract class Order {
  -boolean amount
  -double name
  +processEmail()
  +calculatePhone()
}
class Review {
  +String quantity
  #String address
  +createAmount()
  +updateName()
  +validateType()
  +calculateNote()
}
class Wishlist {
  #boolean code
  +int email
  #long id
  #float active
  +setPhone()
}
class Product {
  +boolean address
  #int level
  #boolean createdAt
  +validateScore()
}
class Payment {
  #boolean createdAt
  -Date score
  -int active
  -Date level
  -boolean code
  +processCode()
  +sendEmail()
  +updateCode()
  +validateAddress()
}
Payment --o Order
Review --|> Payment
@enduml