@startuml
skinparam ArrowColor #555555
class Branch {
  #String type
  -float createdAt
  #int duration
  -String level
  #boolean status
  +deleteCreatedat()
  +cancelAddress()
}
abstract class Member {
  -float phone
  #boolean score
  +String description
  +String email
  +getQuantity()
  +findUpdatedat()
  +getName()
}
abstract class Catalog {
  -int createdAt
  -Date score
  #double price
  +deleteCreatedat()
  +createCode()
}
class Renewal {
  +double code
  #boolean id
  +float duration
  +String name
  +updatePhone()
  +validatePhone()
  +updateStatus()
  +calculateAmount()
}
interface Book {
  #int email
  +double duration
  #String description
  #String code
  +updatePhone()
  +createAddress()
}
abstract class Publisher {
  #Date duration
  +boolean createdAt
  -float code
  +updateCode()
}
Book ..|> Branch
Publisher --o Branch
Publisher ..> Member : "1..*"
Book --> Catalog : "1..*"
Catalog ..> Publisher : "*"
note right of Branch : Library domain
@enduml