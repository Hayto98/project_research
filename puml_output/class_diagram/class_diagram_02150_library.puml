@startuml
skinparam ArrowColor #555555
class Branch {
  #String type
  -float createdAt
  #int duration
  -String level
  #boolean status
  +processUpdatedat()
  +updateDescription()
}
interface Member {
  -double total
  #boolean phone
  +String level
  +String description
  +cancelTotal()
  +updateLevel()
  +createLevel()
}
class Catalog {
  +int name
  #double price
  +updateType()
  +createQuantity()
  +getAmount()
}
abstract class Renewal {
  +int description
  -String createdAt
  +boolean quantity
  +getActive()
}
class Book {
  #String note
  +String level
  +updateStatus()
  +findCode()
  +deleteCode()
  +processStatus()
}
class Publisher {
  #Date price
  #long amount
  +calculateScore()
  +validateCreatedat()
  +cancelPrice()
}
Publisher ..|> Member
Renewal --|> Book
@enduml