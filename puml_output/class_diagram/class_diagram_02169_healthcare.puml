@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
abstract class Nurse {
  #float score
  -float amount
  +updateEmail()
  +processScore()
}
interface Prescription {
  +long createdAt
  #boolean description
  +setLevel()
  +validateId()
  +setNote()
}
class Insurance {
  +float code
  -float status
  +calculateName()
}
class Patient {
  +boolean duration
  +boolean updatedAt
  +validateType()
  +setCreatedat()
}
class Billing {
  #boolean score
  -int id
  +deleteType()
  +calculatePhone()
  +calculateDescription()
  +cancelEmail()
}
interface Appointment {
  -float type
  +int duration
  +processName()
  +updateScore()
  +createTotal()
  +cancelNote()
}
Patient ..|> Nurse
Patient --o Prescription
Appointment --* Insurance
Billing ..|> Prescription
@enduml