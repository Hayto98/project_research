@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
abstract class Nurse {
  #float score
  -float amount
  +calculateLevel()
  +setCreatedat()
}
class Prescription {
  #Date quantity
  -int score
  +calculatePhone()
}
interface Insurance {
  +float code
  -float status
  +validateQuantity()
}
interface Patient {
  +boolean duration
  +boolean updatedAt
  +findAmount()
  +setScore()
}
class Billing {
  #boolean updatedAt
  +Date price
  #double quantity
  #double status
  +deleteAmount()
  +calculateId()
  +findCreatedat()
  +savePhone()
}
abstract class Appointment {
  +double createdAt
  #Date price
  +validateLevel()
  +findAmount()
  +updateQuantity()
}
Prescription --* Appointment
Appointment ..|> Patient
Billing --|> Appointment
note right of Nurse : Healthcare domain
@enduml