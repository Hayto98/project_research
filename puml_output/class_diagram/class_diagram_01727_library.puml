@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Fine {
  #double updatedAt
  -int duration
  -boolean amount
  +getPhone()
  +findId()
  +processCreatedat()
}
class Loan {
  -String address
  +boolean phone
  +saveCode()
}
class Catalog {
  +float note
  +long id
  +double score
  -float address
  +saveEmail()
}
class Publisher {
  +String duration
  #Date amount
  #boolean updatedAt
  -float active
  -String level
  +sendUpdatedat()
}
class Member {
  #float code
  #float updatedAt
  -Date note
  #long name
  -int createdAt
  +cancelCreatedat()
  +getAmount()
  +processNote()
}
class Reservation {
  -boolean id
  +boolean quantity
  +Date createdAt
  -boolean score
  -String description
  +validateName()
  +saveId()
  +findDescription()
  +calculateNote()
}
Reservation --> Fine : "1"
Member --o Publisher
@enduml