@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Fine {
  #double updatedAt
  -int duration
  -boolean amount
  +calculateAmount()
  +getStatus()
  +validatePhone()
}
abstract class Loan {
  +double status
  +long level
  +getScore()
  +validateCode()
  +getEmail()
  +updatePrice()
}
class Catalog {
  -boolean name
  +int quantity
  +setCode()
  +sendDuration()
}
interface Publisher {
  -String note
  +double status
  +int name
  #float createdAt
  +saveDuration()
  +createNote()
  +deleteAddress()
}
abstract class Member {
  +int price
  -boolean id
  +boolean quantity
  +Date createdAt
  +cancelNote()
  +setDuration()
  +calculateType()
}
class Reservation {
  #boolean status
  +boolean id
  -double active
  +sendAddress()
}
Fine --o Reservation
Catalog --|> Loan
Loan ..|> Reservation
Loan --o Catalog
Member ..|> Publisher
note right of Fine : Library domain
@enduml