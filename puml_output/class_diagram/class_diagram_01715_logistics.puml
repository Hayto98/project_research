@startuml
skinparam ArrowColor #555555
class Package {
  #double address
  -String price
  -boolean updatedAt
  +calculatePhone()
  +findEmail()
  +findAmount()
  +sendAddress()
}
class Shipment {
  #int active
  #int code
  -Date total
  +deleteNote()
  +calculateCreatedat()
  +setDescription()
}
class Customer {
  +int name
  +double active
  +sendActive()
  +validateUpdatedat()
  +validateNote()
  +deleteName()
}
class Inventory {
  -int id
  +boolean amount
  +sendScore()
}
class FuelLog {
  +boolean amount
  #long note
  +deleteDuration()
  +deleteAddress()
  +cancelDuration()
}
abstract class Depot {
  +String score
  -long quantity
  +sendAddress()
  +setUpdatedat()
  +validateTotal()
}
Package --o Customer
Depot --* FuelLog
Depot --|> Customer
Customer ..|> Package
@enduml