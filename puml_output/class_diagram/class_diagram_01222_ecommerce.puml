@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Warehouse {
  +Date active
  #String type
  +findLevel()
  +findPhone()
  +calculateActive()
  +saveActive()
}
abstract class Coupon {
  +int active
  +long name
  #boolean duration
  +boolean amount
  -Date score
  +deleteActive()
}
interface Shipment {
  -int score
  +int email
  +String code
  #double phone
  #int total
  +calculateNote()
  +saveEmail()
  +findQuantity()
}
class Wishlist {
  -int duration
  #float quantity
  -float email
  -double type
  -String name
  +updateStatus()
  +saveQuantity()
  +validateDuration()
  +sendId()
}
Coupon --* Wishlist
Wishlist --o Warehouse
@enduml