@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Classroom {
  -Date updatedAt
  -double level
  #long duration
  +findPhone()
}
class Book {
  -boolean email
  +double quantity
  +long address
  +float amount
  -boolean active
  +setCreatedat()
}
class Course {
  +float type
  +boolean duration
  #float createdAt
  #double active
  +findCode()
  +deletePrice()
}
class Enrollment {
  +boolean code
  -Date total
  +validateUpdatedat()
  +sendAddress()
}
interface Assignment {
  -String price
  #float type
  -boolean phone
  #float status
  +createDescription()
  +getEmail()
}
class Teacher {
  +int updatedAt
  #long phone
  -long duration
  +double createdAt
  +validateCreatedat()
}
abstract class Exam {
  #long description
  -boolean score
  #float updatedAt
  #Date name
  +calculateTotal()
  +calculateAddress()
  +saveLevel()
}
Book --* Classroom
Exam ..|> Assignment
Exam --* Course
Enrollment --* Course
@enduml