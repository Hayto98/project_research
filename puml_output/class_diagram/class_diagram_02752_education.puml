@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Classroom {
  -Date updatedAt
  -double level
  #long duration
  +deleteCreatedat()
}
abstract class Book {
  -boolean quantity
  +double address
  +long amount
  +float score
  +sendCode()
  +findStatus()
  +validateType()
  +findType()
}
class Course {
  #float createdAt
  #double level
  +validateNote()
  +findAmount()
}
class Enrollment {
  #long total
  #int description
  +createDuration()
  +sendAddress()
  +calculateType()
  +validateStatus()
}
class Assignment {
  #boolean active
  +boolean total
  +setEmail()
  +updateDuration()
}
class Teacher {
  #long createdAt
  -long amount
  +double duration
  +deletePrice()
}
interface Exam {
  #long description
  -boolean score
  #float updatedAt
  #Date name
  +deleteEmail()
  +updateName()
  +validateLevel()
}
Exam --* Course
Enrollment --* Course
Book ..|> Classroom
note right of Classroom : Education domain
@enduml