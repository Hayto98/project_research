@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Shelf {
  +boolean amount
  -long status
  #long total
  +getLevel()
}
class Fine {
  -Date type
  +Date status
  +int level
  #Date score
  #double price
  +sendPrice()
}
interface Librarian {
  +double phone
  -long type
  +validateScore()
  +saveNote()
  +cancelAmount()
  +sendNote()
}
class Renewal {
  +long description
  +float amount
  #Date price
  +double id
  +updateScore()
}
Librarian --* Renewal
Shelf --|> Librarian
Shelf ..|> Fine
note right of Shelf : Library domain
@enduml