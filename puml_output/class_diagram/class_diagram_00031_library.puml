@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Shelf {
  +boolean amount
  -long status
  #long total
  +setUpdatedat()
}
interface Fine {
  #String total
  -double type
  #float status
  +Date score
  +createScore()
}
interface Librarian {
  -int name
  -double active
  -float price
  #double id
  -boolean phone
  +processEmail()
  +processUpdatedat()
  +sendAmount()
  +cancelQuantity()
}
class Renewal {
  +long description
  +float amount
  #Date price
  +double id
  +findAddress()
}
Librarian --* Renewal
Shelf --|> Librarian
Shelf ..|> Fine
@enduml