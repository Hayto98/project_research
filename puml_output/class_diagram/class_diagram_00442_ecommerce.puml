@startuml
skinparam defaultFontSize 13
abstract class Payment {
  -String updatedAt
  +String note
  -int price
  +getName()
  +deleteDescription()
}
class Category {
  #float address
  #boolean name
  +String email
  -Date quantity
  +getType()
  +validateQuantity()
  +findName()
  +createName()
}
class Product {
  -int description
  -int name
  #double level
  #long email
  +setId()
  +sendQuantity()
  +cancelScore()
  +saveEmail()
}
interface Wishlist {
  #int level
  +long email
  -double type
  +validateCode()
  +setName()
}
Category --o Payment
Product --|> Payment
@enduml