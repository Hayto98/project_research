@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Like {
  +float email
  #long id
  +boolean price
  +createTotal()
  +createCreatedat()
}
abstract class Message {
  -long amount
  #int code
  #long name
  +sendDuration()
  +cancelActive()
}
abstract class Profile {
  #boolean status
  #double quantity
  -long level
  +getQuantity()
  +findDescription()
  +createQuantity()
  +deleteUpdatedat()
}
abstract class User {
  -Date duration
  -float email
  #Date updatedAt
  -String address
  +double total
  +calculateAmount()
  +setDuration()
}
class Report {
  +Date address
  -float status
  +float name
  #Date quantity
  +deleteName()
  +sendScore()
}
class Album {
  +boolean amount
  +double level
  -long status
  #long code
  +calculateScore()
  +createId()
}
User ..|> Album
Profile --* Message
User --* Report
Album --o Message
@enduml