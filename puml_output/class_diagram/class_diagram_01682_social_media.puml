@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
interface Profile {
  -Date phone
  +boolean updatedAt
  -long address
  -float type
  +cancelType()
}
class User {
  -String createdAt
  +String note
  #long code
  #Date duration
  +boolean level
  +updateCreatedat()
  +sendName()
  +setDescription()
  +findId()
}
class Report {
  -Date updatedAt
  #float name
  +getCode()
  +findDuration()
  +calculateActive()
}
class Group {
  #float price
  #long score
  #double name
  +saveScore()
  +createPhone()
  +getTotal()
  +updateId()
}
class Notification {
  +String address
  #int amount
  #Date email
  +saveDescription()
  +getAddress()
}
abstract class Hashtag {
  -double quantity
  +int address
  -float level
  #float score
  +double email
  +setCode()
  +createTotal()
  +findType()
  +deleteName()
}
Group ..|> Profile
Hashtag --|> Report
Notification ..> Profile : "*"
Profile ..|> User
@enduml