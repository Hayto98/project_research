@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
interface Profile {
  -Date phone
  +boolean updatedAt
  -long address
  -float type
  +validateNote()
}
class User {
  +String code
  #long createdAt
  #Date note
  +boolean quantity
  -float status
  +setAmount()
  +saveId()
  +sendStatus()
  +updateName()
}
abstract class Report {
  +Date level
  -boolean active
  #String duration
  #float updatedAt
  +saveType()
  +calculatePhone()
  +setCreatedat()
}
class Group {
  +String address
  #int amount
  #Date email
  +findTotal()
  +calculateType()
}
class Notification {
  -int address
  +double duration
  #float email
  +double price
  +findEmail()
  +findEmail()
  +processName()
  +deleteQuantity()
}
class Hashtag {
  +int total
  #Date status
  +getDuration()
  +createEmail()
  +validateActive()
}
User --* Group
Group --o Report
User --* Profile
User --* Report
Report --|> Group
note right of Profile : Social Media domain
@enduml