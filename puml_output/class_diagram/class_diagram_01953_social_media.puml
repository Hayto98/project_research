@startuml
skinparam ArrowColor #555555
class Report {
  -long level
  #float type
  -int email
  #float updatedAt
  +cancelTotal()
}
class Story {
  +int createdAt
  #boolean phone
  +processPhone()
  +calculateAddress()
  +createUpdatedat()
  +processCreatedat()
}
abstract class Group {
  +int total
  -double note
  +setNote()
}
class Follower {
  -long duration
  +String createdAt
  +long score
  +getAmount()
  +createCode()
  +setPrice()
  +setAmount()
}
Report --* Follower
Story ..|> Report
Story --o Group
@enduml