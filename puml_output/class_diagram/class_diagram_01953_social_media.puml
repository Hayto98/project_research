@startuml
skinparam ArrowColor #555555
class Report {
  -long level
  #float type
  -int email
  #float updatedAt
  +getStatus()
}
interface Story {
  +int createdAt
  #boolean phone
  +deleteActive()
  +calculateId()
  +calculateNote()
  +setCreatedat()
}
abstract class Group {
  #float name
  -long total
  +String status
  +long amount
  #double createdAt
  +validateStatus()
  +getQuantity()
}
class Follower {
  #float amount
  -String updatedAt
  +saveName()
}
Follower ..|> Group
Group --> Follower : "0..1"
note right of Report : Social Media domain
@enduml