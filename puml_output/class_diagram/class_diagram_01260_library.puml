@startuml
skinparam shadowing true
abstract class Reservation {
  #double phone
  #long active
  #String level
  #boolean price
  +calculateEmail()
  +saveScore()
  +deleteDuration()
}
class Member {
  +int duration
  #long note
  #Date createdAt
  +float type
  +calculateCode()
  +saveLevel()
  +setId()
  +setCode()
}
interface Loan {
  -int duration
  -long score
  -double status
  -Date name
  #String updatedAt
  +sendAddress()
}
class Librarian {
  +double total
  +String phone
  #Date email
  +double amount
  +updateStatus()
  +updateAddress()
  +saveNote()
}
class Catalog {
  +float note
  +Date total
  +cancelDuration()
  +findAmount()
  +validateTotal()
}
class Shelf {
  +long duration
  #boolean name
  +updateStatus()
  +sendPrice()
}
class Fine {
  +long address
  +float phone
  #long email
  #double score
  +processPrice()
  +updateNote()
}
Catalog --* Fine
Member ..|> Reservation
Shelf --|> Catalog
Loan --> Fine : "1..*"
@enduml