@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class LabTest {
  -long score
  #Date description
  -String price
  -boolean note
  +deleteType()
  +processCode()
  +cancelLevel()
  +findDescription()
}
interface Diagnosis {
  #String active
  +float createdAt
  #long status
  +findNote()
  +deleteCreatedat()
}
class Patient {
  +float total
  +boolean duration
  -int id
  +double active
  -Date description
  +processId()
  +saveCreatedat()
  +cancelQuantity()
  +sendCode()
}
class Treatment {
  -float name
  -boolean level
  +float description
  +saveName()
  +deleteCreatedat()
  +findActive()
}
LabTest ..> Treatment : "1..*"
Patient --> Diagnosis : "*"
Treatment --* Diagnosis
note right of LabTest : Healthcare domain
@enduml