@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class LabTest {
  -long score
  #Date description
  -String price
  -boolean note
  +saveTotal()
  +updateAmount()
  +processUpdatedat()
  +deleteActive()
}
abstract class Diagnosis {
  #float duration
  +boolean level
  +createUpdatedat()
  +getTotal()
}
class Patient {
  -boolean amount
  #boolean score
  +setCreatedat()
  +cancelLevel()
}
abstract class Treatment {
  -double createdAt
  +boolean name
  #int type
  +processPhone()
}
Patient ..|> LabTest
Treatment ..> Diagnosis : "*"
@enduml