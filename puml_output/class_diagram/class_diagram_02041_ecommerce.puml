@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
interface Return {
  -double status
  -double description
  +getPrice()
  +setCreatedat()
  +updateAmount()
  +setStatus()
}
class Review {
  -double score
  -long code
  #String name
  +processEmail()
  +setAddress()
  +processDuration()
}
class Customer {
  -long note
  #String updatedAt
  +long quantity
  +calculateDescription()
  +validatePhone()
  +deletePrice()
  +createAddress()
}
class Warehouse {
  +long id
  +String description
  +saveAmount()
  +calculatePhone()
  +updateLevel()
}
class Payment {
  -long price
  #long address
  -double note
  +String phone
  +processDescription()
}
class Order {
  #long quantity
  +Date price
  +calculateActive()
}
class Coupon {
  +double email
  +int createdAt
  +findDuration()
  +createNote()
  +calculateScore()
  +findQuantity()
}
Coupon --o Payment
Coupon --|> Warehouse
Order --o Return
@enduml