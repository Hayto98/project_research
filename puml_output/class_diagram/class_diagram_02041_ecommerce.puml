@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
interface Return {
  -double status
  -double description
  +findStatus()
  +updateAmount()
  +sendCode()
  +saveName()
}
class Review {
  #boolean phone
  +int duration
  #int status
  -float active
  +long address
  +validateId()
  +setPhone()
  +findPrice()
  +findCode()
}
abstract class Customer {
  +boolean description
  +String name
  +getStatus()
  +saveScore()
  +validateNote()
}
class Warehouse {
  -long address
  -long email
  #long price
  -double duration
  +setLevel()
}
class Payment {
  #long amount
  +Date code
  +boolean quantity
  -String price
  +updateCreatedat()
  +processDescription()
  +deleteScore()
}
abstract class Order {
  +Date address
  +float duration
  -float note
  -int total
  +saveCode()
  +updateNote()
  +validateLevel()
}
class Coupon {
  -boolean quantity
  -float status
  +deleteActive()
  +findPhone()
}
Customer ..|> Payment
Review ..> Return : "0..1"
note right of Return : Ecommerce domain
@enduml