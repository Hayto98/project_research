@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
interface Publisher {
  -int price
  -Date code
  -boolean email
  +int duration
  +sendTotal()
  +findActive()
  +updateEmail()
}
class Member {
  +float createdAt
  +Date name
  +calculateQuantity()
  +cancelAddress()
  +calculateDescription()
  +updateName()
}
class Branch {
  -int active
  -String amount
  -String address
  -Date type
  #double level
  +sendCreatedat()
}
class Catalog {
  -int id
  +boolean phone
  +updateActive()
  +validateCode()
  +cancelDescription()
  +updateNote()
}
class Reservation {
  +String active
  -long address
  +int type
  +double description
  +cancelScore()
  +updatePrice()
  +processNote()
  +validateUpdatedat()
}
Branch ..> Publisher : "0..1"
Publisher --o Branch
Branch --o Member
Branch --|> Catalog
@enduml