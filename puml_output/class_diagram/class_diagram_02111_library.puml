@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
interface Publisher {
  -int price
  -Date code
  -boolean email
  +int duration
  +getType()
  +calculateStatus()
  +getCreatedat()
}
class Member {
  -long createdAt
  #String note
  +processActive()
  +deleteAddress()
}
abstract class Branch {
  +long total
  +float updatedAt
  -Date duration
  +setType()
  +createName()
  +getPhone()
  +validateUpdatedat()
}
class Catalog {
  #float id
  #Date description
  -double active
  +String email
  +long score
  +setDescription()
  +deleteTotal()
  +calculateId()
}
abstract class Reservation {
  #boolean score
  -double status
  -boolean description
  #float id
  +calculateQuantity()
  +calculateStatus()
}
Branch --o Publisher
Catalog --o Publisher
Catalog ..> Member : "0..1"
Branch ..> Reservation : "1..*"
note right of Publisher : Library domain
@enduml