@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Treatment {
  +int score
  -boolean total
  +long amount
  -int status
  -float updatedAt
  +saveAmount()
  +createQuantity()
  +createName()
}
class Hospital {
  #Date duration
  #Date name
  -float code
  #double description
  +setEmail()
}
interface Prescription {
  #String total
  -float score
  +cancelId()
}
class Doctor {
  +String level
  +float note
  -Date code
  +setType()
  +validateDescription()
  +processDuration()
  +sendQuantity()
}
interface Ward {
  #boolean status
  -String quantity
  +cancelEmail()
  +savePrice()
}
class MedicalRecord {
  +boolean type
  +int description
  +long level
  +cancelAmount()
  +calculateAmount()
  +sendPrice()
}
abstract class Billing {
  #boolean duration
  #int price
  +int id
  +deleteScore()
  +cancelEmail()
  +getTotal()
  +findLevel()
}
Treatment ..> Billing : "1..*"
Hospital --o Doctor
Ward ..> Billing : "1..*"
Prescription --o Billing
MedicalRecord --o Prescription
@enduml