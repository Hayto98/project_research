@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Treatment {
  +int score
  -boolean total
  +long amount
  -int status
  -float updatedAt
  +processQuantity()
  +processId()
  +validateDuration()
}
class Hospital {
  #double description
  #double score
  +validateDuration()
}
class Prescription {
  +int score
  #double status
  +int type
  +String id
  -Date phone
  +deleteUpdatedat()
  +sendLevel()
  +getStatus()
  +createDuration()
}
interface Doctor {
  #double name
  +float createdAt
  #boolean status
  +String updatedAt
  #int level
  +deleteEmail()
  +sendQuantity()
}
interface Ward {
  +int total
  -int description
  +int price
  #String id
  +Date amount
  +updatePrice()
  +processActive()
  +sendDuration()
}
class MedicalRecord {
  -double id
  #long email
  +deleteEmail()
  +deleteQuantity()
  +saveAmount()
  +processType()
}
class Billing {
  #int total
  +int createdAt
  -String duration
  #boolean note
  +long level
  +setDuration()
  +setActive()
}
Treatment ..> Hospital : "1"
Doctor --o Treatment
Ward ..> Billing : "0..1"
note right of Treatment : Healthcare domain
@enduml