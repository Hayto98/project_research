@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
interface Transfer {
  #float phone
  -long type
  +double quantity
  +calculateType()
  +saveQuantity()
  +cancelQuantity()
  +setDuration()
}
class Card {
  #boolean id
  #Date total
  +findDuration()
  +findName()
  +cancelEmail()
}
class Teller {
  +Date name
  #String duration
  +float total
  +deleteLevel()
  +cancelNote()
  +saveEmail()
  +getPrice()
}
class Loan {
  +int note
  #int total
  -String price
  #long level
  +getName()
  +calculateScore()
  +setPhone()
}
interface Interest {
  #Date amount
  -int score
  -boolean price
  -double address
  -long active
  +getTotal()
}
class Withdrawal {
  +Date createdAt
  +Date level
  +String status
  -Date total
  -float name
  +setId()
  +createPrice()
  +findLevel()
  +saveUpdatedat()
}
Card --* Teller
Card ..> Transfer : "1..*"
Interest --> Withdrawal : "1"
@enduml