@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Payment {
  -String address
  #Date name
  +double score
  +createStatus()
  +sendCode()
}
class Order {
  +boolean duration
  -double price
  +long status
  +findScore()
  +processEmail()
}
class Warehouse {
  +boolean note
  #double email
  #Date phone
  -double level
  +deleteScore()
  +setName()
  +setEmail()
}
class Cart {
  #float updatedAt
  #int amount
  -long address
  +float status
  -double duration
  +createLevel()
  +calculateTotal()
  +calculateLevel()
}
class Category {
  +Date quantity
  +long price
  -String description
  +sendTotal()
  +findCode()
  +setEmail()
  +sendId()
}
Order ..> Category : "1..*"
Order --* Warehouse
@enduml