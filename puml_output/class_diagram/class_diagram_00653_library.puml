@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Member {
  -long code
  +float address
  -long level
  +validateName()
}
abstract class Loan {
  #Date quantity
  #float duration
  #Date note
  -String phone
  +sendQuantity()
  +deleteLevel()
}
interface Shelf {
  -boolean address
  #double score
  -boolean id
  #int email
  #String createdAt
  +getName()
  +validateLevel()
  +createScore()
  +deleteAddress()
}
class Branch {
  -int quantity
  -float duration
  +float amount
  +float phone
  -Date address
  +processCode()
}
class Renewal {
  +float address
  +long code
  #String total
  +getActive()
  +saveAmount()
}
class Author {
  -long total
  #int email
  -int updatedAt
  -int price
  #double note
  +sendId()
  +deleteNote()
  +validateUpdatedat()
}
class Book {
  -boolean status
  -double quantity
  +sendDuration()
  +deleteActive()
  +calculateTotal()
  +setUpdatedat()
}
Loan ..> Book : "1"
Shelf --|> Renewal
Renewal --> Member : "0..1"
Book --o Author
Member ..|> Author
@enduml