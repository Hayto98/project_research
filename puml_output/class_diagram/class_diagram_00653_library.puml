@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Member {
  -long code
  +float address
  -long level
  +processTotal()
}
interface Loan {
  #Date quantity
  #float duration
  #Date note
  -String phone
  +sendActive()
  +processAddress()
}
interface Shelf {
  +double level
  #float email
  +createDuration()
  +saveAmount()
  +sendStatus()
  +sendNote()
}
class Branch {
  -long id
  #Date active
  +long total
  +createDescription()
  +validateCode()
  +updateType()
}
interface Renewal {
  +long id
  +Date code
  +updateDescription()
  +validateScore()
  +setScore()
  +updateNote()
}
class Author {
  -long total
  #int email
  -int updatedAt
  -int price
  #double note
  +updateName()
  +processUpdatedat()
  +setStatus()
}
class Book {
  #double active
  +double note
  +int type
  #float price
  +validateDuration()
}
Renewal --> Member : "0..1"
Book --o Author
note right of Member : Library domain
@enduml