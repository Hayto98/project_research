@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Payment {
  -int duration
  +Date id
  -float updatedAt
  #Date email
  +setPhone()
  +cancelNote()
  +createType()
}
interface Housekeeping {
  -double name
  #float price
  #int email
  +sendUpdatedat()
}
class Invoice {
  #float duration
  +long description
  +float note
  +createScore()
}
abstract class Guest {
  #String description
  #String total
  -Date createdAt
  +sendStatus()
  +saveAddress()
  +validateCode()
  +processAmount()
}
class Service {
  -Date address
  -long type
  -double quantity
  #float updatedAt
  +setAmount()
  +findPrice()
  +setName()
  +processAddress()
}
abstract class Booking {
  -long duration
  #Date price
  +Date type
  +double address
  +float level
  +sendEmail()
  +setQuantity()
  +deleteDescription()
}
class CheckOut {
  -double amount
  #int id
  #float note
  #double createdAt
  -Date updatedAt
  +validateLevel()
}
Service --* Booking
Payment ..> Booking : "*"
Invoice --|> CheckOut
note right of Payment : Hotel domain
@enduml