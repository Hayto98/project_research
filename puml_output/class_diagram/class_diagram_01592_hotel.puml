@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Payment {
  -int duration
  +Date id
  -float updatedAt
  #Date email
  +cancelStatus()
  +cancelId()
  +validateActive()
}
abstract class Housekeeping {
  -long type
  -double active
  #float amount
  #int name
  +findDuration()
}
class Invoice {
  -boolean level
  +long updatedAt
  +float description
  +processAddress()
}
class Guest {
  #String updatedAt
  -Date description
  -float total
  #String createdAt
  #Date name
  +calculateName()
  +saveUpdatedat()
  +deleteStatus()
}
class Service {
  -int amount
  -Date updatedAt
  -long phone
  -double address
  #float type
  +cancelEmail()
  +updateId()
  +findId()
  +setCreatedat()
}
abstract class Booking {
  -Date name
  -double note
  +sendCreatedat()
  +createActive()
  +createDuration()
  +getPhone()
}
class CheckOut {
  -float code
  #long price
  +long description
  +setActive()
  +sendPrice()
}
Invoice ..|> Guest
Booking --o Payment
CheckOut ..|> Housekeeping
@enduml