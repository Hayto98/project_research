@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
abstract class Message {
  +float createdAt
  +double description
  +Date type
  -double address
  -float id
  +saveEmail()
  +sendCode()
  +validateAddress()
  +findCode()
}
class Report {
  #Date id
  +float createdAt
  -long status
  #long active
  +findScore()
  +setType()
}
class Post {
  #String score
  -long email
  -double level
  -int description
  -String updatedAt
  +processId()
  +findDescription()
  +setAmount()
  +deleteType()
}
abstract class Notification {
  #Date email
  -Date id
  #boolean type
  +double code
  +sendQuantity()
  +calculateNote()
}
class Like {
  +Date amount
  #double active
  +getCreatedat()
  +deleteAmount()
}
class Album {
  #long quantity
  -double note
  #boolean createdAt
  +createDuration()
  +calculateId()
}
Post --o Notification
Post ..> Report : "*"
Like --* Message
@enduml