@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
abstract class Message {
  +float createdAt
  +double description
  +Date type
  -double address
  -float id
  +getNote()
  +createPhone()
  +validateQuantity()
  +getCreatedat()
}
class Report {
  #long quantity
  +long duration
  +deleteNote()
  +sendEmail()
}
class Post {
  #int duration
  #String active
  -long level
  +calculateTotal()
  +updateQuantity()
  +getPrice()
}
interface Notification {
  #Date address
  -Date email
  #boolean id
  +double type
  +boolean code
  +deleteId()
  +deleteActive()
}
class Like {
  -float amount
  -int score
  #long price
  -double createdAt
  #boolean description
  +calculateName()
  +updateQuantity()
}
abstract class Album {
  #float address
  -String description
  -boolean price
  +Date status
  #boolean duration
  +getCreatedat()
  +updateId()
}
Like --o Post
Album --o Message
Message ..|> Report
Album --|> Notification
note right of Message : Social Media domain
@enduml