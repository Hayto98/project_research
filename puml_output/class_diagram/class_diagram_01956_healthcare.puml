@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
abstract class Billing {
  +String email
  +double updatedAt
  #long status
  +String createdAt
  #Date amount
  +findDuration()
  +createScore()
  +processAmount()
  +findCode()
}
interface Diagnosis {
  #float total
  #String updatedAt
  +deleteAddress()
  +savePhone()
  +deleteEmail()
}
interface Patient {
  +Date phone
  +long email
  +createLevel()
  +updateAddress()
}
class Nurse {
  -double phone
  +boolean name
  #double id
  #boolean amount
  +findName()
  +findAddress()
  +findQuantity()
  +findActive()
}
class Prescription {
  #boolean updatedAt
  +boolean price
  -double level
  +saveCode()
}
class Hospital {
  #Date duration
  #double createdAt
  +findPrice()
  +updateDescription()
  +deleteQuantity()
  +getCode()
}
class Ward {
  -Date quantity
  #double description
  -String active
  +boolean level
  -float code
  +updateActive()
  +findName()
}
Diagnosis ..|> Hospital
Diagnosis --o Patient
@enduml