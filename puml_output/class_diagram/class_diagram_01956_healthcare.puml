@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
abstract class Billing {
  +String email
  +double updatedAt
  #long status
  +String createdAt
  #Date amount
  +sendUpdatedat()
  +setPhone()
  +cancelId()
  +calculateUpdatedat()
}
interface Diagnosis {
  +boolean email
  #String updatedAt
  +createStatus()
  +findId()
  +createActive()
}
interface Patient {
  +String email
  #float quantity
  #int phone
  +calculateAmount()
  +sendActive()
  +calculateActive()
  +cancelPrice()
}
interface Nurse {
  #boolean address
  +int type
  -Date code
  +saveLevel()
  +setDuration()
  +validateType()
  +getPrice()
}
class Prescription {
  #Date duration
  #double createdAt
  +sendCreatedat()
  +setLevel()
  +updateNote()
  +createDescription()
}
interface Hospital {
  -double code
  +int total
  #double score
  +getLevel()
  +getAmount()
}
class Ward {
  #double quantity
  +Date total
  -int email
  +processActive()
  +calculateStatus()
  +processUpdatedat()
}
Ward --> Patient : "1..*"
Hospital ..|> Prescription
Diagnosis --* Patient
Patient --> Billing : "*"
Prescription --* Nurse
note right of Billing : Healthcare domain
@enduml