@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Depot {
  +double status
  -long createdAt
  -float level
  +String name
  +cancelPhone()
  +findLevel()
  +updateActive()
  +getType()
}
interface Inventory {
  #Date level
  +long address
  +createStatus()
  +saveCode()
}
interface Customer {
  #boolean type
  -int active
  +double level
  +deleteLevel()
}
class Package {
  #int total
  -double email
  +String type
  +deleteDuration()
}
interface Driver {
  +long name
  +Date amount
  -Date note
  -String active
  +String code
  +saveDescription()
  +sendCreatedat()
  +sendCode()
  +setScore()
}
Customer --> Depot : "0..1"
Package --> Inventory : "0..1"
Inventory ..|> Driver
Depot --> Customer : "0..1"
note right of Depot : Logistics domain
@enduml