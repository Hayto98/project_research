@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Depot {
  +double status
  -long createdAt
  -float level
  +String name
  +deleteDescription()
  +cancelType()
  +cancelId()
  +getActive()
}
interface Inventory {
  #String active
  #long id
  #Date type
  +deleteCreatedat()
  +findPrice()
}
class Customer {
  #float status
  #boolean code
  #long amount
  +String type
  +validateLevel()
  +cancelName()
  +saveId()
  +deleteId()
}
class Package {
  #int createdAt
  -double total
  +String email
  #String type
  +updateQuantity()
  +validateActive()
}
interface Driver {
  +long name
  +Date amount
  -Date note
  -String active
  +String code
  +setScore()
  +getEmail()
  +setAddress()
  +cancelNote()
}
Depot --> Driver : "1..*"
Driver --> Depot : "0..1"
Package --> Inventory : "0..1"
Inventory ..|> Driver
@enduml