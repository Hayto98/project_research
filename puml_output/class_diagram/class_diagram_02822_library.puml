@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Author {
  +double duration
  -Date description
  +boolean note
  +sendScore()
  +sendName()
  +processEmail()
}
interface Librarian {
  #float active
  -Date code
  #boolean description
  +sendAmount()
  +cancelType()
  +deleteCreatedat()
  +processPhone()
}
class Loan {
  #double active
  -float id
  +float createdAt
  +cancelAmount()
  +createType()
}
class Renewal {
  #Date price
  +String address
  +String duration
  -float level
  -String amount
  +saveStatus()
  +setQuantity()
}
class Catalog {
  -boolean description
  +double duration
  -int active
  #long price
  +setLevel()
  +processAmount()
}
interface Reservation {
  #boolean description
  +Date type
  #double price
  -double updatedAt
  -int active
  +sendLevel()
  +cancelAmount()
}
Renewal ..> Loan : "1..*"
Reservation --|> Catalog
@enduml