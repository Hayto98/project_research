@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Driver {
  -long score
  -float quantity
  +Date createdAt
  -long total
  +long active
  +setScore()
  +calculateLevel()
  +calculateEmail()
}
class Manifest {
  +Date score
  +int active
  +validateActive()
  +createTotal()
  +validatePrice()
}
class Route {
  -int note
  +String price
  +String quantity
  #int total
  #double active
  +processStatus()
  +sendDescription()
}
abstract class Inventory {
  -int amount
  #boolean type
  #long note
  -String quantity
  -long phone
  +calculateType()
  +processName()
}
abstract class Vehicle {
  #double id
  -long code
  -int name
  +cancelQuantity()
  +processAddress()
}
abstract class Depot {
  +Date total
  -Date phone
  #Date quantity
  +setNote()
  +saveDuration()
  +findTotal()
  +getCode()
}
Driver --o Inventory
Driver --> Depot : "1"
Depot --|> Driver
@enduml