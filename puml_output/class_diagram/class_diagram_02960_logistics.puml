@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Driver {
  -long score
  -float quantity
  +Date createdAt
  -long total
  +long active
  +saveName()
  +getStatus()
  +sendActive()
}
class Manifest {
  -float description
  -double address
  -boolean level
  +calculatePhone()
  +updateCreatedat()
  +setCreatedat()
  +setCreatedat()
}
interface Route {
  #double createdAt
  -boolean phone
  #long note
  -long price
  +boolean amount
  +validateCode()
  +createEmail()
  +deleteId()
}
abstract class Inventory {
  #double id
  -long code
  -int name
  +processType()
  +deleteTotal()
}
class Vehicle {
  #float status
  #float price
  +float total
  +double score
  +setCode()
  +cancelCode()
  +findCode()
  +getType()
}
class Depot {
  #long score
  #int status
  +createTotal()
  +setDuration()
}
Inventory --o Depot
Vehicle --o Inventory
note right of Driver : Logistics domain
@enduml