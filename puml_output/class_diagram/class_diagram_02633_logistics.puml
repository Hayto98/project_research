@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
interface Customer {
  +double createdAt
  +float price
  #float status
  #double description
  +createId()
  +saveQuantity()
  +processEmail()
}
class Package {
  -long amount
  #double duration
  +boolean active
  #Date address
  -Date email
  +getQuantity()
  +calculateLevel()
}
class Warehouse {
  #boolean createdAt
  #float active
  +double price
  +cancelAddress()
}
interface Inventory {
  -String quantity
  -String duration
  +int active
  -int name
  -Date type
  +updateActive()
}
Customer --|> Warehouse
Inventory --|> Package
@enduml