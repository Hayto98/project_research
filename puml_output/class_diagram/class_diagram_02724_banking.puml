@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Deposit {
  -boolean duration
  -boolean description
  #double level
  +deletePrice()
  +updateLevel()
}
abstract class Account {
  +Date note
  +String active
  -boolean description
  #int phone
  +createId()
  +deleteActive()
}
class Beneficiary {
  #float duration
  #String note
  #String type
  +long active
  +cancelActive()
  +updateUpdatedat()
}
abstract class Transaction {
  #float updatedAt
  #Date phone
  -long amount
  -long name
  +double price
  +validateTotal()
}
Beneficiary --o Account
Deposit ..|> Beneficiary
note right of Deposit : Banking domain
@enduml