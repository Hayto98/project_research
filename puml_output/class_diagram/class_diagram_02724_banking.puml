@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Deposit {
  -boolean duration
  -boolean description
  #double level
  +validateQuantity()
  +deleteAmount()
}
class Account {
  -String duration
  #int phone
  +double note
  #boolean active
  +int description
  +updateDuration()
  +findPhone()
  +deleteType()
}
interface Beneficiary {
  #float quantity
  #String note
  #String type
  +long active
  +saveDuration()
  +updateNote()
}
class Transaction {
  -float type
  +String duration
  #double updatedAt
  +findQuantity()
  +cancelQuantity()
  +deleteCode()
}
Transaction --* Deposit
@enduml