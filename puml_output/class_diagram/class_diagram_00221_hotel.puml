@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Service {
  #int description
  #String updatedAt
  +calculateEmail()
  +processId()
}
class Booking {
  -int level
  -String name
  +Date status
  +getQuantity()
  +createPhone()
  +cancelCreatedat()
}
interface Reservation {
  -String price
  +double level
  +String phone
  +boolean id
  +createPhone()
  +saveScore()
  +validateId()
  +processAddress()
}
interface Restaurant {
  +double type
  #int active
  +long note
  +float level
  -String code
  +saveName()
  +sendPhone()
}
class Guest {
  #float name
  -String phone
  +float updatedAt
  +createQuantity()
  +getPrice()
  +validateTotal()
}
class Staff {
  +double score
  +long status
  -double createdAt
  +processTotal()
}
class CheckOut {
  -Date type
  #int level
  #String duration
  +boolean amount
  +saveType()
  +setType()
}
Service --|> Booking
Staff --|> Reservation
Reservation --> Booking : "*"
note right of Service : Hotel domain
@enduml