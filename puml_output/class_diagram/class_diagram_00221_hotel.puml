@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Service {
  #int description
  #String updatedAt
  +getPhone()
  +calculateDescription()
}
class Booking {
  -int id
  -String createdAt
  +Date updatedAt
  -float name
  +float status
  +validateAmount()
  +sendType()
  +setCode()
}
class Reservation {
  -double score
  #long level
  +float active
  +deleteNote()
  +calculateAddress()
  +findAmount()
}
class Restaurant {
  -long createdAt
  #float active
  +findStatus()
  +saveActive()
  +processStatus()
}
class Guest {
  #boolean address
  #String level
  +double type
  #int score
  +long note
  +processAddress()
}
class Staff {
  #Date amount
  -long name
  +saveEmail()
  +updateTotal()
}
class CheckOut {
  +double status
  -double description
  +boolean email
  +Date score
  #float quantity
  +saveNote()
}
Restaurant --* Service
CheckOut --o Restaurant
CheckOut --o Service
@enduml