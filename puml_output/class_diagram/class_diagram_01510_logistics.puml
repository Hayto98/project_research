@startuml
skinparam defaultFontSize 13
abstract class Customer {
  +double address
  #Date score
  +double total
  +cancelUpdatedat()
  +calculateStatus()
  +processQuantity()
}
class FuelLog {
  +float duration
  -Date score
  +createQuantity()
}
class Tracking {
  #Date email
  +float updatedAt
  +saveCode()
  +saveAmount()
  +deleteAmount()
  +cancelEmail()
}
abstract class Driver {
  #float email
  #Date address
  #int description
  +calculateScore()
  +processQuantity()
  +calculateDescription()
  +getDescription()
}
abstract class Vehicle {
  -int level
  #float active
  #long address
  +findStatus()
  +setType()
  +setName()
}
FuelLog ..> Tracking : "1"
Customer --> Vehicle : "1..*"
Vehicle --|> Driver
@enduml