@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
interface Restaurant {
  +int email
  #int phone
  +validatePhone()
  +deleteActive()
  +calculateName()
}
class Housekeeping {
  +float score
  +Date name
  #String duration
  +sendCode()
  +findDescription()
  +findLevel()
  +updateQuantity()
}
abstract class Reservation {
  #boolean total
  +String amount
  +calculateDuration()
}
class CheckOut {
  #boolean type
  #int price
  -double name
  #Date total
  +createEmail()
  +processName()
  +createStatus()
  +processPhone()
}
class Staff {
  -int id
  #Date status
  -String total
  -long amount
  +long phone
  +createCode()
  +createActive()
  +deletePrice()
  +deleteDescription()
}
class Payment {
  +boolean note
  -long active
  +float createdAt
  #double status
  +getType()
  +sendStatus()
  +sendDuration()
}
class CheckIn {
  +int id
  -int note
  #boolean total
  #int type
  +calculateLevel()
}
Housekeeping --|> CheckOut
Reservation --> Housekeeping : "*"
@enduml