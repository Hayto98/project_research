@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
abstract class Withdrawal {
  #long duration
  #double address
  +saveId()
}
class Interest {
  -Date score
  -boolean updatedAt
  +boolean amount
  -long quantity
  +savePhone()
  +calculatePrice()
  +calculateQuantity()
  +savePrice()
}
class Statement {
  -String total
  +boolean price
  +deleteNote()
  +validateNote()
}
interface Deposit {
  +float score
  #Date address
  -long level
  +long id
  +sendScore()
  +findScore()
  +findId()
  +sendId()
}
class Transaction {
  -String id
  #float quantity
  #String duration
  +deleteName()
  +sendDuration()
  +calculateEmail()
  +saveScore()
}
Deposit ..> Withdrawal : "*"
Statement ..|> Transaction
@enduml