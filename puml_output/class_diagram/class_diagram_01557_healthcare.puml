@startuml
skinparam defaultFontSize 11
class Ward {
  #boolean id
  -Date phone
  -double total
  +Date status
  +deleteEmail()
}
class Treatment {
  -float active
  -double address
  +long status
  #Date type
  #float email
  +saveTotal()
  +findLevel()
}
interface Patient {
  -double quantity
  -Date level
  +getPrice()
  +saveId()
  +validateTotal()
}
class Nurse {
  #long description
  #float note
  -float level
  +double amount
  +updatePhone()
}
class Doctor {
  #Date note
  +Date amount
  #boolean total
  +setAmount()
  +deleteId()
  +calculateActive()
}
Doctor ..> Ward : "0..1"
Nurse --* Doctor
Treatment --* Doctor
note right of Ward : Healthcare domain
@enduml