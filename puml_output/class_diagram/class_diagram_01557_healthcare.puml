@startuml
skinparam defaultFontSize 11
class Ward {
  #boolean id
  -Date phone
  -double total
  +Date status
  +validateQuantity()
}
class Treatment {
  #Date type
  #long active
  +findLevel()
}
abstract class Patient {
  -Date email
  #boolean duration
  #int note
  #double createdAt
  +createQuantity()
}
interface Nurse {
  #String note
  -double total
  +boolean phone
  -int name
  -double price
  +sendUpdatedat()
  +deleteCode()
}
abstract class Doctor {
  +long type
  #float status
  +deleteScore()
  +sendCode()
  +setCode()
}
Nurse ..> Ward : "1..*"
Ward ..|> Treatment
@enduml