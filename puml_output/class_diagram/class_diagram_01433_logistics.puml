@startuml
skinparam monochrome true
abstract class Package {
  #Date code
  -float updatedAt
  -Date note
  +createScore()
  +findScore()
}
interface Depot {
  #double amount
  -long type
  -String updatedAt
  +calculatePhone()
  +deleteType()
  +getDescription()
  +sendAddress()
}
class Warehouse {
  +String address
  -String score
  +processScore()
}
class Route {
  -int type
  #Date note
  -double id
  #long active
  +processScore()
  +validatePhone()
  +getAddress()
}
interface Vehicle {
  +boolean description
  #long level
  +saveLevel()
  +setCode()
  +validateAddress()
}
class DeliveryNote {
  -long active
  -float phone
  -double quantity
  +findName()
  +savePrice()
  +calculatePhone()
}
class Tracking {
  -int duration
  -long note
  -boolean email
  #String level
  #float quantity
  +sendAddress()
  +getQuantity()
}
Vehicle --|> Package
Depot ..|> Vehicle
Package --|> Route
Vehicle --* Route
Vehicle --o Tracking
@enduml