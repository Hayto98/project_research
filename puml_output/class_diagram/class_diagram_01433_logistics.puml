@startuml
skinparam monochrome true
abstract class Package {
  #Date code
  -float updatedAt
  -Date note
  +updateQuantity()
  +cancelAmount()
}
class Depot {
  +Date updatedAt
  -long total
  #float note
  -Date email
  -String address
  +sendCreatedat()
  +setTotal()
  +getCode()
}
class Warehouse {
  -int type
  #Date note
  -double id
  #long active
  +setTotal()
  +sendName()
  +deleteLevel()
}
class Route {
  +boolean level
  -long phone
  -long email
  -float updatedAt
  +processQuantity()
  +cancelLevel()
  +createAmount()
}
abstract class Vehicle {
  -long email
  -boolean note
  #String quantity
  #float type
  +long description
  +setCreatedat()
}
interface DeliveryNote {
  #float status
  -long total
  +boolean name
  +cancelStatus()
  +createScore()
  +processNote()
  +saveAmount()
}
class Tracking {
  #Date email
  -double type
  -int createdAt
  -Date total
  +validateAddress()
  +calculateDescription()
  +validateDuration()
  +saveLevel()
}
Warehouse ..> Depot : "1..*"
DeliveryNote --|> Depot
Package --* Route
Depot --> Tracking : "1..*"
Vehicle --|> Warehouse
note right of Package : Logistics domain
@enduml