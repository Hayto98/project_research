@startuml
skinparam shadowing true
class Post {
  #double createdAt
  +String status
  -double name
  #boolean code
  #Date amount
  +getUpdatedat()
  +processLevel()
}
class Album {
  -boolean name
  +float score
  +createCreatedat()
  +findPrice()
  +processUpdatedat()
  +processScore()
}
class Report {
  +boolean id
  +float active
  +sendAmount()
  +deleteTotal()
}
class Notification {
  -double createdAt
  #long quantity
  #int type
  -int updatedAt
  +createName()
  +calculateUpdatedat()
  +saveCreatedat()
}
class Like {
  +float active
  -boolean type
  +String status
  +updateId()
  +cancelScore()
  +sendAmount()
  +getCreatedat()
}
Album ..> Report : "*"
Notification ..|> Report
Like ..|> Report
note right of Post : Social Media domain
@enduml