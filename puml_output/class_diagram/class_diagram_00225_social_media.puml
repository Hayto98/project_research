@startuml
skinparam shadowing true
class Post {
  #double createdAt
  +String status
  -double name
  #boolean code
  #Date amount
  +setName()
  +updateStatus()
}
abstract class Album {
  #double active
  #int id
  #double name
  +getTotal()
  +saveLevel()
  +updateScore()
}
abstract class Report {
  #String updatedAt
  #int note
  #String score
  +boolean amount
  +int id
  +updatePhone()
  +updateCode()
  +getName()
  +cancelStatus()
}
class Notification {
  -double quantity
  #long type
  #int updatedAt
  +validateLevel()
  +processPrice()
  +getPrice()
  +cancelName()
}
class Like {
  +int name
  #Date total
  -String updatedAt
  +float createdAt
  +sendQuantity()
  +validateQuantity()
  +validateEmail()
}
Album --> Post : "0..1"
Post ..> Album : "0..1"
Report ..|> Notification
@enduml