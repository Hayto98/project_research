@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Grade {
  #String code
  -boolean duration
  +updateAmount()
  +saveUpdatedat()
}
class Enrollment {
  -double status
  -int code
  -boolean address
  +updatePrice()
}
class Student {
  #Date code
  -boolean amount
  -double duration
  #double type
  +createId()
  +calculateDescription()
  +getScore()
  +createEmail()
}
interface Library {
  +long total
  #long level
  +calculateNote()
  +sendCode()
}
class Department {
  +long duration
  #String score
  -String name
  +getDuration()
  +deleteStatus()
  +processStatus()
  +cancelAmount()
}
abstract class Assignment {
  +double email
  -String duration
  -boolean updatedAt
  +calculateCode()
}
Assignment ..> Library : "1..*"
Department --o Student
Grade --* Department
note right of Grade : Education domain
@enduml