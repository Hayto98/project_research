@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
abstract class Inventory {
  +int name
  #double active
  #Date status
  #Date type
  +cancelTotal()
  +updateDuration()
  +sendPrice()
}
class Tracking {
  -int status
  #long duration
  +float note
  +Date active
  +processAmount()
  +sendPrice()
  +sendEmail()
  +findScore()
}
abstract class Depot {
  #Date description
  #String updatedAt
  +processLevel()
  +calculateType()
  +saveDuration()
}
class Warehouse {
  -boolean quantity
  -Date id
  +String score
  +saveName()
  +calculateEmail()
}
abstract class Vehicle {
  +int total
  +Date name
  -boolean address
  #double createdAt
  -int type
  +processUpdatedat()
  +savePhone()
}
abstract class Driver {
  #Date address
  +double duration
  -boolean status
  -boolean type
  +findActive()
  +cancelUpdatedat()
  +createDescription()
}
Depot ..|> Driver
Depot --o Vehicle
Inventory ..|> Vehicle
@enduml