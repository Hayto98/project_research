@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Student {
  +long duration
  -int amount
  -long quantity
  -long active
  +int email
  +getPhone()
}
class Exam {
  #Date createdAt
  -boolean amount
  -double duration
  #int name
  #float price
  +sendDuration()
  +setLevel()
  +createStatus()
  +calculateAmount()
}
abstract class Attendance {
  #boolean amount
  -boolean code
  -Date status
  +double price
  +boolean description
  +updateId()
  +updateActive()
}
class Course {
  -float description
  +String createdAt
  +long amount
  +getLevel()
  +deletePrice()
}
Exam --o Student
Course --> Student : "*"
@enduml