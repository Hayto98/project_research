@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
abstract class Comment {
  +long duration
  +boolean createdAt
  +updateDescription()
}
class Message {
  -int active
  -long updatedAt
  +validateCreatedat()
  +saveCreatedat()
}
interface Profile {
  +long total
  #String duration
  +boolean type
  +int status
  +findActive()
}
class User {
  #boolean email
  #float name
  +float quantity
  #double status
  #boolean phone
  +setPrice()
  +validateType()
  +deleteDescription()
}
interface Report {
  #Date name
  #double address
  #boolean quantity
  +cancelCode()
}
interface Album {
  #String updatedAt
  -int code
  -double quantity
  +deleteNote()
  +calculateTotal()
}
Album --> Message : "1..*"
Message ..> Profile : "0..1"
@enduml