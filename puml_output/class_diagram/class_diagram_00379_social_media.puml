@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
abstract class Comment {
  +long duration
  +boolean createdAt
  +updateName()
}
class Message {
  -float phone
  #int createdAt
  +long note
  +calculateTotal()
  +cancelType()
  +cancelStatus()
}
class Profile {
  +Date name
  #String id
  -float score
  +boolean duration
  +saveEmail()
  +getQuantity()
  +saveStatus()
  +validateDuration()
}
interface User {
  #long type
  #boolean level
  +getAddress()
  +saveQuantity()
}
abstract class Report {
  +String type
  #boolean description
  +saveId()
  +processAmount()
  +createNote()
}
interface Album {
  #long name
  +float duration
  -Date updatedAt
  +updateName()
  +setPhone()
}
Message --* Comment
User --> Message : "0..1"
note right of Comment : Social Media domain
@enduml