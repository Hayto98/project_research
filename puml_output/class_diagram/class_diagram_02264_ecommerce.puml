@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Cart {
  #Date code
  +String level
  +String name
  #boolean price
  +setEmail()
  +getUpdatedat()
  +processNote()
}
class Wishlist {
  -float id
  +int total
  -boolean description
  -boolean address
  #String note
  +calculatePrice()
}
class Shipment {
  +double code
  #boolean type
  -boolean quantity
  #boolean note
  #String id
  +getDescription()
  +saveAddress()
  +saveStatus()
}
interface Category {
  #float name
  #int amount
  +int duration
  #int active
  -double note
  +cancelId()
}
class Invoice {
  +long quantity
  +String price
  -Date address
  -int duration
  +boolean id
  +setType()
  +saveScore()
}
interface Return {
  -double name
  #int total
  +createPhone()
}
Wishlist --|> Cart
Wishlist --|> Shipment
Wishlist ..|> Category
Wishlist --|> Invoice
Shipment ..|> Category
@enduml