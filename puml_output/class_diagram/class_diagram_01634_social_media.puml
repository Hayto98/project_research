@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
interface Story {
  -boolean active
  +String type
  #boolean name
  +cancelPrice()
  +updateUpdatedat()
}
class Notification {
  #int name
  #int price
  #float status
  -boolean address
  -Date level
  +createDuration()
  +validateUpdatedat()
  +cancelNote()
  +setAddress()
}
abstract class Report {
  #double price
  +long score
  +updateQuantity()
  +updateScore()
  +validateTotal()
  +updatePhone()
}
class Comment {
  -String description
  -String type
  -int code
  -float id
  +setLevel()
}
class Like {
  -double code
  -double createdAt
  #Date total
  +long email
  +cancelName()
  +sendCreatedat()
  +saveType()
}
class Hashtag {
  -long level
  #long duration
  +int score
  +float createdAt
  -boolean updatedAt
  +getStatus()
  +processCode()
}
class Group {
  +String phone
  +Date updatedAt
  -Date address
  +cancelQuantity()
  +updateEmail()
}
Like ..|> Group
Like --|> Report
Comment --o Like
@enduml