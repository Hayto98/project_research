@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
abstract class Teller {
  +long address
  -long price
  #boolean level
  #Date status
  +Date duration
  +deleteActive()
  +processType()
  +getScore()
}
class Card {
  #int phone
  #int id
  +int price
  +getTotal()
  +findNote()
  +createNote()
}
class Transfer {
  +String score
  #long price
  +calculatePrice()
  +saveAddress()
  +getCode()
  +processAddress()
}
abstract class Branch {
  -boolean code
  +Date name
  -double address
  -Date duration
  +calculateDuration()
  +savePrice()
  +calculateId()
}
abstract class Beneficiary {
  +long price
  -String status
  #double createdAt
  +sendNote()
  +cancelPhone()
  +sendAmount()
}
Teller ..|> Branch
Teller ..> Beneficiary : "1"
@enduml