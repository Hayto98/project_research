@startuml
skinparam defaultFontSize 11
abstract class Patient {
  +int phone
  +boolean note
  #int id
  +saveAmount()
}
class Treatment {
  -long description
  #boolean id
  -double address
  +long active
  +Date score
  +findQuantity()
  +findActive()
}
interface Diagnosis {
  #double updatedAt
  +float name
  +processType()
  +getActive()
}
interface Prescription {
  +float total
  -int name
  +long active
  +boolean id
  +calculateScore()
  +findScore()
  +updateActive()
  +sendLevel()
}
class Hospital {
  -String phone
  #float type
  -String name
  +getAddress()
  +findDuration()
  +deleteNote()
}
class Appointment {
  #boolean type
  -boolean phone
  -Date amount
  -int createdAt
  +sendName()
}
class MedicalRecord {
  +String note
  #boolean address
  +boolean createdAt
  +double type
  +cancelPrice()
  +getEmail()
  +calculateDuration()
  +updateId()
}
Patient --* Appointment
Appointment --> Treatment : "1..*"
Appointment ..> MedicalRecord : "1"
MedicalRecord --> Hospital : "1..*"
MedicalRecord --|> Diagnosis
@enduml