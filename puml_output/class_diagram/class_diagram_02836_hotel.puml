@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Housekeeping {
  -float type
  +long description
  -double total
  +createType()
  +validateDescription()
  +findDuration()
}
class CheckIn {
  +String price
  -float phone
  #long code
  #double type
  +cancelCode()
  +sendNote()
  +validateQuantity()
}
abstract class Booking {
  #String duration
  +String price
  +long active
  +updateDescription()
  +findDescription()
  +setAmount()
}
interface Staff {
  #int score
  -double email
  +double code
  +boolean quantity
  #double description
  +sendActive()
}
class Payment {
  #int level
  +Date active
  #float duration
  #Date status
  -double createdAt
  +cancelScore()
  +updateAmount()
  +getType()
}
Booking --> Staff : "1"
Booking ..|> CheckIn
Payment --> Staff : "0..1"
Payment --|> CheckIn
@enduml