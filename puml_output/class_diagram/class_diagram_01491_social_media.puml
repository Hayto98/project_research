@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
abstract class Profile {
  +long email
  -boolean address
  #double createdAt
  +boolean name
  +String description
  +setDuration()
  +calculateActive()
  +saveActive()
  +saveStatus()
}
class Follower {
  +float score
  +long price
  -boolean quantity
  #int phone
  #Date amount
  +setName()
  +getPhone()
  +calculateCreatedat()
  +findLevel()
}
interface Hashtag {
  #Date total
  -double quantity
  +setPhone()
  +calculateNote()
  +getQuantity()
}
class Story {
  -double updatedAt
  +Date price
  -Date description
  +int total
  +calculateEmail()
  +getPrice()
  +sendStatus()
}
Follower ..> Story : "1..*"
Follower ..> Profile : "*"
Hashtag --|> Follower
note right of Profile : Social Media domain
@enduml