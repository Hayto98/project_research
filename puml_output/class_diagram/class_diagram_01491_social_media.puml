@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
abstract class Profile {
  +long email
  -boolean address
  #double createdAt
  +boolean name
  +String description
  +cancelStatus()
  +setPhone()
  +createDuration()
  +getScore()
}
interface Follower {
  #boolean address
  -Date type
  +processEmail()
  +updatePhone()
  +cancelDescription()
}
interface Hashtag {
  -boolean amount
  #int createdAt
  #Date updatedAt
  -String email
  +savePhone()
}
class Story {
  #Date createdAt
  -double level
  -String code
  -double total
  -String quantity
  +validateStatus()
  +updateCode()
  +createActive()
}
Follower ..|> Story
Story --o Follower
Follower --* Hashtag
@enduml