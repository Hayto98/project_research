@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Wishlist {
  +long phone
  #Date name
  -long quantity
  -int price
  #double description
  +validateNote()
  +createQuantity()
}
class Coupon {
  #int email
  -String description
  +processCode()
  +findNote()
  +deleteNote()
}
class Warehouse {
  #int type
  -long quantity
  +String score
  +String level
  #String address
  +setPrice()
  +createPhone()
}
interface Return {
  #double quantity
  #int price
  +validateQuantity()
  +setId()
  +saveTotal()
  +validateTotal()
}
class Category {
  #float code
  #long duration
  +setId()
  +validateNote()
  +findDescription()
}
class Supplier {
  +float code
  -String createdAt
  +long email
  +processTotal()
}
Supplier ..> Warehouse : "0..1"
Coupon ..|> Wishlist
Return --* Coupon
@enduml