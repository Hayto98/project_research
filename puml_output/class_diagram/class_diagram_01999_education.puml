@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Exam {
  #long status
  -long updatedAt
  +Date active
  -int total
  +deleteName()
}
class Library {
  +int address
  -int type
  #long score
  +calculateQuantity()
  +cancelStatus()
  +getDuration()
}
class Schedule {
  +String status
  -String phone
  #Date level
  +validateLevel()
  +validateStatus()
}
abstract class Grade {
  -Date status
  -float duration
  #String score
  -long level
  +findDescription()
  +calculateDescription()
  +setPhone()
}
class Course {
  #long description
  #Date quantity
  +saveAmount()
  +saveEmail()
  +getAmount()
  +calculateUpdatedat()
}
class Attendance {
  -Date duration
  #boolean id
  +savePhone()
  +setPhone()
}
interface Student {
  +String duration
  #String score
  -long code
  -Date name
  #boolean price
  +calculateAddress()
  +createPrice()
  +setAddress()
}
Library --> Grade : "1"
Schedule ..> Exam : "*"
Exam --o Grade
Course ..> Library : "1"
Library --> Exam : "1..*"
@enduml