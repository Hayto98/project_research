@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Exam {
  #long status
  -long updatedAt
  +Date active
  -int total
  +createCreatedat()
}
class Library {
  -int type
  #long score
  -double name
  +float amount
  +updateStatus()
  +validatePhone()
  +updateCode()
}
class Schedule {
  -float description
  +String price
  +createNote()
}
interface Grade {
  -boolean note
  #boolean phone
  +getDescription()
}
class Course {
  +boolean total
  +double note
  #boolean name
  #int amount
  +cancelScore()
}
abstract class Attendance {
  +String name
  #String price
  +createQuantity()
  +findDuration()
  +sendAddress()
}
class Student {
  -String score
  #boolean type
  #double description
  +double level
  -boolean code
  +findName()
  +updateName()
}
Course ..> Attendance : "1..*"
Course --* Grade
Exam --* Student
Schedule --* Grade
Course --|> Exam
Student --|> Course
note right of Exam : Education domain
@enduml