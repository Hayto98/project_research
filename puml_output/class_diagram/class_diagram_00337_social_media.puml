@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Post {
  +Date name
  +String total
  -float level
  #long email
  +sendQuantity()
  +findUpdatedat()
  +sendLevel()
  +createTotal()
}
interface Message {
  -int name
  +float active
  +Date price
  -boolean id
  #long amount
  +processPrice()
  +validateQuantity()
  +createCode()
}
class User {
  #long score
  +String email
  +int description
  +createDescription()
  +cancelPhone()
}
class Follower {
  +long note
  +double description
  +processName()
  +createScore()
}
class Profile {
  +int phone
  #int type
  +setEmail()
  +saveScore()
}
class Story {
  +Date quantity
  +Date description
  +saveLevel()
  +calculateStatus()
  +setPhone()
  +updateId()
}
User --* Message
Post ..|> Follower
Follower --> Story : "0..1"
Story ..> Profile : "*"
Message ..> Post : "*"
note right of Post : Social Media domain
@enduml