@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Post {
  +Date name
  +String total
  -float level
  #long email
  +setAddress()
  +updateLevel()
  +updateId()
  +cancelType()
}
class Message {
  +boolean total
  -boolean active
  #String level
  +float duration
  +createCode()
  +updateDescription()
  +setActive()
  +validateEmail()
}
abstract class User {
  -long quantity
  #String type
  +int price
  #long address
  +processNote()
  +cancelAddress()
}
class Follower {
  +long name
  +boolean description
  +createType()
  +findTotal()
  +updateCode()
}
class Profile {
  +long note
  +double description
  +cancelQuantity()
  +calculateId()
}
class Story {
  +int code
  #int phone
  +String type
  +deleteLevel()
  +updateAddress()
  +setQuantity()
}
Post ..|> User
Post ..> Message : "*"
@enduml