@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Transaction {
  -Date id
  #String price
  #Date level
  #double type
  #String duration
  +cancelType()
  +validateActive()
  +createCreatedat()
  +findType()
}
class Withdrawal {
  #Date description
  +boolean type
  +Date phone
  +setEmail()
}
class Account {
  -float note
  -boolean phone
  -boolean address
  +getDescription()
  +deleteAddress()
}
abstract class Interest {
  #String quantity
  #Date description
  +String status
  #Date active
  +sendQuantity()
  +findStatus()
  +getPrice()
}
interface Transfer {
  +long address
  #long id
  +double score
  #double phone
  +validatePhone()
  +setAmount()
  +calculateEmail()
  +updateCode()
}
abstract class Beneficiary {
  #boolean quantity
  -int description
  +double email
  #Date code
  +saveNote()
  +validateType()
}
class Loan {
  #Date total
  -int createdAt
  #Date amount
  +createCreatedat()
  +calculatePhone()
  +updateLevel()
  +setScore()
}
Transfer ..> Account : "1..*"
Transfer --|> Loan
Loan ..> Account : "*"
Beneficiary --|> Account
note right of Transaction : Banking domain
@enduml