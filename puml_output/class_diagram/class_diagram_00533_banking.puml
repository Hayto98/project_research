@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Transaction {
  -Date id
  #String price
  #Date level
  #double type
  #String duration
  +findDescription()
  +getId()
  +updateCode()
  +findCode()
}
interface Withdrawal {
  +Date createdAt
  -long type
  #Date id
  +boolean description
  +setCode()
  +saveDescription()
}
interface Account {
  +boolean status
  +double email
  +setEmail()
  +deleteActive()
  +getDescription()
}
abstract class Interest {
  -double duration
  #boolean updatedAt
  -long id
  +String description
  #boolean active
  +setPrice()
}
class Transfer {
  -Date quantity
  +String score
  +saveActive()
  +getNote()
  +calculateName()
  +setCode()
}
class Beneficiary {
  -Date name
  -double quantity
  -long level
  +int amount
  +deleteName()
  +processDuration()
  +findNote()
  +deleteAmount()
}
class Loan {
  -int description
  +double email
  #Date code
  #int active
  +createActive()
  +sendCreatedat()
  +validateAmount()
  +findId()
}
Loan ..|> Withdrawal
Beneficiary --o Loan
Withdrawal ..> Transfer : "*"
Account --o Withdrawal
@enduml