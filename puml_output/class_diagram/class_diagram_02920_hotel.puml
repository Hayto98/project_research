@startuml

abstract class Booking {
  -Date amount
  +float price
  +updateLevel()
  +createDescription()
  +saveUpdatedat()
  +createId()
}
class Guest {
  #Date updatedAt
  -String quantity
  #float price
  +Date type
  #int status
  +cancelCreatedat()
}
class CheckOut {
  +boolean id
  #int note
  #Date type
  +getStatus()
  +cancelId()
  +getTotal()
  +createStatus()
}
class Staff {
  -double score
  #int code
  -boolean name
  +Date address
  #boolean createdAt
  +deleteUpdatedat()
  +processDescription()
  +getEmail()
}
class Invoice {
  #Date note
  #Date status
  #long amount
  -String email
  -boolean quantity
  +calculateNote()
  +deleteScore()
}
class Room {
  -Date createdAt
  #boolean id
  +String description
  -boolean type
  +setPrice()
  +sendAddress()
  +cancelCreatedat()
  +getUpdatedat()
}
Staff ..|> CheckOut
Invoice ..> Staff : "*"
note right of Booking : Hotel domain
@enduml