@startuml
skinparam monochrome true
abstract class Invoice {
  -double address
  -double description
  -double total
  -int duration
  +createDuration()
  +createUpdatedat()
}
interface Category {
  +boolean score
  -boolean name
  #long type
  -String level
  +saveAmount()
  +cancelDescription()
  +getStatus()
}
class Supplier {
  #long price
  +boolean duration
  +int updatedAt
  +Date code
  #String quantity
  +calculateDuration()
  +calculatePrice()
}
interface Product {
  +boolean total
  -long quantity
  +float code
  +cancelCode()
  +deleteScore()
  +calculateStatus()
}
interface Coupon {
  +int email
  -Date price
  #Date note
  +boolean createdAt
  +createId()
  +findEmail()
  +deleteType()
  +findEmail()
}
Coupon --o Supplier
Product --* Supplier
note right of Invoice : Ecommerce domain
@enduml