@startuml
skinparam monochrome true
abstract class Invoice {
  -double address
  -double description
  -double total
  -int duration
  +updateLevel()
  +deleteLevel()
}
interface Category {
  -String updatedAt
  +boolean score
  -boolean email
  #long name
  +processCreatedat()
  +updatePrice()
  +setActive()
  +createStatus()
}
class Supplier {
  +String level
  #double description
  -double name
  +getLevel()
  +setTotal()
}
interface Product {
  +Date amount
  #String score
  #int updatedAt
  -boolean duration
  +sendStatus()
  +saveName()
  +getCreatedat()
  +calculateAddress()
}
abstract class Coupon {
  -String code
  -boolean amount
  +int score
  #double note
  +createLevel()
}
Supplier --o Coupon
Product --|> Category
Category ..> Supplier : "1"
Coupon --* Product
@enduml