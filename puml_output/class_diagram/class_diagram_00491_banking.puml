@startuml
skinparam defaultFontSize 11
class Withdrawal {
  -double email
  -long duration
  +sendDuration()
  +sendScore()
  +saveStatus()
}
class Statement {
  +double id
  +double description
  #boolean phone
  -boolean note
  +createLevel()
  +sendType()
  +savePhone()
  +saveName()
}
interface Transaction {
  +int note
  +boolean level
  +String type
  #boolean amount
  #boolean code
  +processTotal()
  +createPhone()
  +updatePrice()
}
class Teller {
  #float score
  -String active
  +findScore()
  +processPhone()
}
abstract class Transfer {
  +String score
  #boolean quantity
  #int type
  +int active
  +int description
  +cancelStatus()
}
class Account {
  -double price
  +long createdAt
  -String description
  -boolean amount
  +updateStatus()
  +saveId()
  +savePhone()
  +saveAddress()
}
class Customer {
  -int description
  -double duration
  +setTotal()
  +sendActive()
  +updateTotal()
}
Customer ..|> Teller
Transfer --> Teller : "0..1"
Statement --* Account
Statement --> Customer : "1"
Transaction --* Statement
note right of Withdrawal : Banking domain
@enduml