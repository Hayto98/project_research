@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Album {
  -int code
  #Date level
  +getDescription()
  +findAddress()
}
class Report {
  -float amount
  #Date price
  #boolean type
  +double total
  #double name
  +saveCreatedat()
  +validateName()
}
class Message {
  +Date updatedAt
  -float note
  #float address
  +long score
  +cancelName()
  +saveCreatedat()
  +saveDescription()
}
class Like {
  #long email
  -String name
  -float address
  +processAddress()
  +getAmount()
}
class Comment {
  -int phone
  #String id
  +float code
  -boolean address
  +String updatedAt
  +validateNote()
  +calculateStatus()
  +cancelEmail()
}
Report --o Album
Report --> Comment : "0..1"
Message --|> Like
note right of Album : Social Media domain
@enduml