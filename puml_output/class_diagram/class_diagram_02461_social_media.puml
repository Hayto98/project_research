@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Album {
  -int code
  #Date level
  +getPrice()
  +setName()
}
class Report {
  -double id
  +double type
  #Date amount
  #boolean price
  +processType()
}
interface Message {
  -float amount
  +Date createdAt
  -float address
  -boolean name
  #long level
  +getAmount()
  +cancelCode()
}
class Like {
  #String phone
  +long name
  +long createdAt
  #long description
  +getLevel()
  +getId()
  +saveLevel()
  +createUpdatedat()
}
class Comment {
  -String address
  +long id
  +double amount
  +boolean updatedAt
  +String total
  +sendAmount()
  +saveAddress()
  +setUpdatedat()
}
Message --o Comment
Like --> Album : "1..*"
Message --|> Report
Like --> Report : "0..1"
@enduml