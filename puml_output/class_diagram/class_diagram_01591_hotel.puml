@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
abstract class Staff {
  -Date updatedAt
  #int price
  +Date note
  -double createdAt
  +validateActive()
  +updateNote()
  +sendTotal()
}
class Service {
  #double description
  +int status
  +deleteScore()
}
interface Housekeeping {
  #double price
  -String name
  -int status
  -Date note
  #float phone
  +createDescription()
  +updateScore()
  +calculateScore()
}
interface Room {
  -int total
  #boolean description
  +createAddress()
  +updateCode()
}
abstract class Restaurant {
  +boolean description
  -String active
  +findAddress()
  +deleteUpdatedat()
  +cancelScore()
  +sendCode()
}
abstract class Invoice {
  -long price
  #long id
  +sendCode()
  +saveUpdatedat()
  +deleteType()
}
abstract class Payment {
  +int description
  +int amount
  +sendId()
  +calculateStatus()
  +calculateName()
}
Invoice --|> Housekeeping
Invoice ..|> Staff
Restaurant --|> Staff
Invoice ..> Room : "*"
@enduml