@startuml
skinparam monochrome true
skinparam defaultFontSize 13
interface Enrollment {
  -String email
  +boolean duration
  +boolean updatedAt
  +validatePrice()
  +setId()
  +deleteStatus()
  +updateNote()
}
abstract class Book {
  +double price
  #double active
  #double quantity
  +boolean level
  -double score
  +sendAddress()
}
abstract class Assignment {
  +String updatedAt
  -boolean address
  #long name
  -long createdAt
  #double amount
  +sendPrice()
  +sendAddress()
  +saveTotal()
}
abstract class Grade {
  +float createdAt
  -Date code
  #Date duration
  -int score
  #String id
  +getLevel()
}
class Classroom {
  #long name
  #long status
  +createDescription()
  +updateDuration()
  +processTotal()
}
class Exam {
  +float description
  -float note
  -int price
  -String id
  +setCreatedat()
  +setName()
  +processAddress()
}
Book --o Exam
Grade --|> Book
@enduml