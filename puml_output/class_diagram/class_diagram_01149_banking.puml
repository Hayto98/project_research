@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
interface Teller {
  +long code
  +Date active
  +processUpdatedat()
}
interface Interest {
  #Date address
  -Date price
  +updateDescription()
}
abstract class Transfer {
  #boolean phone
  +int id
  #float price
  +Date name
  -String code
  +setCode()
  +cancelType()
}
class Statement {
  -boolean note
  -int price
  +updateEmail()
  +validateDescription()
  +updateNote()
}
Transfer --> Interest : "1"
Transfer ..|> Teller
@enduml