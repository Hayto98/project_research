@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
abstract class Category {
  #float code
  -boolean score
  #long total
  -String phone
  +float createdAt
  +findScore()
  +cancelCreatedat()
}
class Warehouse {
  -Date address
  -double type
  +processQuantity()
  +deleteCode()
  +createNote()
  +updatePrice()
}
class Order {
  +float total
  -double description
  +deletePhone()
  +deleteEmail()
  +setName()
}
interface Invoice {
  +int email
  #double createdAt
  #String score
  -Date type
  -long code
  +cancelEmail()
}
interface Wishlist {
  -long code
  #float phone
  +findNote()
  +validateCode()
  +cancelDuration()
  +processType()
}
class Shipment {
  -boolean status
  -String code
  +String createdAt
  +getDescription()
}
Invoice ..> Shipment : "0..1"
Category --o Shipment
Wishlist ..> Shipment : "0..1"
note right of Category : Ecommerce domain
@enduml