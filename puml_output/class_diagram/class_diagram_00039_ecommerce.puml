@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
abstract class Category {
  #float code
  -boolean score
  #long total
  -String phone
  +float createdAt
  +calculateLevel()
  +createTotal()
}
interface Warehouse {
  -long code
  #long name
  -Date address
  +setPrice()
  +findActive()
  +sendDescription()
  +processDescription()
}
class Order {
  +Date quantity
  -Date note
  +calculatePrice()
}
class Invoice {
  +float description
  -float id
  +long total
  +String note
  #float phone
  +deleteCreatedat()
  +calculateNote()
  +deleteTotal()
  +setCreatedat()
}
interface Wishlist {
  #String duration
  -Date code
  -long status
  +boolean description
  -boolean type
  +getType()
}
class Shipment {
  -float address
  +float score
  #float note
  #double level
  +saveTotal()
  +processStatus()
  +createDescription()
  +findEmail()
}
Category ..|> Shipment
Order --* Wishlist
@enduml