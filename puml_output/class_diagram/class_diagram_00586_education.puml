@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Attendance {
  -Date note
  +Date updatedAt
  #Date total
  -boolean price
  #double code
  +setEmail()
  +cancelActive()
}
abstract class Grade {
  -boolean phone
  +float amount
  +updateScore()
}
class Assignment {
  #boolean type
  -double total
  -String active
  +findDescription()
  +getStatus()
  +validateQuantity()
  +getPhone()
}
class Library {
  #Date name
  -Date address
  -double price
  #double code
  +saveCode()
}
Assignment --> Attendance : "1"
Library --o Grade
note right of Attendance : Education domain
@enduml