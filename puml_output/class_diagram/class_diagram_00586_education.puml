@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Attendance {
  -Date note
  +Date updatedAt
  #Date total
  -boolean price
  #double code
  +findNote()
  +validateAddress()
}
interface Grade {
  #float score
  +float name
  +int phone
  #boolean amount
  #float note
  +setAddress()
  +saveQuantity()
}
abstract class Assignment {
  -String active
  -Date level
  #int score
  +Date address
  +long total
  +updateDuration()
  +saveScore()
  +cancelScore()
}
class Library {
  #Date name
  -Date address
  -double price
  #double code
  +validatePrice()
}
Attendance --* Assignment
@enduml