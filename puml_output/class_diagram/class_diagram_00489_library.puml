@startuml
skinparam shadowing true
abstract class Catalog {
  +int price
  -float type
  +float email
  +updateActive()
  +sendAddress()
  +processId()
}
interface Fine {
  -String updatedAt
  #Date code
  +createQuantity()
  +createName()
  +getId()
}
interface Loan {
  +boolean price
  #float level
  -int score
  -double createdAt
  #float duration
  +processId()
  +getScore()
  +saveName()
}
abstract class Reservation {
  #Date active
  +int code
  -String id
  #Date name
  +updateType()
}
class Branch {
  +double score
  -double createdAt
  -double level
  -boolean description
  +validateQuantity()
  +calculateId()
  +createPhone()
}
class Publisher {
  -String level
  +boolean email
  +processId()
  +deleteCreatedat()
}
class Renewal {
  #float status
  +Date active
  -int duration
  +sendActive()
  +processUpdatedat()
}
Renewal ..> Fine : "1..*"
Branch ..|> Publisher
Loan --|> Catalog
note right of Catalog : Library domain
@enduml