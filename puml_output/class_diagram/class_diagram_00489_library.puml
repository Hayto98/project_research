@startuml
skinparam shadowing true
abstract class Catalog {
  +int price
  -float type
  +float email
  +getTotal()
  +processAddress()
  +setScore()
}
interface Fine {
  +double type
  +boolean id
  #long status
  -long updatedAt
  +calculateEmail()
  +saveId()
  +updateId()
}
class Loan {
  +boolean price
  #float level
  -int score
  -double createdAt
  #float duration
  +deletePrice()
  +setScore()
  +processCode()
}
class Reservation {
  #String total
  #String email
  +findUpdatedat()
}
class Branch {
  +float price
  +double id
  +long active
  +updateDescription()
  +processScore()
}
class Publisher {
  -double total
  -boolean email
  -float price
  +createQuantity()
  +saveName()
  +cancelTotal()
}
class Renewal {
  +int code
  #int name
  -float email
  +float note
  +processActive()
  +cancelDescription()
}
Fine --> Catalog : "1"
Branch ..> Fine : "*"
@enduml