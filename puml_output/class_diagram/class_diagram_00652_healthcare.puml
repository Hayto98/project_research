@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Diagnosis {
  #Date name
  -boolean phone
  +validateCode()
  +updateAmount()
  +createLevel()
  +cancelStatus()
}
interface Appointment {
  +Date quantity
  -boolean amount
  +Date phone
  +getAddress()
  +saveNote()
  +createAmount()
}
interface Ward {
  #double phone
  +int duration
  +getDuration()
}
class Treatment {
  -boolean quantity
  -long active
  +float updatedAt
  +boolean price
  +sendStatus()
  +sendId()
  +deleteId()
}
class MedicalRecord {
  +long description
  #Date type
  +Date status
  #double phone
  +cancelCode()
  +findId()
}
class Hospital {
  +boolean id
  #boolean name
  -double price
  +long phone
  +float active
  +createCreatedat()
  +setScore()
  +processTotal()
  +getDescription()
}
class LabTest {
  +long status
  #String level
  #String description
  +double total
  +setScore()
  +cancelCreatedat()
}
LabTest ..> Appointment : "1"
LabTest --|> MedicalRecord
Ward ..|> LabTest
Hospital --|> Treatment
@enduml