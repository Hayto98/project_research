@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Diagnosis {
  #Date name
  -boolean phone
  +deleteCode()
  +findDuration()
  +updateQuantity()
  +deletePhone()
}
class Appointment {
  +long score
  #Date status
  +Date phone
  -long total
  +updateUpdatedat()
  +setAddress()
  +validateQuantity()
  +sendUpdatedat()
}
interface Ward {
  +boolean note
  #long score
  +long address
  -int phone
  -String id
  +deleteAddress()
  +cancelDescription()
  +saveTotal()
}
class Treatment {
  -Date amount
  #long id
  #boolean price
  -int level
  #Date name
  +processCreatedat()
  +validateStatus()
  +sendPrice()
  +deleteNote()
}
class MedicalRecord {
  +long status
  #String level
  #String description
  +double total
  +saveTotal()
  +validateUpdatedat()
}
interface Hospital {
  -long active
  +Date code
  +setScore()
  +processPrice()
  +deleteLevel()
  +updateAddress()
}
abstract class LabTest {
  -boolean level
  -long amount
  -String phone
  +boolean total
  +deleteActive()
  +processCode()
  +setAmount()
  +saveScore()
}
Appointment --> LabTest : "0..1"
Treatment --|> Ward
note right of Diagnosis : Healthcare domain
@enduml