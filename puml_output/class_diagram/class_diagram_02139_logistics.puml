@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Warehouse {
  -float createdAt
  #float quantity
  -float status
  +processAddress()
}
class Vehicle {
  -boolean address
  -float quantity
  -long description
  +float price
  +processType()
  +getType()
  +getCode()
}
class Package {
  #Date status
  -float price
  -boolean address
  #long note
  #float active
  +cancelPrice()
  +updateActive()
  +processDescription()
}
class Customer {
  -boolean price
  #Date note
  +calculateCreatedat()
  +saveCreatedat()
  +cancelLevel()
}
class DeliveryNote {
  #float phone
  -long address
  +int total
  +float name
  -float id
  +sendActive()
  +updatePrice()
  +cancelNote()
  +getScore()
}
class Driver {
  -int status
  #boolean type
  -boolean total
  +setDuration()
}
Vehicle ..> Customer : "1"
Vehicle --> Package : "*"
Driver ..|> Package
note right of Warehouse : Logistics domain
@enduml