@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Warehouse {
  -float createdAt
  #float quantity
  -float status
  +processScore()
}
abstract class Vehicle {
  -int phone
  -float active
  -boolean email
  -float address
  +calculateScore()
  +processName()
  +updateQuantity()
}
class Package {
  -double type
  +boolean id
  -long duration
  -float name
  -Date code
  +processScore()
  +deleteName()
  +deleteUpdatedat()
  +processEmail()
}
class Customer {
  -int duration
  +Date price
  +double updatedAt
  #float active
  +createDuration()
  +deleteUpdatedat()
  +deleteType()
  +setPrice()
}
interface DeliveryNote {
  -long price
  -float createdAt
  -String level
  +float phone
  +deleteName()
  +deletePhone()
  +calculateNote()
  +saveQuantity()
}
class Driver {
  #double note
  +boolean score
  +boolean active
  +String createdAt
  -double price
  +processDuration()
  +cancelAmount()
  +getCode()
}
DeliveryNote --|> Warehouse
Driver ..|> DeliveryNote
Vehicle ..> Customer : "1"
Vehicle --> Package : "*"
@enduml