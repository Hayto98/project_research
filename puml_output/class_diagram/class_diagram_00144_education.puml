@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
interface Library {
  #boolean note
  +float active
  +double email
  +long score
  +updateUpdatedat()
  +processCode()
  +deleteName()
  +createStatus()
}
interface Enrollment {
  #long duration
  #String type
  -long quantity
  +setDuration()
  +validateCreatedat()
  +validatePrice()
  +cancelDuration()
}
class Department {
  -boolean active
  +int createdAt
  #long id
  +Date price
  +deleteName()
  +setLevel()
}
abstract class Book {
  #String status
  +Date price
  -Date score
  -int note
  +boolean id
  +calculateAddress()
  +deleteUpdatedat()
}
interface Attendance {
  +float score
  +long level
  -String total
  +int amount
  +cancelUpdatedat()
}
abstract class Grade {
  -long createdAt
  -long score
  +processTotal()
  +saveUpdatedat()
}
abstract class Course {
  #float active
  +float name
  -double level
  +processStatus()
  +processId()
  +getCode()
}
Book --|> Grade
Library --o Book
Attendance ..> Course : "0..1"
Attendance ..> Grade : "*"
note right of Library : Education domain
@enduml