@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
interface Library {
  #boolean note
  +float active
  +double email
  +long score
  +findEmail()
  +createScore()
  +findAddress()
  +sendName()
}
class Enrollment {
  #boolean name
  #int email
  #boolean status
  +updateLevel()
  +validateType()
  +getQuantity()
  +sendPhone()
}
class Department {
  #int quantity
  -double price
  #boolean status
  -long phone
  +processCode()
  +deleteAmount()
}
abstract class Book {
  #Date createdAt
  +int address
  +String updatedAt
  +deleteDuration()
  +validateId()
  +deleteAmount()
  +setAddress()
}
abstract class Attendance {
  #float code
  -Date duration
  +calculateAddress()
  +findAddress()
  +calculateActive()
}
class Grade {
  #float address
  +String amount
  +long updatedAt
  -String duration
  +int total
  +processId()
}
class Course {
  -long code
  +double createdAt
  -Date score
  +double type
  +boolean address
  +calculateEmail()
}
Course --o Library
Book --o Department
Library --|> Book
Library ..> Course : "1..*"
Book --|> Grade
@enduml