@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
abstract class Inventory {
  -double name
  -String score
  #double active
  +setDescription()
  +setQuantity()
  +deleteDescription()
}
interface Package {
  #String createdAt
  +double status
  #float phone
  #Date note
  #Date level
  +deleteTotal()
}
class Vehicle {
  +String description
  #String updatedAt
  -double email
  +long type
  +getId()
}
class Route {
  +long score
  #String id
  -Date active
  +sendName()
  +setDuration()
  +cancelType()
}
Package --o Inventory
Route --> Inventory : "1..*"
@enduml