@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
abstract class Inventory {
  -double name
  -String score
  #double active
  +setDuration()
  +sendNote()
  +saveCreatedat()
}
class Package {
  +int score
  -boolean note
  #Date status
  #Date active
  +deleteEmail()
}
class Vehicle {
  -int email
  +float level
  #String score
  +calculateUpdatedat()
  +createName()
  +processPhone()
  +deleteScore()
}
class Route {
  +long email
  #long level
  +updateScore()
  +sendUpdatedat()
  +setPrice()
  +calculateAmount()
}
Package --o Inventory
Route ..|> Inventory
Vehicle --|> Inventory
note right of Inventory : Logistics domain
@enduml