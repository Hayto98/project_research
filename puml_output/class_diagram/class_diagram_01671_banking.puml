@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Branch {
  #Date note
  #int description
  -Date type
  +deleteLevel()
}
interface Deposit {
  #long active
  -String quantity
  -float createdAt
  +double email
  +setTotal()
  +validateAmount()
  +validateStatus()
}
class Beneficiary {
  +double phone
  +double level
  -int id
  +long name
  #int description
  +createDescription()
  +setAddress()
  +sendAmount()
  +setTotal()
}
class Loan {
  +double id
  #long level
  +double updatedAt
  +Date address
  +processQuantity()
  +updateQuantity()
  +createId()
}
abstract class Transfer {
  +int description
  -float price
  #int active
  #double quantity
  #Date type
  +calculateActive()
  +saveScore()
  +deleteUpdatedat()
}
abstract class Customer {
  #Date code
  #Date status
  +cancelScore()
  +setName()
}
abstract class Withdrawal {
  #long description
  #float address
  -long createdAt
  +processCreatedat()
  +setActive()
  +calculateCode()
  +processType()
}
Deposit --* Customer
Branch ..> Beneficiary : "1..*"
@enduml