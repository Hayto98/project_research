@startuml

class Librarian {
  #boolean duration
  #boolean amount
  #int status
  +processNote()
  +calculateLevel()
  +getCreatedat()
  +cancelStatus()
}
abstract class Author {
  -long name
  +long description
  -String score
  +calculateName()
}
abstract class Fine {
  +String id
  -String address
  +Date code
  #int phone
  +cancelTotal()
  +deleteCreatedat()
  +sendDescription()
  +processNote()
}
abstract class Publisher {
  +double updatedAt
  +float status
  #double id
  #String score
  +sendName()
}
class Loan {
  #double createdAt
  -float updatedAt
  +double note
  +updateLevel()
  +getName()
}
interface Book {
  -double address
  #double price
  +updateCode()
}
class Member {
  +int id
  -double name
  -float note
  -String amount
  +setAmount()
}
Loan ..> Fine : "0..1"
Librarian --> Publisher : "1"
note right of Librarian : Library domain
@enduml