@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Transfer {
  #Date note
  #String email
  +sendAddress()
}
class Account {
  #double quantity
  +double updatedAt
  +boolean email
  #float createdAt
  +calculateDuration()
  +updateQuantity()
  +cancelScore()
}
abstract class Statement {
  -float email
  +double id
  -boolean quantity
  -Date level
  +setStatus()
  +processType()
  +calculateCode()
  +savePrice()
}
abstract class Transaction {
  #Date description
  +double price
  #boolean quantity
  +Date duration
  +float score
  +sendQuantity()
  +processDuration()
  +createLevel()
  +processUpdatedat()
}
Account --o Transaction
Statement --* Transaction
note right of Transfer : Banking domain
@enduml