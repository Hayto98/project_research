@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Transfer {
  #Date note
  #String email
  +calculateActive()
}
class Account {
  +long address
  +boolean quantity
  +calculateAddress()
  +saveAmount()
  +processPrice()
  +findDuration()
}
interface Statement {
  #long price
  -String updatedAt
  -Date quantity
  #String note
  +getUpdatedat()
  +updatePrice()
  +getStatus()
  +cancelCode()
}
abstract class Transaction {
  -double note
  +Date code
  -Date status
  -boolean type
  +setType()
  +sendScore()
  +getNote()
  +findStatus()
}
Statement ..> Transaction : "1"
Transaction --> Statement : "0..1"
@enduml