@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Message {
  +int createdAt
  +double updatedAt
  +cancelAddress()
  +deleteName()
  +findPrice()
}
abstract class Profile {
  +String code
  #float updatedAt
  +long id
  -Date duration
  +double total
  +processTotal()
  +saveId()
  +cancelDescription()
}
class Story {
  #String code
  #int active
  #Date amount
  +saveAddress()
}
abstract class Hashtag {
  #boolean updatedAt
  -float active
  +sendCreatedat()
  +saveStatus()
}
interface Comment {
  -Date createdAt
  -boolean total
  +Date amount
  #boolean name
  +boolean phone
  +saveCreatedat()
  +findEmail()
  +updateAmount()
}
Profile --> Message : "*"
Profile --o Story
Hashtag --> Message : "1..*"
Message ..> Comment : "1..*"
@enduml