@startuml
skinparam ArrowColor #555555
class Catalog {
  +boolean updatedAt
  -int address
  +float quantity
  +double note
  +double phone
  +getId()
  +findId()
}
interface Fine {
  -double createdAt
  +boolean note
  -float price
  -int address
  -String email
  +createEmail()
  +sendUpdatedat()
  +updateType()
  +processName()
}
class Member {
  +float score
  -int note
  +calculateCreatedat()
  +cancelName()
  +setStatus()
  +calculatePhone()
}
class Publisher {
  +Date createdAt
  -String total
  #String amount
  +getCode()
  +validateDescription()
  +createScore()
  +processLevel()
}
Publisher --|> Fine
Catalog --> Publisher : "0..1"
@enduml