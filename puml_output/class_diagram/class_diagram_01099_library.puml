@startuml
skinparam ArrowColor #555555
class Catalog {
  +boolean updatedAt
  -int address
  +float quantity
  +double note
  +double phone
  +processAmount()
  +findScore()
}
abstract class Fine {
  #long note
  -double price
  +boolean address
  +validateDescription()
  +processName()
  +findType()
}
class Member {
  #float createdAt
  -int id
  +deleteTotal()
  +validateStatus()
  +createId()
}
interface Publisher {
  +Date createdAt
  -String total
  #String amount
  +cancelUpdatedat()
  +calculateStatus()
  +sendNote()
  +calculateCode()
}
Fine ..|> Member
Member --* Catalog
note right of Catalog : Library domain
@enduml