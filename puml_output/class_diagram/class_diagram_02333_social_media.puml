@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
abstract class User {
  -boolean createdAt
  -double quantity
  +getScore()
  +updatePrice()
  +calculateCode()
  +getName()
}
class Comment {
  #String duration
  #long score
  +double level
  +Date amount
  -double type
  +cancelScore()
  +cancelEmail()
  +deleteCreatedat()
}
class Report {
  -long type
  -int createdAt
  +deleteName()
}
class Message {
  -String id
  #Date name
  +createAddress()
  +deleteQuantity()
  +calculateEmail()
  +findDescription()
}
class Hashtag {
  +float status
  #double quantity
  +float address
  -String description
  #int level
  +setName()
  +saveDuration()
  +processPhone()
  +cancelName()
}
class Post {
  +long quantity
  -long amount
  +findId()
  +updatePrice()
  +cancelNote()
  +cancelId()
}
interface Follower {
  #long address
  +String duration
  #String id
  +double description
  +cancelNote()
}
Post ..|> Follower
Hashtag --> Comment : "1"
Hashtag ..|> Follower
Follower ..|> User
User --|> Message
User ..|> Hashtag
note right of User : Social Media domain
@enduml