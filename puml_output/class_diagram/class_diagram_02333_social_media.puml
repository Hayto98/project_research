@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
abstract class User {
  -boolean createdAt
  -double quantity
  +updatePrice()
  +saveType()
  +createStatus()
  +updateDescription()
}
abstract class Comment {
  #boolean code
  #boolean name
  +float level
  -Date amount
  +Date total
  +updateAmount()
  +validateStatus()
  +validateQuantity()
}
abstract class Report {
  -boolean quantity
  #float type
  +findType()
  +validateCreatedat()
  +deleteTotal()
}
class Message {
  +long code
  -float type
  +deleteAddress()
  +validateLevel()
  +cancelUpdatedat()
}
class Hashtag {
  +boolean name
  #String status
  -String level
  +saveLevel()
  +findCreatedat()
  +createActive()
  +validateCode()
}
class Post {
  +float email
  -long description
  +float name
  -String active
  #double note
  +updateCreatedat()
}
abstract class Follower {
  -String level
  +Date updatedAt
  +saveScore()
  +saveDuration()
  +setUpdatedat()
  +setType()
}
Report ..|> Post
Follower --* Comment
@enduml