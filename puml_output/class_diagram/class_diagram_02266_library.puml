@startuml
skinparam defaultFontSize 11
interface Loan {
  +float description
  -String phone
  +int code
  -int duration
  -long active
  +setAddress()
}
interface Librarian {
  #boolean name
  +double total
  #double address
  #long type
  -long description
  +sendAmount()
  +updatePrice()
}
class Author {
  -String quantity
  #long description
  +setName()
  +setAddress()
  +saveActive()
}
class Renewal {
  #Date type
  #float duration
  +String note
  +validateScore()
  +updateUpdatedat()
  +createTotal()
}
Librarian --o Renewal
Librarian --> Loan : "1..*"
note right of Loan : Library domain
@enduml