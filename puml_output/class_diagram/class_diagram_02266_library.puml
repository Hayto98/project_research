@startuml
skinparam defaultFontSize 11
interface Loan {
  +float description
  -String phone
  +int code
  -int duration
  -long active
  +createAddress()
}
class Librarian {
  #boolean name
  +double total
  #double address
  #long type
  -long description
  +getScore()
  +updateType()
}
class Author {
  +float amount
  #long code
  #boolean quantity
  -String description
  +String phone
  +sendDuration()
  +createUpdatedat()
  +createPhone()
}
class Renewal {
  +float type
  #long level
  -boolean note
  +int active
  -double name
  +updateStatus()
  +findCode()
}
Librarian --> Loan : "1..*"
Librarian --> Author : "1..*"
Author --> Renewal : "*"
@enduml