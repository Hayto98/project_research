@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
interface Category {
  #String type
  +int address
  #float email
  +setScore()
  +calculatePhone()
}
class Return {
  #double duration
  -Date score
  -float updatedAt
  +float address
  #float id
  +saveName()
  +findDescription()
  +sendCreatedat()
  +createQuantity()
}
class Review {
  -int phone
  -Date updatedAt
  +createAddress()
  +calculateEmail()
}
interface Cart {
  -boolean code
  #Date updatedAt
  +boolean id
  +long phone
  +deleteType()
  +processActive()
}
class Payment {
  +Date type
  #long description
  #Date address
  +double level
  #int name
  +cancelPhone()
  +findAddress()
  +sendUpdatedat()
}
interface Invoice {
  +int name
  -long id
  #float duration
  +long createdAt
  +String phone
  +saveStatus()
  +setStatus()
}
interface Coupon {
  #String price
  -String total
  #float updatedAt
  #Date name
  +getPhone()
  +processQuantity()
  +saveDuration()
}
Payment --|> Cart
Cart ..|> Category
note right of Category : Ecommerce domain
@enduml