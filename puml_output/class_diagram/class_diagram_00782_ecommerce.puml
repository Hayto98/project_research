@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
interface Category {
  #String type
  +int address
  #float email
  +setDescription()
  +createStatus()
}
abstract class Return {
  #Date address
  #long type
  +boolean score
  -double updatedAt
  +getName()
  +processCode()
  +calculateLevel()
}
interface Review {
  -float name
  #long description
  +float active
  -int createdAt
  -int email
  +calculateStatus()
  +saveDuration()
  +updateType()
  +findScore()
}
class Cart {
  +float email
  -double active
  #boolean duration
  #int code
  #int updatedAt
  +findAddress()
  +setType()
  +findActive()
}
abstract class Payment {
  +String type
  +Date duration
  #long description
  #Date address
  +deleteAmount()
  +setId()
}
class Invoice {
  +boolean level
  #double phone
  +String address
  +int active
  +calculateEmail()
  +cancelLevel()
  +validateCreatedat()
}
abstract class Coupon {
  +int level
  #String createdAt
  +String address
  #boolean id
  +saveCode()
  +getAddress()
  +processPrice()
}
Payment --o Category
Category --> Payment : "1..*"
@enduml