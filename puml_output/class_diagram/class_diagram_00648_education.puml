@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Schedule {
  +double quantity
  #double phone
  -float address
  +String amount
  -int total
  +processNote()
  +calculateLevel()
}
class Attendance {
  #float quantity
  #int active
  -String phone
  -double total
  +deleteAddress()
}
class Classroom {
  -boolean updatedAt
  -long level
  #double createdAt
  +sendQuantity()
  +validateLevel()
  +calculateType()
}
abstract class Grade {
  #long note
  +int type
  +getScore()
  +getPhone()
  +findId()
  +createCreatedat()
}
class Assignment {
  -boolean updatedAt
  #boolean active
  -double address
  +int phone
  +boolean id
  +getStatus()
  +updateId()
}
interface Book {
  -long type
  -Date active
  +String phone
  -float email
  -boolean note
  +sendCreatedat()
  +updatePhone()
  +validateDescription()
  +deletePhone()
}
abstract class Teacher {
  -long score
  #String description
  +int total
  -long id
  -boolean name
  +cancelName()
  +sendQuantity()
  +deleteAddress()
  +validateScore()
}
Attendance --o Assignment
Grade --> Teacher : "1..*"
Teacher --|> Classroom
@enduml