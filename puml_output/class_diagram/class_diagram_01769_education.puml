@startuml
skinparam monochrome true
interface Course {
  #Date updatedAt
  +boolean createdAt
  -double score
  #Date amount
  +deleteDuration()
}
abstract class Classroom {
  +float name
  #float quantity
  +createName()
  +validateQuantity()
  +validateUpdatedat()
}
interface Teacher {
  +boolean total
  +double note
  +deleteType()
}
class Attendance {
  +boolean note
  #float id
  -int name
  +calculateEmail()
}
class Student {
  -int price
  -String id
  +boolean status
  +updateActive()
  +cancelTotal()
  +setType()
}
class Book {
  +int quantity
  #int price
  #String duration
  -float email
  +updateEmail()
  +saveScore()
  +updateNote()
}
Attendance --|> Student
@enduml