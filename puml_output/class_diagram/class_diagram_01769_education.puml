@startuml
skinparam monochrome true
interface Course {
  #Date updatedAt
  +boolean createdAt
  -double score
  #Date amount
  +processType()
}
class Classroom {
  #float quantity
  #long createdAt
  +deleteType()
  +cancelStatus()
  +calculateNote()
  +getScore()
}
class Teacher {
  +float status
  +boolean updatedAt
  #float createdAt
  -int note
  #String id
  +setUpdatedat()
}
abstract class Attendance {
  +float status
  -String price
  +cancelScore()
}
class Student {
  #String id
  #float description
  +createPrice()
  +createEmail()
  +deleteUpdatedat()
}
interface Book {
  -double score
  -boolean id
  +double note
  +processActive()
}
Course ..|> Attendance
Course --|> Book
Course --> Classroom : "0..1"
Classroom ..> Attendance : "1..*"
note right of Course : Education domain
@enduml