@startuml
skinparam monochrome true
skinparam shadowing true
class Statement {
  #float name
  #float amount
  +Date duration
  +sendCode()
  +deleteUpdatedat()
  +deleteCreatedat()
}
interface Transfer {
  #Date updatedAt
  #int score
  -Date address
  +boolean duration
  +deleteStatus()
  +sendId()
}
abstract class Beneficiary {
  -Date description
  +float note
  +validateAmount()
}
interface Withdrawal {
  -Date level
  #int score
  +findQuantity()
  +setActive()
  +cancelLevel()
  +cancelQuantity()
}
class Interest {
  +int quantity
  +double phone
  +String price
  #long createdAt
  -long level
  +setPhone()
  +cancelStatus()
}
interface Loan {
  -long status
  +float id
  +calculateScore()
  +deleteQuantity()
  +setActive()
  +calculatePrice()
}
Beneficiary --o Interest
Loan ..|> Withdrawal
@enduml