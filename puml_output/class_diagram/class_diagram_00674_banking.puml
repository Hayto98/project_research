@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Beneficiary {
  +float description
  #String price
  #float amount
  -Date updatedAt
  -long address
  +sendNote()
  +processDescription()
  +findId()
  +updateEmail()
}
abstract class Branch {
  +String quantity
  #float note
  +calculateNote()
  +updateAmount()
}
abstract class Withdrawal {
  -Date email
  +long price
  -boolean id
  +validateDuration()
  +calculateTotal()
}
abstract class Account {
  #long price
  -double level
  +findAmount()
  +getId()
}
class Deposit {
  -float id
  -boolean phone
  #boolean address
  +findActive()
  +calculateDescription()
  +getTotal()
}
class Teller {
  -float phone
  -String status
  -double price
  +calculateActive()
}
abstract class Transfer {
  #Date duration
  #float status
  +float name
  -int amount
  +Date active
  +saveScore()
  +deleteCode()
  +processStatus()
}
Beneficiary --> Account : "1"
Account --> Withdrawal : "*"
Beneficiary --|> Teller
@enduml