@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Staff {
  +double note
  +boolean total
  -int status
  -long email
  +validateDescription()
}
class Room {
  +Date email
  -boolean createdAt
  #float note
  +saveStatus()
}
class Reservation {
  -float total
  -String quantity
  +boolean description
  +processStatus()
  +deleteUpdatedat()
  +cancelQuantity()
  +sendAmount()
}
interface CheckIn {
  +boolean duration
  +double address
  -int description
  +double active
  +findTotal()
}
class Guest {
  #float level
  +float updatedAt
  #int createdAt
  -String note
  +saveQuantity()
  +getDescription()
}
class Restaurant {
  #Date type
  #double status
  #double score
  +cancelPhone()
}
CheckIn ..> Reservation : "0..1"
Restaurant ..> Room : "1..*"
@enduml