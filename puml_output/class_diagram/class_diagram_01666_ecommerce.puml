@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
abstract class Category {
  -boolean address
  -double status
  #float duration
  +updateLevel()
}
class Order {
  #boolean duration
  #Date amount
  -boolean note
  +Date level
  -Date quantity
  +saveUpdatedat()
  +cancelActive()
  +deleteLevel()
}
class Customer {
  -String status
  -double active
  #long name
  #long phone
  +validateQuantity()
  +findAmount()
}
class Warehouse {
  #String score
  #String amount
  +float name
  #long status
  #double email
  +calculateUpdatedat()
  +createName()
}
class Supplier {
  +boolean phone
  +double score
  #String code
  +boolean note
  #long updatedAt
  +updateDuration()
  +setCode()
  +getAmount()
}
Order ..> Customer : "*"
Supplier --o Customer
Customer --* Supplier
note right of Category : Ecommerce domain
@enduml