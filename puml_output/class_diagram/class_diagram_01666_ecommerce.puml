@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
abstract class Category {
  -boolean address
  -double status
  #float duration
  +processActive()
}
interface Order {
  #float price
  +Date amount
  #Date note
  +getActive()
  +deleteDescription()
  +setPhone()
}
abstract class Customer {
  #Date address
  +boolean quantity
  +saveDuration()
  +updateActive()
}
class Warehouse {
  -long active
  +long name
  +updateCode()
  +getAmount()
  +deleteName()
  +processId()
}
class Supplier {
  +float address
  -boolean quantity
  #int amount
  +cancelEmail()
}
Supplier --> Category : "1"
Order --> Customer : "*"
Order ..|> Warehouse
@enduml