@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Teacher {
  +double duration
  -int total
  +getDuration()
}
class Exam {
  -double level
  #boolean description
  +setPhone()
}
class Library {
  #double duration
  -boolean createdAt
  +Date total
  -Date type
  +createScore()
  +findPrice()
}
class Classroom {
  #long updatedAt
  #float amount
  +validateAmount()
  +createUpdatedat()
  +getStatus()
}
Classroom --* Library
Library --|> Teacher
note right of Teacher : Education domain
@enduml