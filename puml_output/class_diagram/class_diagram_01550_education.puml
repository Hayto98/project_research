@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Teacher {
  +double duration
  -int total
  +updateActive()
}
interface Exam {
  -double id
  #boolean level
  +String description
  +createCode()
  +cancelName()
  +processScore()
}
class Library {
  -boolean total
  +Date type
  -Date price
  +setTotal()
  +sendDescription()
}
interface Classroom {
  #float code
  -long name
  +long updatedAt
  +String amount
  +String address
  +calculateDescription()
  +setTotal()
  +findScore()
  +createScore()
}
Exam ..> Library : "1"
Classroom --o Exam
@enduml