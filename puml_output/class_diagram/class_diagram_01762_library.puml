@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Renewal {
  -long price
  -int type
  #double active
  -Date duration
  +cancelName()
  +processPrice()
  +sendActive()
  +setCreatedat()
}
class Author {
  #double id
  #String createdAt
  +float type
  -long email
  +long quantity
  +updateStatus()
  +getAddress()
}
class Publisher {
  -Date email
  #float phone
  +double score
  #Date type
  #boolean createdAt
  +cancelDuration()
  +processScore()
  +cancelId()
}
abstract class Catalog {
  +int type
  +boolean total
  +updateDuration()
  +sendPhone()
  +sendUpdatedat()
  +updateType()
}
class Member {
  #String phone
  +int email
  -boolean score
  -int note
  +saveScore()
  +deleteName()
  +processCode()
}
class Book {
  -boolean active
  -boolean email
  +deleteId()
  +sendQuantity()
  +validatePhone()
}
interface Fine {
  -Date status
  -long createdAt
  #Date duration
  +validateActive()
  +validateQuantity()
}
Fine ..> Author : "1..*"
Catalog --o Book
Fine --|> Publisher
@enduml