@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Renewal {
  -long price
  -int type
  #double active
  -Date duration
  +findUpdatedat()
  +cancelDescription()
  +sendNote()
  +getDuration()
}
class Author {
  -long email
  +long quantity
  #int price
  +double name
  +double active
  +validateScore()
  +processCreatedat()
  +calculateCreatedat()
}
abstract class Publisher {
  -String phone
  +int price
  #boolean name
  -String type
  +findAmount()
  +getEmail()
  +validateEmail()
}
interface Catalog {
  +float id
  #long name
  -long updatedAt
  +String type
  +float note
  +calculateLevel()
  +createScore()
  +createActive()
}
class Member {
  -Date status
  -long createdAt
  #Date duration
  +cancelAmount()
  +saveAmount()
}
class Book {
  -String type
  #long total
  #long address
  -String id
  +calculateTotal()
  +calculateTotal()
}
class Fine {
  #long status
  +String note
  +int level
  +String code
  +validateQuantity()
  +processLevel()
}
Publisher --> Book : "*"
Member --> Author : "0..1"
note right of Renewal : Library domain
@enduml