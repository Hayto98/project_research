@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
abstract class Renewal {
  -Date type
  #int phone
  #double total
  #long level
  +float duration
  +validateEmail()
  +validateTotal()
}
class Fine {
  #float updatedAt
  +Date status
  #int address
  +setName()
  +setNote()
  +saveEmail()
}
class Catalog {
  +int name
  -float total
  +float status
  +calculateLevel()
  +getName()
}
class Reservation {
  +int id
  +double level
  #boolean active
  +int code
  #Date name
  +validateActive()
}
Fine --* Renewal
Reservation --|> Renewal
@enduml