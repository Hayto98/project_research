@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
abstract class Renewal {
  -Date type
  #int phone
  #double total
  #long level
  +float duration
  +setQuantity()
  +findCreatedat()
}
class Fine {
  #float address
  #int id
  +getTotal()
  +getUpdatedat()
  +sendCreatedat()
}
class Catalog {
  #Date status
  +float duration
  +double description
  +boolean total
  #float score
  +getId()
}
class Reservation {
  +Date total
  #float code
  +cancelLevel()
}
Fine --* Renewal
Reservation --|> Renewal
note right of Renewal : Library domain
@enduml