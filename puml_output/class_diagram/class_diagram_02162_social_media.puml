@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
interface Message {
  #long id
  #boolean type
  #boolean code
  -Date level
  +findName()
  +findStatus()
  +getName()
  +createCode()
}
class Profile {
  +String name
  #long email
  #Date total
  +String score
  +calculateId()
  +setId()
  +validateAddress()
  +createCreatedat()
}
interface User {
  +float total
  +float type
  #float updatedAt
  #boolean amount
  +boolean quantity
  +deleteStatus()
  +sendName()
}
abstract class Post {
  -String duration
  #float description
  +int updatedAt
  +calculateCode()
  +calculateType()
}
Message --|> Profile
Post --* Profile
note right of Message : Social Media domain
@enduml