@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
interface Message {
  #long id
  #boolean type
  #boolean code
  -Date level
  +calculateType()
  +getStatus()
  +cancelUpdatedat()
  +savePhone()
}
class Profile {
  +String name
  -String email
  +cancelUpdatedat()
  +cancelCreatedat()
  +updateEmail()
}
class User {
  #int quantity
  +Date score
  +calculateQuantity()
  +processCode()
  +setPrice()
  +findNote()
}
class Post {
  -double address
  +int email
  -String createdAt
  +float type
  +processId()
}
Profile --> Message : "1"
Post ..|> User
@enduml