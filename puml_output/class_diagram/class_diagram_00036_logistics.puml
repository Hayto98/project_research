@startuml

abstract class Tracking {
  -int amount
  +boolean level
  #long name
  +validateAddress()
  +saveId()
  +calculateLevel()
  +deleteId()
}
class Driver {
  -Date createdAt
  -double status
  -boolean phone
  -double address
  +validatePhone()
  +validateCode()
}
class Customer {
  -long name
  #String quantity
  +getScore()
}
class Warehouse {
  #int description
  +Date total
  +saveNote()
  +deleteId()
  +cancelActive()
}
class Manifest {
  -double id
  #int phone
  +findNote()
  +deleteStatus()
  +validateActive()
}
Warehouse --> Customer : "0..1"
Driver ..> Tracking : "*"
Tracking --o Customer
Warehouse --|> Tracking
@enduml