@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
interface Card {
  -double active
  -boolean phone
  -boolean email
  #String price
  +deleteNote()
  +updateEmail()
}
abstract class Loan {
  #boolean quantity
  -boolean active
  -String note
  +setStatus()
  +setAmount()
  +calculateAddress()
}
interface Statement {
  +boolean description
  +int updatedAt
  #int total
  -float price
  -String quantity
  +deleteQuantity()
  +processPrice()
}
class Customer {
  -float status
  -int level
  -Date updatedAt
  +findCode()
  +createTotal()
}
class Withdrawal {
  +Date createdAt
  -String id
  #String score
  #double duration
  -String name
  +createQuantity()
  +calculateCode()
}
Customer --o Statement
Withdrawal --o Loan
Statement --* Loan
@enduml