@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
interface Staff {
  -long amount
  +int id
  +setLevel()
  +createScore()
}
class Payment {
  #Date phone
  -boolean code
  #int note
  +deleteNote()
  +sendPrice()
}
interface CheckOut {
  +Date updatedAt
  +Date email
  +createScore()
  +findActive()
  +calculateNote()
  +calculateEmail()
}
interface Reservation {
  #String active
  +Date description
  +Date price
  -long score
  #float email
  +sendEmail()
  +setPrice()
}
abstract class Amenity {
  #double email
  #Date createdAt
  +setAmount()
  +calculateTotal()
  +getStatus()
  +setId()
}
interface CheckIn {
  -int status
  #double code
  +double updatedAt
  -double type
  +processQuantity()
  +processNote()
  +getDuration()
  +cancelPhone()
}
Staff ..> CheckIn : "*"
Amenity --|> CheckOut
Payment --o Staff
@enduml