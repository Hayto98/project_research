@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Treatment {
  #String level
  +boolean description
  -long score
  -double quantity
  #float id
  +setLevel()
  +cancelUpdatedat()
  +getDuration()
  +updateNote()
}
class Billing {
  -double updatedAt
  #Date note
  #Date description
  -double name
  +saveType()
}
class Appointment {
  #long note
  #int email
  -Date description
  +float phone
  -Date code
  +getDescription()
  +cancelTotal()
}
class Nurse {
  -float score
  -int duration
  -long amount
  +Date note
  +validateLevel()
  +deletePhone()
  +deleteCreatedat()
}
Appointment ..|> Nurse
Nurse ..> Billing : "1"
note right of Treatment : Healthcare domain
@enduml