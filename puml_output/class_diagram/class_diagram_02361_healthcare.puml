@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Treatment {
  #String level
  +boolean description
  -long score
  -double quantity
  #float id
  +processAmount()
  +savePrice()
  +setPhone()
  +createScore()
}
class Billing {
  #long note
  #int code
  -int active
  +updateLevel()
}
abstract class Appointment {
  -double note
  -int name
  -float type
  +Date address
  +setAddress()
  +saveAddress()
  +createAmount()
}
class Nurse {
  #double score
  +long amount
  #Date name
  #float description
  +setCreatedat()
  +cancelAmount()
}
Appointment ..|> Billing
Nurse --|> Billing
@enduml