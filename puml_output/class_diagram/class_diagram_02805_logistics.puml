@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Tracking {
  #int id
  #int active
  +cancelQuantity()
}
class Inventory {
  +Date price
  -int quantity
  #float note
  +double phone
  +saveAddress()
  +cancelAmount()
  +deleteId()
}
abstract class Package {
  -int note
  -Date score
  +calculateQuantity()
}
interface DeliveryNote {
  +boolean code
  #double name
  #long id
  #double note
  +deleteScore()
  +sendActive()
  +saveUpdatedat()
  +cancelDescription()
}
interface Driver {
  -double total
  #String email
  +validateEmail()
}
Tracking --> Driver : "0..1"
Package ..> Inventory : "*"
@enduml