@startuml
skinparam monochrome true
skinparam shadowing true
class CheckIn {
  -boolean address
  +float status
  #Date active
  +int updatedAt
  -int phone
  +saveId()
  +createType()
}
abstract class Service {
  -int createdAt
  +boolean total
  -Date quantity
  +deleteNote()
  +getCreatedat()
  +sendDuration()
}
class Staff {
  +double active
  -Date quantity
  +long total
  -Date price
  +sendTotal()
  +updateQuantity()
  +validateTotal()
  +createEmail()
}
class Restaurant {
  -int quantity
  -double id
  -boolean createdAt
  #long price
  +double status
  +setUpdatedat()
}
abstract class Payment {
  +String note
  #boolean updatedAt
  +double name
  +Date total
  +sendId()
  +setAmount()
  +setNote()
}
abstract class Booking {
  +double email
  #float name
  -int active
  #double type
  +int level
  +saveName()
}
Restaurant ..|> Service
Payment --|> Service
Service --o Booking
Payment --|> Restaurant
@enduml