@startuml
skinparam monochrome true
skinparam shadowing true
class CheckIn {
  -boolean address
  +float status
  #Date active
  +int updatedAt
  -int phone
  +getNote()
  +updateCreatedat()
}
interface Service {
  #boolean quantity
  #float price
  -String createdAt
  #Date id
  +long note
  +calculatePrice()
  +getTotal()
  +validateName()
}
class Staff {
  -Date score
  #long level
  +int total
  -String id
  -int createdAt
  +processAddress()
  +cancelActive()
  +validateAmount()
  +calculateCode()
}
class Restaurant {
  -String score
  +float email
  #boolean note
  +double updatedAt
  +Date name
  +updateTotal()
  +savePrice()
  +calculateEmail()
}
class Payment {
  #double name
  +int status
  +double price
  -double note
  +int createdAt
  +getAmount()
  +saveCreatedat()
}
abstract class Booking {
  -int status
  #double price
  +int amount
  +double code
  +boolean total
  +processCode()
  +setStatus()
  +updateEmail()
  +calculateUpdatedat()
}
Restaurant ..|> Staff
CheckIn ..|> Staff
note right of CheckIn : Hotel domain
@enduml