@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
interface Beneficiary {
  #long description
  +Date name
  +calculateNote()
  +deleteDuration()
  +createLevel()
  +cancelType()
}
class Interest {
  +double status
  +String description
  +findCode()
  +createType()
}
class Statement {
  +int updatedAt
  -String duration
  -String type
  +createPrice()
  +sendCreatedat()
  +updateName()
  +saveName()
}
class Loan {
  +long quantity
  #double updatedAt
  #long active
  +String level
  #long total
  +cancelNote()
  +sendQuantity()
  +createType()
}
abstract class Deposit {
  #Date note
  -long amount
  +String total
  #String phone
  +calculateCreatedat()
  +createTotal()
  +getCode()
}
class Account {
  -float note
  -double type
  #float quantity
  +getAddress()
  +sendTotal()
  +cancelCreatedat()
  +cancelQuantity()
}
Loan --o Beneficiary
Account --|> Loan
Statement ..|> Account
note right of Beneficiary : Banking domain
@enduml