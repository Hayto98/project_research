@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
interface Beneficiary {
  #long description
  +Date name
  +sendScore()
  +processTotal()
  +deleteScore()
  +getQuantity()
}
class Interest {
  -String createdAt
  +int code
  #String status
  -double description
  -int amount
  +createId()
  +createScore()
}
abstract class Statement {
  -String amount
  -float note
  -double name
  +updateDescription()
  +calculateId()
}
class Loan {
  #boolean price
  #Date quantity
  +createUpdatedat()
  +processPrice()
}
abstract class Deposit {
  +String phone
  #long price
  -boolean duration
  +findEmail()
  +setDuration()
  +getStatus()
  +saveActive()
}
class Account {
  +float type
  -boolean total
  #Date phone
  -float note
  +calculateName()
  +saveNote()
  +processCreatedat()
}
Deposit --* Beneficiary
Loan --* Interest
@enduml