@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
abstract class Invoice {
  #Date name
  +String id
  +validateNote()
}
class Return {
  #String active
  -long amount
  #boolean score
  +processActive()
  +getPrice()
}
class Warehouse {
  #Date quantity
  +Date id
  -double email
  +createAmount()
  +deleteType()
  +findDuration()
  +cancelStatus()
}
class Cart {
  -long description
  #String active
  +Date code
  +float duration
  +float email
  +cancelPrice()
}
class Supplier {
  #int createdAt
  -long code
  -int duration
  +sendPhone()
  +calculateAmount()
  +validateType()
}
Cart ..|> Return
Cart ..> Warehouse : "1..*"
@enduml