@startuml
skinparam shadowing true
class Comment {
  #Date amount
  #int duration
  #String description
  +double email
  -float price
  +calculateScore()
}
class Group {
  -double total
  -double phone
  -double email
  -double quantity
  +validateLevel()
}
abstract class Hashtag {
  #String code
  +int score
  -double level
  #boolean duration
  +updateNote()
}
class Notification {
  -long type
  +String score
  #String address
  +String createdAt
  #String status
  +sendTotal()
  +validatePrice()
  +processQuantity()
  +calculatePhone()
}
Hashtag --|> Notification
Comment ..|> Group
Group --* Notification
@enduml