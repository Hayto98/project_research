@startuml
skinparam shadowing true
class Comment {
  #Date amount
  #int duration
  #String description
  +double email
  -float price
  +createPhone()
}
class Group {
  -double phone
  -double email
  -double quantity
  +double note
  #long type
  +findScore()
}
interface Hashtag {
  +double id
  -Date code
  +sendName()
}
abstract class Notification {
  -int score
  +Date address
  +float createdAt
  +String status
  #String quantity
  +getName()
  +createNote()
  +cancelAddress()
  +findName()
}
Hashtag ..|> Comment
Hashtag ..> Group : "0..1"
note right of Comment : Social Media domain
@enduml