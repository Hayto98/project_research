@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
abstract class Inventory {
  #long amount
  #boolean email
  #String quantity
  +boolean description
  +float updatedAt
  +processLevel()
  +cancelActive()
  +validateDuration()
}
class Customer {
  #double address
  +boolean description
  +getScore()
}
interface Package {
  #boolean active
  #float score
  +float address
  +getTotal()
  +findLevel()
  +sendCreatedat()
}
class Route {
  -boolean note
  -int level
  +updateUpdatedat()
  +findId()
  +processActive()
}
class DeliveryNote {
  +float type
  #int phone
  +calculateUpdatedat()
  +findActive()
}
Package --* Route
Route --> Package : "*"
Package --* Customer
@enduml