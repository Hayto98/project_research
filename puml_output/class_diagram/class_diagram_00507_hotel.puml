@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class CheckOut {
  +float quantity
  -float description
  +String email
  +boolean active
  +float price
  +deleteQuantity()
  +updateAmount()
  +deleteActive()
  +updatePrice()
}
abstract class Room {
  +Date phone
  +boolean email
  +Date status
  -double type
  -double active
  +createId()
}
class Booking {
  -int note
  #boolean status
  #String phone
  +String duration
  +saveAddress()
  +validateLevel()
  +updateNote()
  +setId()
}
interface CheckIn {
  #double status
  -long description
  +boolean total
  #double duration
  #long price
  +cancelTotal()
}
interface Amenity {
  -int email
  #float updatedAt
  #long phone
  -int note
  #double address
  +validateScore()
}
class Reservation {
  -long price
  +int duration
  -String phone
  +saveType()
  +createAddress()
  +calculateNote()
  +saveLevel()
}
Reservation --o CheckOut
Booking --* Reservation
CheckOut ..> CheckIn : "*"
CheckOut ..|> Amenity
@enduml