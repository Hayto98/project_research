@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
interface Statement {
  #long status
  -int createdAt
  +float description
  +String email
  +deleteCode()
}
class Beneficiary {
  -Date name
  -long level
  #float total
  +saveLevel()
}
class Loan {
  #float amount
  -long total
  -Date active
  +double level
  +double duration
  +sendAddress()
  +sendAmount()
  +saveCreatedat()
  +calculatePrice()
}
class Branch {
  +Date active
  #double description
  +float price
  -Date email
  +validatePrice()
}
Beneficiary --> Statement : "1"
Beneficiary --* Branch
@enduml