@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
interface Customer {
  #double amount
  #boolean status
  -int active
  +findStatus()
  +createStatus()
}
class Coupon {
  +Date quantity
  +boolean id
  +boolean price
  #long type
  +validateUpdatedat()
  +validateDescription()
  +getType()
}
class Invoice {
  -double score
  +boolean level
  +float email
  +String active
  +processEmail()
  +validateEmail()
  +calculateTotal()
}
abstract class Review {
  -String note
  -int address
  +String level
  -boolean type
  +String price
  +sendScore()
  +cancelUpdatedat()
  +processDuration()
  +processActive()
}
interface Order {
  +boolean id
  #String quantity
  -boolean type
  #int email
  +boolean createdAt
  +calculateAmount()
  +getCreatedat()
  +findCode()
  +findId()
}
class Supplier {
  -String duration
  #int name
  +boolean description
  -Date score
  +sendName()
}
interface Product {
  +long price
  +boolean total
  +saveCreatedat()
}
Coupon --o Product
Supplier ..> Review : "1..*"
Product --o Review
Supplier --|> Customer
Invoice --|> Supplier
@enduml