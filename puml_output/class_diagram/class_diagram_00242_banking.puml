@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
abstract class Withdrawal {
  +float active
  #long type
  -boolean id
  -boolean name
  +saveDuration()
  +processPrice()
}
interface Card {
  #float description
  -long address
  #long name
  -int quantity
  +calculateAddress()
  +processPrice()
}
class Interest {
  #long id
  -int score
  +float active
  +calculateDuration()
  +calculateAmount()
  +sendDescription()
  +getPrice()
}
class Beneficiary {
  -double phone
  -Date email
  +float score
  +updateType()
}
Card ..> Beneficiary : "1"
Card --o Withdrawal
@enduml