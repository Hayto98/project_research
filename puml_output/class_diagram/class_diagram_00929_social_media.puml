@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
interface Comment {
  +Date type
  #int email
  +processCreatedat()
  +getTotal()
  +sendUpdatedat()
}
abstract class Notification {
  -String email
  +int name
  #long updatedAt
  +double phone
  #long status
  +updateAmount()
}
class Report {
  +Date note
  -String name
  -boolean phone
  +calculateDescription()
  +sendId()
}
class Group {
  -float active
  #boolean level
  #Date address
  +cancelPhone()
}
class Like {
  #String type
  -boolean id
  +long price
  +deleteType()
  +createAddress()
}
Notification --* Report
Group ..> Like : "1"
Group ..|> Comment
note right of Comment : Social Media domain
@enduml