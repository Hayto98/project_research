@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
interface Comment {
  +Date type
  #int email
  +deleteDuration()
  +updateDescription()
  +processCode()
}
abstract class Notification {
  +int total
  -String duration
  -String email
  +validateNote()
}
interface Report {
  +int updatedAt
  -float type
  +double email
  #float id
  +validateStatus()
}
class Group {
  -boolean type
  +float id
  +getEmail()
  +createUpdatedat()
  +sendTotal()
  +validateCreatedat()
}
class Like {
  #long note
  -int score
  -String level
  -Date code
  +processLevel()
}
Comment --> Report : "0..1"
Notification --* Group
Report ..|> Like
@enduml