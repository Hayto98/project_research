@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Guest {
  +long email
  -long level
  #int price
  #boolean total
  #Date code
  +createAddress()
  +validateNote()
}
class Reservation {
  -int level
  -String note
  +findQuantity()
  +saveAddress()
  +saveDescription()
  +deleteCreatedat()
}
interface Booking {
  #long type
  +double active
  -int status
  +boolean note
  +calculateUpdatedat()
  +setPrice()
}
class Payment {
  #boolean code
  +double name
  +setPhone()
  +saveId()
  +saveUpdatedat()
  +createAmount()
}
class CheckIn {
  -Date createdAt
  +int amount
  -float type
  -float code
  +findPhone()
  +getDescription()
}
Reservation --> Guest : "1"
Booking --o Guest
Payment --* Booking
Payment ..> Guest : "1..*"
@enduml