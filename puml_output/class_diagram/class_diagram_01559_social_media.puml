@startuml
skinparam shadowing true
interface Story {
  #double duration
  +Date price
  #double type
  #int updatedAt
  +processUpdatedat()
  +cancelPhone()
}
class Message {
  +Date score
  #long id
  +calculateNote()
  +cancelDescription()
  +saveActive()
}
interface Follower {
  -String address
  -float duration
  #int email
  -String price
  #double type
  +saveCreatedat()
}
class Profile {
  -float score
  #double amount
  #float name
  +sendDuration()
  +findQuantity()
  +calculateDuration()
}
abstract class Post {
  -float address
  #Date active
  -boolean type
  -double price
  +processLevel()
  +updatePrice()
}
Story --|> Follower
Follower ..|> Story
Post --|> Follower
@enduml