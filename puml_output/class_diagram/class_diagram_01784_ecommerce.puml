@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
interface Shipment {
  +long status
  +long active
  +saveAddress()
  +cancelQuantity()
  +updateId()
}
class Invoice {
  +int updatedAt
  #double quantity
  +double status
  +createQuantity()
}
interface Cart {
  +double id
  -boolean note
  +Date email
  +Date address
  #String active
  +validateTotal()
}
class Wishlist {
  -long quantity
  #double score
  +String createdAt
  -int description
  +updateEmail()
  +saveName()
  +getPrice()
}
class Customer {
  -float email
  #long level
  -Date updatedAt
  +calculateNote()
  +sendCreatedat()
  +processCreatedat()
  +cancelEmail()
}
class Payment {
  -boolean status
  -boolean active
  -String email
  #String phone
  -double name
  +cancelAddress()
}
Shipment --|> Cart
Wishlist --o Shipment
Invoice ..> Wishlist : "*"
Wishlist ..|> Invoice
@enduml