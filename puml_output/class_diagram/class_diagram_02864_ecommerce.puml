@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
interface Review {
  +int level
  +int amount
  -String note
  -String status
  +savePhone()
  +cancelNote()
}
class Warehouse {
  #long price
  -double email
  +findPrice()
  +setTotal()
  +updateScore()
  +calculateDuration()
}
class Return {
  -int quantity
  #double id
  #long code
  +getQuantity()
  +processDuration()
  +setScore()
  +cancelPrice()
}
abstract class Shipment {
  -String email
  #String code
  +int level
  -int name
  +deleteCreatedat()
  +sendScore()
  +getType()
}
Shipment --o Return
Return --o Shipment
Shipment --* Review
@enduml