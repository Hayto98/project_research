@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
interface Review {
  +int level
  +int amount
  -String note
  -String status
  +getCreatedat()
  +setName()
}
abstract class Warehouse {
  -boolean score
  -Date email
  #float level
  -Date note
  +createId()
  +setPhone()
}
class Return {
  -long score
  +float quantity
  +String total
  -String updatedAt
  #String note
  +deleteNote()
  +deleteAddress()
}
class Shipment {
  #float code
  -double price
  +float note
  -int type
  #boolean phone
  +validateId()
  +calculateLevel()
  +validateTotal()
  +saveId()
}
Warehouse --* Review
Return --> Review : "0..1"
note right of Review : Ecommerce domain
@enduml