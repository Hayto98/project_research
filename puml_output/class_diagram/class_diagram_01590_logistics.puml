@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Shipment {
  -Date updatedAt
  +String status
  +getAddress()
  +calculateId()
  +setEmail()
  +findCreatedat()
}
class Manifest {
  +double status
  -float createdAt
  -String address
  +double amount
  +calculateName()
  +setNote()
  +validatePrice()
}
class Warehouse {
  +float code
  +int quantity
  +processPhone()
  +validateAddress()
  +validateCreatedat()
}
interface Package {
  +float active
  +boolean id
  #String status
  -int level
  +deleteEmail()
  +processTotal()
  +findEmail()
  +findName()
}
class Driver {
  +long duration
  #int description
  #float level
  #int total
  +calculateScore()
  +validateUpdatedat()
  +updateDuration()
}
class Tracking {
  +int status
  #long email
  -double name
  +float note
  #Date address
  +createCode()
}
abstract class Customer {
  -boolean updatedAt
  +float score
  #float phone
  +validateTotal()
  +sendPhone()
  +validateDuration()
  +findStatus()
}
Customer --* Driver
Shipment --o Driver
Shipment ..> Tracking : "1..*"
Warehouse --o Package
Customer ..> Warehouse : "*"
note right of Shipment : Logistics domain
@enduml