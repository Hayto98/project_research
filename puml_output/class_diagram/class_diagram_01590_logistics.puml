@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Shipment {
  -Date updatedAt
  +String status
  +processName()
  +validateScore()
  +getAddress()
  +setName()
}
class Manifest {
  +long createdAt
  +String address
  -double phone
  -String status
  +calculateCode()
  +cancelId()
}
abstract class Warehouse {
  -double status
  +String note
  +getNote()
}
class Package {
  -float createdAt
  -float quantity
  +validateScore()
  +deleteCode()
  +updateDescription()
}
interface Driver {
  +float active
  +boolean id
  #String status
  -int level
  +createCode()
  +sendAddress()
  +calculateAmount()
  +setNote()
}
class Tracking {
  -float id
  #Date score
  +sendDuration()
  +setCreatedat()
}
class Customer {
  -double name
  #long email
  +int description
  #Date active
  #long updatedAt
  +updateName()
  +validateAmount()
  +calculateId()
  +cancelDescription()
}
Package --|> Warehouse
Manifest --* Tracking
Warehouse --|> Package
Customer ..> Driver : "1"
Warehouse --o Shipment
@enduml