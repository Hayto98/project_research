@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Reservation {
  -String quantity
  -int email
  #String type
  -Date status
  +processAddress()
  +getStatus()
  +deleteCode()
  +cancelEmail()
}
class Staff {
  #boolean type
  #float createdAt
  +validateAddress()
  +sendPhone()
  +createScore()
}
abstract class Amenity {
  #Date duration
  -boolean active
  -double total
  #double quantity
  -long code
  +deleteCreatedat()
}
class Payment {
  -boolean active
  -float quantity
  #Date total
  +float price
  +findLevel()
}
Payment ..|> Reservation
Reservation --> Staff : "0..1"
@enduml