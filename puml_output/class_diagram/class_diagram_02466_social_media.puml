@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class User {
  +double name
  +long id
  #int note
  +setPrice()
  +calculateName()
  +validatePhone()
  +deleteNote()
}
class Story {
  +boolean score
  -boolean note
  #String description
  +String code
  #float amount
  +saveLevel()
  +setCode()
  +validateScore()
}
class Album {
  -int address
  +long level
  -Date updatedAt
  +int amount
  +setEmail()
  +deleteTotal()
  +getDuration()
  +processStatus()
}
abstract class Comment {
  #Date amount
  +Date email
  #double address
  #double total
  +deleteUpdatedat()
  +deleteStatus()
  +findAddress()
  +validateNote()
}
Comment --o Story
Album --o Comment
note right of User : Social Media domain
@enduml