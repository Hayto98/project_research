@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class User {
  +double name
  +long id
  #int note
  +updateUpdatedat()
  +sendScore()
  +saveName()
  +savePhone()
}
class Story {
  #double description
  +Date note
  #Date address
  #String price
  +saveId()
  +createDescription()
}
abstract class Album {
  #float name
  #float duration
  +deleteStatus()
  +saveDuration()
  +updateCreatedat()
}
class Comment {
  +long address
  -boolean score
  +calculateAddress()
  +saveName()
}
User --* Story
User --o Comment
@enduml