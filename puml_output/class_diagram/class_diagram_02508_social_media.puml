@startuml
skinparam defaultFontSize 13
class Story {
  +Date duration
  +float type
  #double code
  +deleteAddress()
  +sendDuration()
  +validateNote()
  +sendType()
}
interface Message {
  #String name
  #boolean note
  +cancelCreatedat()
  +deleteAmount()
  +calculatePhone()
  +findUpdatedat()
}
class Group {
  +float type
  #Date amount
  -boolean name
  -int price
  -double createdAt
  +calculateUpdatedat()
  +saveDuration()
  +createType()
  +deleteUpdatedat()
}
class User {
  #double total
  -boolean note
  +double name
  #int level
  +calculateLevel()
  +setTotal()
  +calculateCode()
}
class Follower {
  -long level
  +String id
  +int price
  +getScore()
  +setDuration()
  +getCreatedat()
}
Follower ..> Message : "*"
User ..> Story : "0..1"
Follower --|> User
note right of Story : Social Media domain
@enduml