@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
interface Patient {
  #boolean code
  -String duration
  +validateNote()
  +updateAddress()
  +createStatus()
}
abstract class Insurance {
  #String level
  +double email
  +String type
  +updateCreatedat()
  +cancelId()
  +cancelLevel()
}
class Prescription {
  -double quantity
  #Date total
  +getCreatedat()
  +createScore()
  +sendActive()
}
class Appointment {
  #int code
  +boolean name
  +long status
  +double amount
  +int createdAt
  +deleteType()
}
class Hospital {
  -long total
  #boolean code
  #boolean quantity
  +validateQuantity()
}
Patient --o Insurance
Prescription --o Patient
@enduml