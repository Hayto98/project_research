@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
interface Notification {
  +Date total
  #float status
  +String phone
  -boolean level
  #double createdAt
  +processScore()
  +setActive()
  +updateScore()
  +getCode()
}
class Story {
  #double createdAt
  -String type
  +saveUpdatedat()
  +sendQuantity()
}
class Group {
  +String duration
  -float level
  +long address
  +savePrice()
}
class Follower {
  #Date address
  +float updatedAt
  #int name
  +saveAddress()
}
class Comment {
  #double email
  #boolean note
  -boolean phone
  #Date status
  #long description
  +findType()
  +createCode()
  +findScore()
}
Notification --* Group
Comment --> Group : "1..*"
Follower ..|> Notification
Comment ..> Notification : "*"
@enduml