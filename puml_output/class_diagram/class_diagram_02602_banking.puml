@startuml
skinparam monochrome true
skinparam shadowing true
interface Teller {
  +int level
  #Date amount
  +sendPhone()
}
abstract class Customer {
  -double score
  -long id
  #boolean address
  #float code
  -int createdAt
  +findEmail()
  +validateCode()
  +cancelPhone()
}
class Statement {
  +double level
  +int total
  -long createdAt
  -int active
  +cancelDuration()
  +updateStatus()
  +setStatus()
}
class Withdrawal {
  #double type
  #Date description
  +deleteNote()
  +processEmail()
}
Statement --o Teller
Teller ..> Customer : "0..1"
Withdrawal --|> Teller
@enduml