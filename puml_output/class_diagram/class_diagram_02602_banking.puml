@startuml
skinparam monochrome true
skinparam shadowing true
interface Teller {
  +int level
  #Date amount
  +validateType()
}
abstract class Customer {
  #int address
  -double code
  +validateLevel()
  +sendQuantity()
  +deletePhone()
}
class Statement {
  #float quantity
  #float phone
  #String total
  -int createdAt
  +processQuantity()
  +validateUpdatedat()
}
class Withdrawal {
  -int status
  #double name
  #Date id
  +getLevel()
  +calculatePhone()
}
Withdrawal --o Teller
Customer --|> Withdrawal
note right of Teller : Banking domain
@enduml