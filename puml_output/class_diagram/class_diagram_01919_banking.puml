@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Statement {
  -String id
  +boolean note
  +boolean updatedAt
  +setEmail()
  +updateActive()
  +calculateTotal()
  +findType()
}
class Interest {
  #Date level
  +long email
  +saveType()
  +validateAddress()
  +validateName()
  +updateAddress()
}
abstract class Branch {
  +int amount
  -float address
  +double type
  #boolean level
  +boolean price
  +calculateStatus()
  +setDuration()
}
class Withdrawal {
  #int amount
  #double code
  +float status
  #float id
  +boolean email
  +deleteDuration()
  +updateUpdatedat()
  +processStatus()
  +processDescription()
}
class Transaction {
  +double createdAt
  #long level
  +getUpdatedat()
  +setLevel()
  +updateTotal()
  +findAddress()
}
abstract class Beneficiary {
  +Date active
  #float name
  +double score
  -String code
  +String duration
  +createStatus()
}
class Customer {
  -int email
  #boolean score
  +createLevel()
  +sendUpdatedat()
  +setAmount()
  +savePhone()
}
Withdrawal --|> Branch
Branch ..> Statement : "1"
@enduml