@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Statement {
  -String id
  +boolean note
  +boolean updatedAt
  +validateId()
  +deleteName()
  +cancelEmail()
  +saveName()
}
class Interest {
  -boolean email
  -float type
  #long level
  #double note
  +int amount
  +updateTotal()
  +sendLevel()
  +deleteScore()
}
class Branch {
  #String score
  +boolean note
  +float amount
  +findUpdatedat()
  +findNote()
  +updateLevel()
}
class Withdrawal {
  +float note
  +float status
  #int phone
  -Date quantity
  -double address
  +validateUpdatedat()
  +calculatePrice()
}
interface Transaction {
  +int score
  #Date code
  +calculateNote()
  +getDescription()
}
class Beneficiary {
  +float score
  -boolean createdAt
  +deleteDuration()
  +processName()
  +getTotal()
}
class Customer {
  #boolean email
  #String id
  +setCode()
}
Branch --|> Interest
Branch --> Transaction : "1..*"
Transaction ..> Interest : "*"
note right of Statement : Banking domain
@enduml