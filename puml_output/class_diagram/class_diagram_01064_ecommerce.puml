@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Cart {
  -String email
  +Date amount
  #Date id
  -long note
  +processEmail()
}
interface Order {
  +Date address
  +int amount
  #Date name
  +String status
  -float type
  +setCreatedat()
  +calculateUpdatedat()
  +calculateLevel()
}
interface Invoice {
  #Date score
  -boolean level
  -long status
  -String total
  +processUpdatedat()
  +validateLevel()
  +findCode()
}
class Wishlist {
  -boolean total
  +double id
  +double status
  -double name
  -boolean active
  +setName()
  +setQuantity()
  +getDuration()
  +validatePrice()
}
class Payment {
  #float type
  +float address
  -Date duration
  +createDescription()
  +validateActive()
  +updateQuantity()
}
Order --|> Cart
Cart --* Order
note right of Cart : Ecommerce domain
@enduml