@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Cart {
  -String email
  +Date amount
  #Date id
  -long note
  +findActive()
}
class Order {
  +Date address
  +int amount
  #Date name
  +String status
  -float type
  +cancelLevel()
  +createPhone()
  +updateAmount()
}
class Invoice {
  -boolean updatedAt
  #float total
  -boolean score
  -long email
  -String status
  +saveLevel()
  +getId()
  +setQuantity()
}
class Wishlist {
  -Date level
  +float code
  +float quantity
  +String note
  +getQuantity()
  +saveStatus()
  +setLevel()
  +sendCreatedat()
}
class Payment {
  +Date address
  +String total
  -String level
  #long active
  -String price
  +updateCreatedat()
  +deleteActive()
}
Wishlist --* Cart
Invoice ..> Payment : "0..1"
Invoice --* Order
@enduml