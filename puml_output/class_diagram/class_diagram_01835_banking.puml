@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
abstract class Transfer {
  -long level
  +long code
  +updateCreatedat()
  +deleteType()
}
class Card {
  #float type
  -Date name
  #Date amount
  +calculateAmount()
  +findLevel()
  +sendCode()
  +saveAddress()
}
class Statement {
  -long quantity
  #int note
  +float address
  -Date type
  +createLevel()
  +sendCode()
}
class Beneficiary {
  -float code
  +double amount
  #boolean active
  +boolean email
  #boolean quantity
  +setQuantity()
  +createId()
  +validateAmount()
  +findTotal()
}
class Customer {
  +double code
  -boolean phone
  +long name
  -String email
  +findActive()
  +processDescription()
  +calculateAmount()
}
class Interest {
  +Date note
  #Date price
  +boolean amount
  -int quantity
  -float address
  +createCreatedat()
  +sendQuantity()
  +cancelId()
  +processUpdatedat()
}
class Branch {
  #double total
  +Date status
  +saveScore()
  +sendCreatedat()
}
Beneficiary --o Customer
note right of Transfer : Banking domain
@enduml