@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
abstract class Transfer {
  -long level
  +long code
  +processPrice()
  +saveNote()
}
class Card {
  #float amount
  -Date duration
  #Date type
  -double name
  +Date level
  +saveUpdatedat()
}
class Statement {
  #boolean address
  -double quantity
  -long note
  +setActive()
  +processAmount()
}
abstract class Beneficiary {
  +float email
  +double level
  +int active
  +cancelUpdatedat()
  +calculatePhone()
  +cancelCode()
}
class Customer {
  -long active
  +long amount
  +Date duration
  -int note
  #long status
  +cancelId()
}
class Interest {
  -double status
  +boolean type
  #long note
  #boolean id
  +getEmail()
  +calculateCode()
  +deleteScore()
  +createEmail()
}
class Branch {
  +Date note
  #Date price
  +boolean amount
  -int quantity
  -float address
  +createId()
  +validateAddress()
  +saveNote()
  +createDescription()
}
Customer --o Transfer
Card --> Statement : "1"
Beneficiary --|> Customer
Interest ..|> Beneficiary
@enduml