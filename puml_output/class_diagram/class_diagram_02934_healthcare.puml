@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Hospital {
  #Date amount
  +double type
  +long email
  -Date createdAt
  +long active
  +calculateName()
  +createCreatedat()
  +calculateUpdatedat()
  +sendDuration()
}
class Ward {
  -long email
  -float description
  -String score
  #long note
  -Date name
  +calculateDuration()
  +updateAddress()
  +deletePhone()
}
abstract class Appointment {
  -String amount
  #int updatedAt
  -float address
  -String id
  +int description
  +calculateUpdatedat()
  +sendId()
  +getScore()
}
abstract class Prescription {
  #int updatedAt
  -int active
  #long description
  +float name
  +cancelAmount()
}
class Patient {
  -boolean phone
  #Date id
  +String score
  +calculateDuration()
  +processActive()
  +processTotal()
  +findTotal()
}
Ward ..|> Appointment
Ward --|> Prescription
Patient ..|> Prescription
@enduml