@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Hospital {
  #Date amount
  +double type
  +long email
  -Date createdAt
  +long active
  +validateDescription()
  +saveDescription()
  +savePrice()
  +createDescription()
}
interface Ward {
  +Date name
  -long total
  #Date address
  #long score
  #Date type
  +saveType()
  +deleteUpdatedat()
  +validateId()
  +deleteType()
}
class Appointment {
  +int total
  -Date phone
  +boolean code
  +saveEmail()
  +updateActive()
  +deleteName()
  +saveDescription()
}
class Prescription {
  #Date level
  +boolean email
  -int code
  +getScore()
  +createActive()
  +cancelDescription()
}
class Patient {
  #Date score
  #long createdAt
  +int note
  #float type
  #double updatedAt
  +sendLevel()
}
Prescription --* Ward
Appointment --|> Hospital
Ward ..> Appointment : "*"
Appointment --* Prescription
note right of Hospital : Healthcare domain
@enduml