@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Withdrawal {
  -Date note
  -long phone
  #int id
  +setPrice()
  +updateEmail()
  +validatePhone()
}
class Interest {
  -double code
  #double address
  -double name
  +validateNote()
  +deleteDescription()
}
abstract class Teller {
  -String total
  -long phone
  #boolean note
  #int duration
  -String createdAt
  +createCreatedat()
  +findCode()
  +setQuantity()
}
interface Branch {
  +int level
  +String address
  -String id
  +calculateStatus()
  +findPhone()
}
abstract class Transfer {
  #long level
  +double createdAt
  +getActive()
  +saveCode()
  +getId()
  +findType()
}
Branch --* Interest
Branch ..|> Withdrawal
@enduml