@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Withdrawal {
  -Date note
  -long phone
  #int id
  +calculateCode()
  +getDescription()
  +setAddress()
}
class Interest {
  #int note
  +boolean score
  -double type
  -float address
  -double duration
  +updateEmail()
  +setType()
  +createDuration()
  +cancelCreatedat()
}
class Teller {
  +long level
  #int address
  +getUpdatedat()
  +updateUpdatedat()
  +setPhone()
}
class Branch {
  +Date description
  #int note
  #long score
  +processPrice()
  +findPrice()
}
abstract class Transfer {
  #boolean note
  #int updatedAt
  -String email
  +float total
  +getAmount()
  +calculateDuration()
  +deleteEmail()
  +processAddress()
}
Teller ..|> Branch
Withdrawal --|> Branch
Withdrawal ..> Transfer : "1..*"
note right of Withdrawal : Banking domain
@enduml