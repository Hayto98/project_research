@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
abstract class Depot {
  -boolean name
  -boolean updatedAt
  -String email
  #String note
  +createNote()
}
class Customer {
  #long phone
  #Date amount
  +boolean level
  -int createdAt
  +deleteDuration()
}
class FuelLog {
  -Date duration
  +String note
  #boolean type
  +String address
  -float createdAt
  +findActive()
  +calculateAddress()
  +processUpdatedat()
}
abstract class Package {
  -double level
  #Date updatedAt
  +Date phone
  +cancelActive()
  +createType()
  +getEmail()
  +getActive()
}
class Tracking {
  -double createdAt
  +float id
  +findNote()
}
Depot --* FuelLog
Tracking --* Customer
FuelLog --|> Tracking
FuelLog --|> Package
@enduml