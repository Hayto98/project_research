@startuml
skinparam defaultFontSize 11
class Billing {
  #String price
  +boolean createdAt
  +String email
  +findQuantity()
  +deleteId()
  +calculateActive()
  +processType()
}
class Patient {
  #long createdAt
  #Date updatedAt
  +double address
  #boolean quantity
  +processId()
  +setDescription()
  +createCreatedat()
  +validateId()
}
class Ward {
  +boolean price
  -float description
  -long note
  #String status
  +Date createdAt
  +createTotal()
}
class LabTest {
  +int price
  -float note
  +float code
  -boolean updatedAt
  +String description
  +calculateLevel()
}
abstract class Diagnosis {
  #String price
  +String description
  -boolean status
  +double score
  +validateActive()
  +findPrice()
}
interface MedicalRecord {
  -float phone
  +boolean price
  +String amount
  +Date id
  +saveStatus()
}
class Hospital {
  -String id
  #String active
  -float status
  #int duration
  #String description
  +cancelNote()
  +validateCreatedat()
  +getScore()
  +saveId()
}
LabTest ..|> Billing
Billing --> Ward : "1..*"
@enduml