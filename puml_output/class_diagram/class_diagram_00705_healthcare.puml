@startuml
skinparam defaultFontSize 11
class Billing {
  #String price
  +boolean createdAt
  +String email
  +validateActive()
  +calculateAddress()
  +validateCreatedat()
  +updateAddress()
}
class Patient {
  #String id
  +String price
  +double active
  #double level
  +processStatus()
  +sendCreatedat()
}
class Ward {
  #Date type
  +Date quantity
  +double status
  -double createdAt
  +updateDescription()
}
class LabTest {
  #int address
  +Date amount
  +float email
  +validatePrice()
  +deleteStatus()
  +setDuration()
  +getCode()
}
class Diagnosis {
  #boolean active
  #long description
  -double price
  +String amount
  +getActive()
  +deleteCode()
  +setStatus()
  +updateType()
}
class MedicalRecord {
  -String id
  #String description
  +findUpdatedat()
  +sendName()
  +calculateCreatedat()
  +deleteActive()
}
class Hospital {
  +String note
  -boolean id
  +setType()
  +processDuration()
  +updateUpdatedat()
}
Hospital ..> Diagnosis : "*"
Ward --|> Billing
Billing --o Patient
note right of Billing : Healthcare domain
@enduml