@startuml

abstract class Package {
  -long phone
  -String id
  -long description
  +sendName()
  +setQuantity()
  +getId()
}
abstract class Depot {
  +String phone
  #Date amount
  -Date note
  -int id
  -Date createdAt
  +cancelEmail()
  +getPhone()
  +processActive()
}
class Tracking {
  #Date code
  +String type
  -boolean quantity
  +saveScore()
  +sendLevel()
  +getActive()
}
class FuelLog {
  #Date amount
  #double email
  +saveEmail()
  +setName()
}
class Vehicle {
  +int email
  -String name
  -boolean quantity
  #boolean price
  -String createdAt
  +createDuration()
  +processCreatedat()
  +sendDuration()
  +deleteDescription()
}
class Manifest {
  #double email
  #int name
  +int updatedAt
  +getCreatedat()
  +setEmail()
  +saveTotal()
  +createId()
}
interface Shipment {
  +boolean code
  #long score
  +findStatus()
}
Tracking --o Package
Depot --* Tracking
Shipment --o Vehicle
Manifest --|> Vehicle
Manifest --o FuelLog
@enduml