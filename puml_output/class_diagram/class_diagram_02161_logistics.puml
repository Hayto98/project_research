@startuml

abstract class Package {
  -long phone
  -String id
  -long description
  +processType()
  +processPrice()
  +validateAmount()
}
interface Depot {
  #float id
  -int createdAt
  -Date code
  -String name
  -int note
  +saveUpdatedat()
}
class Tracking {
  -Date quantity
  +String amount
  +long code
  #Date note
  #double duration
  +getId()
  +deleteType()
}
class FuelLog {
  #int quantity
  +int price
  +setTotal()
  +cancelDuration()
  +createName()
  +processPrice()
}
interface Vehicle {
  +int description
  #double email
  +updateCreatedat()
  +calculateScore()
}
class Manifest {
  +boolean code
  #long score
  +savePrice()
}
class Shipment {
  -long note
  #double amount
  +findType()
}
Package --o Manifest
Shipment --o Tracking
Manifest --* Shipment
Vehicle --|> Depot
FuelLog ..> Depot : "*"
note right of Package : Logistics domain
@enduml