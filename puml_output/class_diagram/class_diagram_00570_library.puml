@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Author {
  +Date total
  +boolean score
  +createAddress()
  +calculatePhone()
  +validateStatus()
}
class Branch {
  +float price
  #double quantity
  +float phone
  +getType()
  +findQuantity()
  +getQuantity()
  +saveId()
}
interface Reservation {
  +int note
  #float type
  +createLevel()
  +setPhone()
  +getPhone()
  +processEmail()
}
class Catalog {
  #Date price
  +boolean duration
  #String note
  #int phone
  #float email
  +updateNote()
  +updateLevel()
}
interface Librarian {
  +boolean id
  #Date active
  -float description
  +createDuration()
  +getDescription()
  +deleteStatus()
  +createActive()
}
abstract class Member {
  -int code
  #float phone
  +createId()
}
Branch --|> Author
Reservation ..> Member : "1"
@enduml