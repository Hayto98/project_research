@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Profile {
  -String total
  #int name
  +int active
  +String phone
  +int note
  +processNote()
  +findPhone()
  +sendNote()
  +saveAmount()
}
class Album {
  -double status
  #int price
  -boolean level
  +int duration
  +double id
  +saveUpdatedat()
  +validatePrice()
  +sendDuration()
}
abstract class Like {
  +long quantity
  -Date duration
  +createType()
  +findStatus()
  +calculateEmail()
}
class Notification {
  #int quantity
  -Date updatedAt
  +boolean createdAt
  +float duration
  +validateNote()
  +getCreatedat()
  +createLevel()
}
class Report {
  -double status
  -boolean quantity
  #Date duration
  -long name
  +findCode()
  +createDuration()
  +sendEmail()
  +calculateEmail()
}
class Group {
  +int quantity
  +int description
  -float address
  +processAddress()
  +createScore()
  +validateAddress()
  +setNote()
}
Group ..|> Like
Profile ..|> Album
Like --* Notification
note right of Profile : Social Media domain
@enduml