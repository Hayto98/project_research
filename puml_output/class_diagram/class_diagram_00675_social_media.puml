@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Profile {
  -String total
  #int name
  +int active
  +String phone
  +int note
  +getId()
  +calculateAmount()
  +createLevel()
  +createAmount()
}
interface Album {
  -String amount
  #String updatedAt
  -double total
  #int status
  -boolean price
  +cancelLevel()
}
class Like {
  -double total
  #boolean email
  #double updatedAt
  +getName()
}
class Notification {
  -double code
  #String email
  -long address
  +boolean quantity
  +cancelAddress()
  +createScore()
  +calculateNote()
}
class Report {
  +float note
  -long id
  -String score
  +findScore()
  +deleteUpdatedat()
}
class Group {
  -double status
  -boolean quantity
  #Date duration
  -long name
  +calculateStatus()
  +cancelStatus()
  +deleteName()
  +sendActive()
}
Notification --|> Like
Album ..|> Like
Like ..|> Profile
Profile --o Album
@enduml