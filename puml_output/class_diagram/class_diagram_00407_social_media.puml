@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class User {
  -int duration
  +boolean address
  #Date phone
  +double status
  #float updatedAt
  +processTotal()
  +cancelDuration()
  +deleteActive()
  +cancelActive()
}
abstract class Story {
  -long score
  #boolean address
  #long code
  +setCode()
  +createName()
  +setCode()
}
class Post {
  +int total
  +int code
  +double id
  #String status
  -float amount
  +deleteStatus()
  +setCode()
  +findId()
  +getQuantity()
}
interface Profile {
  +int phone
  #double level
  -double status
  -long email
  +deleteCode()
  +setUpdatedat()
  +getNote()
}
class Message {
  #boolean address
  +String phone
  +saveEmail()
}
class Report {
  -float total
  #String updatedAt
  -int score
  +float level
  +validateUpdatedat()
}
interface Hashtag {
  #int score
  +Date amount
  #String price
  -Date level
  -int createdAt
  +deleteActive()
}
Story ..|> Hashtag
User ..> Message : "1"
Message ..|> Report
Hashtag ..|> Post
Report --|> Hashtag
note right of User : Social Media domain
@enduml