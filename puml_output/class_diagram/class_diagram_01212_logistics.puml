@startuml
skinparam defaultFontSize 11
interface Warehouse {
  -String score
  -boolean active
  -Date amount
  +findEmail()
  +saveAddress()
  +validateDuration()
  +calculateUpdatedat()
}
class Vehicle {
  -String code
  #long description
  -int quantity
  +calculateAmount()
  +cancelId()
  +validateUpdatedat()
  +createDuration()
}
class Manifest {
  -Date price
  +String amount
  #float createdAt
  #int note
  -long phone
  +processDuration()
  +deleteAddress()
}
class Customer {
  +double duration
  +float address
  #double amount
  +float description
  +calculateAddress()
  +validatePrice()
  +createCreatedat()
}
class Shipment {
  #int duration
  -String amount
  -String active
  +sendName()
}
Customer ..|> Manifest
Manifest --> Customer : "0..1"
Manifest --|> Vehicle
Vehicle ..|> Customer
note right of Warehouse : Logistics domain
@enduml