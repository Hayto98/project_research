@startuml
skinparam defaultFontSize 11
interface Warehouse {
  -String score
  -boolean active
  -Date amount
  +setCode()
  +cancelUpdatedat()
  +validateAddress()
  +findStatus()
}
class Vehicle {
  +String duration
  +long total
  -String updatedAt
  #long quantity
  +processActive()
  +saveCode()
  +calculateCode()
  +createCode()
}
interface Manifest {
  -Date phone
  #float updatedAt
  +sendScore()
}
abstract class Customer {
  -Date createdAt
  +String note
  #float phone
  +createActive()
  +deleteEmail()
}
class Shipment {
  -Date type
  #long amount
  #boolean address
  +processUpdatedat()
  +createStatus()
  +getUpdatedat()
}
Vehicle ..|> Customer
Shipment ..|> Customer
@enduml