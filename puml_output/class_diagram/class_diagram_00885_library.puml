@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Loan {
  #boolean amount
  #boolean duration
  #boolean name
  +boolean price
  +sendName()
}
class Catalog {
  #long createdAt
  -boolean score
  +long name
  #float code
  +setEmail()
  +setNote()
  +getId()
}
class Shelf {
  -boolean price
  #long total
  +processType()
  +deleteActive()
}
class Branch {
  +int phone
  -long code
  +Date amount
  #int name
  #float note
  +setTotal()
}
class Member {
  -int code
  -Date updatedAt
  +findType()
}
Catalog --o Branch
Catalog --* Shelf
@enduml