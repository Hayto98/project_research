@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Vehicle {
  -float note
  +int status
  +findPrice()
  +setCreatedat()
}
class Depot {
  #float phone
  #double name
  +long code
  +getId()
  +calculatePhone()
  +findName()
}
interface Warehouse {
  -double score
  #float quantity
  #float duration
  +getCreatedat()
}
abstract class Route {
  #boolean code
  -long updatedAt
  #String type
  +getLevel()
}
Route ..> Depot : "1..*"
Warehouse --* Vehicle
@enduml