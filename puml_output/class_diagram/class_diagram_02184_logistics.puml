@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Vehicle {
  -float note
  +int status
  +sendQuantity()
  +deletePhone()
}
class Depot {
  -Date total
  -double amount
  +cancelScore()
  +updateScore()
  +createScore()
}
class Warehouse {
  +float id
  -Date score
  #long total
  -Date updatedAt
  +String code
  +updatePrice()
}
abstract class Route {
  +long duration
  +float email
  -float id
  -Date address
  +deleteAddress()
  +setCode()
  +processQuantity()
  +updateTotal()
}
Vehicle ..|> Warehouse
Route --* Depot
note right of Vehicle : Logistics domain
@enduml