@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Teller {
  +double description
  +long address
  #long price
  +boolean amount
  +processEmail()
}
class Customer {
  +String id
  +boolean email
  +cancelUpdatedat()
}
class Loan {
  -String total
  #int id
  #double amount
  +createNote()
  +updateAddress()
}
abstract class Withdrawal {
  +double duration
  #double note
  +Date amount
  +saveDescription()
  +savePrice()
  +setPhone()
}
class Account {
  +double level
  #boolean price
  +deleteUpdatedat()
}
interface Interest {
  #boolean quantity
  +long id
  -float email
  +double description
  +setCode()
  +updateScore()
}
Account ..|> Loan
Withdrawal --|> Teller
@enduml