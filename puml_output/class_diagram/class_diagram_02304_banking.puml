@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Teller {
  +double description
  +long address
  #long price
  +boolean amount
  +cancelUpdatedat()
}
class Customer {
  +int email
  #String updatedAt
  +deleteTotal()
  +getAmount()
  +createName()
}
interface Loan {
  #Date type
  +boolean updatedAt
  #double total
  +setType()
  +saveNote()
}
class Withdrawal {
  #double level
  +double description
  #boolean score
  +boolean status
  +createId()
  +createDescription()
  +cancelDuration()
}
class Account {
  #Date price
  #String status
  #long duration
  +double amount
  +getStatus()
}
class Interest {
  +double id
  +int description
  +updateEmail()
  +updateName()
}
Account ..> Withdrawal : "*"
Loan ..|> Interest
note right of Teller : Banking domain
@enduml