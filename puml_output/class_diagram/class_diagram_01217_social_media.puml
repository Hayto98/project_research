@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
interface Report {
  +Date address
  #long note
  +getType()
  +calculateCode()
}
class Notification {
  +String active
  +long id
  +calculateCreatedat()
  +findEmail()
  +validateLevel()
  +deleteId()
}
abstract class Hashtag {
  #double quantity
  #double name
  #boolean active
  +String createdAt
  -int level
  +deleteAddress()
}
class Comment {
  -double address
  -boolean level
  +updateAddress()
  +calculatePhone()
}
class Story {
  -long updatedAt
  +Date id
  +boolean level
  -long description
  -Date duration
  +sendAmount()
  +processId()
  +saveCode()
}
Hashtag --> Notification : "1..*"
Comment --* Story
@enduml