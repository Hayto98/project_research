@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
interface Report {
  +Date address
  #long note
  +setPrice()
  +validateDuration()
}
class Notification {
  +long updatedAt
  -long name
  +processQuantity()
  +findName()
  +sendCreatedat()
  +sendDuration()
}
class Hashtag {
  +Date note
  #String level
  +long updatedAt
  +long id
  #long duration
  +processActive()
  +updateQuantity()
  +deleteActive()
  +calculateUpdatedat()
}
class Comment {
  -long description
  +Date updatedAt
  +sendTotal()
}
class Story {
  -int phone
  #long score
  -Date price
  -long createdAt
  +deleteUpdatedat()
  +validateCreatedat()
  +setNote()
  +findQuantity()
}
Comment --o Report
Story ..|> Comment
Hashtag ..> Story : "0..1"
Report --|> Story
note right of Report : Social Media domain
@enduml