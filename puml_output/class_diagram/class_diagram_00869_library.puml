@startuml
skinparam defaultFontSize 11
abstract class Librarian {
  #String name
  +double id
  -Date active
  +boolean code
  +calculateScore()
  +findStatus()
  +cancelActive()
  +validateUpdatedat()
}
class Member {
  #long id
  -int description
  +cancelActive()
  +processAmount()
}
interface Branch {
  #Date id
  #String note
  +updateStatus()
  +findTotal()
  +findQuantity()
  +processScore()
}
interface Book {
  -long duration
  -long price
  +updateUpdatedat()
  +findDuration()
  +processDuration()
  +processQuantity()
}
class Fine {
  #float code
  +long level
  +updateId()
  +updateType()
  +cancelLevel()
}
Fine --|> Member
Member ..> Fine : "*"
Member --> Book : "1"
@enduml