@startuml
skinparam defaultFontSize 11
abstract class Librarian {
  #String name
  +double id
  -Date active
  +boolean code
  +createLevel()
  +processName()
  +saveStatus()
  +saveId()
}
class Member {
  #Date email
  #String amount
  +double description
  #Date code
  +saveNote()
}
class Branch {
  -long level
  -float code
  -String price
  #int email
  +findAddress()
}
class Book {
  #float duration
  +long level
  +findAmount()
  +validateScore()
  +updateStatus()
}
class Fine {
  #String total
  -double description
  +boolean duration
  +deleteName()
  +saveUpdatedat()
  +setAmount()
  +validateLevel()
}
Fine ..> Book : "1..*"
Fine --|> Member
note right of Librarian : Library domain
@enduml