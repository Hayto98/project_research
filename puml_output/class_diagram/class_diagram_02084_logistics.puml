@startuml
skinparam monochrome true
skinparam defaultFontSize 11
interface Inventory {
  +float address
  -Date note
  +validateDuration()
  +findDescription()
}
class Shipment {
  +int type
  #long id
  -int createdAt
  +float duration
  +calculateDescription()
  +deleteQuantity()
  +deleteAddress()
  +cancelAmount()
}
interface DeliveryNote {
  #Date name
  +int amount
  -Date email
  +processId()
  +saveAddress()
}
abstract class Manifest {
  +Date amount
  -boolean id
  -long score
  +updateEmail()
}
Inventory --o DeliveryNote
Shipment ..> Inventory : "1"
@enduml