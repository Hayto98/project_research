@startuml
skinparam monochrome true
skinparam defaultFontSize 11
interface Inventory {
  +float address
  -Date note
  +validateDuration()
  +setPhone()
}
abstract class Shipment {
  +int createdAt
  #long type
  +deleteDescription()
  +calculateStatus()
  +updateScore()
  +sendCreatedat()
}
class DeliveryNote {
  +double level
  #boolean email
  +boolean code
  +processDescription()
  +deleteId()
}
interface Manifest {
  -String address
  -int score
  #String price
  +findScore()
  +updateAmount()
  +findStatus()
  +getScore()
}
Inventory --|> Shipment
Inventory --> DeliveryNote : "0..1"
note right of Inventory : Logistics domain
@enduml