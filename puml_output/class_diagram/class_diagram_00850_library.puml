@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Author {
  +int active
  +double score
  -int type
  +double level
  +createAddress()
}
interface Publisher {
  +float amount
  #int quantity
  +Date code
  -double address
  #String active
  +saveId()
  +saveId()
}
abstract class Fine {
  #Date note
  #long status
  -int type
  #double score
  +getId()
  +processEmail()
  +createStatus()
  +getName()
}
abstract class Loan {
  -double price
  +long createdAt
  +createId()
}
class Shelf {
  -String quantity
  +boolean duration
  +Date id
  +calculateEmail()
}
class Librarian {
  +long email
  +boolean code
  +double type
  #float updatedAt
  +float description
  +validateLevel()
}
class Reservation {
  #Date phone
  #boolean note
  +double updatedAt
  #double code
  +updateDescription()
  +setName()
}
Fine --|> Loan
Loan --* Shelf
Librarian --> Publisher : "0..1"
note right of Author : Library domain
@enduml