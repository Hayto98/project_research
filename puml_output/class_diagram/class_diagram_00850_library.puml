@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Author {
  +int active
  +double score
  -int type
  +double level
  +findScore()
}
class Publisher {
  +float amount
  #int quantity
  +Date code
  -double address
  #String active
  +getDescription()
  +sendPrice()
}
class Fine {
  -String total
  -Date phone
  +calculatePrice()
  +deleteType()
  +setActive()
  +saveUpdatedat()
}
class Loan {
  -long createdAt
  -String note
  +String type
  -String id
  -int active
  +getPhone()
  +calculateLevel()
  +setDescription()
  +calculateScore()
}
class Shelf {
  -String id
  -String duration
  +boolean updatedAt
  +Date quantity
  +sendScore()
}
class Librarian {
  +Date type
  #double email
  +saveQuantity()
  +saveTotal()
}
class Reservation {
  #float description
  +float score
  +long updatedAt
  #String price
  +deleteCode()
  +sendCode()
  +updateStatus()
}
Reservation ..> Author : "0..1"
Loan --o Shelf
Publisher ..> Reservation : "0..1"
Author ..|> Reservation
Fine --|> Loan
@enduml