@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class DeliveryNote {
  -int createdAt
  -long description
  -String active
  +Date amount
  +calculateQuantity()
  +processId()
  +calculateDuration()
}
abstract class Shipment {
  -boolean level
  -float type
  -Date phone
  +float price
  +validatePrice()
  +getName()
}
abstract class Inventory {
  #float amount
  +int quantity
  -float email
  #Date name
  +deletePhone()
  +deleteCode()
}
class Route {
  -long status
  #String email
  #int note
  +findPhone()
  +validateName()
}
class Customer {
  +Date email
  +Date duration
  #double price
  #Date level
  +findQuantity()
  +calculateEmail()
  +validateActive()
  +processName()
}
abstract class Warehouse {
  #float score
  #float quantity
  +long type
  -double status
  +calculateId()
  +getId()
  +getUpdatedat()
  +updateActive()
}
class Depot {
  -float level
  #double quantity
  #int updatedAt
  +int price
  +setScore()
  +cancelLevel()
  +deleteId()
}
Shipment --* Inventory
Route --o Shipment
note right of DeliveryNote : Logistics domain
@enduml