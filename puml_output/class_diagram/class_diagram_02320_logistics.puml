@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class DeliveryNote {
  -int createdAt
  -long description
  -String active
  +Date amount
  +findAmount()
  +getNote()
  +calculateAmount()
}
class Shipment {
  -float duration
  -boolean type
  -float quantity
  -Date level
  +float phone
  +findQuantity()
  +processNote()
}
abstract class Inventory {
  #long name
  #int type
  +deleteName()
  +deleteNote()
  +getScore()
}
class Route {
  +Date phone
  -int score
  +long description
  +validateEmail()
  +validateAddress()
}
abstract class Customer {
  #long address
  -String id
  +long amount
  -Date createdAt
  +sendDescription()
  +sendScore()
  +deleteCreatedat()
}
class Warehouse {
  #long total
  -long price
  +createDescription()
  +calculateAmount()
  +sendUpdatedat()
}
class Depot {
  #float address
  #float score
  +long quantity
  -double type
  #boolean status
  +saveName()
  +sendTotal()
  +getDescription()
  +calculateEmail()
}
DeliveryNote ..|> Shipment
Customer --* Shipment
@enduml