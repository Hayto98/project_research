@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Inventory {
  -int updatedAt
  -long price
  +Date amount
  +getPhone()
  +updateDescription()
  +createDuration()
}
class Package {
  +int id
  #long score
  +getDescription()
  +setAmount()
}
interface Vehicle {
  -String duration
  #long total
  +calculateAmount()
  +saveStatus()
  +updateName()
}
class Shipment {
  -double note
  +boolean price
  -String phone
  -boolean createdAt
  +sendName()
  +validateCreatedat()
  +updateActive()
}
class Driver {
  #long duration
  #float createdAt
  -boolean phone
  +float active
  +findPrice()
  +saveAmount()
}
class Depot {
  +int quantity
  -int note
  +saveScore()
  +setStatus()
  +deleteQuantity()
}
class Tracking {
  +long level
  -String duration
  #String total
  -Date status
  +double price
  +processNote()
  +calculateScore()
  +validateName()
}
Driver ..> Package : "1"
Package --> Depot : "0..1"
Driver ..> Tracking : "0..1"
Tracking ..> Depot : "1"
Package --> Vehicle : "1"
@enduml