@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Inventory {
  -int updatedAt
  -long price
  +Date amount
  +calculateCreatedat()
  +calculateStatus()
  +getId()
}
interface Package {
  -int amount
  #boolean level
  +saveDuration()
}
abstract class Vehicle {
  +long code
  #long quantity
  -float level
  -long note
  +validateTotal()
  +getDuration()
}
class Shipment {
  -double total
  +String score
  +createDuration()
  +updatePhone()
  +cancelActive()
}
interface Driver {
  #double active
  #Date total
  -String status
  -boolean description
  +deleteCreatedat()
  +validateAmount()
  +createPhone()
  +setStatus()
}
class Depot {
  +long level
  -String duration
  #String total
  -Date status
  +double price
  +saveEmail()
  +processType()
  +sendUpdatedat()
}
class Tracking {
  #Date duration
  +float amount
  #Date active
  +updateEmail()
}
Inventory --> Shipment : "1"
Shipment --* Depot
Inventory ..|> Depot
Package --* Driver
Depot ..|> Tracking
note right of Inventory : Logistics domain
@enduml