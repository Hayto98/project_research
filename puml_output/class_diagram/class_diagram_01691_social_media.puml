@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Story {
  +int amount
  +float updatedAt
  +validateScore()
}
interface Profile {
  #float address
  -int email
  +getDescription()
}
class Follower {
  -String note
  -String address
  #long level
  +Date updatedAt
  +validateQuantity()
}
class Message {
  +float duration
  +long active
  -double note
  -String total
  +calculateCode()
}
class User {
  #String createdAt
  -long code
  +long email
  +validateScore()
  +deleteId()
  +getAmount()
  +getType()
}
class Report {
  #double amount
  -long total
  +long level
  #int email
  +processUpdatedat()
  +sendType()
  +sendPrice()
  +getTotal()
}
interface Like {
  #int duration
  -int quantity
  #String email
  +Date address
  #Date status
  +updatePrice()
}
Message --|> Story
User --* Follower
Report --|> Follower
Follower --|> Report
note right of Story : Social Media domain
@enduml