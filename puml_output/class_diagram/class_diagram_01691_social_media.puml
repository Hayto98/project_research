@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Story {
  +int amount
  +float updatedAt
  +findQuantity()
}
interface Profile {
  #float address
  -int email
  +calculateId()
}
class Follower {
  -int phone
  -String note
  -String address
  +setStatus()
  +calculateDescription()
  +processQuantity()
}
class Message {
  -int phone
  +long quantity
  -double active
  -String note
  +saveStatus()
}
abstract class User {
  #int updatedAt
  +boolean duration
  +getDescription()
  +sendPrice()
  +createPhone()
}
abstract class Report {
  -boolean code
  +String email
  +int score
  +double type
  +sendUpdatedat()
  +deletePhone()
}
class Like {
  -boolean duration
  -long total
  -int level
  +getActive()
  +processUpdatedat()
  +createType()
}
Message --> Profile : "*"
User --|> Message
Message ..> User : "*"
User --* Follower
Follower ..> Story : "0..1"
@enduml