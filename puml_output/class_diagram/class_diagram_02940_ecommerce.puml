@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Review {
  +float name
  +int price
  -long quantity
  #String createdAt
  +calculateAmount()
}
abstract class Category {
  -long phone
  +long description
  #Date note
  #Date updatedAt
  +updateAddress()
  +deleteType()
  +deleteEmail()
}
abstract class Order {
  -boolean price
  #double status
  +int total
  -double email
  -Date level
  +saveDuration()
}
interface Invoice {
  -Date active
  -Date name
  -String status
  +sendTotal()
  +findActive()
}
class Supplier {
  #String active
  -Date status
  +long note
  -double updatedAt
  +boolean address
  +updateTotal()
}
Review ..|> Category
Invoice --o Review
Category ..|> Supplier
@enduml