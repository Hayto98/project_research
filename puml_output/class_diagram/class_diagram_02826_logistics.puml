@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Route {
  -String name
  #String total
  +saveNote()
}
class Depot {
  +String score
  #String id
  -float updatedAt
  +cancelScore()
}
class DeliveryNote {
  +String quantity
  #boolean address
  +String id
  +boolean total
  +float level
  +setDuration()
}
class Tracking {
  #long code
  -Date description
  #boolean duration
  +validateType()
  +saveScore()
  +createAmount()
  +findType()
}
abstract class Shipment {
  +boolean total
  +Date email
  #boolean status
  +sendPrice()
  +findAmount()
}
interface Driver {
  -float active
  #long total
  #Date description
  +cancelQuantity()
  +validateUpdatedat()
  +cancelCreatedat()
  +findLevel()
}
Tracking --o Driver
Driver --> Shipment : "*"
@enduml