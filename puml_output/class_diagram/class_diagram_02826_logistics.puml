@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Route {
  -String name
  #String total
  +updateId()
}
class Depot {
  +boolean updatedAt
  +double code
  +saveCreatedat()
}
abstract class DeliveryNote {
  -int address
  +boolean id
  #String score
  +String total
  +findCode()
  +saveAmount()
}
class Tracking {
  #long description
  -Date code
  +validatePhone()
  +processUpdatedat()
  +calculateEmail()
  +setCreatedat()
}
interface Shipment {
  #double score
  #int level
  #double createdAt
  +createEmail()
  +findNote()
}
abstract class Driver {
  -double total
  #float amount
  #boolean type
  #double score
  +Date note
  +cancelType()
  +findCreatedat()
  +cancelPrice()
  +saveNote()
}
DeliveryNote --> Depot : "1"
Depot ..> Route : "0..1"
Depot ..|> Shipment
Depot --* Tracking
note right of Route : Logistics domain
@enduml