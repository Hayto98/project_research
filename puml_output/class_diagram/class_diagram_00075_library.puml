@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Publisher {
  +long createdAt
  -boolean quantity
  +calculateDuration()
}
class Shelf {
  +int updatedAt
  -float createdAt
  #Date description
  #String total
  +cancelStatus()
  +calculateNote()
  +sendScore()
  +saveNote()
}
interface Book {
  +float name
  -double updatedAt
  #int price
  +getUpdatedat()
  +setDescription()
  +setName()
  +validateCode()
}
class Renewal {
  #double active
  +Date createdAt
  #boolean phone
  #boolean total
  +findPrice()
  +findLevel()
}
class Catalog {
  #int email
  +String description
  #float name
  -Date address
  +updateDuration()
}
Renewal --|> Shelf
Publisher --> Book : "1..*"
note right of Publisher : Library domain
@enduml