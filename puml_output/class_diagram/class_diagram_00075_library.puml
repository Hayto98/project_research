@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Publisher {
  +long createdAt
  -boolean quantity
  +getDuration()
}
abstract class Shelf {
  +boolean email
  +boolean updatedAt
  +deleteNote()
  +validateCode()
  +saveCode()
  +updateQuantity()
}
interface Book {
  -double price
  #boolean status
  +getCreatedat()
  +getScore()
  +calculateAddress()
  +saveEmail()
}
class Renewal {
  +int name
  +int type
  +String total
  -String description
  -long price
  +setAmount()
  +processStatus()
}
abstract class Catalog {
  #boolean updatedAt
  +float score
  -long level
  +String amount
  #float price
  +validateStatus()
  +createTotal()
  +deleteScore()
}
Publisher ..> Book : "1"
Shelf --o Catalog
@enduml