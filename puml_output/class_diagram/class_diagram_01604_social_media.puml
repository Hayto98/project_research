@startuml
skinparam ArrowColor #555555
class User {
  -long id
  +String updatedAt
  +double duration
  #String email
  +getAddress()
  +sendAddress()
  +createPhone()
}
class Group {
  #String email
  #double quantity
  +setAmount()
  +processAmount()
  +processQuantity()
}
class Hashtag {
  +float note
  -boolean total
  -Date description
  +deleteType()
  +sendLevel()
  +deleteTotal()
  +findLevel()
}
class Post {
  -double score
  #double name
  #float price
  -Date active
  +getNote()
  +deleteTotal()
}
class Comment {
  -String description
  -float updatedAt
  +int id
  #float duration
  +sendActive()
}
class Message {
  -long createdAt
  -double address
  +float active
  +savePhone()
  +setNote()
  +updatePrice()
  +saveName()
}
User --> Comment : "1"
Message --* Group
Post --* Hashtag
User --> Message : "1"
note right of User : Social Media domain
@enduml