@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Enrollment {
  #float email
  #String level
  +setCode()
  +updatePrice()
}
class Department {
  +double type
  +boolean amount
  -float description
  -long score
  +updateNote()
  +getPrice()
  +cancelCreatedat()
  +cancelEmail()
}
interface Exam {
  #String quantity
  -double status
  +processCode()
  +deleteName()
}
class Grade {
  -int level
  #String id
  #double name
  #boolean email
  #int note
  +validateDuration()
}
class Schedule {
  +boolean type
  +boolean updatedAt
  #Date email
  +calculateNote()
}
class Classroom {
  +int price
  -long status
  +boolean id
  -double code
  #long phone
  +processPhone()
  +findNote()
  +createCreatedat()
}
Department --|> Schedule
Enrollment ..|> Department
Exam --* Department
Grade ..|> Department
@enduml