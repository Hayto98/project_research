@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Booking {
  +boolean note
  +String score
  #boolean active
  +boolean duration
  +String email
  +setDescription()
  +processLevel()
  +processStatus()
  +getLevel()
}
class Restaurant {
  -int score
  +boolean description
  +setEmail()
  +setPhone()
  +deleteCreatedat()
}
class Invoice {
  +int total
  +Date note
  +boolean type
  +processNote()
  +getAmount()
  +cancelType()
  +setDescription()
}
interface Staff {
  -Date level
  #Date email
  +Date description
  #Date quantity
  +updateUpdatedat()
  +sendType()
}
Staff ..> Restaurant : "1..*"
Invoice --o Restaurant
@enduml