@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Staff {
  #Date address
  -boolean code
  +createDuration()
  +calculateName()
}
interface Reservation {
  #long price
  +boolean level
  +boolean createdAt
  +validateUpdatedat()
  +processUpdatedat()
}
abstract class Booking {
  #long price
  #String description
  -Date id
  -double active
  +saveActive()
  +calculateScore()
  +getId()
  +validatePhone()
}
class Restaurant {
  #int active
  #long address
  #boolean updatedAt
  +sendEmail()
  +processPrice()
}
class CheckOut {
  #long name
  -int active
  +int description
  +saveActive()
  +processCreatedat()
}
interface Guest {
  #float total
  +int type
  -double level
  #long amount
  +int note
  +createStatus()
}
Restaurant --o CheckOut
Staff --* Booking
Booking --> Guest : "1"
note right of Staff : Hotel domain
@enduml