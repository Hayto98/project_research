@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Staff {
  #Date address
  -boolean code
  +updateQuantity()
  +deleteCreatedat()
}
interface Reservation {
  #long name
  +boolean active
  +boolean updatedAt
  +long price
  +double createdAt
  +saveAmount()
  +createAmount()
}
abstract class Booking {
  #String id
  -Date active
  -double email
  +updatePhone()
  +calculateActive()
  +getPhone()
  +getStatus()
}
interface Restaurant {
  -String id
  #Date address
  +sendQuantity()
  +findEmail()
}
class CheckOut {
  +boolean amount
  -double phone
  -int score
  +validateType()
  +calculateEmail()
}
interface Guest {
  +float active
  +int quantity
  +Date address
  +processActive()
  +calculateLevel()
  +sendDuration()
  +sendLevel()
}
Guest --o Restaurant
Restaurant --o Reservation
Guest ..|> Staff
Restaurant --> Guest : "1..*"
Staff --|> Reservation
@enduml