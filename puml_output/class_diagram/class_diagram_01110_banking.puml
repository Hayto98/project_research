@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
interface Card {
  #boolean note
  #int id
  -float total
  #boolean address
  +getCreatedat()
  +updateQuantity()
  +sendAddress()
}
class Transaction {
  #int name
  +double level
  +boolean updatedAt
  -float phone
  +createUpdatedat()
  +saveCode()
  +processPhone()
  +findPhone()
}
class Loan {
  +double amount
  #boolean code
  #double name
