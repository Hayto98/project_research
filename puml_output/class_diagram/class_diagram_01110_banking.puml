@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
interface Card {
  #boolean note
  #int id
  -float total
  #boolean address
  +updateDuration()
  +setScore()
  +processActive()
}
class Transaction {
  +boolean active
  +boolean address
  -Date quantity
  +String email
  +createCreatedat()
  +getQuantity()
  +calculateQuantity()
  +deleteEmail()
}
abstract class Loan {
  #long updatedAt
  -boolean code
  #boolean note
  +Date phone
  +getLevel()
  +calculateStatus()
}
class Statement {
  #double note
  #int score
  +int price
  +createUpdatedat()
  +cancelLevel()
  +sendAddress()
}
Card --|> Loan
Loan --|> Statement
@enduml