@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Category {
  +boolean amount
  -Date total
  #int email
  +double note
  +long status
  +calculateCode()
}
abstract class Coupon {
  -boolean score
  -int quantity
  #boolean amount
  -long level
  #long duration
  +updateAmount()
  +sendName()
  +deleteAmount()
}
interface Product {
  #double active
  -String duration
  +boolean id
  +deleteType()
  +saveDuration()
  +sendId()
  +sendPrice()
}
class Review {
  #double duration
  -boolean name
  +deleteNote()
  +processCode()
  +getType()
  +updatePhone()
}
class Payment {
  -double phone
  +Date score
  #Date address
  -long status
  +float email
  +findNote()
  +findQuantity()
  +sendLevel()
  +validateEmail()
}
abstract class Cart {
  +int description
  +int updatedAt
  #int duration
  +deleteStatus()
}
Product --> Review : "1..*"
Category ..|> Coupon
Coupon ..> Category : "1"
Cart ..|> Payment
note right of Category : Ecommerce domain
@enduml