@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Category {
  +boolean amount
  -Date total
  #int email
  +double note
  +long status
  +cancelCreatedat()
}
class Coupon {
  #long level
  +long score
  #double total
  +float quantity
  #boolean amount
  +findScore()
  +setCode()
  +updateLevel()
  +updateId()
}
class Product {
  +int amount
  #int score
  #boolean name
  +validateTotal()
}
abstract class Review {
  -Date name
  #boolean code
  +float active
  #double type
  +boolean amount
  +setId()
}
class Payment {
  -String email
  +double active
  +long total
  +double description
  -Date note
  +validateId()
  +createId()
  +validateAddress()
}
class Cart {
  #float updatedAt
  -Date address
  -boolean email
  #boolean amount
  -long type
  +updateDescription()
  +cancelScore()
  +saveTotal()
  +saveQuantity()
}
Coupon ..|> Cart
Category --> Coupon : "0..1"
@enduml