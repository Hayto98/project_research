@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Depot {
  +int id
  -boolean score
  -boolean quantity
  -double description
  -long code
  +findLevel()
  +deleteCreatedat()
  +cancelAddress()
  +createTotal()
}
class Route {
  +Date amount
  -String name
  +String email
  +getScore()
  +saveActive()
  +validateAmount()
}
class Warehouse {
  -long id
  +Date note
  -boolean code
  -Date updatedAt
  #Date duration
  +updateName()
}
class Inventory {
  #Date quantity
  #String total
  +getStatus()
  +cancelCreatedat()
  +createAddress()
}
Route ..|> Warehouse
Warehouse --o Inventory
note right of Depot : Logistics domain
@enduml