@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Depot {
  +int id
  -boolean score
  -boolean quantity
  -double description
  -long code
  +validateTotal()
  +processId()
  +setLevel()
  +saveNote()
}
interface Route {
  #int quantity
  +long total
  +Date id
  -String updatedAt
  +cancelTotal()
}
interface Warehouse {
  +String name
  #double score
  +double active
  +int phone
  +getUpdatedat()
}
abstract class Inventory {
  +String updatedAt
  +Date address
  #String type
  -double code
  +calculateUpdatedat()
}
Depot --> Inventory : "0..1"
Warehouse ..|> Route
Route ..|> Warehouse
@enduml