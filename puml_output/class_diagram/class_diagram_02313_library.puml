@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Catalog {
  #float address
  #long email
  +long note
  #String status
  +deleteAddress()
}
abstract class Fine {
  -int updatedAt
  -long level
  #String name
  #String duration
  +cancelUpdatedat()
  +saveTotal()
  +setQuantity()
}
class Reservation {
  #int id
  -long duration
  #Date quantity
  +String total
  +updatePrice()
}
class Member {
  #Date description
  +long note
  +int phone
  #long code
  -boolean id
  +calculateAmount()
  +updateStatus()
  +saveQuantity()
  +sendActive()
}
interface Book {
  -double total
  +boolean level
  +double quantity
  +Date status
  +float email
  +sendEmail()
  +validateDuration()
  +findDuration()
}
abstract class Branch {
  #float total
  -Date score
  +int phone
  -double type
  +processEmail()
  +processPhone()
  +cancelType()
}
abstract class Librarian {
  +float status
  -Date level
  #float phone
  +int address
  -Date description
  +validateCreatedat()
}
Book --|> Member
Librarian ..|> Fine
Member --> Branch : "1"
Catalog --o Fine
Book --o Librarian
Librarian ..|> Member
@enduml