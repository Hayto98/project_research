@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Catalog {
  #float address
  #long email
  +long note
  #String status
  +updateTotal()
}
class Fine {
  +long level
  +long duration
  -boolean name
  +sendCode()
}
class Reservation {
  #Date duration
  #float email
  -boolean id
  -Date score
  +calculateQuantity()
  +findCode()
}
class Member {
  -float id
  +double createdAt
  +setId()
  +saveUpdatedat()
  +createId()
}
class Book {
  +boolean total
  #double type
  -float note
  #float updatedAt
  +setEmail()
  +calculateTotal()
  +deleteActive()
}
class Branch {
  #double description
  -double id
  #Date address
  #boolean createdAt
  -double score
  +saveAmount()
  +deleteTotal()
  +calculatePhone()
  +cancelPrice()
}
abstract class Librarian {
  -boolean level
  +int phone
  +findName()
  +updateType()
  +findId()
}
Book --o Librarian
Catalog ..|> Fine
Member --> Branch : "1"
note right of Catalog : Library domain
@enduml