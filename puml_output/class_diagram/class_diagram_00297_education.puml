@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
abstract class Enrollment {
  +long level
  #float code
  +getQuantity()
  +calculateNote()
}
interface Teacher {
  +boolean updatedAt
  -int amount
  +updatePrice()
}
class Assignment {
  #float score
  #long description
  +Date id
  -String name
  +int note
  +validateDuration()
  +validateName()
  +validateCode()
  +updateEmail()
}
interface Exam {
  #double description
  +int quantity
  #String name
  -Date duration
  +deleteTotal()
  +calculateAddress()
}
Enrollment --> Teacher : "0..1"
Enrollment ..|> Exam
note right of Enrollment : Education domain
@enduml