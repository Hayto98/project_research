@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
abstract class Enrollment {
  +long level
  #float code
  +processCode()
  +setTotal()
}
abstract class Teacher {
  #long duration
  +String code
  +Date updatedAt
  -int amount
  -Date score
  +setActive()
  +validatePrice()
}
class Assignment {
  #long note
  +Date active
  +setDescription()
  +cancelEmail()
  +updateDescription()
}
abstract class Exam {
  #float duration
  +int address
  -float name
  #Date phone
  +setLevel()
  +updateLevel()
  +setUpdatedat()
}
Exam ..|> Enrollment
Enrollment ..> Teacher : "0..1"
@enduml