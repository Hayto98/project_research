@startuml
skinparam defaultFontSize 11
class Appointment {
  -boolean active
  #String phone
  +sendCreatedat()
  +setEmail()
  +validateAmount()
  +getType()
}
class Nurse {
  -int code
  #float price
  #String createdAt
  +createDuration()
  +findActive()
}
class Patient {
  +int phone
  -String createdAt
  -String address
  +createLevel()
  +saveAddress()
}
class MedicalRecord {
  +int total
  #Date quantity
  +boolean name
  #String duration
  -int email
  +setName()
}
interface Insurance {
  -long createdAt
  -boolean amount
  +findUpdatedat()
  +updateEmail()
  +setAddress()
}
Appointment --* MedicalRecord
Nurse --o MedicalRecord
note right of Appointment : Healthcare domain
@enduml