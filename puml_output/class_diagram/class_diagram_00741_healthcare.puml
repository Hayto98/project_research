@startuml
skinparam defaultFontSize 11
class Appointment {
  -boolean active
  #String phone
  +saveActive()
  +createType()
  +processActive()
  +createNote()
}
class Nurse {
  #int phone
  #int amount
  +double id
  +double type
  +sendAmount()
  +updateCode()
}
class Patient {
  +Date email
  -int active
  -String status
  +cancelCreatedat()
  +saveTotal()
}
class MedicalRecord {
  #int name
  #double amount
  #double quantity
  #long address
  +updateAddress()
}
abstract class Insurance {
  -int createdAt
  +String description
  +float level
  #boolean id
  +updateDescription()
}
MedicalRecord --o Patient
Insurance ..> Patient : "0..1"
@enduml