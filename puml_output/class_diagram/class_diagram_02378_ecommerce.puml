@startuml
skinparam defaultFontSize 13
abstract class Category {
  -boolean description
  -boolean quantity
  +saveAddress()
  +cancelType()
  +saveDescription()
  +calculateUpdatedat()
}
interface Customer {
  -int status
  -int updatedAt
  +createPrice()
  +getCreatedat()
  +calculateAmount()
  +deleteLevel()
}
interface Invoice {
  +float name
  -boolean amount
  -String score
  +boolean level
  +getActive()
  +findTotal()
  +updateScore()
  +deleteId()
}
abstract class Coupon {
  -String updatedAt
  -double code
  #boolean id
  -String address
  +boolean quantity
  +getName()
  +calculateUpdatedat()
  +saveTotal()
}
interface Product {
  -Date description
  -boolean code
  -Date updatedAt
  +boolean name
  +saveDuration()
  +processId()
}
interface Payment {
  +boolean type
  #double total
  -boolean phone
  #int status
  #double quantity
  +findCode()
  +sendAmount()
}
abstract class Shipment {
  -String level
  +long note
  #Date duration
  +int status
  #int phone
  +setPhone()
  +setStatus()
}
Coupon --|> Payment
Invoice ..> Payment : "0..1"
@enduml