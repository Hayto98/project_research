@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
abstract class Follower {
  #float type
  #Date score
  +getPrice()
}
abstract class Hashtag {
  #long address
  #boolean level
  #double type
  -String code
  +sendStatus()
  +sendUpdatedat()
  +createDuration()
  +findCode()
}
class Comment {
  +float score
  +float quantity
  #String total
  -boolean email
  #double type
  +getName()
  +setAddress()
}
class Notification {
  #double email
  +double phone
  -double name
  +getTotal()
  +findDescription()
  +getPhone()
  +setId()
}
class Report {
  +int code
  -double amount
  +boolean level
  +saveDescription()
  +getAddress()
  +updateCode()
  +calculateDescription()
}
Hashtag --o Notification
Comment ..> Report : "1..*"
@enduml