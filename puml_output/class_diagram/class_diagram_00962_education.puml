@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Enrollment {
  -Date score
  -long phone
  +savePrice()
  +cancelEmail()
}
class Attendance {
  +double updatedAt
  +int createdAt
  -float score
  +float name
  #int type
  +getEmail()
}
abstract class Department {
  -String price
  +float status
  #boolean amount
  +createPhone()
  +updateStatus()
  +calculateType()
  +processName()
}
interface Library {
  +double total
  -long address
  #String status
  +Date amount
  +int id
  +setDuration()
  +processAddress()
  +deleteUpdatedat()
}
class Book {
  +String active
  -boolean quantity
  #String description
  +boolean address
  +setType()
}
interface Schedule {
  #long code
  #long status
  +findEmail()
  +saveAmount()
  +cancelDuration()
  +saveCreatedat()
}
Library --* Enrollment
Attendance --|> Enrollment
note right of Enrollment : Education domain
@enduml