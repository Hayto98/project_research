@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Enrollment {
  -Date score
  -long phone
  +validatePrice()
  +saveCode()
}
interface Attendance {
  #boolean email
  #float note
  +boolean updatedAt
  -String createdAt
  +validatePhone()
  +processActive()
  +saveName()
  +validateStatus()
}
class Department {
  -Date status
  #float id
  +double email
  +setDuration()
}
interface Library {
  #boolean address
  -float code
  -Date description
  +getPrice()
  +calculateNote()
  +validateId()
}
abstract class Book {
  #String note
  +String name
  +double duration
  -long total
  #String address
  +calculateUpdatedat()
}
class Schedule {
  -int quantity
  +float code
  -long type
  +updateId()
  +saveDuration()
  +saveQuantity()
}
Enrollment --* Schedule
Book --|> Schedule
Enrollment ..> Book : "1"
Enrollment --> Library : "1"
@enduml