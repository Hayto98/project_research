@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Doctor {
  #String description
  #boolean status
  #long updatedAt
  +updateAddress()
  +savePhone()
}
interface Patient {
  #float id
  +int type
  +sendDescription()
}
class Billing {
  #int email
  -float createdAt
  -boolean address
  -int price
  #float amount
  +processCode()
  +cancelType()
}
class Prescription {
  -float level
  +Date note
  +long active
  #boolean updatedAt
  -double amount
  +validateScore()
  +setEmail()
  +validateScore()
}
Prescription --o Doctor
Patient --o Prescription
note right of Doctor : Healthcare domain
@enduml