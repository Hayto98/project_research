@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Doctor {
  #String description
  #boolean status
  #long updatedAt
  +calculateTotal()
  +validateNote()
}
class Patient {
  #float duration
  +int code
  +boolean id
  +long type
  +createType()
  +validateAddress()
  +sendId()
  +saveCreatedat()
}
interface Billing {
  +Date amount
  #Date description
  +double address
  +boolean quantity
  #double active
  +setAmount()
  +updateNote()
  +createType()
}
abstract class Prescription {
  -float active
  +Date score
  +long level
  #boolean updatedAt
  -double amount
  +processStatus()
  +validateLevel()
  +getCreatedat()
}
Billing --> Patient : "1..*"
Prescription --o Doctor
@enduml