@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
abstract class FuelLog {
  #String total
  #boolean id
  #boolean status
  +setScore()
  +getPhone()
  +updateAddress()
}
class Vehicle {
  -int name
  -Date email
  -double active
  #boolean duration
  -int amount
  +findScore()
  +saveNote()
  +validateLevel()
}
abstract class Inventory {
  #Date type
  #long price
  +Date total
  +Date active
  #double score
  +findCreatedat()
  +processStatus()
}
class Customer {
  +long note
  -int amount
  -double score
  +cancelType()
}
interface Shipment {
  +float score
  +long phone
  +sendCreatedat()
  +sendNote()
}
class DeliveryNote {
  #String id
  +double code
  -Date amount
  +updateId()
  +createName()
  +getName()
}
Customer ..|> Inventory
Shipment ..|> Vehicle
Shipment --> DeliveryNote : "*"
@enduml