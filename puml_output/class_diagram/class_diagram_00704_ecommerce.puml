@startuml
skinparam monochrome true
skinparam shadowing true
class Order {
  #float active
  #Date total
  +float createdAt
  #String amount
  #long description
  +validateQuantity()
  +validateActive()
}
abstract class Return {
  #String name
  +long active
  +updatePrice()
  +cancelPhone()
}
class Invoice {
  +float duration
  #boolean address
  -String level
  +createPhone()
  +sendStatus()
  +createType()
}
class Supplier {
  -float address
  +double amount
  -Date price
  #int status
  -double phone
  +createQuantity()
}
interface Shipment {
  -long level
  +double amount
  +updateScore()
  +validateAddress()
}
class Customer {
  +int amount
  #Date total
  #int quantity
  +Date description
  +sendCreatedat()
  +processCreatedat()
  +processCode()
}
Return --o Invoice
Shipment --> Order : "*"
Customer ..> Shipment : "1"
Customer --> Return : "1"
note right of Order : Ecommerce domain
@enduml