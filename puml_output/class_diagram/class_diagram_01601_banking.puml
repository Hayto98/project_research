@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Beneficiary {
  -String note
  #int amount
  +setPhone()
}
class Teller {
  -double quantity
  -Date status
  #String id
  +updateDuration()
  +processPhone()
}
interface Account {
  -boolean duration
  -Date note
  -int name
  +saveEmail()
  +saveActive()
  +createAddress()
}
abstract class Transaction {
  +Date description
  #String name
  +saveEmail()
  +cancelTotal()
  +createEmail()
  +getUpdatedat()
}
interface Deposit {
  +long name
  #int code
  #float amount
  #int duration
  +long status
  +getNote()
  +deleteTotal()
}
interface Customer {
  +String description
  -float amount
  +updateStatus()
  +setType()
  +validateCreatedat()
}
Account --> Customer : "*"
Teller ..> Beneficiary : "1..*"
@enduml