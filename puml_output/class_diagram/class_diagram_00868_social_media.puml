@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
interface Post {
  #float description
  -double email
  -long code
  +saveDescription()
  +saveScore()
  +saveTotal()
}
abstract class User {
  -boolean phone
  -double note
  -double type
  #Date updatedAt
  -long name
  +getEmail()
  +validateNote()
  +sendStatus()
}
interface Group {
  +float level
  #float type
  -double price
  -double phone
  #long createdAt
  +setDescription()
  +cancelPrice()
  +sendActive()
  +deleteAmount()
}
class Message {
  -long createdAt
  +boolean duration
  #String level
  #Date description
  #int price
  +processNote()
  +updateName()
  +sendAmount()
}
class Notification {
  +String name
  #long score
  #String quantity
  #int status
  +createDuration()
  +calculateName()
  +sendCode()
  +processLevel()
}
Message ..|> Post
Group --|> Message
note right of Post : Social Media domain
@enduml