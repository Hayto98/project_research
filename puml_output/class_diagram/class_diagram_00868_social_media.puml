@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
interface Post {
  #float description
  -double email
  -long code
  +validatePrice()
  +cancelDescription()
  +findPhone()
}
interface User {
  +String note
  -boolean duration
  -double phone
  -double level
  #Date type
  +cancelId()
  +saveDuration()
  +updateDuration()
}
class Group {
  #double note
  #Date active
  -float status
  #boolean price
  +processActive()
  +processCode()
  +findType()
}
class Message {
  +float total
  #double note
  #boolean address
  +float type
  +long status
  +sendId()
  +calculateNote()
  +findDescription()
  +getTotal()
}
class Notification {
  -double type
  -int email
  +boolean description
  +int status
  -String createdAt
  +sendLevel()
  +validateEmail()
  +sendTotal()
}
Group ..> Post : "0..1"
Message --> Group : "*"
@enduml