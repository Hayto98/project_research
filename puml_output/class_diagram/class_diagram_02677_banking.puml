@startuml
skinparam shadowing true
class Transfer {
  #String status
  #float createdAt
  #boolean level
  +cancelPrice()
}
class Teller {
  -int email
  #float updatedAt
  +calculateTotal()
  +saveUpdatedat()
  +processPrice()
  +findUpdatedat()
}
abstract class Statement {
  +boolean score
  -long quantity
  -long active
  +getId()
  +setDuration()
  +cancelStatus()
}
class Withdrawal {
  -String phone
  +double level
  +deleteDuration()
}
abstract class Account {
  +Date updatedAt
  -String amount
  +createAddress()
  +getNote()
  +updateActive()
}
class Customer {
  +long description
  -int score
  -long level
  -boolean createdAt
  +getActive()
  +findTotal()
  +findTotal()
  +processLevel()
}
class Branch {
  +Date level
  #double score
  #float price
  +long code
  +processQuantity()
  +setDescription()
}
Account ..|> Withdrawal
Customer ..> Transfer : "1"
Statement ..|> Customer
Branch --|> Withdrawal
Teller ..> Withdrawal : "1"
note right of Transfer : Banking domain
@enduml