@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Driver {
  +int code
  -String amount
  -Date email
  +calculateActive()
  +sendDuration()
  +validateLevel()
  +deleteName()
}
class FuelLog {
  +float active
  #String quantity
  -boolean code
  #String phone
  +getCode()
  +getType()
  +setName()
}
class Depot {
  +long type
  -int phone
  +deleteScore()
}
class Customer {
  #int type
  +int id
  #Date amount
  +setId()
  +sendTotal()
  +cancelCreatedat()
  +calculateScore()
}
abstract class Manifest {
  -Date active
  -float price
  -float note
  +findNote()
  +sendUpdatedat()
  +cancelName()
}
class Route {
  -double phone
  +boolean description
  +processNote()
  +deleteAddress()
}
Depot --* Route
Customer --> Route : "*"
Manifest ..> Route : "0..1"
FuelLog --* Depot
note right of Driver : Logistics domain
@enduml