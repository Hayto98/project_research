@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Driver {
  +int code
  -String amount
  -Date email
  +calculateCode()
  +updateNote()
  +sendQuantity()
  +updateAddress()
}
interface FuelLog {
  -float level
  #boolean amount
  -Date name
  +long id
  +saveType()
  +deletePhone()
}
class Depot {
  +float score
  +double status
  +String phone
  +String name
  +cancelDescription()
  +saveDescription()
  +sendLevel()
  +findCode()
}
class Customer {
  #long total
  +double description
  +Date id
  +boolean amount
  +updateStatus()
  +cancelNote()
}
interface Manifest {
  -boolean code
  -int id
  #double score
  -double total
  #long createdAt
  +setQuantity()
  +createDescription()
  +getDescription()
}
class Route {
  -float score
  #Date updatedAt
  +long name
  -int level
  #int code
  +cancelQuantity()
  +validateQuantity()
  +calculateName()
  +calculateScore()
}
Depot --o Route
Customer --o Manifest
Manifest ..> Route : "0..1"
FuelLog --* Depot
@enduml