@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
abstract class Account {
  +int updatedAt
  #double status
  #long active
  #int score
  +updateName()
  +deleteStatus()
}
interface Transfer {
  +double active
  #int updatedAt
  -int email
  +createCode()
  +saveQuantity()
}
abstract class Statement {
  #long address
  -boolean email
  -float type
  +calculateUpdatedat()
  +updateActive()
  +createActive()
  +setScore()
}
abstract class Interest {
  #double total
  -long createdAt
  -long email
  #boolean description
  +setAddress()
  +deletePhone()
}
class Teller {
  +int quantity
  #double email
  -double description
  +saveEmail()
  +sendUpdatedat()
  +processDescription()
  +createPhone()
}
class Deposit {
  +int name
  +long type
  -float score
  -double duration
  +int createdAt
  +cancelDescription()
  +sendNote()
  +validateType()
  +sendCode()
}
abstract class Card {
  #int status
  -float score
  #float duration
  #Date type
  +boolean id
  +createPrice()
}
Card --|> Teller
Statement --* Account
Card ..> Account : "*"
Transfer ..> Account : "0..1"
@enduml