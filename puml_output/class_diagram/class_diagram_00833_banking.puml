@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Transfer {
  -int address
  +Date level
  +processScore()
  +createId()
  +sendLevel()
}
abstract class Interest {
  -long createdAt
  -Date active
  -long type
  +int status
  #Date email
  +sendQuantity()
  +sendName()
}
abstract class Withdrawal {
  -boolean total
  -String level
  -int email
  +validateId()
  +processDuration()
}
class Branch {
  +long amount
  #float code
  +float note
  +boolean type
  #double updatedAt
  +cancelTotal()
}
class Customer {
  #double address
  +float phone
  -int description
  +createTotal()
  +cancelName()
}
class Card {
  +Date total
  #float active
  +int quantity
  -boolean phone
  -Date email
  +validateCode()
  +setDuration()
  +cancelId()
}
abstract class Transaction {
  #Date note
  #long createdAt
  -String duration
  +boolean name
  +updateScore()
}
Transaction ..|> Transfer
Interest --* Customer
Withdrawal --> Transfer : "*"
Transfer ..|> Transaction
@enduml