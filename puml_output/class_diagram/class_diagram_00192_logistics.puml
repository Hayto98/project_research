@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class DeliveryNote {
  -float note
  -float updatedAt
  +float description
  +cancelCode()
  +deleteUpdatedat()
  +updateQuantity()
}
class Package {
  #String createdAt
  -long id
  +cancelActive()
  +createActive()
  +validateId()
  +updateNote()
}
interface Route {
  -Date quantity
  -String createdAt
  +saveAmount()
  +processPhone()
  +cancelNote()
  +deleteScore()
}
class Vehicle {
  -float price
  -long score
  -boolean note
  +setActive()
  +createDuration()
  +cancelType()
}
interface FuelLog {
  #double active
  #int price
  +float duration
  -Date updatedAt
  +validateScore()
  +processDuration()
  +findDuration()
}
abstract class Depot {
  #float amount
  #float phone
  -String createdAt
  #long name
  +sendCode()
}
Package ..|> DeliveryNote
Vehicle --* DeliveryNote
@enduml