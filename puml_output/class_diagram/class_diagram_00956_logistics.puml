@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class DeliveryNote {
  -float status
  +Date id
  +String address
  +float active
  +deleteAmount()
  +processAmount()
}
interface Customer {
  #float quantity
  +int note
  #boolean createdAt
  +setLevel()
}
class Inventory {
  +String updatedAt
  #Date score
  -double email
  +setType()
  +processQuantity()
  +calculateQuantity()
}
abstract class Route {
  -int active
  -boolean description
  +createActive()
  +setCreatedat()
  +cancelAmount()
}
class Package {
  -float phone
  +double total
  +setActive()
  +processActive()
}
Customer ..|> Inventory
Customer --* Route
Customer --|> DeliveryNote
@enduml