@startuml
skinparam defaultFontSize 11
class Order {
  -String duration
  +int address
  #long score
  +findDescription()
  +createCode()
}
interface Warehouse {
  +Date note
  #double id
  +long price
  -float level
  +validateStatus()
}
class Coupon {
  #float name
  #boolean quantity
  +int createdAt
  #double updatedAt
  #long note
  +calculateTotal()
}
class Category {
  +long id
  +long price
  -int description
  #int score
  #long status
  +findAmount()
  +cancelScore()
  +createLevel()
}
class Supplier {
  #long name
  +int updatedAt
  +String quantity
  +processDescription()
  +sendType()
}
class Cart {
  -int code
  +double type
  #long total
  +String amount
  #int address
  +findCreatedat()
}
Category --|> Coupon
Warehouse ..> Cart : "1"
Warehouse --* Coupon
Order --o Coupon
note right of Order : Ecommerce domain
@enduml