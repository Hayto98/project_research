@startuml
skinparam ArrowColor #555555
interface Customer {
  +float phone
  -double total
  #Date type
  +updateAmount()
  +validateName()
}
class Supplier {
  -boolean type
  #String total
  -String description
  +int name
  +getTotal()
}
abstract class Shipment {
  +String note
  +long amount
  +processScore()
  +updateAmount()
}
interface Coupon {
  -Date id
  -Date phone
  -int name
  +calculateType()
  +getDescription()
}
Coupon --* Customer
Coupon --|> Supplier
note right of Customer : Ecommerce domain
@enduml