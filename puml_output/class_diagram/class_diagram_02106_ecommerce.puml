@startuml
skinparam ArrowColor #555555
interface Customer {
  +float phone
  -double total
  #Date type
  +setDuration()
  +sendId()
}
class Supplier {
  -int name
  +long code
  #Date quantity
  +long type
  +saveEmail()
}
class Shipment {
  #double id
  +float total
  +validateDescription()
  +findId()
  +processScore()
  +updateUpdatedat()
}
class Coupon {
  #int quantity
  +float description
  #int type
  +updatePhone()
}
Customer ..> Supplier : "1..*"
Shipment ..> Customer : "0..1"
Coupon --|> Supplier
@enduml