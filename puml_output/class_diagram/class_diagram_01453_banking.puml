@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Customer {
  -long code
  +String duration
  +updateLevel()
  +validateStatus()
  +createId()
}
class Account {
  -long duration
  +int active
  +boolean status
  #float total
  +updateType()
  +createEmail()
}
class Beneficiary {
  +double email
  +int duration
  -long level
  +boolean status
  +processQuantity()
  +cancelNote()
  +sendDuration()
  +validateScore()
}
class Branch {
  -float id
  #double total
  +sendDuration()
  +validateQuantity()
}
class Transfer {
  -int price
  #String active
  +findCreatedat()
  +sendId()
  +sendStatus()
}
class Teller {
  -boolean name
  +double code
  +createStatus()
  +deletePhone()
  +validateDuration()
}
Account --> Customer : "1"
Transfer ..|> Account
note right of Customer : Banking domain
@enduml