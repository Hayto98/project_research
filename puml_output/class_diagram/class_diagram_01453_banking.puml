@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Customer {
  -long code
  +String duration
  +validateDescription()
  +updateStatus()
  +updatePhone()
}
interface Account {
  #long status
  #boolean quantity
  #String id
  -double address
  +updateDuration()
  +sendId()
  +findType()
}
class Beneficiary {
  -Date createdAt
  -Date type
  -long quantity
  +sendAddress()
  +createEmail()
  +getDescription()
}
class Branch {
  -long price
  +boolean id
  -double description
  +findName()
  +setDuration()
  +deletePrice()
}
interface Transfer {
  -long score
  #double status
  +boolean code
  #float id
  +updateQuantity()
  +createType()
  +updateLevel()
}
class Teller {
  -int price
  #String active
  +sendUpdatedat()
  +getTotal()
  +setDuration()
}
Transfer --|> Customer
Customer --|> Teller
@enduml