@startuml
skinparam monochrome true
skinparam shadowing true
class Account {
  -boolean type
  -long code
  +int email
  -long price
  +double phone
  +setPrice()
  +processCreatedat()
}
interface Withdrawal {
  #double createdAt
  +float amount
  +deleteType()
  +processName()
  +cancelCreatedat()
}
abstract class Teller {
  +double amount
  #int id
  +int level
  +calculateDuration()
  +getDescription()
}
class Transaction {
  -Date updatedAt
  +double active
  +long level
  +sendTotal()
}
abstract class Branch {
  -double note
  #double total
  +cancelQuantity()
  +calculateQuantity()
  +processTotal()
  +updateType()
}
interface Customer {
  -int active
  +double code
  +Date description
  +validatePrice()
  +createType()
  +updateUpdatedat()
  +updateLevel()
}
Withdrawal ..> Teller : "1"
Account --* Branch
Account --* Transaction
Branch --> Teller : "1"
Branch --o Withdrawal
@enduml