@startuml
skinparam shadowing true
class Transaction {
  #long quantity
  +int phone
  +boolean amount
  +float note
  +createPrice()
  +processStatus()
  +processNote()
  +saveType()
}
class Customer {
  #Date id
  #Date address
  +int quantity
  +calculatePhone()
}
class Withdrawal {
  +String price
  #float name
  #Date active
  +cancelUpdatedat()
  +deleteAddress()
}
interface Deposit {
  #double amount
  #boolean duration
  +Date phone
  -boolean quantity
  #String score
  +cancelPrice()
}
class Card {
  -float active
  #Date note
  #double updatedAt
  #String email
  #Date type
  +getPrice()
  +processCreatedat()
}
interface Teller {
  +long active
  #long address
  +deleteCode()
}
Card ..> Withdrawal : "0..1"
Customer --o Withdrawal
note right of Transaction : Banking domain
@enduml