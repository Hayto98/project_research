@startuml
skinparam shadowing true
class Transaction {
  #long quantity
  +int phone
  +boolean amount
  +float note
  +getNote()
  +processType()
  +findActive()
  +validateEmail()
}
abstract class Customer {
  -boolean type
  #boolean phone
  #String createdAt
  +String id
  -long address
  +updateStatus()
  +cancelDuration()
}
abstract class Withdrawal {
  +Date active
  #Date id
  +setPhone()
  +findAddress()
}
class Deposit {
  +float duration
  +float level
  -long score
  #Date note
  +deleteStatus()
  +findActive()
  +savePrice()
}
interface Card {
  #String email
  #Date id
  +getTotal()
  +processLevel()
  +calculateActive()
  +createName()
}
class Teller {
  #String type
  #Date price
  +String active
  -float note
  +getTotal()
  +getCode()
  +updatePrice()
  +sendQuantity()
}
Transaction ..> Withdrawal : "1..*"
Transaction --|> Customer
Customer --* Card
Teller ..> Card : "0..1"
@enduml