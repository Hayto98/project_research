@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class LabTest {
  #double type
  #String duration
  -float price
  +updateScore()
}
interface Hospital {
  #float updatedAt
  #double quantity
  #double phone
  +Date code
  -String note
  +saveId()
}
abstract class Appointment {
  #long score
  #double status
  #Date total
  #boolean email
  #String address
  +deleteId()
  +processName()
  +findStatus()
}
abstract class Ward {
  +int active
  +float email
  +String level
  +getId()
  +calculateQuantity()
  +validateCreatedat()
}
class Nurse {
  -double phone
  +String duration
  #boolean id
  #int code
  -boolean address
  +getCreatedat()
  +calculateAmount()
  +processNote()
}
class Diagnosis {
  #int description
  -long duration
  +String type
  #long price
  #boolean id
  +saveAddress()
}
class MedicalRecord {
  -Date updatedAt
  #double createdAt
  +findScore()
}
Appointment --* MedicalRecord
Diagnosis ..|> MedicalRecord
Ward --* LabTest
Hospital --|> MedicalRecord
@enduml