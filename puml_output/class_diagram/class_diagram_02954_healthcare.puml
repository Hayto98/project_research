@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class LabTest {
  #double type
  #String duration
  -float price
  +findLevel()
}
abstract class Hospital {
  -float quantity
  #float phone
  #double code
  +deleteEmail()
  +getId()
  +getTotal()
  +processScore()
}
class Appointment {
  -String email
  #double address
  +Date duration
  #long type
  -float id
  +updateStatus()
  +deleteCode()
}
class Ward {
  -boolean total
  #float description
  +String phone
  #float type
  -double score
  +updateId()
  +cancelActive()
  +saveDescription()
  +createDuration()
}
class Nurse {
  -String status
  #int total
  -long description
  +String score
  #long type
  +deleteEmail()
}
class Diagnosis {
  +long createdAt
  -long note
  -long level
  +calculateStatus()
  +validateUpdatedat()
}
class MedicalRecord {
  +long note
  -int status
  +updateDescription()
  +findAmount()
}
MedicalRecord ..> Nurse : "1..*"
Ward --> Nurse : "0..1"
Appointment ..> MedicalRecord : "1..*"
LabTest --o Diagnosis
LabTest ..|> Hospital
note right of LabTest : Healthcare domain
@enduml