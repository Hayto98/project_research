@startuml

class Renewal {
  -long duration
  -Date description
  +getCode()
  +deleteCreatedat()
}
class Loan {
  #boolean level
  #boolean phone
  -Date status
  +validatePrice()
  +validateStatus()
}
abstract class Librarian {
  #float total
  +long price
  -long description
  #long amount
  +calculateUpdatedat()
  +updateUpdatedat()
  +findLevel()
  +saveId()
}
class Shelf {
  -float code
  #int name
  #long active
  #long id
  #int createdAt
  +findId()
  +deleteDuration()
  +validateDescription()
  +createAddress()
}
abstract class Member {
  -double updatedAt
  #Date duration
  +Date total
  -boolean active
  +findTotal()
  +getId()
}
abstract class Author {
  +long price
  +Date address
  +boolean status
  -String name
  +processTotal()
}
class Book {
  #float duration
  +String quantity
  #int active
  +getDuration()
  +deleteCreatedat()
  +cancelName()
  +findScore()
}
Shelf ..> Member : "0..1"
Librarian ..> Member : "1"
Member --* Author
Author ..|> Shelf
Renewal --> Loan : "1..*"
@enduml