@startuml

class Renewal {
  -long duration
  -Date description
  +cancelEmail()
  +getAmount()
}
interface Loan {
  #int status
  #float score
  -float active
  -double phone
  +deleteScore()
  +deleteUpdatedat()
  +createPrice()
  +validateActive()
}
class Librarian {
  #String status
  #Date name
  +float duration
  #boolean price
  +double code
  +cancelEmail()
  +savePhone()
}
interface Shelf {
  +float note
  #float amount
  -float duration
  +updateUpdatedat()
  +calculateActive()
  +createNote()
}
class Member {
  -double score
  -String amount
  +int type
  -String total
  +sendAddress()
  +getCode()
}
abstract class Author {
  +boolean updatedAt
  +double quantity
  -Date active
  -long id
  +processActive()
  +findAmount()
  +validateDuration()
  +findId()
}
interface Book {
  #float price
  #float description
  -long id
  -int createdAt
  +createPrice()
  +getType()
}
Shelf ..|> Loan
Author --o Shelf
note right of Renewal : Library domain
@enduml