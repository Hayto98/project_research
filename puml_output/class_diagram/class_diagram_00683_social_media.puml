@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Post {
  #double duration
  -String price
  +double description
  #long phone
  +sendLevel()
  +updateScore()
  +calculateCreatedat()
}
interface Album {
  -String amount
  #float level
  +processActive()
  +sendNote()
}
class Profile {
  -String price
  #String level
  -long updatedAt
  #long address
  +getPrice()
}
class Comment {
  #Date price
  #int duration
  +setEmail()
  +getTotal()
  +setPrice()
  +updateActive()
}
class User {
  -double address
  -float duration
  #int email
  +sendDuration()
}
User ..|> Post
Post --> Comment : "1"
Comment --|> Profile
note right of Post : Social Media domain
@enduml