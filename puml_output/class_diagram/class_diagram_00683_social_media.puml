@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Post {
  #double duration
  -String price
  +double description
  #long phone
  +updateNote()
  +calculateTotal()
  +cancelActive()
}
class Album {
  +boolean createdAt
  +float active
  -boolean status
  #double amount
  +long total
  +savePrice()
  +sendNote()
  +validateDuration()
  +sendAddress()
}
class Profile {
  #long total
  +String phone
  +setScore()
  +validateNote()
  +findType()
  +calculateDescription()
}
interface Comment {
  #Date price
  #int duration
  +setStatus()
  +deleteName()
  +saveEmail()
  +findAmount()
}
class User {
  -long createdAt
  -double active
  -float name
  #int description
  #Date address
  +updateNote()
}
User ..|> Post
Post --> Comment : "1"
Comment --|> Profile
@enduml