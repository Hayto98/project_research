@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Guest {
  #double note
  #int quantity
  -float createdAt
  +cancelActive()
}
abstract class Staff {
  -long duration
  +int description
  -boolean name
  -double email
  +calculateScore()
  +cancelAmount()
  +saveStatus()
  +processTotal()
}
abstract class Reservation {
  -double updatedAt
  #double duration
  +updateName()
  +setType()
  +getUpdatedat()
}
abstract class CheckOut {
  -long amount
  -float status
  +validateDescription()
  +updateCode()
  +calculateType()
}
abstract class Room {
  -double total
  +long quantity
  #Date email
  -Date phone
  +deleteScore()
  +getLevel()
  +saveQuantity()
}
class Service {
  -double status
  #boolean id
  -boolean price
  +float type
  +validateDuration()
  +cancelActive()
}
CheckOut --o Staff
Staff ..|> CheckOut
@enduml