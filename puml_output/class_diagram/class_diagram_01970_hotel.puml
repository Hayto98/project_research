@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Guest {
  #double note
  #int quantity
  -float createdAt
  +cancelTotal()
}
class Staff {
  -int name
  +long email
  #double address
  +processEmail()
  +sendNote()
  +processId()
  +updateUpdatedat()
}
class Reservation {
  -String score
  +String type
  -long phone
  -float status
  -float description
  +cancelPhone()
  +calculateQuantity()
  +createPhone()
  +processPrice()
}
class CheckOut {
  +int score
  -Date phone
  -float level
  +String amount
  +sendType()
  +calculatePrice()
  +saveLevel()
  +calculateDuration()
}
class Room {
  -int address
  -int level
  -int id
  +setAddress()
  +setEmail()
  +createLevel()
  +updateType()
}
class Service {
  -String phone
  +long name
  +getLevel()
}
Staff ..|> Guest
Room ..|> Staff
note right of Guest : Hotel domain
@enduml