@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
abstract class Payment {
  -Date createdAt
  +int description
  -float price
  #double active
  +processEmail()
  +setId()
}
interface Review {
  #Date amount
  +float name
  #float phone
  +sendUpdatedat()
  +createAmount()
}
interface Invoice {
  +String total
  -int email
  -long name
  -String updatedAt
  +deleteScore()
  +createId()
  +validatePrice()
}
class Customer {
  #String score
  -int quantity
  -boolean name
  -String price
  +sendUpdatedat()
  +cancelPhone()
  +saveScore()
}
Payment --* Review
Invoice --|> Payment
@enduml