@startuml
skinparam monochrome true
abstract class Booking {
  +boolean total
  #int createdAt
  -String type
  +long phone
  -int name
  +getActive()
}
class Housekeeping {
  -boolean id
  #boolean level
  +Date status
  #double price
  +Date type
  +createTotal()
  +cancelId()
  +calculateDescription()
}
interface Service {
  -Date quantity
  +boolean email
  +getCode()
}
class CheckIn {
  -Date quantity
  -Date description
  +double level
  +validatePrice()
}
Service --> Housekeeping : "*"
CheckIn ..|> Booking
@enduml