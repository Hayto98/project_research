@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
interface Order {
  +long duration
  +boolean phone
  +String active
  +processType()
  +updateQuantity()
  +setNote()
  +getActive()
}
class Review {
  +float updatedAt
  +boolean note
  -long email
  -float id
  +updateStatus()
  +saveName()
  +saveNote()
  +createQuantity()
}
class Return {
  #long active
  -int code
  +setLevel()
  +cancelNote()
  +createName()
  +deleteUpdatedat()
}
abstract class Warehouse {
  #Date type
  #Date updatedAt
  -double createdAt
  #long code
  +float description
  +setPrice()
  +createScore()
  +createQuantity()
  +setScore()
}
abstract class Customer {
  +String quantity
  +float price
  #long email
  +float updatedAt
  +findStatus()
  +getUpdatedat()
  +updateAmount()
}
Warehouse --* Customer
Order --o Return
Review --|> Order
Return --* Warehouse
@enduml