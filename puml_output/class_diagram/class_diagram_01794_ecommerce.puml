@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
interface Order {
  +long duration
  +boolean phone
  +String active
  +calculateTotal()
  +findDescription()
  +validateUpdatedat()
  +processEmail()
}
class Review {
  -long amount
  -float active
  +updatePrice()
  +updateQuantity()
  +createName()
  +sendCode()
}
class Return {
  -boolean amount
  -double total
  -int description
  +String createdAt
  +cancelScore()
  +findAddress()
}
abstract class Warehouse {
  #Date code
  -boolean note
  -long updatedAt
  #double quantity
  +updateName()
  +setCode()
  +savePhone()
}
class Customer {
  +float level
  -float type
  -int price
  +String address
  +processEmail()
  +createAmount()
  +findActive()
}
Return --* Order
Customer --o Review
Warehouse --o Order
note right of Order : Ecommerce domain
@enduml