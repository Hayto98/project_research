@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
abstract class Post {
  #String description
  #String phone
  +boolean createdAt
  +updateCreatedat()
}
class Report {
  +boolean createdAt
  +long code
  +validateDescription()
}
class Follower {
  #float price
  #boolean phone
  +setDescription()
  +getNote()
  +sendStatus()
}
class Message {
  +String address
  +long quantity
  +saveNote()
  +updateAmount()
  +setUpdatedat()
  +validateType()
}
Message --o Report
Follower --|> Post
@enduml