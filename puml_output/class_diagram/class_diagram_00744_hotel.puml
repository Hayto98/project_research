@startuml
skinparam monochrome true
skinparam defaultFontSize 11
abstract class Reservation {
  #long quantity
  #int name
  +validateAmount()
}
abstract class Restaurant {
  #long code
  -Date duration
  -int level
  #Date id
  -Date status
  +cancelDescription()
  +calculateTotal()
  +cancelStatus()
}
class Staff {
  #float address
  +float code
  +long active
  +boolean score
  #float description
  +getAddress()
  +updateActive()
}
interface Room {
  +float email
  #Date quantity
  +long id
  +boolean updatedAt
  +long status
  +createScore()
  +createNote()
  +getDescription()
}
class Invoice {
  -int active
  -int address
  -String name
  +processCode()
}
interface Service {
  #double phone
  #double status
  -float code
  +sendAddress()
  +findAddress()
}
class CheckIn {
  #Date price
  #int note
  #float email
  #long score
  +findDuration()
  +getPrice()
}
CheckIn ..|> Staff
Invoice --> Room : "1..*"
Service ..> Restaurant : "*"
@enduml