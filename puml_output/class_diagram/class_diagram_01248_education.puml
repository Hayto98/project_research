@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
interface Enrollment {
  +boolean quantity
  #int name
  +double phone
  -boolean note
  +validateCreatedat()
}
class Attendance {
  +Date score
  #double updatedAt
  -String active
  +boolean address
  -boolean id
  +updatePrice()
  +saveScore()
  +calculateQuantity()
  +setScore()
}
abstract class Course {
  -float score
  +boolean address
  +deleteCreatedat()
  +setLevel()
  +findQuantity()
  +sendType()
}
interface Grade {
  +double code
  #float address
  -long level
  +String score
  +deleteQuantity()
}
Attendance --> Enrollment : "1..*"
Enrollment --o Attendance
@enduml