@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
interface Enrollment {
  +boolean quantity
  #int name
  +double phone
  -boolean note
  +deleteName()
}
abstract class Attendance {
  +Date active
  #double address
  -String id
  +cancelNote()
}
interface Course {
  #float id
  #Date phone
  #long total
  -float price
  +boolean status
  +createDescription()
  +validateDuration()
  +createCode()
  +validateAddress()
}
class Grade {
  -int total
  +String quantity
  +updateLevel()
}
Enrollment ..> Course : "1..*"
Enrollment --o Attendance
note right of Enrollment : Education domain
@enduml