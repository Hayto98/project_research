@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Book {
  #int id
  +long address
  -String status
  -long name
  +setCreatedat()
  +createActive()
}
class Student {
  +String score
  -double price
  +validateStatus()
  +calculateAmount()
  +updateCreatedat()
}
interface Exam {
  -double type
  +float note
  -Date duration
  -double quantity
  +sendDescription()
  +setDescription()
  +calculateAmount()
  +updateActive()
}
class Course {
  #long code
  +int active
  +processNote()
}
Exam ..> Book : "0..1"
Course --> Student : "0..1"
@enduml