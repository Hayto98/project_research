@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Book {
  #int id
  +long address
  -String status
  -long name
  +findAddress()
  +validateCode()
}
interface Student {
  -float id
  #long code
  -double total
  -long type
  -double email
  +processEmail()
  +calculatePrice()
}
class Exam {
  +int id
  #String name
  #int duration
  #long code
  +float quantity
  +calculatePrice()
  +sendAmount()
}
interface Course {
  +double score
  #double type
  +boolean amount
  -float level
  +int email
  +getPhone()
}
Book --|> Student
Course --> Book : "*"
note right of Book : Education domain
@enduml