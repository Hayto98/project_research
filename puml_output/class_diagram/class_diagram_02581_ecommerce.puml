@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Order {
  #long price
  +String quantity
  #long description
  +Date status
  +setActive()
  +processId()
  +sendActive()
  +calculateType()
}
interface Product {
  -long status
  +double address
  -Date quantity
  +int amount
  +int code
  +calculateId()
  +cancelPrice()
  +createId()
}
class Cart {
  -String note
  +float phone
  +String active
  +deleteName()
  +calculateName()
  +getQuantity()
}
class Warehouse {
  +double level
  +boolean amount
  #Date active
  +sendLevel()
}
class Customer {
  #String level
  +double quantity
  +Date type
  +getStatus()
  +findDescription()
  +calculateAddress()
}
class Supplier {
  +int level
  #double code
  -String price
  +processActive()
  +updateUpdatedat()
  +deleteScore()
  +deleteQuantity()
}
Supplier ..|> Order
Warehouse --|> Supplier
@enduml