@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
abstract class Department {
  -double description
  #long type
  -int phone
  +long note
  #Date amount
  +setDescription()
  +validateCode()
  +processLevel()
}
interface Attendance {
  -double name
  -double duration
  -long id
  +boolean level
  -int total
  +calculateAmount()
  +saveCode()
  +cancelType()
}
class Library {
  -long status
  #double createdAt
  #float type
  +setCreatedat()
  +processDuration()
  +updateAddress()
  +getActive()
}
class Schedule {
  +String duration
  +Date total
  #double id
  -long status
  +long description
  +cancelAddress()
}
class Student {
  -String name
  +long active
  +saveCode()
  +setLevel()
}
interface Classroom {
  #float amount
  -int id
  -int address
  -double quantity
  +sendPrice()
}
class Course {
  #int score
  #float level
  +validateId()
}
Library --|> Classroom
Course --|> Student
Library --o Attendance
@enduml