@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
abstract class Department {
  -double description
  #long type
  -int phone
  +long note
  #Date amount
  +setDescription()
  +calculateScore()
  +processName()
}
class Attendance {
  -double name
  -double total
  +validateDescription()
  +cancelType()
  +updatePhone()
  +processPrice()
}
class Library {
  -long status
  #double createdAt
  #float type
  +findUpdatedat()
  +saveName()
  +calculateDuration()
  +calculateId()
}
class Schedule {
  #boolean code
  -double status
  -int duration
  +findCode()
  +createStatus()
  +getName()
}
interface Student {
  +boolean code
  -Date updatedAt
  +String quantity
  -long level
  #float price
  +deletePrice()
  +updatePrice()
  +calculateCode()
  +saveAddress()
}
class Classroom {
  #int score
  -Date name
  +float status
  +validateUpdatedat()
}
abstract class Course {
  -int name
  -long active
  +long phone
  -String type
  -String level
  +validateQuantity()
}
Student --|> Schedule
Student ..|> Library
Department ..|> Student
Attendance ..|> Student
Library --> Attendance : "*"
note right of Department : Education domain
@enduml