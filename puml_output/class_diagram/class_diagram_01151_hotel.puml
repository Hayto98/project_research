@startuml

interface Guest {
  #String description
  -long price
  -boolean score
  -Date email
  +saveCreatedat()
  +deletePrice()
  +sendCreatedat()
  +deleteActive()
}
class Housekeeping {
  #boolean total
  #boolean score
  +String type
  +setDuration()
  +setScore()
}
class Restaurant {
  +Date email
  -float quantity
  -String active
  -boolean status
  +double note
  +findName()
  +getPhone()
  +createLevel()
  +getNote()
}
interface CheckOut {
  +double level
  +float address
  +float amount
  +Date score
  -String code
  +setCreatedat()
  +cancelUpdatedat()
  +setLevel()
  +setCreatedat()
}
class CheckIn {
  +int active
  -boolean id
  -float score
  +cancelDuration()
  +cancelEmail()
  +setNote()
}
interface Staff {
  #float email
  -float level
  +calculatePrice()
  +findQuantity()
  +findLevel()
}
Housekeeping --o Guest
Staff --* CheckOut
note right of Guest : Hotel domain
@enduml