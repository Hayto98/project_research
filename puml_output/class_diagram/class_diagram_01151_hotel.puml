@startuml

interface Guest {
  #String description
  -long price
  -boolean score
  -Date email
  +sendDuration()
  +updateId()
  +setActive()
  +updateDescription()
}
class Housekeeping {
  +float active
  -boolean createdAt
  #double amount
  #boolean duration
  #boolean code
  +createAddress()
  +processActive()
}
class Restaurant {
  #double score
  -long name
  +createName()
}
class CheckOut {
  +double note
  -Date status
  +String phone
  -float active
  +validateStatus()
  +processEmail()
  +saveEmail()
}
abstract class CheckIn {
  +double level
  +float address
  +float amount
  +Date score
  -String code
  +findNote()
  +updateDescription()
  +savePrice()
  +createScore()
}
class Staff {
  +Date createdAt
  #float code
  +calculateDuration()
}
Housekeeping --> Restaurant : "1..*"
CheckIn --> Restaurant : "1..*"
@enduml