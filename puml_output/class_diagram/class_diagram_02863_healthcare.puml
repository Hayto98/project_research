@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
interface Diagnosis {
  +long total
  -String type
  +double email
  #long price
  -float active
  +createType()
  +cancelLevel()
  +createCreatedat()
  +saveTotal()
}
abstract class Appointment {
  +double price
  -int score
  -String status
  +setAmount()
}
class Hospital {
  +long address
  #long status
  #Date note
  -double price
  #long level
  +deleteId()
  +deleteCreatedat()
  +deleteLevel()
}
class Insurance {
  -int id
  #boolean status
  +float createdAt
  -Date quantity
  +sendTotal()
}
class Ward {
  +float name
  -double quantity
  #Date phone
  #double price
  +cancelType()
  +saveStatus()
  +getTotal()
}
abstract class Billing {
  -Date score
  #double note
  #double duration
  #String type
  +findDuration()
}
Ward ..|> Diagnosis
Diagnosis ..|> Ward
@enduml