@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
abstract class Exam {
  #boolean email
  -double score
  #boolean duration
  +double id
  #long note
  +sendDescription()
  +updateNote()
  +deleteId()
}
class Enrollment {
  +long status
  -boolean quantity
  #boolean updatedAt
  +sendLevel()
}
class Teacher {
  -int id
  -boolean active
  -long price
  +deleteTotal()
}
class Assignment {
  -Date code
  #boolean level
  -Date id
  -String score
  -long note
  +createName()
}
interface Library {
  +boolean note
  +int code
  +boolean status
  +String updatedAt
  -String level
  +validateNote()
}
class Attendance {
  +double updatedAt
  +float status
  #double name
  +long price
  #float active
  +deleteStatus()
}
abstract class Schedule {
  -int level
  -long note
  -String description
  +getDescription()
  +validateAddress()
  +sendAmount()
}
Schedule ..|> Attendance
Library ..> Exam : "0..1"
Schedule --|> Teacher
Assignment ..> Attendance : "0..1"
note right of Exam : Education domain
@enduml