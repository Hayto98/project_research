@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
abstract class Exam {
  #boolean email
  -double score
  #boolean duration
  +double id
  #long note
  +calculateDuration()
  +sendUpdatedat()
  +saveQuantity()
}
class Enrollment {
  -Date description
  +int id
  -long level
  #boolean updatedAt
  #String status
  +updatePhone()
}
class Teacher {
  -int active
  -boolean price
  +findCreatedat()
  +cancelDescription()
  +sendActive()
}
class Assignment {
  +boolean total
  +boolean quantity
  +double price
  +updateAddress()
  +validatePrice()
  +calculateDuration()
  +validateScore()
}
abstract class Library {
  +long note
  #String email
  +cancelQuantity()
  +getLevel()
  +calculateType()
  +cancelEmail()
}
interface Attendance {
  #String score
  +String code
  #int id
  +createAmount()
}
class Schedule {
  +double address
  #int note
  +saveId()
}
Assignment --o Exam
Enrollment --o Library
Exam --> Teacher : "1"
Schedule --|> Enrollment
Assignment --> Enrollment : "*"
@enduml