@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
abstract class Branch {
  -String level
  +Date status
  +int score
  -int total
  -long phone
  +createPrice()
  +createEmail()
}
class Renewal {
  -long address
  -long score
  +double price
  #float amount
  #Date type
  +updatePrice()
  +validateType()
  +validateLevel()
}
class Fine {
  +int address
  -long active
  +boolean email
  +setLevel()
  +setStatus()
  +saveName()
  +processEmail()
}
class Shelf {
  -double address
  +Date createdAt
  -boolean name
  -int email
  -float price
  +saveId()
  +createDescription()
}
class Author {
  +boolean description
  +String active
  -String total
  #boolean price
  +float address
  +getAmount()
  +sendPhone()
  +validateDescription()
}
Fine --|> Branch
Renewal --> Fine : "1"
Branch --* Renewal
note right of Branch : Library domain
@enduml