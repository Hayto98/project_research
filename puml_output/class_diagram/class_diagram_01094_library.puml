@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
abstract class Branch {
  -String level
  +Date status
  +int score
  -int total
  -long phone
  +validateAmount()
  +findStatus()
}
abstract class Renewal {
  #Date email
  #boolean address
  -int total
  -long level
  +setEmail()
  +setTotal()
  +validateQuantity()
}
abstract class Fine {
  -boolean createdAt
  +boolean price
  #float phone
  +Date type
  +calculateStatus()
  +updateQuantity()
  +updateNote()
}
class Shelf {
  -String amount
  #Date quantity
  +setDescription()
  +validateStatus()
  +deleteUpdatedat()
  +setStatus()
}
class Author {
  -double type
  #long email
  +saveEmail()
  +deleteName()
}
Author --o Shelf
Shelf ..> Branch : "1..*"
Author ..|> Fine
Fine ..> Renewal : "1"
@enduml