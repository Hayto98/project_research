@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Catalog {
  +boolean quantity
  #String id
  +long address
  -double price
  #double createdAt
  +processAddress()
  +validateCreatedat()
  +processScore()
  +setType()
}
class Branch {
  #double duration
  +float total
  -double name
  #long id
  +updateLevel()
}
class Member {
  -double id
  +float status
  +Date phone
  +long address
  +validateUpdatedat()
}
class Book {
  +long description
  -long level
  #float email
  +double type
  +double active
  +setType()
  +getTotal()
  +processTotal()
  +cancelTotal()
}
class Fine {
  #String createdAt
  +String email
  +validateTotal()
}
class Renewal {
  #long active
  #int name
  #float type
  -int amount
  #double total
  +updateType()
  +sendCode()
  +updateId()
}
abstract class Reservation {
  +float updatedAt
  +boolean duration
  -long score
  +validateUpdatedat()
}
Branch ..|> Fine
Member --> Renewal : "0..1"
Reservation --* Catalog
@enduml