@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Catalog {
  +boolean quantity
  #String id
  +long address
  -double price
  #double createdAt
  +deleteDescription()
  +getPhone()
  +saveDuration()
  +cancelTotal()
}
class Branch {
  -double total
  #long updatedAt
  +createPhone()
}
interface Member {
  -double id
  +float status
  +Date phone
  +long address
  +processStatus()
}
abstract class Book {
  #double level
  #double duration
  +long email
  +validateActive()
  +updateType()
  +getType()
  +calculateDescription()
}
class Fine {
  +int note
  -Date id
  +String createdAt
  +getId()
}
abstract class Renewal {
  #Date type
  #double amount
  +sendUpdatedat()
  +cancelEmail()
  +updateScore()
}
abstract class Reservation {
  +int amount
  #String note
  +boolean total
  -long description
  +processEmail()
}
Fine --* Branch
Renewal --> Fine : "0..1"
Reservation --* Catalog
note right of Catalog : Library domain
@enduml