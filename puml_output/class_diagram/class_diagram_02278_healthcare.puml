@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class MedicalRecord {
  -double type
  +long updatedAt
  #String score
  #float createdAt
  -boolean status
  +calculateEmail()
  +calculateTotal()
}
abstract class Prescription {
  -String score
  #Date updatedAt
  -int id
  +deleteActive()
  +findCode()
}
interface Doctor {
  -double active
  -Date total
  +calculatePhone()
  +validateCreatedat()
  +cancelUpdatedat()
  +processActive()
}
class Patient {
  -long note
  -long price
  +double level
  #String total
  +int description
  +createLevel()
  +validateName()
  +deleteDescription()
}
MedicalRecord ..> Doctor : "1"
Patient --o Prescription
@enduml