@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Warehouse {
  +long duration
  -long code
  +createName()
  +validateStatus()
}
class Product {
  #double id
  +float duration
  -long address
  +getUpdatedat()
  +updateDuration()
}
class Shipment {
  +float name
  #double total
  -long note
  +double status
  #float score
  +sendAddress()
}
class Customer {
  -Date level
  -float status
  +saveCreatedat()
  +updateQuantity()
}
class Coupon {
  -boolean phone
  #Date price
  +getQuantity()
  +setTotal()
}
class Cart {
  +Date level
  -int id
  -boolean description
  +deleteDescription()
}
abstract class Order {
  -String phone
  +float type
  #long amount
  +float createdAt
  -int status
  +createActive()
}
Customer --o Cart
Warehouse --|> Shipment
Shipment --|> Product
@enduml