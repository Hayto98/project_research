@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Warehouse {
  +long duration
  -long code
  +processUpdatedat()
  +deleteId()
}
class Product {
  -boolean score
  +float total
  +String amount
  #Date phone
  +getTotal()
  +processStatus()
  +processDescription()
  +saveTotal()
}
abstract class Shipment {
  -float createdAt
  #long type
  +Date score
  #String code
  +findEmail()
  +sendDescription()
  +validateEmail()
  +getPhone()
}
abstract class Customer {
  #String active
  #int createdAt
  +Date quantity
  -int description
  -boolean level
  +cancelNote()
}
interface Coupon {
  -String phone
  +float type
  #long amount
  +float createdAt
  -int status
  +validateCreatedat()
}
abstract class Cart {
  +int code
  #String email
  -double id
  +String address
  #double description
  +sendNote()
  +cancelCode()
  +setPrice()
  +getAddress()
}
class Order {
  +double phone
  -Date id
  #float email
  +setId()
}
Order ..> Customer : "*"
Shipment ..|> Customer
Cart --o Warehouse
note right of Warehouse : Ecommerce domain
@enduml