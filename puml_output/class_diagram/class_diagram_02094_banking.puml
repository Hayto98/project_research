@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
abstract class Deposit {
  -boolean phone
  -double code
  +sendUpdatedat()
  +getCreatedat()
  +cancelQuantity()
  +updateDescription()
}
abstract class Beneficiary {
  -float price
  +long address
  #String level
  +validateStatus()
  +calculateDescription()
}
interface Interest {
  -double type
  +Date email
  #double note
  +setPhone()
  +calculateAmount()
}
abstract class Account {
  -double active
  +long quantity
  #String code
  #Date note
  -float score
  +validateDescription()
}
class Withdrawal {
  #double email
  #long createdAt
  +cancelPhone()
  +createEmail()
  +setAddress()
}
interface Statement {
  -Date amount
  +double name
  #int duration
  +updateLevel()
  +saveStatus()
}
class Branch {
  -float name
  +int phone
  -double duration
  +findScore()
  +getStatus()
  +cancelPrice()
}
Account ..> Beneficiary : "1..*"
Deposit --> Interest : "1"
Withdrawal ..> Beneficiary : "1"
@enduml