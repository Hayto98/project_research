@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Fine {
  #String id
  -double type
  #long createdAt
  +sendCode()
  +saveTotal()
}
class Catalog {
  +Date status
  -Date duration
  #int phone
  #long address
  +setPrice()
  +updateCreatedat()
  +updateNote()
}
class Publisher {
  -long amount
  +long code
  +double note
  +setPrice()
  +saveEmail()
}
class Librarian {
  #int createdAt
  #float type
  +long price
  +sendCode()
  +processCreatedat()
}
class Loan {
  -int name
  #double note
  -long total
  -String address
  +float price
  +saveUpdatedat()
  +setEmail()
  +savePhone()
}
Loan --|> Publisher
Loan ..> Fine : "1..*"
Fine ..|> Publisher
@enduml