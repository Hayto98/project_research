@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Fine {
  #String id
  -double type
  #long createdAt
  +processId()
  +validateStatus()
}
class Catalog {
  #long address
  #boolean createdAt
  -float phone
  #int amount
  +deleteCode()
  +findNote()
}
abstract class Publisher {
  #float updatedAt
  +String phone
  +int code
  +double note
  +sendUpdatedat()
  +cancelId()
  +validateScore()
  +deleteNote()
}
class Librarian {
  -int name
  #double note
  -long total
  -String address
  +float price
  +saveAddress()
  +getPhone()
  +sendQuantity()
}
class Loan {
  -int email
  -float code
  +setDescription()
  +processDuration()
  +getPrice()
}
Loan --|> Catalog
Loan --* Publisher
Loan ..> Librarian : "*"
note right of Fine : Library domain
@enduml