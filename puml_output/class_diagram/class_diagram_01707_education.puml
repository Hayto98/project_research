@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
interface Exam {
  +String phone
  #float name
  +boolean price
  #double email
  +findId()
  +deleteStatus()
}
class Enrollment {
  +boolean updatedAt
  +boolean email
  -int duration
  +deleteNote()
  +getAmount()
  +findTotal()
  +deleteUpdatedat()
}
class Course {
  -boolean updatedAt
  +float description
  +String level
  -float email
  +int price
  +deleteAddress()
  +setPrice()
  +saveDescription()
  +getCreatedat()
}
class Attendance {
  +long status
  #float level
  +double quantity
  +String score
  +createType()
  +validateScore()
}
class Department {
  +String score
  #Date name
  -Date level
  +updateLevel()
  +validateEmail()
  +createLevel()
}
class Teacher {
  #boolean address
  +float note
  +Date phone
  #boolean total
  +sendScore()
}
Course --* Enrollment
Enrollment ..> Teacher : "1..*"
Teacher ..> Attendance : "0..1"
@enduml