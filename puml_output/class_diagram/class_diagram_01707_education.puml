@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
interface Exam {
  +String phone
  #float name
  +boolean price
  #double email
  +deleteCode()
  +findDescription()
}
class Enrollment {
  +float updatedAt
  -String status
  #String createdAt
  #Date phone
  +processUpdatedat()
  +cancelDescription()
  +cancelDescription()
}
class Course {
  -float phone
  +int active
  #double createdAt
  +Date id
  #long status
  +setLevel()
  +createQuantity()
  +updateAddress()
}
interface Attendance {
  +float note
  #int updatedAt
  +getCreatedat()
  +sendName()
  +getName()
}
class Department {
  -float email
  -Date quantity
  -double status
  #boolean duration
  +float active
  +findDuration()
  +findDuration()
}
class Teacher {
  +Date description
  #long email
  #double duration
  #int address
  +double updatedAt
  +setPhone()
}
Enrollment --o Attendance
Course ..|> Department
Department ..|> Course
note right of Exam : Education domain
@enduml