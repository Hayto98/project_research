@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Exam {
  #float updatedAt
  -Date code
  +String createdAt
  #String id
  #int price
  +updateEmail()
  +sendLevel()
  +calculateNote()
  +updateTotal()
}
interface Library {
  -float amount
  #Date level
  #int score
  #Date type
  -int quantity
  +cancelScore()
  +validateId()
  +deletePrice()
}
interface Classroom {
  -boolean updatedAt
  #long note
  +int phone
  +updatePhone()
}
class Teacher {
  +Date status
  #float active
  +boolean type
  +saveId()
  +setCreatedat()
  +saveCode()
  +calculateUpdatedat()
}
abstract class Course {
  +double address
  +boolean name
  -String email
  +saveAmount()
  +setLevel()
}
Classroom ..> Exam : "*"
Classroom ..|> Library
Course --> Classroom : "1"
Library ..|> Exam
@enduml