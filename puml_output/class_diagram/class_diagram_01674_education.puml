@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Exam {
  #float updatedAt
  -Date code
  +String createdAt
  #String id
  #int price
  +calculateCreatedat()
  +validateDuration()
  +findTotal()
  +deleteLevel()
}
interface Library {
  -Date quantity
  +double type
  #int updatedAt
  #Date phone
  +double createdAt
  +processScore()
  +findQuantity()
  +setUpdatedat()
}
class Classroom {
  -int score
  #boolean description
  +boolean status
  #float active
  +getPrice()
  +saveType()
  +deleteAddress()
  +getEmail()
}
class Teacher {
  -int id
  #long score
  +Date address
  -float name
  -Date updatedAt
  +updateLevel()
  +validateScore()
}
class Course {
  #double id
  -String createdAt
  -String total
  +cancelQuantity()
}
Teacher ..> Exam : "1..*"
Course --|> Exam
Library --* Course
note right of Exam : Education domain
@enduml