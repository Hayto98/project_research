@startuml
skinparam defaultFontSize 13
abstract class Loan {
  #int active
  -long status
  -long createdAt
  #Date code
  +findTotal()
  +processDescription()
  +createScore()
  +setDescription()
}
class Deposit {
  -float updatedAt
  #String note
  +float createdAt
  #int description
  +processScore()
}
interface Branch {
  -float level
  +Date status
  -boolean note
  #float amount
  +int address
  +sendPhone()
}
class Transaction {
  +Date code
  #int createdAt
  +int updatedAt
  #String score
  +savePhone()
  +findEmail()
  +validateCode()
  +setType()
}
class Card {
  #double duration
  #String price
  +double level
  +String type
  +createCode()
}
class Statement {
  +double type
  #boolean phone
  -double updatedAt
  +createScore()
  +saveTotal()
  +validateLevel()
}
Loan ..|> Statement
Branch --> Transaction : "0..1"
note right of Loan : Banking domain
@enduml