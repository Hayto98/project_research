@startuml
skinparam defaultFontSize 13
abstract class Loan {
  #int active
  -long status
  -long createdAt
  #Date code
  +updateId()
  +processLevel()
  +validateType()
  +deleteDuration()
}
class Deposit {
  -int score
  -int code
  +double description
  #String level
  +deleteLevel()
  +saveDescription()
}
class Branch {
  #float note
  -Date score
  +createName()
}
class Transaction {
  +String phone
  #float description
  -Date quantity
  +long code
  +updateDescription()
}
class Card {
  +float updatedAt
  #String duration
  -float name
  +sendUpdatedat()
  +sendAddress()
  +findCode()
}
class Statement {
  -Date type
  #float description
  +sendScore()
  +deleteActive()
  +deleteStatus()
  +processTotal()
}
Deposit ..|> Transaction
Loan --* Statement
@enduml