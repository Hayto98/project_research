@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Wishlist {
  -int code
  #String type
  -long name
  #int createdAt
  #long score
  +validateName()
  +getUpdatedat()
}
abstract class Shipment {
  #boolean email
  +String status
  +validatePhone()
  +validateUpdatedat()
}
class Warehouse {
