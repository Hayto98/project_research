@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Wishlist {
  -int code
  #String type
  -long name
  #int createdAt
  #long score
  +cancelId()
  +sendUpdatedat()
}
class Shipment {
  #String updatedAt
  #long total
  +setPhone()
}
interface Warehouse {
  -Date id
  -long description
  +findCode()
  +createName()
}
abstract class Coupon {
  -float name
  +int createdAt
  -Date address
  +processScore()
  +saveTotal()
  +createNote()
}
class Customer {
  -int score
  -String active
  #long code
  +float email
  -double total
  +getCreatedat()
}
Warehouse ..|> Coupon
Wishlist --> Shipment : "1"
Wishlist ..|> Coupon
@enduml