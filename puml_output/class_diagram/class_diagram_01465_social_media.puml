@startuml
skinparam monochrome true
skinparam defaultFontSize 13
interface Follower {
  -float phone
  +float code
  -int createdAt
  +String status
  +processScore()
  +calculateDescription()
  +getLevel()
}
class Like {
  -double address
  #int duration
  #boolean updatedAt
  +float phone
  +processPrice()
  +processQuantity()
  +processDuration()
}
class Message {
  #double name
  #long active
  +setActive()
  +findDuration()
}
class Post {
  #long score
  #String quantity
  +saveAmount()
  +validatePhone()
}
Post ..|> Follower
Like ..> Message : "*"
Like ..|> Post
@enduml