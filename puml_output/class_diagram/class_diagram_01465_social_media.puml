@startuml
skinparam monochrome true
skinparam defaultFontSize 13
interface Follower {
  -float phone
  +float code
  -int createdAt
  +String status
  +findCode()
  +deleteEmail()
  +validateAddress()
}
class Like {
  #long phone
  +String price
  +String updatedAt
  +float amount
  +sendPrice()
}
class Message {
  #long active
  #long updatedAt
  #String status
  +processCode()
  +validateTotal()
}
class Post {
  -int amount
  -long note
  -Date duration
  +sendUpdatedat()
  +cancelActive()
  +findDuration()
}
Message ..|> Like
Like --|> Message
note right of Follower : Social Media domain
@enduml