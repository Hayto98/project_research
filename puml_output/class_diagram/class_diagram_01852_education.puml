@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
abstract class Exam {
  #int quantity
  #String type
  +validateType()
  +findDuration()
}
class Book {
  -float email
  -boolean price
  -boolean code
  +saveScore()
  +findCode()
  +calculatePhone()
}
class Classroom {
  #double amount
  +int total
  -long id
  +int address
  +findId()
}
interface Grade {
  +int status
  -float score
  +calculateLevel()
  +setUpdatedat()
  +deleteType()
}
Book ..|> Grade
Exam --o Grade
@enduml