@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class CheckOut {
  +String active
  #long score
  #int email
  +processNote()
  +calculateActive()
  +cancelTotal()
  +deleteAddress()
}
interface Housekeeping {
  -String type
  -long id
  #boolean amount
  +findScore()
}
abstract class Amenity {
  -float email
  -float address
  +String createdAt
  +String active
  #boolean code
  +processQuantity()
  +processId()
  +processAddress()
  +validateDescription()
}
class Invoice {
  -float phone
  -double type
  #int quantity
  +processAmount()
  +deleteQuantity()
  +createTotal()
  +getDescription()
}
interface Room {
  +boolean level
  -long id
  #Date updatedAt
  +boolean name
  +getCreatedat()
  +findQuantity()
}
Invoice ..> Housekeeping : "1"
Amenity --o Room
note right of CheckOut : Hotel domain
@enduml