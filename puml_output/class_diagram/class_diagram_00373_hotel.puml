@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class CheckOut {
  +String active
  #long score
  #int email
  +calculateAmount()
  +sendUpdatedat()
  +saveTotal()
  +validatePrice()
}
abstract class Housekeeping {
  -String active
  +long total
  +long amount
  -Date address
  #String description
  +updateCreatedat()
  +createId()
  +cancelCode()
  +findCreatedat()
}
interface Amenity {
  -float createdAt
  +String active
  +String code
  #boolean address
  +sendDescription()
  +validateUpdatedat()
  +setTotal()
  +cancelCode()
}
class Invoice {
  #float address
  -double phone
  -double description
  -double status
  #int score
  +getId()
  +validateQuantity()
  +saveLevel()
  +validateCreatedat()
}
class Room {
  -Date total
  #String name
  +String description
  +boolean active
  +getStatus()
  +updateLevel()
  +createType()
  +cancelDuration()
}
Room --|> Housekeeping
Housekeeping --o Amenity
@enduml