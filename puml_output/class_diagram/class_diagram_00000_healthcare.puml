@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Hospital {
  +int code
  -Date score
  +deletePrice()
}
interface Patient {
  +String amount
  -int total
  +updateScore()
  +calculateScore()
}
class Ward {
  #double amount
  -String quantity
  -boolean price
  -boolean type
  -Date total
  +saveAddress()
  +createDuration()
  +createStatus()
  +setName()
}
class MedicalRecord {
  #String id
  -boolean duration
  +int code
  #float createdAt
  +processId()
  +setScore()
  +processStatus()
  +updateCreatedat()
}
abstract class Billing {
  #double id
  -long code
  -String note
  +sendStatus()
  +processCode()
}
class Appointment {
  #double duration
  #String level
  +int createdAt
  -Date total
  -double updatedAt
  +findScore()
}
MedicalRecord --|> Hospital
Billing ..> Ward : "1..*"
Ward --o MedicalRecord
MedicalRecord ..> Patient : "0..1"
@enduml