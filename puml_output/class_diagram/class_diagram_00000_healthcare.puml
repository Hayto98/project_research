@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Hospital {
  +int code
  -Date score
  +processDuration()
}
class Patient {
  -int total
  +Date description
  -long id
  +saveAmount()
  +createPrice()
  +processScore()
  +sendTotal()
}
abstract class Ward {
  #float status
  -Date note
  #Date active
  -int total
  +sendId()
  +createLevel()
  +validateId()
  +findId()
}
class MedicalRecord {
  #int score
  +Date id
  #double quantity
  +processScore()
  +sendCreatedat()
  +saveId()
}
class Billing {
  +Date duration
  #int type
  +float price
  +boolean address
  -boolean score
  +calculateLevel()
  +updateDuration()
}
abstract class Appointment {
  -Date status
  -double description
  +createPhone()
}
Hospital --> Appointment : "1..*"
Appointment --* Ward
MedicalRecord --o Appointment
Patient --* Appointment
Patient --> Hospital : "1"
note right of Hospital : Healthcare domain
@enduml