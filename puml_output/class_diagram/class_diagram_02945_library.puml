@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Fine {
  #String score
  +float name
  -boolean status
  +boolean address
  +calculateAmount()
  +getEmail()
  +getCode()
  +getScore()
}
abstract class Publisher {
  +long description
  +double name
  +Date id
  #int createdAt
  +int amount
  +setScore()
}
abstract class Loan {
  +int score
  +int name
  -boolean updatedAt
  #boolean active
  +String createdAt
  +sendCreatedat()
  +saveCreatedat()
  +deleteEmail()
  +getEmail()
}
class Reservation {
  +long note
  -float updatedAt
  +int active
  #String description
  +long total
  +validateId()
  +getLevel()
}
Reservation --|> Loan
Loan --* Publisher
note right of Fine : Library domain
@enduml