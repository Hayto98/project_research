@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Fine {
  #String score
  +float name
  -boolean status
  +boolean address
  +getPhone()
  +processUpdatedat()
  +validateDescription()
  +deleteNote()
}
class Publisher {
  #double code
  -int name
  +getName()
}
class Loan {
  -int active
  -int amount
  #boolean code
  +validateQuantity()
  +setType()
}
class Reservation {
  #double score
  #String type
  +calculateActive()
  +getActive()
}
Fine ..|> Reservation
Publisher --> Reservation : "1"
@enduml