@startuml
skinparam ArrowColor #555555
class Book {
  #float amount
  +boolean price
  #float type
  +sendUpdatedat()
}
interface Author {
  +double updatedAt
  #double status
  #String note
  #int score
  #String id
  +getActive()
  +savePrice()
}
class Loan {
  #Date phone
  #double address
  #Date price
  +findPhone()
  +deleteUpdatedat()
  +sendActive()
}
class Branch {
  #float note
  -long active
  +validatePrice()
  +sendDescription()
  +deleteName()
  +findStatus()
}
class Renewal {
  #boolean note
  -Date duration
  #double quantity
  +boolean updatedAt
  +Date createdAt
  +validateActive()
  +updateType()
  +getActive()
  +saveName()
}
class Catalog {
  -String status
  -boolean id
  #Date level
  +float quantity
  +updateNote()
  +deleteLevel()
  +validateStatus()
  +createLevel()
}
Book ..> Loan : "1..*"
Renewal --> Author : "0..1"
@enduml