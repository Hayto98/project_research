@startuml
skinparam monochrome true
skinparam shadowing true
class Return {
  +Date active
  +float createdAt
  -float type
  #double duration
  #Date code
  +calculateCreatedat()
}
abstract class Cart {
  #Date quantity
  +String active
  +setTotal()
  +saveDescription()
  +findAddress()
  +savePhone()
}
class Warehouse {
  +long duration
  -Date phone
  +float amount
  +long total
  +deleteQuantity()
  +calculateLevel()
  +saveTotal()
}
class Invoice {
  #float duration
  -long address
  +long createdAt
  +cancelPrice()
  +calculateQuantity()
}
class Wishlist {
  +double note
  +boolean status
  #double amount
  +cancelDescription()
  +calculateCreatedat()
  +processActive()
}
class Customer {
  #float name
  #float email
  #String code
  #long level
  +boolean phone
  +sendPhone()
  +sendPrice()
  +createId()
}
Customer ..|> Wishlist
Customer ..|> Return
Cart ..|> Invoice
note right of Return : Ecommerce domain
@enduml