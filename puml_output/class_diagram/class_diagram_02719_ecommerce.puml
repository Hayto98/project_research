@startuml
skinparam monochrome true
skinparam shadowing true
class Return {
  +Date active
  +float createdAt
  -float type
  #double duration
  #Date code
  +saveCode()
}
class Cart {
  -String name
  #double quantity
  #int active
  #float updatedAt
  -Date duration
  +calculateId()
  +getDescription()
  +cancelUpdatedat()
}
class Warehouse {
  -Date amount
  +float total
  +long duration
  -int phone
  +sendScore()
  +validateType()
  +findName()
}
abstract class Invoice {
  #float amount
  -long address
  +long createdAt
  +findUpdatedat()
  +createDuration()
}
abstract class Wishlist {
  #Date address
  #float description
  #int note
  +double status
  +processId()
  +getQuantity()
}
abstract class Customer {
  -Date duration
  #String description
  #float total
  -Date createdAt
  +deleteName()
}
Customer --> Warehouse : "1..*"
Wishlist ..> Customer : "1"
@enduml