@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
abstract class Product {
  -boolean type
  +String createdAt
  +float address
  #int id
  +findAddress()
  +findCode()
  +createStatus()
}
interface Coupon {
  -float id
  +float score
  #Date email
  -long address
  +calculateTotal()
  +findId()
}
class Warehouse {
  +float updatedAt
  -int email
  -String description
  +float price
  -double status
  +createDescription()
  +saveUpdatedat()
  +cancelAmount()
  +setActive()
}
class Supplier {
  #Date description
  -float createdAt
  +Date price
  +String address
  -long code
  +updateAddress()
}
class Shipment {
  +float note
  -long updatedAt
  +findScore()
  +validateUpdatedat()
  +findEmail()
  +findPrice()
}
abstract class Customer {
  +double total
  -double address
  +double updatedAt
  #float amount
  +int code
  +sendStatus()
  +updateScore()
  +processLevel()
  +validateDuration()
}
Customer --o Shipment
Coupon --* Product
Warehouse --> Customer : "1"
Supplier --|> Coupon
Warehouse ..> Product : "1"
@enduml