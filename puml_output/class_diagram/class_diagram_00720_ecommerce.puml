@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
abstract class Product {
  -boolean type
  +String createdAt
  +float address
  #int id
  +updatePhone()
  +sendDuration()
  +sendScore()
}
class Coupon {
  #long score
  -float email
  +cancelNote()
  +validateAmount()
}
class Warehouse {
  -float price
  +float updatedAt
  +setName()
  +validateCreatedat()
  +calculateId()
  +setQuantity()
}
abstract class Supplier {
  #int active
  #double score
  -Date amount
  #boolean price
  +boolean description
  +updateAmount()
  +getPhone()
  +createName()
  +saveName()
}
class Shipment {
  -double updatedAt
  #double id
  -double email
  -int quantity
  +Date note
  +setNote()
}
abstract class Customer {
  #double amount
  -double price
  #Date code
  #double description
  +String total
  +createQuantity()
  +sendStatus()
  +processDescription()
}
Warehouse ..> Product : "1"
Product ..|> Coupon
note right of Product : Ecommerce domain
@enduml