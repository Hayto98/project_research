@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Route {
  +long type
  #Date name
  +deleteName()
  +calculateAmount()
}
class Driver {
  +double phone
  +float type
  +validateTotal()
  +saveAmount()
  +processEmail()
}
class Shipment {
  #int code
  #String level
  +float description
  -String amount
  -long address
  +processNote()
  +processCode()
  +validateNote()
}
class DeliveryNote {
  +Date level
  #long note
  -long status
  -String name
  +updateId()
  +findQuantity()
  +getId()
  +validatePhone()
}
interface Tracking {
  #Date name
  -double amount
  -long email
  +calculateAmount()
  +saveCode()
}
interface Warehouse {
  #Date address
  #long updatedAt
  +String status
  +String name
  -float description
  +findTotal()
}
class Customer {
  +String id
  +Date duration
  #int email
  +updateDuration()
}
Customer --o Route
DeliveryNote --o Driver
DeliveryNote ..|> Route
Customer --o DeliveryNote
Route ..> Tracking : "*"
Driver ..> Tracking : "0..1"
@enduml