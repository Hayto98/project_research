@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Route {
  +long type
  #Date name
  +createNote()
  +getCode()
}
class Driver {
  #long amount
  -Date note
  +boolean updatedAt
  +Date phone
  +boolean level
  +sendCreatedat()
  +saveName()
  +setEmail()
}
class Shipment {
  -boolean phone
  -String email
  +int id
  #float updatedAt
  #long code
  +createNote()
  +setTotal()
  +findAddress()
}
abstract class DeliveryNote {
  #String duration
  #float updatedAt
  +createQuantity()
  +processQuantity()
}
class Tracking {
  -int note
  #String price
  +float total
  +cancelDuration()
  +validateAmount()
}
class Warehouse {
  +float status
  -int price
  +getEmail()
}
class Customer {
  #String code
  +float description
  +processTotal()
}
DeliveryNote --|> Customer
Driver --o DeliveryNote
Route ..> Tracking : "*"
note right of Route : Logistics domain
@enduml