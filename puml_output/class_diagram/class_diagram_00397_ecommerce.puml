}
class Wishlist {
  +double price
  #boolean active
  -boolean updatedAt
  -float type
  #boolean id
  +cancelDescription()
  +getActive()
  +cancelUpdatedat()
}
class Warehouse {
  #boolean name
  #Date price
  -boolean amount
  #double email
  -boolean phone
  +cancelDescription()
  +cancelPhone()
  +updateTotal()
  +setActive()
}
