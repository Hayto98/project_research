@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
interface Supplier {
  -double quantity
  -int code
  -float status
  -double amount
  -Date createdAt
  +saveAddress()
}
class Shipment {
  +float level
  -String phone
  -long price
  +sendAmount()
  +setPhone()
  +updateStatus()
  +processTotal()
}
class Customer {
  #Date address
  -String duration
  +findActive()
  +createPhone()
}
interface Wishlist {
  -String status
  #long type
  -String total
  +createActive()
  +setEmail()
  +sendType()
  +processAddress()
}
abstract class Warehouse {
  -Date active
  #float updatedAt
  -boolean type
  -float id
  #boolean code
  +createId()
  +getCode()
  +cancelType()
}
Supplier --|> Shipment
Wishlist ..> Supplier : "*"
@enduml