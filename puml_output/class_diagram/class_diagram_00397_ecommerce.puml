@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
interface Supplier {
  -double quantity
  -int code
  -float status
  -double amount
  -Date createdAt
  +deleteName()
}
interface Shipment {
  +float level
  -String phone
  -long price
  +sendDuration()
  +updateNote()
  +saveAddress()
  +saveCode()
}
class Customer {
  -String quantity
  #int name
  +double score
  #float createdAt
  +processStatus()
