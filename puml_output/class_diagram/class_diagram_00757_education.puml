@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Assignment {
  -double description
  +float note
  +float updatedAt
  -String type
  #float total
  +calculateType()
}
class Library {
  +String updatedAt
  +Date active
  +boolean phone
  #double email
  -int total
  +createId()
  +createNote()
  +createDescription()
  +updateAddress()
}
class Student {
  +String note
  #String quantity
  -double active
  +int amount
  +findPrice()
  +createNote()
  +getQuantity()
  +updateEmail()
}
class Teacher {
  -int type
  #int status
  +long createdAt
  -long total
  +saveCode()
  +calculateQuantity()
}
abstract class Schedule {
  -Date price
  -String total
  +long type
  -double address
  +createName()
}
class Course {
  +Date level
  #String status
  +int amount
  +long note
  +saveQuantity()
  +getPrice()
  +validateDuration()
  +validateTotal()
}
Schedule ..|> Teacher
Library --|> Schedule
Schedule ..> Student : "*"
Assignment --> Schedule : "0..1"
@enduml