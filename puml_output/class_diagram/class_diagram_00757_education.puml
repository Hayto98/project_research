@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Assignment {
  -double description
  +float note
  +float updatedAt
  -String type
  #float total
  +updateType()
}
class Library {
  +Date email
  +boolean total
  #double id
  -int score
  +sendDescription()
  +validateNote()
  +createActive()
  +findLevel()
}
class Student {
  -int status
  +boolean code
  -boolean note
  +createQuantity()
  +processStatus()
  +cancelCreatedat()
  +calculateAddress()
}
class Teacher {
  -int id
  -double email
  -float address
  +calculateTotal()
  +processAddress()
  +calculateEmail()
}
class Schedule {
  -boolean quantity
  +double type
  +validateLevel()
}
class Course {
  +int note
  +long updatedAt
  -int status
  +findEmail()
  +cancelTotal()
  +deleteCreatedat()
}
Schedule ..> Student : "*"
Assignment --> Schedule : "0..1"
note right of Assignment : Education domain
@enduml