@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Return {
  -boolean price
  +boolean id
  #long code
  +long type
  +cancelCreatedat()
  +getDescription()
  +getTotal()
  +sendCreatedat()
}
abstract class Shipment {
  -long score
  +String status
  -long total
  +int active
  +setQuantity()
}
class Cart {
  #double duration
  #float amount
  -long type
  +long level
  +boolean score
  +calculateQuantity()
  +sendPhone()
  +sendQuantity()
}
interface Invoice {
  -boolean updatedAt
  -Date name
  +updateQuantity()
  +setScore()
  +createLevel()
}
class Category {
  #String name
  +Date createdAt
  +double updatedAt
  #String phone
  +int score
  +cancelTotal()
  +processEmail()
  +saveId()
  +deleteUpdatedat()
}
interface Customer {
  -long address
  +boolean amount
  -float code
  #String score
  -int updatedAt
  +findNote()
  +calculateCreatedat()
  +processPhone()
}
class Order {
  #boolean updatedAt
  -String duration
  +saveTotal()
  +calculateDescription()
  +setId()
}
Category --> Cart : "1..*"
Category --* Order
Invoice ..|> Order
Customer --* Return
Invoice ..> Shipment : "1"
Order --|> Return
@enduml