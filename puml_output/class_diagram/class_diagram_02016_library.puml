@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Catalog {
  +float email
  #int updatedAt
  +double id
  +float code
  #int note
  +calculatePhone()
}
interface Branch {
  +boolean address
  +boolean status
  #double createdAt
  +float email
  -double name
  +sendCode()
  +getNote()
}
abstract class Loan {
  +long price
  -double description
  -Date id
  +String address
  +updateId()
  +processCreatedat()
  +validateActive()
  +processType()
}
class Shelf {
  +Date createdAt
  -double status
  -double address
  +findId()
  +processTotal()
}
abstract class Member {
  #int total
  #int note
  #float createdAt
  #long id
  +processName()
}
class Author {
  -boolean note
  -double level
  +cancelName()
  +calculateCode()
  +calculatePrice()
}
Catalog --> Branch : "1"
Shelf --> Branch : "0..1"
Branch --|> Shelf
Loan --|> Member
Shelf --|> Author
@enduml