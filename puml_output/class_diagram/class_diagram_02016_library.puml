@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Catalog {
  +float email
  #int updatedAt
  +double id
  +float code
  #int note
  +createActive()
}
abstract class Branch {
  +boolean status
  +boolean createdAt
  #double email
  +float name
  +calculateAmount()
  +processQuantity()
  +calculateLevel()
  +sendEmail()
}
abstract class Loan {
  #float duration
  #float level
  -int id
  +calculateNote()
  +calculateStatus()
  +setType()
}
interface Shelf {
  +Date phone
  -double createdAt
  -double level
  #Date status
  +int address
  +processEmail()
  +findTotal()
  +processCreatedat()
  +saveId()
}
interface Member {
  #long duration
  +String createdAt
  #float score
  +setNote()
}
interface Author {
  #double level
  +int price
  #String note
  -int email
  #float duration
  +deletePrice()
  +getPhone()
}
Shelf --|> Author
Loan --|> Branch
note right of Catalog : Library domain
@enduml