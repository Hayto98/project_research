@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Department {
  +Date updatedAt
  #double phone
  +setQuantity()
  +cancelAmount()
}
class Grade {
  -boolean quantity
  +long description
  #int type
  +saveAmount()
}
abstract class Library {
  -long name
  +int duration
  -float type
  #int address
  +calculateEmail()
}
class Attendance {
  #double code
  +boolean type
  -float status
  +processEmail()
}
Department ..|> Library
Department --o Grade
note right of Department : Education domain
@enduml