@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Department {
  +Date updatedAt
  #double phone
  +calculateLevel()
  +findType()
}
class Grade {
  -float level
  +double amount
  -boolean address
  +long createdAt
  +calculateLevel()
  +sendTotal()
}
class Library {
  -long phone
  +int name
  -float level
  #int type
  #Date address
  +deleteAmount()
}
class Attendance {
  #double updatedAt
  +boolean code
  -float type
  +double status
  +sendStatus()
  +getName()
  +calculateEmail()
}
Grade --o Department
Attendance ..> Library : "1"
@enduml