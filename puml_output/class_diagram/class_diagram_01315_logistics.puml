@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Driver {
  -boolean amount
  +Date quantity
  +processDuration()
  +findTotal()
  +validateAmount()
  +deleteCreatedat()
}
interface Customer {
  -float type
  +boolean quantity
  -boolean description
  +sendName()
}
class Inventory {
  #Date address
  #double active
  -boolean level
  +setAmount()
  +cancelType()
  +cancelTotal()
  +createStatus()
}
class Depot {
  -int level
  #boolean email
  -long price
  #int note
  +validatePrice()
  +findEmail()
  +createType()
}
class Manifest {
  -boolean description
  +int updatedAt
  +int phone
  #double price
  +calculateCreatedat()
  +findNote()
  +cancelPrice()
}
Customer --|> Manifest
Inventory ..|> Driver
@enduml