@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Driver {
  -boolean amount
  +Date quantity
  +updateEmail()
  +createScore()
  +updateType()
  +createDescription()
}
abstract class Customer {
  #boolean score
  +double phone
  +deleteAddress()
  +sendActive()
  +saveNote()
}
abstract class Inventory {
  -boolean id
  -long score
  +Date quantity
  #long email
  -boolean active
  +findEmail()
  +saveStatus()
}
class Depot {
  -double duration
  #float updatedAt
  +int phone
  +updateActive()
  +calculateDuration()
}
class Manifest {
  +long code
  +int createdAt
  +String updatedAt
  #float score
  +cancelPrice()
  +saveUpdatedat()
  +createType()
  +sendCreatedat()
}
Customer --|> Driver
Inventory --> Customer : "*"
Driver --* Customer
note right of Driver : Logistics domain
@enduml