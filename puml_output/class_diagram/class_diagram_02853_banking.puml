@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Card {
  #float note
  #Date level
  -boolean name
  +setAddress()
  +findLevel()
  +createEmail()
  +cancelTotal()
}
class Account {
  #int price
  #String description
  +deleteLevel()
  +setTotal()
  +processScore()
  +calculateActive()
}
class Teller {
  +long duration
  +long address
  +String email
  +processTotal()
}
interface Beneficiary {
  +double active
  #float duration
  #String level
  -float type
  +getPrice()
  +sendScore()
  +updateQuantity()
  +getPhone()
}
Beneficiary --* Card
Card ..|> Beneficiary
Card --* Account
note right of Card : Banking domain
@enduml