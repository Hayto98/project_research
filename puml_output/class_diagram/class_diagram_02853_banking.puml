@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Card {
  #float note
  #Date level
  -boolean name
  +getLevel()
  +createType()
  +createActive()
  +createTotal()
}
interface Account {
  +double email
  +boolean level
  +boolean total
  +float createdAt
  +saveQuantity()
  +deleteUpdatedat()
  +validateEmail()
  +setNote()
}
abstract class Teller {
  +long active
  +long name
  +String description
  #boolean address
  #boolean email
  +calculateAmount()
}
abstract class Beneficiary {
  +double active
  #float duration
  #String level
  -float type
  +saveEmail()
  +processType()
  +getCreatedat()
  +cancelType()
}
Teller --* Card
Beneficiary --> Teller : "*"
@enduml