@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Restaurant {
  #String code
  +String score
  +Date amount
  +sendScore()
  +calculateStatus()
  +createQuantity()
}
class Guest {
  -int score
  -String id
  +setDescription()
  +sendPhone()
  +setCreatedat()
  +cancelType()
}
abstract class Staff {
  #long type
  #long status
  +deleteType()
  +validateUpdatedat()
  +saveNote()
  +createLevel()
}
class CheckIn {
  +Date id
  +long price
  -Date level
  +findQuantity()
  +validateStatus()
}
class Housekeeping {
  -Date status
  -float code
  -boolean active
  -int id
  #String description
  +processDuration()
  +updateScore()
  +validateEmail()
}
abstract class Service {
  -String level
  #long id
  -int status
  -double active
  #long code
  +deleteCreatedat()
  +calculateEmail()
}
Restaurant ..> Guest : "0..1"
Restaurant ..> CheckIn : "0..1"
Housekeeping --|> Staff
CheckIn ..> Guest : "1..*"
Staff --> Restaurant : "1"
@enduml