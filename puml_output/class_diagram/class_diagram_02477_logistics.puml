@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
abstract class Driver {
  -boolean status
  +float address
  #String price
  -Date email
  #long score
  +processScore()
}
class Route {
  -long total
  +Date type
  +createPhone()
  +getNote()
  +createDescription()
  +cancelEmail()
}
class Manifest {
  #float address
  #int code
  +boolean amount
  #int level
  +long type
  +sendLevel()
  +calculatePhone()
}
abstract class Package {
  +double type
  #double status
  -float total
  +calculateQuantity()
}
class FuelLog {
  +float score
  +double active
  +long duration
  +processDescription()
  +setQuantity()
  +calculateDuration()
}
interface Tracking {
  -String active
  -double quantity
  -String type
  +String email
  +float total
  +calculatePrice()
  +getPrice()
  +createScore()
}
Driver ..|> Tracking
FuelLog --|> Manifest
@enduml