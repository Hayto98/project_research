@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
abstract class Driver {
  -boolean status
  +float address
  #String price
  -Date email
  #long score
  +findName()
}
class Route {
  +long type
  #String email
  +Date address
  -long code
  +int price
  +processDuration()
}
class Manifest {
  +long level
  +long updatedAt
  +updateType()
  +setTotal()
  +updatePrice()
  +cancelType()
}
class Package {
  +boolean total
  #boolean phone
  +getTotal()
  +updateEmail()
}
class FuelLog {
  -double score
  #long duration
  -double type
  +double active
  +processCode()
  +setId()
  +deletePhone()
  +sendUpdatedat()
}
class Tracking {
  #long code
  +boolean description
  +createCreatedat()
  +getPhone()
  +setAddress()
}
Driver --o Manifest
Package --|> Driver
Tracking ..|> FuelLog
Tracking --* Route
note right of Driver : Logistics domain
@enduml