@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Hashtag {
  -double total
  +double price
  +float description
  +long type
  #String quantity
  +deleteNote()
  +getEmail()
  +setDescription()
  +findQuantity()
}
class Like {
  -float address
  #String updatedAt
  -boolean description
  #long id
  +boolean level
  +processCode()
  +createActive()
  +getCreatedat()
  +findActive()
}
class Group {
  +boolean level
  -Date updatedAt
  -double email
  +setName()
  +getType()
  +cancelDuration()
}
interface Post {
  +int total
  +String duration
  #double price
  -boolean updatedAt
  -float phone
  +processEmail()
}
class Profile {
  +float level
  -float description
  #float type
  -float phone
  -float email
  +calculateLevel()
  +deleteEmail()
  +findDuration()
}
Like --|> Group
Post --|> Hashtag
Like ..> Hashtag : "*"
@enduml