@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Hashtag {
  -double total
  +double price
  +float description
  +long type
  #String quantity
  +getDescription()
  +setAddress()
  +setNote()
  +validateUpdatedat()
}
interface Like {
  +double id
  #String level
  -boolean active
  +getDuration()
  +processId()
  +validateScore()
}
abstract class Group {
  +boolean duration
  -Date amount
  -double updatedAt
  -String email
  +saveDuration()
}
abstract class Post {
  +int total
  +float price
  #double updatedAt
  -boolean phone
  -float status
  +cancelCreatedat()
}
abstract class Profile {
  +float type
  -float phone
  #float email
  +createPhone()
  +sendNote()
  +deleteScore()
}
Profile --|> Group
Post --|> Hashtag
Like ..> Hashtag : "*"
note right of Hashtag : Social Media domain
@enduml