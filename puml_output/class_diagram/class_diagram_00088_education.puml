@startuml
skinparam shadowing true
class Course {
  #double id
  +long score
  +int total
  +saveAddress()
  +createUpdatedat()
  +cancelTotal()
  +savePrice()
}
class Exam {
  -Date name
  +String phone
  #double price
  +String description
  #String id
  +deleteUpdatedat()
  +findActive()
  +getDuration()
}
class Book {
  #String id
  +double amount
  +double address
  #int type
  +getTotal()
  +setStatus()
  +updateNote()
}
class Assignment {
  -boolean code
  -Date quantity
  #float score
  -float address
  +setDuration()
  +findScore()
  +cancelName()
}
class Student {
  +double description
  -int total
  +calculateAddress()
}
class Library {
  #String score
  +int description
  +sendDuration()
  +validateCode()
  +savePrice()
  +calculateAmount()
}
Assignment --* Student
Assignment ..> Course : "1"
Student ..|> Library
Student --> Exam : "1"
Exam ..|> Book
note right of Course : Education domain
@enduml