@startuml
skinparam shadowing true
class Course {
  #double id
  +long score
  +int total
  +setScore()
  +createTotal()
  +validateDuration()
  +validateAmount()
}
class Exam {
  -Date price
  -Date createdAt
  +String active
  -Date note
  +String name
  +updateStatus()
  +updatePrice()
  +createTotal()
  +getType()
}
class Book {
  #long updatedAt
  -String active
  +long name
  +processNote()
  +updateUpdatedat()
  +sendEmail()
  +deleteActive()
}
class Assignment {
  +float updatedAt
  +Date address
  -String name
  #long total
  #String status
  +deleteId()
  +calculatePrice()
  +processScore()
}
class Student {
  +boolean level
  #boolean phone
  #String email
  -String score
  +getAddress()
  +calculateType()
}
class Library {
  +String phone
  #float amount
  +boolean id
  +float total
  +int address
  +setAddress()
  +setId()
  +calculateName()
  +createAddress()
}
Assignment --o Exam
Assignment --* Student
Assignment ..> Course : "1"
Student ..|> Library
Student --> Exam : "1"
@enduml