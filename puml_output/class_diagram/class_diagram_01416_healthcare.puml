@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
interface Patient {
  #long duration
  -long email
  +String createdAt
  #long description
  +calculateStatus()
  +validateDescription()
  +updateTotal()
  +findQuantity()
}
class Insurance {
  +String score
  -double price
  #boolean name
  +deleteCreatedat()
  +deleteActive()
  +createPrice()
  +createId()
}
class Ward {
  +long status
  +long active
  +float address
  +createType()
}
class Billing {
  -boolean code
  #int score
  +updateTotal()
}
Insurance ..|> Ward
Insurance --> Billing : "*"
Ward --> Billing : "1"
note right of Patient : Healthcare domain
@enduml