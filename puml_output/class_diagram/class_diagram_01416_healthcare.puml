@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
interface Patient {
  #long duration
  -long email
  +String createdAt
  #long description
  +calculateCode()
  +validateEmail()
  +setEmail()
  +validateCode()
}
class Insurance {
  +String quantity
  -double code
  #boolean amount
  -int price
  +int name
  +createDuration()
  +calculateLevel()
  +updateLevel()
}
class Ward {
  -float description
  +long status
  +long active
  +sendStatus()
  +createType()
}
class Billing {
  #float type
  -boolean description
  #int code
  #boolean score
  +processDuration()
}
Billing ..> Patient : "0..1"
Insurance --> Billing : "*"
Ward --> Billing : "1"
@enduml