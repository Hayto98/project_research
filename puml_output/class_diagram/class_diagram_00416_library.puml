@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Renewal {
  #double active
  #String type
  #double level
  +calculateName()
}
class Publisher {
  -int price
  -String total
  -Date phone
  +updateDuration()
}
class Catalog {
  +int score
  -float code
  #boolean level
  #float quantity
  +deleteTotal()
  +deleteLevel()
  +sendType()
}
interface Loan {
  +String updatedAt
  +Date amount
  +long note
  -String score
  -float type
  +getTotal()
  +processAddress()
  +deleteUpdatedat()
  +processDuration()
}
class Reservation {
  +long score
  -double address
  +setName()
  +setName()
}
class Librarian {
  -double type
  #float phone
  +double description
  #boolean status
  +validateLevel()
  +getLevel()
  +findUpdatedat()
  +processStatus()
}
Catalog ..> Renewal : "1..*"
Publisher ..|> Renewal
Loan --|> Reservation
Catalog --* Loan
note right of Renewal : Library domain
@enduml