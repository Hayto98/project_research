@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Renewal {
  #double active
  #String type
  #double level
  +getAddress()
}
class Publisher {
  #long description
  -int price
  -String total
  +findStatus()
  +sendTotal()
  +processDuration()
}
interface Catalog {
  -float phone
  +int score
  -float code
  #boolean level
  +createCreatedat()
  +getAddress()
  +setLevel()
}
interface Loan {
  -double duration
  +String total
  +Date updatedAt
  +long amount
  -String note
  +getDescription()
  +cancelPrice()
  +deletePrice()
}
class Reservation {
  #String note
  +boolean address
  -int description
  -double updatedAt
  -int duration
  +saveId()
}
class Librarian {
  -Date phone
  -Date email
  +findType()
  +setStatus()
}
Loan --|> Reservation
Reservation --* Loan
Reservation --> Renewal : "0..1"
Loan --* Renewal
@enduml