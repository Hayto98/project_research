@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
abstract class Statement {
  +long description
  +long type
  +String note
  +Date name
  +findEmail()
  +cancelLevel()
}
abstract class Branch {
  #int address
  +boolean amount
  -Date name
  +float description
  +getCode()
  +findNote()
  +calculateType()
}
class Transfer {
  -String score
  +long email
  +sendNote()
  +setDuration()
  +cancelEmail()
  +sendAmount()
}
interface Transaction {
  #float level
  +int updatedAt
  -long active
  #String duration
  +sendDescription()
  +deleteNote()
}
abstract class Deposit {
  +String status
  +String level
  -long code
  #float score
  +processAddress()
  +processTotal()
}
Transfer --|> Deposit
Deposit --|> Transfer
Transaction ..> Branch : "*"
@enduml