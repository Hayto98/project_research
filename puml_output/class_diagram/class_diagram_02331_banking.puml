@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
abstract class Statement {
  +long description
  +long type
  +String note
  +Date name
  +calculateActive()
  +validateAddress()
}
class Branch {
  #int score
  +boolean description
  +findStatus()
  +validateLevel()
  +setCreatedat()
  +findStatus()
}
interface Transfer {
  #double quantity
  +String id
  #boolean code
  -float duration
  +saveActive()
  +updateCreatedat()
}
class Transaction {
  -long email
  +boolean id
  #boolean createdAt
  #String name
  +updateCode()
}
class Deposit {
  #float total
  +float quantity
  +processAddress()
  +validateId()
  +sendAddress()
  +setNote()
}
Transaction ..> Transfer : "0..1"
Deposit --|> Transfer
note right of Statement : Banking domain
@enduml