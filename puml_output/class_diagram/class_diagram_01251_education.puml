@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Attendance {
  #String status
  #float name
  #double phone
  +int quantity
  +updateCreatedat()
  +createDuration()
  +getAddress()
  +updateAmount()
}
interface Library {
  -Date updatedAt
  #double address
  -long email
  +cancelAddress()
  +saveScore()
}
class Grade {
  +boolean note
  -double name
  +saveCode()
  +deleteLevel()
}
interface Schedule {
  +String note
  +double type
  +saveDescription()
  +findDuration()
  +deleteName()
}
abstract class Teacher {
  #long email
  -boolean level
  +boolean duration
  -int phone
  +calculateUpdatedat()
  +savePrice()
  +deleteStatus()
  +deleteScore()
}
interface Student {
  -float quantity
  #boolean active
  +findQuantity()
}
class Exam {
  +String name
  -long level
  +calculateType()
  +findDuration()
  +processActive()
}
Schedule ..> Library : "*"
Student --o Exam
Library --|> Teacher
Teacher --> Attendance : "0..1"
Library ..|> Attendance
@enduml