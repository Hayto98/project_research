@startuml
skinparam defaultFontSize 11
class Amenity {
  -Date address
  #boolean createdAt
  #double active
  -boolean quantity
  +createName()
  +saveTotal()
}
class Reservation {
  #float code
  -double updatedAt
  #String level
  +long amount
  +calculateName()
  +processId()
  +findAddress()
}
class Payment {
  #String type
  #Date quantity
  -double total
  -double description
  +sendDuration()
  +updateAmount()
  +findQuantity()
  +calculateCreatedat()
}
class Guest {
  +boolean level
  -long duration
  -double email
  +processCode()
  +setDuration()
  +sendLevel()
  +calculateNote()
}
class CheckIn {
  +boolean id
  +int level
  -boolean total
  -double address
  +getUpdatedat()
  +sendCode()
}
abstract class Booking {
  -Date quantity
  +long level
  +double price
  -String type
  +boolean note
  +processNote()
}
Booking ..|> Reservation
Amenity --|> Reservation
Booking --> Amenity : "1"
Payment --> CheckIn : "1"
@enduml