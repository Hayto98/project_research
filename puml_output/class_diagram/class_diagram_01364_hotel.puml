@startuml
skinparam defaultFontSize 11
class Amenity {
  -Date address
  #boolean createdAt
  #double active
  -boolean quantity
  +processStatus()
  +sendScore()
}
class Reservation {
  +Date updatedAt
  -double duration
  +deletePhone()
}
class Payment {
  -long level
  -int updatedAt
  #String description
  #Date phone
  +calculateEmail()
  +processType()
  +saveAddress()
  +validateId()
}
interface Guest {
  +boolean level
  -long duration
  -double email
  +getCreatedat()
  +findName()
  +validateId()
  +findLevel()
}
interface CheckIn {
  -boolean address
  -double name
  +float score
  -double createdAt
  -float description
  +cancelPrice()
  +processNote()
  +validateId()
}
class Booking {
  +boolean price
  +Date email
  -Date status
  +deleteId()
  +updateStatus()
}
CheckIn --* Amenity
Booking --> CheckIn : "1"
note right of Amenity : Hotel domain
@enduml