@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Supplier {
  +double active
  #int phone
  +String address
  -boolean type
  +deleteEmail()
  +sendScore()
}
class Product {
  -int score
  #String address
  +calculateId()
  +saveCreatedat()
  +setScore()
}
interface Review {
  #int updatedAt
  #float name
  +getId()
  +savePhone()
  +setLevel()
}
class Payment {
  +long type
  -double description
  #Date updatedAt
  -int phone
  -Date active
  +createDuration()
  +updateAmount()
  +validateQuantity()
}
abstract class Category {
  +int type
  #int quantity
  +cancelAmount()
}
interface Wishlist {
  +double id
  #Date name
  +createScore()
}
Wishlist ..|> Supplier
Supplier --|> Product
note right of Supplier : Ecommerce domain
@enduml