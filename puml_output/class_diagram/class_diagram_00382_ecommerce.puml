@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Supplier {
  +double active
  #int phone
  +String address
  -boolean type
  +validateCode()
  +validateAmount()
}
interface Product {
  #long score
  -int duration
  #String code
  +sendScore()
  +processName()
  +findStatus()
}
class Review {
  +Date score
  +String level
  +sendDuration()
  +findType()
}
class Payment {
  +boolean id
  +double phone
  +setLevel()
  +deleteAddress()
  +deleteCode()
  +calculateType()
}
class Category {
  #Date address
  -int quantity
  -Date type
  +sendLevel()
  +getNote()
  +deletePhone()
}
interface Wishlist {
  -String amount
  #float phone
  #double quantity
  +calculateType()
  +saveStatus()
  +getTotal()
}
Wishlist --|> Product
Category --> Product : "1"
Supplier ..|> Wishlist
@enduml