@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
interface Loan {
  -Date total
  #String createdAt
  +double note
  +updateLevel()
  +getType()
  +sendAddress()
}
class Account {
  #String updatedAt
  #Date name
  +String description
  +setPrice()
  +findCode()
}
class Teller {
  -int total
  -long amount
  +deleteEmail()
  +createScore()
}
class Deposit {
  -double phone
  -float price
  #int updatedAt
  -long active
  +deletePhone()
  +createPrice()
  +saveQuantity()
  +validateCreatedat()
}
interface Beneficiary {
  -String createdAt
  +float id
  -String score
  +String price
  #long code
  +createType()
  +findTotal()
  +setUpdatedat()
}
Account --> Deposit : "0..1"
Account --> Beneficiary : "0..1"
note right of Loan : Banking domain
@enduml