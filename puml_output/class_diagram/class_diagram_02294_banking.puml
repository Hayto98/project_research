@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
interface Loan {
  -Date total
  #String createdAt
  +double note
  +deleteAddress()
  +processId()
  +findEmail()
}
class Account {
  +float score
  +float address
  #String updatedAt
  #Date createdAt
  +String duration
  +findNote()
  +createPrice()
}
class Teller {
  +long id
  +double total
  +deleteLevel()
  +saveQuantity()
  +findId()
}
class Deposit {
  -float score
  +boolean description
  -double quantity
  -float phone
  +getId()
  +deletePhone()
}
class Beneficiary {
  -int amount
  #boolean phone
  -float quantity
  +String price
  #double score
  +createActive()
}
Loan --|> Teller
Account ..> Loan : "1..*"
@enduml