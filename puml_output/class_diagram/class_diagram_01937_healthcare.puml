@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
abstract class Doctor {
  -int note
  +String name
  +int quantity
  -double email
  +processTotal()
  +updateNote()
  +updateStatus()
}
abstract class Patient {
  #long email
  -float quantity
  +int description
  +setEmail()
  +cancelScore()
}
class Nurse {
  +String id
  -boolean type
  -double quantity
  #double active
  +getId()
  +createId()
  +createCode()
  +processQuantity()
}
abstract class Treatment {
  -Date code
  -double id
  +double email
  +createActive()
  +sendId()
}
class LabTest {
  +long updatedAt
  -long email
  +float active
  +getLevel()
  +processPhone()
  +findUpdatedat()
}
abstract class Ward {
  #double email
  +long quantity
  +float status
  #int level
  +deletePhone()
  +sendEmail()
  +getPrice()
}
LabTest --|> Patient
Treatment ..> Patient : "0..1"
Patient --o Treatment
Nurse --o Doctor
note right of Doctor : Healthcare domain
@enduml