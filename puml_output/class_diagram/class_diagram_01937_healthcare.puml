@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
abstract class Doctor {
  -int note
  +String name
  +int quantity
  -double email
  +findActive()
  +createType()
  +cancelCreatedat()
}
class Patient {
  #float createdAt
  -Date status
  #Date price
  +boolean description
  -double email
  +findId()
  +setType()
}
class Nurse {
  #float duration
  -String score
  -long updatedAt
  #String active
  +saveStatus()
}
class Treatment {
  +long type
  +float note
  -String score
  -long price
  #double name
  +saveLevel()
  +getType()
}
class LabTest {
  -float total
  +long note
  #boolean type
  +int code
  +processDuration()
  +deleteType()
}
class Ward {
  +float phone
  -String type
  #boolean address
  +processCreatedat()
  +findType()
  +updateScore()
  +validateTotal()
}
Ward --o Patient
Nurse --* Ward
Doctor ..> Nurse : "*"
@enduml