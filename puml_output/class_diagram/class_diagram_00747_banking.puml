@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
abstract class Customer {
  #int phone
  +Date amount
  -int price
  +calculateEmail()
}
class Interest {
  #String createdAt
  +String quantity
  -String email
  +findEmail()
}
class Loan {
  +long type
  -boolean amount
  +findCreatedat()
  +validatePhone()
}
abstract class Card {
  #long id
  +Date status
  +Date code
  +deleteName()
  +setAmount()
  +createPhone()
}
class Deposit {
  +Date type
  +int duration
  +saveStatus()
  +updateAmount()
}
Loan ..|> Card
Customer --o Deposit
Interest --|> Loan
note right of Customer : Banking domain
@enduml