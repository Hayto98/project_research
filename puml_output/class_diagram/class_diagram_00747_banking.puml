@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
abstract class Customer {
  #int phone
  +Date amount
  -int price
  +createEmail()
}
abstract class Interest {
  -boolean address
  +String updatedAt
  +double createdAt
  +String quantity
  +updatePhone()
  +validateCreatedat()
  +getType()
}
abstract class Loan {
  #Date createdAt
  +Date email
  +long quantity
  +deleteActive()
  +processUpdatedat()
  +saveTotal()
}
class Card {
  +Date code
  +Date address
  +saveAddress()
  +calculateEmail()
  +setStatus()
}
class Deposit {
  #Date phone
  -String amount
  #String code
  +int type
  +processActive()
}
Loan ..> Deposit : "*"
Interest --|> Customer
@enduml