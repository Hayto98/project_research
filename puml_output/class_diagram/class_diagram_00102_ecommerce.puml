@startuml
skinparam monochrome true
class Shipment {
  -long duration
  -boolean status
  +long updatedAt
  #double address
  -long level
  +cancelType()
  +findScore()
}
class Category {
  +float amount
  -double quantity
  +cancelLevel()
  +setActive()
}
abstract class Invoice {
  +double status
  #Date duration
  +cancelCreatedat()
  +createScore()
}
class Customer {
  #long updatedAt
  -Date status
  +float total
  -Date quantity
  -int level
  +processPrice()
  +setTotal()
}
class Return {
  +int score
  -Date name
  +calculateTotal()
  +cancelAmount()
  +getScore()
  +sendAddress()
}
interface Supplier {
  -boolean code
  #double amount
  #int duration
  #int phone
  #double status
  +findCreatedat()
  +createDuration()
}
class Product {
  -boolean phone
  #long updatedAt
  #Date address
  -Date total
  +cancelPrice()
  +validateScore()
}
Product ..|> Category
Customer --|> Category
Shipment ..> Customer : "0..1"
Category --* Customer
@enduml