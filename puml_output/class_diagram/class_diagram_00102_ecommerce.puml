@startuml
skinparam monochrome true
class Shipment {
  -long duration
  -boolean status
  +long updatedAt
  #double address
  -long level
  +createEmail()
  +getAmount()
}
class Category {
  +float type
  #float note
  +saveName()
  +findStatus()
  +setUpdatedat()
  +processDuration()
}
interface Invoice {
  -int total
  #Date updatedAt
  +boolean address
  +saveQuantity()
  +setDuration()
  +createType()
  +saveStatus()
}
class Customer {
  +boolean description
  #Date updatedAt
  +int level
  +float quantity
  -Date name
  +sendActive()
  +createActive()
  +processCode()
  +deleteCode()
}
interface Return {
  #int status
  #int price
  #double score
  #int note
  +calculateStatus()
  +createPhone()
  +updateAddress()
}
abstract class Supplier {
  #long score
  -float address
  +int active
  -int email
  +float description
  +getTotal()
  +saveCreatedat()
}
class Product {
  -Date address
  #Date price
  #int score
  +boolean updatedAt
  #int createdAt
  +processQuantity()
  +calculatePhone()
}
Category ..|> Supplier
Invoice --|> Category
note right of Shipment : Ecommerce domain
@enduml