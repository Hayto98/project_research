@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
abstract class Doctor {
  +double note
  -boolean duration
  #Date level
  -long id
  +double score
  +sendPhone()
  +validateAmount()
}
class Billing {
  #boolean phone
  #Date type
  +int id
  +updateType()
  +updatePrice()
}
class MedicalRecord {
  #Date total
  #int score
  #double status
  +findCode()
  +createName()
  +calculateStatus()
  +deletePhone()
}
class Insurance {
  #double amount
  +boolean type
  -long description
  +findScore()
  +calculatePhone()
}
abstract class Hospital {
  #String code
  -int score
  #float updatedAt
  +findActive()
  +sendType()
  +calculateTotal()
}
class Prescription {
  #long description
  #boolean total
  -Date price
  +long active
  +savePrice()
  +createEmail()
  +validateTotal()
}
class Diagnosis {
  -String note
  +long price
  +validateDuration()
  +setAddress()
  +deleteCreatedat()
}
Billing --* Prescription
Billing --|> Hospital
Insurance ..|> Prescription
Hospital ..|> Doctor
Billing --* Doctor
@enduml