@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
abstract class Package {
  #double active
  -float name
  -boolean level
  +String amount
  #String createdAt
  +deleteDuration()
  +validateScore()
}
interface DeliveryNote {
  +long code
  +String address
  +validateStatus()
  +setCreatedat()
  +saveScore()
  +updatePrice()
}
class Vehicle {
  +long quantity
  +double duration
  +updateUpdatedat()
}
class FuelLog {
  #String status
  #float code
  -double price
  #Date email
  -String phone
  +validateName()
  +cancelType()
}
abstract class Inventory {
  +Date type
  +float price
  #long active
  #boolean id
  +long duration
  +sendDescription()
  +saveLevel()
  +setAddress()
}
Inventory --* Package
Package --> Inventory : "0..1"
Inventory --* DeliveryNote
@enduml