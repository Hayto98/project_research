@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Package {
  #int price
  +double phone
  #long note
  +sendAmount()
  +calculateName()
  +sendUpdatedat()
}
class Vehicle {
  +Date active
  #String id
  +String score
  +validateLevel()
  +getNote()
  +cancelPhone()
  +getActive()
}
abstract class Depot {
  -long createdAt
  -double type
  -double duration
  -String code
  +findCreatedat()
  +validateActive()
  +calculateQuantity()
}
abstract class DeliveryNote {
  -float quantity
  -double active
  #boolean updatedAt
  #double address
  +int description
  +calculateName()
}
class Driver {
  +Date status
  +Date email
  #float note
  +cancelCreatedat()
  +updateAddress()
}
class Tracking {
  #double note
  +long id
  +getName()
  +deleteTotal()
}
Vehicle --* Package
DeliveryNote --|> Vehicle
Depot ..|> Tracking
DeliveryNote ..|> Depot
@enduml