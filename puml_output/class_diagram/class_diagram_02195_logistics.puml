@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Package {
  #int price
  +double phone
  #long note
  +sendAddress()
  +findPhone()
  +findUpdatedat()
}
interface Vehicle {
  #Date score
  +int updatedAt
  +saveNote()
}
class Depot {
  +String price
  -long address
  -double createdAt
  -double type
  +setEmail()
  +createDuration()
  +calculateType()
}
abstract class DeliveryNote {
  -float active
  -double updatedAt
  #boolean address
  #double description
  +updateName()
  +validateName()
}
class Driver {
  +Date email
  +Date note
  +calculateName()
  +getNote()
}
class Tracking {
  +String status
  -double phone
  +String createdAt
  -long active
  +double address
  +updatePhone()
  +processTotal()
  +createAddress()
}
DeliveryNote --* Vehicle
DeliveryNote --> Driver : "1"
Driver --> DeliveryNote : "1..*"
note right of Package : Logistics domain
@enduml