@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Library {
  +Date status
  +Date active
  -double quantity
  +validateDuration()
}
abstract class Department {
  +boolean updatedAt
  #int score
  +createDescription()
}
class Grade {
  +long quantity
  -Date amount
  -long score
  +processDuration()
}
abstract class Student {
  +int active
  +Date id
  +cancelAmount()
}
Grade --o Student
Student --o Library
Library ..> Department : "1"
note right of Library : Education domain
@enduml