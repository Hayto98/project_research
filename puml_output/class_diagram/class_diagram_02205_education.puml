@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Library {
  +Date status
  +Date active
  -double quantity
  +updateTotal()
}
interface Department {
  +float name
  -int updatedAt
  -int score
  -float duration
  +Date level
  +deleteCode()
  +deleteId()
}
class Grade {
  +boolean address
  +float code
  +int note
  +Date type
  +findUpdatedat()
}
class Student {
  -String phone
  -Date level
  #float type
  #boolean price
  +String name
  +updateTotal()
}
Library ..> Department : "1"
@enduml