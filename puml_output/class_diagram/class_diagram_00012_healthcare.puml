@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
abstract class Billing {
  +int address
  +String active
  +float price
  +cancelAddress()
  +saveUpdatedat()
}
class MedicalRecord {
  #int phone
  #double type
  -boolean amount
  +boolean price
  +createLevel()
}
class Patient {
  #long type
  -int duration
  -String price
  +calculateAmount()
}
class Hospital {
  -int quantity
  -double createdAt
  +calculateStatus()
  +sendDescription()
  +saveType()
}
class LabTest {
  +double active
  #double status
  #long phone
  -float note
  +createAddress()
  +updateCreatedat()
}
LabTest ..|> Hospital
LabTest ..|> MedicalRecord
Billing --o LabTest
@enduml