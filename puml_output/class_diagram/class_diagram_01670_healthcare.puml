@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
abstract class Insurance {
  #int status
  -Date note
  +getName()
  +calculateActive()
  +cancelNote()
  +savePrice()
}
class Hospital {
  +boolean score
  +String phone
  +String total
  +processId()
  +getCreatedat()
}
abstract class Nurse {
  #long quantity
  -int status
  #boolean type
  #Date level
  +calculateLevel()
}
abstract class Diagnosis {
  +boolean id
  -int code
  +getDuration()
  +cancelQuantity()
  +cancelCreatedat()
  +validateAmount()
}
class Treatment {
  -Date type
  #float updatedAt
  -int id
  -String active
  +boolean status
  +getCreatedat()
  +createPrice()
}
interface Billing {
  #boolean updatedAt
  +String duration
  #Date phone
  #long status
  +updateEmail()
  +getNote()
  +calculateCode()
  +saveTotal()
}
Billing --* Diagnosis
Insurance --* Treatment
Insurance --* Nurse
@enduml