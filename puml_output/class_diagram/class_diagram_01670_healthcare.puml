@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
abstract class Insurance {
  #int status
  -Date note
  +sendCreatedat()
  +cancelPhone()
  +deleteScore()
  +validateTotal()
}
class Hospital {
  +float name
  +boolean createdAt
  +findQuantity()
  +createStatus()
  +processStatus()
  +sendQuantity()
}
abstract class Nurse {
  +String score
  +String status
  #double note
  +sendPrice()
  +processTotal()
}
class Diagnosis {
  +Date total
  #String type
  -Date updatedAt
  +updateQuantity()
  +getCode()
  +sendAmount()
  +sendPrice()
}
interface Treatment {
  #boolean updatedAt
  +String duration
  #Date phone
  #long status
  +calculateQuantity()
  +calculateActive()
  +findUpdatedat()
  +findPrice()
}
class Billing {
  +Date level
  -long phone
  +calculateAddress()
  +createLevel()
  +findType()
  +getCreatedat()
}
Nurse ..|> Billing
Treatment --* Diagnosis
note right of Insurance : Healthcare domain
@enduml