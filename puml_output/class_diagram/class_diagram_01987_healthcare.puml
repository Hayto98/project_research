@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
interface Prescription {
  #Date createdAt
  -boolean quantity
  #int address
  -Date active
  +int id
  +processCode()
  +cancelEmail()
  +deleteActive()
}
abstract class Diagnosis {
  #Date description
  +String email
  -int price
  -long total
  #boolean address
  +calculateActive()
}
interface Ward {
  -String active
  #String createdAt
  -Date description
  +cancelTotal()
  +getType()
  +cancelAmount()
}
class Hospital {
  +float price
  -boolean total
  +createStatus()
  +saveType()
}
class Patient {
  #String level
  #float address
  +saveDescription()
  +sendAddress()
}
abstract class Insurance {
  #String note
  +double address
  +calculateId()
}
Patient --|> Diagnosis
Insurance --* Patient
Ward ..> Diagnosis : "1..*"
@enduml