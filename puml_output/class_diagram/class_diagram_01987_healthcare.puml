@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
interface Prescription {
  #Date createdAt
  -boolean quantity
  #int address
  -Date active
  +int id
  +getStatus()
  +processType()
  +calculateDescription()
}
class Diagnosis {
  -int total
  -long active
  #boolean address
  +boolean id
  #Date code
  +sendCreatedat()
  +findDescription()
}
abstract class Ward {
  #Date status
  #boolean phone
  +getCode()
  +sendId()
  +sendCode()
}
abstract class Hospital {
  +boolean description
  -boolean type
  +boolean score
  #boolean amount
  +Date id
  +calculateName()
  +processAddress()
  +sendCode()
}
class Patient {
  +Date active
  #long id
  -int name
  #long updatedAt
  +int createdAt
  +findCreatedat()
  +processCreatedat()
  +processCreatedat()
  +updateUpdatedat()
}
class Insurance {
  +long status
  #boolean quantity
  +updateActive()
  +getName()
  +getName()
  +setNote()
}
Patient --|> Diagnosis
Insurance --o Hospital
Prescription --o Insurance
Insurance ..|> Ward
note right of Prescription : Healthcare domain
@enduml