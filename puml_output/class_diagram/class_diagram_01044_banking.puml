@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Loan {
  +float description
  -Date address
  +double note
  +boolean id
  +String level
  +deleteId()
  +getScore()
  +validateAmount()
  +createCode()
}
abstract class Branch {
  #boolean quantity
  #long duration
  +String note
  #long email
  +calculateCode()
  +saveStatus()
  +calculatePhone()
}
class Withdrawal {
  -long note
  +String status
  #boolean id
  +updateTotal()
  +sendType()
  +deleteScore()
}
class Customer {
  #float description
  -String score
  -float updatedAt
  -float quantity
  +long id
  +saveLevel()
  +createCode()
  +getDuration()
  +getDuration()
}
class Statement {
  -boolean code
  -String phone
  #String status
  -Date duration
  +processDescription()
  +validateDuration()
  +processName()
  +sendTotal()
}
Branch ..> Loan : "1..*"
Customer --|> Branch
Loan --|> Statement
note right of Loan : Banking domain
@enduml