@startuml
skinparam defaultFontSize 13
class Invoice {
  -double updatedAt
  #double note
  -float address
  -boolean duration
  +findDuration()
  +validateActive()
  +updateLevel()
}
class Cart {
  #int quantity
  +double phone
  #Date amount
  #double duration
  #double status
  +validateType()
  +cancelPrice()
  +getScore()
  +updatePhone()
}
interface Order {
  #boolean note
  -Date level
  -long code
  +double address
  +double active
  +cancelCode()
  +sendTotal()
  +createLevel()
}
abstract class Payment {
  +double code
  #int description
  #int active
  +long name
  +cancelPrice()
}
class Review {
  #float description
  +boolean price
  +getName()
  +createName()
  +updateDuration()
}
abstract class Warehouse {
  -boolean address
  -double code
  #double description
  +processCode()
  +setEmail()
  +getId()
  +saveId()
}
class Customer {
  +Date level
  +float address
  +double duration
  +Date createdAt
  +deleteEmail()
  +setCreatedat()
}
Cart ..|> Review
Customer --|> Payment
note right of Invoice : Ecommerce domain
@enduml