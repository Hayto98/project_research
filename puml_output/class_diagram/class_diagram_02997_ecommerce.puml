@startuml
skinparam defaultFontSize 13
class Invoice {
  -double updatedAt
  #double note
  -float address
  -boolean duration
  +updateScore()
  +getDuration()
  +deletePhone()
}
interface Cart {
  -long active
  -int createdAt
  -String email
  #int duration
  +deleteAmount()
}
abstract class Order {
  #int price
  -Date address
  #Date type
  #Date duration
  #double id
  +createLevel()
  +deleteUpdatedat()
  +updateCode()
  +findNote()
}
class Payment {
  +double score
  +double phone
  #Date note
  -boolean quantity
  +deletePhone()
}
interface Review {
  +boolean email
  +int level
  -Date type
  +Date duration
  +int code
  +updateName()
  +deleteUpdatedat()
  +updateCreatedat()
}
abstract class Warehouse {
  #float status
  +boolean description
  -String price
  +findScore()
}
class Customer {
  -float duration
  +int total
  -boolean description
  +saveCode()
  +cancelAmount()
  +deleteDuration()
  +createTotal()
}
Payment --|> Customer
Customer --* Invoice
Invoice ..> Customer : "1"
Cart --> Order : "1..*"
Order ..|> Cart
Warehouse ..|> Invoice
@enduml