@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
interface Reservation {
  #double total
  -float score
  +createId()
  +setTotal()
}
abstract class Shelf {
  -Date level
  #double price
  +boolean amount
  #boolean score
  +findEmail()
  +validateStatus()
}
interface Fine {
  -Date createdAt
  -String description
  #int email
  +getAddress()
  +createDescription()
  +findQuantity()
}
class Renewal {
  +Date score
  #long active
  #String code
  -float duration
  +updateUpdatedat()
  +getActive()
  +saveStatus()
  +setPhone()
}
interface Librarian {
  +float code
  +float email
  +int note
  -boolean amount
  #float address
  +processAmount()
  +processAddress()
}
class Catalog {
  +boolean type
  #int status
  #float duration
  +setAmount()
  +calculateType()
  +setUpdatedat()
}
abstract class Publisher {
  #int active
  #float score
  +long total
  #long address
  +findScore()
  +getLevel()
  +validateEmail()
  +savePrice()
}
Librarian ..> Publisher : "*"
Librarian ..|> Renewal
Catalog --o Librarian
Shelf --* Reservation
Renewal --o Reservation
@enduml