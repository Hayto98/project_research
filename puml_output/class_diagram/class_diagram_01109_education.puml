@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Teacher {
  +boolean id
  #int level
  +boolean name
  +String updatedAt
  +calculateScore()
  +getAddress()
  +setPrice()
  +createPrice()
}
class Classroom {
  -int active
  #Date id
  +saveActive()
  +validateUpdatedat()
  +calculateTotal()
  +saveLevel()
}
abstract class Grade {
  +long name
  #String email
  +sendScore()
}
class Enrollment {
  +long code
  +float level
  +Date email
  +long type
  -float name
  +getName()
}
Enrollment --|> Teacher
Enrollment --|> Grade
Grade --o Teacher
note right of Teacher : Education domain
@enduml