@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Teacher {
  +boolean id
  #int level
  +boolean name
  +String updatedAt
  +getDescription()
  +cancelCreatedat()
  +cancelAmount()
  +saveId()
}
class Classroom {
  -int price
  #Date email
  +sendDescription()
}
interface Grade {
  #Date quantity
  -Date amount
  +processPrice()
  +getPhone()
  +getPrice()
}
abstract class Enrollment {
  #String id
  +float name
  #boolean email
  +double code
  +float phone
  +sendName()
  +savePhone()
  +createCreatedat()
}
Classroom ..> Teacher : "0..1"
Grade --|> Classroom
Teacher --|> Grade
@enduml