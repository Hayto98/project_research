@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Group {
  -double level
  +Date status
  -boolean quantity
  +sendActive()
  +updateEmail()
}
class Comment {
  -float amount
  +int note
  +createPrice()
  +sendType()
}
class Follower {
  +Date name
  -Date total
  -long updatedAt
  +boolean note
  +updateStatus()
  +validateDescription()
}
class Story {
  -int score
  #boolean id
  +double duration
  #float type
  #Date status
  +createType()
  +updateEmail()
}
Story ..> Group : "1..*"
Follower ..> Group : "*"
Follower --o Story
@enduml