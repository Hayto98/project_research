@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Group {
  -double level
  +Date status
  -boolean quantity
  +cancelTotal()
  +setCode()
}
class Comment {
  -float total
  -String amount
  -float level
  #int createdAt
  -String price
  +savePrice()
  +createStatus()
  +cancelAmount()
  +updateDescription()
}
interface Follower {
  -int score
  #boolean id
  +double duration
  #float type
  #Date status
  +saveTotal()
  +calculateNote()
}
class Story {
  -boolean address
  -boolean status
  +long active
  -long price
  +calculateTotal()
  +saveActive()
  +createLevel()
}
Group --|> Story
Comment --|> Story
note right of Group : Social Media domain
@enduml