@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Classroom {
  -long total
  -int status
  +long phone
  -boolean price
  +Date active
  +findQuantity()
  +deleteScore()
  +cancelId()
  +findType()
}
class Exam {
  +String updatedAt
  -long active
  +createPhone()
  +updatePrice()
}
class Attendance {
  #Date updatedAt
  #long active
  +float total
  -float amount
  #int address
  +saveCreatedat()
}
class Course {
  -Date duration
  #long type
  -int quantity
  +cancelDuration()
  +getAddress()
}
Classroom ..|> Exam
Exam --* Attendance
Attendance --> Course : "*"
@enduml