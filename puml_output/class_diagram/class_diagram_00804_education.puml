@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Classroom {
  -long total
  -int status
  +long phone
  -boolean price
  +Date active
  +validateAmount()
  +validateUpdatedat()
  +getUpdatedat()
  +sendId()
}
class Exam {
  +long quantity
  -int level
  #double amount
  +long status
  +updateAddress()
  +cancelUpdatedat()
  +getAddress()
}
class Attendance {
  -Date duration
  #long type
  -int quantity
  +saveTotal()
  +validateDuration()
}
class Course {
  #long createdAt
  #boolean active
  #double duration
  #Date quantity
  +updateLevel()
  +findDescription()
  +deleteAddress()
}
Course --o Classroom
Exam ..> Classroom : "1"
Exam ..|> Course
note right of Classroom : Education domain
@enduml