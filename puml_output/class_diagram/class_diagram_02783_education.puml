@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
abstract class Grade {
  #String score
  #double updatedAt
  -double quantity
  -String status
  +sendId()
}
class Schedule {
  #double updatedAt
  #double duration
  +float email
  +double status
  +validateCode()
  +processDescription()
  +setActive()
}
class Department {
  #int quantity
  -int email
  +getDescription()
  +setUpdatedat()
  +sendStatus()
}
class Exam {
  +String amount
  #String createdAt
  #Date note
  -String id
  +long score
  +findTotal()
  +setPhone()
  +sendDuration()
}
interface Library {
  +Date createdAt
  +Date level
  +Date score
  #Date code
  +Date phone
  +deleteUpdatedat()
}
Department --* Schedule
Exam --> Department : "*"
Schedule ..> Grade : "0..1"
@enduml