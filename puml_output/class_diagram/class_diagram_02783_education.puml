@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
abstract class Grade {
  #String score
  #double updatedAt
  -double quantity
  -String status
  +updateName()
}
class Schedule {
  #double updatedAt
  #double email
  +float status
  +processAddress()
  +deleteQuantity()
}
class Department {
  #int quantity
  -int email
  +getCreatedat()
  +processAmount()
  +updateDuration()
}
abstract class Exam {
  +boolean note
  +boolean amount
  +getStatus()
  +validateDuration()
  +sendQuantity()
  +cancelDuration()
}
abstract class Library {
  #boolean level
  -int score
  #int code
  +findDuration()
}
Schedule --> Grade : "1..*"
Department --* Schedule
Exam --> Department : "*"
note right of Grade : Education domain
@enduml