@startuml
skinparam defaultFontSize 13
class Product {
  +String total
  #int quantity
  -boolean status
  -String phone
  +getActive()
  +calculateQuantity()
}
class Customer {
  +int active
  #Date quantity
  #long createdAt
  +long level
  +updateDescription()
  +updateScore()
  +calculateDescription()
}
class Warehouse {
  +boolean price
  +float status
  #boolean code
  -float quantity
  +setActive()
  +saveDuration()
  +deleteType()
}
abstract class Supplier {
  +Date active
  -int id
  +boolean createdAt
  #Date total
  -float level
  +deletePrice()
  +saveTotal()
  +setType()
}
interface Return {
  -String amount
  -float address
  #int name
  +calculateType()
  +getLevel()
}
Supplier ..> Warehouse : "1"
Product ..> Warehouse : "1"
Warehouse --> Supplier : "1..*"
@enduml