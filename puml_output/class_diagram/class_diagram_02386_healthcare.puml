@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
abstract class Diagnosis {
  -float code
  +int updatedAt
  +long address
  +boolean note
  +deleteNote()
  +deleteName()
}
class Billing {
  -double amount
  -double price
  -int type
  #Date createdAt
  +float level
  +cancelDuration()
}
interface Ward {
  +boolean createdAt
  +float id
  #double amount
  #float status
  -Date quantity
  +deletePrice()
}
interface Insurance {
  +String type
  +int quantity
  -int duration
  -boolean phone
  +findAddress()
  +createAddress()
  +setEmail()
  +getQuantity()
}
Insurance --* Billing
Insurance ..|> Ward
@enduml