@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Withdrawal {
  #long status
  #double createdAt
  #boolean address
  +calculatePrice()
}
class Card {
  +double id
  +boolean active
  #long createdAt
  -long email
  +saveEmail()
  +calculateCreatedat()
}
interface Account {
  +float status
  +String quantity
  #float description
  -double updatedAt
  +saveScore()
  +findId()
}
abstract class Loan {
  -int note
  #Date total
  +validateDuration()
  +createAddress()
}
interface Branch {
  +int score
  +long duration
  +setAddress()
}
class Beneficiary {
  +double duration
  #boolean address
  -int type
  +saveId()
  +createName()
}
Beneficiary --* Loan
Branch ..> Loan : "1..*"
Branch --|> Beneficiary
Withdrawal --o Loan
Beneficiary --|> Branch
@enduml