@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Withdrawal {
  #long status
  #double createdAt
  #boolean address
  +sendCreatedat()
}
class Card {
  -int active
  -int createdAt
  +validateAddress()
  +deleteName()
  +validateScore()
}
class Account {
  #float quantity
  +int description
  +setDuration()
  +createType()
}
class Loan {
  -long amount
  +Date total
  #int name
  -String note
  +sendScore()
}
class Branch {
  #String amount
  +boolean address
  -float code
  +updateType()
  +findActive()
  +validateCreatedat()
  +deleteName()
}
abstract class Beneficiary {
  +double note
  -float address
  #Date total
  #String email
  #float status
  +calculateScore()
  +findDuration()
  +getTotal()
}
Withdrawal --|> Loan
Beneficiary ..> Card : "*"
Loan ..> Branch : "1..*"
Account --o Withdrawal
note right of Withdrawal : Banking domain
@enduml