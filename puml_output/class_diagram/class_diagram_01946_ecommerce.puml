@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Product {
  +long price
  -long name
  #float level
  +float type
  #float active
  +setDuration()
  +updateCreatedat()
}
class Payment {
  +long phone
  -Date note
  -long code
  #int score
  +validatePrice()
  +saveNote()
}
class Wishlist {
  #Date code
  #float address
  -float active
  #int description
  -float id
  +cancelAmount()
  +createTotal()
  +createName()
}
abstract class Customer {
  #double score
  -double status
  #long email
  +setName()
  +updateName()
  +createName()
  +findDescription()
}
Wishlist ..|> Product
Payment --o Wishlist
Wishlist --o Customer
@enduml