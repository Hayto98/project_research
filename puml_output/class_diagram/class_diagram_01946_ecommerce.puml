@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Product {
  +long price
  -long name
  #float level
  +float type
  #float active
  +validateAddress()
  +validateNote()
}
class Payment {
  -Date createdAt
  -long address
  +updateCreatedat()
  +findDescription()
}
abstract class Wishlist {
  #int address
  #String level
  +cancelAmount()
  +processAddress()
  +sendNote()
  +processDescription()
}
interface Customer {
  #double duration
  -double email
  +calculateId()
  +setNote()
  +cancelPrice()
}
Product ..> Customer : "0..1"
Customer --* Wishlist
note right of Product : Ecommerce domain
@enduml