@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
abstract class Like {
  +Date score
  +boolean note
  +updateLevel()
  +validateType()
  +processStatus()
}
abstract class Story {
  #String active
  +double total
  #long score
  -double description
  +float phone
  +createDescription()
}
interface User {
  #String description
  +boolean score
  +String createdAt
  #boolean address
  +sendActive()
  +sendPrice()
  +processPrice()
}
class Follower {
  -float quantity
  -float level
  +float total
  #float id
  -String active
  +processDuration()
  +validateType()
}
Like --|> Story
Story --* User
Story --o Follower
@enduml