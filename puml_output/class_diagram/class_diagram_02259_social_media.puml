@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
abstract class Like {
  +Date score
  +boolean note
  +createPhone()
  +calculateDuration()
  +processActive()
}
abstract class Story {
  -Date phone
  -double code
  -int id
  +sendLevel()
}
class User {
  #String score
  +boolean createdAt
  +String address
  +cancelUpdatedat()
  +getType()
  +createLevel()
}
abstract class Follower {
  -float id
  +float note
  +getDescription()
  +updateEmail()
  +saveStatus()
  +calculateId()
}
User --o Like
Follower ..|> Like
note right of Like : Social Media domain
@enduml