@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Fine {
  -boolean total
  -String score
  +float price
  #String duration
  +boolean name
  +updateUpdatedat()
  +createQuantity()
  +sendTotal()
  +saveScore()
}
class Member {
  +long phone
  #float address
  -Date duration
  +calculateDuration()
  +setAddress()
  +validateActive()
}
class Shelf {
  -long code
  -boolean name
  #int amount
  -String quantity
  +double duration
  +saveStatus()
  +getNote()
}
interface Librarian {
  +long note
  #int address
  #String amount
  -Date type
  -float email
  +updateTotal()
  +getEmail()
  +deleteCreatedat()
}
class Catalog {
  -Date createdAt
  -Date phone
  -int level
  -int amount
  -int total
  +deleteNote()
  +setType()
  +calculateCode()
  +createScore()
}
abstract class Loan {
  -boolean createdAt
  #long address
  #int duration
  +deleteName()
}
Fine --* Member
Librarian --> Member : "*"
@enduml