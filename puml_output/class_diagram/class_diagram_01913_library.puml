@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Fine {
  -boolean total
  -String score
  +float price
  #String duration
  +boolean name
  +setQuantity()
  +getPhone()
  +validateCreatedat()
  +validateAddress()
}
class Member {
  #long email
  #boolean total
  +sendNote()
  +setName()
}
class Shelf {
  #boolean code
  +long price
  +int email
  -int phone
  +cancelActive()
  +processNote()
  +findAddress()
}
class Librarian {
  #String level
  -Date email
  -float status
  #long quantity
  -int amount
  +saveDescription()
  +processCreatedat()
  +validatePhone()
}
class Catalog {
  +double quantity
  +double total
  +int level
  -int description
  -int score
  +validateCreatedat()
  +processScore()
}
interface Loan {
  +int description
  -double name
  +boolean email
  -long code
  +sendQuantity()
  +deleteAmount()
  +updateQuantity()
  +cancelUpdatedat()
}
Member ..|> Librarian
Member --o Catalog
Fine --> Librarian : "1"
note right of Fine : Library domain
@enduml