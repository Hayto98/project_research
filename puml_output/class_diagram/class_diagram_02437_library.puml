@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
interface Author {
  +boolean phone
  +boolean amount
  -long status
  +processQuantity()
  +deleteType()
  +calculatePrice()
}
class Book {
  +float description
  #Date createdAt
  #boolean duration
  #Date address
  #long price
  +saveName()
  +cancelName()
  +getCreatedat()
  +calculateLevel()
}
abstract class Renewal {
  #float level
  +Date active
  +float address
  +String phone
  +boolean quantity
  +createType()
  +sendCreatedat()
  +savePrice()
  +createQuantity()
}
interface Shelf {
  -Date updatedAt
  #float quantity
  +long code
  -Date duration
  -Date type
  +calculateEmail()
  +sendQuantity()
  +cancelLevel()
}
class Loan {
  #float updatedAt
  #float email
  +Date id
  #double createdAt
  #double note
  +deleteTotal()
}
interface Librarian {
  +boolean price
  #float level
  +int type
  +getDescription()
}
abstract class Catalog {
  +double address
  #int active
  #long price
  +updatePhone()
}
Loan --* Shelf
Shelf --|> Book
Book --o Author
Author --o Librarian
Librarian --> Book : "0..1"
@enduml