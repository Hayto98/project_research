@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
interface Author {
  +boolean phone
  +boolean amount
  -long status
  +getScore()
  +updateNote()
  +deleteCreatedat()
}
class Book {
  -double duration
  #boolean price
  -float updatedAt
  -boolean quantity
  +validateQuantity()
  +saveCreatedat()
  +saveStatus()
}
class Renewal {
  #boolean description
  -Date score
  +cancelQuantity()
  +sendNote()
  +updateQuantity()
  +findCode()
}
class Shelf {
  #float phone
  #long id
  +boolean quantity
  +double address
  +long price
  +updateNote()
}
class Loan {
  -Date active
  #double type
  +boolean score
  #float id
  +int createdAt
  +findPrice()
}
class Librarian {
  #int active
  #long price
  +Date id
  #float type
  +cancelPrice()
  +createType()
  +deleteCode()
  +deleteCode()
}
abstract class Catalog {
  #int type
  +float amount
  +createQuantity()
  +createStatus()
  +sendActive()
  +updateCreatedat()
}
Shelf ..> Author : "0..1"
Author --|> Catalog
note right of Author : Library domain
@enduml