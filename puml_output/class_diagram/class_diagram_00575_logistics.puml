@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class FuelLog {
  -Date status
  #Date level
  -Date description
  +findStatus()
  +updateDuration()
}
class Warehouse {
  -Date updatedAt
  +int duration
  +Date total
  #boolean quantity
  +deleteScore()
  +deleteCode()
  +calculateType()
}
class Driver {
  -double amount
  #double createdAt
  +deleteName()
  +findEmail()
  +saveCode()
  +getAmount()
}
class Tracking {
  #double status
  -float amount
  +setType()
}
class Package {
  #Date status
  #Date price
  +int address
  +String duration
  +calculateCreatedat()
}
interface Manifest {
  -String status
  +long price
  +boolean code
  #long name
  +getLevel()
}
Package ..|> Warehouse
Manifest --|> FuelLog
Manifest --|> Warehouse
@enduml