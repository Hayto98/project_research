@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class FuelLog {
  -Date status
  #Date level
  -Date description
  +saveId()
  +saveQuantity()
}
class Warehouse {
  -Date updatedAt
  +int total
  +Date quantity
  +deletePhone()
  +validateStatus()
  +deleteCreatedat()
}
class Driver {
  #String total
  +float note
  +boolean email
  -double price
  +int phone
  +saveActive()
}
class Tracking {
  #boolean price
  +Date address
  +deleteAmount()
}
class Package {
  -float address
  +double score
  +getEmail()
}
class Manifest {
  #long address
  #float amount
  #String active
  +saveUpdatedat()
}
Warehouse --|> FuelLog
Manifest --|> Warehouse
Tracking --* Package
note right of FuelLog : Logistics domain
@enduml