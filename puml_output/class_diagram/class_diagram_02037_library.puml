@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Loan {
  #String total
  #Date type
  -String quantity
  -double createdAt
  +getCode()
}
abstract class Publisher {
  +double total
  -float phone
  -int description
  +float level
  +createDescription()
  +getDuration()
}
abstract class Shelf {
  #float updatedAt
  -long quantity
  +savePhone()
  +validateDuration()
  +getCode()
  +findCode()
}
interface Member {
  #int id
  #boolean type
  +getNote()
  +createNote()
  +getPrice()
}
class Catalog {
  #double score
  -boolean active
  #long level
  +setScore()
  +calculateCode()
  +calculateDuration()
}
class Fine {
  #long email
  -int total
  +createStatus()
  +sendLevel()
  +sendName()
  +sendActive()
}
class Author {
  -int createdAt
  #float duration
  +boolean active
  -long price
  +updateId()
}
Publisher ..|> Author
Publisher --|> Shelf
Author --* Shelf
Catalog --> Shelf : "1"
Member --> Catalog : "1"
note right of Loan : Library domain
@enduml