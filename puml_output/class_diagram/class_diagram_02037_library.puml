@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Loan {
  #String total
  #Date type
  -String quantity
  -double createdAt
  +getName()
}
class Publisher {
  -long total
  +long address
  +processType()
  +sendCreatedat()
}
abstract class Shelf {
  -int name
  +boolean level
  -String amount
  +validateTotal()
  +createEmail()
}
class Member {
  #String phone
  +Date total
  +boolean duration
  #String address
  +sendCreatedat()
}
interface Catalog {
  -String duration
  -float score
  -double level
  +sendScore()
}
class Fine {
  #double score
  -boolean active
  #long level
  +setDescription()
  +sendAmount()
  +getPhone()
}
class Author {
  #long duration
  -int createdAt
  -long id
  #String email
  #Date total
  +getCreatedat()
}
Publisher ..|> Shelf
Publisher --o Catalog
Member ..> Publisher : "0..1"
Catalog --* Member
Fine ..|> Loan
Loan ..|> Member
@enduml