@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Ward {
  +String code
  +float id
  #boolean duration
  -double note
  #int amount
  +sendNote()
  +saveCreatedat()
  +findAddress()
}
interface Diagnosis {
  #long duration
  +float address
  +double id
  #int level
  -Date score
  +deleteCode()
  +sendLevel()
}
interface Patient {
  -float code
  -long note
  -long duration
  +deleteDescription()
  +saveDuration()
  +createCode()
  +validateAddress()
}
class MedicalRecord {
  +double quantity
  -Date email
  #Date price
  +long name
  #int duration
  +processEmail()
  +cancelName()
}
class Insurance {
  #String id
  -Date type
  +boolean updatedAt
  +setPrice()
  +findPrice()
  +setAmount()
  +saveCreatedat()
}
abstract class Prescription {
  +Date active
  +float quantity
  +saveQuantity()
  +calculateId()
}
class Hospital {
  +double level
  #String price
  #Date id
  #Date score
  +validateDescription()
}
Hospital --o Diagnosis
Hospital --> Patient : "0..1"
Prescription --* MedicalRecord
Diagnosis --* Ward
Insurance ..> Prescription : "*"
Ward ..|> Patient
@enduml