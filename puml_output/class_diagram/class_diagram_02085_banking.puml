@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Beneficiary {
  -String total
  +long active
  +boolean type
  +updateCode()
  +sendAmount()
  +sendPhone()
}
class Card {
  +String amount
  +Date score
  #long createdAt
  +long description
  -long status
  +setQuantity()
}
class Teller {
  -long updatedAt
  #float total
  -boolean createdAt
  #Date id
  +calculateCreatedat()
  +calculateDuration()
  +updateQuantity()
}
class Customer {
  +int createdAt
  #float status
  -double description
  -boolean phone
  #float active
  +deleteDescription()
  +createPhone()
}
class Interest {
  #String total
  #float phone
  -Date active
  +deleteDuration()
}
abstract class Branch {
  -String address
  +String score
  -boolean name
  -String type
  -String total
  +updateUpdatedat()
}
class Loan {
  -String updatedAt
  +double phone
  +Date code
  +float email
  +boolean active
  +createLevel()
  +validatePhone()
}
Customer ..|> Card
Card --|> Branch
Loan --* Interest
Beneficiary ..> Loan : "*"
@enduml