@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
abstract class CheckIn {
  -double createdAt
  +float duration
  #String type
  +calculatePrice()
}
interface CheckOut {
  -long code
  +long address
  #boolean score
  #String quantity
  +int price
  +calculateEmail()
  +deleteTotal()
  +processDuration()
}
abstract class Reservation {
  #double duration
  #String name
  #int price
  +Date quantity
  +findEmail()
  +setPhone()
  +deleteAmount()
  +calculateStatus()
}
class Guest {
  -double createdAt
  -boolean type
  #String code
  -long phone
  #float status
  +setCode()
}
class Amenity {
  -boolean address
  -long level
  +validatePhone()
  +getTotal()
}
interface Staff {
  -String quantity
  #long amount
  -long email
  -double description
  +calculateLevel()
  +saveCreatedat()
}
CheckIn --* Guest
Amenity --o CheckOut
CheckOut ..> Staff : "1..*"
@enduml