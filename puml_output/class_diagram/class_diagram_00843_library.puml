@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Librarian {
  -int description
  #double quantity
  +String name
  #long phone
  -long duration
  +updateType()
  +updateStatus()
  +updateAmount()
  +validateName()
}
class Branch {
  -double updatedAt
  +Date id
  +double quantity
  +processLevel()
  +findScore()
  +createDuration()
}
class Renewal {
  -String status
  #float code
  -double name
  -float type
  +setScore()
}
class Fine {
  -int email
  #boolean level
  #float duration
  +float createdAt
  #int active
  +cancelScore()
  +findAmount()
}
class Publisher {
  +long name
  -float id
  -String note
  -boolean amount
  -String level
  +createNote()
  +getNote()
  +setPhone()
  +findType()
}
Branch --* Librarian
Fine ..|> Librarian
@enduml