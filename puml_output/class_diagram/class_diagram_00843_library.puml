@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Librarian {
  -int description
  #double quantity
  +String name
  #long phone
  -long duration
  +deleteUpdatedat()
  +processId()
  +updateUpdatedat()
  +getQuantity()
}
abstract class Branch {
  -double amount
  -long name
  #Date type
  +String quantity
  #String total
  +createCode()
  +cancelType()
  +calculateType()
  +setPhone()
}
abstract class Renewal {
  -int level
  #boolean email
  #float createdAt
  +float score
  +saveDuration()
  +updateTotal()
}
class Fine {
  +long name
  -float id
  -String note
  -boolean amount
  -String level
  +createDuration()
  +updateCreatedat()
  +setQuantity()
  +processName()
}
class Publisher {
  +boolean note
  -boolean id
  #double type
  -float description
  +cancelTotal()
}
Renewal ..> Branch : "0..1"
Librarian --|> Fine
note right of Librarian : Library domain
@enduml