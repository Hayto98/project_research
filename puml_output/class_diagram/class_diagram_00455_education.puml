@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Course {
  -String name
  +float level
  +sendUpdatedat()
  +calculateActive()
  +validateCode()
  +updateStatus()
}
abstract class Grade {
  -Date score
  +int price
  -long id
  -float amount
  +getEmail()
}
abstract class Teacher {
  -Date id
  -boolean level
  +getName()
  +updateEmail()
  +createCode()
}
class Library {
  #long quantity
  +long email
  +int status
  +String address
  -int amount
  +cancelQuantity()
  +sendNote()
}
interface Classroom {
  +Date address
  +double createdAt
  +String phone
  #float duration
  +deleteCode()
  +cancelDuration()
  +cancelAddress()
}
class Attendance {
  -boolean level
  +int name
  -boolean active
  +findNote()
  +processQuantity()
  +setPhone()
}
Library --> Attendance : "1"
Grade --* Teacher
note right of Course : Education domain
@enduml