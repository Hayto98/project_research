@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Course {
  -String name
  +float level
  +sendAmount()
  +sendNote()
  +createDuration()
  +calculateActive()
}
class Grade {
  -long updatedAt
  #double status
  +findDescription()
}
class Teacher {
  -float amount
  #boolean description
  +String note
  -double phone
  +deletePhone()
}
class Library {
  +int total
  #float level
  #long address
  -String id
  +findDuration()
}
abstract class Classroom {
  #long email
  +long status
  +int address
  +String amount
  +createScore()
  +updateStatus()
  +findDescription()
}
class Attendance {
  -String duration
  #String quantity
  -int address
  +boolean createdAt
  -int phone
  +savePrice()
}
Grade ..|> Classroom
Classroom --> Course : "*"
Classroom ..|> Grade
Library --> Classroom : "1..*"
@enduml