@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Teacher {
  -double amount
  +double quantity
  +setPhone()
  +processDescription()
  +saveCreatedat()
  +calculateScore()
}
class Course {
  +int total
  +String id
  -Date name
  +deleteCode()
  +setCode()
}
abstract class Department {
  +long code
  #String amount
  +float name
  +int price
  -String duration
  +deleteEmail()
  +setCreatedat()
  +createActive()
  +cancelPhone()
}
class Enrollment {
  #boolean active
  +boolean createdAt
  +float id
  -double amount
  +double note
  +findPrice()
  +saveCreatedat()
  +deleteCode()
}
Department --o Teacher
Department --|> Course
Teacher --|> Course
@enduml