@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Teacher {
  -double amount
  +double quantity
  +cancelQuantity()
  +validateEmail()
  +createUpdatedat()
  +calculateId()
}
class Course {
  +double description
  #int duration
  +findNote()
  +processCode()
  +findAmount()
}
class Department {
  +int code
  -String name
  -Date phone
  -long id
  -boolean level
  +findActive()
  +saveCreatedat()
  +getAmount()
  +processLevel()
}
interface Enrollment {
  -double duration
  +double createdAt
  +sendAddress()
  +validateDuration()
  +validateEmail()
}
Enrollment --o Course
Teacher --|> Department
note right of Teacher : Education domain
@enduml