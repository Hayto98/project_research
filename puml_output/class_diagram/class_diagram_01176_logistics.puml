@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Warehouse {
  +float price
  +float id
  +long name
  +long description
  +calculateUpdatedat()
  +validateCreatedat()
  +sendAmount()
  +sendScore()
}
abstract class Customer {
  #String active
  #float type
  #double note
  #Date level
  +String email
  +processName()
}
class Package {
  -int id
  +Date code
  +setStatus()
}
class Shipment {
  +boolean name
  +long id
  -double code
  +sendTotal()
}
class Vehicle {
  +boolean note
  +float name
  -long description
  -Date quantity
  +setPrice()
  +findActive()
  +setUpdatedat()
}
class Inventory {
  -String updatedAt
  -float total
  +updateStatus()
  +updateId()
  +processActive()
}
class DeliveryNote {
  -boolean code
  -boolean id
  -float level
  +deleteDescription()
}
Customer --> Inventory : "1..*"
Warehouse --* Inventory
Vehicle --o Shipment
@enduml