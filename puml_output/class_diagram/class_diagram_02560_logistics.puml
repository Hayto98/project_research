@startuml
skinparam defaultFontSize 11
class Tracking {
  -Date total
  #float id
  #boolean amount
  -double level
  +saveActive()
  +createCreatedat()
  +sendTotal()
  +updateAmount()
}
class Driver {
  +Date updatedAt
  +String score
  +boolean total
  +int level
  #int duration
  +cancelStatus()
  +getNote()
  +deleteStatus()
}
class Vehicle {
  #boolean description
  #int type
  +long price
  -int phone
  +float address
  +setDescription()
  +setDuration()
  +saveDuration()
}
class Inventory {
  +int updatedAt
  -double status
  +String description
  -float total
  #long price
  +getTotal()
  +deleteAddress()
}
Vehicle --|> Inventory
Driver --* Vehicle
note right of Tracking : Logistics domain
@enduml