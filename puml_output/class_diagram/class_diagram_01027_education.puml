@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
abstract class Grade {
  -long total
  +int price
  +float status
  +setName()
  +saveLevel()
}
abstract class Classroom {
  #float email
  #String price
  +int note
  +createNote()
  +processActive()
  +createAddress()
}
abstract class Teacher {
  +double name
  +Date status
  +double code
  +updateLevel()
  +findTotal()
  +cancelCode()
  +getQuantity()
}
class Schedule {
  #String email
  -String duration
  +savePhone()
  +setPrice()
  +deleteCode()
  +deleteId()
}
class Enrollment {
  #float updatedAt
  #double note
  #Date phone
  -boolean level
  +sendActive()
  +createAddress()
  +sendAmount()
}
class Department {
  +float id
  #int amount
  -Date total
  +validatePhone()
  +calculateAmount()
  +processPrice()
  +sendPrice()
}
Grade --> Department : "1"
Enrollment --> Schedule : "*"
@enduml