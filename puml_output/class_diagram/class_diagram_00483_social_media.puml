@startuml
skinparam ArrowColor #555555
interface Profile {
  +boolean name
  -String phone
  +long level
  +findDescription()
  +updateDescription()
  +processTotal()
  +cancelAddress()
}
class Message {
  +Date updatedAt
  -int active
  +double email
  +updatePrice()
}
abstract class Album {
  +boolean email
  #int duration
  -long level
  -double price
  #Date total
  +setEmail()
  +sendPhone()
}
class Group {
  +long createdAt
  #int id
  -Date note
  +Date status
  #double address
  +getStatus()
  +sendCreatedat()
  +setActive()
  +getTotal()
}
abstract class User {
  -int duration
  #int phone
  -double id
  -boolean description
  #float price
  +saveScore()
  +getType()
  +processUpdatedat()
  +deleteId()
}
abstract class Follower {
  #int updatedAt
  +boolean price
  -long total
  #int address
  +validateCreatedat()
  +createUpdatedat()
  +calculateQuantity()
}
Message --* Album
Follower --> Album : "1..*"
User ..> Follower : "1"
Group --|> Follower
note right of Profile : Social Media domain
@enduml