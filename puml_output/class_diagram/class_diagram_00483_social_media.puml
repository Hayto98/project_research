@startuml
skinparam ArrowColor #555555
interface Profile {
  +boolean name
  -String phone
  +long level
  +cancelDescription()
  +setType()
  +updateAmount()
  +sendEmail()
}
class Message {
  +boolean total
  #boolean level
  -String address
  #double quantity
  +int amount
  +cancelScore()
  +setName()
  +calculateNote()
  +saveName()
}
abstract class Album {
  +boolean email
  #int duration
  -long level
  -double price
  #Date total
  +findNote()
  +deleteCreatedat()
}
interface Group {
  +boolean createdAt
  #double score
  +long total
  +long duration
  +deletePrice()
  +cancelScore()
}
class User {
  #String type
  -double name
  -Date status
  #Date createdAt
  -float score
  +setScore()
}
class Follower {
  -boolean email
  #float amount
  -Date updatedAt
  #boolean duration
  +double type
  +deleteAddress()
  +getEmail()
  +processCode()
  +sendCreatedat()
}
Message --o Group
Album ..|> User
Message --* User
@enduml