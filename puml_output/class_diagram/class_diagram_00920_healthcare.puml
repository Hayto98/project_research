@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
abstract class Patient {
  +boolean active
  #float score
  +saveAmount()
  +updateDescription()
}
abstract class Nurse {
  +String amount
  #String price
  +int duration
  -int score
  -long type
  +calculateUpdatedat()
  +processPhone()
  +createNote()
  +validateLevel()
}
class Hospital {
  +Date price
  #boolean createdAt
  #boolean type
  +Date active
  +deleteType()
}
class Insurance {
  +double total
  -String price
  -double address
  +boolean duration
  +int active
  +processUpdatedat()
}
abstract class Billing {
  #Date total
  +String amount
  +double phone
  -double createdAt
  +processPhone()
}
class Treatment {
  +Date phone
  #Date active
  -String status
  +long quantity
  #double address
  +setAmount()
  +findName()
  +cancelCreatedat()
  +validateNote()
}
Patient --> Billing : "0..1"
Insurance ..> Billing : "1"
Patient --* Hospital
Hospital ..> Patient : "1..*"
@enduml