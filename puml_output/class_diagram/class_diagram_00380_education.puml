@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
interface Assignment {
  -Date updatedAt
  +float name
  +boolean id
  +updateAmount()
  +cancelUpdatedat()
  +sendDescription()
}
class Library {
  -int phone
  +boolean email
  #long level
  #boolean code
  #Date quantity
  +calculateNote()
  +saveStatus()
  +saveDuration()
  +sendPhone()
}
interface Enrollment {
  #double name
  #Date score
  #Date level
  +deleteEmail()
  +getPhone()
}
class Classroom {
  +long note
  +int email
  -boolean amount
  -boolean description
  +createLevel()
}
Library --> Classroom : "1..*"
Enrollment --* Library
@enduml