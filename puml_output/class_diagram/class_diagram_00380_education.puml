@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
interface Assignment {
  -Date updatedAt
  +float name
  +boolean id
  +findAddress()
  +cancelLevel()
  +calculatePhone()
}
class Library {
  +boolean code
  #long quantity
  #boolean price
  #Date createdAt
  +updateLevel()
  +validateScore()
  +cancelUpdatedat()
  +getScore()
}
interface Enrollment {
  -boolean duration
  -int createdAt
  #int total
  +long name
  +int phone
  +sendAddress()
  +sendLevel()
  +getPhone()
  +findDescription()
}
abstract class Classroom {
  -int description
  +double total
  -float email
  #boolean address
  +findCreatedat()
  +saveAmount()
  +setEmail()
  +deletePrice()
}
Assignment --> Classroom : "*"
Library ..> Assignment : "*"
Assignment --o Library
note right of Assignment : Education domain
@enduml