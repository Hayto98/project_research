@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Loan {
  +int amount
  -double type
  -boolean code
  +Date level
  +setDescription()
  +validateNote()
  +cancelUpdatedat()
  +updateLevel()
}
class Statement {
  -Date score
  +int type
  #long email
  +saveAmount()
  +saveActive()
  +calculateEmail()
  +processEmail()
}
class Account {
  -int active
  -String price
  -boolean phone
  +cancelAddress()
  +deleteLevel()
}
class Beneficiary {
  +boolean note
  #long updatedAt
  #boolean id
  -long email
  +updateEmail()
  +findType()
}
class Customer {
  -long total
  -String description
  #boolean updatedAt
  +Date type
  +processDescription()
  +setPhone()
  +findCreatedat()
  +validateDuration()
}
class Card {
  #Date id
  -boolean description
  #int address
  #float updatedAt
  +processName()
  +validateAmount()
}
Card --o Statement
Loan --* Beneficiary
Account ..> Beneficiary : "*"
Account ..> Customer : "1..*"
Beneficiary ..|> Statement
@enduml