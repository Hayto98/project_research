@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Loan {
  +int amount
  -double type
  -boolean code
  +Date level
  +setUpdatedat()
  +findQuantity()
  +getActive()
  +updateScore()
}
abstract class Statement {
  #double price
  -boolean code
  +double amount
  #String email
  +sendPrice()
  +validateAddress()
}
class Account {
  +Date status
  #float price
  #long score
  -int updatedAt
  +long quantity
  +sendEmail()
}
interface Beneficiary {
  -double email
  #int createdAt
  +float total
  -double level
  +processStatus()
  +findScore()
  +updateScore()
}
abstract class Customer {
  #boolean duration
  #float email
  -String address
  +float name
  +updatePhone()
  +sendCreatedat()
  +cancelAmount()
}
class Card {
  +double active
  -long type
  -Date amount
  #double note
  +cancelAddress()
  +calculateDescription()
  +updateNote()
}
Card --o Beneficiary
Loan --|> Statement
note right of Loan : Banking domain
@enduml