@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Branch {
  +String createdAt
  +int price
  +float phone
  +saveName()
  +validateEmail()
  +createScore()
  +deleteType()
}
class Author {
  -float phone
  +Date level
  #String email
  #double name
  +createCode()
  +sendDuration()
}
class Catalog {
  -String address
  -float duration
  +long amount
  -int email
  #String updatedAt
  +updateAmount()
  +deleteDuration()
  +updateDuration()
}
class Librarian {
  #long email
  +boolean description
  +int address
  -boolean code
  #String duration
  +calculateId()
  +processTotal()
  +cancelUpdatedat()
}
interface Renewal {
  #float description
  +long address
  +float email
  +boolean note
  +boolean status
  +findActive()
}
class Shelf {
  -boolean type
  #boolean quantity
  +float price
  -String level
  +deletePhone()
  +cancelAddress()
  +validateScore()
  +findName()
}
Librarian --|> Branch
Renewal --o Librarian
Catalog ..> Author : "0..1"
Shelf ..> Author : "*"
Librarian ..|> Author
note right of Branch : Library domain
@enduml