@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Branch {
  +String createdAt
  +int price
  +float phone
  +calculateUpdatedat()
  +saveId()
  +calculateCreatedat()
  +cancelPhone()
}
class Author {
  -boolean type
  -String code
  -float email
  +sendPrice()
}
interface Catalog {
  +long level
  +boolean price
  +calculateDuration()
  +getPhone()
}
class Librarian {
  +long amount
  +long email
  -int updatedAt
  #String total
  +calculateNote()
  +createCode()
  +saveAddress()
}
interface Renewal {
  -int duration
  -String amount
  -boolean price
  +processQuantity()
  +createDescription()
  +calculateAddress()
}
class Shelf {
  -Date active
  -boolean code
  +Date email
  #boolean price
  -int id
  +processAddress()
  +sendAddress()
  +calculateType()
}
Branch --|> Renewal
Catalog --|> Branch
Renewal --> Branch : "1"
Shelf --|> Renewal
Catalog --* Librarian
@enduml