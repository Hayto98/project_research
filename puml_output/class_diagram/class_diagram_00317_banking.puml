@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Interest {
  #double status
  #Date level
  #float duration
  +sendId()
  +getTotal()
  +processCreatedat()
  +calculateName()
}
class Transaction {
  #boolean type
  #float active
  #long address
  +String price
  +setStatus()
  +getDuration()
  +deleteLevel()
  +calculateCode()
}
interface Beneficiary {
  -Date id
  +boolean price
  +long code
  #double active
  +Date amount
  +validateName()
  +sendType()
}
class Card {
  -boolean phone
  -int createdAt
  #Date total
  -int duration
  +boolean amount
  +setPhone()
  +processTotal()
}
abstract class Statement {
  #long note
  +long name
  +Date duration
  #boolean type
  -double code
  +saveCreatedat()
  +cancelPhone()
}
class Withdrawal {
  +long updatedAt
  -int total
  -int level
  #float phone
  +calculateCreatedat()
  +calculateName()
}
class Transfer {
  +Date createdAt
  #String active
  -String description
  +deleteType()
  +deleteStatus()
  +processName()
  +findQuantity()
}
Withdrawal --o Statement
Beneficiary --|> Interest
Card --o Statement
Transfer --* Transaction
note right of Interest : Banking domain
@enduml