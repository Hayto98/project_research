@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Interest {
  #double status
  #Date level
  #float duration
  +setActive()
  +cancelAmount()
  +cancelTotal()
  +deleteNote()
}
abstract class Transaction {
  -boolean createdAt
  -double total
  #boolean name
  #float updatedAt
  #long email
  +cancelStatus()
}
abstract class Beneficiary {
  #boolean status
  +float id
  +setDescription()
  +findDuration()
  +createName()
  +cancelTotal()
}
abstract class Card {
  #int active
  -Date duration
  +cancelActive()
}
class Statement {
  -String duration
  #double type
  +double name
  -int description
  +setQuantity()
  +createAmount()
  +validateLevel()
  +updateCreatedat()
}
class Withdrawal {
  +int level
  #Date email
  +String updatedAt
  #long phone
  +validatePrice()
  +updateScore()
  +processLevel()
  +deleteDuration()
}
abstract class Transfer {
  +long name
  +Date note
  #boolean type
  -double code
  #int email
  +findDescription()
  +setCode()
}
Withdrawal --* Transfer
Statement ..|> Beneficiary
Card --* Transfer
Interest --o Beneficiary
@enduml