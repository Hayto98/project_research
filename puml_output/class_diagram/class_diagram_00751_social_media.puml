@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
abstract class Hashtag {
  -Date level
  #float type
  +saveLevel()
  +setName()
}
class Notification {
  -double address
  +int name
  -String note
  #long type
  #int code
  +validateAddress()
  +updateCreatedat()
  +validateUpdatedat()
  +findActive()
}
class Story {
  #boolean name
  #long active
  +int amount
  #float phone
  +String level
  +sendDuration()
  +calculateDescription()
  +findDuration()
  +getQuantity()
}
interface Comment {
  -double note
  +long description
  #int quantity
  -String email
  -Date level
  +validateCode()
  +cancelCreatedat()
  +getUpdatedat()
  +validateAmount()
}
abstract class Message {
  -long address
  #String id
  -String total
  #long amount
  +sendId()
}
abstract class Album {
  -double status
  #boolean phone
  -int createdAt
  +updateScore()
  +validateScore()
  +sendAddress()
}
class Follower {
  #float phone
  #Date id
  -long amount
  +int quantity
  +long description
  +updateNote()
  +processDescription()
}
Album ..> Notification : "*"
Story --> Follower : "*"
Comment ..> Story : "0..1"
@enduml