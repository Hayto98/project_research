@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
abstract class Hashtag {
  -Date level
  #float type
  +getPhone()
  +processAddress()
}
class Notification {
  +int type
  -String level
  #long code
  #int total
  -long active
  +processPhone()
  +sendPrice()
  +getActive()
  +deleteDuration()
}
class Story {
  #float score
  +String email
  -Date updatedAt
  #boolean description
  +processDescription()
  +createEmail()
  +sendDescription()
  +processTotal()
}
class Comment {
  #float description
  -int type
  -float status
  -float price
  +validateAddress()
  +getLevel()
  +cancelTotal()
  +deleteTotal()
}
class Message {
  #long total
  #String name
  +calculateDuration()
  +deleteStatus()
}
class Album {
  +long quantity
  #long total
  -long duration
  +validateId()
  +deleteLevel()
  +createDescription()
  +sendScore()
}
class Follower {
  #int status
  #long amount
  +Date level
  +Date email
  +createQuantity()
  +sendPrice()
  +processAddress()
  +findAmount()
}
Hashtag --o Comment
Notification --> Comment : "0..1"
Hashtag ..|> Follower
note right of Hashtag : Social Media domain
@enduml