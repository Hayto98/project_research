@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Transaction {
  +double createdAt
  +float code
  +createName()
}
class Card {
  -int id
  #long code
  -double createdAt
  #boolean note
  +deletePhone()
}
abstract class Account {
  -Date code
  -long createdAt
  -double level
  -long id
  -float note
  +saveType()
}
class Loan {
  -Date level
  -int name
  -String duration
  +String active
  #boolean note
  +updateTotal()
  +setTotal()
  +getActive()
}
abstract class Customer {
  +boolean email
  -double duration
  -Date phone
  +calculateEmail()
}
class Withdrawal {
  +long status
  #Date duration
  +calculateQuantity()
  +setCreatedat()
  +updateTotal()
  +validateId()
}
class Transfer {
  +float name
  -long price
  +String type
  +saveLevel()
  +calculateNote()
}
Withdrawal --o Account
Account --* Transfer
Loan --* Withdrawal
note right of Transaction : Banking domain
@enduml