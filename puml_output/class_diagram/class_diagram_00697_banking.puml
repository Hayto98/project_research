@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Transaction {
  +double createdAt
  +float code
  +updateLevel()
}
class Card {
  +int address
  #double id
  +deleteScore()
  +calculateType()
  +processPhone()
}
class Account {
  +long note
  -boolean score
  -String active
  #int id
  +sendActive()
  +createTotal()
}
class Loan {
  -long type
  -float address
  +Date phone
  #double total
  +double active
  +setPhone()
}
class Customer {
  +String quantity
  #boolean type
  #long createdAt
  +double level
  +double name
  +createUpdatedat()
}
abstract class Withdrawal {
  +boolean email
  -double duration
  -Date phone
  +getPhone()
}
class Transfer {
  -Date name
  #double status
  -float level
  -String createdAt
  +createScore()
  +setNote()
}
Transaction --|> Withdrawal
Customer --|> Card
Loan ..|> Transfer
Transfer --* Account
@enduml