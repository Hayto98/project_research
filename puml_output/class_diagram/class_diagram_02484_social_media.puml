@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Story {
  #int type
  -double status
  -long updatedAt
  +int description
  +sendPrice()
  +setType()
  +saveUpdatedat()
  +validateTotal()
}
abstract class Message {
  #boolean active
  +int address
  #int score
  +String total
  +createScore()
  +findScore()
}
abstract class Hashtag {
  #int price
  -double description
  +saveDescription()
  +savePrice()
  +updateAmount()
  +getType()
}
class Album {
  #Date name
  +double level
  #boolean createdAt
  +Date updatedAt
  +deleteAddress()
  +findType()
  +calculateQuantity()
}
interface Notification {
  #String createdAt
  -Date address
  -float active
  -double status
  +updateId()
  +createEmail()
  +cancelUpdatedat()
  +findQuantity()
}
class Like {
  #float id
  +float code
  +findEmail()
}
Like --> Hashtag : "1..*"
Notification ..|> Hashtag
Album --* Hashtag
Hashtag --o Notification
@enduml