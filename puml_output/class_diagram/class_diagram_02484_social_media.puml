@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Story {
  #int type
  -double status
  -long updatedAt
  +int description
  +saveDescription()
  +saveTotal()
  +validateActive()
  +validateScore()
}
abstract class Message {
  +String updatedAt
  +int createdAt
  +processStatus()
  +calculateDescription()
  +findCreatedat()
}
class Hashtag {
  #float type
  +boolean level
  +int code
  #Date quantity
  +double email
  +findPhone()
}
class Album {
  #float level
  +boolean score
  +double address
  #long createdAt
  -double duration
  +findAddress()
  +findCode()
  +setId()
  +setId()
}
class Notification {
  -long address
  -boolean duration
  -Date level
  -long updatedAt
  #String total
  +deleteActive()
  +findCreatedat()
  +processId()
  +processPrice()
}
abstract class Like {
  -float type
  +int duration
  #boolean level
  +updateNote()
}
Like --> Hashtag : "1..*"
Message --o Hashtag
Hashtag --o Notification
note right of Story : Social Media domain
@enduml