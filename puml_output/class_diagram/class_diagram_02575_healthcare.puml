@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Hospital {
  #double note
  #double phone
  +processPrice()
  +savePrice()
  +validateTotal()
}
class Ward {
  #int score
  +boolean price
  #float amount
  -long level
  +getId()
  +validateActive()
  +validateDescription()
}
class Insurance {
  -String address
  #boolean status
  +sendTotal()
  +validateCreatedat()
  +createNote()
}
interface LabTest {
  +long quantity
  +long updatedAt
  #String score
  +long note
  #float level
  +updateLevel()
  +findActive()
  +updateId()
  +findCreatedat()
}
abstract class Doctor {
  #long name
  #boolean type
  +saveCreatedat()
  +updatePhone()
  +processDescription()
  +setEmail()
}
class Diagnosis {
  +Date name
  #String code
  +double duration
  -double active
  +validatePrice()
  +processType()
}
Doctor --o Hospital
LabTest --|> Diagnosis
Diagnosis ..|> Hospital
Ward --|> Doctor
note right of Hospital : Healthcare domain
@enduml