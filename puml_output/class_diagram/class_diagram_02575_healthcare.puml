@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Hospital {
  #double note
  #double phone
  +cancelQuantity()
  +findStatus()
  +updateAmount()
}
abstract class Ward {
  #float address
  -Date total
  +double status
  #int active
  +boolean quantity
  +validateScore()
  +saveCreatedat()
  +calculateId()
  +updateDuration()
}
class Insurance {
  -String description
  -String duration
  #boolean score
  #boolean status
  +createStatus()
  +cancelCreatedat()
  +saveScore()
}
class LabTest {
  +boolean note
  #double score
  +int price
  -String quantity
  +deleteUpdatedat()
  +getLevel()
  +processUpdatedat()
}
class Doctor {
  #int createdAt
  -String level
  +double active
  #long updatedAt
  #boolean id
  +createType()
  +updateCode()
  +cancelNote()
  +sendId()
}
class Diagnosis {
  +String description
  +float status
  #String email
  #float duration
  #String score
  +getId()
}
LabTest --* Ward
LabTest --o Diagnosis
LabTest --|> Doctor
@enduml