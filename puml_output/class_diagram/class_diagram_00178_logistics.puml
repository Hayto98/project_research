@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Package {
  -long price
  #boolean email
  +sendUpdatedat()
  +processLevel()
}
class Customer {
  +double price
  #double note
  #boolean level
  -long status
  +boolean duration
  +calculateLevel()
  +saveAddress()
  +setQuantity()
  +calculateType()
}
interface Inventory {
  -double description
  #float name
  -float updatedAt
  +String total
  #float amount
  +createCreatedat()
  +setName()
  +saveScore()
  +getNote()
}
class Warehouse {
  +int amount
  #float active
  #float type
  -Date address
  +setDuration()
}
interface FuelLog {
  #Date quantity
  -float updatedAt
  +validateScore()
  +processDescription()
}
class Shipment {
  -long quantity
  +long active
  +Date code
  +getScore()
  +processEmail()
  +saveAmount()
  +validateName()
}
Package --> Inventory : "1..*"
Warehouse --> Inventory : "0..1"
Warehouse --* Package
FuelLog ..|> Shipment
@enduml