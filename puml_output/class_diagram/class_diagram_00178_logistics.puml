@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Package {
  -long price
  #boolean email
  +findTotal()
  +updatePrice()
}
abstract class Customer {
  #double note
  #boolean status
  -long price
  +boolean createdAt
  -float total
  +sendType()
  +deleteName()
}
class Inventory {
  +String amount
  #float note
  #float total
  -int active
  +long score
  +getLevel()
  +cancelEmail()
  +deleteActive()
}
abstract class Warehouse {
  #String createdAt
  #String description
  -int score
  #Date address
  +updateAddress()
  +createCreatedat()
  +updateQuantity()
  +sendCode()
}
abstract class FuelLog {
  #boolean code
  -double address
  #float description
  -String type
  +cancelAddress()
  +processPhone()
  +cancelDescription()
}
abstract class Shipment {
  +long email
  #long level
  +processPhone()
  +setActive()
  +updateCode()
  +processName()
}
Inventory --o Customer
Inventory --> Warehouse : "0..1"
Inventory --o Package
Package --|> Inventory
Warehouse ..|> FuelLog
note right of Package : Logistics domain
@enduml