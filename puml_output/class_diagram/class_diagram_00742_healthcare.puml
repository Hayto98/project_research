@startuml
skinparam ArrowColor #555555
class Appointment {
  #String status
  +float updatedAt
  +float total
  +processLevel()
  +validateCreatedat()
  +saveDescription()
}
class Insurance {
  +double updatedAt
  #float name
  +processCode()
  +getType()
  +calculateAddress()
}
class Treatment {
  -long type
  -Date amount
  #float total
  -Date address
  +Date quantity
  +createCreatedat()
  +saveStatus()
  +createAddress()
  +deleteEmail()
}
class Hospital {
  -double amount
  +long active
  #boolean createdAt
  #float email
  +long status
  +findId()
}
interface LabTest {
  #float status
  #long description
  #float level
  -boolean note
  +double createdAt
  +validateTotal()
  +updateCode()
  +getTotal()
  +calculateEmail()
}
Treatment --o Insurance
Appointment ..> Treatment : "1..*"
Appointment ..|> Insurance
Hospital --* Insurance
@enduml