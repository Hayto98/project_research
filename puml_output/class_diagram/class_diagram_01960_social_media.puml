@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
abstract class Profile {
  +int price
  +float email
  +String type
  +deletePrice()
  +calculateAddress()
}
class Post {
  -int score
  +String description
  +boolean createdAt
  +processQuantity()
  +processPrice()
}
class Group {
  -String description
  -boolean quantity
  -double note
  -boolean status
  +setCode()
  +deleteId()
  +saveTotal()
}
abstract class Comment {
  +Date total
  #int level
  +Date score
  -float id
  +getStatus()
  +setAmount()
}
class Like {
  #String type
  -long price
  +sendAddress()
}
class Album {
  +String description
  #Date email
  #double name
  -String active
  -String note
  +updateName()
  +saveName()
  +deletePhone()
  +createName()
}
Group --|> Profile
Profile --> Post : "1"
@enduml