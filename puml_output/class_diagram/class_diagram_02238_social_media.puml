@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
abstract class Post {
  #double name
  +Date email
  +deleteAmount()
}
class Follower {
  #double level
  +String updatedAt
  +validateCode()
  +setStatus()
  +findAmount()
}
class Profile {
  #Date note
  +String status
  +sendEmail()
  +cancelEmail()
}
abstract class Comment {
  -long active
  #Date createdAt
  -boolean type
  +sendPrice()
  +processPrice()
}
class Message {
  #double type
  #int duration
  -long phone
  -float updatedAt
  +createCode()
}
class Story {
  +Date active
  -Date note
  +saveLevel()
  +createPrice()
}
class Album {
  #Date level
  -int quantity
  +cancelPhone()
}
Follower --> Story : "1"
Message --|> Post
Follower --* Comment
Post ..|> Follower
Story --o Album
Story --o Message
@enduml