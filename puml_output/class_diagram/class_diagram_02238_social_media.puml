@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
abstract class Post {
  #double name
  +Date email
  +calculateName()
}
interface Follower {
  #double level
  +String updatedAt
  +deleteStatus()
  +calculateDescription()
  +setNote()
}
class Profile {
  +double id
  +boolean description
  +double createdAt
  +validateLevel()
  +saveTotal()
  +cancelDescription()
  +saveUpdatedat()
}
class Comment {
  #double type
  #int duration
  -long phone
  -float updatedAt
  +deleteName()
}
class Message {
  #String amount
  #Date quantity
  #long updatedAt
  #Date price
  -int status
  +createActive()
}
class Story {
  +int score
  -long name
  +updateCreatedat()
}
abstract class Album {
  #String note
  +Date phone
  #Date level
  +boolean address
  #boolean email
  +sendStatus()
  +createLevel()
}
Follower ..> Message : "0..1"
Follower --> Profile : "1..*"
Profile ..> Message : "0..1"
note right of Post : Social Media domain
@enduml