@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Customer {
  +float description
  -String quantity
  +boolean email
  +validatePrice()
  +cancelAddress()
  +setStatus()
  +saveTotal()
}
interface DeliveryNote {
  -String address
  -String note
  #int description
  +boolean amount
  #String id
  +processActive()
}
interface Warehouse {
  -String level
  #String updatedAt
  +cancelPrice()
}
interface Package {
  #long duration
  #double quantity
  #int code
  +getDuration()
  +cancelActive()
}
Warehouse --> Package : "*"
Customer --* Warehouse
@enduml