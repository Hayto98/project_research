@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Cart {
  +int duration
  +double price
  #String createdAt
  +sendName()
}
class Invoice {
  +String price
  #double id
  +cancelName()
  +cancelDescription()
  +getDescription()
}
interface Product {
  #Date phone
  -String name
  +deleteActive()
}
class Return {
  -int phone
  #String createdAt
  #float name
  +int updatedAt
  +deleteStatus()
  +calculateDescription()
}
abstract class Review {
  +long total
  #Date description
  #String price
  +updateCode()
}
abstract class Order {
  +boolean quantity
  +double email
  +cancelScore()
  +deleteName()
  +createTotal()
}
interface Customer {
  +boolean address
  #double active
  #boolean score
  +processName()
}
Customer ..> Review : "0..1"
Cart --|> Review
Invoice --o Customer
@enduml