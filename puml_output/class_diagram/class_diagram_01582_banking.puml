@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
abstract class Transfer {
  +float amount
  -float description
  -double type
  #Date total
  +cancelPrice()
  +deleteTotal()
  +setUpdatedat()
  +findPrice()
}
class Customer {
  +long quantity
  #String createdAt
  -String note
  +createAddress()
}
class Transaction {
  #Date note
  #float name
  +Date status
  #float updatedAt
  +sendEmail()
  +setName()
  +cancelPrice()
  +validatePrice()
}
class Statement {
  -int phone
  #Date level
  #String email
  #int createdAt
  +deleteLevel()
  +findId()
  +createUpdatedat()
}
class Deposit {
  +int note
  +Date description
  +deleteAddress()
  +cancelNote()
  +deleteLevel()
}
interface Card {
  #float note
  #Date email
  #long status
  +sendAmount()
}
Customer --* Card
Statement ..|> Customer
Deposit --> Statement : "0..1"
Statement --* Card
Transaction ..|> Customer
@enduml