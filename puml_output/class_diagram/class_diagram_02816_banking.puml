@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Card {
  -double status
  #double total
  #long score
  +findCreatedat()
  +calculateId()
  +sendEmail()
}
class Transaction {
  #boolean updatedAt
  -String level
  +String phone
  #float type
  +findNote()
}
class Interest {
  -double name
  #String code
  -long amount
  -float phone
  +sendName()
  +updateType()
  +createEmail()
}
abstract class Transfer {
  +int updatedAt
  +String note
  +validateEmail()
}
class Loan {
  #Date name
  #float note
  -float phone
  #long type
  -boolean status
  +createDescription()
  +findScore()
  +validatePrice()
  +findStatus()
}
Card --> Loan : "1..*"
Card --* Interest
Transaction --|> Loan
@enduml