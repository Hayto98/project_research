@startuml
skinparam monochrome true
skinparam defaultFontSize 13
interface Post {
  -int duration
  -int score
  +long type
  +deletePhone()
  +createNote()
  +setCreatedat()
}
abstract class Report {
  #double name
  -float note
  +long id
  +cancelActive()
}
class Group {
  #double address
  #String type
  +long score
  #Date active
  +float email
  +createPhone()
  +processNote()
  +sendEmail()
}
class Comment {
  +float code
  -String status
  #String note
  +String price
  +processAmount()
  +findName()
  +sendName()
}
abstract class Message {
  +int email
  +boolean code
  #String type
  #double name
  +getScore()
  +createId()
  +sendTotal()
  +processNote()
}
abstract class Notification {
  -Date quantity
  #Date amount
  +updateActive()
}
Report ..|> Post
Message --> Post : "0..1"
note right of Post : Social Media domain
@enduml