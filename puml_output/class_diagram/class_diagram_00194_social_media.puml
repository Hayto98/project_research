@startuml
skinparam monochrome true
skinparam defaultFontSize 13
interface Post {
  -int duration
  -int score
  +long type
  +findId()
  +updateAmount()
  +processStatus()
}
class Report {
  #double status
  +float createdAt
  #double note
  -float level
  +long name
  +sendActive()
}
interface Group {
  #boolean total
  #Date address
  -boolean type
  +getCreatedat()
  +createPhone()
  +createCode()
  +deleteCode()
}
class Comment {
  #long email
  -boolean phone
  -String type
  +double note
  +sendTotal()
  +getName()
  +findLevel()
  +sendScore()
}
class Message {
  -double updatedAt
  +Date id
  +getScore()
}
class Notification {
  +int address
  +boolean email
  #String code
  #double type
  -String name
  +updatePrice()
  +validateStatus()
  +processPhone()
}
Comment --o Notification
Notification --* Post
Report ..> Comment : "1"
Report --> Message : "1"
Report ..|> Post
@enduml