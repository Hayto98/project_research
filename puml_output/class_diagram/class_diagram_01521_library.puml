@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Librarian {
  +float note
  #int score
  +validateAmount()
  +findUpdatedat()
  +saveId()
}
class Book {
  -double level
  +long phone
  +boolean address
  -String updatedAt
  +boolean createdAt
  +validateActive()
}
interface Reservation {
  +boolean code
  -Date email
  +cancelName()
  +validateQuantity()
}
abstract class Catalog {
  +double email
  -double updatedAt
  +processStatus()
  +getDuration()
}
Book --> Librarian : "*"
Catalog ..> Book : "1..*"
Catalog --o Librarian
note right of Librarian : Library domain
@enduml