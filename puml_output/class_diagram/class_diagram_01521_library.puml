@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Librarian {
  +float note
  #int score
  +validateType()
  +validateDuration()
  +findId()
}
class Book {
  #float email
  -long price
  +sendId()
  +saveLevel()
}
abstract class Reservation {
  +boolean status
  #String phone
  -boolean name
  #String level
  +long score
  +calculatePrice()
}
class Catalog {
  -float duration
  -String name
  -float address
  +createId()
  +updateStatus()
}
Reservation ..> Book : "0..1"
Catalog --|> Librarian
Reservation --|> Librarian
@enduml