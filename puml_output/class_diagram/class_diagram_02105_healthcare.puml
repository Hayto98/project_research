@startuml
skinparam defaultFontSize 13
class MedicalRecord {
  -String email
  #Date total
  -int note
  +updateNote()
  +sendStatus()
}
class Doctor {
  +double active
  #Date email
  +updateDescription()
  +processPrice()
}
class Insurance {
  -long active
  #int price
  -boolean id
  -long phone
  +getDuration()
}
class LabTest {
  #int quantity
  #Date phone
  +double level
  -double email
  +getCode()
  +calculateQuantity()
}
class Ward {
  #Date score
  -float createdAt
  +String description
  -Date code
  +cancelQuantity()
  +setCode()
}
Ward --> Doctor : "1"
Insurance ..|> Ward
Doctor ..|> Insurance
@enduml