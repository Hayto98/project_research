@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Payment {
  +long description
  +float status
  -float price
  +updateScore()
  +getCreatedat()
  +findQuantity()
  +validateType()
}
interface Cart {
  +String description
  -int updatedAt
  +updateScore()
}
interface Invoice {
  #String price
  +String name
  +int updatedAt
  +String note
  -float description
  +getPhone()
  +createPhone()
  +saveDuration()
  +updateUpdatedat()
}
interface Product {
  #int duration
  +boolean note
  +findQuantity()
  +getEmail()
  +validateEmail()
}
class Supplier {
  #int note
  +int price
  +saveCode()
  +saveType()
  +createType()
  +sendUpdatedat()
}
interface Order {
  -String duration
  -boolean name
  -float level
  -String score
  +getDuration()
  +saveLevel()
  +createDuration()
}
Cart ..|> Supplier
Order ..|> Supplier
Cart --|> Payment
Product --o Invoice
note right of Payment : Ecommerce domain
@enduml