@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Comment {
  #double score
  -boolean type
  +Date status
  -int price
  +getQuantity()
  +validateEmail()
  +setAddress()
  +deleteLevel()
}
class Group {
  -boolean status
  -long level
  #long quantity
  -double type
  +sendAddress()
  +updatePrice()
}
interface Album {
  #double address
  -long type
  +boolean name
  +createTotal()
}
class Message {
  +boolean phone
  #boolean active
  +deleteName()
}
class Like {
  +float createdAt
  #String name
  #Date score
  #float updatedAt
  +sendCode()
  +updatePrice()
  +sendStatus()
  +findEmail()
}
interface Profile {
  -float level
  #float updatedAt
  +float price
  +getAddress()
  +cancelAddress()
  +createName()
  +deleteStatus()
}
Like ..|> Comment
Profile --> Album : "1..*"
Comment --> Album : "*"
note right of Comment : Social Media domain
@enduml