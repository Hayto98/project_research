@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Comment {
  #double score
  -boolean type
  +Date status
  -int price
  +setName()
  +getDuration()
  +processDescription()
  +createEmail()
}
class Group {
  -float status
  +boolean address
  -double description
  -boolean updatedAt
  +setTotal()
  +saveActive()
  +calculateCreatedat()
}
abstract class Album {
  #int amount
  #long score
  #float address
  -String createdAt
  #double price
  +findCode()
  +processPrice()
  +saveActive()
}
class Message {
  #String total
  #boolean name
  #Date level
  #float phone
  +validateQuantity()
}
class Like {
  #String quantity
  #boolean createdAt
  +cancelNote()
  +getUpdatedat()
}
class Profile {
  #long score
  #int code
  #int updatedAt
  -long price
  #float status
  +deleteTotal()
  +calculateAmount()
}
Album --* Like
Album ..|> Comment
@enduml