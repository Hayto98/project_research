@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Profile {
  -boolean amount
  -double quantity
  #boolean updatedAt
  +validateLevel()
  +deleteScore()
}
class Story {
  -int amount
  #float status
  +String description
  +validateAddress()
  +cancelTotal()
  +setEmail()
  +updateQuantity()
}
class Post {
  -Date total
  #boolean phone
  -boolean type
  -int active
  +createPrice()
}
abstract class User {
  +String id
  +long code
  +String active
  +long amount
  +getCreatedat()
  +sendDuration()
  +validateName()
}
class Group {
  #float quantity
  +String description
  -long type
  +String active
  -String duration
  +saveStatus()
  +sendId()
}
User --o Story
Post ..|> Story
note right of Profile : Social Media domain
@enduml