@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Profile {
  -boolean amount
  -double quantity
  #boolean updatedAt
  +processStatus()
  +savePrice()
}
class Story {
  +long updatedAt
  +float amount
  #float status
  +savePhone()
}
abstract class Post {
  +long address
  #int total
  #long code
  -boolean email
  +sendCreatedat()
  +createDescription()
  +cancelQuantity()
}
interface User {
  -float level
  -Date address
  #boolean description
  #Date code
  -Date email
  +sendType()
}
class Group {
  -int status
  +float id
  +long name
  +updatePrice()
  +calculateTotal()
  +sendEmail()
}
Group --|> Post
Story --* User
@enduml