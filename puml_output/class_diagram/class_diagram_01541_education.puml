@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
abstract class Attendance {
  -Date createdAt
  +long name
  +setEmail()
}
class Course {
  +Date updatedAt
  +Date code
  #long status
  #String price
  +long quantity
  +updateQuantity()
  +getCreatedat()
  +cancelNote()
}
interface Book {
  +long name
  -int code
  -double type
  +boolean note
  #String amount
  +createUpdatedat()
}
abstract class Schedule {
  #long phone
  #String score
  #long quantity
  #float description
  +long status
  +updateLevel()
  +findStatus()
  +calculateQuantity()
  +findNote()
}
class Teacher {
  #int active
  #double id
  #Date quantity
  +validateLevel()
  +validatePhone()
}
interface Student {
  +double active
  #String description
  #int address
  +deleteId()
  +deleteDescription()
  +setPrice()
  +createLevel()
}
Attendance --|> Schedule
Book --|> Course
@enduml