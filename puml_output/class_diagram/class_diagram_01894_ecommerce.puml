@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
abstract class Customer {
  -Date code
  +int address
  #int duration
  +updateTotal()
  +calculateScore()
  +setNote()
}
abstract class Return {
  +float score
  -float description
  #boolean total
  #int status
  +getCode()
}
abstract class Product {
  -double phone
  +float quantity
  -double note
  -boolean id
  #float amount
  +sendQuantity()
}
class Review {
  #String code
  +String duration
  #boolean total
  #float amount
  -double email
  +sendStatus()
  +validateQuantity()
  +saveDescription()
}
class Wishlist {
  #int createdAt
  +String level
  +Date duration
  +validateEmail()
}
class Category {
  +long address
  #String name
  +Date phone
  +saveId()
  +getLevel()
}
interface Payment {
  #String code
  -String type
  +String total
  -Date price
  #Date quantity
  +calculateType()
  +findPrice()
  +validateAddress()
  +updateScore()
}
Review --> Payment : "0..1"
Review --* Wishlist
@enduml