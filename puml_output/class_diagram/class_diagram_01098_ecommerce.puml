@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
abstract class Return {
  -boolean quantity
  +double updatedAt
  -double id
  +setName()
}
class Payment {
  +double quantity
  +Date status
  -boolean updatedAt
  -Date total
  +calculateDuration()
  +validateDuration()
  +cancelScore()
}
interface Review {
  +float id
  -int duration
  +int email
  +float updatedAt
  +processScore()
  +saveScore()
}
class Coupon {
  -long updatedAt
  -int description
  -String quantity
  +saveType()
  +saveCode()
  +calculateCode()
}
abstract class Order {
  #Date email
  +float status
  #int score
  +createAmount()
  +sendStatus()
}
class Invoice {
  -boolean id
  -String duration
  -String note
  +deleteName()
}
class Shipment {
  -int total
  #Date quantity
  -double phone
  #Date type
  +findCreatedat()
  +updatePrice()
  +processName()
  +setActive()
}
Review ..> Return : "0..1"
Order --> Invoice : "0..1"
Return --o Review
@enduml