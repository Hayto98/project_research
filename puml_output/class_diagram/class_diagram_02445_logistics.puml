@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
interface DeliveryNote {
  +boolean code
  -long score
  +boolean total
  -int id
  #double name
  +processDescription()
  +updateDescription()
  +cancelDuration()
  +saveQuantity()
}
abstract class Route {
  +String price
  +int description
  +processAmount()
  +processId()
  +validateQuantity()
}
interface Manifest {
  #String id
  #int code
  #boolean address
  +saveNote()
  +calculateNote()
  +calculateDescription()
}
interface FuelLog {
  +Date name
  #float address
  #boolean duration
  +createEmail()
  +sendUpdatedat()
  +createName()
}
DeliveryNote ..> FuelLog : "*"
Route ..> FuelLog : "0..1"
@enduml