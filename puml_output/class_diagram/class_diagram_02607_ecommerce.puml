@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Coupon {
  +double code
  #long active
  +createType()
  +saveQuantity()
}
class Order {
  #float score
  #long name
  -double address
  -boolean active
  +updateAddress()
  +setEmail()
  +validateQuantity()
  +sendId()
}
class Payment {
  #int level
  +boolean email
  +String phone
  +saveDescription()
  +updateQuantity()
}
class Warehouse {
  -long note
  #long duration
  -long phone
  #long name
  -int amount
  +findScore()
  +setDescription()
  +findTotal()
}
class Product {
  #int price
  #Date quantity
  #boolean phone
  +findEmail()
}
class Shipment {
  +Date quantity
  #double status
  +processDescription()
  +calculatePrice()
  +sendCreatedat()
  +updateCode()
}
Order --o Shipment
Payment --|> Coupon
note right of Coupon : Ecommerce domain
@enduml