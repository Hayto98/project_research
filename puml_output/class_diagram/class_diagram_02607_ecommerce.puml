@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Coupon {
  +double code
  #long active
  +updateLevel()
  +validateUpdatedat()
}
class Order {
  #boolean quantity
  #float score
  #long name
  -double address
  +validateActive()
  +findAmount()
  +validateNote()
}
class Payment {
  -boolean email
  +String phone
  +findName()
  +validateAmount()
}
class Warehouse {
  +int name
  #int score
  +float updatedAt
  +updatePrice()
  +sendName()
  +processTotal()
}
abstract class Product {
  -boolean duration
  -long name
  -Date amount
  -long type
  +calculateCreatedat()
  +setCreatedat()
}
interface Shipment {
  -boolean description
  +double total
  +createAmount()
  +setAmount()
  +setActive()
}
Product --|> Shipment
Shipment ..|> Payment
Coupon --|> Payment
@enduml