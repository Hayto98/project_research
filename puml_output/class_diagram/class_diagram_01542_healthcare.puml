@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Insurance {
  +long email
  +int updatedAt
  +float status
  -Date score
  +int duration
  +setQuantity()
  +setScore()
}
abstract class MedicalRecord {
  +long quantity
  +Date total
  +int active
  +saveDescription()
  +validateType()
  +setEmail()
}
abstract class LabTest {
  -double email
  +Date phone
  #long updatedAt
  -float active
  +validatePrice()
  +savePrice()
  +getUpdatedat()
  +cancelUpdatedat()
}
abstract class Hospital {
  -String level
  #float code
  -double amount
  -float duration
  +double name
  +saveTotal()
  +processPhone()
}
class Doctor {
  -boolean code
  -int updatedAt
  -float email
  +long note
  +findPrice()
  +updateName()
}
LabTest ..> MedicalRecord : "1"
Hospital --|> MedicalRecord
note right of Insurance : Healthcare domain
@enduml