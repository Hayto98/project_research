@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Insurance {
  +long email
  +int updatedAt
  +float status
  -Date score
  +int duration
  +createEmail()
  +deleteQuantity()
}
class MedicalRecord {
  +long score
  -boolean price
  +setEmail()
}
class LabTest {
  #int updatedAt
  -Date address
  +createId()
  +cancelType()
  +updateName()
  +validateAmount()
}
abstract class Hospital {
  -double email
  +Date phone
  #long updatedAt
  -float active
  +createAmount()
  +saveUpdatedat()
  +setScore()
  +createPrice()
}
abstract class Doctor {
  -double updatedAt
  #boolean duration
  +createCode()
}
Doctor --|> Insurance
LabTest ..> Insurance : "1..*"
Hospital --|> Doctor
Hospital ..> MedicalRecord : "*"
@enduml