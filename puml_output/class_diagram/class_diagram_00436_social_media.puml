@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Story {
  #String type
  +String name
  #float code
  +calculatePrice()
}
abstract class Follower {
  -int price
  +Date score
  #float code
  +Date createdAt
  #float name
  +getCode()
  +validateActive()
  +processId()
  +deleteType()
}
class Post {
  +double code
  +long status
  +processId()
}
interface Like {
  -int status
  +int type
  -boolean name
  #float phone
  +createScore()
  +processPhone()
  +processAddress()
}
class Profile {
  #String phone
  #boolean createdAt
  #int address
  +updateUpdatedat()
  +sendAmount()
}
class Report {
  +boolean phone
  +int amount
  +deleteScore()
}
interface Message {
  +Date email
  +Date name
  #boolean createdAt
  -Date address
  +setType()
  +findActive()
  +processCode()
  +updatePhone()
}
Post ..> Message : "0..1"
Message ..> Post : "0..1"
Profile --> Story : "0..1"
note right of Story : Social Media domain
@enduml