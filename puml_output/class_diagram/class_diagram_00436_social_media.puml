@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Story {
  #String type
  +String name
  #float code
  +getAddress()
}
abstract class Follower {
  #String type
  -int price
  +Date score
  #float code
  +Date createdAt
  +updatePrice()
  +findNote()
  +deleteLevel()
  +cancelId()
}
interface Post {
  +String id
  +double description
  +long type
  #String code
  -Date status
  +createStatus()
}
interface Like {
  -int status
  +int type
  -boolean name
  #float phone
  +validateAmount()
  +updateQuantity()
  +calculateDuration()
}
abstract class Profile {
  -Date note
  +Date address
  -Date level
  +float description
  +deleteScore()
  +findAddress()
}
class Report {
  #int email
  +boolean code
  +int phone
  +deleteId()
}
class Message {
  +Date email
  +Date name
  #boolean createdAt
  -Date address
  +getType()
  +findActive()
  +createTotal()
  +getScore()
}
Story --* Follower
Follower --* Post
Report --* Follower
Report ..> Profile : "0..1"
Profile --> Story : "0..1"
@enduml