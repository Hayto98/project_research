@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
interface Staff {
  -int active
  -long status
  +long description
  +deleteEmail()
  +cancelAmount()
  +deleteAmount()
  +deleteUpdatedat()
}
abstract class Housekeeping {
  #float note
  -String code
  #float duration
  -double status
  +float name
  +createQuantity()
  +getNote()
}
interface Room {
  +long description
  #int amount
  -String status
  -boolean id
  -boolean updatedAt
  +processQuantity()
  +createDescription()
  +setActive()
  +updateTotal()
}
class Booking {
  +double id
  #Date total
  #boolean email
  #long address
  +cancelCreatedat()
  +savePhone()
  +cancelDescription()
  +sendName()
}
class Payment {
  #String code
  -boolean total
  -String createdAt
  +double score
  #Date updatedAt
  +saveTotal()
  +deleteQuantity()
  +cancelName()
}
abstract class Amenity {
  #boolean active
  -String level
  -boolean description
  #float duration
  +processLevel()
  +updateLevel()
  +saveType()
}
Booking --|> Room
Staff --o Housekeeping
Amenity --o Staff
Staff --> Booking : "1..*"
@enduml