@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
interface Department {
  +int email
  #int code
  #float active
  +createDuration()
  +processQuantity()
}
abstract class Assignment {
  -long score
  #String amount
  +int email
  +Date note
  +validateType()
  +createDescription()
}
interface Book {
  +boolean quantity
  #long createdAt
  -int type
  -Date duration
  -Date email
  +updateQuantity()
}
class Grade {
  #long amount
  -String total
  #double price
  -boolean note
  +Date quantity
  +cancelPrice()
  +validateStatus()
  +validatePhone()
}
interface Library {
  +double type
  #long quantity
  +validateEmail()
}
class Enrollment {
  -boolean updatedAt
  +long duration
  #int quantity
  +deleteId()
  +validateAddress()
  +cancelAddress()
}
abstract class Schedule {
  +float phone
  -double type
  +getCreatedat()
  +validateEmail()
  +calculateEmail()
  +savePrice()
}
Schedule --|> Assignment
Department --o Grade
Schedule --|> Department
Grade ..|> Department
Assignment --> Book : "*"
note right of Department : Education domain
@enduml