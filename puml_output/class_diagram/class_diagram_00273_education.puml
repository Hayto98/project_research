@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
interface Department {
  +int email
  #int code
  #float active
  +findScore()
  +setId()
}
abstract class Assignment {
  -double total
  -long phone
  #String score
  +int amount
  +calculateStatus()
}
class Book {
  -int type
  -long quantity
  #long description
  +boolean duration
  +createPrice()
  +processPrice()
  +validateScore()
}
abstract class Grade {
  +double createdAt
  +float quantity
  +updateCreatedat()
  +deleteAmount()
  +getCreatedat()
  +validateTotal()
}
interface Library {
  -boolean quantity
  +Date phone
  -boolean level
  -long status
  +long note
  +createUpdatedat()
  +sendPrice()
  +setStatus()
}
abstract class Enrollment {
  #float updatedAt
  +long type
  -float active
  +Date phone
  +getActive()
  +calculateDescription()
}
class Schedule {
  -Date quantity
  +Date duration
  -int name
  +sendPhone()
}
Library --o Book
Department --o Book
Assignment --o Book
Enrollment --|> Grade
@enduml