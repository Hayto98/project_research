@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Route {
  -long updatedAt
  -long duration
  +findTotal()
  +createName()
  +cancelUpdatedat()
}
class Tracking {
  -int phone
  +boolean createdAt
  #Date name
  +String email
  +double type
  +getLevel()
  +calculatePrice()
  +saveQuantity()
  +cancelAmount()
}
interface Customer {
  #int active
  -int email
  +long address
  +processLevel()
  +deleteEmail()
  +cancelScore()
  +processAddress()
}
abstract class Package {
  -long price
  +float code
  +Date score
  +saveActive()
  +cancelScore()
  +cancelId()
}
class DeliveryNote {
  +boolean updatedAt
  +double score
  +String name
  +getName()
}
class FuelLog {
  -long address
  -long code
  -long total
  +String active
  #double price
  +calculateEmail()
  +setStatus()
  +savePrice()
}
class Driver {
  -boolean code
  #float phone
  +saveLevel()
}
FuelLog --o Tracking
Route --|> Tracking
note right of Route : Logistics domain
@enduml