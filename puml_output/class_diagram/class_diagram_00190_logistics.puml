@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Route {
  -long updatedAt
  -long duration
  +validateType()
  +validateStatus()
  +cancelDescription()
}
abstract class Tracking {
  -Date name
  +String updatedAt
  -Date description
  -long type
  +saveTotal()
  +processName()
}
interface Customer {
  #double name
  +boolean updatedAt
  -Date note
  +cancelPrice()
  +updateId()
  +setDuration()
  +updateLevel()
}
interface Package {
  -long duration
  #int amount
  -int active
  +validateAddress()
  +sendScore()
}
abstract class DeliveryNote {
  -double email
  +Date score
  -String note
  +cancelAddress()
  +saveTotal()
  +createScore()
}
class FuelLog {
  +Date active
  +int level
  #String score
  +boolean id
  +saveName()
}
class Driver {
  +float status
  #long id
  +setEmail()
  +cancelType()
  +getLevel()
  +validateDescription()
}
DeliveryNote --* Package
Customer --* Package
Customer ..|> Driver
Route --o FuelLog
DeliveryNote --o Customer
@enduml