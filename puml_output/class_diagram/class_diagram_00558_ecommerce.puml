@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
abstract class Product {
  +String total
  +float active
  -String amount
  +processLevel()
  +setStatus()
  +updateDuration()
}
interface Return {
  #long description
  #Date note
  +validateLevel()
  +calculateType()
  +validateCreatedat()
  +findPrice()
}
interface Order {
  +double type
  #double status
  -String description
  #String updatedAt
  +updateEmail()
  +saveLevel()
  +updateQuantity()
}
class Category {
  +String level
  #double description
  -long note
  +boolean score
  #float email
  +setLevel()
}
class Payment {
  #String level
  +String amount
  #String note
  +findDuration()
  +sendDescription()
  +setEmail()
  +createLevel()
}
Return ..|> Payment
Category ..|> Return
Return --o Order
@enduml