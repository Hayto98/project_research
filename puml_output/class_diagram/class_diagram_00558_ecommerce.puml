@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
abstract class Product {
  +String total
  +float active
  -String amount
  +calculateStatus()
  +getScore()
  +getDescription()
}
abstract class Return {
  #boolean active
  #long score
  -Date total
  +int description
  +deletePrice()
  +saveNote()
}
abstract class Order {
  #long duration
  -float name
  +calculateLevel()
  +deleteNote()
  +saveNote()
}
class Category {
  -long status
  +boolean price
  +deleteEmail()
}
class Payment {
  +boolean note
  +float id
  -boolean status
  +findAddress()
  +deleteUpdatedat()
  +deletePrice()
}
Return --> Payment : "1..*"
Category ..> Product : "0..1"
note right of Product : Ecommerce domain
@enduml