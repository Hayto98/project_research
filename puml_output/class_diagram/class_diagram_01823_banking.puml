@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Withdrawal {
  -boolean status
  #int type
  #long amount
  +cancelQuantity()
  +sendQuantity()
  +sendActive()
}
class Loan {
  #float active
  #boolean email
  +calculateNote()
  +calculateDescription()
  +updateStatus()
  +processActive()
}
class Branch {
  #int id
  +long active
  #String createdAt
  +deleteEmail()
  +validateType()
  +findName()
  +saveStatus()
}
class Customer {
  -float quantity
  +int score
  -boolean amount
  +double address
  +Date id
  +getAddress()
}
class Transaction {
  -int code
  #boolean createdAt
  -int note
  +updateAmount()
  +findCode()
}
Loan --|> Transaction
Loan --|> Customer
Withdrawal ..|> Customer
@enduml