@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Statement {
  #Date address
  -Date code
  +sendUpdatedat()
  +calculatePhone()
  +updateNote()
  +deleteTotal()
}
class Customer {
  #String total
  -Date score
  #double code
  #boolean note
  -float type
  +cancelScore()
  +validateEmail()
}
interface Interest {
  #int active
  -Date note
  -boolean duration
  +double phone
  +processName()
  +findDuration()
  +cancelEmail()
}
interface Account {
  +Date active
  -String note
  -int description
  +int quantity
  -float amount
  +sendTotal()
  +getPhone()
  +setCreatedat()
  +calculateQuantity()
}
Account ..> Statement : "*"
Account ..|> Interest
note right of Statement : Banking domain
@enduml