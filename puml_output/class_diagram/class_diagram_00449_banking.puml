@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Statement {
  #Date address
  -Date code
  +updateNote()
  +updateStatus()
  +createPrice()
  +saveScore()
}
class Customer {
  #String amount
  -double total
  #String email
  -Date level
  #double active
  +getDescription()
  +validateCreatedat()
  +processId()
  +sendAmount()
}
class Interest {
  -boolean duration
  -boolean score
  +double email
  #long active
  +processLevel()
}
class Account {
  +long name
  +int email
  #long note
  +long active
  +String score
  +findQuantity()
  +validateDescription()
}
Account ..> Statement : "1..*"
Statement --o Account
Interest --> Account : "0..1"
@enduml