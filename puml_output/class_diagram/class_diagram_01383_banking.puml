@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
abstract class Teller {
  +float type
  -boolean id
  -float duration
  +double level
  #long amount
  +cancelStatus()
  +validateName()
}
interface Customer {
  #float duration
  +int code
  +long price
  +validateLevel()
  +sendAmount()
  +updateUpdatedat()
}
class Statement {
  +double active
  +float updatedAt
  #long createdAt
  +double duration
  +saveCreatedat()
}
interface Interest {
  -long id
  +int total
  -float name
  -boolean createdAt
  #double address
  +calculateTotal()
  +sendPhone()
  +findUpdatedat()
  +updateCreatedat()
}
Statement ..> Customer : "1..*"
Teller --|> Statement
Statement --> Interest : "1"
@enduml