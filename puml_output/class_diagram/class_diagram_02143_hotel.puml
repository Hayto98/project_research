@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
abstract class Invoice {
  #float address
  #double price
  #float email
  +calculateCreatedat()
  +deleteAmount()
  +setQuantity()
}
class Amenity {
  -Date type
  +String active
  -Date price
  +int code
  -int createdAt
  +calculateStatus()
  +calculateAmount()
  +validateTotal()
  +getScore()
}
abstract class Reservation {
  +long name
  -boolean type
  +String note
  +findPrice()
  +sendStatus()
  +calculateQuantity()
  +getEmail()
}
class Payment {
  +long createdAt
  #String description
  +getAmount()
}
abstract class Service {
  -boolean name
  -double price
  +boolean type
  +sendCreatedat()
  +getStatus()
  +cancelType()
}
Amenity --* Reservation
Reservation --> Invoice : "0..1"
@enduml