@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
abstract class Album {
  #boolean score
  #double createdAt
  -boolean name
  #String address
  #double duration
  +calculateAmount()
  +getType()
  +cancelId()
}
abstract class Post {
  +String status
  +long amount
  -Date level
  +double quantity
  +cancelTotal()
}
abstract class Report {
  #boolean updatedAt
  #String quantity
  -Date active
  +float duration
  +processTotal()
  +calculateEmail()
  +validateCode()
}
class Message {
  +long email
  +long description
  +deletePrice()
  +saveNote()
}
Post --> Album : "1..*"
Report --|> Post
Post ..|> Message
@enduml