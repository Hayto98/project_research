@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
abstract class Album {
  #boolean score
  #double createdAt
  -boolean name
  #String address
  #double duration
  +processCode()
  +validatePrice()
  +validateStatus()
}
class Post {
  +long quantity
  -Date name
  +double status
  +getType()
}
class Report {
  #boolean quantity
  #String active
  -Date updatedAt
  +createNote()
}
class Message {
  +int code
  -String status
  -float email
  +processCreatedat()
  +sendQuantity()
}
Album --* Report
Report --|> Post
note right of Album : Social Media domain
@enduml