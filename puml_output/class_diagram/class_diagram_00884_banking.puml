@startuml
skinparam defaultFontSize 13
class Branch {
  #double active
  #float level
  +float phone
  -float createdAt
  +createDescription()
  +validateCreatedat()
}
class Loan {
  #String name
  #boolean address
  +int price
  +int duration
  #Date updatedAt
  +processPhone()
  +calculateId()
}
class Beneficiary {
  #Date id
  #double amount
  +double quantity
  #long updatedAt
  +processTotal()
}
class Interest {
  #float quantity
  -Date description
  +processScore()
  +setUpdatedat()
  +calculateScore()
  +findAddress()
}
Beneficiary --* Interest
Interest --* Branch
note right of Branch : Banking domain
@enduml