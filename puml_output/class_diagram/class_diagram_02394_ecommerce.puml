@startuml
skinparam monochrome true
abstract class Invoice {
  +double createdAt
  +boolean type
  +double code
  +createQuantity()
  +createEmail()
  +validateLevel()
  +getTotal()
}
abstract class Return {
  -int active
  -long description
  #long price
  +String note
  +validateTotal()
  +processStatus()
  +cancelType()
}
class Review {
  #float note
  #long email
  +deleteLevel()
  +validateStatus()
}
class Payment {
  #long phone
  -int email
  +float code
  #boolean price
  +saveId()
  +sendUpdatedat()
  +createStatus()
  +createPrice()
}
abstract class Warehouse {
  -boolean quantity
  #double description
  +long status
  #boolean active
  +int level
  +calculateQuantity()
  +validateActive()
}
Payment --o Review
Invoice --|> Review
@enduml