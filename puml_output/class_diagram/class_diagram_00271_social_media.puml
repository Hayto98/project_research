@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Follower {
  -double score
  +long address
  +calculateAmount()
  +validateDescription()
  +createEmail()
}
interface Profile {
  +long level
  -double status
  #Date email
  #double phone
  #float total
  +updateName()
}
class Story {
  -double score
  #Date amount
  -int email
  +getActive()
  +sendUpdatedat()
  +createPhone()
  +createPhone()
}
abstract class Notification {
  #long active
  -long code
  +calculateCreatedat()
}
Notification --> Story : "0..1"
Profile ..> Notification : "1"
note right of Follower : Social Media domain
@enduml