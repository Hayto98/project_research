@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Follower {
  -double score
  +long address
  +sendScore()
  +updateAmount()
  +sendLevel()
}
class Profile {
  #boolean description
  +long quantity
  #float email
  #Date total
  +updateEmail()
  +sendId()
  +cancelAddress()
}
abstract class Story {
  +Date active
  #int level
  +float note
  #boolean code
  +long updatedAt
  +saveName()
  +findName()
  +validatePrice()
}
abstract class Notification {
  #int note
  -long id
  -long active
  +createAddress()
  +cancelDescription()
  +updateNote()
  +setDescription()
}
Story --|> Profile
Notification --> Follower : "1"
Notification --> Story : "0..1"
@enduml