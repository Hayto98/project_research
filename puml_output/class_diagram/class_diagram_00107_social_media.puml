@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
abstract class Hashtag {
  +int active
  -String name
  -String type
  #long price
  +deleteEmail()
  +setCreatedat()
  +processAmount()
}
interface Profile {
  +float updatedAt
  #boolean status
  +String code
  +saveActive()
}
abstract class Story {
  #long quantity
  -String active
  -int createdAt
  +boolean status
  +deleteTotal()
  +processType()
}
class Group {
  -float name
  +float total
  +findQuantity()
}
Profile --|> Group
Hashtag --> Group : "1"
note right of Hashtag : Social Media domain
@enduml