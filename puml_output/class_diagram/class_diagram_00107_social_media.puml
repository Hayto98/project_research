@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
abstract class Hashtag {
  +int active
  -String name
  -String type
  #long price
  +calculateLevel()
  +updateType()
  +getAmount()
}
class Profile {
  #int createdAt
  #int type
  +createPhone()
  +validatePhone()
}
class Story {
  -long status
  #long name
  #int active
  +calculateTotal()
}
interface Group {
  +boolean price
  +int code
  -double type
  -Date description
  +findTotal()
  +cancelPrice()
  +createPhone()
}
Group ..|> Profile
Hashtag --* Story
@enduml