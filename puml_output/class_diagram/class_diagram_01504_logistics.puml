@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Driver {
  +long updatedAt
  #float address
  +processLevel()
  +setCreatedat()
  +validateId()
}
abstract class Shipment {
  -boolean amount
  -Date total
  +String duration
  #Date phone
  +validateDuration()
  +createPhone()
}
class Depot {
  +float status
  -double active
  +float id
  +deletePrice()
  +cancelCode()
  +deleteAmount()
}
interface Tracking {
  +String price
  -int level
  -String total
  -Date type
  +saveScore()
  +processAmount()
  +processStatus()
}
abstract class Customer {
  -boolean duration
  #double updatedAt
  +processEmail()
}
class Package {
  #double total
  -long phone
  +createPhone()
}
Driver --o Package
Package --|> Shipment
Package ..> Driver : "*"
@enduml