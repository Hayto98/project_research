@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Category {
  -long email
  #boolean code
  #int active
  +getDuration()
  +updateEmail()
  +getCode()
  +setStatus()
}
abstract class Review {
  +double code
  -boolean status
  +double total
  +int phone
  -long note
  +saveEmail()
  +getPhone()
  +createId()
  +calculateDuration()
}
class Coupon {
  -double address
  #int price
  -double note
  +long amount
  +findTotal()
  +getUpdatedat()
}
class Payment {
  +Date description
  #String code
  -double score
  +boolean status
  #long level
  +findPrice()
  +sendCreatedat()
}
Category --o Review
Review --* Coupon
note right of Category : Ecommerce domain
@enduml