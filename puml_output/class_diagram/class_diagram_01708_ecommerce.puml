@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Category {
  -long email
  #boolean code
  #int active
  +setName()
  +getActive()
  +saveLevel()
  +validateActive()
}
class Review {
  -double name
  +String code
  #double status
  #long score
  +setType()
  +getAddress()
  +deleteTotal()
  +deletePrice()
}
interface Coupon {
  -long price
  -Date updatedAt
  #long description
  +validateLevel()
}
class Payment {
  -double id
  -int price
  -double amount
  #int phone
  +setNote()
  +createPhone()
  +sendAddress()
  +calculateTotal()
}
Payment ..|> Category
Category ..> Review : "0..1"
@enduml