@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
abstract class Amenity {
  #float amount
  #String updatedAt
  #Date level
  +long total
  +getDescription()
  +processCreatedat()
}
interface Room {
  +String duration
  #String email
  #boolean score
  -float total
  +Date level
  +calculateStatus()
}
interface Booking {
  +long address
  +String createdAt
  +processDescription()
}
class Restaurant {
  -String name
  +long level
  #long note
  +saveQuantity()
  +saveTotal()
  +updateEmail()
  +processCode()
}
class Invoice {
  +float description
  #String code
  -float duration
  +calculateDuration()
}
class Payment {
  -int createdAt
  +float active
  +calculateEmail()
  +getStatus()
  +sendNote()
}
Room --* Restaurant
Booking --o Restaurant
Booking ..> Payment : "0..1"
Restaurant ..|> Invoice
@enduml