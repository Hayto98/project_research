@startuml
skinparam ArrowColor #555555
abstract class Hashtag {
  +int description
  -float name
  +long total
  -Date email
  +getType()
  +deleteName()
}
abstract class Follower {
  -long price
  +double type
  -float createdAt
  +int phone
  +setDescription()
}
class Like {
  #String updatedAt
  #long phone
  +float note
  -Date duration
  +updateNote()
}
abstract class Report {
  +long code
  -Date price
  +String description
  #float level
  #double address
  +sendActive()
}
Hashtag --> Report : "*"
Like ..|> Hashtag
Hashtag --> Follower : "*"
note right of Hashtag : Social Media domain
@enduml