@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
interface Vehicle {
  +int code
  #long quantity
  +int email
  +deleteCreatedat()
  +cancelDuration()
  +setName()
}
abstract class Package {
  +long updatedAt
  #int createdAt
  #Date amount
  +calculateAmount()
}
interface DeliveryNote {
  +long level
  +boolean status
  +long active
  #double phone
  +processLevel()
  +calculateAddress()
  +createQuantity()
}
class Shipment {
  -boolean code
  +float level
  #double name
  +deleteType()
  +setAmount()
}
Package --o Shipment
Shipment --|> Package
note right of Vehicle : Logistics domain
@enduml