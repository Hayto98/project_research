@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
interface Vehicle {
  +int code
  #long quantity
  +int email
  +updateType()
  +setCreatedat()
  +getTotal()
}
interface Package {
  +int name
  +float note
  +calculateNote()
  +validateAmount()
}
interface DeliveryNote {
  +Date level
  #boolean id
  -boolean price
  +createDescription()
}
class Shipment {
  #int address
  -boolean id
  +createQuantity()
  +sendCode()
  +sendDescription()
  +processEmail()
}
DeliveryNote --* Package
DeliveryNote ..|> Shipment
Vehicle --|> DeliveryNote
@enduml