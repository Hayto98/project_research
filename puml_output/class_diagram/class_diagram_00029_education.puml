@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
interface Student {
  #Date total
  +boolean amount
  +boolean email
  -double score
  +sendEmail()
  +processDescription()
  +calculateName()
  +setType()
}
class Classroom {
  +String name
  -boolean updatedAt
  +String price
  +double createdAt
  #long score
  +setType()
}
interface Library {
  #String phone
  #int duration
  -double type
  +double price
  -int amount
  +createAddress()
  +getNote()
  +updateNote()
}
interface Enrollment {
  +Date price
  +String amount
  +getType()
  +getCreatedat()
}
abstract class Exam {
  -float status
  -float code
  +setDuration()
}
Exam --o Classroom
Student --* Enrollment
Exam --* Library
@enduml