@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
interface Student {
  #Date total
  +boolean amount
  +boolean email
  -double score
  +updateQuantity()
  +validateDescription()
  +validateType()
  +getUpdatedat()
}
abstract class Classroom {
  -boolean price
  +String updatedAt
  +double status
  +getDescription()
  +cancelType()
  +validatePhone()
}
interface Library {
  -double price
  +double amount
  -int active
  #long status
  +long updatedAt
  +calculateAmount()
}
class Enrollment {
  #double code
  +String updatedAt
  +double duration
  +setDuration()
  +sendActive()
  +updatePrice()
}
class Exam {
  #String phone
  -float level
  +Date description
  #double duration
  -long address
  +cancelName()
}
Enrollment ..> Student : "1..*"
Student --* Enrollment
Enrollment --|> Exam
note right of Student : Education domain
@enduml