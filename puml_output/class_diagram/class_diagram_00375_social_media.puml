@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Album {
  +long note
  -Date createdAt
  #Date address
  +Date phone
  -long type
  +updateQuantity()
  +saveTotal()
}
class Profile {
  +double price
  -int status
  -long note
  +long phone
  +setCode()
}
class Report {
  -int duration
  #float createdAt
  #int active
  +Date score
  +findUpdatedat()
}
class Group {
  #float phone
  #float name
  #float duration
  -long quantity
  #String id
  +saveAmount()
  +validateLevel()
  +calculateAddress()
}
class Post {
  +float total
  #String address
  -long quantity
  -long description
  +cancelQuantity()
  +setDescription()
}
Report --* Profile
Post --* Album
Report --o Group
@enduml