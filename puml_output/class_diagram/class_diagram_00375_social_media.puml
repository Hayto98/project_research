@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Album {
  +long note
  -Date createdAt
  #Date address
  +Date phone
  -long type
  +updateEmail()
  +calculateStatus()
}
abstract class Profile {
  -long updatedAt
  +long total
  +Date note
  +long duration
  +cancelActive()
  +saveLevel()
}
interface Report {
  #boolean updatedAt
  +boolean active
  #String score
  -long description
  +float duration
  +createId()
  +findActive()
  +processAddress()
}
interface Group {
  #boolean score
  -double level
  +updateActive()
  +createTotal()
}
interface Post {
  -long quantity
  -long description
  +double name
  +double score
  +cancelCreatedat()
  +createLevel()
  +getAddress()
}
Report --o Group
Report --* Album
Group ..|> Report
note right of Album : Social Media domain
@enduml