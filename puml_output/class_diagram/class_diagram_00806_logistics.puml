@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Tracking {
  #String price
  +long code
  +getActive()
  +createPrice()
}
interface Driver {
  -String description
  +boolean code
  #double total
  +boolean score
  +getPhone()
}
interface Inventory {
  #Date duration
  -boolean note
  #boolean amount
  +saveStatus()
  +processLevel()
  +calculateScore()
}
interface Customer {
  -float level
  +long createdAt
  +createType()
  +updateDuration()
}
class DeliveryNote {
  #Date total
  #double duration
  +validateStatus()
  +updateLevel()
  +sendType()
}
interface Vehicle {
  #int code
  #Date duration
  -String status
  +String quantity
  -double score
  +cancelCreatedat()
  +validateCode()
  +calculateId()
  +sendQuantity()
}
Vehicle --* Tracking
Vehicle --o DeliveryNote
Customer --* Driver
@enduml