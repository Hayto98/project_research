@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Loan {
  -int code
  -float total
  -String id
  +long status
  -double score
  +cancelCreatedat()
  +deleteId()
  +updateDescription()
  +calculateDuration()
}
class Fine {
  #Date level
  -long amount
  #double email
  +setPrice()
}
interface Reservation {
  +String duration
  -int type
  -float total
  +deletePrice()
}
abstract class Book {
  #double score
  #int quantity
  +float email
  #long status
  +sendEmail()
}
Book --|> Reservation
Book --* Fine
Loan ..> Book : "0..1"
@enduml