@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Loan {
  -int code
  -float total
  -String id
  +long status
  -double score
  +calculateCreatedat()
  +sendStatus()
  +deleteLevel()
  +deleteEmail()
}
abstract class Fine {
  #double score
  -float total
  +String status
  -int updatedAt
  +cancelStatus()
  +processTotal()
  +sendScore()
}
class Reservation {
  +float email
  #long status
  +int type
  -double createdAt
  +findLevel()
}
abstract class Book {
  +float email
  #double status
  #long code
  #float description
  -long active
  +updateAmount()
  +createId()
}
Book --> Fine : "1..*"
Fine ..|> Loan
note right of Loan : Library domain
@enduml