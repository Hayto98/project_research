@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
abstract class Room {
  -double email
  +boolean phone
  -double level
  #String type
  +boolean updatedAt
  +validateLevel()
  +setStatus()
  +sendAddress()
}
interface Invoice {
  -boolean duration
  +float active
  +long level
  -Date updatedAt
  +int description
  +calculateActive()
  +getPrice()
  +calculateId()
}
interface Payment {
  +double score
  #int level
  #float createdAt
  #float active
  +validateType()
  +validateCreatedat()
  +sendCode()
  +sendAmount()
}
abstract class Guest {
  -int address
  #int price
  -long phone
  +createDuration()
  +calculateQuantity()
  +deleteActive()
}
class Housekeeping {
  +double address
  #boolean updatedAt
  #String status
  -String email
  +String active
  +findAddress()
  +sendName()
}
interface Service {
  -String score
  -double name
  +findDuration()
  +calculateActive()
}
class Reservation {
  +Date level
  +Date price
  -long amount
  #long score
  +sendCode()
}
Housekeeping ..> Service : "1..*"
Invoice ..|> Service
@enduml