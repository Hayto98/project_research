@startuml
skinparam defaultFontSize 13
class Customer {
  -float price
  #Date status
  +findDescription()
}
abstract class FuelLog {
  -String score
  #String code
  +long quantity
  -Date active
  +findEmail()
}
abstract class Driver {
  -double address
  #int amount
  #double active
  -double quantity
  +validateQuantity()
  +deleteDuration()
  +cancelLevel()
  +cancelStatus()
}
class Depot {
  #float score
  #int duration
  #double description
  #double amount
  +findType()
  +saveType()
}
class Package {
  #long code
  +String total
  +sendDuration()
  +validateAmount()
  +findCreatedat()
  +saveLevel()
}
Depot --|> Driver
Driver ..|> FuelLog
@enduml