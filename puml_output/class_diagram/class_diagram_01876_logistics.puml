@startuml
skinparam defaultFontSize 13
class Customer {
  -float price
  #Date status
  +cancelTotal()
}
class FuelLog {
  -String quantity
  #String active
  +createType()
}
class Driver {
  -double address
  #int duration
  #double amount
  -double active
  -int quantity
  +setCreatedat()
  +createScore()
  +sendDescription()
  +deleteScore()
}
class Depot {
  +float level
  -boolean note
  -int description
  +double phone
  #long code
  +setTotal()
  +createName()
  +savePhone()
}
class Package {
  +double email
  +double createdAt
  +long total
  +setCode()
  +processId()
  +findQuantity()
  +findPhone()
}
Package --* FuelLog
FuelLog --o Package
Customer --* Driver
note right of Customer : Logistics domain
@enduml