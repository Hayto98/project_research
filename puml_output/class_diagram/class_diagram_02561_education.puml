@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
interface Book {
  -boolean active
  #float status
  -int duration
  #int id
  +calculateDuration()
  +sendPrice()
  +saveCode()
  +getCode()
}
class Student {
  +int duration
  -int active
  +findId()
  +calculateName()
  +calculateLevel()
  +processQuantity()
}
class Teacher {
  #int createdAt
  #boolean active
  #float status
  +long code
  +cancelCode()
  +createType()
  +saveLevel()
  +findScore()
}
abstract class Course {
  +float phone
  #boolean note
  +float updatedAt
  #double price
  +findUpdatedat()
  +calculateScore()
  +processStatus()
  +setQuantity()
}
class Exam {
  +int name
  #Date quantity
  -boolean phone
  -Date total
  #long level
  +getNote()
  +setScore()
  +sendCode()
}
class Assignment {
  +int amount
  #int active
  +processStatus()
}
class Grade {
  #int type
  -long email
  -int code
  -float quantity
  +boolean total
  +setEmail()
  +processPrice()
  +validateNote()
}
Book ..> Grade : "*"
Student --|> Book
Exam --|> Teacher
Course --o Student
Exam --|> Grade
@enduml