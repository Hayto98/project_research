@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
interface Book {
  -boolean active
  #float status
  -int duration
  #int id
  +sendPrice()
  +cancelQuantity()
  +getDuration()
  +saveActive()
}
class Student {
  +long address
  +long updatedAt
  #Date total
  +updateActive()
  +setCode()
  +findDescription()
}
interface Teacher {
  -Date quantity
  -float type
  +validatePhone()
  +processUpdatedat()
  +calculateCreatedat()
  +cancelLevel()
}
class Course {
  #String total
  -boolean email
  -double phone
  -int status
  +boolean price
  +cancelType()
  +saveScore()
  +validateAddress()
  +createNote()
}
class Exam {
  +int amount
  #int active
  +validateCreatedat()
}
abstract class Assignment {
  -long email
  -int code
  -float quantity
  +boolean total
  -long amount
  +updateActive()
  +setName()
}
interface Grade {
  -int amount
  -boolean status
  #String level
  #long quantity
  #String score
  +validatePhone()
  +findQuantity()
}
Teacher ..|> Course
Teacher --|> Book
Grade --* Exam
note right of Book : Education domain
@enduml