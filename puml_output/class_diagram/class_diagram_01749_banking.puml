@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
interface Beneficiary {
  #Date duration
  #long id
  +calculateDescription()
}
interface Branch {
  -int type
  #String code
  +Date createdAt
  -float amount
  #String level
  +validateType()
  +getScore()
  +setCode()
}
class Withdrawal {
  +boolean name
  +double phone
  +sendPrice()
  +validateAddress()
  +sendType()
  +cancelDescription()
}
class Customer {
  #String type
  +long code
  #boolean id
  #int active
  +processCreatedat()
  +calculateStatus()
}
Beneficiary --* Withdrawal
Branch --* Withdrawal
@enduml