@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Comment {
  #double createdAt
  +boolean price
  -String name
  +getQuantity()
  +processType()
}
interface Follower {
  +long price
  #long updatedAt
  +boolean amount
  +deleteLevel()
  +validateEmail()
  +getEmail()
}
class Report {
  -int note
  +long code
  -double active
  -Date id
  +createStatus()
  +calculateStatus()
  +getLevel()
}
class Group {
  -long code
  #float id
  -double quantity
  -boolean note
  +boolean active
  +validateStatus()
}
class Like {
  #Date createdAt
  +int code
  +findStatus()
}
Group --* Follower
Report --* Follower
Follower --> Like : "*"
Comment ..|> Report
note right of Comment : Social Media domain
@enduml