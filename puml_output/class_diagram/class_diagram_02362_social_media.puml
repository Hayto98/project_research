@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Comment {
  #double createdAt
  +boolean price
  -String name
  +savePhone()
  +cancelDescription()
}
class Follower {
  +int type
  -boolean level
  -String amount
  #boolean price
  -int updatedAt
  +findCreatedat()
  +setName()
  +createLevel()
}
class Report {
  +boolean level
  #String phone
  -int note
  +sendPhone()
}
class Group {
  +float note
  +boolean address
  -float quantity
  -String status
  +Date price
  +findType()
  +createName()
  +createNote()
}
abstract class Like {
  #int phone
  #String address
  -String note
  +float type
  +saveNote()
}
Like ..|> Comment
@enduml