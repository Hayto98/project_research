@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
interface Like {
  -int price
  #long note
  #float address
  +sendTotal()
  +processCreatedat()
}
abstract class User {
  +long duration
  -int createdAt
  -Date quantity
  -boolean total
  +cancelStatus()
  +processId()
}
abstract class Message {
  -String id
  #int description
  +float note
  +Date createdAt
  +getId()
  +cancelScore()
  +getLevel()
}
class Story {
  +long id
  -int score
  -String active
  +saveCreatedat()
}
class Report {
  -Date price
  #boolean active
  -int address
  #String level
  -double note
  +createPrice()
  +createTotal()
  +sendName()
}
class Comment {
  -Date address
  +Date updatedAt
  +double name
  +deleteCreatedat()
  +updateCode()
  +createUpdatedat()
}
Like --o Report
Comment ..|> User
Message --* Story
@enduml