@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
interface Like {
  -int price
  #long note
  #float address
  +getTotal()
  +validateDuration()
}
class User {
  +float total
  -Date amount
  -boolean email
  #boolean score
  +setLevel()
  +processLevel()
}
class Message {
  +long description
  +boolean note
  +getId()
  +findLevel()
}
class Story {
  -float code
  -int description
  -String createdAt
  +long id
  +boolean updatedAt
  +calculateActive()
  +cancelAddress()
  +sendNote()
  +calculateDuration()
}
interface Report {
  -long description
  -Date level
  -String status
  +long price
  +getNote()
  +saveUpdatedat()
}
class Comment {
  #double quantity
  #int email
  +long active
  #double amount
  -float id
  +getQuantity()
  +updateAmount()
}
Message --o Report
Message --> Story : "1..*"
Comment --* Report
note right of Like : Social Media domain
@enduml