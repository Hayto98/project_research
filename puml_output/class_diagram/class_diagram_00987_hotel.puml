@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Amenity {
  #float id
  #long email
  #int active
  #double address
  #boolean total
  +validatePrice()
  +createActive()
  +validateName()
}
class Reservation {
  #float active
  #float total
  -double phone
  -double id
  #double name
  +saveCreatedat()
}
class Staff {
  #Date code
  -double phone
  +validateLevel()
}
class Booking {
  +double id
  -String duration
  #long price
  +validateId()
  +cancelCode()
  +getActive()
}
class Guest {
  -Date createdAt
  #float price
  -String name
  #Date quantity
  -Date code
  +validatePhone()
  +getLevel()
  +validateCreatedat()
}
class Invoice {
  -long phone
  -double total
  +double name
  #float createdAt
  +updateDuration()
  +findDuration()
}
Booking ..> Amenity : "1..*"
Amenity ..|> Staff
@enduml