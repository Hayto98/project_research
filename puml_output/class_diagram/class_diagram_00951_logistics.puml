@startuml
skinparam shadowing true
abstract class Manifest {
  +double name
  +boolean price
  +setUpdatedat()
  +setLevel()
  +updateActive()
}
interface Tracking {
  -boolean quantity
  #int updatedAt
  #Date level
  #int type
  +getQuantity()
  +findEmail()
  +findId()
}
abstract class Driver {
  #long amount
  #Date address
  +cancelPhone()
  +createActive()
  +calculateQuantity()
}
interface Inventory {
  #boolean id
  -float email
  +validateId()
  +saveCreatedat()
}
interface FuelLog {
  #boolean level
  #boolean quantity
  +float type
  +processLevel()
  +deleteTotal()
  +updateNote()
}
Inventory --* Tracking
Inventory --> Driver : "*"
Inventory --* FuelLog
note right of Manifest : Logistics domain
@enduml