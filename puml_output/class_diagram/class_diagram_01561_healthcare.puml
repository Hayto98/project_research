@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Insurance {
  #float duration
  #double email
  +boolean createdAt
  #double status
  +saveEmail()
}
class Hospital {
  -String level
  #long score
  -String type
  #Date createdAt
  +int id
  +findTotal()
  +validateId()
  +setPrice()
  +deleteScore()
}
class Billing {
  #String amount
  -Date address
  +deleteType()
  +getPrice()
}
class Prescription {
  +double createdAt
  #long phone
  +Date name
  +validateUpdatedat()
  +setId()
}
abstract class Patient {
  #String code
  -int name
  -long status
  +getCreatedat()
  +setId()
  +setPhone()
}
class Treatment {
  +int createdAt
  #boolean name
  #double id
  +processScore()
}
Treatment --|> Insurance
Patient --> Hospital : "1..*"
Billing --* Hospital
@enduml