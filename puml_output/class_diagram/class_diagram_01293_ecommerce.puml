@startuml
skinparam monochrome true
skinparam shadowing true
interface Product {
  -double address
  +boolean phone
  #boolean id
  -boolean updatedAt
  +createCode()
  +updateUpdatedat()
  +processAmount()
}
interface Return {
  +boolean amount
  +Date duration
  -int status
  +saveType()
  +calculateEmail()
}
class Warehouse {
  #double updatedAt
  #float name
  +processActive()
  +processDescription()
  +createEmail()
  +createActive()
}
abstract class Shipment {
  #String duration
  +int phone
  +findType()
  +createScore()
  +saveCode()
  +setQuantity()
}
Shipment --* Return
Warehouse --|> Product
Shipment --* Warehouse
note right of Product : Ecommerce domain
@enduml