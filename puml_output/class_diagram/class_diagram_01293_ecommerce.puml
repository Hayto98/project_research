@startuml
skinparam monochrome true
skinparam shadowing true
interface Product {
  -double address
  +boolean phone
  #boolean id
  -boolean updatedAt
  +processCreatedat()
  +deleteCreatedat()
  +validatePhone()
}
class Return {
  #boolean note
  +int amount
  #int score
  +findPhone()
}
interface Warehouse {
  #double quantity
  -long amount
  -String updatedAt
  +getQuantity()
  +processNote()
}
class Shipment {
  +long active
  -float note
  -boolean type
  -String duration
  #float level
  +createTotal()
  +cancelTotal()
  +setLevel()
}
Shipment --o Warehouse
Warehouse ..> Shipment : "1"
@enduml