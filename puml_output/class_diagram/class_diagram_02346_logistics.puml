@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Manifest {
  +Date phone
  #boolean price
  -String duration
  #long type
  -long level
  +sendName()
}
class Customer {
  #long price
  +long amount
  +processTotal()
  +findTotal()
}
interface Inventory {
  #Date updatedAt
  -String amount
  -int createdAt
  +float description
  +setEmail()
}
class Shipment {
  -Date updatedAt
  +long id
  +boolean status
  #double amount
  #String note
  +sendActive()
  +updateDuration()
  +getType()
  +findDescription()
}
class Warehouse {
  -String id
  -float note
  #double type
  -double price
  #boolean status
  +validateStatus()
  +cancelPrice()
}
Inventory --|> Shipment
Shipment --|> Warehouse
@enduml