@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
abstract class Message {
  +float score
  #boolean type
  -boolean createdAt
  +sendScore()
  +sendQuantity()
  +updateStatus()
  +getDescription()
}
class Like {
  #int address
  #float quantity
  +int name
  +int status
  +Date amount
  +saveLevel()
  +saveTotal()
  +createStatus()
  +cancelId()
}
interface Post {
  +int status
  -int note
  -String address
  -int id
  +deleteAmount()
  +processTotal()
}
class Notification {
  +int code
  +String score
  #String createdAt
  -int updatedAt
  +float description
  +validateLevel()
  +deleteEmail()
  +calculateAmount()
}
Notification --|> Post
Post --* Notification
@enduml