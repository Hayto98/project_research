@startuml

class Story {
  +boolean phone
  #boolean note
  #double createdAt
  #int active
  +findType()
  +validateEmail()
  +calculateUpdatedat()
  +sendQuantity()
}
class Comment {
  -int quantity
  #Date status
  +double amount
  #Date level
  -Date active
  +validateNote()
  +saveNote()
  +calculateStatus()
}
class Message {
  -boolean email
  +double duration
  +int active
  +float score
  +createPrice()
}
class Follower {
  #String active
  #int level
  +double quantity
  #Date score
  +createNote()
  +calculatePrice()
  +setEmail()
}
Follower --> Story : "1..*"
Comment --* Story
Story ..|> Follower
note right of Story : Social Media domain
@enduml