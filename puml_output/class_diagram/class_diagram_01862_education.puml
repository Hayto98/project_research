@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Department {
  #long score
  #double note
  +validateStatus()
  +findId()
  +cancelName()
  +calculateLevel()
}
class Library {
  #int duration
  -double price
  +processAddress()
  +validateLevel()
  +setActive()
  +findTotal()
}
class Classroom {
  #float total
  -String status
  #double createdAt
  +boolean active
  +getCode()
  +processLevel()
  +cancelId()
}
class Student {
  +double level
  -double note
  +float status
  +boolean duration
  #float id
  +createId()
}
interface Course {
  +boolean email
  #boolean level
  -Date status
  -long phone
  +int address
  +getTotal()
  +cancelCode()
  +getLevel()
  +validateUpdatedat()
}
Course ..|> Classroom
Course --> Student : "*"
Classroom --|> Library
note right of Department : Education domain
@enduml