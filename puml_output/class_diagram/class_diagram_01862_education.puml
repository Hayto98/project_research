@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Department {
  #long score
  #double note
  +validateScore()
  +cancelEmail()
  +calculateLevel()
  +saveTotal()
}
class Library {
  -String price
  #double level
  +setNote()
  +createPrice()
}
abstract class Classroom {
  +Date address
  -double phone
  +float code
  #boolean active
  +Date total
  +processCode()
  +findDuration()
  +sendLevel()
  +getPhone()
}
class Student {
  +Date name
  -boolean code
  -String note
  -float id
  +saveEmail()
}
abstract class Course {
  -String total
  #boolean updatedAt
  -long name
  #float active
  +long code
  +validateQuantity()
  +cancelActive()
  +saveTotal()
}
Course ..> Student : "1..*"
Classroom ..|> Department
Student --o Department
Course --|> Department
@enduml