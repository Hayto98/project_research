@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
abstract class Schedule {
  -boolean active
  #boolean score
  -Date status
  -boolean code
  -String note
  +saveNote()
}
interface Teacher {
  #int createdAt
  #Date email
  +setName()
}
class Grade {
  #boolean note
  #float duration
  #long quantity
  +createScore()
}
class Course {
  -boolean total
  -double duration
  #int price
  -double level
  -long code
  +updateId()
  +createTotal()
  +processScore()
}
class Attendance {
  -long id
  #int total
  +findName()
  +updatePrice()
  +findPrice()
}
class Enrollment {
  +long updatedAt
  -long name
  -String phone
  #Date id
  -float note
  +sendEmail()
  +sendType()
  +cancelUpdatedat()
  +cancelId()
}
abstract class Assignment {
  -double description
  -Date name
  +createEmail()
  +findDescription()
}
Schedule --* Attendance
Attendance --|> Course
note right of Schedule : Education domain
@enduml