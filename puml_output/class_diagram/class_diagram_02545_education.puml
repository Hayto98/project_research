@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
abstract class Schedule {
  -boolean active
  #boolean score
  -Date status
  -boolean code
  -String note
  +updateAddress()
}
abstract class Teacher {
  #int createdAt
  #Date email
  +getType()
}
class Grade {
  -boolean createdAt
  -Date note
  +savePhone()
  +deleteCreatedat()
  +sendAmount()
}
class Course {
  -boolean total
  -double duration
  #int price
  -double level
  -long code
  +cancelNote()
  +sendDuration()
  +updateDuration()
}
class Attendance {
  -double type
  -Date score
  +float createdAt
  -Date id
  #String active
  +deleteAmount()
  +cancelUpdatedat()
}
abstract class Enrollment {
  +String duration
  #long level
  +double active
  +long total
  +findCreatedat()
  +deleteCreatedat()
  +saveEmail()
}
class Assignment {
  #float active
  #String email
  -boolean score
  #String type
  #Date updatedAt
  +saveId()
  +getUpdatedat()
}
Course ..> Assignment : "0..1"
Grade ..> Assignment : "0..1"
Enrollment --|> Schedule
Attendance --> Grade : "*"
Schedule --> Teacher : "1..*"
@enduml