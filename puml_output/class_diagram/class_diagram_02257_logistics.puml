@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
abstract class Driver {
  #String email
  +int id
  -int status
  +calculateTotal()
  +setType()
  +findNote()
}
class Customer {
  -String address
  -long quantity
  #int price
  +createLevel()
  +processActive()
  +calculateEmail()
}
class Warehouse {
  +boolean description
  +long duration
  +calculateCreatedat()
  +processAddress()
  +cancelDuration()
  +saveAmount()
}
class Inventory {
  -Date total
  +long description
  +double createdAt
  +Date score
  +cancelName()
  +createPhone()
  +sendId()
  +processDescription()
}
class Manifest {
  +boolean address
  -String updatedAt
  #int id
  +getQuantity()
  +sendDescription()
}
class DeliveryNote {
  #Date code
  -Date note
  +double updatedAt
  +Date name
  #long active
  +calculateStatus()
}
Driver --o Manifest
Manifest --* Customer
note right of Driver : Logistics domain
@enduml