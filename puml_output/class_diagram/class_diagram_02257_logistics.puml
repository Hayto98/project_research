@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
abstract class Driver {
  #String email
  +int id
  -int status
  +saveName()
  +calculateUpdatedat()
  +calculateQuantity()
}
class Customer {
  -double note
  +long createdAt
  -Date level
  +float address
  #long quantity
  +validateDescription()
  +getCode()
  +cancelQuantity()
}
interface Warehouse {
  +boolean email
  +long amount
  -double code
  +float description
  -float active
  +findUpdatedat()
  +cancelPrice()
  +findType()
}
class Inventory {
  +int level
  +double address
  #String total
  +saveType()
  +cancelNote()
  +saveCode()
}
class Manifest {
  -int level
  -int name
  -int email
  +int phone
  #float id
  +processName()
  +updateAddress()
  +processUpdatedat()
}
interface DeliveryNote {
  +int name
  #float quantity
  -String score
  +deleteAddress()
  +calculateEmail()
  +savePhone()
  +findName()
}
DeliveryNote --o Driver
Driver --* Manifest
Inventory --|> Driver
@enduml