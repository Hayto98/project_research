@startuml
skinparam defaultFontSize 11
class Story {
  +int id
  +float quantity
  -int duration
  #String address
  +saveAmount()
}
class Hashtag {
  #int id
  -int address
  +long score
  #float phone
  +processDuration()
  +calculateActive()
  +getCreatedat()
}
interface Report {
  +int level
  -double total
  +deleteStatus()
  +cancelNote()
}
abstract class Follower {
  #float id
  +boolean code
  +saveId()
}
abstract class Notification {
  #boolean quantity
  -long address
  #String price
  -long id
  -Date email
  +processScore()
  +sendLevel()
}
Hashtag ..|> Notification
Follower --* Notification
Story --> Notification : "*"
@enduml