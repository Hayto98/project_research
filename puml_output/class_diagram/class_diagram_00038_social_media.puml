@startuml
skinparam defaultFontSize 11
class Story {
  +int id
  +float quantity
  -int duration
  #String address
  +processStatus()
}
interface Hashtag {
  #int id
  -int address
  +long score
  #float phone
  +updateActive()
  +sendActive()
  +setLevel()
}
abstract class Report {
  -int createdAt
  #int phone
  +getId()
  +setLevel()
  +getLevel()
  +cancelName()
}
class Follower {
  -Date type
  #double quantity
  -boolean address
  +double price
  -long id
  +createDescription()
  +updateUpdatedat()
}
abstract class Notification {
  +int address
  -Date status
  -boolean active
  -boolean name
  -float price
  +findAmount()
  +calculateTotal()
  +processPhone()
  +validateLevel()
}
Follower ..> Notification : "1..*"
Follower --o Report
Story --o Hashtag
Hashtag --|> Report
note right of Story : Social Media domain
@enduml