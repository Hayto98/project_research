@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
abstract class Catalog {
  +boolean quantity
  -float note
  #double updatedAt
  +saveCreatedat()
  +getDuration()
  +getCode()
  +processScore()
}
class Reservation {
  #boolean amount
  #float createdAt
  +cancelId()
  +findActive()
  +setCreatedat()
  +processDuration()
}
interface Fine {
  +boolean type
  #long amount
  #int code
  +int duration
  -float price
  +validatePrice()
  +processQuantity()
  +findCode()
  +findUpdatedat()
}
class Librarian {
  +int duration
  -long quantity
  #boolean active
  #boolean status
  -String description
  +calculatePrice()
}
class Publisher {
  #String description
  -double score
  -Date status
  +getDuration()
  +savePrice()
}
abstract class Member {
  -boolean duration
  +double total
  #String code
  +getUpdatedat()
  +processPrice()
  +validateType()
  +savePrice()
}
class Renewal {
  +float price
  #boolean address
  #float duration
  -boolean note
  +updateQuantity()
  +deleteEmail()
  +cancelName()
  +deleteName()
}
Renewal --o Catalog
Catalog --> Member : "0..1"
Fine --* Publisher
@enduml