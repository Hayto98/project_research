@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
interface Reservation {
  #boolean quantity
  -float updatedAt
  +boolean description
  +Date type
  -boolean duration
  +findDescription()
}
class Librarian {
  +boolean status
  -double active
  -long updatedAt
  -Date quantity
  #Date score
  +validateName()
  +sendEmail()
  +sendAmount()
  +processLevel()
}
class Author {
  #String quantity
  -boolean id
  +saveDuration()
  +getActive()
  +createName()
  +setAddress()
}
interface Branch {
  #float status
  #long description
  #float duration
  +setDescription()
  +findType()
}
interface Loan {
  -float total
  #int note
  +sendQuantity()
  +createDescription()
  +sendType()
}
interface Fine {
  -int price
  -String email
  +updateEmail()
  +sendQuantity()
}
interface Member {
  #Date email
  -long active
  #boolean type
  +sendName()
  +validatePrice()
  +cancelActive()
  +findCreatedat()
}
Reservation ..|> Fine
Loan --* Reservation
Reservation ..> Branch : "1..*"
Fine ..|> Member
Member ..|> Reservation
@enduml