@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
abstract class Inventory {
  -long level
  #String duration
  #String updatedAt
  -Date email
  +getNote()
  +getScore()
}
interface Vehicle {
  #float description
  -double email
  +boolean total
  +findName()
  +setEmail()
}
class Package {
  #Date createdAt
  #long address
  +boolean updatedAt
  #String amount
  +saveTotal()
  +updateAddress()
}
class Driver {
  -boolean email
  #long level
  #double id
  +updateNote()
  +getNote()
}
Vehicle ..|> Package
Driver --> Package : "0..1"
Driver ..|> Vehicle
note right of Inventory : Logistics domain
@enduml