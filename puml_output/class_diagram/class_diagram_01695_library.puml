@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Shelf {
  -String type
  +double price
  +double createdAt
  +createName()
  +cancelStatus()
  +setUpdatedat()
  +setNote()
}
class Book {
  #int updatedAt
  -String description
  -long address
  -int status
  #float name
  +updateEmail()
  +updateScore()
  +deletePrice()
}
class Branch {
  -boolean duration
  +float type
  #double status
  -float description
  -boolean active
  +setName()
}
class Reservation {
  -boolean id
  #String updatedAt
  +float type
  #long amount
  #double code
  +createAmount()
  +cancelActive()
  +processPhone()
  +processCreatedat()
}
class Loan {
  +Date type
  #boolean name
  #String address
  +String id
  +int status
  +calculateStatus()
}
Loan --|> Reservation
Book ..> Reservation : "1..*"
@enduml