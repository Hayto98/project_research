@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Shelf {
  -String type
  +double price
  +double createdAt
  +processCode()
  +getTotal()
  +validateType()
  +updateDescription()
}
class Book {
  #int score
  -String name
  +createAddress()
  +updateDuration()
  +createTotal()
}
abstract class Branch {
  #int price
  +float type
  -boolean status
  +saveNote()
  +processNote()
}
interface Reservation {
  -float id
  +int duration
  +deleteCode()
  +createLevel()
  +findStatus()
  +updateAddress()
}
interface Loan {
  +boolean price
  -String phone
  #boolean id
  +String total
  #boolean type
  +updateCode()
}
Book ..> Shelf : "1"
Loan --|> Reservation
note right of Shelf : Library domain
@enduml