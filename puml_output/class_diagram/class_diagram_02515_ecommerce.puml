@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Product {
  #boolean price
  -boolean name
  -float description
  #Date quantity
  #long note
  +createActive()
  +validateDuration()
}
interface Supplier {
  #int score
  -int description
  +findScore()
}
class Payment {
  #Date total
  -boolean score
  +updatePrice()
  +processCreatedat()
}
class Customer {
  #float phone
  -boolean id
  #float updatedAt
  +saveQuantity()
  +setPrice()
  +getType()
}
Supplier --* Payment
Payment --o Supplier
@enduml