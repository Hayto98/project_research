@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Product {
  #boolean price
  -boolean name
  -float description
  #Date quantity
  #long note
  +validateAddress()
  +cancelStatus()
}
interface Supplier {
  +String duration
  -float description
  +float phone
  +calculateDuration()
}
interface Payment {
  -float score
  +float description
  +Date id
  -boolean email
  #float level
  +deleteCode()
  +getDescription()
  +sendAddress()
}
class Customer {
  -float type
  #String description
  +Date score
  #float level
  #double name
  +setType()
}
Supplier --* Payment
Payment --> Supplier : "*"
note right of Product : Ecommerce domain
@enduml