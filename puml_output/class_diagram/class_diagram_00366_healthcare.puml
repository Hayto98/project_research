@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
interface Billing {
  #double code
  -int quantity
  -double amount
  #Date updatedAt
  +deleteActive()
  +findLevel()
  +calculateId()
  +processNote()
}
class MedicalRecord {
  +boolean quantity
  #int address
  +createLevel()
  +getPhone()
}
class Diagnosis {
  +float email
  -Date note
  #String type
  +long status
  +updateNote()
  +createLevel()
}
class Patient {
  -String email
  +String quantity
  #Date id
  #Date price
  -int phone
  +updatePrice()
}
interface Appointment {
  -long type
  +double phone
  +Date level
  +int updatedAt
  +validatePhone()
  +sendUpdatedat()
  +findId()
}
interface Nurse {
  +String active
  #boolean address
  #float createdAt
  +long code
  +saveName()
  +sendType()
}
class Treatment {
  #int level
  -long score
  +updateQuantity()
  +processTotal()
  +setNote()
  +calculatePhone()
}
Treatment --o Appointment
Treatment --> Nurse : "1..*"
MedicalRecord --> Appointment : "0..1"
@enduml