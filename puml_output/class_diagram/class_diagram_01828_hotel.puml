@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
abstract class Payment {
  -Date address
  +String name
  -float type
  -boolean duration
  -boolean active
  +setAddress()
  +setScore()
  +findAmount()
}
class Booking {
  #String total
  #double email
  +boolean price
  +calculateStatus()
  +cancelEmail()
  +deleteAmount()
  +findDuration()
}
interface Room {
  #float active
  -Date quantity
  #boolean total
  +setScore()
  +processCode()
}
class Invoice {
  -long updatedAt
  +Date amount
  +calculateQuantity()
  +sendLevel()
  +deleteCode()
}
interface Amenity {
  #double type
  -int createdAt
  +sendUpdatedat()
  +sendTotal()
  +setId()
}
class Staff {
  -double quantity
  -long level
  #String address
  +sendQuantity()
}
Room ..|> Booking
Staff ..|> Invoice
@enduml