@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
interface Notification {
  +Date total
  -int price
  +boolean amount
  -Date id
  +setCreatedat()
}
interface Comment {
  -double total
  #boolean id
  #float code
  +sendTotal()
}
class Follower {
  +int level
  -double description
  #boolean price
  #float createdAt
  +processDuration()
  +updateAmount()
  +validateId()
}
class Report {
  -boolean description
  -boolean active
  +findPhone()
  +createName()
  +validateCreatedat()
}
interface User {
  +double level
  -long code
  +float total
  +sendQuantity()
}
User ..|> Notification
Follower --> User : "*"
Notification --> User : "*"
@enduml