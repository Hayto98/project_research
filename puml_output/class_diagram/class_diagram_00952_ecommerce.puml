@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Warehouse {
  #float price
  -long amount
  -boolean email
  +Date duration
  -float note
  +validateActive()
  +cancelNote()
  +cancelPrice()
}
class Order {
  +long active
  -boolean amount
  #String createdAt
  -String type
  -double id
  +cancelEmail()
  +cancelUpdatedat()
  +processAmount()
  +saveUpdatedat()
}
class Invoice {
  +String code
  -boolean level
  +updateAddress()
}
class Review {
  +Date code
  -boolean email
  +findUpdatedat()
  +validateType()
  +setCode()
  +saveAmount()
}
class Return {
  -double updatedAt
  #boolean amount
  #boolean name
  -float phone
  +String code
  +setEmail()
  +calculateStatus()
}
class Shipment {
  +Date email
  -float phone
  +boolean quantity
  -double active
  #float name
  +setActive()
  +sendAddress()
  +validateId()
  +cancelLevel()
}
Order --> Warehouse : "*"
Invoice ..> Order : "1"
Shipment ..> Invoice : "1"
Order --|> Shipment
@enduml