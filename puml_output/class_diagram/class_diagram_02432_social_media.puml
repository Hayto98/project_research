@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Report {
  -Date status
  +String id
  -Date type
  +updateId()
  +sendCreatedat()
  +processId()
  +sendDescription()
}
abstract class Profile {
  +String email
  -Date phone
  +String updatedAt
  -long name
  #Date address
  +createLevel()
  +findCreatedat()
}
abstract class User {
  +boolean score
  -boolean email
  +validateTotal()
  +getNote()
  +deleteNote()
}
class Comment {
  -long code
  -Date status
  +findCreatedat()
  +getUpdatedat()
  +getQuantity()
  +processAddress()
}
abstract class Message {
  +String active
  #int description
  -boolean total
  -boolean score
  -double type
  +setAmount()
  +calculateAddress()
  +validateType()
  +deletePhone()
}
interface Hashtag {
  #Date level
  -String phone
  #long id
  +sendAmount()
  +createAddress()
  +saveAmount()
}
Report ..|> User
Comment --* Report
Report ..|> Hashtag
Profile --> Message : "*"
note right of Report : Social Media domain
@enduml