@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Shipment {
  #float note
  +double quantity
  +String code
  +validateDescription()
}
interface FuelLog {
  +int email
  +long status
  +createName()
  +getScore()
  +setCreatedat()
}
abstract class Warehouse {
  #float note
  #float amount
  -double active
  -boolean address
  +sendPrice()
  +validateUpdatedat()
}
abstract class Vehicle {
  #double description
  +long total
  +createPrice()
}
interface Customer {
  #float amount
  -float address
  -float email
  -double updatedAt
  +saveAmount()
  +cancelLevel()
  +createCode()
}
class Driver {
  #Date address
  +boolean createdAt
  +double id
  +Date duration
  +getAddress()
}
Shipment --* Vehicle
Shipment ..|> Customer
note right of Shipment : Logistics domain
@enduml