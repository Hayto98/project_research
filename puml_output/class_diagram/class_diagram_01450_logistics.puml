@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Shipment {
  #float note
  +double quantity
  +String code
  +saveCreatedat()
}
class FuelLog {
  +int email
  +long status
  +processDescription()
  +deleteLevel()
  +cancelType()
}
class Warehouse {
  +double score
  #long status
  +processUpdatedat()
  +validateTotal()
  +getStatus()
  +deleteTotal()
}
interface Vehicle {
  #double phone
  -float total
  +double duration
  +float createdAt
  +saveType()
  +calculateQuantity()
}
abstract class Customer {
  -boolean email
  -int id
  -long quantity
  +saveUpdatedat()
  +sendLevel()
}
class Driver {
  #float total
  #long price
  +int quantity
  #boolean amount
  +calculateName()
  +findLevel()
  +sendId()
}
Driver ..> Warehouse : "0..1"
Customer --o FuelLog
@enduml