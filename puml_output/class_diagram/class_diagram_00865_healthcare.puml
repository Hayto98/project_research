@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Hospital {
  -String status
  +double email
  +updateScore()
  +validateActive()
  +cancelPrice()
}
class Insurance {
  #Date updatedAt
  #int address
  -int score
  +findLevel()
  +processPhone()
}
class Doctor {
  -boolean amount
  #float score
  +findStatus()
  +cancelPhone()
  +createAmount()
  +processUpdatedat()
}
class Appointment {
  -boolean duration
  #int active
  -boolean score
  +updateDescription()
}
abstract class Nurse {
  #float level
  #double id
  +long phone
  #boolean price
  +int quantity
  +saveCreatedat()
}
class MedicalRecord {
  -boolean description
  -String level
  +createDuration()
  +cancelType()
}
Insurance --|> MedicalRecord
Insurance --|> Doctor
Insurance ..|> Appointment
MedicalRecord ..> Doctor : "*"
Doctor ..|> Appointment
@enduml