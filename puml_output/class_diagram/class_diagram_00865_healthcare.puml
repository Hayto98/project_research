@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Hospital {
  -String status
  +double email
  +findDuration()
  +saveDescription()
  +updateUpdatedat()
}
class Insurance {
  +float email
  +int description
  #long amount
  +saveEmail()
  +validateAmount()
  +deleteCreatedat()
  +saveDuration()
}
interface Doctor {
  -Date level
  -boolean createdAt
  #String phone
  -float status
  -Date duration
  +cancelActive()
  +calculateId()
  +createDuration()
}
class Appointment {
  #String status
  +boolean address
  -boolean updatedAt
  +getUpdatedat()
  +calculateActive()
  +processUpdatedat()
}
class Nurse {
  +float createdAt
  +double quantity
  +findEmail()
  +findLevel()
}
abstract class MedicalRecord {
  #long price
  -long description
  #float note
  #float level
  +getAmount()
  +updateNote()
  +findEmail()
  +deleteAddress()
}
Insurance ..|> Hospital
note right of Hospital : Healthcare domain
