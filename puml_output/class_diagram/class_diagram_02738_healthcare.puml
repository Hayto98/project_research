@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Hospital {
  -String active
  -float code
  +int total
  #double score
  -String price
  +createCreatedat()
  +validateType()
  +cancelPrice()
  +createTotal()
}
class Appointment {
  -long code
  +long address
  -String active
  -boolean phone
  +float note
  +createId()
  +calculateAmount()
  +getTotal()
}
class MedicalRecord {
  #int active
  -String name
  +sendLevel()
  +calculateAmount()
  +calculateActive()
}
class Ward {
  -long amount
  -double id
  +long description
  #double duration
  #boolean updatedAt
  +findPrice()
  +deleteStatus()
}
class LabTest {
  #float score
  -float quantity
  +boolean active
  +setStatus()
  +validateCode()
  +sendDescription()
  +createUpdatedat()
}
class Insurance {
  -long note
  -float type
  +float active
  +findNote()
  +setDescription()
  +getCode()
  +cancelScore()
}
Insurance ..> Hospital : "1"
Appointment --* MedicalRecord
Ward ..|> Hospital
@enduml