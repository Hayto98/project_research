@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Supplier {
  -int price
  #long amount
  #double phone
  #boolean code
  +sendQuantity()
}
class Review {
  +Date updatedAt
  -float phone
  +long description
  +findId()
  +deleteEmail()
  +deleteUpdatedat()
}
interface Customer {
  +float note
  -boolean level
  +int amount
  +findTotal()
  +updateAddress()
  +deletePhone()
  +validateAddress()
}
class Product {
  #long level
  +Date createdAt
  #Date duration
  -float id
  +createEmail()
}
interface Cart {
  #double email
  +int code
  +int level
  #int score
  +long active
  +updateCreatedat()
  +processTotal()
  +processUpdatedat()
}
Customer --o Review
note right of Supplier : Ecommerce domain
@enduml