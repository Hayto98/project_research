@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Supplier {
  -int price
  #long amount
  #double phone
  #boolean code
  +sendAmount()
}
class Review {
  -int createdAt
  +Date updatedAt
  +deleteId()
  +validateType()
  +updateActive()
  +createQuantity()
}
class Customer {
  +int description
  #Date email
  +validateTotal()
  +calculateStatus()
}
abstract class Product {
  +float code
  #double address
  #double duration
  +calculateName()
  +setLevel()
}
class Cart {
  +String address
  #long createdAt
  +Date email
  #Date level
  +processScore()
  +saveEmail()
  +updateLevel()
}
Cart --* Product
Supplier --|> Cart
Supplier ..|> Product
@enduml