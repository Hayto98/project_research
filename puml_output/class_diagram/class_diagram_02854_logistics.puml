@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Manifest {
  #Date phone
  +String duration
  #float name
  #String active
  +calculateName()
  +deleteActive()
  +getStatus()
}
interface Shipment {
  #float createdAt
  +boolean address
  #long type
  +setTotal()
  +processAddress()
}
class Inventory {
  #String status
  +boolean duration
  +calculateType()
  +setName()
  +calculateActive()
  +validateStatus()
}
class Driver {
  +float status
  #String quantity
  -boolean duration
  #float level
  #int amount
  +createTotal()
  +deleteNote()
  +createPrice()
  +processActive()
}
class DeliveryNote {
  +String description
  -int status
  +validateTotal()
  +processTotal()
  +cancelCode()
}
Shipment ..|> Manifest
DeliveryNote --> Inventory : "0..1"
DeliveryNote ..> Shipment : "*"
@enduml