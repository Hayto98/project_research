@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
interface Customer {
  +int name
  #long address
  #String createdAt
  +double price
  #Date email
  +processPrice()
  +deleteDuration()
}
class Interest {
  #float createdAt
  +int duration
  +calculateName()
  +getType()
  +createPhone()
  +calculateCreatedat()
}
interface Withdrawal {
  #boolean updatedAt
  #float status
  #boolean description
  +setNote()
  +updateLevel()
  +setTotal()
  +setCreatedat()
}
class Transfer {
  -boolean quantity
  +Date total
  +validateType()
  +sendAmount()
  +createCreatedat()
  +findEmail()
}
class Teller {
  #float total
  -Date price
  +float type
  +deletePhone()
  +processDuration()
  +deleteTotal()
  +setCreatedat()
}
class Card {
  +boolean createdAt
  +Date total
  #long phone
  +saveNote()
  +calculateCode()
  +calculateId()
  +calculateTotal()
}
Interest --|> Teller
Customer ..> Transfer : "0..1"
Transfer ..|> Withdrawal
Transfer --> Interest : "1"
note right of Customer : Banking domain
@enduml