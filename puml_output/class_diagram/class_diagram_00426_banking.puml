@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
interface Customer {
  +int name
  #long address
  #String createdAt
  +double price
  #Date email
  +cancelCode()
  +deleteAmount()
}
class Interest {
  #float id
  +int createdAt
  -double level
  +setName()
}
abstract class Withdrawal {
  +boolean phone
  +boolean price
  +boolean createdAt
  #float score
  +findNote()
  +calculateLevel()
  +updateScore()
  +deletePrice()
}
class Transfer {
  +String total
  +Date status
  +createType()
  +updateCode()
  +getPhone()
}
abstract class Teller {
  #float note
  +long phone
  +Date type
  +sendDescription()
  +findQuantity()
  +getDuration()
}
class Card {
  #double duration
  +long price
  -float type
  #int total
  -String status
  +validateCode()
  +processActive()
}
Transfer ..|> Withdrawal
Teller ..> Customer : "1..*"
Card ..> Transfer : "*"
@enduml