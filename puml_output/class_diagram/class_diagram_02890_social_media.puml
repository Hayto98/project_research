@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Post {
  -String updatedAt
  -boolean status
  +getLevel()
  +saveActive()
}
class Profile {
  -int createdAt
  -double price
  +sendScore()
  +findAddress()
  +validateScore()
}
class Like {
  +int status
  -long amount
  +Date duration
  +int price
  +updateName()
  +updatePrice()
  +sendId()
}
class Hashtag {
  -Date quantity
  #long createdAt
  -long phone
  #String address
  #Date note
  +cancelDuration()
  +calculateCode()
  +cancelTotal()
}
class Notification {
  #float duration
  -long address
  +String id
  +double type
  +Date price
  +cancelName()
  +sendNote()
}
class Message {
  -double createdAt
  -int id
  +getActive()
  +deleteCreatedat()
  +cancelLevel()
  +findPrice()
}
class Follower {
  #int price
  +Date phone
  #Date total
  #int description
  +getStatus()
}
Like ..|> Profile
Like --> Notification : "1"
Profile ..> Hashtag : "1..*"
Profile --* Like
Message --o Profile
note right of Post : Social Media domain
@enduml