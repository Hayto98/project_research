@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Post {
  -String updatedAt
  -boolean status
  +updatePrice()
  +calculateStatus()
}
interface Profile {
  -long status
  +long createdAt
  +sendAmount()
  +calculateCreatedat()
  +setPrice()
  +createUpdatedat()
}
interface Like {
  +Date address
  #Date score
  +String email
  #double duration
  +saveAddress()
  +processScore()
}
class Hashtag {
  #long status
  +float updatedAt
  +float level
  +double active
  +validateCreatedat()
}
abstract class Notification {
  -Date createdAt
  #long phone
  -long address
  #String note
  +findUpdatedat()
  +getQuantity()
  +deleteAmount()
}
class Message {
  -Date createdAt
  -long price
  +String address
  +double id
  +Date type
  +findDescription()
  +calculateId()
}
interface Follower {
  -long status
  +double id
  +boolean createdAt
  +int level
  #boolean address
  +processName()
  +deleteCode()
  +getStatus()
  +getUpdatedat()
}
Like --o Message
Profile ..|> Message
Post ..> Message : "0..1"
Post --|> Follower
Follower --> Message : "1..*"
@enduml