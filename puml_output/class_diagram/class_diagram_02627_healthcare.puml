@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
abstract class Diagnosis {
  +double type
  #Date amount
  -String name
  -int phone
  #double duration
  +saveEmail()
  +updateId()
  +sendCreatedat()
}
class Ward {
  -int name
  -long updatedAt
  -Date email
  +deleteQuantity()
  +calculateAmount()
  +getPhone()
  +processActive()
}
interface Prescription {
  #Date note
  #int address
  #boolean level
  +createPrice()
}
interface Appointment {
  -String amount
  +String name
  +Date id
  +String status
  +sendDescription()
  +findNote()
  +createAmount()
  +calculateDuration()
}
class LabTest {
  #float total
  -float amount
  +Date phone
  +saveStatus()
}
Prescription --> Appointment : "1"
LabTest --> Diagnosis : "1..*"
Ward --* LabTest
Appointment --|> Ward
@enduml