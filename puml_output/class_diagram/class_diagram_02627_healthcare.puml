@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
abstract class Diagnosis {
  +double type
  #Date amount
  -String name
  -int phone
  #double duration
  +getType()
  +createAmount()
  +getUpdatedat()
}
class Ward {
  #float updatedAt
  -String email
  -double quantity
  +boolean phone
  +processAddress()
  +validateDuration()
}
class Prescription {
  -int price
  +String level
  +createCode()
}
class Appointment {
  +double description
  +long createdAt
  +findCreatedat()
  +calculateAmount()
  +validateActive()
}
abstract class LabTest {
  #double id
  #boolean score
  +boolean address
  +cancelScore()
}
Ward --* LabTest
Appointment --|> Ward
Diagnosis ..|> LabTest
note right of Diagnosis : Healthcare domain
@enduml