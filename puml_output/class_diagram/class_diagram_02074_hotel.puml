@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Service {
  -double code
  #Date updatedAt
  +getStatus()
  +findDuration()
  +setCreatedat()
  +validateDescription()
}
class CheckOut {
  #Date description
  +Date name
  -String score
  +processAddress()
  +getTotal()
  +cancelPrice()
  +findNote()
}
class Booking {
  -Date address
  +String amount
  +Date total
  +saveStatus()
  +deleteAddress()
  +deletePrice()
  +findEmail()
}
abstract class Reservation {
  -Date level
  +float name
  -String createdAt
  #String description
  +getLevel()
  +setNote()
  +sendType()
  +createType()
}
class Housekeeping {
  +double amount
  +double code
  +double quantity
  +cancelNote()
  +setId()
  +deleteCode()
}
interface Room {
  +Date duration
  #double address
  #String status
  +Date code
  +float note
  +findTotal()
}
class CheckIn {
  #float status
  -int note
  -float price
  +String total
  +setName()
  +updateId()
  +processUpdatedat()
}
Service ..> Booking : "1"
CheckIn --o CheckOut
Service --* CheckOut
Reservation --* CheckOut
Housekeeping --* CheckOut
@enduml