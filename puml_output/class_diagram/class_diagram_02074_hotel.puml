@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Service {
  -double code
  #Date updatedAt
  +sendDescription()
  +cancelUpdatedat()
  +deleteName()
  +cancelScore()
}
class CheckOut {
  +Date code
  -int total
  -long createdAt
  #int duration
  +int email
  +updateNote()
  +findType()
  +validateLevel()
  +getCreatedat()
}
class Booking {
  #double code
  +double address
  #Date status
  +float name
  +deleteDuration()
  +setQuantity()
}
class Reservation {
  +boolean amount
  -float price
  #double createdAt
  #long total
  +String email
  +deleteScore()
  +processCode()
  +updateId()
  +sendStatus()
}
class Housekeeping {
  #float status
  -int note
  -float price
  +String total
  +getAmount()
  +processName()
  +validateCode()
}
class Room {
  -boolean status
  +long createdAt
  +double email
  #Date total
  +long level
  +processType()
  +cancelAmount()
  +cancelNote()
  +createId()
}
class CheckIn {
  +float duration
  #Date id
  #boolean name
  #boolean quantity
  +saveScore()
}
CheckOut --> Reservation : "*"
Housekeeping --o CheckOut
Room ..|> Housekeeping
Reservation ..> Room : "*"
note right of Service : Hotel domain
@enduml