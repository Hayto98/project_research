@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Inventory {
  +float name
  +int amount
  -float address
  +saveType()
  +validateUpdatedat()
  +createPhone()
  +calculateType()
}
class Route {
  -double amount
  +int total
  #double code
  #long quantity
  +String createdAt
  +getAddress()
}
class Shipment {
  #Date address
  -boolean total
  #String updatedAt
  +cancelTotal()
  +setType()
  +getPrice()
}
class Depot {
  -Date score
  +boolean type
  -double price
  +processTotal()
  +calculateEmail()
  +processPhone()
  +findDescription()
}
abstract class Driver {
  -long duration
  +boolean level
  #int updatedAt
  +setName()
  +validateAddress()
  +createAddress()
}
class Manifest {
  +int note
  #long type
  #double updatedAt
  -int quantity
  +setStatus()
  +calculateAmount()
  +validateQuantity()
  +findUpdatedat()
}
class Warehouse {
  -Date level
  #Date type
  +updateActive()
}
Inventory --> Driver : "0..1"
Shipment --> Driver : "*"
Inventory --* Route
@enduml