@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Review {
  -boolean duration
  -Date note
  +setDescription()
  +getQuantity()
}
class Coupon {
  #Date quantity
  -Date active
  +double amount
  +long phone
  #double total
  +calculateStatus()
}
class Order {
  -boolean score
  -double amount
  +boolean updatedAt
  +Date address
  -String active
  +saveLevel()
  +validateDuration()
}
interface Category {
  #boolean price
  +double score
  #float phone
  +long address
  #int type
  +findEmail()
  +validateStatus()
}
abstract class Warehouse {
  +double quantity
  +float address
  +double code
  -Date email
  +processId()
  +saveAddress()
}
class Cart {
  #double quantity
  +boolean phone
  +boolean type
  +cancelCreatedat()
}
abstract class Wishlist {
  -long quantity
  +String note
  #String createdAt
  +updateUpdatedat()
  +processId()
  +setAmount()
}
Category ..> Order : "*"
Wishlist --|> Review
Review --* Category
@enduml