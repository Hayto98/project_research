@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Review {
  -boolean duration
  -Date note
  +setDuration()
  +validatePrice()
}
class Coupon {
  #String phone
  -int total
  -float type
  +findCode()
  +findName()
  +calculateScore()
  +deleteUpdatedat()
}
class Order {
  +boolean email
  +Date active
  -String note
  #Date total
  +validateScore()
  +cancelPrice()
}
abstract class Category {
  -boolean address
  +long type
  #int active
  #int updatedAt
  +sendEmail()
  +createAddress()
  +saveCode()
  +createDescription()
}
abstract class Warehouse {
  #float description
  +boolean price
  +long type
  +createPhone()
  +processType()
}
class Cart {
  -boolean active
  +float name
  -double total
  +calculatePhone()
  +setId()
}
class Wishlist {
  -Date status
  -float level
  +String createdAt
  +double total
  +setUpdatedat()
  +processAddress()
  +processNote()
}
Category ..> Coupon : "*"
Wishlist --* Coupon
Cart ..> Order : "*"
Coupon --> Wishlist : "1..*"
Order --|> Wishlist
Category ..|> Order
note right of Review : Ecommerce domain
@enduml