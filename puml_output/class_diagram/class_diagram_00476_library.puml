@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Shelf {
  -long note
  -String status
  -int total
  +processActive()
  +getCreatedat()
  +saveCreatedat()
  +findStatus()
}
interface Publisher {
  -String createdAt
  +boolean code
  +Date quantity
  #Date id
  -String price
  +createPrice()
  +saveStatus()
}
abstract class Renewal {
  #boolean total
  +int active
  +Date type
  +boolean status
  +double description
  +calculateCode()
}
class Librarian {
  #boolean id
  #int active
  #double email
  +boolean updatedAt
  +Date note
  +deleteName()
  +createAddress()
}
Renewal ..|> Publisher
Publisher ..> Shelf : "*"
@enduml