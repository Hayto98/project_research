@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Shelf {
  -long note
  -String status
  -int total
  +updateScore()
  +validateScore()
  +processCreatedat()
  +cancelCode()
}
class Publisher {
  +String price
  #String email
  +getCreatedat()
  +calculatePrice()
  +calculateScore()
  +calculateTotal()
}
interface Renewal {
  +Date status
  +boolean description
  +double score
  #String id
  -long level
  +getActive()
  +createLevel()
  +findUpdatedat()
  +saveNote()
}
interface Librarian {
  +Date note
  +long name
  +float active
  +validatePrice()
}
Publisher ..> Shelf : "*"
note right of Shelf : Library domain
@enduml