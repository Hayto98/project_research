@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Return {
  +String name
  -long active
  +double updatedAt
  +double status
  #double score
  +createEmail()
  +saveCode()
  +getPrice()
  +findUpdatedat()
}
abstract class Supplier {
  -String email
  +double quantity
  #int amount
  +validateUpdatedat()
  +deleteQuantity()
}
class Payment {
  -long description
  #Date note
  +processQuantity()
}
class Warehouse {
  +String phone
  #String email
  -double type
  +float note
  +updateDuration()
  +calculateDuration()
  +findActive()
  +sendPrice()
}
class Wishlist {
  +Date type
  -long score
  +validateCode()
  +sendAmount()
  +deleteNote()
}
class Invoice {
  +String createdAt
  #int level
  #Date code
  +float score
  +validateCode()
  +getScore()
}
class Cart {
  +float amount
  +String createdAt
  +getId()
}
Return ..> Invoice : "0..1"
Warehouse --* Supplier
Supplier --o Warehouse
Payment --o Invoice
Payment --> Warehouse : "0..1"
Wishlist ..> Payment : "*"
@enduml