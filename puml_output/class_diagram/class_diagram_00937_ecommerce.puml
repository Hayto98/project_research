@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Return {
  +String name
  -long active
  +double updatedAt
  +double status
  #double score
  +calculateDuration()
  +processCreatedat()
  +createQuantity()
  +deleteTotal()
}
class Supplier {
  -String type
  #String createdAt
  +int updatedAt
  +processEmail()
  +findCode()
  +getQuantity()
  +validatePhone()
}
class Payment {
  -String note
  -String id
  #double level
  #String name
  +double address
  +saveType()
  +validatePhone()
}
class Warehouse {
  +boolean id
  +String phone
  +getAmount()
}
interface Wishlist {
  -String amount
  +Date description
  #float active
  +getDescription()
  +setId()
}
abstract class Invoice {
  +long updatedAt
  +double price
  +createPrice()
  +createTotal()
  +sendLevel()
  +saveAmount()
}
interface Cart {
  +Date type
  -long price
  -long quantity
  -String updatedAt
  +calculateStatus()
  +validatePrice()
}
Invoice ..|> Cart
Wishlist --|> Return
note right of Return : Ecommerce domain
@enduml