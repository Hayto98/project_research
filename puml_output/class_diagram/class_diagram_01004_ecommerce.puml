@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Payment {
  #double level
  -double email
  +processNote()
  +createCode()
}
class Invoice {
  +double description
  -Date price
  +Date address
  +setType()
}
class Cart {
  -int code
  +int level
  #int address
  +int phone
  +sendId()
  +deleteCreatedat()
  +setAmount()
}
class Category {
  -int status
  -int score
  +float note
  +Date id
  +float description
  +getStatus()
  +processEmail()
  +getEmail()
  +processDuration()
}
interface Wishlist {
  -double status
  #String updatedAt
  +validatePhone()
  +setDescription()
  +findScore()
}
class Order {
  +boolean type
  +long status
  +findActive()
}
Invoice --> Order : "1"
Payment --|> Order
@enduml