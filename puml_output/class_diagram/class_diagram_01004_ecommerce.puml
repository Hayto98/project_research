@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Payment {
  #double level
  -double email
  +saveAmount()
  +deleteAmount()
}
class Invoice {
  #String address
  +int createdAt
  -Date price
  +boolean total
  -long status
  +updateUpdatedat()
  +deleteDescription()
  +getUpdatedat()
  +validateCreatedat()
}
class Cart {
  -String price
  +long status
  +long score
  +setDescription()
  +findAmount()
}
abstract class Category {
  #float updatedAt
  +int level
  -double name
  +findAddress()
}
class Wishlist {
  +double quantity
  +int id
  +createDuration()
}
interface Order {
  +int type
  #boolean id
  +setCode()
}
Payment ..|> Cart
Payment --o Order
note right of Payment : Ecommerce domain
@enduml