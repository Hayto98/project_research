@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
abstract class Teller {
  #double name
  -float status
  #Date total
  +findUpdatedat()
  +updateStatus()
  +updateQuantity()
  +validateType()
}
class Loan {
  -Date note
  +double total
  -Date price
  #String updatedAt
  +calculateAddress()
}
class Customer {
  -String name
  -String status
  +long quantity
  +setStatus()
  +processAmount()
  +calculateScore()
  +createNote()
}
interface Interest {
  #float status
  -int id
  #double updatedAt
  -int total
  +createQuantity()
  +findActive()
}
Customer --> Loan : "1..*"
Loan --o Teller
Interest ..|> Customer
@enduml