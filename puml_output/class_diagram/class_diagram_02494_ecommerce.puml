@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Review {
  -String status
  #long note
  +double code
  +long email
  +int name
  +validateActive()
  +getPrice()
  +sendDuration()
}
class Order {
  #long name
  -double price
  -long note
  -String createdAt
  +saveAmount()
}
abstract class Shipment {
  #int description
  -boolean id
  +long active
  +int quantity
  -double price
  +calculateNote()
  +saveUpdatedat()
}
interface Coupon {
  #long email
  #double total
  -double createdAt
  +getAddress()
  +calculateDescription()
  +sendCode()
  +calculateEmail()
}
Review --o Shipment
Review ..> Coupon : "1..*"
@enduml