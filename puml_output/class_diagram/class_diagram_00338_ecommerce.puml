@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Return {
  #double amount
  #long duration
  #String id
  #double level
  +getEmail()
  +cancelNote()
}
class Shipment {
  +int score
  #float status
  -String quantity
  +double phone
  +double duration
  +sendDescription()
  +findTotal()
  +cancelName()
  +createEmail()
}
abstract class Order {
  +double address
  +String total
  +validateAddress()
  +findId()
  +processDescription()
  +calculateId()
}
interface Category {
  +long quantity
  #Date code
  +validateNote()
  +createLevel()
}
class Review {
  #long phone
  #long email
  #float status
  +validateType()
}
interface Supplier {
  #float level
  #String duration
  +double updatedAt
  +updateDuration()
  +saveCode()
  +processAddress()
  +getAddress()
}
class Warehouse {
  #Date score
  -float address
  -long note
  +sendAmount()
  +validateLevel()
  +cancelDuration()
  +getId()
}
Category --* Warehouse
Review --* Return
Order --> Shipment : "*"
note right of Return : Ecommerce domain
@enduml