@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Return {
  #double amount
  #long duration
  #String id
  #double level
  +setUpdatedat()
  +setScore()
}
class Shipment {
  #long id
  #long price
  +int score
  #float status
  -String quantity
  +cancelQuantity()
}
class Order {
  -long note
  -String score
  -double description
  +double total
  +String name
  +saveCreatedat()
  +createTotal()
  +getAmount()
  +validateScore()
}
class Category {
  +int description
  -boolean price
  #int id
  -double code
  -Date quantity
  +updatePhone()
  +findAddress()
  +setQuantity()
}
class Review {
  #float status
  #Date email
  #String active
  -double phone
  +processId()
  +findName()
}
interface Supplier {
  -Date level
  -float name
  +boolean createdAt
  +getId()
}
class Warehouse {
  +boolean address
  -double duration
  +deleteTotal()
  +findTotal()
  +getDuration()
  +cancelCode()
}
Review --> Category : "0..1"
Warehouse --> Order : "1"
Warehouse ..|> Return
Category --* Warehouse
@enduml