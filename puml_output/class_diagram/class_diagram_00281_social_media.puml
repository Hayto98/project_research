@startuml
skinparam monochrome true
skinparam defaultFontSize 11
abstract class Message {
  #String phone
  +float price
  #int code
  #float active
  -String amount
  +sendUpdatedat()
  +saveStatus()
}
class Report {
  #long duration
  +float amount
  +int score
  -double phone
  +calculateCreatedat()
  +cancelScore()
}
abstract class Profile {
  #int id
  #String createdAt
  #Date score
  #float address
  #float price
  +findActive()
}
class Post {
  #float name
  -int level
  +Date amount
  #int note
  -float code
  +validateTotal()
}
class Hashtag {
  -Date status
  +double updatedAt
  -boolean id
  #Date phone
  +Date level
  +cancelPrice()
}
interface Album {
  #Date description
  -double updatedAt
  -String amount
  #String code
  -int note
  +validateCreatedat()
}
Post ..|> Message
Post --o Album
@enduml