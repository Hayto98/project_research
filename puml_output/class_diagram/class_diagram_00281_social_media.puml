@startuml
skinparam monochrome true
skinparam defaultFontSize 11
abstract class Message {
  #String phone
  +float price
  #int code
  #float active
  -String amount
  +findQuantity()
  +createDuration()
}
class Report {
  +float active
  -double quantity
  +long createdAt
  #Date id
  +calculateId()
  +saveCreatedat()
  +sendAddress()
  +findPrice()
}
interface Profile {
  -String duration
  -String name
  #Date status
  +findNote()
  +findScore()
}
class Post {
  -float description
  #float createdAt
  +Date active
  #Date amount
  +processStatus()
  +findUpdatedat()
}
class Hashtag {
  -boolean updatedAt
  #Date note
  +Date duration
  +Date total
  +findDescription()
  +findUpdatedat()
  +deleteCode()
  +findNote()
}
abstract class Album {
  +String phone
  +String status
  -String score
  +double name
  -float type
  +validateType()
  +createStatus()
  +calculateScore()
  +sendEmail()
}
Album --|> Profile
Hashtag --|> Post
note right of Message : Social Media domain
@enduml