@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Appointment {
  -float type
  #boolean status
  +deleteEmail()
  +saveAddress()
}
interface Insurance {
  #int price
  -String duration
  +createDuration()
}
abstract class Diagnosis {
  #boolean description
  #float score
  +float code
  +getUpdatedat()
  +deleteAmount()
}
class Billing {
  +double status
  -boolean code
  #float amount
  #int email
  +saveNote()
  +deleteType()
  +sendName()
  +deleteScore()
}
class Doctor {
  +int level
  #double updatedAt
  #int address
  +sendTotal()
}
class Hospital {
  #Date note
  -long phone
  -long price
  -long code
  +savePhone()
  +sendActive()
  +getName()
}
abstract class Treatment {
  #boolean description
  +double address
  +double duration
  -Date total
  -String id
  +cancelTotal()
  +deleteCode()
  +getPrice()
  +getType()
}
Insurance --o Treatment
Hospital ..> Diagnosis : "0..1"
Insurance --> Diagnosis : "1..*"
Doctor ..|> Hospital
Diagnosis --> Hospital : "0..1"
Doctor --> Treatment : "0..1"
note right of Appointment : Healthcare domain
@enduml