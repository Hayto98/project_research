@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Appointment {
  -float type
  #boolean status
  +validateQuantity()
  +deleteCreatedat()
}
class Insurance {
  #int price
  -String duration
  +validateAddress()
}
interface Diagnosis {
  #int amount
  +int description
  +Date score
  #int code
  -long updatedAt
  +processAmount()
}
class Billing {
  +float id
  -Date price
  -int quantity
  -boolean active
  +saveAddress()
}
interface Doctor {
  -int amount
  +Date level
  -boolean updatedAt
  +savePhone()
  +sendQuantity()
}
abstract class Hospital {
  -double quantity
  #String note
  +createAmount()
  +createQuantity()
  +processStatus()
}
abstract class Treatment {
  +String address
  -double phone
  +long score
  +double active
  +processAddress()
}
Doctor --o Insurance
Treatment --o Insurance
Diagnosis --o Hospital
Appointment --> Billing : "*"
Insurance --|> Appointment
Billing --o Appointment
@enduml