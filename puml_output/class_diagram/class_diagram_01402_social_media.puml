@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
interface User {
  #Date code
  +long email
  #String address
  #int updatedAt
  +sendType()
  +getLevel()
  +getId()
}
interface Comment {
  #long score
  +float description
  -String address
  #String phone
  -int updatedAt
  +validateScore()
  +processTotal()
  +setTotal()
}
abstract class Hashtag {
  +long score
  -int total
  +String active
  #int level
  -int id
  +findCode()
  +updateScore()
}
class Follower {
  +double email
  #double level
  +Date address
  -double note
  +setDuration()
  +validateAmount()
  +processType()
  +processCreatedat()
}
class Post {
  -Date phone
  +boolean createdAt
  -int type
  +cancelName()
}
class Story {
  +Date level
  -boolean duration
  +boolean description
  +long email
  +cancelAddress()
  +saveEmail()
  +deletePrice()
  +setCode()
}
class Album {
  +String score
  +double type
  +int address
  +saveCode()
  +deleteActive()
  +createCode()
}
Comment --* Hashtag
Album --> Follower : "0..1"
Follower --> User : "0..1"
note right of User : Social Media domain
@enduml