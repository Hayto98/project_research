@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
interface User {
  #Date code
  +long email
  #String address
  #int updatedAt
  +sendQuantity()
  +sendName()
  +updateActive()
}
interface Comment {
  -boolean id
  +float level
  +deleteCode()
  +createTotal()
  +processDuration()
}
class Hashtag {
  -int total
  #long name
  -boolean level
  +findAmount()
  +saveTotal()
  +createAddress()
  +cancelName()
}
abstract class Follower {
  +int note
  -float score
  -int total
  +String active
  #int level
  +setType()
  +createScore()
  +deletePhone()
}
class Post {
  -long score
  #boolean address
  #Date active
  +processTotal()
  +validateQuantity()
  +cancelAmount()
}
abstract class Story {
  +boolean email
  -int type
  -double note
  +processActive()
  +createCode()
  +savePrice()
  +getDuration()
}
class Album {
  #long createdAt
  +String type
  #float address
  +String description
  +updateScore()
  +deleteUpdatedat()
  +getDuration()
}
Story ..|> Album
Hashtag ..> Comment : "*"
Post --> Comment : "1"
Hashtag --> Follower : "1..*"
Story ..|> Hashtag
Follower --|> User
@enduml