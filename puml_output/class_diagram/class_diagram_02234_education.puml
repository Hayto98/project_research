@startuml
skinparam defaultFontSize 13
class Student {
  #String phone
  +long updatedAt
  +setDuration()
  +getDescription()
  +sendId()
  +sendType()
}
class Course {
  #Date status
  +int total
  +int createdAt
  +createPrice()
  +validateName()
  +findActive()
  +validateLevel()
}
interface Exam {
  -Date total
  -float createdAt
  +double email
  +sendQuantity()
  +setType()
}
interface Assignment {
  #long note
  -double type
  #String name
  +calculatePhone()
}
class Attendance {
  -boolean address
  +int score
  -boolean level
  +processType()
  +deleteScore()
  +cancelScore()
  +findQuantity()
}
class Book {
  #Date name
  +boolean code
  -float description
  +deleteLevel()
  +validateType()
  +validateAmount()
  +findCreatedat()
}
Book ..|> Student
Student --* Assignment
Exam --o Assignment
note right of Student : Education domain
@enduml