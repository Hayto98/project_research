@startuml
skinparam defaultFontSize 13
class Student {
  #String phone
  +long updatedAt
  +getLevel()
  +deleteDescription()
  +setName()
  +findLevel()
}
class Course {
  +Date active
  +String type
  +cancelNote()
  +deleteEmail()
  +findLevel()
  +findType()
}
class Exam {
  -long status
  #double updatedAt
  -String active
  +cancelActive()
  +sendQuantity()
  +cancelUpdatedat()
}
class Assignment {
  -boolean createdAt
  #boolean email
  #int note
  #long address
  +double duration
  +updateScore()
  +validateTotal()
}
abstract class Attendance {
  +double name
  #long email
  +int total
  -float score
  #boolean duration
  +findUpdatedat()
  +validateCode()
  +createCreatedat()
  +sendPhone()
}
interface Book {
  +float note
  +String type
  #int amount
  #Date quantity
  +boolean id
  +getDescription()
  +saveStatus()
  +calculateAmount()
  +setLevel()
}
Book --* Assignment
Course ..|> Book
Book ..|> Student
Student --* Assignment
@enduml