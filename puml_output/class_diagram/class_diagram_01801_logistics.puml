@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
abstract class FuelLog {
  -boolean price
  +long code
  #String note
  -long level
  -long address
  +calculateCreatedat()
}
class Customer {
  #long note
  -long id
  -long level
  +cancelActive()
  +getDescription()
  +saveStatus()
  +deleteName()
}
class Inventory {
  #boolean quantity
  -long type
  #String updatedAt
  -float code
  +boolean email
  +updateName()
}
abstract class Tracking {
  #String total
  #double updatedAt
  +String address
  +deletePrice()
  +findAddress()
  +cancelTotal()
}
class Depot {
  -Date phone
  -boolean updatedAt
  #boolean name
  -boolean description
  +calculateCreatedat()
}
class Driver {
  -int type
  +double level
  -boolean amount
  +float email
  +String price
  +calculateAddress()
  +cancelStatus()
  +saveName()
  +sendDescription()
}
abstract class Route {
  #boolean status
  #Date address
  -int id
  +findCode()
  +findLevel()
}
Depot --o Inventory
Customer --|> Driver
Route --|> Depot
Customer --|> Tracking
Route --o Tracking
note right of FuelLog : Logistics domain
@enduml