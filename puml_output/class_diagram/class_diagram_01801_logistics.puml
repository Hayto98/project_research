@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
abstract class FuelLog {
  -boolean price
  +long code
  #String note
  -long level
  -long address
  +processLevel()
}
class Customer {
  +String amount
  #long note
  +saveCreatedat()
  +getDescription()
  +cancelCode()
}
class Inventory {
  +String level
  -double active
  -float name
  #double description
  +String status
  +cancelLevel()
  +findDuration()
  +sendActive()
}
abstract class Tracking {
  +String code
  -boolean phone
  +double name
  +boolean duration
  +sendType()
  +setId()
  +setUpdatedat()
}
interface Depot {
  #float id
  -boolean code
  #double address
  +long description
  -int price
  +findUpdatedat()
}
class Driver {
  -int total
  +boolean score
  -Date level
  -boolean duration
  +long code
  +getNote()
  +cancelLevel()
  +saveNote()
  +saveAddress()
}
abstract class Route {
  #float score
  #boolean description
  #float name
  #double id
  +validateScore()
  +getCode()
  +updateName()
  +updateCreatedat()
}
Depot --o Customer
Route ..|> Driver
@enduml