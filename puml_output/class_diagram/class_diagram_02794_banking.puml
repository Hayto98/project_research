@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Transaction {
  -boolean code
  +long type
  -int updatedAt
  +setCreatedat()
  +sendLevel()
  +setCode()
  +updateScore()
}
class Branch {
  +double quantity
  -Date phone
  -boolean score
  -int name
  +processDescription()
  +findQuantity()
}
interface Deposit {
  #double level
  +long status
  +createQuantity()
  +deleteDescription()
  +processPhone()
  +saveCode()
}
class Card {
  -boolean address
  -boolean status
  +boolean updatedAt
  #int code
  -float level
  +sendDescription()
  +getCreatedat()
  +getAddress()
}
class Customer {
  +double level
  +Date name
  #long quantity
  +sendUpdatedat()
}
interface Transfer {
  #Date quantity
  #Date description
  +double phone
  +deleteId()
  +cancelDuration()
  +saveId()
}
class Teller {
  +float amount
  #float createdAt
  +deleteAmount()
  +updateCreatedat()
  +findStatus()
}
Branch --* Teller
Customer ..> Transfer : "0..1"
note right of Transaction : Banking domain
@enduml