@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Transaction {
  -boolean code
  +long type
  -int updatedAt
  +validateEmail()
  +updateDescription()
  +findPrice()
  +getCode()
}
class Branch {
  +long createdAt
  -long score
  +saveEmail()
}
abstract class Deposit {
  +double phone
  +Date active
  -boolean address
  #String updatedAt
  +processNote()
}
abstract class Card {
  -long address
  +float active
  #int price
  +deletePhone()
  +validateTotal()
  +setCode()
  +cancelId()
}
class Customer {
  +String note
  -boolean address
  -boolean status
  +boolean updatedAt
  +calculateCreatedat()
  +deleteTotal()
}
class Transfer {
  -long name
  #boolean createdAt
  #boolean id
  +updateScore()
  +deleteUpdatedat()
}
class Teller {
  #Date amount
  #float note
  +boolean duration
  +boolean quantity
  +processCreatedat()
  +calculateType()
}
Branch --> Deposit : "0..1"
Card --* Transfer
Branch --> Transaction : "1"
Deposit ..|> Transaction
@enduml