@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
abstract class Staff {
  #double level
  +String email
  +cancelNote()
  +createPrice()
}
class Amenity {
  -float level
  -Date quantity
  +calculateStatus()
}
abstract class Guest {
  #int price
  +double code
  +createCode()
  +saveDescription()
  +findUpdatedat()
}
class Restaurant {
  -long updatedAt
  -long total
  +sendPhone()
}
interface Room {
  #int quantity
  #long type
  +float duration
  +updateType()
}
Amenity --> Guest : "1..*"
Guest --o Restaurant
Amenity ..|> Room
Room --o Staff
@enduml