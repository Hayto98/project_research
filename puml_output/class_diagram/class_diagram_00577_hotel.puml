@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
abstract class Staff {
  #double level
  +String email
  +updatePrice()
  +deleteId()
}
interface Amenity {
  #String address
  -Date quantity
  +float status
  #int price
  +processEmail()
  +deleteDuration()
}
class Guest {
  -long updatedAt
  -long total
  +validateActive()
}
class Restaurant {
  +float type
  +int quantity
  #int updatedAt
  #Date phone
  +sendActive()
  +createQuantity()
  +processPrice()
}
class Room {
  -int description
  +int active
  -boolean code
  +findNote()
}
Room --o Staff
Guest --> Restaurant : "0..1"
Guest ..> Room : "1..*"
note right of Staff : Hotel domain
@enduml