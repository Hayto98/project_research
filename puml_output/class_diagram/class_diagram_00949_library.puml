@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Fine {
  +boolean note
  -String price
  +validateQuantity()
  +calculateActive()
  +cancelDescription()
  +createName()
}
class Branch {
  -boolean total
  #float name
  #int createdAt
  #int amount
  +calculateUpdatedat()
}
abstract class Loan {
  #String level
  -float id
  #int amount
  -float phone
  +validateDuration()
}
abstract class Member {
  +double amount
  #boolean description
  +float price
  +sendDescription()
}
abstract class Reservation {
  #String type
  -boolean total
  #long email
  #int phone
  +processLevel()
  +createDuration()
  +sendDescription()
  +deleteDescription()
}
Reservation --> Fine : "1..*"
Branch --o Member
note right of Fine : Library domain
@enduml