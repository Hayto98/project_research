@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Fine {
  +boolean note
  -String price
  +validateScore()
  +getNote()
  +sendScore()
  +createDescription()
}
interface Branch {
  #float email
  -Date name
  #float id
  +calculateEmail()
  +processActive()
  +deleteStatus()
  +setDuration()
}
class Loan {
  -int score
  -boolean createdAt
  -boolean updatedAt
  +int status
  +findStatus()
  +updateName()
  +setTotal()
}
interface Member {
  #boolean total
  -int name
  +int address
  +saveAddress()
  +calculateCode()
  +calculateActive()
  +findName()
}
class Reservation {
  -long active
  #Date description
  +cancelCreatedat()
  +validateAddress()
  +saveScore()
  +findUpdatedat()
}
Member --> Loan : "0..1"
Member --> Reservation : "1..*"
@enduml