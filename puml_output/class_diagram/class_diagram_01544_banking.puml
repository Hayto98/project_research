@startuml
skinparam defaultFontSize 11
abstract class Beneficiary {
  +long phone
  -boolean name
  +validateTotal()
  +updateNote()
  +cancelCreatedat()
}
class Branch {
  -long score
  -String createdAt
  -double amount
  +double name
  +long quantity
  +sendDescription()
  +sendCreatedat()
  +saveActive()
}
abstract class Withdrawal {
  #float status
  #Date level
  +int type
  #float address
  -double updatedAt
  +setCode()
}
class Interest {
  #double description
  -String name
  +getAddress()
  +calculateTotal()
  +deleteType()
  +cancelScore()
}
class Customer {
  +double name
  #boolean id
  +Date type
  #long level
  +createLevel()
  +sendQuantity()
  +cancelDuration()
  +updateCreatedat()
}
class Statement {
  -double score
  +String quantity
  #String description
  #String email
  #Date code
  +findPrice()
  +validateUpdatedat()
  +updatePhone()
}
abstract class Transaction {
  -float score
  #int level
  +setStatus()
  +sendType()
  +createAmount()
}
Customer ..|> Withdrawal
Branch --> Interest : "0..1"
Withdrawal ..> Interest : "1..*"
Customer ..> Statement : "1..*"
@enduml