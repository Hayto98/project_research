@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Renewal {
  +long name
  +double createdAt
  -long email
  +boolean phone
  +validateActive()
  +deleteCreatedat()
  +createScore()
  +validateId()
}
class Catalog {
  +long status
  -int level
  +int duration
  -boolean total
  #long email
  +sendCode()
}
class Publisher {
  -boolean email
  #float type
  #boolean name
  +getPhone()
  +setCode()
  +validateEmail()
  +getAmount()
}
interface Fine {
  -double type
  -float note
  +processUpdatedat()
  +sendActive()
  +deleteTotal()
}
interface Shelf {
  #double description
  +Date status
  #String price
  +boolean phone
  #long createdAt
  +sendUpdatedat()
  +setLevel()
  +createTotal()
  +createUpdatedat()
}
class Member {
  -long active
  -boolean description
  -String score
  +double note
  +sendCode()
  +setNote()
  +getDescription()
  +findDuration()
}
Publisher --> Renewal : "*"
Fine ..|> Renewal
@enduml