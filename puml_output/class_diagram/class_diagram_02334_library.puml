@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Branch {
  #Date amount
  -int score
  #boolean price
  +processEmail()
}
class Loan {
  -long level
  #String email
  -double type
  #double score
  +String status
  +cancelActive()
}
interface Fine {
  -boolean address
  -float type
  +boolean id
  +double note
  +updateActive()
  +processPrice()
}
class Member {
  +double name
  -String total
  +float type
  +calculateDescription()
  +getDescription()
  +sendAddress()
  +findDuration()
}
Fine --> Loan : "1"
Member ..|> Fine
@enduml