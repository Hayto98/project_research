@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Branch {
  #Date amount
  -int score
  #boolean price
  +cancelPhone()
}
abstract class Loan {
  -float type
  #String duration
  -double status
  #double phone
  +getId()
}
interface Fine {
  -boolean address
  -float type
  +boolean id
  +double note
  +getUpdatedat()
  +deleteScore()
}
interface Member {
  +double name
  -String total
  +float type
  +findEmail()
  +sendStatus()
  +createType()
  +sendId()
}
Loan ..|> Fine
Fine --> Branch : "1"
note right of Branch : Library domain
@enduml