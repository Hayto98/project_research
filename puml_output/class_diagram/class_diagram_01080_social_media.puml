@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
interface Comment {
  -int name
  -int phone
  #Date price
  +processUpdatedat()
  +updateType()
  +deleteStatus()
}
class Message {
  -String code
  +double score
  +calculateAmount()
  +findCode()
}
abstract class Post {
  +long note
  #boolean amount
  #double phone
  #Date level
  +setType()
  +deleteStatus()
}
class Like {
  -float price
  +int description
  +sendAmount()
  +setCreatedat()
}
Post ..> Message : "*"
Post --|> Comment
Comment ..|> Like
@enduml