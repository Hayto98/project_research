@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
interface Manifest {
  #int level
  #String address
  -long name
  +Date status
  +deleteActive()
  +getPhone()
}
class Inventory {
  -double email
  -long level
  +Date updatedAt
  +saveLevel()
  +findNote()
}
class Depot {
  -long status
  +Date price
  +findPhone()
  +validateNote()
  +getAddress()
}
class Shipment {
  -int type
  +String active
  +calculateUpdatedat()
}
abstract class Warehouse {
  +double price
  +int score
  +updateQuantity()
}
Manifest --|> Depot
Warehouse ..> Inventory : "0..1"
@enduml