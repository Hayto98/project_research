@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
interface Manifest {
  #int level
  #String address
  -long name
  +Date status
  +processTotal()
  +createUpdatedat()
}
class Inventory {
  -String quantity
  #int type
  +int total
  +findStatus()
}
abstract class Depot {
  -float email
  +String code
  #double duration
  #double description
  +int updatedAt
  +setType()
}
class Shipment {
  +float score
  -Date id
  +float price
  -String status
  +long amount
  +saveAmount()
  +createQuantity()
}
abstract class Warehouse {
  #long code
  +String total
  -int phone
  +String updatedAt
  -float id
  +cancelId()
  +processPrice()
  +cancelDescription()
}
Depot --> Inventory : "1..*"
Warehouse --o Inventory
Manifest ..|> Inventory
note right of Manifest : Logistics domain
@enduml