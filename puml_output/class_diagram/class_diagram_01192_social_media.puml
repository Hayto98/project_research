@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Album {
  #String score
  #boolean description
  +String active
  +boolean duration
  +createScore()
  +findName()
  +validateUpdatedat()
}
abstract class Story {
  #Date amount
  -String updatedAt
  +updateId()
}
class Notification {
  +long email
  #float note
  #double total
  -String type
  +saveNote()
  +savePrice()
  +updateName()
}
class Report {
  -int type
  -long description
  +deleteScore()
  +cancelPrice()
}
class Profile {
  +long level
  #double address
  -Date code
  #Date createdAt
  +boolean description
  +deleteScore()
}
class Group {
  -double updatedAt
  #String name
  -int amount
  +validateEmail()
  +saveEmail()
  +processStatus()
  +validateUpdatedat()
}
Album --o Profile
Profile --|> Group
Report --o Album
Report --|> Group
Notification --> Story : "0..1"
note right of Album : Social Media domain
@enduml