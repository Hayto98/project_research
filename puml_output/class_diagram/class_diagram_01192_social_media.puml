@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Album {
  #String score
  #boolean description
  +String active
  +boolean duration
  +deleteName()
  +calculatePrice()
  +cancelUpdatedat()
}
class Story {
  +boolean updatedAt
  #double total
  +String status
  +String amount
  +setTotal()
  +validatePrice()
  +cancelPhone()
}
abstract class Notification {
  +long type
  #double name
  #double email
  +float price
  +String total
  +getId()
}
class Report {
  #boolean amount
  #double type
  +double quantity
  #long updatedAt
  +int description
  +processScore()
  +validateNote()
}
class Profile {
  +int email
  #String description
  +double id
  -Date level
  +long createdAt
  +getStatus()
  +findType()
}
abstract class Group {
  -int email
  -float duration
  +boolean note
  -boolean status
  +getPhone()
}
Report --o Group
Album ..|> Notification
@enduml