@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
abstract class FuelLog {
  #Date amount
  #float id
  -double phone
  -Date active
  #Date createdAt
  +getQuantity()
}
class Route {
  +long level
  #float total
  #float type
  +validateAmount()
}
abstract class Warehouse {
  -String duration
  #long name
  +createPrice()
  +createActive()
}
abstract class Tracking {
  -int type
  -float quantity
  +createCode()
  +findScore()
  +setName()
  +saveLevel()
}
Tracking ..|> FuelLog
FuelLog --> Warehouse : "0..1"
FuelLog --|> Route
@enduml