@startuml
skinparam defaultFontSize 11
class Group {
  -int note
  #long score
  #boolean description
  +int email
  +calculatePhone()
  +cancelId()
}
class Album {
  #Date price
  #Date name
  +double score
  #String level
  -float total
  +cancelTotal()
  +createPrice()
  +saveTotal()
}
class Follower {
  +float description
  #long createdAt
  +sendEmail()
  +saveStatus()
  +sendAddress()
}
abstract class Comment {
  +long phone
  +Date description
  -Date amount
  -Date quantity
  +boolean address
  +createCreatedat()
  +cancelDescription()
  +saveLevel()
}
Follower ..> Group : "1..*"
Album --|> Group
@enduml