@startuml
skinparam defaultFontSize 11
class Group {
  -int note
  #long score
  #boolean description
  +int email
  +createPhone()
  +setActive()
}
abstract class Album {
  -boolean name
  +double score
  #long duration
  +double total
  -String id
  +updateCreatedat()
  +cancelAddress()
}
class Follower {
  -int email
  +long price
  #long level
  +validateDescription()
  +saveEmail()
}
abstract class Comment {
  +Date level
  #float address
  +cancelAddress()
}
Follower ..|> Comment
Album --* Group
note right of Group : Social Media domain
@enduml