@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
interface Profile {
  -int createdAt
  +Date type
  +validateQuantity()
}
class Group {
  #Date email
  +long note
  -float active
  #Date createdAt
  +validateActive()
}
class Hashtag {
  -String description
  -long score
  -float id
  +long note
  +calculatePhone()
}
abstract class Like {
  #long id
  #int description
  +deleteNote()
  +cancelStatus()
}
class Message {
  #String name
  -long score
  +float status
  -float active
  -double code
  +findAddress()
  +calculateStatus()
  +updateQuantity()
  +sendType()
}
class Report {
  +boolean status
  -int type
  +cancelCode()
  +sendAmount()
  +validateUpdatedat()
}
abstract class Follower {
  #int note
  #float name
  #boolean address
  -Date description
  -int email
  +createName()
}
Group ..> Message : "0..1"
Profile --|> Hashtag
Follower --|> Hashtag
Hashtag ..|> Group
Group --|> Like
Message --|> Report
@enduml