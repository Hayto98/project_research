@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
interface Profile {
  -int createdAt
  +Date type
  +deleteCreatedat()
}
class Group {
  -double note
  #Date active
  +boolean createdAt
  +long updatedAt
  +sendId()
  +processAddress()
}
class Hashtag {
  -float phone
  -String total
  #String amount
  +Date quantity
  -boolean name
  +deleteName()
  +setCreatedat()
}
abstract class Like {
  #boolean score
  +boolean status
  +validateAddress()
}
class Message {
  #float quantity
  #boolean total
  #float price
  +float updatedAt
  #String active
  +updateScore()
  +processDescription()
  +validateType()
  +sendType()
}
abstract class Report {
  #int note
  #float name
  #boolean address
  -Date description
  -int email
  +processDuration()
}
class Follower {
  -String name
  -int address
  +int status
  +getLevel()
  +saveName()
  +updateDuration()
  +validateLevel()
}
Profile ..|> Like
Like --* Profile
Group --* Profile
Follower --|> Like
Message ..> Group : "1..*"
note right of Profile : Social Media domain
@enduml