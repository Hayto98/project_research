@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Card {
  -float active
  -long id
  +double email
  +long name
  -int updatedAt
  +getTotal()
  +createUpdatedat()
}
class Withdrawal {
  -float phone
  #Date email
  +validateCreatedat()
  +createTotal()
  +getEmail()
  +updateTotal()
}
abstract class Teller {
  -double type
  #long status
  #int amount
  #double score
  #int name
  +sendId()
}
class Interest {
  #long duration
  +boolean updatedAt
  -float price
  +validateEmail()
  +validateAmount()
  +sendId()
}
class Customer {
  +Date id
  -String price
  +int level
  +float type
  +sendStatus()
  +createName()
  +getEmail()
}
class Account {
  #String amount
  +String name
  #float score
  +boolean level
  +sendName()
  +deleteType()
  +validateName()
}
Account --|> Interest
Interest --o Customer
note right of Card : Banking domain
@enduml