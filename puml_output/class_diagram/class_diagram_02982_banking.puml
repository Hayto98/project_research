@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Card {
  -float active
  -long id
  +double email
  +long name
  -int updatedAt
  +deleteNote()
  +findAmount()
}
class Withdrawal {
  -double status
  #Date name
  #double phone
  +createEmail()
  +setCreatedat()
  +updateDescription()
}
class Teller {
  #Date name
  -double email
  +int updatedAt
  +float total
  +long active
  +getStatus()
  +createUpdatedat()
  +deleteCreatedat()
  +cancelScore()
}
class Interest {
  +int updatedAt
  #int score
  #double code
  #long active
  +boolean id
  +findType()
  +processPhone()
  +getQuantity()
  +createLevel()
}
class Customer {
  +Date email
  +long phone
  #String amount
  -float active
  +deleteStatus()
  +deleteActive()
  +saveLevel()
  +validatePhone()
}
abstract class Account {
  +float name
  #long updatedAt
  +cancelAddress()
}
Card --* Teller
Teller --|> Withdrawal
@enduml