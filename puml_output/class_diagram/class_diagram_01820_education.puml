@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Book {
  #Date type
  -long quantity
  +cancelCode()
}
class Assignment {
  +int address
  -long description
  +calculateLevel()
  +updateEmail()
}
class Grade {
  #int phone
  -boolean duration
  #Date active
  -int price
  #float address
  +createAmount()
  +saveEmail()
}
class Library {
  +Date note
  #int code
  #double quantity
  -String email
  -String id
  +findUpdatedat()
  +saveCode()
  +saveNote()
  +createType()
}
Library --* Book
Assignment --|> Grade
@enduml