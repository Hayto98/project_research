@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Book {
  #Date type
  -long quantity
  +processName()
}
class Assignment {
  -int description
  -String name
  #double updatedAt
  -long quantity
  +findAddress()
  +saveAmount()
  +validateLevel()
  +findPhone()
}
class Grade {
  -double phone
  +long name
  -String email
  +saveDescription()
}
interface Library {
  #double price
  +Date status
  +boolean address
  -int code
  -Date note
  +findId()
  +validateAmount()
}
Library ..> Assignment : "1..*"
Grade ..|> Book
Grade --|> Assignment
note right of Book : Education domain
@enduml