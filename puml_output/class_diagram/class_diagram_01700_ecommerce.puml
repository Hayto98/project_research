@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Warehouse {
  -int updatedAt
  -long type
  -long total
  +getId()
  +saveTotal()
  +createEmail()
  +updateTotal()
}
class Category {
  +long code
  +boolean name
  #long id
  #int quantity
  +validateCreatedat()
  +setCode()
  +processId()
}
abstract class Wishlist {
  +double note
  -boolean duration
  #long active
  #Date amount
  -int updatedAt
  +getActive()
  +getAmount()
  +cancelQuantity()
}
class Order {
  #float amount
  -long address
  +int note
  -boolean status
  -float createdAt
  +findLevel()
  +saveActive()
  +findPhone()
}
interface Shipment {
  #String email
  -float address
  +updateTotal()
}
Category --> Shipment : "*"
Order --|> Category
@enduml