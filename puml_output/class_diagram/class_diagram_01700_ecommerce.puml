@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Warehouse {
  -int updatedAt
  -long type
  -long total
  +processPhone()
  +setQuantity()
  +setName()
  +getQuantity()
}
class Category {
  +Date status
  #Date email
  -Date description
  -double level
  +sendLevel()
  +sendAmount()
  +updateStatus()
  +processPhone()
}
interface Wishlist {
  #Date level
  -long note
  #double amount
  +Date phone
  +cancelLevel()
  +processStatus()
  +updatePrice()
}
class Order {
  #double description
  -float phone
  +cancelId()
  +saveEmail()
}
class Shipment {
  #float total
  #String score
  +getUpdatedat()
  +updateDuration()
  +processPrice()
}
Warehouse ..|> Shipment
Order --o Category
note right of Warehouse : Ecommerce domain
@enduml