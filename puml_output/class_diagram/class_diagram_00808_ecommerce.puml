@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Warehouse {
  #boolean duration
  +double name
  -boolean note
  #float price
  +updateName()
  +processPrice()
  +deleteUpdatedat()
}
class Invoice {
  +long status
  +double createdAt
  -int active
  #long type
  -long quantity
  +findNote()
  +cancelDuration()
}
class Return {
  #float createdAt
  +double level
  #Date code
  #long amount
  +validateActive()
  +validateCode()
  +findUpdatedat()
  +calculateScore()
}
abstract class Shipment {
  #double active
  #Date score
  +updateAmount()
  +calculateEmail()
}
class Category {
  #double quantity
  -int createdAt
  -float email
  +Date type
  +setId()
  +createAddress()
}
class Order {
  #String code
  -String note
  #long level
  -double duration
  +createPhone()
}
interface Customer {
  -String price
  +Date status
  -long active
  -Date code
  +cancelTotal()
  +validateTotal()
  +updateType()
  +cancelAmount()
}
Order --|> Return
Warehouse --|> Return
Category --o Customer
Shipment --o Warehouse
Shipment --> Invoice : "1"
@enduml