@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Withdrawal {
  #float type
  -float quantity
  +createScore()
  +savePrice()
}
interface Transfer {
  +boolean total
  +float quantity
  -int name
  -int type
  +deleteDescription()
  +cancelLevel()
  +deleteActive()
}
abstract class Interest {
  -int phone
  #boolean active
  -boolean score
  #long amount
  +sendDuration()
  +deleteNote()
}
abstract class Deposit {
  -boolean status
  +Date description
  +updateNote()
  +validateEmail()
  +cancelPrice()
}
class Beneficiary {
  #double duration
  -boolean address
  -long level
  #Date score
  -long email
  +validateQuantity()
  +getEmail()
  +validateCreatedat()
}
class Transaction {
  #double type
  -int name
  +cancelName()
  +getEmail()
  +createAddress()
  +processTotal()
}
abstract class Card {
  +boolean status
  -float phone
  +getDescription()
  +calculateId()
  +sendAmount()
}
Deposit --|> Interest
Transaction --> Interest : "1"
Beneficiary --> Interest : "*"
@enduml