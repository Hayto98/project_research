@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Withdrawal {
  #float type
  -float quantity
  +updateLevel()
  +saveScore()
}
class Transfer {
  -int quantity
  -int name
  -boolean type
  -float createdAt
  -boolean code
  +savePhone()
  +sendScore()
  +deletePhone()
}
class Interest {
  #String level
  -String duration
  +int email
  -boolean description
  +findPhone()
  +sendStatus()
}
class Deposit {
  #double duration
  -boolean address
  -long level
  #Date score
  -long email
  +deleteDescription()
  +deleteName()
  +getType()
}
class Beneficiary {
  -double type
  +Date amount
  +long price
  +boolean description
  -float code
  +getScore()
  +deleteNote()
  +validateCode()
}
class Transaction {
  #double duration
  +float address
  +createName()
  +updatePhone()
}
class Card {
  +boolean note
  +boolean quantity
  -float total
  #float amount
  +sendEmail()
  +validateLevel()
  +setEmail()
}
Interest ..|> Card
Transaction ..|> Beneficiary
Card ..> Beneficiary : "*"
note right of Withdrawal : Banking domain
@enduml