@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
interface Book {
  #Date email
  -boolean description
  #boolean name
  -long id
  +processNote()
}
class Member {
  #int total
  #int updatedAt
  +int address
  #double createdAt
  +Date id
  +cancelStatus()
  +calculateCode()
}
abstract class Librarian {
  #long type
  -Date amount
  +Date code
  #String active
  -float name
  +getEmail()
  +createPhone()
}
interface Publisher {
  -long active
  +boolean code
  -Date price
  -Date score
  +calculateCode()
  +getStatus()
  +sendId()
  +createEmail()
}
Publisher --> Book : "0..1"
Book --> Publisher : "1"
Book --> Librarian : "1"
@enduml