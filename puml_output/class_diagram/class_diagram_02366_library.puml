@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
interface Book {
  #Date email
  -boolean description
  #boolean name
  -long id
  +saveEmail()
}
interface Member {
  #int total
  #int updatedAt
  +int address
  #double createdAt
  +Date id
  +setPrice()
  +calculateType()
}
abstract class Librarian {
  #long code
  -Date active
  +Date name
  +validateDescription()
}
class Publisher {
  #String duration
  -float email
  +calculateAddress()
  +setLevel()
  +createQuantity()
  +saveActive()
}
Publisher --o Book
Member --|> Book
note right of Book : Library domain
@enduml