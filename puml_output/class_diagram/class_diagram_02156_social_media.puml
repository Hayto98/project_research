@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Message {
  #Date duration
  +long email
  +double score
  #double address
  +Date amount
  +cancelLevel()
  +processActive()
  +setScore()
}
abstract class Comment {
  -String quantity
  +boolean level
  +findUpdatedat()
  +deletePrice()
}
class Hashtag {
  #boolean score
  #long email
  +float createdAt
  +cancelCode()
  +validateScore()
}
abstract class Notification {
  +float note
  -String amount
  +processLevel()
  +validateUpdatedat()
  +createEmail()
}
class Post {
  -String email
  #String code
  +boolean type
  +saveCode()
}
class Follower {
  -long note
  +long active
  +processCreatedat()
  +updateScore()
}
class Report {
  +Date createdAt
  -float updatedAt
  -int name
  +calculateScore()
  +updateType()
  +updateDescription()
}
Message ..> Comment : "1"
Message ..|> Notification
Post --o Message
Notification --|> Hashtag
note right of Message : Social Media domain
@enduml