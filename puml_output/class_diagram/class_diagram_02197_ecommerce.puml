@startuml
skinparam ArrowColor #555555
class Coupon {
  -boolean status
  -Date level
  -long note
  -String quantity
  +cancelStatus()
  +calculateAddress()
}
class Order {
  -float duration
  -String total
  -String score
  +setAddress()
  +deleteCreatedat()
}
class Customer {
  #int status
  -long address
  #float duration
  #double name
  #String active
  +setNote()
}
abstract class Product {
  #int note
  -long amount
  +deletePhone()
  +saveDuration()
  +sendDuration()
  +calculatePhone()
}
class Supplier {
  #int address
  -String updatedAt
  #Date email
  +sendId()
  +deletePhone()
  +processName()
  +validateUpdatedat()
}
interface Wishlist {
  #float status
  -float type
  +findTotal()
  +setName()
  +processQuantity()
}
Product ..> Supplier : "1..*"
Customer --o Coupon
Customer ..|> Wishlist
@enduml