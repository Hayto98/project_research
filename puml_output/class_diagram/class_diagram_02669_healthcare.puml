@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Treatment {
  -long amount
  #boolean level
  #long quantity
  +deleteCreatedat()
  +getEmail()
  +cancelDuration()
  +calculateNote()
}
class Patient {
  +int code
  -int name
  -double level
  +processTotal()
  +deleteId()
  +calculateDescription()
  +deleteAmount()
}
class Ward {
  -String score
  #String id
  #int updatedAt
  +int code
  -long note
  +updateAddress()
  +getCreatedat()
  +deleteTotal()
}
interface Insurance {
  -boolean score
  #double total
  #double createdAt
  #Date phone
  +cancelTotal()
  +setNote()
  +calculateCreatedat()
  +findPrice()
}
interface Appointment {
  #double type
  +long duration
  +String price
  +findPrice()
  +savePrice()
  +processPrice()
  +setNote()
}
class Hospital {
  -int email
  -double createdAt
  +Date amount
  #long price
  +saveType()
  +deleteEmail()
  +validateType()
  +setPrice()
}
Treatment --* Patient
Appointment --|> Ward
Insurance --* Treatment
@enduml