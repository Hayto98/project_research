@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Treatment {
  -long amount
  #boolean level
  #long quantity
  +createDescription()
  +saveCreatedat()
  +getAmount()
  +setName()
}
class Patient {
  -double createdAt
  -double total
  #double duration
  +cancelNote()
  +findScore()
  +cancelId()
}
class Ward {
  +boolean note
  +Date quantity
  +setAmount()
  +createPhone()
}
interface Insurance {
  +long score
  -boolean active
  #double email
  #double total
  +getTotal()
  +validateActive()
  +cancelActive()
  +updateType()
}
abstract class Appointment {
  +double score
  #boolean note
  +double amount
  +long phone
  -Date description
  +deletePrice()
  +processAmount()
}
class Hospital {
  +float status
  -boolean email
  -String note
  -Date address
  +long code
  +findStatus()
  +getQuantity()
  +processPrice()
}
Treatment ..|> Insurance
Treatment --|> Patient
Hospital ..> Insurance : "1..*"
Insurance --|> Treatment
note right of Treatment : Healthcare domain
@enduml