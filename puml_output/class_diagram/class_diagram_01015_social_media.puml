@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Hashtag {
  +long email
  -double address
  -double createdAt
  #double amount
  #long status
  +deletePhone()
  +findName()
  +deleteTotal()
  +createTotal()
}
class Follower {
  #double description
  -float phone
  #String address
  +double status
  +saveQuantity()
  +updateDuration()
  +saveNote()
  +createLevel()
}
interface Story {
  #long createdAt
  -float updatedAt
  #int active
  +cancelTotal()
  +findPrice()
  +calculateLevel()
  +cancelDescription()
}
abstract class Like {
  +long active
  +String price
  +float score
  +validateDescription()
}
interface Report {
  #int quantity
  #String score
  -boolean status
  -double code
  +sendDescription()
  +createDuration()
  +cancelStatus()
  +findPhone()
}
Follower --|> Like
Report ..|> Hashtag
Report --* Follower
Hashtag --|> Like
note right of Hashtag : Social Media domain
@enduml