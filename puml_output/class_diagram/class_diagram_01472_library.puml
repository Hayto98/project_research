@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Member {
  -float note
  #int code
  #int id
  +Date score
  #String level
  +calculateType()
  +processAddress()
}
interface Fine {
  -long id
  +float amount
  +String updatedAt
  +validateDescription()
  +deleteDescription()
  +validateAddress()
}
interface Librarian {
  -int amount
  +Date updatedAt
  +sendTotal()
  +cancelType()
  +findDuration()
}
abstract class Book {
  +int updatedAt
  -Date name
  +validatePhone()
  +createStatus()
}
class Publisher {
  #Date level
  #long active
  +double description
  +validateNote()
  +setId()
  +updateCode()
}
class Loan {
  -int score
  -int price
  #String address
  -boolean active
  +findLevel()
  +findId()
}
class Branch {
  +Date createdAt
  +boolean total
  +String id
  +saveAddress()
  +sendName()
}
Librarian --* Branch
Member --* Loan
Loan ..|> Branch
Book --* Member
note right of Member : Library domain
@enduml