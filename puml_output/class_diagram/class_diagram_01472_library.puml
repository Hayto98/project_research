@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Member {
  -float note
  #int code
  #int id
  +Date score
  #String level
  +calculateQuantity()
  +getId()
}
abstract class Fine {
  +double score
  -String updatedAt
  +String id
  #boolean amount
  +validateScore()
  +saveQuantity()
  +calculateLevel()
}
class Librarian {
  +int address
  -int duration
  +Date id
  +findPrice()
  +deletePhone()
  +processLevel()
}
interface Book {
  +int duration
  -Date price
  +float status
  -long updatedAt
  -String name
  +processUpdatedat()
  +processId()
  +updateNote()
}
class Publisher {
  -String createdAt
  +int note
  +String quantity
  -Date phone
  +findQuantity()
  +getScore()
  +updateLevel()
  +updateStatus()
}
class Loan {
  #int duration
  #boolean name
  #String type
  +setAddress()
  +cancelScore()
}
class Branch {
  #String total
  #int id
  +float updatedAt
  +getPrice()
  +saveStatus()
}
Publisher --o Member
Librarian --* Branch
Member --* Loan
Loan ..|> Branch
@enduml