@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
abstract class Teller {
  +long code
  +boolean email
  +Date updatedAt
  +findDescription()
}
class Branch {
  +Date price
  +Date email
  -Date id
  -long duration
  -String updatedAt
  +updateCode()
  +validateType()
}
class Transaction {
  +int name
  #double status
  -double note
  #float quantity
  +updateDescription()
  +findTotal()
}
interface Withdrawal {
  #Date duration
  #boolean type
  +deleteCreatedat()
  +cancelType()
}
class Interest {
  #Date status
  +Date type
  +long id
  +createType()
  +cancelCreatedat()
}
class Transfer {
  +float description
  +boolean createdAt
  +float level
  +calculateName()
  +processDuration()
}
abstract class Deposit {
  -boolean code
  -int active
  +cancelTotal()
  +deleteTotal()
  +cancelCreatedat()
}
Teller --* Deposit
Withdrawal ..> Transaction : "1"
Interest ..|> Branch
Teller --o Transfer
@enduml