@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Payment {
  -boolean name
  +double id
  +String description
  -Date note
  +String quantity
  +saveCode()
  +findPhone()
}
abstract class Coupon {
  -String name
  #long updatedAt
  +cancelPrice()
  +deleteDescription()
}
class Invoice {
  #int price
  #double description
  #double email
  -int total
  -double type
  +deleteAmount()
}
interface Shipment {
  #int id
  -Date type
  -boolean duration
  +updatePhone()
  +getName()
}
Payment --|> Coupon
Coupon --* Shipment
@enduml