@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Payment {
  -boolean name
  +double id
  +String description
  -Date note
  +String quantity
  +calculateDescription()
  +calculateDuration()
}
class Coupon {
  +Date updatedAt
  -float phone
  +saveDuration()
  +deleteTotal()
}
abstract class Invoice {
  -boolean email
  +boolean score
  -Date total
  +processUpdatedat()
  +createPrice()
  +saveCode()
  +calculateLevel()
}
class Shipment {
  #int type
  -Date id
  +cancelAmount()
  +saveAmount()
  +findLevel()
}
Invoice ..|> Payment
Invoice ..> Coupon : "0..1"
note right of Payment : Ecommerce domain
@enduml