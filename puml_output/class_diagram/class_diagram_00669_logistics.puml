@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Warehouse {
  #boolean id
  +long total
  +sendPhone()
  +createLevel()
}
abstract class Manifest {
  +boolean phone
  #boolean amount
  +processCode()
  +validateDescription()
  +saveUpdatedat()
}
class Inventory {
  -int note
  +int phone
  +long status
  #int level
  +createStatus()
  +createPrice()
  +getPhone()
  +validateAmount()
}
interface DeliveryNote {
  -boolean note
  #double price
  -double address
  +boolean status
  #Date duration
  +sendQuantity()
}
class Vehicle {
  #float updatedAt
  +Date name
  -long id
  -float code
  +processType()
  +findTotal()
  +calculateUpdatedat()
  +deleteScore()
}
Manifest --o Inventory
Warehouse --> Inventory : "1"
DeliveryNote --o Inventory
@enduml