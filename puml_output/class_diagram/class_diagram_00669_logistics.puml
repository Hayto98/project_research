@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Warehouse {
  #boolean id
  +long total
  +validateNote()
  +setPhone()
}
class Manifest {
  -String score
  #int active
  +processPhone()
  +setPhone()
  +validateDescription()
}
class Inventory {
  +double amount
  #double quantity
  -long score
  +processPrice()
  +cancelAddress()
  +setNote()
  +processDuration()
}
interface DeliveryNote {
  #float note
  -int type
  +float description
  #String status
  #String quantity
  +findPhone()
}
class Vehicle {
  -Date note
  +long price
  +boolean amount
  -boolean createdAt
  #Date address
  +calculateActive()
}
DeliveryNote --> Warehouse : "1"
Manifest --o DeliveryNote
Inventory --|> Warehouse
note right of Warehouse : Logistics domain
@enduml