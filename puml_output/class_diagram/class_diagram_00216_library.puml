@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Reservation {
  #boolean address
  +int quantity
  +getPrice()
  +deleteLevel()
}
class Publisher {
  +String type
  #float updatedAt
  +calculateStatus()
  +saveCreatedat()
}
class Member {
  +float active
  #Date description
  -double amount
  #String duration
  -double status
  +deleteLevel()
  +createType()
  +createActive()
}
class Shelf {
  +Date email
  +double code
  #float createdAt
  #boolean score
  +validateDescription()
  +cancelPhone()
  +updateStatus()
}
class Catalog {
  +String status
  +boolean createdAt
  -String quantity
  +calculatePhone()
  +cancelId()
  +findCode()
  +calculateName()
}
Shelf --o Member
Publisher --o Reservation
Publisher --* Catalog
@enduml