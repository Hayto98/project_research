@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Reservation {
  #boolean address
  +int quantity
  +saveStatus()
  +cancelStatus()
}
abstract class Publisher {
  #long name
  +boolean status
  -boolean description
  +deleteActive()
  +setAmount()
}
interface Member {
  #long note
  -long status
  #long total
  #float duration
  +int quantity
  +deleteStatus()
  +processActive()
}
class Shelf {
  #int updatedAt
  -String email
  +String createdAt
  #long status
  +calculateQuantity()
}
class Catalog {
  -int address
  +float email
  -int price
  +long phone
  +findCreatedat()
  +cancelActive()
  +updateTotal()
}
Publisher ..|> Member
Reservation ..|> Publisher
note right of Reservation : Library domain
@enduml