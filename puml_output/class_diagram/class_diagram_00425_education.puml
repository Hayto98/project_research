@startuml
skinparam monochrome true
skinparam shadowing true
interface Classroom {
  #long email
  -long address
  -boolean description
  -long name
  #double duration
  +findEmail()
  +setNote()
  +calculateId()
}
class Student {
  #int phone
  #float note
  +long description
  +createAddress()
  +calculateAmount()
}
class Teacher {
  -long status
  -double quantity
  +deleteDescription()
}
class Enrollment {
  -boolean duration
  -boolean note
  -double createdAt
  +updateLevel()
  +createAddress()
}
abstract class Attendance {
  +float email
  #double quantity
  +saveNote()
}
abstract class Book {
  +double score
  #int updatedAt
  +getCreatedat()
  +sendAddress()
}
Student --> Classroom : "1..*"
Student --o Teacher
Enrollment ..|> Attendance
note right of Classroom : Education domain
@enduml