@startuml
skinparam monochrome true
skinparam shadowing true
interface Classroom {
  #long email
  -long address
  -boolean description
  -long name
  #double duration
  +cancelName()
  +deleteName()
  +sendType()
}
class Student {
  -int price
  #int id
  #float amount
  +long description
  #Date phone
  +processCreatedat()
  +deleteCreatedat()
}
class Teacher {
  -long amount
  -double createdAt
  +float status
  +float score
  +float quantity
  +findId()
  +findDescription()
}
abstract class Enrollment {
  #long email
  -int active
  +float address
  +validateTotal()
  +findQuantity()
  +validateStatus()
}
abstract class Attendance {
  +float email
  #double quantity
  +findStatus()
}
abstract class Book {
  #int name
  +String score
  +float updatedAt
  #long code
  +int note
  +setPhone()
}
Student --o Teacher
Enrollment ..|> Attendance
Enrollment ..> Teacher : "1"
Enrollment ..> Classroom : "*"
@enduml