@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
interface Ward {
  -double code
  -Date active
  +validateId()
  +calculateTotal()
}
class Appointment {
  +float id
  -long status
  +setCode()
  +setStatus()
  +updateDescription()
  +validateType()
}
interface Billing {
  -long amount
  #int quantity
  -String score
  +sendCode()
  +saveAddress()
}
abstract class Diagnosis {
  #boolean description
  -Date address
  -int score
  #boolean amount
  -int status
  +sendPhone()
  +sendCode()
  +saveStatus()
  +createDuration()
}
abstract class Doctor {
  -double createdAt
  #String updatedAt
  +sendDuration()
  +processType()
  +processStatus()
  +processLevel()
}
Billing --|> Appointment
Diagnosis --o Doctor
@enduml