@startuml

class Product {
  #boolean score
  #float active
  +Date id
  -String email
  -int description
  +sendUpdatedat()
  +cancelEmail()
  +createId()
  +calculateLevel()
}
class Order {
  #String duration
  #Date status
  -int type
  +boolean email
  +cancelUpdatedat()
  +findAmount()
  +updateTotal()
  +saveCreatedat()
}
abstract class Supplier {
  #double score
  #long note
  #String status
  #String type
  +float updatedAt
  +sendEmail()
  +saveUpdatedat()
  +findId()
  +calculateDuration()
}
class Payment {
  #Date address
  -float quantity
  +deleteActive()
  +deleteName()
  +saveAddress()
  +findTotal()
}
Order --o Payment
Order ..> Product : "0..1"
@enduml