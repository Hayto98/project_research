@startuml

class Product {
  #boolean score
  #float active
  +Date id
  -String email
  -int description
  +findStatus()
  +setAddress()
  +cancelStatus()
  +processEmail()
}
class Order {
  -long amount
  #double status
  -boolean type
  #double total
  +processUpdatedat()
}
interface Supplier {
  +float duration
  #double phone
  +Date score
  +boolean name
  +float code
  +findAddress()
}
class Payment {
  #int total
  +long type
  -int email
  +float amount
  +getLevel()
  +createDuration()
}
Order --> Payment : "1..*"
Order --|> Product
note right of Product : Ecommerce domain
@enduml