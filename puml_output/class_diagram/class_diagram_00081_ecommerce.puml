@startuml
skinparam monochrome true
skinparam defaultFontSize 11
interface Order {
  -int duration
  +String createdAt
  #double address
  +findPhone()
  +deleteAmount()
  +updatePhone()
  +findPhone()
}
abstract class Cart {
  #double amount
  -long score
  #Date phone
  #float quantity
  +updateTotal()
}
interface Coupon {
  #float description
  -boolean phone
  +savePhone()
  +validateCode()
  +processId()
  +createPrice()
}
abstract class Shipment {
  -long total
  +long duration
  -double phone
  -boolean name
  #double price
  +processDuration()
  +deleteQuantity()
}
interface Review {
  #Date status
  +float code
  +updateScore()
  +findDescription()
}
class Supplier {
  -Date phone
  -double id
  +Date status
  -float note
  #Date level
  +updateUpdatedat()
  +deletePrice()
  +updateEmail()
  +createName()
}
interface Payment {
  +boolean phone
  #String note
  #float status
  -double updatedAt
  +createDescription()
  +validateDescription()
  +createPhone()
  +createQuantity()
}
Payment --* Order
Supplier --* Review
Shipment --> Cart : "1..*"
Order --o Cart
Cart --* Review
note right of Order : Ecommerce domain
@enduml