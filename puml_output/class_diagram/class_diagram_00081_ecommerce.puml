@startuml
skinparam monochrome true
skinparam defaultFontSize 11
interface Order {
  -int duration
  +String createdAt
  #double address
  +cancelName()
  +cancelId()
  +updateType()
  +deleteScore()
}
class Cart {
  #Date phone
  -long type
  #double quantity
  -long amount
  +cancelNote()
}
abstract class Coupon {
  #float description
  -boolean phone
  +cancelScore()
  +cancelId()
  +validateDuration()
  +getType()
}
abstract class Shipment {
  -float quantity
  #boolean price
  +processPhone()
  +calculateTotal()
  +setNote()
  +cancelCreatedat()
}
class Review {
  -String price
  -float total
  +processTotal()
  +getUpdatedat()
  +validateUpdatedat()
}
interface Supplier {
  #boolean level
  +String updatedAt
  +boolean note
  #float description
  +float quantity
  +findAddress()
  +getCreatedat()
}
class Payment {
  +String total
  #double phone
  +findCode()
}
Shipment ..> Order : "1..*"
Payment ..> Supplier : "*"
Cart ..|> Supplier
Cart ..|> Shipment
@enduml