@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Diagnosis {
  +double createdAt
  +double type
  #Date duration
  +findQuantity()
  +updateType()
  +setDuration()
  +updateAddress()
}
abstract class Treatment {
  #int active
  -double email
  -long createdAt
  +updateStatus()
  +cancelTotal()
}
class Ward {
  +boolean name
  #int quantity
  -float note
  +int type
  +createDescription()
  +updateQuantity()
}
class MedicalRecord {
  +long createdAt
  #boolean updatedAt
  +String note
  +long level
  +findName()
  +updateQuantity()
}
class Hospital {
  #long type
  #long note
  +String quantity
  +getName()
}
MedicalRecord --> Hospital : "*"
Treatment ..> Hospital : "1"
Treatment --* Ward
@enduml