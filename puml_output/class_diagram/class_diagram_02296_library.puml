@startuml
skinparam monochrome true
interface Reservation {
  -int quantity
  +String code
  -double status
  #Date level
  +processTotal()
  +savePhone()
  +cancelDescription()
  +createEmail()
}
class Loan {
  -double active
  -float note
  #int quantity
  -boolean amount
  -int phone
  +validateName()
  +createAddress()
  +deleteAddress()
  +sendAmount()
}
abstract class Branch {
  #boolean id
  #boolean type
  -float active
  +int phone
  #String total
  +findDescription()
  +setLevel()
  +deleteEmail()
  +deleteAddress()
}
class Author {
  #String phone
  -long duration
  -boolean status
  #String active
  #long id
  +validateQuantity()
  +calculateLevel()
  +deleteLevel()
}
Reservation --|> Branch
Loan --> Reservation : "*"
@enduml