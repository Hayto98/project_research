@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
abstract class Profile {
  #long code
  +boolean name
  -Date level
  +int total
  +updateId()
}
class Album {
  +boolean quantity
  -int price
  -Date note
  +getActive()
  +validateStatus()
}
class Post {
  +double total
  -long quantity
  -Date type
  +deleteQuantity()
}
abstract class Group {
  #String active
  #double id
  +Date code
  +setEmail()
  +deletePhone()
  +createDuration()
}
class Notification {
  #boolean duration
  +long type
  +sendTotal()
  +updateActive()
}
class Story {
  -String type
  #long status
  +double quantity
  #long createdAt
  #boolean updatedAt
  +validateAmount()
  +setNote()
  +deleteAddress()
}
Notification ..|> Profile
Album --> Profile : "0..1"
@enduml