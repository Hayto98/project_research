@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
abstract class Profile {
  #long code
  +boolean name
  -Date level
  +int total
  +findQuantity()
}
class Album {
  +long price
  #int note
  #float updatedAt
  +int duration
  +createType()
  +updateNote()
  +processPhone()
  +calculateName()
}
class Post {
  #String duration
  #double amount
  +Date active
  #long id
  -double code
  +setDuration()
}
abstract class Group {
  +String quantity
  +Date active
  +calculateType()
}
class Notification {
  +Date createdAt
  -int score
  -Date updatedAt
  -Date type
  +createTotal()
  +updateName()
  +cancelName()
}
class Story {
  +long name
  +long level
  #String description
  +cancelQuantity()
}
Notification --o Album
Profile --o Album
note right of Profile : Social Media domain
@enduml