@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Vehicle {
  +long total
  -float duration
  #boolean id
  #float phone
  +getLevel()
}
interface DeliveryNote {
  +Date amount
  +float total
  +String status
  +cancelCreatedat()
  +saveEmail()
}
class Driver {
  +double type
  +float id
  #int active
  #Date total
  +findUpdatedat()
  +processPhone()
  +createDuration()
}
class Tracking {
  -String name
  #String phone
  +String level
  +processPhone()
}
class Customer {
  -String score
  +double createdAt
  +saveNote()
  +processPhone()
  +deleteUpdatedat()
  +updateTotal()
}
Tracking --|> DeliveryNote
Driver --* DeliveryNote
Customer ..> DeliveryNote : "0..1"
@enduml