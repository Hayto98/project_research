@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Vehicle {
  +long total
  -float duration
  #boolean id
  #float phone
  +setDuration()
}
class DeliveryNote {
  +Date duration
  +float total
  +String status
  +calculateName()
  +getEmail()
}
abstract class Driver {
  -int duration
  -int active
  +cancelPhone()
  +cancelPrice()
}
class Tracking {
  -String name
  #String phone
  +String level
  +getStatus()
}
interface Customer {
  -double quantity
  +float code
  #long level
  +saveTotal()
  +updateStatus()
  +findPhone()
}
Driver ..> DeliveryNote : "0..1"
DeliveryNote --* Driver
note right of Vehicle : Logistics domain
@enduml