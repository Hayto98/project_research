@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
interface Library {
  +boolean total
  #String status
  +float price
  -float description
  -boolean duration
  +setDescription()
  +updateTotal()
}
abstract class Classroom {
  -long price
  +long id
  +cancelUpdatedat()
  +sendTotal()
  +createPhone()
  +validateType()
}
class Assignment {
  -double updatedAt
  -boolean name
  -double quantity
  +sendCode()
}
class Grade {
  -Date phone
  +int duration
  +int amount
  -boolean status
  #int total
  +getQuantity()
  +saveNote()
  +sendActive()
}
Library ..> Assignment : "*"
Classroom ..|> Grade
@enduml