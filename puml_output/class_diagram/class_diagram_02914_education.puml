@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
interface Library {
  +boolean total
  #String status
  +float price
  -float description
  -boolean duration
  +setPhone()
  +processName()
}
abstract class Classroom {
  +long address
  #double email
  +setUpdatedat()
}
class Assignment {
  -long name
  #long quantity
  -float total
  +processCreatedat()
}
abstract class Grade {
  -Date phone
  +int amount
  +int status
  -boolean total
  +createDuration()
  +updateDuration()
}
Library ..> Assignment : "*"
Classroom ..|> Grade
note right of Library : Education domain
@enduml