@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Ward {
  -boolean level
  #int status
  +Date score
  #long email
  +String description
  +cancelNote()
  +processTotal()
}
class MedicalRecord {
  -String price
  -Date updatedAt
  +deletePhone()
  +saveDescription()
  +deleteUpdatedat()
}
class Billing {
  #double score
  -String createdAt
  +findId()
  +cancelCode()
}
class Nurse {
  #String note
  -String level
  #long email
  -Date amount
  +cancelPrice()
  +findId()
  +updateName()
}
class Hospital {
  -String quantity
  +double status
  +saveScore()
}
Ward --o Billing
Nurse ..> MedicalRecord : "1..*"
Ward --* Hospital
@enduml