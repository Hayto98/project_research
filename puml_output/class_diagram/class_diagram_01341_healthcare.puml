@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Ward {
  -boolean level
  #int status
  +Date score
  #long email
  +String description
  +updateNote()
  +validateDuration()
}
class MedicalRecord {
  #boolean updatedAt
  +String address
  #int code
  #double phone
  -String level
  +deleteType()
  +validateEmail()
}
abstract class Billing {
  #long amount
  -Date name
  #Date email
  -Date code
  +setDescription()
  +setQuantity()
}
class Nurse {
  -String id
  -double description
  -int note
  #long status
  #String phone
  +createEmail()
}
class Hospital {
  -boolean price
  -String score
  +double level
  #long status
  +saveAddress()
  +setDuration()
  +findName()
  +validateId()
}
Nurse ..|> Ward
Billing ..> MedicalRecord : "0..1"
note right of Ward : Healthcare domain
@enduml