@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Story {
  +float description
  -float note
  +boolean quantity
  +Date level
  +long email
  +updateAddress()
  +saveDescription()
  +deleteQuantity()
}
abstract class Notification {
  +float quantity
  -int level
  +cancelDescription()
  +calculateLevel()
}
abstract class Hashtag {
  #float name
  -int score
  +Date createdAt
  -long address
  +double price
  +cancelStatus()
  +deleteLevel()
  +validateNote()
}
interface Report {
  +int updatedAt
  +Date status
  #long phone
  +calculateActive()
  +cancelPrice()
}
class Profile {
  #int note
  +int type
  +setDuration()
  +deleteAmount()
}
Hashtag ..> Notification : "1..*"
Hashtag ..> Report : "1"
Story --|> Profile
Report --> Hashtag : "*"
note right of Story : Social Media domain
@enduml