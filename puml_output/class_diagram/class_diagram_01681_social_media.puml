@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Story {
  +float description
  -float note
  +boolean quantity
  +Date level
  +long email
  +deleteAddress()
  +setEmail()
  +updateAddress()
}
class Notification {
  -boolean quantity
  +float price
  -int code
  +savePrice()
  +validateCreatedat()
}
abstract class Hashtag {
  #double note
  #float name
  -int score
  +Date createdAt
  -long address
  +sendCode()
}
class Report {
  -double description
  #int level
  +validateEmail()
  +cancelId()
}
class Profile {
  +double amount
  #boolean address
  #double active
  +cancelStatus()
  +processTotal()
  +getDuration()
}
Profile ..|> Notification
Notification --|> Profile
@enduml