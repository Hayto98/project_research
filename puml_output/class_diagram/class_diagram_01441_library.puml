@startuml

class Reservation {
  -String amount
  +boolean duration
  -Date createdAt
  -float updatedAt
  +sendName()
  +saveName()
}
abstract class Shelf {
  #int active
  -Date address
  +float status
  +String quantity
  +deletePhone()
  +calculateCode()
}
interface Fine {
  #String id
  +int price
  -Date active
  +calculateStatus()
  +createDescription()
}
class Member {
  #Date note
  +int description
  -long type
  #Date price
  +int active
  +cancelAmount()
}
Shelf --o Fine
Reservation --|> Fine
note right of Reservation : Library domain
@enduml