@startuml

class Reservation {
  -String amount
  +boolean duration
  -Date createdAt
  -float updatedAt
  +validateStatus()
  +calculatePrice()
}
class Shelf {
  #long note
  #long active
  +getNote()
}
class Fine {
  +long createdAt
  -String id
  #float name
  +String duration
  +setDuration()
  +updateAmount()
  +sendQuantity()
  +deleteUpdatedat()
}
class Member {
  #int description
  -String type
  +saveDescription()
  +setLevel()
  +saveAddress()
}
Member --o Reservation
Member --> Shelf : "1"
Shelf --* Member
@enduml