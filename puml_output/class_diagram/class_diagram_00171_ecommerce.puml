@startuml
skinparam monochrome true
skinparam shadowing true
abstract class Payment {
  -boolean note
  #long total
  +processDuration()
  +sendDuration()
  +validateAddress()
  +setActive()
}
interface Cart {
  -Date note
  -long email
  +updateDuration()
}
interface Warehouse {
  +float active
  #int note
  -String price
  +validateDescription()
  +getName()
  +createId()
}
abstract class Review {
  #int status
  +String note
  +sendDuration()
}
Cart --|> Review
Warehouse --* Review
Payment --* Warehouse
@enduml