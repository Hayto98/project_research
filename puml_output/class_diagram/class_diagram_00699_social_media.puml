@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
abstract class Message {
  +int total
  #boolean level
  #int description
  +long id
  -String address
  +processName()
}
interface User {
  -boolean type
  #long price
  -int status
  +String email
  +long address
  +createEmail()
  +createStatus()
  +setId()
  +calculateTotal()
}
class Post {
  #double status
  -Date active
  +createAddress()
  +setActive()
  +sendDuration()
  +deletePrice()
}
class Like {
  -boolean createdAt
  -double note
  #boolean phone
  -float active
  -double description
  +validateAddress()
  +createLevel()
  +calculatePhone()
}
Message --> Like : "1..*"
User ..> Post : "1..*"
@enduml