@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class DeliveryNote {
  #String email
  +int total
  +boolean quantity
  +int createdAt
  +processQuantity()
  +calculatePhone()
  +getPrice()
  +cancelLevel()
}
class Shipment {
  -int address
  -int updatedAt
  #boolean id
  +validateTotal()
}
class Tracking {
  #float status
  -String description
  -long updatedAt
  +validateName()
}
interface FuelLog {
  +Date phone
  -long level
  +validateName()
  +cancelEmail()
  +createUpdatedat()
  +calculateId()
}
Shipment ..|> FuelLog
Tracking --o Shipment
Shipment --* Tracking
@enduml