@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class DeliveryNote {
  #String email
  +int total
  +boolean quantity
  +int createdAt
  +getQuantity()
  +updateCreatedat()
  +validateUpdatedat()
  +saveLevel()
}
class Shipment {
  #int amount
  #int address
  +int description
  +boolean name
  +setPrice()
  +createCode()
  +processScore()
  +getPhone()
}
interface Tracking {
  -double price
  +boolean address
  +calculateLevel()
}
interface FuelLog {
  -double email
  +boolean description
  -long phone
  +cancelPhone()
  +saveStatus()
}
DeliveryNote --|> Tracking
FuelLog ..|> Shipment
Tracking ..> Shipment : "0..1"
note right of DeliveryNote : Logistics domain
@enduml