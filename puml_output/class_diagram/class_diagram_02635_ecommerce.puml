@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Payment {
  +long description
  -float score
  -double code
  -String email
  -float createdAt
  +sendQuantity()
  +validateDuration()
}
class Return {
  -float id
  #double score
  -double address
  +double status
  #long level
  +cancelUpdatedat()
  +sendQuantity()
  +sendAmount()
  +getStatus()
}
class Customer {
  -String createdAt
  -int note
  -int type
  -int active
  #double address
  +deleteDuration()
  +deleteCode()
}
class Product {
  #String score
  -Date note
  +boolean duration
  -double amount
  -int address
  +updateTotal()
  +deleteDuration()
  +validateType()
}
Payment --o Product
@enduml