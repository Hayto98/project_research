@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
interface Payment {
  +int amount
  #String code
  +int id
  -boolean type
  -float email
  +calculateLevel()
  +updateActive()
}
class Housekeeping {
  -boolean email
  -String description
  #String level
  #boolean price
  +processPhone()
  +cancelEmail()
  +saveScore()
  +cancelAmount()
}
class Service {
  -int total
  #double type
  +sendCreatedat()
  +validateScore()
  +setNote()
  +processCode()
}
class Guest {
  +double score
  #long phone
  #String level
  +processActive()
}
Guest --|> Payment
Guest ..|> Housekeeping
@enduml