@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class FuelLog {
  #String total
  -boolean level
  +Date duration
  #float status
  +sendActive()
}
interface Route {
  #int total
  +Date description
  +boolean duration
  -Date id
  +cancelDescription()
  +validateQuantity()
}
abstract class Warehouse {
  +Date note
  +int score
  -String amount
  +int status
  -double type
  +calculateNote()
  +saveTotal()
  +createScore()
}
abstract class DeliveryNote {
  #double note
  #boolean id
  -boolean createdAt
  #boolean updatedAt
  +processScore()
  +getLevel()
  +saveTotal()
}
abstract class Customer {
  -boolean total
  #String address
  +String createdAt
  -boolean score
  +double description
  +sendNote()
  +processCode()
}
FuelLog --> Customer : "*"
Warehouse --|> DeliveryNote
@enduml