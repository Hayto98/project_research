@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Booking {
  +Date id
  +float total
  +saveUpdatedat()
  +cancelCode()
}
class Service {
  -double price
  -int name
  +float phone
  +calculateScore()
  +validatePhone()
  +cancelEmail()
  +updateNote()
}
class Housekeeping {
  +float createdAt
  #Date id
  -int code
  #long type
  +findType()
  +validateScore()
}
class CheckOut {
  #Date active
  -String code
  -long updatedAt
  +float quantity
  +calculateStatus()
}
class CheckIn {
  #Date name
  +String id
  +long level
  +processType()
  +processScore()
  +createDescription()
}
class Invoice {
  #Date address
  -String duration
  +boolean status
  +cancelUpdatedat()
  +getStatus()
  +deletePrice()
}
class Room {
  -double note
  #boolean amount
  -float code
  #boolean createdAt
  +sendCreatedat()
  +processDescription()
  +sendDuration()
}
Housekeeping ..> Invoice : "0..1"
Service --|> CheckOut
CheckIn --* CheckOut
Invoice --|> Service
@enduml