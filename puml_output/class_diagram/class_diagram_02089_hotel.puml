@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Invoice {
  -int address
  -long score
  +validateEmail()
  +cancelScore()
}
class Staff {
  +long updatedAt
  +boolean quantity
  +Date description
  +validateAmount()
}
interface Amenity {
  +String updatedAt
  -long phone
  #String email
  #Date duration
  +boolean price
  +validatePrice()
  +getCreatedat()
}
class Restaurant {
  -int level
  -boolean updatedAt
  +processAddress()
  +updateCreatedat()
  +cancelDescription()
  +sendEmail()
}
abstract class CheckIn {
  -long note
  +double total
  +int phone
  -double active
  -boolean duration
  +calculateAddress()
  +setUpdatedat()
}
class CheckOut {
  -boolean active
  -int duration
  +long status
  +setPrice()
  +cancelLevel()
  +setDuration()
}
Restaurant ..|> CheckOut
CheckIn --> CheckOut : "0..1"
Amenity --o CheckIn
@enduml