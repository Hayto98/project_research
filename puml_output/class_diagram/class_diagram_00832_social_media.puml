@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class User {
  +String amount
  #int updatedAt
  +Date score
  +boolean total
  +Date description
  +deleteScore()
  +createStatus()
  +processActive()
  +findUpdatedat()
}
class Follower {
  -float code
  +Date updatedAt
  +updateNote()
  +savePhone()
  +validateScore()
  +processTotal()
}
class Notification {
  -Date note
  -double duration
  +deleteEmail()
  +cancelUpdatedat()
}
class Hashtag {
  -int amount
  +double status
  #boolean price
  -long score
  +float type
  +saveActive()
  +calculateStatus()
}
interface Comment {
  -Date updatedAt
  #String score
  +boolean duration
  +boolean price
  +long createdAt
  +setId()
  +processLevel()
  +setDuration()
}
Comment --> Notification : "1"
Comment ..> Follower : "1"
Notification ..> User : "*"
Follower --* Comment
@enduml