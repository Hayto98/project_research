@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class User {
  +String amount
  #int updatedAt
  +Date score
  +boolean total
  +Date description
  +deleteScore()
  +updateDuration()
  +saveId()
  +getCode()
}
class Follower {
  -long amount
  +double note
  -double active
  #long name
  -int address
  +processAmount()
}
class Notification {
  +double duration
  #boolean price
  -long type
  +float email
  +boolean amount
  +updateScore()
  +updatePrice()
  +saveCreatedat()
  +processName()
}
class Hashtag {
  -boolean duration
  -boolean code
  #float quantity
  +sendId()
  +findScore()
  +updateName()
}
class Comment {
  +long note
  +long createdAt
  +processEmail()
  +cancelName()
  +saveEmail()
}
Notification ..|> Hashtag
Hashtag --* Notification
User ..> Notification : "1..*"
note right of User : Social Media domain
@enduml