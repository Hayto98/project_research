@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class FuelLog {
  -double price
  +double active
  #String total
  +Date status
  +updateNote()
}
class Warehouse {
  +long quantity
  #int active
  +String duration
  +boolean name
  -Date score
  +setPhone()
  +setCreatedat()
  +getCode()
  +updateTotal()
}
class Shipment {
  #long level
  #Date createdAt
  #int address
  #double score
  +getNote()
  +deleteType()
}
class Inventory {
  #String id
  +boolean phone
  #Date description
  +String createdAt
  +String amount
  +setScore()
  +setCreatedat()
}
class Route {
  +String active
  +float note
  #int description
  +int code
  +setType()
}
Shipment --|> Route
Route --o Warehouse
FuelLog --> Inventory : "1"
Shipment --> Inventory : "1..*"
@enduml