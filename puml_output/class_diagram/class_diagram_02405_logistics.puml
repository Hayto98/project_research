@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class FuelLog {
  -double price
  +double active
  #String total
  +Date status
  +sendAddress()
}
abstract class Warehouse {
  +long active
  #int quantity
  +String name
  +boolean level
  +findPrice()
  +cancelLevel()
  +validatePhone()
  +validateLevel()
}
class Shipment {
  #Date address
  #float email
  +long updatedAt
  #int type
  +getPhone()
  +deleteCreatedat()
  +cancelAmount()
  +saveId()
}
class Inventory {
  +Date status
  #int name
  -Date level
  +deleteCode()
  +getId()
  +deleteDuration()
  +updateStatus()
}
class Route {
  -float description
  +Date phone
  +processId()
  +calculateActive()
}
Shipment --> Inventory : "1..*"
Inventory ..> Shipment : "*"
note right of FuelLog : Logistics domain
@enduml