@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
interface Course {
  +long id
  +long note
  -int quantity
  +findQuantity()
}
class Exam {
  #int score
  #int phone
  +String updatedAt
  #double duration
  #Date note
  +processUpdatedat()
  +saveCreatedat()
}
abstract class Schedule {
  +long level
  #float price
  +cancelStatus()
}
interface Classroom {
  #String email
  -boolean address
  -float score
  -boolean total
  +float phone
  +findCreatedat()
}
class Library {
  #double score
  +boolean quantity
  -boolean email
  +cancelPhone()
  +processActive()
}
Schedule --|> Classroom
Exam --* Schedule
Exam --|> Library
Classroom --> Exam : "0..1"
note right of Course : Education domain
@enduml