@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
interface Course {
  +long id
  +long note
  -int quantity
  +setCreatedat()
}
class Exam {
  #int note
  #Date score
  -boolean phone
  +boolean updatedAt
  +setDuration()
  +setName()
}
class Schedule {
  #Date description
  +boolean note
  -float updatedAt
  +long createdAt
  #float price
  +sendType()
}
interface Classroom {
  -long duration
  #double note
  +cancelActive()
  +processName()
  +sendCode()
}
interface Library {
  -float address
  +Date description
  #Date id
  -long createdAt
  +setDescription()
  +processEmail()
  +sendName()
  +sendQuantity()
}
Library --o Schedule
@enduml