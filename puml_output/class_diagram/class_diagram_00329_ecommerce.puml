@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Order {
  #int level
  +String createdAt
  -long amount
  -double active
  +double address
  +deleteTotal()
  +sendCreatedat()
}
class Review {
  +Date id
  +int description
  +saveCode()
  +getActive()
  +validateAddress()
}
class Product {
  +double quantity
  +float createdAt
  -double code
  #boolean address
  -String score
  +createDescription()
  +cancelTotal()
  +processNote()
}
class Warehouse {
  #int quantity
  #double email
  +Date amount
  +deleteId()
  +calculateDuration()
  +processPhone()
  +cancelDescription()
}
class Payment {
  -int active
  +float name
  +float duration
  +processName()
  +findId()
  +createDescription()
}
abstract class Shipment {
  #boolean note
  +boolean description
  -Date status
  #Date score
  +calculateLevel()
}
Warehouse ..> Order : "0..1"
Shipment --|> Review
note right of Order : Ecommerce domain
@enduml