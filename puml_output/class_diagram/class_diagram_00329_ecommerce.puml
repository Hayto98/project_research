@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Order {
  #int level
  +String createdAt
  -long amount
  -double active
  +double address
  +findId()
  +cancelType()
}
abstract class Review {
  +String phone
  +int level
  #String score
  +cancelAddress()
  +processCreatedat()
}
class Product {
  -String active
  -long phone
  +getType()
  +createId()
}
class Warehouse {
  +float id
  -double total
  +processName()
  +findCode()
  +sendAddress()
  +getEmail()
}
interface Payment {
  -long type
  +boolean note
  +float name
  #double active
  +Date amount
  +updateType()
  +updatePrice()
  +sendScore()
  +setCreatedat()
}
interface Shipment {
  #boolean phone
  +float level
  #boolean description
  #long id
  +int updatedAt
  +createId()
}
Warehouse ..> Order : "1"
Product --o Review
Shipment --> Payment : "1..*"
Warehouse --|> Review
@enduml