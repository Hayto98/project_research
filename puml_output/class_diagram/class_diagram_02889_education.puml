@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Assignment {
  -String score
  -int code
  +String phone
  +saveCreatedat()
  +getQuantity()
  +getUpdatedat()
}
interface Teacher {
  -int total
  -double status
  -boolean active
  -Date updatedAt
  -float code
  +sendNote()
  +deleteScore()
  +calculateName()
  +sendScore()
}
class Attendance {
  +int name
  +int score
  -float type
  #long createdAt
  -int id
  +processPrice()
  +deleteAddress()
}
class Library {
  +int quantity
  -Date name
  +float description
  #float active
  #Date updatedAt
  +saveName()
}
class Classroom {
  #double address
  #String status
  #long updatedAt
  +validateAmount()
  +validateUpdatedat()
  +sendLevel()
  +cancelPrice()
}
class Exam {
  +int amount
  -String note
  +float updatedAt
  #float createdAt
  +saveDescription()
  +setUpdatedat()
  +deleteUpdatedat()
}
Teacher --o Library
Library --> Classroom : "0..1"
@enduml