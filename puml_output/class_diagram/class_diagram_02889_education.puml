@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Assignment {
  -String score
  -int code
  +String phone
  +validateDuration()
  +sendType()
  +calculateStatus()
}
interface Teacher {
  -double code
  -boolean quantity
  -Date createdAt
  +findType()
  +updateAmount()
  +validatePrice()
  +validateTotal()
}
class Attendance {
  +int score
  -float createdAt
  #long id
  -int updatedAt
  #int description
  +updateAddress()
  +calculateQuantity()
}
class Library {
  +float active
  -Date updatedAt
  +float createdAt
  +calculateEmail()
}
class Classroom {
  #String status
  #long updatedAt
  #double score
  -double note
  +validateAmount()
  +processUpdatedat()
}
interface Exam {
  +int name
  #float createdAt
  -Date total
  +cancelStatus()
}
Library --o Exam
Exam --> Classroom : "0..1"
Classroom --o Attendance
note right of Assignment : Education domain
@enduml