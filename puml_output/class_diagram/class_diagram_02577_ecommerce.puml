@startuml

class Product {
  +long amount
  +Date note
  #Date quantity
  #double active
  +findEmail()
  +deleteActive()
  +saveUpdatedat()
  +findName()
}
abstract class Invoice {
  -long total
  -float duration
  -long email
  +setCode()
}
interface Supplier {
  #float status
  #Date name
  -String duration
  +updateActive()
  +findUpdatedat()
  +getId()
}
class Shipment {
  #float active
  -String createdAt
  -String level
  +validateId()
  +findUpdatedat()
  +setScore()
}
abstract class Category {
  -double updatedAt
  -long code
  +sendUpdatedat()
}
Supplier ..|> Category
Category --> Invoice : "1..*"
Supplier ..> Product : "1..*"
Category --o Product
@enduml