@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
interface Book {
  #double description
  #long total
  #double status
  +String createdAt
  +findStatus()
  +deleteType()
  +deleteName()
}
class Classroom {
  +float type
  -String address
  -float email
  +deleteType()
  +deleteStatus()
  +updateCreatedat()
  +processActive()
}
class Enrollment {
  -long total
  +float score
  +updateName()
  +calculateStatus()
  +deleteCode()
}
class Attendance {
  +String price
  #boolean name
  +cancelPhone()
  +saveStatus()
}
class Department {
  #boolean active
  +float price
  -long type
  #boolean code
  +String updatedAt
  +deleteAmount()
}
interface Exam {
  #Date email
  +int address
  -float amount
  -long quantity
  -long duration
  +processPrice()
  +findCreatedat()
  +createPhone()
  +getDuration()
}
Attendance --* Department
Department --o Classroom
Enrollment ..|> Book
Exam --o Attendance
@enduml