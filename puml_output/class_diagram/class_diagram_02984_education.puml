@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
interface Book {
  #double description
  #long total
  #double status
  +String createdAt
  +saveEmail()
  +findUpdatedat()
  +deleteType()
}
class Classroom {
  -Date amount
  #float type
  +long code
  #String address
  +sendType()
  +validateCode()
  +validateStatus()
  +findPhone()
}
class Enrollment {
  +String price
  #boolean name
  +createAddress()
  +findTotal()
}
interface Attendance {
  -long type
  #boolean code
  +String updatedAt
  +double active
  #float status
  +createAddress()
  +findLevel()
  +findAmount()
  +createEmail()
}
interface Department {
  -long amount
  -long price
  +updateEmail()
  +setAddress()
  +calculateDuration()
  +createActive()
}
class Exam {
  #int phone
  +Date code
  #double createdAt
  -int type
  +boolean total
  +createDescription()
  +createEmail()
  +cancelDuration()
}
Attendance --|> Classroom
Attendance --> Exam : "1"
Department ..|> Classroom
Classroom ..> Book : "*"
Enrollment --o Book
note right of Book : Education domain
@enduml