@startuml
skinparam monochrome true
skinparam ArrowColor #555555
abstract class Teller {
  +int name
  -float level
  +long type
  +validateScore()
  +processEmail()
}
class Transaction {
  -long score
  +Date amount
  #String address
  +processId()
  +getId()
  +deleteUpdatedat()
}
class Account {
  #boolean description
  +float amount
  +int status
  +int total
  +sendDuration()
  +cancelCode()
  +processNote()
}
interface Transfer {
  -boolean id
  +double type
  +Date duration
  +float total
  +updateActive()
  +getNote()
  +updateTotal()
  +createCreatedat()
}
class Beneficiary {
  +Date description
  -float price
  +boolean name
  #int score
  +createLevel()
}
Account --|> Teller
Teller ..> Account : "0..1"
note right of Teller : Banking domain
@enduml