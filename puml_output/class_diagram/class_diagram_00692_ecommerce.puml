@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Coupon {
  -boolean note
  #long address
  -String createdAt
  +Date duration
  #float active
  +calculateActive()
  +validateDuration()
  +validateName()
}
abstract class Cart {
  +Date quantity
  +long score
  -boolean status
  -Date name
  +Date amount
  +updatePhone()
}
abstract class Wishlist {
  #float name
  #String total
  +createAddress()
}
interface Payment {
  +int total
  #boolean note
  +saveEmail()
  +saveUpdatedat()
}
Coupon --* Cart
Cart --> Payment : "0..1"
Wishlist ..> Cart : "1"
@enduml