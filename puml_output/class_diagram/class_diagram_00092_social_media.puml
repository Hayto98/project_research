@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Album {
  +String createdAt
  -int description
  +double total
  +boolean phone
  -Date name
  +findQuantity()
  +calculateLevel()
  +getDuration()
  +getQuantity()
}
interface Like {
  +boolean description
  #Date price
  +Date address
  #boolean note
  +findLevel()
  +updateActive()
}
abstract class Profile {
  #boolean score
  +boolean description
  -float level
  +cancelPhone()
  +validateId()
  +getName()
}
abstract class Hashtag {
  +double updatedAt
  +boolean price
  #int createdAt
  +updatePhone()
}
Hashtag ..> Album : "1..*"
Like --* Profile
Hashtag --* Like
note right of Album : Social Media domain
@enduml