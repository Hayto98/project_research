@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Album {
  +String createdAt
  -int description
  +double total
  +boolean phone
  -Date name
  +setCreatedat()
  +processCreatedat()
  +updateLevel()
  +updateEmail()
}
interface Like {
  -boolean duration
  -int name
  +calculateCreatedat()
  +getPrice()
  +deleteDuration()
  +setUpdatedat()
}
interface Profile {
  +Date duration
  #int level
  +createCode()
  +sendAmount()
  +getEmail()
  +deleteEmail()
}
interface Hashtag {
  -boolean active
  #long description
  -String total
  +setUpdatedat()
}
Like ..> Album : "*"
Hashtag --> Album : "0..1"
@enduml