@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
interface Comment {
  #float updatedAt
  #double total
  -long status
  +processUpdatedat()
  +createPhone()
  +findStatus()
}
interface Like {
  +float id
  #int price
  +deleteAmount()
  +processCreatedat()
}
abstract class Message {
  #boolean phone
  #long price
  -float active
  +String status
  +validateUpdatedat()
  +findPhone()
  +validateId()
}
class Report {
  -boolean description
  +float id
  +updateCode()
  +findAmount()
  +calculateCreatedat()
}
abstract class Follower {
  +int total
  -double address
  #long quantity
  #String name
  #long level
  +validateCreatedat()
  +sendLevel()
}
abstract class Album {
  -String address
  +Date code
  -double active
  +Date updatedAt
  #int total
  +validateActive()
  +processActive()
  +calculateTotal()
  +processName()
}
Message --o Like
Comment --o Album
Comment --* Report
Follower --> Report : "1..*"
@enduml