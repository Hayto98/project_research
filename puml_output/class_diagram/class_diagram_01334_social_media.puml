@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
interface Comment {
  #float updatedAt
  #double total
  -long status
  +deleteStatus()
  +saveActive()
  +sendCode()
}
class Like {
  -long id
  #double createdAt
  #String amount
  #boolean price
  #long note
  +getCode()
  +findActive()
  +saveAddress()
  +processDescription()
}
class Message {
  +double code
  #int description
  +calculateAddress()
  +processType()
  +calculateAddress()
}
class Report {
  +double address
  -boolean description
  +cancelCode()
  +saveAddress()
  +updateDescription()
}
abstract class Follower {
  -String address
  +Date code
  -double active
  +Date updatedAt
  #int total
  +cancelCreatedat()
  +getQuantity()
  +validateCreatedat()
  +calculateCode()
}
class Album {
  +boolean status
  -String note
  -String address
  #boolean level
  #double quantity
  +calculateScore()
  +calculatePrice()
  +sendPrice()
}
Report --o Comment
Comment --* Message
note right of Comment : Social Media domain
@enduml