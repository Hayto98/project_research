@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
abstract class Route {
  #float email
  +long description
  #String score
  +sendType()
  +cancelScore()
  +updateTotal()
  +deleteName()
}
class Tracking {
  #float type
  +double level
  -String description
  +double status
  +deleteType()
  +setNote()
  +getCreatedat()
}
interface Warehouse {
  -boolean email
  +String price
  #double amount
  +validateStatus()
  +deleteAddress()
}
class Customer {
  +Date type
  #double quantity
  +updateLevel()
  +setStatus()
  +saveUpdatedat()
}
class Shipment {
  #float code
  +double total
  #String active
  +double name
  +float quantity
  +deleteTotal()
  +setDescription()
}
interface Depot {
  +float phone
  #int address
  +String createdAt
  -double email
  -boolean name
  +saveAmount()
  +saveAddress()
}
Shipment --o Route
Shipment --|> Tracking
note right of Route : Logistics domain
@enduml