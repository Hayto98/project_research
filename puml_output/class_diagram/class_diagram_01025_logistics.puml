@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
abstract class Route {
  #float email
  +long description
  #String score
  +createUpdatedat()
  +validateUpdatedat()
  +findDescription()
  +saveActive()
}
class Tracking {
  #int description
  +float name
  #float code
  +double phone
  -String type
  +deleteId()
  +deleteDuration()
}
class Warehouse {
  +int type
  #int status
  #Date note
  +setDuration()
  +cancelPrice()
  +saveCode()
}
class Customer {
  +long duration
  +int description
  -int id
  +double total
  +saveStatus()
  +createPhone()
  +createLevel()
}
interface Shipment {
  #int score
  +float quantity
  -String updatedAt
  -Date code
  #String status
  +deleteType()
  +validateDescription()
  +createPhone()
}
abstract class Depot {
  +float status
  #int note
  +sendDescription()
  +getPhone()
}
Tracking --o Shipment
Depot --* Warehouse
@enduml