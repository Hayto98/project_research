@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class CheckIn {
  +double type
  -double email
  +Date description
  +findActive()
}
abstract class Reservation {
  -Date total
  +double level
  #boolean createdAt
  +calculateStatus()
  +sendName()
  +processTotal()
  +processCode()
}
abstract class Guest {
  -boolean status
  -Date type
  -double active
  -String note
  +double duration
  +setCreatedat()
  +getTotal()
  +sendNote()
}
interface Staff {
  #double price
  #double type
  #float id
  -int score
  #float duration
  +updateCode()
  +updateScore()
  +sendScore()
  +cancelPhone()
}
abstract class Payment {
  #float price
  -float code
  +Date note
  +float status
  +Date score
  +sendAddress()
  +sendUpdatedat()
  +setScore()
}
Reservation --|> Staff
Staff --> Reservation : "1..*"
Payment --o Staff
@enduml