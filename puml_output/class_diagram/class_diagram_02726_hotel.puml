@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class CheckIn {
  +double type
  -double email
  +Date description
  +processTotal()
}
interface Reservation {
  -Date total
  +double level
  #boolean createdAt
  +findType()
  +processId()
  +processType()
  +setType()
}
interface Guest {
  -float status
  -String total
  +double active
  -Date email
  +int price
  +calculateType()
  +getDuration()
  +getDuration()
  +calculateScore()
}
abstract class Staff {
  -double score
  -double type
  +double updatedAt
  +double total
  #float price
  +deleteId()
  +updateAddress()
  +createLevel()
  +saveUpdatedat()
}
abstract class Payment {
  #long total
  +float amount
  +sendPrice()
  +calculateQuantity()
  +sendDuration()
  +getName()
}
Reservation --> Staff : "0..1"
Staff --> Payment : "1"
note right of CheckIn : Hotel domain
@enduml