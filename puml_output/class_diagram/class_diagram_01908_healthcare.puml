@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
interface Billing {
  -boolean total
  #Date address
  #boolean level
  +float type
  -int active
  +updateAddress()
  +updateTotal()
  +setCreatedat()
}
abstract class Hospital {
  +String duration
  -float active
  +int price
  +sendLevel()
}
class Treatment {
  +String createdAt
  #boolean id
  #float score
  +saveAmount()
  +processUpdatedat()
}
class Patient {
  +long address
  #Date id
  +String active
  #double status
  +setQuantity()
  +createActive()
  +getId()
}
class Prescription {
  #boolean quantity
  -float phone
  +int total
  -int address
  -String name
  +getActive()
  +findLevel()
}
class Nurse {
  #float amount
  -boolean price
  +float type
  +createQuantity()
}
class Diagnosis {
  #long type
  -Date email
  #long level
  +updateCode()
  +saveQuantity()
  +findScore()
  +validateQuantity()
}
Patient ..> Hospital : "0..1"
Diagnosis --o Treatment
Billing ..> Treatment : "1..*"
Prescription ..|> Nurse
note right of Billing : Healthcare domain
@enduml