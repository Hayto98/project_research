@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
interface Billing {
  -boolean total
  #Date address
  #boolean level
  +float type
  -int active
  +getTotal()
  +calculateCreatedat()
  +processActive()
}
abstract class Hospital {
  +boolean createdAt
  #Date type
  +createCode()
  +calculateId()
  +getPhone()
  +setPrice()
}
class Treatment {
  #boolean duration
  #long id
  +int active
  +cancelLevel()
}
interface Patient {
  #float id
  +double score
  +long createdAt
  +validateScore()
  +processName()
  +createUpdatedat()
}
interface Prescription {
  #Date code
  +String phone
  +setTotal()
  +validateId()
  +processDescription()
  +deleteCreatedat()
}
interface Nurse {
  -long id
  -double duration
  +saveId()
  +calculateStatus()
  +findName()
}
class Diagnosis {
  +long updatedAt
  +float note
  +calculateId()
  +findDuration()
}
Treatment ..|> Hospital
Patient ..> Diagnosis : "*"
Prescription ..> Hospital : "1"
Treatment --* Nurse
Billing ..|> Nurse
Nurse --> Patient : "1..*"
@enduml