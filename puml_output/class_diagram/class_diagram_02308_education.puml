@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Library {
  #float note
  -int phone
  #long updatedAt
  +long createdAt
  -int active
  +validateStatus()
  +deleteAmount()
  +findEmail()
}
abstract class Assignment {
  -int updatedAt
  +boolean phone
  +long active
  #float description
  +updateAmount()
  +saveDuration()
  +getDescription()
  +updateName()
}
abstract class Teacher {
  #boolean score
  #double price
  #double quantity
  #int amount
  #Date email
  +getUpdatedat()
}
abstract class Student {
  +long type
  #long code
  #float quantity
  +cancelAddress()
}
Teacher ..|> Assignment
Library --|> Teacher
@enduml