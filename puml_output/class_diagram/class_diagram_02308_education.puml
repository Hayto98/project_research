@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Library {
  #float note
  -int phone
  #long updatedAt
  +long createdAt
  -int active
  +calculateTotal()
  +createUpdatedat()
  +validateActive()
}
class Assignment {
  #float description
  #Date duration
  -boolean score
  +double amount
  -boolean quantity
  +createAmount()
  +saveEmail()
  +sendActive()
  +findPrice()
}
interface Teacher {
  -String description
  #long active
  +long id
  #long note
  #float createdAt
  +createAmount()
}
interface Student {
  -int address
  -float amount
  -long id
  #float status
  +validateCreatedat()
  +getCreatedat()
  +getId()
  +setNote()
}
Library ..> Student : "*"
Student --o Library
note right of Library : Education domain
@enduml