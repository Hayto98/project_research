@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Review {
  +int address
  -int email
  #Date createdAt
  -int phone
  +double duration
  +processPhone()
  +findId()
  +getId()
}
abstract class Wishlist {
  #int score
  +String total
  +String status
  +updatePrice()
}
class Category {
  +String active
  #double code
  -Date description
  -String type
  -String phone
  +createUpdatedat()
  +getTotal()
}
abstract class Cart {
  -float type
  -double quantity
  +boolean duration
  #float total
  +calculateUpdatedat()
  +saveCode()
  +findScore()
}
Wishlist --|> Cart
Category --* Wishlist
note right of Review : Ecommerce domain
@enduml