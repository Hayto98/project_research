@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Fine {
  +boolean createdAt
  -long duration
  #Date score
  +setType()
  +sendCreatedat()
  +sendLevel()
  +processAddress()
}
class Publisher {
  #long description
  #float phone
  +processQuantity()
}
class Book {
  -Date address
  -Date note
  +long amount
  +createScore()
  +processDescription()
  +createName()
  +createQuantity()
}
interface Renewal {
  #float createdAt
  -Date phone
  #Date email
  +validateId()
  +createScore()
  +getAmount()
}
class Branch {
  -boolean score
  +Date id
  #String type
  #float createdAt
  +calculateAmount()
  +cancelQuantity()
}
Fine ..> Branch : "0..1"
Fine --> Renewal : "*"
Branch --> Book : "1..*"
note right of Fine : Library domain
@enduml