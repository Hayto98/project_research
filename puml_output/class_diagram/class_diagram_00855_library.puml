@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Fine {
  +boolean createdAt
  -long duration
  #Date score
  +getLevel()
  +validateUpdatedat()
  +getScore()
  +calculateNote()
}
interface Publisher {
  #long address
  #float description
  #Date id
  #String level
  -long phone
  +deleteDescription()
  +createUpdatedat()
  +setLevel()
}
class Book {
  -long amount
  #double email
  +float quantity
  -String name
  -long score
  +sendEmail()
  +updateId()
}
class Renewal {
  +long active
  #String quantity
  +float phone
  -Date address
  +sendAmount()
  +updatePrice()
  +findActive()
}
class Branch {
  +double score
  +boolean name
  -long level
  +String active
  +validateId()
  +getPrice()
}
Branch --> Renewal : "*"
Branch --> Book : "1..*"
Renewal --|> Publisher
Publisher --|> Branch
@enduml