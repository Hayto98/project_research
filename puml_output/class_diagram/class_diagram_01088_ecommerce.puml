@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Supplier {
  -long name
  #int total
  #String score
  -Date updatedAt
  #double code
  +findNote()
  +processName()
}
abstract class Warehouse {
  #long address
  +boolean description
  +processAmount()
  +findLevel()
  +saveName()
  +processCreatedat()
}
class Order {
  -long score
  #int type
  #String note
  -boolean duration
  +String name
  +setPhone()
  +processQuantity()
  +sendDescription()
  +validateCode()
}
abstract class Review {
  #Date note
  +long code
  -long createdAt
  +Date score
  +calculateAddress()
  +setCode()
  +findScore()
  +processType()
}
interface Product {
  -long score
  #boolean code
  +sendPrice()
  +saveTotal()
  +calculateAmount()
  +calculateId()
}
Product --> Review : "1"
Order --* Review
Supplier --* Review
@enduml