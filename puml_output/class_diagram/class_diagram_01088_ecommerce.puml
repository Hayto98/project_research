@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Supplier {
  -long name
  #int total
  #String score
  -Date updatedAt
  #double code
  +setId()
  +processStatus()
}
class Warehouse {
  -String quantity
  -int code
  -float score
  +processNote()
  +sendName()
  +createEmail()
  +findDescription()
}
class Order {
  #String duration
  +Date amount
  -Date name
  -double total
  +updateLevel()
}
class Review {
  +Date phone
  -int duration
  #long level
  +findLevel()
  +cancelStatus()
  +sendCode()
  +calculateAddress()
}
interface Product {
  #long note
  -long name
  +double phone
  -boolean total
  #float level
  +calculateActive()
  +findActive()
}
Product --* Review
Order ..|> Product
Product ..|> Warehouse
Order ..> Warehouse : "*"
note right of Supplier : Ecommerce domain
@enduml