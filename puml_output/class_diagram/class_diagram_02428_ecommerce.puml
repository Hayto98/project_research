@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
interface Coupon {
  -long phone
  -long type
  #float updatedAt
  +cancelScore()
}
class Supplier {
  +int updatedAt
  -int name
  +updateTotal()
  +saveCreatedat()
  +findCreatedat()
  +getCode()
}
class Product {
  +int description
  +boolean note
  +float duration
  -boolean level
  +boolean active
  +validateDescription()
  +updatePrice()
  +cancelId()
}
class Customer {
  -long email
  +boolean active
  +String score
  +double description
  +validateActive()
  +getPrice()
  +createId()
}
interface Wishlist {
  #boolean name
  #int email
  #long price
  #boolean quantity
  +int type
  +processAmount()
  +calculateNote()
}
Coupon --|> Customer
Wishlist --o Coupon
note right of Coupon : Ecommerce domain
@enduml