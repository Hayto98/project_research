@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
interface Coupon {
  -long phone
  -long type
  #float updatedAt
  +findUpdatedat()
}
interface Supplier {
  +float name
  -int updatedAt
  #boolean duration
  -int createdAt
  +validatePrice()
  +cancelLevel()
  +calculateTotal()
  +calculateNote()
}
class Product {
  #double code
  +double id
  +deletePrice()
  +processNote()
}
interface Customer {
  #String amount
  #long description
  -int createdAt
  +double updatedAt
  #String note
  +updateCode()
  +updateTotal()
  +processAddress()
}
class Wishlist {
  #float phone
  +String duration
  +double amount
  +validateType()
  +saveCreatedat()
  +sendQuantity()
}
Customer --|> Product
Wishlist --|> Customer
@enduml