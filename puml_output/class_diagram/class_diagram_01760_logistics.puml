@startuml
skinparam monochrome true
class Tracking {
  #int price
  #float code
  -double address
  #long score
  -double duration
  +getPrice()
}
interface Vehicle {
  +float updatedAt
  #double active
  +double amount
  -long type
  +createPhone()
  +validateDuration()
}
class Inventory {
  -boolean active
  #long note
  +Date phone
  +createStatus()
  +cancelUpdatedat()
  +deleteAddress()
}
class Warehouse {
  #float email
  #double description
  +long createdAt
  -String type
  -double amount
  +deletePrice()
  +cancelPrice()
  +createPrice()
  +findScore()
}
abstract class FuelLog {
  +String createdAt
  -boolean type
  -Date total
  +getEmail()
}
interface DeliveryNote {
  -float address
  +String createdAt
  #boolean type
  #String duration
  #String note
  +updateEmail()
  +setStatus()
}
abstract class Manifest {
  #long description
  -int quantity
  #long updatedAt
  +findLevel()
  +calculateDescription()
  +validateLevel()
  +sendQuantity()
}
FuelLog --* Vehicle
DeliveryNote ..> Warehouse : "*"
Manifest --> DeliveryNote : "1"
DeliveryNote ..|> Vehicle
DeliveryNote --o Tracking
Tracking --* DeliveryNote
note right of Tracking : Logistics domain
@enduml