@startuml
skinparam monochrome true
class Tracking {
  #int price
  #float code
  -double address
  #long score
  -double duration
  +processCode()
}
abstract class Vehicle {
  +float updatedAt
  #double active
  +double amount
  -long type
  +calculateScore()
  +findCode()
}
class Inventory {
  -double createdAt
  #Date active
  -int note
  +deleteId()
  +deleteName()
  +updateUpdatedat()
}
interface Warehouse {
  #Date amount
  -Date address
  -float phone
  +getCode()
  +validateDescription()
}
class FuelLog {
  +long amount
  -float note
  -int status
  -boolean address
  -long total
  +cancelName()
  +saveActive()
  +setNote()
  +updateType()
}
class DeliveryNote {
  #String total
  +long code
  #double status
  -int quantity
  -long type
  +validateScore()
  +setAmount()
  +getEmail()
  +calculateEmail()
}
interface Manifest {
  #Date level
  +int id
  +setDescription()
  +validateStatus()
  +updateName()
}
Vehicle ..> Manifest : "1..*"
Vehicle --* DeliveryNote
Warehouse ..> Vehicle : "1..*"
Warehouse ..> DeliveryNote : "*"
Vehicle ..> Inventory : "1..*"
@enduml