@startuml
skinparam defaultFontSize 11
class Student {
  -long price
  +boolean amount
  #boolean description
  #long address
  +String type
  +getActive()
}
class Book {
  -int updatedAt
  #String price
  +float level
  -int description
  #float address
  +findPhone()
  +cancelEmail()
  +updateCreatedat()
}
class Department {
  #long total
  +long duration
  #boolean address
  #String id
  -boolean phone
  +deletePhone()
  +processStatus()
}
abstract class Exam {
  +String name
  -String price
  +int amount
  -int code
  +setQuantity()
  +deleteUpdatedat()
  +getAmount()
  +sendCreatedat()
}
class Attendance {
  +int name
  #Date note
  -boolean active
  +long duration
  #double updatedAt
  +updateQuantity()
}
Book --|> Exam
Student ..> Attendance : "*"
Book --> Attendance : "1..*"
Student --* Book
note right of Student : Education domain
@enduml