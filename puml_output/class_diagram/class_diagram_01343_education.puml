@startuml
skinparam defaultFontSize 11
class Student {
  -long price
  +boolean amount
  #boolean description
  #long address
  +String type
  +setUpdatedat()
}
interface Book {
  +long price
  -int updatedAt
  #String duration
  +float score
  +findId()
  +validateTotal()
  +updateQuantity()
}
class Department {
  -Date level
  -Date email
  -float createdAt
  #double score
  +calculateDescription()
  +getAmount()
  +updateDuration()
}
interface Exam {
  -boolean phone
  +int updatedAt
  -double duration
  +double name
  +deleteNote()
  +cancelScore()
  +updateCode()
}
abstract class Attendance {
  -String code
  +int status
  -int level
  +processAmount()
  +setCreatedat()
  +cancelAddress()
  +sendType()
}
Book ..|> Student
Attendance ..|> Book
@enduml