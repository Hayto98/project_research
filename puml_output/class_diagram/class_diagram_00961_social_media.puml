@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Group {
  #boolean duration
  #long price
  -Date score
  #long phone
  +float createdAt
  +findStatus()
  +saveCode()
}
class Hashtag {
  #long quantity
  #int id
  +boolean createdAt
  -boolean duration
  +processDuration()
}
class Report {
  -float duration
  #Date id
  +boolean quantity
  +createScore()
  +processDescription()
}
abstract class Profile {
  +long id
  +long address
  +int updatedAt
  #String quantity
  +sendAmount()
}
class Story {
  #int address
  -int email
  +findTotal()
  +calculateId()
  +calculateLevel()
  +processPhone()
}
Group --|> Hashtag
Hashtag --|> Group
Report --> Hashtag : "1"
@enduml