@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Group {
  #boolean duration
  #long price
  -Date score
  #long phone
  +float createdAt
  +savePrice()
  +deleteAddress()
}
class Hashtag {
  #long createdAt
  #int quantity
  +cancelQuantity()
}
interface Report {
  +boolean updatedAt
  +float name
  +createScore()
  +findStatus()
  +cancelCreatedat()
}
class Profile {
  #int note
  #long quantity
  +long id
  +long address
  +deleteActive()
}
class Story {
  +long score
  -float email
  +calculateUpdatedat()
  +findPrice()
}
Profile ..|> Group
Group --|> Hashtag
note right of Group : Social Media domain
@enduml