@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
interface Shipment {
  -int note
  #long address
  #int code
  -float updatedAt
  +validateLevel()
  +sendCode()
}
interface Inventory {
  +Date email
  -long phone
  +setDescription()
  +findStatus()
  +validateStatus()
  +calculateDuration()
}
interface Manifest {
  +boolean active
  #boolean duration
  #Date level
  +cancelNote()
}
abstract class Tracking {
  #String phone
  #String updatedAt
  +float note
  +boolean address
  +validateDescription()
  +setActive()
  +saveDuration()
}
Inventory --o Manifest
Shipment ..|> Manifest
@enduml