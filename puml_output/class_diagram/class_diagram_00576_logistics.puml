@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
interface Shipment {
  -int note
  #long address
  #int code
  -float updatedAt
  +processActive()
  +setEmail()
}
class Inventory {
  +Date type
  #boolean quantity
  +boolean total
  +sendDuration()
  +cancelId()
}
class Manifest {
  #String quantity
  #String phone
  +float updatedAt
  +boolean note
  -float address
  +cancelUpdatedat()
  +saveType()
}
class Tracking {
  -double phone
  +boolean amount
  #int email
  +deleteEmail()
  +deleteCode()
  +sendCreatedat()
  +deleteScore()
}
Inventory --> Tracking : "*"
Manifest --|> Shipment
note right of Shipment : Logistics domain
@enduml