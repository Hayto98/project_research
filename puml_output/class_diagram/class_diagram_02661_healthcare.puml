}
class MedicalRecord {
  #long duration
  -boolean id
  #double note
  -int total
  -String score
  +saveQuantity()
  +deleteCreatedat()
}
Diagnosis --o Patient
Diagnosis ..> MedicalRecord : "1"
@enduml