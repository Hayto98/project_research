@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Librarian {
  +Date price
  +float total
  -float email
  +boolean note
  +createEmail()
}
abstract class Loan {
  -String email
  -boolean createdAt
  #String code
  +boolean name
  +setAmount()
  +setActive()
}
abstract class Branch {
  +int level
  #String status
  #float score
  +String phone
  +long active
  +calculateCreatedat()
}
class Catalog {
  +long quantity
  +long description
  +Date total
  +savePrice()
}
interface Author {
  +long email
  -boolean updatedAt
  +String amount
  +getUpdatedat()
  +validateScore()
  +validateType()
  +deleteEmail()
}
class Member {
  -int status
  +int amount
  +processActive()
  +sendUpdatedat()
}
class Shelf {
  #Date address
  #String email
  +double code
  +int type
  +deleteEmail()
  +findScore()
  +deleteScore()
  +setNote()
}
Shelf --* Branch
Shelf --o Member
Member --* Branch
note right of Librarian : Library domain
@enduml