@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Librarian {
  +Date price
  +float total
  -float email
  +boolean note
  +createQuantity()
}
class Loan {
  -String quantity
  -boolean email
  #String createdAt
  +boolean code
  +String name
  +getLevel()
  +findStatus()
}
interface Branch {
  +int price
  #String level
  #float status
  +String phone
  +long active
  +updateEmail()
}
class Catalog {
  -int duration
  -String amount
  +createAddress()
  +sendAddress()
  +processUpdatedat()
}
class Author {
  +long score
  -boolean createdAt
  +String email
  -String updatedAt
  #Date amount
  +findCode()
  +sendAmount()
}
class Member {
  +double amount
  +int email
  +int address
  -boolean code
  #int status
  +findTotal()
  +cancelPhone()
}
class Shelf {
  -float code
  +int type
  -int status
  -Date duration
  +saveActive()
  +deleteQuantity()
}
Loan --* Branch
Shelf --o Member
Member --* Branch
Member ..> Librarian : "0..1"
Loan --* Member
@enduml