@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Story {
  -float createdAt
  -long score
  +String status
  +findUpdatedat()
  +getCreatedat()
  +findId()
  +getNote()
}
class Profile {
  -boolean email
  #double id
  +validateType()
  +calculateScore()
  +getCode()
  +sendAddress()
}
interface Comment {
  +boolean email
  #double type
  +getActive()
  +deletePrice()
  +cancelUpdatedat()
  +getNote()
}
class Message {
  +double description
  -float amount
  #boolean code
  +cancelNote()
  +sendName()
  +processNote()
  +createLevel()
}
class Like {
  +long note
  #double phone
  +getTotal()
}
abstract class Hashtag {
  -double updatedAt
  #float phone
  +createAddress()
  +validateCreatedat()
  +validateType()
  +sendAddress()
}
class User {
  +String active
  #double address
  #long phone
  #String quantity
  +cancelQuantity()
}
Profile --* Like
Like --o Profile
note right of Story : Social Media domain
@enduml