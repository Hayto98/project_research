@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Story {
  -float createdAt
  -long score
  +String status
  +deleteTotal()
  +deleteLevel()
  +updateCreatedat()
  +sendUpdatedat()
}
class Profile {
  +float createdAt
  -String id
  +validateAmount()
}
interface Comment {
  -double email
  -double score
  +calculateDuration()
  +calculateId()
  +getType()
  +createActive()
}
interface Message {
  +boolean email
  #double type
  +updateActive()
  +createUpdatedat()
  +validateCode()
  +calculateCode()
}
interface Like {
  +int name
  +String note
  +double status
  +getName()
  +createUpdatedat()
  +cancelAmount()
}
abstract class Hashtag {
  #long active
  +double name
  -String type
  -Date note
  -Date quantity
  +updatePrice()
}
abstract class User {
  #float id
  -long updatedAt
  -long phone
  +float type
  -double total
  +setPrice()
  +sendEmail()
  +processDescription()
}
Hashtag --* Comment
Like ..|> Comment
Story --o Hashtag
User --|> Like
Story ..> Like : "1..*"
@enduml