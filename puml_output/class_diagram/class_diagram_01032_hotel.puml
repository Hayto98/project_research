@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
abstract class Guest {
  #long quantity
  -boolean price
  +boolean name
  #double createdAt
  -Date description
  +getEmail()
}
abstract class CheckOut {
  +int level
  +Date amount
  #float note
  -String duration
  +boolean type
  +calculateId()
  +findActive()
  +validateCode()
  +saveCreatedat()
}
class Restaurant {
  +long amount
  +long score
  +double status
  #Date description
  +Date quantity
  +getPhone()
}
class Payment {
  #Date level
  #boolean type
  +int status
  -boolean phone
  #Date duration
  +createDescription()
  +sendNote()
  +deletePhone()
  +calculateAddress()
}
Guest --|> CheckOut
note right of Guest : Hotel domain
@enduml