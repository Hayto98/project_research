@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
abstract class Guest {
  #long quantity
  -boolean price
  +boolean name
  #double createdAt
  -Date description
  +sendTotal()
}
class CheckOut {
  #double duration
  +int type
  +Date amount
  #float note
  -String score
  +getScore()
}
abstract class Restaurant {
  +double id
  +float active
  #String address
  +boolean code
  #long createdAt
  +processDescription()
}
class Payment {
  +Date updatedAt
  -int price
  #double code
  #double status
  +setCode()
}
Payment ..> Restaurant : "0..1"
CheckOut --> Payment : "*"
Restaurant ..|> Payment
@enduml