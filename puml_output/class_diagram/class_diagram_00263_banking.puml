@startuml
skinparam monochrome true
skinparam shadowing true
class Withdrawal {
  #float quantity
  #long note
  +createId()
}
class Customer {
  #long note
  #Date updatedAt
  #long address
  +setType()
  +findCreatedat()
  +createId()
}
class Transaction {
  -float phone
  -long quantity
  +int active
  #boolean note
  #boolean email
  +getPhone()
  +updateQuantity()
  +findUpdatedat()
  +getEmail()
}
abstract class Statement {
  #float id
  -float level
  +double createdAt
  +cancelType()
  +cancelEmail()
}
class Branch {
  #boolean note
  +double address
  +String description
  #int level
  +updateAmount()
  +deleteAmount()
  +cancelStatus()
}
Withdrawal ..> Customer : "1"
Customer --* Withdrawal
Transaction ..> Withdrawal : "0..1"
Transaction --* Statement
@enduml