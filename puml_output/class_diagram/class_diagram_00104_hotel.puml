@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Room {
  -Date status
  -float email
  #int address
  +sendTotal()
  +findPrice()
}
class Reservation {
  -int level
  +long id
  +String phone
  -int quantity
  #int total
  +cancelQuantity()
  +deleteUpdatedat()
}
class Housekeeping {
  +long description
  +float status
  +int level
  +double address
  +float type
  +getStatus()
  +createName()
}
class Invoice {
  +int active
  -int phone
  +boolean createdAt
  +long type
  +boolean total
  +validateType()
  +validateNote()
}
Housekeeping ..> Invoice : "*"
Invoice --> Housekeeping : "1..*"
Room --> Invoice : "1"
@enduml