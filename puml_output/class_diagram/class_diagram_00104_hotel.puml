@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Room {
  -Date status
  -float email
  #int address
  +getActive()
  +findStatus()
}
abstract class Reservation {
  #double phone
  -int quantity
  +createUpdatedat()
  +getNote()
}
class Housekeeping {
  -int updatedAt
  #Date note
  +String amount
  +processDescription()
  +validateStatus()
  +deleteAmount()
}
class Invoice {
  #long code
  +float updatedAt
  -double note
  +int amount
  -int price
  +sendUpdatedat()
  +validateDescription()
}
Reservation ..> Invoice : "1..*"
Invoice --> Housekeeping : "*"
note right of Room : Hotel domain
@enduml