@startuml
skinparam defaultFontSize 13
class Tracking {
  -int score
  #Date price
  +String note
  +cancelType()
  +findAddress()
  +cancelAddress()
}
abstract class Driver {
  #boolean address
  +Date score
  +setActive()
  +updateName()
  +createUpdatedat()
  +sendType()
}
class DeliveryNote {
  #float createdAt
  +boolean amount
  +createStatus()
  +sendUpdatedat()
  +calculatePrice()
  +calculateDescription()
}
class Vehicle {
  +double duration
  +int note
  +saveTotal()
  +setAmount()
  +validateActive()
  +processCreatedat()
}
class Inventory {
  #int note
  #int code
  #boolean updatedAt
  -double score
  -int phone
  +validateAddress()
  +createDescription()
  +deleteLevel()
}
abstract class Customer {
  #int code
  #double phone
  #boolean price
  +int total
  +sendCode()
  +updateScore()
  +validateId()
}
class Warehouse {
  #boolean description
  #long email
  +deletePhone()
  +updateStatus()
  +getPhone()
  +saveCode()
}
Vehicle ..|> Tracking
Tracking ..|> Driver
DeliveryNote --|> Driver
@enduml