@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Notification {
  #double note
  #float id
  -Date total
  +updateEmail()
  +processName()
}
class Post {
  #double level
  +String address
  #boolean price
  -boolean createdAt
  #double id
  +findQuantity()
  +getTotal()
}
abstract class User {
  -boolean createdAt
  #String duration
  +getPrice()
  +updateAmount()
  +findPhone()
}
interface Profile {
  -int score
  #double phone
  +updatePhone()
}
User --o Post
@enduml