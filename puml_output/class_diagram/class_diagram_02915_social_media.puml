@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Notification {
  #double note
  #float id
  -Date total
  +calculateId()
  +deleteTotal()
}
interface Post {
  -String price
  +boolean createdAt
  #double id
  #boolean active
  +deleteAddress()
  +updateNote()
  +sendId()
  +updateCreatedat()
}
class User {
  #String address
  #long description
  +updateActive()
  +processCode()
  +saveCode()
  +findPhone()
}
class Profile {
  +String address
  #Date price
  #long note
  -double duration
  #String description
  +saveActive()
  +updateCreatedat()
  +setQuantity()
}
Notification ..|> Profile
Profile --|> Post
Profile --|> Notification
note right of Notification : Social Media domain
@enduml