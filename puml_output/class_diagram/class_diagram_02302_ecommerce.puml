@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Cart {
  #long duration
  #long amount
  #double score
  +sendAddress()
  +updateType()
}
class Category {
  #Date createdAt
  +float status
  +double active
  #int price
  -Date score
  +updateDescription()
  +createEmail()
}
class Wishlist {
  #Date duration
  -String name
  #boolean updatedAt
  -String score
  -boolean address
  +findUpdatedat()
  +saveCode()
  +setCreatedat()
  +sendEmail()
}
interface Review {
  #double code
  -double note
  #boolean email
  +validateAmount()
  +updateDuration()
  +getPrice()
}
Category --|> Wishlist
Review ..> Category : "*"
Review ..> Wishlist : "1"
@enduml