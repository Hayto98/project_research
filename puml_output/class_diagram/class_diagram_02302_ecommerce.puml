@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Cart {
  #long duration
  #long amount
  #double score
  +createAmount()
  +setNote()
}
class Category {
  -Date active
  #int price
  +calculateActive()
  +deleteTotal()
}
class Wishlist {
  +int quantity
  -Date price
  #long name
  +saveDuration()
}
class Review {
  -boolean address
  -Date level
  +sendAmount()
  +setNote()
}
Review --o Category
Wishlist --|> Category
Wishlist ..> Cart : "1"
note right of Cart : Ecommerce domain
@enduml