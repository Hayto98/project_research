@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Doctor {
  +Date email
  +Date phone
  -String level
  +float price
  +cancelNote()
}
abstract class Nurse {
  #boolean code
  +boolean quantity
  +findStatus()
  +updateDuration()
  +setNote()
  +deleteStatus()
}
class Patient {
  #Date price
  -boolean code
  +Date address
  +Date amount
  +setUpdatedat()
}
class Hospital {
  +boolean code
  -String quantity
  +double note
  +long amount
  -double type
  +sendId()
  +processPrice()
  +getQuantity()
}
class Treatment {
  #float active
  -float name
  #long id
  #Date phone
  +createScore()
  +sendType()
  +saveTotal()
  +processName()
}
interface Appointment {
  -String updatedAt
  #double address
  #boolean status
  +double price
  #boolean note
  +processDuration()
  +cancelUpdatedat()
  +findUpdatedat()
  +processCode()
}
Treatment --> Doctor : "1"
Appointment --* Treatment
@enduml