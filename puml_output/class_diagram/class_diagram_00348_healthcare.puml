@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Nurse {
  -long address
  +String type
  +getActive()
}
class Prescription {
  -double updatedAt
  #int description
  -float active
  -boolean price
  +calculateUpdatedat()
}
interface Diagnosis {
  +float note
  +int amount
  #Date active
  +int email
  +calculateTotal()
  +findStatus()
  +saveType()
}
class MedicalRecord {
  #String createdAt
  +long email
  +calculatePhone()
  +findEmail()
  +saveEmail()
  +deleteActive()
}
MedicalRecord ..> Diagnosis : "0..1"
Nurse --> Diagnosis : "0..1"
Nurse --|> Prescription
@enduml