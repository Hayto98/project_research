@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
interface Driver {
  +float price
  +long duration
  -boolean id
  -boolean total
  -int level
  +findActive()
}
class FuelLog {
  #Date total
  -float name
  +calculateDuration()
  +createDuration()
}
abstract class Manifest {
  #int status
  #Date code
  +cancelDescription()
  +cancelId()
}
class Warehouse {
  +boolean note
  #Date quantity
  -long phone
  -int email
  #float price
  +validateTotal()
  +cancelTotal()
  +createActive()
  +sendId()
}
class Shipment {
  +int createdAt
  +double status
  +deleteId()
}
class Depot {
  +double code
  #Date createdAt
  +findPhone()
}
Shipment ..|> Depot
Driver ..|> FuelLog
Warehouse ..> Depot : "*"
Shipment --|> FuelLog
@enduml