@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
interface Driver {
  +float price
  +long duration
  -boolean id
  -boolean total
  -int level
  +processQuantity()
}
class FuelLog {
  -String name
  #String level
  +float phone
  #int updatedAt
  #Date price
  +findPhone()
  +setType()
}
abstract class Manifest {
  #boolean phone
  #long email
  -double price
  +boolean id
  +findId()
  +validateCreatedat()
  +getId()
  +updateStatus()
}
class Warehouse {
  -boolean name
  +Date note
  +int code
  +calculateName()
}
class Shipment {
  +float duration
  +double active
  -Date updatedAt
  #double code
  +setDescription()
  +createId()
}
class Depot {
  #double score
  #String price
  -Date name
  +deleteName()
  +sendPrice()
  +getQuantity()
  +deleteCode()
}
Driver --o Shipment
FuelLog --|> Depot
note right of Driver : Logistics domain
@enduml