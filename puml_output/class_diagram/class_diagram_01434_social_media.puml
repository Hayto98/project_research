@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
abstract class Follower {
  #long phone
  +int address
  +createActive()
}
class Hashtag {
  #int address
  -double phone
  +sendStatus()
}
class Report {
  #long active
  +double status
  -String email
  -int address
  +deleteActive()
  +findDescription()
  +findDescription()
}
abstract class Notification {
  -long code
  +long createdAt
  +getQuantity()
}
abstract class Post {
  -boolean level
  #String type
  #int note
  #float createdAt
  #int updatedAt
  +createId()
}
Follower --* Report
Report --|> Hashtag
Notification --|> Post
note right of Follower : Social Media domain
@enduml