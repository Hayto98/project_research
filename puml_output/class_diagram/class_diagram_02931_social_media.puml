@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Profile {
  +float level
  -String email
  +processTotal()
  +findTotal()
}
class Message {
  -int status
  #double description
  +validateDescription()
}
class User {
  +long score
  +double note
  #int duration
  +String code
  -String name
  +findId()
  +createAmount()
}
class Hashtag {
  +double status
  +Date createdAt
  +double price
  +int duration
  +getAddress()
  +deletePhone()
  +setDuration()
  +updateType()
}
abstract class Post {
  #Date updatedAt
  +double amount
  #long note
  +updateActive()
  +sendId()
  +findQuantity()
}
class Comment {
  +String level
  +double total
  -int id
  #long description
  #String address
  +sendCreatedat()
}
class Notification {
  -Date amount
  -long duration
  +sendType()
  +createCode()
  +processStatus()
}
Message --o Profile
Post --> Profile : "1"
User --> Message : "1..*"
Message --> Notification : "0..1"
@enduml