@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Attendance {
  +boolean status
  #int note
  -String code
  -float email
  -boolean duration
  +deleteType()
  +getPrice()
  +getPhone()
}
class Grade {
  +double address
  +int duration
  -String price
  +updateTotal()
  +validatePrice()
  +saveUpdatedat()
}
class Book {
  #boolean amount
  +float address
  +findScore()
  +cancelNote()
  +validateStatus()
  +createName()
}
interface Exam {
  +Date status
  +Date quantity
  +updateStatus()
  +getStatus()
}
class Schedule {
  -String amount
  #float note
  +updateActive()
}
interface Course {
  +float total
  #float updatedAt
  +int quantity
  +validateCode()
  +cancelName()
  +cancelPrice()
  +setUpdatedat()
}
interface Enrollment {
  #int email
  #double type
  -String duration
  +setLevel()
}
Schedule ..|> Exam
Grade --* Exam
Exam --> Enrollment : "0..1"
Grade ..> Attendance : "0..1"
note right of Attendance : Education domain
@enduml