@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Attendance {
  +boolean status
  #int note
  -String code
  -float email
  -boolean duration
  +validateCreatedat()
  +cancelPrice()
  +deleteActive()
}
class Grade {
  -double id
  +double phone
  +int quantity
  -String createdAt
  -int address
  +saveCreatedat()
  +saveCode()
  +cancelPrice()
  +processPrice()
}
class Book {
  #boolean amount
  +float address
  +cancelDescription()
  +processCreatedat()
  +calculatePrice()
  +processId()
}
abstract class Exam {
  +long status
  +Date quantity
  +Date name
  #Date duration
  +sendNote()
  +deleteQuantity()
}
class Schedule {
  +double id
  -String name
  +getTotal()
}
interface Course {
  +float total
  #float updatedAt
  +int quantity
  +calculateCreatedat()
  +findNote()
  +deleteId()
  +validateActive()
}
class Enrollment {
  -float status
  #int updatedAt
  #double amount
  -String email
  #boolean type
  +updateUpdatedat()
}
Book --o Schedule
Enrollment ..|> Grade
Exam --o Book
Exam ..|> Schedule
Grade ..> Attendance : "0..1"
Enrollment --> Exam : "1..*"
@enduml