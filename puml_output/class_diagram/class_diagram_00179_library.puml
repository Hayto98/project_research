@startuml
skinparam monochrome true
interface Member {
  #long duration
  #int createdAt
  +getDuration()
}
abstract class Reservation {
  +Date quantity
  +float amount
  -double total
  #String updatedAt
  +Date address
  +createDuration()
}
abstract class Renewal {
  +Date email
  +String updatedAt
  +findTotal()
  +deleteId()
  +updateDuration()
}
abstract class Catalog {
  +double note
  #String phone
  +int description
  #double email
  +setLevel()
  +validatePrice()
  +getPrice()
}
class Publisher {
  -float phone
  -Date status
  +String email
  +deletePhone()
  +validateName()
  +findAmount()
}
Reservation ..> Publisher : "0..1"
Reservation --> Renewal : "0..1"
Renewal --o Catalog
@enduml