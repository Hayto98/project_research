@startuml
skinparam monochrome true
interface Member {
  #long duration
  #int createdAt
  +processPrice()
}
class Reservation {
  +Date total
  +float updatedAt
  -double address
  +setName()
}
abstract class Renewal {
  +float code
  -float email
  +double updatedAt
  #long name
  -long active
  +createCreatedat()
  +calculateScore()
}
class Catalog {
  -long createdAt
  +Date active
  +deletePhone()
}
class Publisher {
  #long note
  -double price
  -Date status
  +int id
  +updatePhone()
  +cancelDuration()
}
Reservation --> Renewal : "*"
Catalog --|> Reservation
Catalog ..|> Renewal
Publisher ..|> Catalog
note right of Member : Library domain
@enduml