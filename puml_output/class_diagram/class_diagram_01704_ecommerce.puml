@startuml
skinparam ArrowColor #555555
class Supplier {
  +long total
  -float id
  +createId()
  +saveUpdatedat()
  +deletePrice()
  +createNote()
}
interface Payment {
  -boolean address
  -boolean quantity
  #double updatedAt
  -boolean id
  +processActive()
}
interface Coupon {
  -int total
  #boolean createdAt
  #boolean updatedAt
  +getQuantity()
  +processActive()
  +findEmail()
  +calculateNote()
}
abstract class Order {
  #Date id
  -double active
  +Date createdAt
  +updateScore()
}
class Warehouse {
  +boolean code
  +double price
  +double email
  +deleteName()
}
class Customer {
  +long total
  +float code
  #long amount
  #long address
  -String quantity
  +deleteDescription()
  +sendAmount()
  +updateLevel()
  +calculateTotal()
}
Payment --|> Customer
Warehouse ..|> Customer
Warehouse --* Supplier
Coupon ..|> Order
@enduml