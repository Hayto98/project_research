@startuml
skinparam monochrome true
skinparam shadowing true
class Housekeeping {
  +long createdAt
  +float quantity
  #double amount
  #boolean phone
  +saveDescription()
  +deleteDuration()
  +calculateId()
  +createUpdatedat()
}
class Staff {
  +String score
  -int price
  +createType()
  +createActive()
}
class Service {
  +float active
  #String note
  #float amount
  +boolean description
  +sendStatus()
  +calculateActive()
}
class Guest {
  #float price
  -Date total
  +processDuration()
  +getStatus()
}
Staff --|> Housekeeping
note right of Housekeeping : Hotel domain
@enduml