@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
interface Billing {
  +String price
  +float quantity
  -long phone
  +boolean name
  -Date level
  +calculatePrice()
  +processCode()
  +calculateNote()
  +validateCode()
}
abstract class Appointment {
  +double total
  #float quantity
  -Date name
  -float price
  +updateTotal()
  +deleteEmail()
  +findPrice()
  +updateCreatedat()
}
interface Nurse {
  +long updatedAt
  -String id
  #long status
  #Date phone
  +double code
  +saveType()
  +sendPrice()
  +setCreatedat()
}
interface MedicalRecord {
  +Date description
  -String note
  +getAddress()
  +sendDescription()
  +calculateId()
}
class Prescription {
  +String price
  +String active
  +getDescription()
  +validateUpdatedat()
  +calculateCode()
  +calculateUpdatedat()
}
class Insurance {
  #float code
  #Date status
  #String level
  -boolean createdAt
  +savePrice()
  +createDuration()
  +cancelPhone()
  +saveNote()
}
Prescription ..> Nurse : "1..*"
Nurse --o Billing
Prescription --* Appointment
Nurse --o MedicalRecord
@enduml