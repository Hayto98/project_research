@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Hashtag {
  #float address
  -int total
  -double price
  +calculateQuantity()
  +getPrice()
}
abstract class Notification {
  #boolean active
  #float total
  +sendTotal()
}
class Post {
  -int name
  -String code
  -String email
  +validateLevel()
  +cancelType()
  +findQuantity()
  +setQuantity()
}
class Report {
  #float code
  #String email
  +updateEmail()
  +updateCreatedat()
}
interface Story {
  #Date phone
  +long createdAt
  #float duration
  #float level
  #int price
  +setNote()
}
class Comment {
  +String code
  -long phone
  +int level
  #Date updatedAt
  +int name
  +getAmount()
  +saveScore()
  +updateDescription()
}
abstract class Message {
  #String active
  +Date score
  -boolean createdAt
  +Date name
  +Date email
  +calculateLevel()
  +getPhone()
  +findAddress()
  +getStatus()
}
Comment --> Post : "*"
Comment ..|> Notification
Post --o Message
Message ..> Story : "*"
@enduml