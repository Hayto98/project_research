@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Hashtag {
  #float address
  -int total
  -double price
  +calculateNote()
  +setActive()
}
abstract class Notification {
  +String id
  +long status
  +updatePhone()
  +setQuantity()
  +getDuration()
  +processAddress()
}
class Post {
  #float code
  #String email
  +calculateActive()
  +processPhone()
}
class Report {
  #float createdAt
  #float price
  #int id
  #String email
  +setActive()
  +processCode()
  +validateDuration()
  +cancelPhone()
}
class Story {
  -long id
  +int code
  +updatePhone()
  +savePhone()
}
class Comment {
  -boolean note
  +int active
  #double score
  #String createdAt
  #int name
  +calculateUpdatedat()
  +createAddress()
  +cancelNote()
  +saveUpdatedat()
}
class Message {
  +int phone
  #String total
  #boolean price
  -long id
  +processScore()
  +updateAmount()
  +createName()
  +setLevel()
}
Post --|> Notification
Notification ..> Hashtag : "0..1"
Story ..|> Post
Notification --* Comment
Post --o Comment
Comment --|> Hashtag
note right of Hashtag : Social Media domain
@enduml