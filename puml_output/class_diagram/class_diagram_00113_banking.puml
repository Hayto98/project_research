@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Loan {
  #boolean id
  #int amount
  #Date name
  +setId()
}
abstract class Interest {
  +boolean status
  -long phone
  -String active
  -int id
  +boolean duration
  +updateDuration()
  +validateDescription()
}
class Transfer {
  -boolean name
  -float createdAt
  -float updatedAt
  #float id
  +double type
  +setLevel()
  +setAddress()
  +findStatus()
  +sendNote()
}
interface Branch {
  +int id
  -Date amount
  #boolean phone
  +findId()
  +deleteAddress()
  +cancelName()
  +saveName()
}
class Beneficiary {
  -double total
  -double price
  #float level
  +processCreatedat()
  +deleteLevel()
  +updateScore()
  +saveDescription()
}
class Statement {
  #float updatedAt
  #Date duration
  -Date createdAt
  -Date amount
  +sendLevel()
  +findDuration()
  +updateAmount()
}
Statement ..|> Loan
Transfer ..> Interest : "0..1"
note right of Loan : Banking domain
@enduml