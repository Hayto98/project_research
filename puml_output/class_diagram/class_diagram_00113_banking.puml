@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Loan {
  #boolean id
  #int amount
  #Date name
  +getName()
}
class Interest {
  #String type
  -float duration
  +createPhone()
}
class Transfer {
  +boolean phone
  +int total
  #long id
  #Date duration
  +long description
  +updateAmount()
  +deleteNote()
  +getTotal()
  +processPrice()
}
class Branch {
  -float phone
  #double level
  +boolean total
  +long type
  #String updatedAt
  +createStatus()
  +updateType()
  +processCode()
  +validateType()
}
class Beneficiary {
  -Date amount
  +int createdAt
  -boolean email
  +Date active
  +cancelDuration()
}
class Statement {
  -double total
  -double price
  #float level
  +validateName()
  +createTotal()
  +processActive()
  +updateType()
}
Beneficiary --* Interest
Transfer ..> Interest : "0..1"
Interest --> Statement : "*"
@enduml