@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
interface Department {
  +String active
  #Date type
  -Date createdAt
  -String address
  #Date updatedAt
  +getCreatedat()
  +cancelNote()
  +validateName()
  +getDuration()
}
interface Attendance {
  +String code
  #Date address
  -boolean type
  +calculateAmount()
  +setAddress()
}
class Course {
  +long price
  -int address
  -boolean createdAt
  +boolean quantity
  -boolean level
  +cancelTotal()
  +cancelNote()
  +setPrice()
}
interface Exam {
  #String type
  +int description
  -float quantity
  +cancelTotal()
  +createTotal()
  +cancelTotal()
  +setLevel()
}
Exam ..> Course : "1..*"
Attendance --> Exam : "*"
Department --* Attendance
note right of Department : Education domain
@enduml