@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
interface Department {
  +String active
  #Date type
  -Date createdAt
  -String address
  #Date updatedAt
  +findTotal()
  +updatePrice()
  +calculateNote()
  +calculateType()
}
interface Attendance {
  -double address
  +String name
  #Date level
  -boolean createdAt
  +double code
  +validatePhone()
  +saveCreatedat()
}
class Course {
  +long price
  -int address
  -boolean createdAt
  +boolean quantity
  -boolean level
  +sendActive()
  +processAddress()
  +processLevel()
}
interface Exam {
  +Date code
  -boolean price
  +float score
  +int description
  -float type
  +findName()
  +updateEmail()
  +sendAddress()
  +processLevel()
}
Department ..> Course : "1..*"
Exam ..> Course : "1..*"
Attendance --> Exam : "*"
@enduml