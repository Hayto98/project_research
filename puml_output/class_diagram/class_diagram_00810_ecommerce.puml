@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Payment {
  +Date quantity
  #boolean code
  -Date email
  #Date active
  +String phone
  +calculateLevel()
}
abstract class Shipment {
  +int code
  +long name
  +String status
  #String duration
  #int description
  +saveUpdatedat()
  +processLevel()
  +createAmount()
}
interface Category {
  +Date email
  -boolean note
  #int active
  +long id
  -boolean score
  +cancelStatus()
  +deleteEmail()
  +sendTotal()
}
class Coupon {
  -int id
  #long createdAt
  +boolean email
  +savePhone()
}
abstract class Wishlist {
  #Date level
  #String email
  #boolean active
  #int updatedAt
  +updateId()
  +sendAmount()
  +setQuantity()
}
Coupon --> Wishlist : "0..1"
Wishlist --* Shipment
Shipment --o Wishlist
@enduml