@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
abstract class Message {
  +float status
  -long note
  -String id
  +int code
  +setActive()
  +validateAmount()
  +calculateScore()
}
abstract class Follower {
  #String status
  #int quantity
  -boolean email
  -boolean name
  +double note
  +validateScore()
  +updateLevel()
  +findDescription()
  +updateDuration()
}
class Profile {
  -boolean email
  #float active
  -long level
  #float price
  +deletePrice()
  +createName()
  +getDuration()
}
class Report {
  #Date email
  #long duration
  +long phone
  +boolean updatedAt
  +int id
  +createLevel()
  +sendCode()
  +deleteQuantity()
}
interface User {
  #int duration
  #double createdAt
  -double type
  -long description
  +Date status
  +findDescription()
  +updateQuantity()
  +findAddress()
}
abstract class Comment {
  #double phone
  -float score
  -String name
  -float address
  +String createdAt
  +calculateNote()
  +findEmail()
}
Profile ..> Follower : "0..1"
Comment --|> User
Message --* Report
@enduml