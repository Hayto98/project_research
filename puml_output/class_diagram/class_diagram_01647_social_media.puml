@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
abstract class Message {
  +float status
  -long note
  -String id
  +int code
  +createEmail()
  +savePrice()
  +saveTotal()
}
class Follower {
  #int email
  -boolean name
  -boolean note
  +double status
  +validateQuantity()
  +cancelId()
  +deleteAddress()
  +createActive()
}
interface Profile {
  #float note
  #long level
  -double active
  +double duration
  -long phone
  +updateScore()
  +saveId()
  +saveQuantity()
}
class Report {
  #double id
  +boolean status
  -boolean updatedAt
  +Date email
  +findDescription()
  +findLevel()
  +cancelStatus()
  +sendUpdatedat()
}
abstract class User {
  #long type
  #float phone
  +double email
  -long status
  +saveAddress()
}
class Comment {
  +int price
  +int type
  -int status
  #int note
  #boolean name
  +setNote()
}
User ..|> Report
Report --* Message
User --|> Comment
Report --* User
note right of Message : Social Media domain
@enduml