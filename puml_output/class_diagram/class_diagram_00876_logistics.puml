@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
abstract class Manifest {
  -Date description
  +float createdAt
  -int quantity
  +setStatus()
}
class Tracking {
  -String type
  #Date level
  +saveName()
}
class Customer {
  -String description
  #boolean updatedAt
  +double note
  #int email
  +sendAddress()
}
class Shipment {
  #long email
  +float score
  -float duration
  +int status
  -Date phone
  +deleteType()
  +sendCode()
  +setType()
}
Manifest --|> Customer
Shipment --|> Manifest
note right of Manifest : Logistics domain
@enduml