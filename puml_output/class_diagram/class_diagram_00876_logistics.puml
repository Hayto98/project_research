@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
abstract class Manifest {
  -Date description
  +float createdAt
  -int quantity
  +validateEmail()
}
class Tracking {
  +float name
  #Date type
  +Date quantity
  +updateDuration()
}
class Customer {
  -String updatedAt
  #boolean note
  +double email
  +savePhone()
  +sendDescription()
}
interface Shipment {
  +long email
  #long type
  +float duration
  -float score
  +getEmail()
}
Customer ..> Manifest : "*"
Manifest --o Shipment
Tracking ..> Manifest : "1"
@enduml