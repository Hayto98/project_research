@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Warehouse {
  +double type
  #boolean amount
  +calculateNote()
  +processStatus()
  +sendDuration()
}
class FuelLog {
  -Date id
  +String code
  -String score
  +validateType()
}
class DeliveryNote {
  -long quantity
  #long score
  #double createdAt
  +saveAddress()
  +createNote()
  +processType()
  +setAddress()
}
class Shipment {
  +int status
  #boolean createdAt
  +setUpdatedat()
  +cancelEmail()
  +validateName()
  +updateAddress()
}
interface Route {
  #float updatedAt
  +Date total
  #float amount
  +updateAddress()
}
DeliveryNote --* Shipment
FuelLog ..|> Shipment
Warehouse --* Shipment
@enduml