@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Warehouse {
  +double type
  #boolean amount
  +updatePhone()
  +saveUpdatedat()
  +cancelLevel()
}
class FuelLog {
  -Date code
  +String score
  +setId()
  +validateUpdatedat()
  +createScore()
}
interface DeliveryNote {
  -boolean type
  -double quantity
  +double score
  +saveLevel()
}
class Shipment {
  +Date createdAt
  #double updatedAt
  +setType()
}
interface Route {
  #float updatedAt
  +Date total
  #float amount
  +saveActive()
}
Shipment ..|> DeliveryNote
Route ..|> Shipment
DeliveryNote --|> Shipment
note right of Warehouse : Logistics domain
@enduml