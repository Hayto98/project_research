@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class FuelLog {
  +String amount
  -long createdAt
  +createName()
  +saveAddress()
  +findAmount()
  +cancelPrice()
}
class Vehicle {
  #float status
  -long description
  +saveStatus()
  +processPrice()
  +deleteTotal()
  +findNote()
}
abstract class Manifest {
  +int quantity
  #double address
  #boolean active
  +processPhone()
  +deleteQuantity()
}
interface Driver {
  #long email
  #float note
  -Date level
  +cancelCode()
  +sendTotal()
  +saveDuration()
  +calculateAddress()
}
class Tracking {
  #String name
  +String updatedAt
  +Date phone
  +boolean price
  +updateTotal()
}
class Package {
  -boolean score
  #long updatedAt
  -int level
  #boolean code
  +calculateQuantity()
  +validateId()
}
Driver --* Vehicle
Vehicle --* Package
Tracking --> FuelLog : "*"
Tracking ..> Package : "1"
note right of FuelLog : Logistics domain
@enduml