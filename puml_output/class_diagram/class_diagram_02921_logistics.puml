@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class FuelLog {
  +String amount
  -long createdAt
  +updateLevel()
  +savePhone()
  +cancelDuration()
  +validateScore()
}
class Vehicle {
  -double email
  #String id
  -float status
  -int description
  -Date duration
  +getPhone()
  +validateCode()
  +calculatePhone()
  +calculateCreatedat()
}
interface Manifest {
  #float updatedAt
  +double type
  -int active
  +savePrice()
  +validateCode()
  +calculateScore()
}
abstract class Driver {
  #boolean address
  -Date type
  #long level
  -long code
  +int total
  +cancelDescription()
  +deleteAmount()
  +setAddress()
}
class Tracking {
  #int code
  #String name
  +updateQuantity()
  +findAmount()
}
class Package {
  -boolean score
  #long updatedAt
  -int level
  #boolean code
  +updateEmail()
  +cancelAddress()
}
FuelLog --* Tracking
Driver --* Vehicle
Vehicle --* Package
Tracking --> FuelLog : "*"
@enduml