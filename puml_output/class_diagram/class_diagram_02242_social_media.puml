@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Group {
  #double email
  #Date id
  +validateScore()
  +getCreatedat()
  +deleteStatus()
}
interface Post {
  +float address
  #int updatedAt
  +double price
  -String type
  #double createdAt
  +sendName()
  +createCreatedat()
}
class Follower {
  #int amount
  #Date status
  +deleteEmail()
  +updateCreatedat()
}
abstract class User {
  +long duration
  +int name
  +double quantity
  -float phone
  +getActive()
}
interface Profile {
  -boolean total
  +boolean quantity
  #long code
  +updateCode()
}
Follower ..> Profile : "1..*"
User --o Profile
Group ..|> Follower
Profile ..|> Post
@enduml