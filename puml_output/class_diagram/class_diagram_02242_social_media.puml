@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Group {
  #double email
  #Date id
  +validateScore()
  +saveActive()
  +processAddress()
}
class Post {
  +double type
  -String createdAt
  #double level
  #int active
  -int description
  +cancelName()
  +deleteStatus()
  +sendUpdatedat()
}
interface Follower {
  #float price
  -Date email
  -float name
  +createCreatedat()
}
class User {
  #boolean total
  +double quantity
  -String name
  +sendCode()
  +sendActive()
  +createStatus()
}
interface Profile {
  -float phone
  +long quantity
  +boolean note
  +int price
  +getAmount()
  +setId()
  +getNote()
  +deleteActive()
}
Follower ..|> Post
Group ..> Profile : "*"
Post --* Profile
note right of Group : Social Media domain
@enduml