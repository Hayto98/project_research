@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
abstract class Service {
  -Date phone
  +boolean id
  -long score
  +deleteEmail()
  +findId()
}
class Housekeeping {
  +String level
  +String id
  +getPrice()
}
abstract class Payment {
  #double status
  #float level
  +validateUpdatedat()
  +saveScore()
}
interface CheckOut {
  +int status
  #long total
  +findActive()
}
class Invoice {
  #float code
  -double address
  #float status
  +setNote()
  +getId()
  +sendType()
}
class Booking {
  +Date address
  #float active
  -int price
  +updatePrice()
  +findCode()
  +sendCode()
}
interface CheckIn {
  #double email
  -int status
  +Date active
  -Date amount
  +int phone
  +processTotal()
  +updateTotal()
  +setStatus()
}
CheckIn --* Payment
CheckOut --* Service
Invoice --* CheckOut
Payment ..> Invoice : "1"
@enduml