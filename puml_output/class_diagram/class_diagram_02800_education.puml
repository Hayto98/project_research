@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Classroom {
  +Date address
  -boolean level
  #long name
  +processDescription()
}
class Department {
  +double active
  -float updatedAt
  +createCode()
}
class Exam {
  +String quantity
  +long total
  #String price
  +boolean amount
  +createEmail()
  +validatePrice()
  +deleteName()
}
class Schedule {
  #int level
  #long quantity
  #int address
  -float duration
  +setPrice()
  +calculateTotal()
  +cancelUpdatedat()
}
class Student {
  #float updatedAt
  +int email
  +double active
  #String type
  +deletePhone()
}
class Enrollment {
  #String price
  +int type
  #long createdAt
  +Date score
  +long name
  +cancelScore()
  +deleteActive()
  +updateId()
  +findPhone()
}
class Attendance {
  #int price
  #float createdAt
  #long description
  -double score
  #int phone
  +getStatus()
}
Enrollment --|> Student
Attendance ..> Department : "1"
Attendance --|> Schedule
@enduml