@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Classroom {
  +Date address
  -boolean level
  #long name
  +createStatus()
}
class Department {
  +int createdAt
  +long price
  -float note
  +calculateDuration()
  +deleteName()
  +setAmount()
  +validateLevel()
}
class Exam {
  +long duration
  #long phone
  #float email
  +saveQuantity()
  +sendDescription()
  +sendEmail()
}
interface Schedule {
  #float phone
  -int duration
  -Date email
  +cancelAmount()
  +deleteId()
  +calculateName()
  +setDescription()
}
abstract class Student {
  +int type
  #long createdAt
  +Date level
  +long name
  -Date status
  +findDescription()
  +getPrice()
  +calculateCreatedat()
  +saveDescription()
}
class Enrollment {
  #int createdAt
  +int email
  #boolean type
  +float note
  +findId()
  +calculateName()
}
class Attendance {
  +double active
  -Date amount
  -Date status
  +findCreatedat()
  +sendUpdatedat()
  +cancelPhone()
}
Schedule --o Exam
Student ..> Classroom : "1"
note right of Classroom : Education domain
@enduml