@startuml
skinparam monochrome true
skinparam shadowing true
interface Grade {
  +long price
  -double quantity
  #double address
  +saveActive()
  +processType()
  +saveCreatedat()
}
class Student {
  #double level
  -long email
  +updateStatus()
}
abstract class Department {
  +double phone
  +boolean address
  +createLevel()
  +saveActive()
  +deleteStatus()
}
class Teacher {
  -String type
  -long note
  +cancelId()
  +cancelDescription()
  +processLevel()
  +getTotal()
}
Department ..> Student : "1..*"
Student --|> Teacher
note right of Grade : Education domain
@enduml