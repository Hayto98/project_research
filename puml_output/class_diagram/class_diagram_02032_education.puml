@startuml
skinparam monochrome true
skinparam shadowing true
interface Grade {
  +long price
  -double quantity
  #double address
  +findStatus()
  +createUpdatedat()
  +sendCreatedat()
}
abstract class Student {
  #double createdAt
  -long name
  +float email
  +sendType()
  +updateUpdatedat()
}
abstract class Department {
  +double phone
  +boolean address
  +calculatePhone()
  +cancelActive()
  +processNote()
}
interface Teacher {
  -boolean status
  -double createdAt
  +double duration
  +getDuration()
  +getDescription()
  +findEmail()
}
Grade ..|> Department
Teacher --|> Department
@enduml