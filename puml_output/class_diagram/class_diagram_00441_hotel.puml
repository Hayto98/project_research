@startuml

class Invoice {
  #int address
  #float price
  -String createdAt
  +calculateType()
  +sendUpdatedat()
  +validateId()
  +setPrice()
}
abstract class Booking {
  -boolean amount
  +float email
  -Date note
  +sendAmount()
  +getUpdatedat()
  +deleteStatus()
  +setNote()
}
class Reservation {
  #boolean score
  -double type
  +long updatedAt
  +sendQuantity()
  +processEmail()
}
abstract class Room {
  #String name
  +String code
  +String phone
  +cancelPrice()
  +validateUpdatedat()
}
abstract class CheckOut {
  #String email
  #int active
  +updatePrice()
  +cancelActive()
  +calculateEmail()
  +cancelAddress()
}
class Guest {
  +String level
  +String id
  -long total
  -String email
  #int phone
  +getName()
}
class Housekeeping {
  #double phone
  #int updatedAt
  #int quantity
  +getEmail()
  +setType()
  +cancelEmail()
}
Room --* Invoice
CheckOut --|> Room
Invoice --* CheckOut
Guest ..> Reservation : "1"
Reservation ..|> Housekeeping
@enduml