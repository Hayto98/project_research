@startuml

class Invoice {
  #int address
  #float price
  -String createdAt
  +findStatus()
  +processDescription()
  +deleteEmail()
  +processType()
}
interface Booking {
  #float note
  #double type
  +cancelCreatedat()
  +sendType()
}
class Reservation {
  #int total
  +String description
  -Date email
  +String updatedAt
  +int price
  +updateType()
}
abstract class Room {
  #String email
  #int active
  +getLevel()
  +getQuantity()
  +deleteTotal()
  +cancelId()
}
abstract class CheckOut {
  +long phone
  -float updatedAt
  -String name
  #int amount
  +updateCreatedat()
}
class Guest {
  #int quantity
  #int active
  #long total
  +deleteStatus()
  +calculatePrice()
}
class Housekeeping {
  #long score
  #float note
  -Date code
  #boolean duration
  +validateQuantity()
}
Reservation --> Invoice : "0..1"
Room --o Housekeeping
Room ..> Guest : "0..1"
note right of Invoice : Hotel domain
@enduml