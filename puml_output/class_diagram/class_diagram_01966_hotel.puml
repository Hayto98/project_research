@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class CheckOut {
  +Date phone
  -float description
  +Date id
  +String type
  +processDescription()
  +updateType()
  +findName()
  +deleteEmail()
}
class Invoice {
  #Date total
  -boolean createdAt
  +Date email
  #float note
  +setUpdatedat()
  +calculateAmount()
  +sendAddress()
  +findActive()
}
abstract class Reservation {
  +String duration
  +Date score
  -float email
  +long status
  +float price
  +saveName()
  +updateDuration()
  +calculateAmount()
}
class Staff {
  #int total
  #int createdAt
  +int quantity
  +deleteDuration()
  +createDuration()
  +cancelScore()
}
interface Booking {
  +int createdAt
  #long active
  +int phone
  -String note
  +createAddress()
}
class Housekeeping {
  #float status
  #float description
  -long phone
  -float score
  +int note
  +validateAmount()
  +saveLevel()
  +saveDuration()
}
Booking --> Reservation : "1..*"
Invoice ..|> CheckOut
CheckOut ..> Staff : "*"
Staff ..> Reservation : "1"
note right of CheckOut : Hotel domain
@enduml