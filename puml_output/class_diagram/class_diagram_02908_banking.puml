@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Card {
  -long score
  +float id
  -int phone
  +float level
  #int email
  +createAddress()
}
abstract class Transfer {
  #long createdAt
  +boolean status
  -float level
  +int updatedAt
  +createCode()
  +getName()
}
class Deposit {
  #int phone
  #String address
  -String score
  #double code
  #float description
  +createUpdatedat()
  +getScore()
  +findActive()
}
interface Loan {
  +long phone
  -double updatedAt
  +updateActive()
  +getEmail()
  +createTotal()
  +deleteAddress()
}
Deposit --* Transfer
Loan ..|> Deposit
note right of Card : Banking domain
@enduml