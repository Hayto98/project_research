@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Card {
  -long score
  +float id
  -int phone
  +float level
  #int email
  +createQuantity()
}
class Transfer {
  #long quantity
  +boolean createdAt
  -float status
  +int score
  +long updatedAt
  +sendTotal()
}
class Deposit {
  #boolean total
  #int phone
  #int address
  #String code
  +getLevel()
  +validateTotal()
  +validateName()
  +findDuration()
}
class Loan {
  #String updatedAt
  -int id
  +long score
  -double active
  +validateNote()
  +createDescription()
  +updateDuration()
  +deleteName()
}
Loan --* Card
Transfer --o Loan
Deposit ..> Transfer : "0..1"
@enduml