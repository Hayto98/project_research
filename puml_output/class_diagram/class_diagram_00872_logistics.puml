@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
interface FuelLog {
  +double status
  -int total
  -Date id
  +boolean amount
  +processScore()
  +saveQuantity()
}
class Tracking {
  #long amount
  -Date updatedAt
  +cancelName()
  +calculateAmount()
  +setDescription()
  +createStatus()
}
class Warehouse {
  #double duration
  +double name
  +setName()
  +calculateAddress()
  +processNote()
}
class Package {
  #double level
  +float name
  +processNote()
  +createUpdatedat()
}
class Route {
  -String quantity
  +double status
  +saveTotal()
  +validateNote()
  +findTotal()
  +saveEmail()
}
Warehouse --* Tracking
Tracking --> Package : "1"
Package --> FuelLog : "1..*"
FuelLog ..|> Package
@enduml