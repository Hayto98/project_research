@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
interface Tracking {
  +String phone
  #double address
  -double score
  -long code
  +updateScore()
  +deletePrice()
}
class Vehicle {
  +boolean createdAt
  +int note
  #long id
  +processType()
  +validateDescription()
  +findCreatedat()
  +setEmail()
}
interface Package {
  +boolean address
  #long quantity
  #double status
  -String active
  +findType()
  +createScore()
  +getCode()
  +calculateNote()
}
class Route {
  -long price
  +int name
  -double phone
  -boolean address
  #Date total
  +findId()
  +createId()
  +saveDuration()
  +findActive()
}
class Customer {
  +String code
  #float updatedAt
  +Date duration
  +createQuantity()
  +createUpdatedat()
  +sendPrice()
}
interface Driver {
  -int updatedAt
  #double id
  +int name
  #String price
  #boolean createdAt
  +calculateId()
  +createNote()
  +updateStatus()
}
class Manifest {
  +double phone
  +String active
  +String description
  +sendEmail()
  +validateName()
  +cancelType()
  +createAddress()
}
Tracking --|> Route
Customer ..> Vehicle : "1..*"
Manifest ..|> Vehicle
Route --o Customer
@enduml