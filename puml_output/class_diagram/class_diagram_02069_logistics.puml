@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
interface Tracking {
  +String phone
  #double address
  -double score
  -long code
  +findNote()
  +saveName()
}
class Vehicle {
  #String note
  +boolean id
  -double level
  +createAddress()
  +cancelLevel()
  +createAddress()
  +findDuration()
}
class Package {
  #Date active
  -boolean name
  +processStatus()
  +saveScore()
  +processUpdatedat()
  +cancelCreatedat()
}
class Route {
  -long price
  +int name
  -double phone
  -boolean address
  #Date total
  +deleteLevel()
  +processUpdatedat()
  +updateCode()
  +updateCode()
}
class Customer {
  -boolean status
  #boolean email
  +updateId()
  +getPrice()
  +updateQuantity()
  +deleteDuration()
}
abstract class Driver {
  #boolean description
  -String id
  +findName()
  +deletePhone()
}
interface Manifest {
  +String id
  +boolean total
  #double updatedAt
  +processCode()
  +validateCode()
}
Tracking ..|> Customer
Driver ..|> Package
Vehicle --> Route : "*"
Customer --> Vehicle : "1"
Manifest ..|> Customer
note right of Tracking : Logistics domain
@enduml