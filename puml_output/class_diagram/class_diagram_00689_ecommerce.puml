@startuml
skinparam defaultFontSize 13
class Review {
  +double updatedAt
  +double score
  +double email
  -float note
  +long total
  +getAmount()
  +createPhone()
  +deleteUpdatedat()
  +updateQuantity()
}
interface Wishlist {
  #long type
  #long note
  +deleteLevel()
  +validateDescription()
  +validatePrice()
  +processLevel()
}
class Invoice {
  +double duration
  -int createdAt
  +int total
  -double level
  +calculateQuantity()
  +validateTotal()
  +deleteCode()
  +processAmount()
}
class Product {
  +long total
  #long id
  +deleteId()
}
Product ..> Wishlist : "0..1"
Invoice ..> Review : "0..1"
note right of Review : Ecommerce domain
@enduml