@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Invoice {
  #String score
  #String level
  +updatePrice()
}
class Coupon {
  +Date score
  #String active
  #float quantity
  +saveName()
  +saveEmail()
  +processNote()
  +saveCode()
}
class Supplier {
  -long price
  #int status
  +createId()
  +setAmount()
  +getType()
  +setUpdatedat()
}
abstract class Wishlist {
  -String type
  +int address
  #String active
  +long status
  +createPrice()
  +saveLevel()
  +getDuration()
  +setEmail()
}
class Order {
  +long id
  +String code
  -float quantity
  +long price
  +double address
  +createCode()
  +findName()
}
interface Payment {
  -Date description
  #long type
  +cancelDuration()
  +processName()
}
Invoice --* Payment
Invoice --> Order : "1..*"
@enduml