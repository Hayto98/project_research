@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
abstract class Report {
  #int id
  #Date status
  +float level
  #double type
  +int score
  +createTotal()
}
class Post {
  -String status
  +double total
  -boolean description
  +float level
  +sendType()
  +updateUpdatedat()
  +saveId()
}
abstract class Follower {
  +double level
  -boolean updatedAt
  #double duration
  +calculateType()
  +setType()
  +getPrice()
  +sendPhone()
}
class Album {
  +long address
  +String updatedAt
  +setCode()
  +saveNote()
}
Report --* Album
Post --|> Album
@enduml