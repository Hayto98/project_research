@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Booking {
  #boolean id
  #long duration
  +sendId()
  +sendName()
}
interface Room {
  #Date code
  -int note
  #boolean type
  #String address
  +findActive()
  +cancelStatus()
}
abstract class Amenity {
  -double status
  #int price
  +double phone
  -long level
  +calculateUpdatedat()
  +createAddress()
  +calculateQuantity()
  +updateAmount()
}
class Reservation {
  -Date updatedAt
  #String quantity
  +int duration
  +long type
  +deleteType()
  +createQuantity()
  +createScore()
}
Amenity --> Booking : "0..1"
Reservation --|> Amenity
Amenity --* Reservation
@enduml