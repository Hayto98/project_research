@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Interest {
  -Date active
  -double phone
  -Date code
  +String id
  +updatePhone()
  +updateTotal()
}
abstract class Teller {
  -long updatedAt
  #double note
  +int code
  +validateId()
}
class Withdrawal {
  -Date level
  +double quantity
  +boolean amount
  +double total
  -Date phone
  +processPhone()
  +saveLevel()
  +processTotal()
}
class Statement {
  +Date amount
  +double address
  +validateId()
  +cancelStatus()
}
class Account {
  +float updatedAt
  -long active
  -boolean price
  +calculateDescription()
  +findType()
  +setNote()
  +getTotal()
}
class Transaction {
  #boolean quantity
  -int email
  -int total
  +findTotal()
}
interface Card {
  -double createdAt
  +String active
  +validatePrice()
  +deletePhone()
  +updateNote()
  +cancelDuration()
}
Interest --o Transaction
Teller --> Interest : "*"
Card ..> Interest : "1"
@enduml