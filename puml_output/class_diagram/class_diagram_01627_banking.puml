@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Interest {
  -Date active
  -double phone
  -Date code
  +String id
  +savePhone()
  +calculateCreatedat()
}
class Teller {
  +float code
  #String note
  +Date email
  -float level
  -boolean description
  +deleteTotal()
  +savePhone()
  +createId()
}
abstract class Withdrawal {
  -Date level
  -float updatedAt
  -String note
  +deleteAddress()
}
class Statement {
  +float type
  -int updatedAt
  +float status
  +deleteAddress()
  +validatePhone()
  +cancelNote()
  +findTotal()
}
class Account {
  -double description
  #boolean quantity
  +updatePrice()
  +deleteLevel()
  +getDuration()
  +sendId()
}
class Transaction {
  +Date note
  -int name
  +boolean code
  -float total
  +Date createdAt
  +findScore()
}
abstract class Card {
  +String createdAt
  #String updatedAt
  +saveQuantity()
  +saveType()
  +setEmail()
}
Card --|> Teller
Teller ..> Interest : "0..1"
Interest --* Transaction
Interest --> Teller : "1"
Card --> Transaction : "1"
note right of Interest : Banking domain
@enduml