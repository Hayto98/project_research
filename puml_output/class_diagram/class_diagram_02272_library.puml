@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Librarian {
  -int name
  +int level
  +float id
  #double active
  +deleteEmail()
}
class Fine {
  #float phone
  #long score
  -String level
  +Date name
  -int note
  +setEmail()
}
class Book {
  #float quantity
  #String price
  #double name
  -float updatedAt
  +sendType()
  +setTotal()
  +calculateTotal()
}
class Member {
  -float email
  #boolean id
  -long address
  -boolean active
  +createAddress()
}
Fine --> Book : "0..1"
Member --o Book
note right of Librarian : Library domain
@enduml