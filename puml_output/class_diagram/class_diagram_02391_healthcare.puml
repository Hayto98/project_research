@startuml
skinparam shadowing true
interface Diagnosis {
  #int phone
  -Date active
  +int price
  #Date address
  -long status
  +processPrice()
  +findId()
  +sendDescription()
  +calculateAddress()
}
abstract class Appointment {
  +String email
  -double description
  +boolean price
  #String createdAt
  +getCode()
  +findPrice()
}
class Hospital {
  +int duration
  #float amount
  +String description
  +Date note
  #double address
  +processScore()
  +validateType()
  +calculateQuantity()
}
abstract class LabTest {
  -boolean score
  +int updatedAt
  +cancelName()
}
interface Treatment {
  +int note
  +boolean createdAt
  #String email
  +processEmail()
}
LabTest ..|> Hospital
LabTest --* Treatment
Appointment --> Diagnosis : "1..*"
@enduml