@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Librarian {
  -int phone
  #double duration
  #boolean description
  #long level
  +createDuration()
}
abstract class Reservation {
  +String email
  #int amount
  #float id
  +setTotal()
  +processAddress()
  +processAmount()
  +cancelId()
}
interface Shelf {
  -long id
  -String status
  +cancelDuration()
  +cancelAddress()
}
class Author {
  #boolean type
  +Date amount
  +validateActive()
  +calculateTotal()
  +cancelDuration()
}
class Renewal {
  #Date email
  -boolean name
  +boolean total
  -String updatedAt
  -String status
  +setActive()
  +processDuration()
  +updateTotal()
}
interface Member {
  -Date level
  -float createdAt
  #String quantity
  +sendDescription()
  +validatePrice()
  +updateEmail()
}
class Fine {
  +double phone
  +long updatedAt
  +setId()
  +saveScore()
}
Renewal --o Fine
Shelf ..|> Fine
Renewal --> Member : "*"
@enduml