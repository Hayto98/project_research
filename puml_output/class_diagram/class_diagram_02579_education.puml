@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
abstract class Student {
  -int status
  -boolean quantity
  #double amount
  +cancelId()
  +validateEmail()
  +calculateName()
  +processActive()
}
class Enrollment {
  #long description
  -Date total
  #long active
  -Date duration
  +boolean status
  +sendCreatedat()
}
class Assignment {
  +long description
  #float createdAt
  -boolean status
  +cancelDuration()
  +createAddress()
  +calculatePhone()
}
class Schedule {
  #double price
  -float phone
  +updateUpdatedat()
}
Schedule ..|> Student
Student ..|> Enrollment
@enduml