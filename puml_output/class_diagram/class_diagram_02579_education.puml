@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
abstract class Student {
  -int status
  -boolean quantity
  #double amount
  +validateStatus()
  +validateCreatedat()
  +updateNote()
  +deleteTotal()
}
interface Enrollment {
  #boolean status
  -double quantity
  #float total
  +sendId()
  +processPhone()
}
class Assignment {
  -boolean createdAt
  -boolean status
  #long duration
  +createEmail()
}
class Schedule {
  +boolean phone
  -double score
  +int note
  #String total
  -int name
  +updatePhone()
  +cancelDescription()
  +createPhone()
  +calculateDescription()
}
Schedule --o Enrollment
Enrollment ..|> Student
note right of Student : Education domain
@enduml