@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
abstract class Department {
  -Date createdAt
  -long id
  +createPrice()
  +createType()
  +setActive()
}
class Attendance {
  #int updatedAt
  #double active
  #long price
  #int level
  +long address
  +calculateName()
}
abstract class Course {
  +long note
  -int type
  +setActive()
  +saveScore()
  +updatePhone()
}
abstract class Teacher {
  -int code
  -int duration
  +calculateCode()
}
Attendance ..|> Course
note right of Department : Education domain
@enduml