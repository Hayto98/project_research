@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
abstract class Department {
  -Date createdAt
  -long id
  +validateDescription()
  +cancelType()
  +setPrice()
}
class Attendance {
  -Date email
  #Date type
  +boolean status
  -Date active
  #boolean quantity
  +setAddress()
  +sendEmail()
  +processNote()
}
abstract class Course {
  -String updatedAt
  #double description
  +double phone
  #Date code
  +processPrice()
  +setEmail()
  +updateEmail()
  +sendNote()
}
class Teacher {
  +long active
  -float score
  +validatePhone()
}
Course --o Department
Attendance --> Course : "1"
@enduml