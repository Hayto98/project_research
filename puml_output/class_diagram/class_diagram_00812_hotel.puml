@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Restaurant {
  #float amount
  +long note
  +long updatedAt
  #int description
  +deletePhone()
  +getPrice()
}
interface CheckIn {
  -long description
  +boolean duration
  +long price
  +float id
  #int email
  +findScore()
  +setName()
}
class Amenity {
  -Date id
  #double quantity
  -float code
  -int type
  +String email
  +deleteNote()
  +cancelNote()
  +calculateLevel()
}
class Housekeeping {
  #String note
  +int description
  -float total
  #String quantity
  +int id
  +calculateName()
}
CheckIn --* Housekeeping
Amenity --* CheckIn
@enduml