@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Warehouse {
  #Date quantity
  +float amount
  -float score
  +validateCode()
  +saveNote()
  +updateQuantity()
}
interface Invoice {
  #String email
  #Date quantity
  #int name
  +setName()
  +setType()
}
class Review {
  -String total
  +double createdAt
  +deleteId()
}
class Coupon {
  #long id
  #Date updatedAt
  +setPrice()
  +updateQuantity()
}
class Shipment {
  +double quantity
  +int duration
  +boolean level
  +float id
  +calculateCreatedat()
  +updateLevel()
  +calculateTotal()
}
interface Cart {
  +float id
  #Date updatedAt
  +setPhone()
  +cancelAmount()
}
class Customer {
  #double active
  -double updatedAt
  +double price
  -long email
  +calculateDuration()
  +cancelName()
}
Invoice --> Review : "*"
Shipment --|> Invoice
Invoice --|> Coupon
@enduml