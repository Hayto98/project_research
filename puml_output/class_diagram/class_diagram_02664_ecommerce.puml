@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Warehouse {
  #Date quantity
  +float amount
  -float score
  +deleteCreatedat()
  +cancelLevel()
  +deleteEmail()
}
class Invoice {
  +String id
  +int amount
  +calculateCreatedat()
}
abstract class Review {
  #float createdAt
  +long total
  +saveId()
}
class Coupon {
  -long description
  +int name
  -int address
  +String quantity
  +createAddress()
}
class Shipment {
  +float id
  #Date updatedAt
  +cancelScore()
  +setAddress()
}
interface Cart {
  -double price
  +double email
  -long duration
  +sendDescription()
  +deleteQuantity()
}
interface Customer {
  +long level
  #String updatedAt
  -Date id
  +int amount
  +double type
  +createTotal()
  +processQuantity()
  +sendStatus()
}
Customer --|> Invoice
Shipment --* Cart
Customer --|> Coupon
Shipment --* Invoice
note right of Warehouse : Ecommerce domain
@enduml