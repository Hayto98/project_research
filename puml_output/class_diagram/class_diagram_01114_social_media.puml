@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Like {
  +String price
  #float email
  -long total
  +cancelPrice()
}
class Post {
  -double phone
  +Date quantity
  #boolean score
  +updateCreatedat()
  +processDescription()
  +createDuration()
  +deletePhone()
}
class User {
  +String note
  +int score
  -float code
  +processAmount()
}
class Notification {
  #String name
  +int level
  +processEmail()
  +validateDuration()
  +cancelUpdatedat()
  +cancelTotal()
}
class Report {
  #String score
  -Date price
  -double amount
  -String code
  +getPrice()
}
Notification --* Post
Report ..> Like : "1"
Like ..|> Post
note right of Like : Social Media domain
@enduml