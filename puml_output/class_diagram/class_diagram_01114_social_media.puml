@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Like {
  +String price
  #float email
  -long total
  +processId()
}
abstract class Post {
  -String description
  #Date phone
  #double quantity
  +float price
  +validateName()
  +saveQuantity()
}
class User {
  -boolean phone
  +String createdAt
  +int description
  +createActive()
  +deleteLevel()
}
interface Notification {
  -String type
  +float amount
  +calculateEmail()
}
class Report {
  #int type
  -boolean email
  -int phone
  +Date updatedAt
  +double total
  +deleteDuration()
  +deleteName()
  +createPhone()
}
Like ..> Notification : "*"
Post ..> User : "1"
@enduml