@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
interface Librarian {
  #Date code
  #boolean level
  +float active
  #boolean address
  #int description
  +deleteAmount()
  +getPrice()
  +updateTotal()
}
abstract class Loan {
  +float amount
  #double quantity
  -int name
  -long total
  +findLevel()
  +cancelType()
  +cancelNote()
  +deleteAmount()
}
abstract class Branch {
  -String createdAt
  +String quantity
  -int score
  +deleteDescription()
  +createQuantity()
  +getId()
}
class Book {
  -double status
  #long phone
  +calculateUpdatedat()
}
interface Reservation {
  -long type
  #String active
  -double status
  -String level
  +getPrice()
  +validateNote()
  +createPhone()
}
class Publisher {
  #float amount
  +int quantity
  -int status
  +cancelDuration()
  +findActive()
}
interface Shelf {
  #Date description
  -Date name
  #boolean price
  #float quantity
  +updateDescription()
}
Loan --> Publisher : "0..1"
Branch --o Librarian
Shelf --> Book : "1"
Publisher --o Shelf
@enduml