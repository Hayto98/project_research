@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Customer {
  +boolean score
  -long address
  +Date name
  #float note
  -float level
  +setTotal()
  +validateCreatedat()
}
class Interest {
  +Date name
  #float amount
  -boolean address
  #boolean code
  +double duration
  +deleteNote()
  +saveTotal()
  +saveDescription()
  +processDuration()
}
interface Loan {
  -long status
  -String id
  +deleteScore()
  +createStatus()
}
class Teller {
  +long score
  -float total
  -long address
  +String amount
  +double type
  +findUpdatedat()
  +setDuration()
}
interface Statement {
  #double code
  -float updatedAt
  +sendType()
  +updateAddress()
  +setDescription()
}
interface Deposit {
  +double duration
  +long email
  +String address
  +validateActive()
  +processActive()
}
class Withdrawal {
  +boolean description
  +Date level
  -float name
  +int total
  +deleteDuration()
}
Teller --> Statement : "1"
Customer ..|> Statement
Interest --|> Loan
note right of Customer : Banking domain
@enduml