@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Customer {
  +boolean score
  -long address
  +Date name
  #float note
  -float level
  +validatePhone()
  +findAmount()
}
class Interest {
  -Date address
  +float level
  +long score
  +calculateId()
}
class Loan {
  +float level
  -float duration
  #double id
  #int total
  -boolean price
  +deleteQuantity()
}
class Teller {
  #long email
  +int total
  -boolean id
  -boolean amount
  -int active
  +sendTotal()
  +calculateName()
  +createAmount()
  +updateQuantity()
}
class Statement {
  +float status
  #int code
  +boolean amount
  #float note
  +cancelStatus()
}
class Deposit {
  +long address
  +float level
  +float phone
  #int active
  #long type
  +updateCode()
  +validateStatus()
  +findAddress()
}
abstract class Withdrawal {
  +int address
  -boolean createdAt
  +findPrice()
  +processPhone()
  +createActive()
  +validateTotal()
}
Statement ..|> Loan
Statement --o Customer
Customer --|> Statement
Deposit --|> Loan
Interest ..|> Customer
Withdrawal --o Statement
@enduml