@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Post {
  -long score
  +boolean total
  #int updatedAt
  +findUpdatedat()
  +validateAmount()
  +sendLevel()
  +validateName()
}
interface Group {
  +Date total
  -int level
  +updateScore()
}
abstract class Profile {
  +float score
  #long phone
  #double level
  +validateAmount()
  +saveId()
  +deleteActive()
}
class Album {
  #String phone
  +double score
  #int createdAt
  +cancelName()
}
class User {
  +Date price
  #double quantity
  +cancelAddress()
  +deleteAddress()
  +createNote()
  +updateUpdatedat()
}
Profile ..|> Group
User --* Post
@enduml