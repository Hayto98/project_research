@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Post {
  -long score
  +boolean total
  #int updatedAt
  +cancelEmail()
  +processDuration()
  +getTotal()
  +cancelName()
}
abstract class Group {
  #long status
  -String note
  #long description
  +validateEmail()
  +getType()
  +getCreatedat()
  +validateScore()
}
class Profile {
  #int status
  +Date type
  +setPrice()
}
interface Album {
  +String createdAt
  +Date type
  -Date total
  +int quantity
  +validateAmount()
}
class User {
  -Date description
  -double email
  -int type
  -long id
  #Date level
  +sendUpdatedat()
  +setPhone()
  +deleteDuration()
}
User ..> Album : "1"
User --|> Profile
User --* Post
note right of Post : Social Media domain
@enduml