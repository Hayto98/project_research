@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
interface DeliveryNote {
  +float total
  -String price
  +boolean level
  +getNote()
  +setNote()
  +calculateDuration()
}
interface Tracking {
  -double amount
  #boolean name
  +setAddress()
  +updateQuantity()
  +calculateCode()
  +sendAddress()
}
abstract class Depot {
  #String total
  -boolean createdAt
  +boolean quantity
  -Date score
  +findUpdatedat()
  +cancelId()
  +createUpdatedat()
}
class Inventory {
  -String createdAt
  -float id
  -String price
  +updateLevel()
  +updateAddress()
  +deleteQuantity()
  +findUpdatedat()
}
class Route {
  #int address
  -String price
  #double status
  +boolean score
  -float active
  +cancelName()
  +setDescription()
  +saveDuration()
  +findQuantity()
}
class Shipment {
  -Date level
  #String type
  +float phone
  +findAmount()
  +getName()
  +setStatus()
  +updateQuantity()
}
DeliveryNote ..> Route : "1"
Depot --|> Route
Depot --> DeliveryNote : "1..*"
@enduml