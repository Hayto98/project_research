@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Assignment {
  -Date active
  -float score
  -String amount
  #String duration
  +createDescription()
  +getName()
  +calculateQuantity()
  +createQuantity()
}
class Department {
  #int updatedAt
  #String type
  #long total
  -float duration
  +updatePhone()
  +calculateCode()
  +saveType()
  +updateName()
}
abstract class Attendance {
  +double address
  #boolean active
  +Date code
  +setAddress()
  +calculateCode()
}
class Schedule {
  -float score
  +boolean address
  +updateLevel()
  +calculateTotal()
  +setActive()
  +deleteUpdatedat()
}
Department --o Schedule
Schedule --* Assignment
note right of Assignment : Education domain
@enduml