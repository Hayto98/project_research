@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Assignment {
  -Date active
  -float score
  -String amount
  #String duration
  +updateLevel()
  +saveTotal()
  +findPhone()
  +findLevel()
}
class Department {
  -long price
  +long quantity
  +findActive()
  +sendLevel()
}
abstract class Attendance {
  #long description
  -float level
  #boolean status
  +updateDescription()
  +cancelId()
  +sendScore()
  +cancelLevel()
}
class Schedule {
  #String updatedAt
  +double name
  #boolean price
  +Date description
  +String address
  +sendScore()
  +getLevel()
  +sendPrice()
}
Assignment --* Attendance
Schedule --> Assignment : "*"
Department --o Attendance
@enduml