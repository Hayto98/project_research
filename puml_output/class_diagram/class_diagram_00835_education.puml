@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Book {
  +long amount
  -boolean duration
  +double note
  -long code
  +saveUpdatedat()
}
class Attendance {
  +String price
  -float note
  #float level
  #int name
  #double id
  +findUpdatedat()
}
interface Course {
  #boolean price
  -Date address
  +sendName()
  +saveUpdatedat()
  +updateAddress()
  +findCode()
}
abstract class Grade {
  #int status
  +int level
  +deleteActive()
}
interface Library {
  +double phone
  -boolean quantity
  +boolean total
  +float address
  #double status
  +updateCreatedat()
}
class Department {
  #boolean active
  +double note
  -String code
  +String description
  -long id
  +deleteNote()
  +deleteAmount()
  +updateAddress()
}
interface Exam {
  -boolean total
  #double level
  +float email
  -String id
  +setLevel()
  +saveUpdatedat()
  +sendScore()
  +getType()
}
Grade ..> Book : "0..1"
Library --|> Course
Exam --|> Book
@enduml