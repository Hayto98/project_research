@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Book {
  +long amount
  -boolean duration
  +double note
  -long code
  +saveEmail()
}
interface Attendance {
  +String price
  -float note
  #float level
  #int name
  #double id
  +cancelDuration()
}
class Course {
  #Date address
  -float active
  -String quantity
  +boolean total
  #int type
  +deleteStatus()
}
abstract class Grade {
  +double phone
  -boolean quantity
  +boolean total
  +float address
  #double status
  +getLevel()
}
abstract class Library {
  -String code
  +String description
  -long id
  #float score
  #boolean price
  +getPrice()
  +saveLevel()
  +findAddress()
}
abstract class Department {
  -String id
  -int price
  #double total
  +Date description
  +processCode()
  +saveUpdatedat()
}
interface Exam {
  -boolean name
  +boolean duration
  -boolean level
  -float email
  +getDescription()
}
Library --> Department : "*"
Course ..|> Library
note right of Book : Education domain
@enduml