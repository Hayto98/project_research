@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Staff {
  +boolean score
  -long status
  #String quantity
  -double name
  +saveEmail()
  +deleteDescription()
  +setActive()
  +updateQuantity()
}
class Reservation {
  -Date level
  #int phone
  #long address
  +saveStatus()
  +getCode()
}
interface CheckOut {
  -int address
  #long createdAt
  +setEmail()
  +saveQuantity()
  +createDuration()
}
abstract class Booking {
  #long phone
  +Date updatedAt
  #String id
  +deleteDuration()
  +processName()
  +deleteUpdatedat()
}
class Payment {
  +float id
  -Date quantity
  #boolean email
  +String description
  #float price
  +deleteCode()
}
Payment --|> CheckOut
Staff --> CheckOut : "0..1"
Booking --> Reservation : "*"
@enduml