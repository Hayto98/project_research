@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
abstract class Doctor {
  -String code
  #double quantity
  -Date level
  +cancelQuantity()
  +createQuantity()
  +createUpdatedat()
}
class Billing {
  -boolean note
  -boolean phone
  #double status
  +getNote()
  +cancelStatus()
  +cancelCode()
}
class Nurse {
  -double note
  +Date name
  +long quantity
  +double level
  #float total
  +deleteType()
  +cancelQuantity()
  +processCode()
  +createCreatedat()
}
class Ward {
  -long amount
  -long code
  +updateDuration()
}
class Hospital {
  +String email
  #long price
  -long score
  +boolean updatedAt
  -double level
  +processTotal()
  +deleteType()
}
class Treatment {
  -int status
  +float updatedAt
  +double phone
  +createUpdatedat()
  +getEmail()
  +setType()
  +calculateType()
}
Treatment --* Ward
Hospital --|> Ward
Doctor --* Ward
Treatment ..|> Nurse
@enduml