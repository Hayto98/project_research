@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Hashtag {
  -long total
  +float description
  #String name
  -Date createdAt
  -boolean level
  +sendPhone()
  +getStatus()
  +getCode()
}
class Report {
  #String email
  +String amount
  +cancelId()
  +createId()
  +getScore()
  +setAddress()
}
class Profile {
  -String active
  #Date createdAt
  +validateScore()
}
interface Follower {
  -Date score
  -float address
  +deletePrice()
  +setId()
  +setQuantity()
}
class Story {
  +long id
  -int name
  +saveDescription()
}
class User {
  +Date level
  #int type
  +deleteName()
}
class Like {
  +double address
  #int id
  +double price
  +findUpdatedat()
}
Follower --o Profile
Like --|> User
Story --* User
note right of Hashtag : Social Media domain
@enduml