@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Hashtag {
  -long total
  +float description
  #String name
  -Date createdAt
  -boolean level
  +updateNote()
  +deleteCode()
  +setName()
}
class Report {
  +float code
  -int address
  +createPhone()
}
class Profile {
  #String level
  #long id
  #String email
  +boolean duration
  +long active
  +cancelType()
}
interface Follower {
  #Date phone
  +float score
  +processTotal()
  +cancelDuration()
  +createDuration()
}
class Story {
  +long price
  -String status
  +String id
  +setTotal()
}
abstract class User {
  -String duration
  #double name
  +Date description
  +processName()
  +processUpdatedat()
}
class Like {
  -int updatedAt
  -float address
  #int id
  +updateEmail()
}
User --* Report
Follower --o Profile
@enduml