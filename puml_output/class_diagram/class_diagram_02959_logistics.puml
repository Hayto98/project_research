@startuml

interface Package {
  -long duration
  -boolean quantity
  -float email
  +deleteCreatedat()
  +createEmail()
  +calculatePrice()
}
class Vehicle {
  +float active
  -String status
  -double total
  #boolean id
  -float updatedAt
  +updateLevel()
  +saveUpdatedat()
}
class Tracking {
  #boolean id
  +float amount
  -String active
  -double total
  +getStatus()
  +createNote()
}
class Route {
  #boolean createdAt
  +Date amount
  +findActive()
}
class DeliveryNote {
  -boolean id
  -Date phone
  -Date total
  #float amount
  +updateTotal()
}
class Shipment {
  #float address
  #double status
  +sendNote()
  +calculatePrice()
  +updateAmount()
  +updatePrice()
}
class Depot {
  #String price
  #double name
  +setLevel()
}
Tracking --> DeliveryNote : "1"
DeliveryNote --o Tracking
Shipment --* DeliveryNote
Tracking --> Vehicle : "1"
note right of Package : Logistics domain
@enduml