@startuml

interface Package {
  -long duration
  -boolean quantity
  -float email
  +createCreatedat()
  +updateAmount()
  +processCreatedat()
}
class Vehicle {
  -boolean email
  #String total
  -Date price
  +float name
  +deleteAddress()
  +saveStatus()
}
class Tracking {
  #boolean quantity
  -float note
  +cancelNote()
  +processEmail()
}
class Route {
  #boolean phone
  #double id
  #boolean amount
  +float active
  +savePhone()
  +cancelAddress()
  +saveAmount()
}
class DeliveryNote {
  -int status
  +int quantity
  +calculateActive()
  +processCreatedat()
}
interface Shipment {
  #boolean active
  #long status
  +getActive()
  +processCode()
  +updateTotal()
}
abstract class Depot {
  #double quantity
  #boolean score
  +float note
  +updateQuantity()
  +getPhone()
}
Package --|> Tracking
Shipment --o Depot
@enduml