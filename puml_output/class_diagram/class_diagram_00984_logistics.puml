@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Warehouse {
  +float amount
  #String description
  +long active
  #float code
  +getCode()
  +saveAmount()
  +validateActive()
  +processScore()
}
class Tracking {
  +int status
  #float address
  +String price
  +validateScore()
  +validatePhone()
  +createDuration()
}
class DeliveryNote {
  -String address
  -String createdAt
  +int id
  #String name
  +validateQuantity()
  +setScore()
  +getQuantity()
  +validateDuration()
}
class FuelLog {
  #double quantity
  +String updatedAt
  +int score
  +int phone
  -boolean code
  +cancelPrice()
  +saveActive()
  +createAddress()
}
class Driver {
  +double phone
  #long updatedAt
  +String active
  +processUpdatedat()
}
DeliveryNote --> Driver : "1..*"
Driver --o DeliveryNote
Warehouse ..> FuelLog : "1"
@enduml