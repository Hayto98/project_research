@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
abstract class Message {
  #int type
  +String code
  -float amount
  -double price
  +updateNote()
  +validateActive()
  +validateLevel()
}
class Follower {
  +String note
  #boolean createdAt
  +findName()
  +calculateUpdatedat()
}
abstract class Comment {
  #boolean code
  -String total
  +setCreatedat()
  +findId()
  +calculateDescription()
}
interface User {
  #String status
  +double name
  +deleteStatus()
  +deleteId()
  +getPhone()
  +saveCreatedat()
}
class Album {
  +long code
  -double address
  +cancelQuantity()
}
class Notification {
  #long status
  -float updatedAt
  +int active
  -double price
  +calculateQuantity()
}
class Post {
  -boolean score
  -long id
  #float amount
  -Date createdAt
  +float total
  +getName()
  +getEmail()
  +findPhone()
}
Follower --o Notification
Post ..> Comment : "*"
@enduml