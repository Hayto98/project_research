@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
abstract class Renewal {
  #float active
  -float description
  #float quantity
  -double price
  +String name
  +validateCreatedat()
  +processPrice()
  +cancelStatus()
  +saveLevel()
}
class Member {
  -double quantity
  #Date id
  +getCode()
  +createAmount()
  +calculateDescription()
  +processTotal()
}
abstract class Shelf {
  +String score
  #double quantity
  +updateDuration()
  +getDescription()
  +createCreatedat()
  +processCode()
}
interface Branch {
  #Date description
  +String score
  +String createdAt
  #Date name
  +findQuantity()
  +findScore()
  +saveActive()
}
Branch ..> Shelf : "0..1"
Renewal ..> Member : "*"
@enduml