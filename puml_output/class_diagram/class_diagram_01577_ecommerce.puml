@startuml
skinparam monochrome true
skinparam ArrowColor #555555
interface Payment {
  #boolean note
  #Date price
  -int description
  -long email
  +saveDuration()
  +processStatus()
  +cancelTotal()
  +validateNote()
}
abstract class Wishlist {
  #double quantity
  -long status
  #double level
  #boolean description
  +Date name
  +calculateQuantity()
  +cancelType()
  +cancelUpdatedat()
}
interface Customer {
  -String status
  #boolean updatedAt
  +validateUpdatedat()
  +setDescription()
  +cancelEmail()
  +findEmail()
}
class Category {
  #float quantity
  +double amount
  -boolean updatedAt
  +float description
  +validateType()
  +saveAmount()
}
abstract class Return {
  -int price
  -long active
  #float code
  +cancelAddress()
  +sendQuantity()
  +calculateAddress()
  +cancelQuantity()
}
class Review {
  #int name
  #long level
  #long address
  -Date note
  +boolean updatedAt
  +saveLevel()
}
class Shipment {
  -Date note
  +int duration
  #long name
  -int code
  +String description
  +cancelQuantity()
  +setPrice()
}
Return ..|> Wishlist
Category --|> Wishlist
@enduml