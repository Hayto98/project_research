@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
interface Wishlist {
  +boolean description
  #String quantity
  +processNote()
  +setActive()
  +sendName()
  +findPrice()
}
class Category {
  -long id
  -String updatedAt
  +calculateCode()
  +findNote()
  +updateScore()
}
interface Shipment {
  #double score
  +int phone
  +boolean name
  +sendDescription()
  +deleteDuration()
}
class Order {
  +int total
  -double id
  -float level
  +validateCreatedat()
  +deleteAmount()
  +setCreatedat()
}
class Payment {
  +long active
  +int duration
  -double amount
  -float createdAt
  +float quantity
  +sendCode()
  +saveNote()
}
Order ..> Category : "*"
Wishlist --|> Shipment
Payment --> Shipment : "0..1"
Wishlist ..> Order : "1..*"
@enduml