@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
abstract class CheckOut {
  #float email
  -float address
  +double createdAt
  -float description
  #long active
  +saveUpdatedat()
  +findScore()
}
abstract class Amenity {
  -String price
  -Date amount
  -boolean status
  -long note
  #int score
  +createAmount()
  +createEmail()
  +calculateAmount()
  +updateTotal()
}
abstract class Housekeeping {
  +Date price
  -String duration
  #Date note
  +double email
  -String type
  +createQuantity()
}
class Guest {
  #Date status
  +double code
  -int duration
  #int active
  #double description
  +getDuration()
  +calculateDescription()
  +cancelDuration()
}
class Staff {
  -String createdAt
  +int address
  #String id
  +createScore()
  +updateDescription()
  +calculateActive()
  +findPrice()
}
class Invoice {
  #long description
  +boolean createdAt
  +long code
  +String type
  +calculateNote()
}
Amenity --|> Invoice
Invoice --|> CheckOut
CheckOut --|> Amenity
@enduml