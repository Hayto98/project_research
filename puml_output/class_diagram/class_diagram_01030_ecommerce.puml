@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
abstract class Return {
  -Date status
  -int code
  -String active
  -boolean id
  +saveId()
  +getQuantity()
  +deleteStatus()
}
class Wishlist {
  -long description
  +int createdAt
  +long id
  +updateNote()
  +findCreatedat()
  +processCreatedat()
  +cancelAddress()
}
class Supplier {
  +float id
  -double updatedAt
  +validateAmount()
  +setDuration()
  +cancelPrice()
  +validateId()
}
interface Warehouse {
  +float email
  #boolean description
  +Date price
  +getUpdatedat()
  +processId()
  +updatePhone()
  +cancelUpdatedat()
}
class Cart {
  +Date total
  +String level
  -boolean type
  #float createdAt
  +int updatedAt
  +updateAddress()
}
Return ..> Supplier : "0..1"
Wishlist ..> Cart : "*"
Supplier --> Return : "1..*"
note right of Return : Ecommerce domain
@enduml