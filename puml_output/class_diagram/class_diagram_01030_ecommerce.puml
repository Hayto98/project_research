@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
abstract class Return {
  -Date status
  -int code
  -String active
  -boolean id
  +processNote()
  +sendTotal()
  +savePhone()
}
class Wishlist {
  #int status
  +String name
  -long createdAt
  +findPhone()
}
class Supplier {
  #int duration
  -Date note
  #int updatedAt
  #long level
  +calculateEmail()
  +calculateUpdatedat()
}
class Warehouse {
  #float updatedAt
  -long total
  +String level
  +processStatus()
  +findEmail()
  +updateDuration()
  +cancelScore()
}
interface Cart {
  +float email
  #boolean description
  +Date price
  +createNote()
  +updatePrice()
  +createScore()
  +validateName()
}
Return ..> Wishlist : "1..*"
Cart --|> Wishlist
Warehouse --> Cart : "*"
Wishlist --|> Cart
@enduml