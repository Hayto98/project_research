@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Loan {
  -Date code
  #long quantity
  -Date id
  +findDescription()
  +calculateUpdatedat()
  +calculateLevel()
}
class Catalog {
  #float phone
  #double score
  +processType()
  +getEmail()
}
class Shelf {
  -int price
  #int score
  -Date note
  +deleteStatus()
  +saveCreatedat()
  +findPhone()
  +cancelNote()
}
class Librarian {
  #String address
  +String quantity
  +sendPhone()
  +validateType()
  +calculateName()
  +findTotal()
}
class Reservation {
  +boolean price
  -String level
  +double status
  -String amount
  +saveAmount()
  +sendCreatedat()
  +updateAddress()
}
class Member {
  +double description
  +float quantity
  -float note
  -boolean createdAt
  -boolean price
  +sendActive()
  +validateScore()
  +setNote()
}
Catalog --o Loan
Member ..> Catalog : "0..1"
Reservation --|> Shelf
Reservation ..|> Librarian
Loan --|> Reservation
note right of Loan : Library domain
@enduml