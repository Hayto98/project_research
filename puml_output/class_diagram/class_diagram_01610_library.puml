@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Loan {
  -Date code
  #long quantity
  -Date id
  +createLevel()
  +validateType()
  +validateCode()
}
abstract class Catalog {
  +Date total
  #Date level
  #long name
  +validateQuantity()
  +sendCode()
  +deleteActive()
  +setUpdatedat()
}
class Shelf {
  #double active
  -int amount
  #int price
  +cancelLevel()
  +deleteType()
  +createTotal()
}
abstract class Librarian {
  #double status
  +Date createdAt
  +Date phone
  +getNote()
  +deleteDescription()
  +validatePhone()
}
class Reservation {
  -long note
  -float score
  +getDescription()
  +updateId()
  +processQuantity()
  +calculateStatus()
}
abstract class Member {
  #boolean address
  +int price
  +getQuantity()
  +calculateAmount()
}
Catalog --* Librarian
Loan ..> Shelf : "0..1"
@enduml