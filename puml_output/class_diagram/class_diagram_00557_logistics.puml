@startuml
skinparam shadowing true
interface Depot {
  -float phone
  -String email
  -boolean total
  +double name
  +saveLevel()
  +processType()
  +deleteId()
  +cancelStatus()
}
interface Vehicle {
  +boolean phone
  -long address
  #float type
  +String name
  #long code
  +getStatus()
}
interface Inventory {
  -float score
  -double duration
  #boolean amount
  +updateAmount()
  +validateUpdatedat()
  +sendDuration()
  +updateQuantity()
}
class Shipment {
  #boolean description
  #String active
  #boolean quantity
  +deletePrice()
  +updateCode()
  +createType()
  +setNote()
}
class Package {
  #boolean name
  #double level
  -float email
  -double type
  -double address
  +sendActive()
}
class Manifest {
  #String createdAt
  #boolean id
  +int description
  +getLevel()
  +deletePrice()
  +cancelLevel()
  +setScore()
}
class Route {
  +String level
  -String email
  +Date score
  #Date duration
  +updateId()
  +validateName()
  +createPhone()
  +setQuantity()
}
Inventory --> Package : "0..1"
Route --* Depot
Vehicle --o Depot
Inventory ..> Depot : "1..*"
Package --o Manifest
note right of Depot : Logistics domain
@enduml