@startuml
skinparam shadowing true
interface Depot {
  -float phone
  -String email
  -boolean total
  +double name
  +sendDescription()
  +updatePhone()
  +findName()
  +getId()
}
abstract class Vehicle {
  #double id
  -Date level
  #float status
  +saveStatus()
  +cancelCode()
  +processQuantity()
}
class Inventory {
  -Date score
  +String price
  +processCode()
  +calculateEmail()
  +validateId()
}
interface Shipment {
  -float score
  -double duration
  #boolean amount
  +sendId()
  +setActive()
  +processUpdatedat()
  +findQuantity()
}
class Package {
  +int quantity
  #long name
  #boolean score
  +createNote()
}
interface Manifest {
  -String description
  -long price
  -Date createdAt
  +Date code
  #boolean quantity
  +validateUpdatedat()
  +calculateName()
  +getCreatedat()
}
interface Route {
  +boolean note
  #Date total
  +int duration
  +String quantity
  #int type
  +findStatus()
}
Vehicle ..> Route : "*"
Depot ..|> Package
Shipment --> Package : "1"
Package --|> Manifest
Manifest --> Inventory : "1..*"
Package ..|> Inventory
@enduml