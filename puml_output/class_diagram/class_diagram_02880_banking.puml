@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Customer {
  #boolean name
  #int active
  -long id
  #float level
  +saveType()
  +createQuantity()
}
class Card {
  +int address
  +long description
  +double quantity
  +getQuantity()
  +processNote()
  +cancelCreatedat()
}
class Teller {
  -boolean code
  -int description
  +sendPrice()
}
class Loan {
  #int level
  -float price
  -long quantity
  +int code
  +deleteActive()
  +cancelStatus()
  +setNote()
}
abstract class Deposit {
  +String phone
  +int email
  +String quantity
  -String active
  +boolean type
  +cancelLevel()
  +validateQuantity()
  +saveDuration()
}
class Account {
  #boolean id
  -long description
  #boolean type
  #Date score
  +double updatedAt
  +saveAddress()
  +processEmail()
  +calculatePhone()
}
Teller --* Customer
Deposit --* Customer
Account --|> Customer
Teller --o Account
@enduml