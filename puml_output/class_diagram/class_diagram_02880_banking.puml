@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Customer {
  #boolean name
  #int active
  -long id
  #float level
  +createUpdatedat()
  +updateAddress()
}
class Card {
  +double createdAt
  #long duration
  #Date updatedAt
  -String address
  +setDescription()
}
class Teller {
  -boolean amount
  -long score
  #String status
  #int email
  +calculateQuantity()
  +setUpdatedat()
  +createType()
  +setTotal()
}
abstract class Loan {
  +String phone
  +int email
  +String quantity
  -String active
  +boolean type
  +deleteLevel()
  +createDuration()
  +calculateId()
}
class Deposit {
  -boolean type
  -int updatedAt
  #long address
  -long phone
  +long level
  +createCode()
}
class Account {
  -double address
  #String total
  -String score
  #boolean price
  +sendActive()
  +findAmount()
  +getStatus()
  +deleteUpdatedat()
}
Card ..|> Account
Customer --|> Teller
Customer ..> Deposit : "1"
note right of Customer : Banking domain
@enduml