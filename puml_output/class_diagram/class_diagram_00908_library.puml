@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
interface Member {
  -double note
  -float address
  +Date type
  #long level
  -boolean name
  +createCreatedat()
  +findQuantity()
}
class Book {
  #boolean price
  +Date code
  +saveDuration()
  +getDescription()
  +sendEmail()
  +cancelTotal()
}
class Reservation {
  -int note
  +Date level
  +int phone
  +processNote()
}
interface Loan {
  -int createdAt
  +int price
  #double status
  +createPrice()
  +updateCreatedat()
  +validateDuration()
  +sendDescription()
}
class Fine {
  #Date total
  #int amount
  -boolean address
  +createUpdatedat()
  +cancelPrice()
  +updateScore()
}
abstract class Branch {
  #String price
  +boolean total
  #double note
  #double email
  +createUpdatedat()
  +processCreatedat()
  +calculateDuration()
  +deleteDescription()
}
class Shelf {
  -String total
  +boolean type
  +getName()
  +processName()
  +setCreatedat()
  +findName()
}
Member ..|> Shelf
Reservation ..> Book : "0..1"
Reservation --> Branch : "1"
Reservation --> Loan : "1..*"
Member ..> Reservation : "1"
note right of Member : Library domain
@enduml