@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
interface Member {
  -double note
  -float address
  +Date type
  #long level
  -boolean name
  +validateAmount()
  +deletePhone()
}
class Book {
  #boolean address
  +Date name
  #double price
  #Date code
  +getUpdatedat()
}
class Reservation {
  -boolean duration
  -double total
  +int phone
  #String createdAt
  +processName()
  +deleteLevel()
}
abstract class Loan {
  -int duration
  +int amount
  #double createdAt
  -long price
  -int status
  +validateScore()
  +validateActive()
}
interface Fine {
  #double name
  +long level
  #Date createdAt
  +deleteId()
  +sendCreatedat()
}
interface Branch {
  #double email
  -double updatedAt
  -double price
  -boolean level
  +processName()
}
interface Shelf {
  +double level
  #int note
  -boolean active
  +int duration
  +String email
  +calculateLevel()
  +deleteActive()
  +setEmail()
  +updateName()
}
Fine ..> Branch : "*"
Member --o Shelf
@enduml