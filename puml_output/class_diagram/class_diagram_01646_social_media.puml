@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
interface Hashtag {
  +int total
  -float email
  +cancelLevel()
}
class Report {
  #Date note
  -String score
  +double email
  +findType()
  +deleteUpdatedat()
  +setPhone()
  +validateTotal()
}
interface Story {
  -int type
  #long description
  -Date total
  +getType()
  +createName()
  +cancelEmail()
}
class Message {
  -Date status
  +Date type
  +Date code
  +int total
  +setDuration()
}
class User {
  -long updatedAt
  +double total
  +deleteDescription()
  +processType()
  +processActive()
  +validateDescription()
}
Message --> User : "1..*"
User ..|> Message
User ..|> Report
Story --|> Hashtag
note right of Hashtag : Social Media domain
@enduml