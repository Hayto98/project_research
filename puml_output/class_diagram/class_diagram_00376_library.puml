@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
abstract class Author {
  +boolean duration
  #boolean score
  +sendAddress()
  +findUpdatedat()
  +findNote()
}
class Shelf {
  +int description
  -boolean createdAt
  -long score
  +double phone
  #double amount
  +setPhone()
  +updateStatus()
  +sendActive()
}
interface Renewal {
  -long description
  -String amount
  +Date total
  +float level
  +String updatedAt
  +sendId()
  +saveScore()
}
class Reservation {
  +double address
  +boolean price
  -String code
  -Date email
  -double active
  +updateCode()
  +saveStatus()
  +validateActive()
  +createActive()
}
class Branch {
  +String quantity
  #boolean code
  #double email
  -double amount
  +saveAmount()
  +findAddress()
  +validateLevel()
  +createTotal()
}
interface Loan {
  #float name
  -int level
  +String address
  -boolean total
  -double status
  +calculateEmail()
}
Reservation --o Loan
