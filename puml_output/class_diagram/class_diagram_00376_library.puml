@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
abstract class Author {
  +boolean duration
  #boolean score
  +updateNote()
  +calculateCreatedat()
  +calculateDescription()
}
class Shelf {
  #long email
  +int level
  +long type
  #double description
  -String createdAt
  +cancelAmount()
  +updateEmail()
  +updateTotal()
  +setStatus()
}
class Renewal {
  #Date status
  #double score
  +int active
  +calculateAddress()
  +setPrice()
  +updateNote()
  +deleteStatus()
}
class Reservation {
  #int phone
  +String address
  +float name
  #String updatedAt
  +createDuration()
}
class Branch {
  +boolean code
  -String email
  -Date level
  -double updatedAt
  #double type
  +createNote()
  +saveUpdatedat()
}
class Loan {
  -boolean phone
  #int active
  +findScore()
  +processPhone()
  +setDescription()
}
Loan ..|> Shelf
Author ..> Branch : "*"
Renewal --o Reservation
@enduml