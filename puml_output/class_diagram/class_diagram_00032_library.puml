@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Publisher {
  -long quantity
  -double name
  -int id
  +setDescription()
}
class Librarian {
  #boolean email
  -float quantity
  -boolean id
  +cancelNote()
  +cancelUpdatedat()
  +findPhone()
  +sendNote()
}
interface Reservation {
  #boolean updatedAt
  #long active
  #int status
  +boolean type
  +Date quantity
  +sendName()
  +getPhone()
}
abstract class Branch {
  #String email
  +Date quantity
  -long active
  +cancelUpdatedat()
}
Branch --o Librarian
Librarian --o Reservation
Reservation --* Librarian
@enduml