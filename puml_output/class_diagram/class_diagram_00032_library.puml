@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Publisher {
  -long quantity
  -double name
  -int id
  +setUpdatedat()
}
class Librarian {
  -boolean quantity
  -int id
  #int active
  +Date duration
  +findUpdatedat()
  +sendStatus()
  +processQuantity()
  +saveLevel()
}
interface Reservation {
  -double createdAt
  -boolean name
  #int duration
  -long description
  +getAddress()
}
class Branch {
  -double email
  +boolean note
  +validatePrice()
  +createDescription()
  +setPrice()
  +findNote()
}
Branch --|> Publisher
Librarian --* Branch
note right of Publisher : Library domain
@enduml