@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Author {
  -int createdAt
  -boolean note
  #Date level
  +Date description
  +createQuantity()
}
abstract class Librarian {
  +double active
  #long price
  #String code
  +validateId()
  +processNote()
  +saveActive()
  +updateDuration()
}
class Catalog {
  #String updatedAt
  +Date name
  #long createdAt
  +sendName()
  +sendActive()
  +calculateLevel()
}
class Fine {
  -double address
  #String createdAt
  +processPhone()
  +getDuration()
  +processTotal()
  +saveType()
}
class Shelf {
  +int duration
  +String amount
  +cancelStatus()
  +saveUpdatedat()
  +updateScore()
}
Fine ..|> Shelf
Author ..> Librarian : "1..*"
note right of Author : Library domain
@enduml