@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Author {
  -int createdAt
  -boolean note
  #Date level
  +Date description
  +cancelPhone()
}
class Librarian {
  -Date description
  -Date active
  +double price
  -String code
  -float id
  +deleteStatus()
  +findPrice()
  +updateAmount()
  +updateDescription()
}
interface Catalog {
  +Date score
  +String updatedAt
  #Date level
  -long name
  +cancelAmount()
}
interface Fine {
  -double level
  #String description
  #double code
  -long address
  +boolean createdAt
  +findAmount()
  +updateAddress()
  +updateCode()
  +deleteActive()
}
class Shelf {
  +int duration
  +String amount
  +validateActive()
  +getActive()
  +validateEmail()
}
Librarian --> Shelf : "0..1"
Fine ..|> Shelf
Author ..> Librarian : "1..*"
Fine --> Author : "1"
@enduml