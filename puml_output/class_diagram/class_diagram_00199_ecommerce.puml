@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
interface Shipment {
  +boolean level
  #float code
  -double status
  +updateQuantity()
}
interface Payment {
  +float level
  +int address
  -float phone
  #float quantity
  +calculateDuration()
  +deleteLevel()
  +updateQuantity()
  +getName()
}
abstract class Wishlist {
  #boolean note
  #Date type
  +findNote()
  +getNote()
  +setId()
}
abstract class Supplier {
  #long code
  +boolean active
  +calculatePhone()
  +setStatus()
}
class Return {
  -int price
  -boolean score
  +calculateCode()
  +processPrice()
}
Return --o Supplier
Supplier --* Return
Wishlist ..> Return : "0..1"
@enduml