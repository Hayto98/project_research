@startuml
skinparam defaultFontSize 11
interface Staff {
  -float type
  +float code
  +float score
  #String createdAt
  +double active
  +deleteCode()
  +deleteName()
  +deleteDescription()
}
class CheckOut {
  #long amount
  +double createdAt
  #float address
  +float quantity
  +double level
  +saveDescription()
  +createAddress()
  +deleteType()
  +sendName()
}
class Invoice {
  +int type
  -double name
  #String score
  #long quantity
  +cancelActive()
  +sendCreatedat()
  +saveDescription()
  +processDescription()
}
class Service {
  -Date description
  #Date name
  +createActive()
  +sendCode()
  +processPrice()
  +createQuantity()
}
class Amenity {
  +boolean name
  +double total
  +Date amount
  +validateType()
  +updateAmount()
  +sendLevel()
  +sendActive()
}
class CheckIn {
  #float type
  #String email
  #Date code
  -Date level
  +updateTotal()
  +sendScore()
  +processNote()
}
interface Booking {
  #boolean level
  +double phone
  +saveDescription()
  +updateActive()
  +setUpdatedat()
  +calculateDescription()
}
Booking --|> Staff
Service --o CheckIn
Booking --o Amenity
Service ..> Booking : "0..1"
note right of Staff : Hotel domain
@enduml