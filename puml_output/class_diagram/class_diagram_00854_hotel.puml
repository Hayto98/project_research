@startuml
skinparam defaultFontSize 11
interface Staff {
  -float type
  +float code
  +float score
  #String createdAt
  +double active
  +findId()
  +validateType()
  +getType()
}
class CheckOut {
  +Date amount
  -int description
  +calculateDescription()
  +saveCreatedat()
}
class Invoice {
  #float phone
  +float name
  +double type
  +createNote()
  +updateAddress()
  +validateCode()
  +cancelPhone()
}
class Service {
  +float type
  -double score
  +boolean name
  +savePhone()
  +createScore()
  +sendCreatedat()
}
abstract class Amenity {
  -boolean score
  #boolean quantity
  +createType()
  +validateCreatedat()
}
abstract class CheckIn {
  +double quantity
  #boolean code
  #float description
  +validateAddress()
  +createDescription()
  +saveType()
  +findTotal()
}
interface Booking {
  -long type
  +boolean price
  +validateStatus()
  +deleteNote()
}
CheckOut --> Booking : "0..1"
Service ..> CheckOut : "*"
Booking --o Invoice
Booking ..|> CheckOut
Booking --> Amenity : "0..1"
@enduml