@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
interface Amenity {
  -boolean level
  #long name
  +long note
  +cancelName()
}
class Staff {
  #int description
  +float status
  +String updatedAt
  #double phone
  #long createdAt
  +createNote()
  +validateDescription()
}
interface Room {
  +String description
  #Date address
  +long id
  +deletePrice()
  +setActive()
}
class Invoice {
  +double duration
  +String type
  +boolean updatedAt
  +processLevel()
  +sendEmail()
  +validatePhone()
  +getQuantity()
}
class Guest {
  +float quantity
  +double duration
  +getAddress()
  +calculateTotal()
  +calculateNote()
  +setNote()
}
class Restaurant {
  -String code
  +String level
  -long id
  +deletePhone()
  +validateScore()
}
class Booking {
  #Date total
  -float id
  -long type
  +double code
  -int name
  +sendUpdatedat()
  +setCreatedat()
}
Room ..|> Guest
Invoice --> Staff : "1"
Room --|> Restaurant
Room --* Staff
@enduml