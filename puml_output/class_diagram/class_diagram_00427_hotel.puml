@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
interface Amenity {
  -boolean level
  #long name
  +long note
  +findCreatedat()
}
abstract class Staff {
  +boolean status
  +String updatedAt
  +String phone
  +findAddress()
  +saveAmount()
  +cancelCreatedat()
  +deleteAddress()
}
class Room {
  #int status
  -float createdAt
  +int email
  +updateStatus()
  +calculateCreatedat()
  +setAmount()
  +cancelNote()
}
abstract class Invoice {
  -long code
  +float status
  +double id
  +calculateCreatedat()
  +calculateAmount()
  +updateCode()
  +cancelId()
}
class Guest {
  -long amount
  +long id
  +findPrice()
  +calculateId()
  +findType()
}
class Restaurant {
  -String quantity
  -double type
  +findCreatedat()
  +findNote()
}
class Booking {
  #String type
  -int description
  -Date active
  +validateCreatedat()
}
Booking --|> Amenity
Staff --o Room
Invoice --o Amenity
Amenity --o Restaurant
note right of Amenity : Hotel domain
@enduml