@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Shipment {
  #Date level
  #int type
  #long quantity
  -int createdAt
  +findId()
  +validateQuantity()
  +saveDescription()
  +saveLevel()
}
interface Package {
  #double duration
  #long amount
  +Date address
  #float id
  +createTotal()
}
class Route {
  +boolean id
  -double name
  -float score
  #int price
  #boolean quantity
  +createCode()
  +updateId()
  +createId()
  +saveUpdatedat()
}
class Depot {
  -String id
  -long score
  #long amount
  #float level
  +getTotal()
  +saveNote()
}
Depot --|> Route
Package --o Depot
Depot --|> Package
@enduml