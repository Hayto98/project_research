@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Invoice {
  #long total
  #long level
  #double status
  -long duration
  +setCreatedat()
  +calculateTotal()
}
class Wishlist {
  +String status
  #boolean address
  -Date updatedAt
  -long description
  +saveCreatedat()
  +sendName()
  +processCode()
}
interface Category {
  #float name
  -int phone
  -Date quantity
  +saveUpdatedat()
  +createDescription()
}
class Payment {
  -double phone
  +double email
  #String description
  +createPrice()
  +updateId()
  +saveScore()
  +getDuration()
}
abstract class Review {
  +float note
  +float duration
  -float updatedAt
  +boolean quantity
  +float phone
  +sendAmount()
}
interface Warehouse {
  -long createdAt
  -int name
  -Date email
  -String level
  -String price
  +deleteDuration()
  +calculateScore()
  +getQuantity()
  +deleteTotal()
}
Warehouse ..> Wishlist : "*"
Warehouse --|> Category
Invoice --|> Review
@enduml