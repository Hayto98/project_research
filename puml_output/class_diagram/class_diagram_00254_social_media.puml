@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
interface Report {
  +boolean price
  -long updatedAt
  #long note
  +getQuantity()
  +getPrice()
  +updateCode()
}
class Follower {
  +String active
  +String amount
  -long status
  +boolean price
  +processLevel()
  +validateAmount()
  +saveEmail()
}
class Story {
  #float duration
  -String score
  +Date active
  +String status
  +boolean type
  +getDuration()
  +setTotal()
  +createActive()
  +saveEmail()
}
class Group {
  -long amount
  -String type
  +Date address
  +sendCode()
}
class Notification {
  #boolean duration
  +long amount
  #boolean total
  +long level
  -boolean note
  +validateEmail()
  +deleteScore()
}
interface Like {
  -boolean level
  +String active
  #float name
  +setCreatedat()
  +getTotal()
  +processQuantity()
  +validateAmount()
}
Notification --o Story
Story --* Like
Like --* Notification
@enduml