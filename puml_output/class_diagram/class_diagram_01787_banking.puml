@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Transfer {
  +boolean level
  #boolean name
  -String amount
  #double description
  -String type
  +calculateName()
  +getPhone()
  +findAddress()
}
class Account {
  -boolean updatedAt
  -boolean score
  -double id
  +savePhone()
}
class Interest {
  #Date phone
  #String level
  -String price
  -int active
  +getScore()
  +getEmail()
}
class Card {
  -String name
  -int score
  +float amount
  +deleteType()
  +calculateDuration()
  +updateAmount()
  +cancelPrice()
}
abstract class Branch {
  +int email
  +long level
  +calculateTotal()
  +createStatus()
  +saveActive()
  +updatePhone()
}
abstract class Withdrawal {
  -Date updatedAt
  +Date score
  +String total
  #long id
  -boolean amount
  +setDuration()
  +calculateDescription()
  +getType()
  +processUpdatedat()
}
interface Customer {
  -float createdAt
  #int phone
  #String price
  +processAmount()
  +cancelDuration()
  +validateType()
  +calculatePhone()
}
Card ..|> Transfer
Withdrawal --* Customer
@enduml