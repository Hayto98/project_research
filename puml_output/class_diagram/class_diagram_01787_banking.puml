@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Transfer {
  +boolean level
  #boolean name
  -String amount
  #double description
  -String type
  +validateTotal()
  +updateEmail()
  +deleteUpdatedat()
}
interface Account {
  -boolean email
  -double active
  +getId()
}
class Interest {
  -String level
  -int price
  +boolean active
  +String name
  +saveName()
  +sendAmount()
}
abstract class Card {
  +float phone
  -Date amount
  +getEmail()
  +cancelAmount()
  +deleteName()
  +createType()
}
interface Branch {
  +long score
  #String total
  #String updatedAt
  +Date level
  -double id
  +findCode()
  +deleteLevel()
  +deleteCreatedat()
  +validateLevel()
}
abstract class Withdrawal {
  #float score
  -long createdAt
  -String id
  +double price
  +Date code
  +processId()
  +updatePrice()
  +calculateType()
}
class Customer {
  #int amount
  #boolean price
  +int email
  #int name
  +getAmount()
  +sendType()
}
Withdrawal --o Branch
Branch ..|> Withdrawal
Branch ..|> Transfer
Transfer --* Branch
note right of Transfer : Banking domain
@enduml