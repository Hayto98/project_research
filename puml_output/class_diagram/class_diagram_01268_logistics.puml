@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
interface Inventory {
  #float phone
  -boolean price
  #int type
  #double score
  +deleteQuantity()
  +calculateCode()
}
interface Package {
  +Date name
  +long email
  #long createdAt
  +getScore()
  +getCreatedat()
  +processName()
}
class FuelLog {
  -String level
  #Date id
  +boolean amount
  #long active
  +savePhone()
  +processCode()
}
class Vehicle {
  -Date amount
  -String duration
  +createNote()
  +cancelActive()
}
class Route {
  #double quantity
  +float status
  +String duration
  #int address
  -Date email
  +deletePrice()
  +cancelActive()
}
FuelLog --o Inventory
Route ..|> FuelLog
Vehicle --o Package
Vehicle --> FuelLog : "0..1"
@enduml