@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
interface Inventory {
  #float phone
  -boolean price
  #int type
  #double score
  +setPrice()
  +cancelDuration()
}
class Package {
  +Date email
  +long createdAt
  +saveScore()
  +validateActive()
  +sendId()
}
class FuelLog {
  -String level
  #Date id
  +boolean amount
  #long active
  +getId()
  +findStatus()
}
class Vehicle {
  +int amount
  #int quantity
  -long total
  +createAddress()
}
class Route {
  #int createdAt
  -boolean name
  #float code
  -boolean amount
  #String phone
  +sendLevel()
  +createUpdatedat()
  +calculateCreatedat()
  +processPrice()
}
FuelLog --o Package
Route ..|> FuelLog
Package ..> Route : "0..1"
Package ..> Inventory : "1..*"
note right of Inventory : Logistics domain
@enduml