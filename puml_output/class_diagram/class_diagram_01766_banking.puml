@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Transfer {
  -long type
  +int description
  +calculateEmail()
  +processActive()
}
class Beneficiary {
  -Date amount
  #boolean phone
  -int description
  -double email
  +updateQuantity()
  +cancelAddress()
  +calculateEmail()
  +createUpdatedat()
}
abstract class Branch {
  #double level
  #Date note
  +boolean address
  +double score
  #Date type
  +calculateActive()
  +sendName()
  +updateId()
}
class Deposit {
  +int createdAt
  #boolean phone
  +sendName()
  +updateName()
}
class Loan {
  #long note
  +long price
  #float phone
  +validatePhone()
  +createName()
}
class Withdrawal {
  -int duration
  #String email
  +long code
  +saveId()
  +updateNote()
}
class Card {
  +boolean description
  +Date score
  +validatePrice()
  +getDescription()
  +findName()
  +sendTotal()
}
Transfer --* Withdrawal
Card --> Beneficiary : "1..*"
Card ..|> Withdrawal
@enduml