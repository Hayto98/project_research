@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class User {
  #double address
  +boolean note
  +cancelUpdatedat()
  +calculateScore()
  +findLevel()
}
class Like {
  -long address
  +double phone
  -Date name
  +calculateId()
  +saveLevel()
  +validateUpdatedat()
}
abstract class Story {
  #double email
  +long level
  +long address
  -double createdAt
  +boolean code
  +updatePhone()
  +calculateEmail()
  +setPrice()
  +processId()
}
class Follower {
  -String email
  +long level
  -boolean active
  +float type
  -Date total
  +getCode()
}
class Notification {
  #String price
  +long level
  +calculateName()
  +getAmount()
}
class Message {
  #long total
  -double type
  -double name
  #float level
  +double updatedAt
  +processPhone()
  +calculateAmount()
  +cancelLevel()
}
User --> Story : "1"
Notification ..|> Like
note right of User : Social Media domain
@enduml