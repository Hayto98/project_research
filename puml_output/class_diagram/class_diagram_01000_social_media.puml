@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class User {
  #double address
  +boolean note
  +cancelActive()
  +findAddress()
  +findAmount()
}
interface Like {
  -long createdAt
  +double address
  -Date phone
  -double name
  +cancelScore()
}
interface Story {
  #long updatedAt
  #int price
  #Date total
  +Date email
  +deleteEmail()
  +deleteId()
  +processUpdatedat()
  +findQuantity()
}
class Follower {
  +long note
  -float type
  -String name
  #double duration
  +sendTotal()
  +saveScore()
  +findUpdatedat()
  +findType()
}
interface Notification {
  -String email
  +long level
  -boolean active
  +float type
  -Date total
  +updateActive()
}
class Message {
  +long duration
  +double code
  +String price
  +long level
  +getPhone()
  +saveDescription()
  +deletePhone()
  +findEmail()
}
User ..> Follower : "0..1"
Notification --* Story
Follower --o Message
Message --o Like
Story --* Follower
@enduml