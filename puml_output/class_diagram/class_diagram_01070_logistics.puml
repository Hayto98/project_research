@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
abstract class FuelLog {
  +int score
  #long address
  +String description
  +validatePrice()
  +findQuantity()
  +createTotal()
  +sendTotal()
}
interface Tracking {
  -int quantity
  -float price
  #float active
  +deleteCode()
  +findName()
  +setEmail()
  +deleteName()
}
interface Customer {
  #String type
  -long code
  +String description
  +getCreatedat()
  +findPrice()
}
interface Package {
  #Date address
  #String quantity
  #float amount
  +double type
  #Date code
  +processQuantity()
  +setName()
  +getQuantity()
}
abstract class DeliveryNote {
  #String duration
  -String code
  -long description
  +Date score
  -double updatedAt
  +cancelAddress()
  +setScore()
}
class Driver {
  #double code
  #int createdAt
  #long score
  +updateStatus()
  +cancelScore()
  +cancelCode()
  +calculateCode()
}
DeliveryNote --o Driver
Package --o Customer
Tracking ..> DeliveryNote : "*"
Driver --* DeliveryNote
@enduml