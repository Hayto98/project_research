@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
abstract class FuelLog {
  +int score
  #long address
  +String description
  +saveAddress()
  +findId()
  +cancelDescription()
  +findQuantity()
}
abstract class Tracking {
  -boolean description
  +Date phone
  -String note
  +boolean level
  +double address
  +deleteCode()
  +findDescription()
  +sendActive()
}
interface Customer {
  #Date address
  #String quantity
  #float amount
  +double type
  #Date code
  +getId()
  +cancelPrice()
  +processDuration()
}
class Package {
  #String duration
  -String description
  -long updatedAt
  +savePhone()
  +processDuration()
}
class DeliveryNote {
  #float id
  #Date createdAt
  -boolean code
  +boolean level
  +saveTotal()
  +updateType()
  +calculateEmail()
}
interface Driver {
  #boolean total
  -boolean phone
  +int type
  -float amount
  +float duration
  +calculateNote()
}
Tracking ..|> Customer
DeliveryNote --* Driver
note right of FuelLog : Logistics domain
@enduml