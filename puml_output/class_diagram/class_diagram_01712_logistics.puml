@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class FuelLog {
  +float duration
  +Date name
  +double email
  +sendScore()
  +deleteDuration()
}
class DeliveryNote {
  +double level
  #boolean description
  #int amount
  -boolean email
  +updateCode()
  +processQuantity()
}
abstract class Customer {
  +long email
  +long id
  +setAmount()
  +getCreatedat()
  +findType()
  +sendType()
}
class Tracking {
  +int price
  -String email
  #Date status
  +calculatePhone()
}
class Inventory {
  +float total
  -float active
  #int createdAt
  +int updatedAt
  +saveQuantity()
  +calculateId()
  +saveCode()
}
abstract class Vehicle {
  +double id
  +long duration
  +long name
  +int amount
  #boolean quantity
  +deleteName()
  +findStatus()
  +cancelTotal()
  +updateEmail()
}
Customer ..> Vehicle : "1..*"
Tracking --|> DeliveryNote
Tracking --> Customer : "1"
DeliveryNote ..> Customer : "0..1"
Vehicle --o Inventory
@enduml