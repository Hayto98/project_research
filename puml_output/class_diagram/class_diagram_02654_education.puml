@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Classroom {
  -String quantity
  #float phone
  +saveName()
  +saveScore()
}
class Attendance {
  -String amount
  -Date note
  -float updatedAt
  +sendEmail()
  +updateAddress()
  +getDuration()
}
interface Library {
  #double amount
  +Date status
  +validateScore()
  +saveDescription()
}
interface Course {
  #float total
  #int level
  -float quantity
  +long code
  #double updatedAt
  +saveId()
  +validateEmail()
  +validateAmount()
}
Attendance --|> Classroom
Library ..> Course : "*"
@enduml