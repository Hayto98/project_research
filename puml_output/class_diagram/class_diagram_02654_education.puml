@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Classroom {
  -String quantity
  #float phone
  +calculatePhone()
  +setCreatedat()
}
class Attendance {
  -int updatedAt
  #float note
  #float code
  #float email
  +int phone
  +saveNote()
}
class Library {
  -boolean address
  -String level
  +float note
  +createStatus()
  +validateDuration()
}
abstract class Course {
  +int name
  +int status
  +Date email
  -Date type
  +findUpdatedat()
  +updateQuantity()
  +findType()
  +processNote()
}
Course ..|> Library
Course ..> Attendance : "1..*"
note right of Classroom : Education domain
@enduml