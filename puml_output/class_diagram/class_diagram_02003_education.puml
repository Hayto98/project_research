@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
interface Department {
  -boolean score
  +String description
  #String phone
  -Date type
  -Date duration
  +deleteCode()
  +sendName()
}
class Book {
  #String description
  #Date address
  -int updatedAt
  +deleteScore()
  +createPrice()
  +sendType()
}
class Student {
  +int level
  +double id
  -float type
  -float price
  #double email
  +createType()
  +calculateEmail()
  +getAmount()
  +sendAmount()
}
class Assignment {
  +long price
  #Date name
  #double updatedAt
  +findId()
  +calculateTotal()
  +calculateNote()
}
class Course {
  -long duration
  -float status
  #boolean name
  +double phone
  +int email
  +calculateScore()
}
Assignment --> Book : "0..1"
Course ..> Student : "1..*"
note right of Department : Education domain
@enduml