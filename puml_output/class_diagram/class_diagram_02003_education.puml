@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
interface Department {
  -boolean score
  +String description
  #String phone
  -Date type
  -Date duration
  +validateCode()
  +setDescription()
}
interface Book {
  +long name
  #int updatedAt
  +saveDescription()
}
abstract class Student {
  -double phone
  #Date amount
  -String score
  +findName()
  +sendTotal()
  +validateName()
  +saveCode()
}
class Assignment {
  -float createdAt
  -float status
  #double price
  +findScore()
  +sendCreatedat()
  +calculateCode()
  +validateStatus()
}
class Course {
  +int amount
  +Date active
  +createType()
  +savePhone()
  +createNote()
  +findAddress()
}
Student --* Assignment
Department ..> Assignment : "*"
@enduml