@startuml
skinparam monochrome true
skinparam shadowing true
class Customer {
  +Date email
  -boolean quantity
  +cancelName()
  +deletePhone()
  +sendStatus()
}
class Teller {
  #float address
  -Date description
  +long active
  +calculateQuantity()
  +getAddress()
  +setEmail()
}
class Withdrawal {
  +double email
  -Date total
  +savePhone()
  +deleteTotal()
  +getUpdatedat()
}
class Transaction {
  -Date code
  +double amount
  +boolean updatedAt
  #float level
  +getDescription()
  +findScore()
}
class Account {
  +boolean quantity
  +boolean type
  #Date phone
  -boolean amount
  +float description
  +cancelActive()
  +updateAddress()
}
class Loan {
  -int type
  -double name
  +String updatedAt
  -int id
  #boolean email
  +deleteCreatedat()
  +calculateId()
  +sendPhone()
  +createTotal()
}
class Statement {
  -int total
  -double type
  +deleteEmail()
}
Customer --* Statement
Teller --|> Withdrawal
Loan --|> Statement
note right of Customer : Banking domain
@enduml