@startuml
skinparam monochrome true
skinparam shadowing true
class Customer {
  +Date email
  -boolean quantity
  +saveDuration()
  +findEmail()
  +getStatus()
}
class Teller {
  +Date phone
  +long score
  +Date status
  +validatePrice()
  +deletePhone()
  +validateCreatedat()
  +saveScore()
}
class Withdrawal {
  +boolean quantity
  +float name
  -Date address
  -String status
  -long email
  +cancelScore()
  +createAmount()
  +createCreatedat()
}
abstract class Transaction {
  -String updatedAt
  #int createdAt
  +calculateAddress()
  +getAddress()
}
class Account {
  #boolean name
  +double active
  -double amount
  #Date duration
  -boolean description
  +setType()
  +sendDescription()
}
class Loan {
  #String active
  +boolean address
  +validateDuration()
  +getNote()
}
abstract class Statement {
  +double name
  -int updatedAt
  +double id
  +Date email
  #double type
  +saveNote()
  +validateType()
}
Loan --> Customer : "1..*"
Withdrawal --|> Transaction
Loan --o Statement
Statement --* Transaction
@enduml