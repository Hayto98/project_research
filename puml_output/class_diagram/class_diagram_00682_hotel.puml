@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Guest {
  #String level
  #boolean createdAt
  +validateScore()
  +validateCode()
  +saveEmail()
}
class Restaurant {
  +long amount
  +long createdAt
  -boolean score
  -String code
  +cancelName()
  +findType()
  +updateAddress()
  +createActive()
}
class Amenity {
  #boolean type
  +boolean email
  +float name
  +saveNote()
  +calculateDuration()
  +calculateId()
  +deleteStatus()
}
abstract class Room {
  +String quantity
  #float address
  +double createdAt
  #float type
  +float id
  +saveDescription()
  +processAmount()
  +sendActive()
  +setName()
}
class Housekeeping {
  +Date active
  -boolean createdAt
  +findCode()
  +findAddress()
}
interface Invoice {
  +float active
  -boolean id
  +int type
  -float level
  -long note
  +setDuration()
}
Amenity ..> Room : "1"
Guest --* Amenity
Room ..> Restaurant : "*"
Room --> Housekeeping : "*"
Guest --> Room : "0..1"
@enduml