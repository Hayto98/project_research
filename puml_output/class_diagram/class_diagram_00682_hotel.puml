@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Guest {
  #String level
  #boolean createdAt
  +validateDescription()
  +getCode()
  +sendQuantity()
}
class Restaurant {
  -int score
  -long code
  #long level
  +calculateAddress()
}
class Amenity {
  #boolean type
  +boolean email
  +float name
  +updateScore()
  +getNote()
  +processQuantity()
  +validateCreatedat()
}
abstract class Room {
  #float id
  +double code
  +processCode()
}
interface Housekeeping {
  #int updatedAt
  +Date name
  +sendUpdatedat()
  +validateUpdatedat()
  +cancelScore()
}
interface Invoice {
  +float active
  -boolean id
  +int type
  -float level
  -long note
  +saveType()
}
Room --|> Guest
Invoice --* Amenity
Room ..> Restaurant : "*"
Room --> Housekeeping : "*"
note right of Guest : Hotel domain
@enduml