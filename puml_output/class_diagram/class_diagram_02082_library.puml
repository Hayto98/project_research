@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
interface Loan {
  -Date duration
  -int updatedAt
  #float email
  +Date phone
  +Date code
  +createPhone()
  +setScore()
  +setNote()
  +findPhone()
}
class Book {
  -Date address
  -float amount
  #long updatedAt
  +setScore()
  +cancelCode()
  +createId()
}
class Reservation {
  +int status
  #float type
  -float active
  -String email
  #int description
  +setName()
  +updateId()
  +deleteCode()
  +validateLevel()
}
interface Branch {
  +float address
  #long total
  -String active
  #boolean name
  +cancelAmount()
  +cancelStatus()
}
class Librarian {
  #Date email
  +int createdAt
  #Date description
  #double amount
  +deleteEmail()
}
class Catalog {
  +long status
  #double phone
  +findDuration()
}
class Member {
  -long duration
  +boolean score
  #double email
  +findType()
  +sendType()
}
Branch --o Member
Loan ..> Reservation : "*"
note right of Loan : Library domain
@enduml