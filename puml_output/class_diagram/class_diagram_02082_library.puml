@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
interface Loan {
  -Date duration
  -int updatedAt
  #float email
  +Date phone
  +Date code
  +findCreatedat()
  +deleteCode()
  +updateUpdatedat()
  +calculatePrice()
}
class Book {
  +float phone
  -Date duration
  -float amount
  #long address
  -String score
  +findScore()
}
class Reservation {
  #Date total
  -float status
  #int type
  +createCreatedat()
  +setCode()
}
abstract class Branch {
  +Date status
  +int updatedAt
  +long note
  #boolean duration
  #long name
  +setNote()
  +processNote()
  +findPrice()
}
interface Librarian {
  -long updatedAt
  +Date score
  +getQuantity()
  +deleteScore()
}
interface Catalog {
  #long name
  -int score
  +findName()
  +validateQuantity()
}
interface Member {
  +int description
  #long level
  +Date note
  +cancelType()
}
Member --|> Reservation
Reservation --o Librarian
@enduml