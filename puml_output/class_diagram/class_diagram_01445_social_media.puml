@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
abstract class Album {
  -String amount
  -boolean type
  -Date quantity
  -long status
  -Date email
  +calculateQuantity()
  +validateActive()
  +saveCreatedat()
  +getId()
}
interface Notification {
  #float duration
  -int status
  +Date id
  +String level
  #boolean address
  +findDuration()
  +setType()
}
class Message {
  +long email
  +long phone
  +updateEmail()
  +cancelName()
  +calculateAddress()
}
abstract class Like {
  +int description
  +Date createdAt
  +double code
  +sendNote()
  +validateDescription()
  +deleteLevel()
  +processPrice()
}
Album --* Notification
Notification --|> Like
Message ..|> Like
@enduml