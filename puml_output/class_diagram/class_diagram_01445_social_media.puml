@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
abstract class Album {
  -String amount
  -boolean type
  -Date quantity
  -long status
  -Date email
  +calculateDuration()
  +validateType()
  +cancelType()
  +findDuration()
}
class Notification {
  #float status
  -int address
  +saveDescription()
}
class Message {
  +long active
  -float description
  +long level
  +createPhone()
  +calculateAmount()
}
abstract class Like {
  +int description
  +Date createdAt
  +double code
  +updateUpdatedat()
  +validateId()
  +createPhone()
  +sendUpdatedat()
}
Album --> Notification : "0..1"
Message --o Like
Message ..> Album : "0..1"
note right of Album : Social Media domain
@enduml