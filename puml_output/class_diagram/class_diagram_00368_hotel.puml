@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Invoice {
  +Date price
  -float quantity
  +int description
  +int code
  #float level
  +validatePhone()
  +getEmail()
  +sendActive()
}
interface Reservation {
  #Date type
  #boolean code
  +calculateType()
  +findActive()
}
class CheckOut {
  -Date amount
  -float price
  +boolean name
  +getType()
}
interface Restaurant {
  -float duration
  +Date amount
  -int updatedAt
  #int address
  +double score
  +sendAmount()
  +createAmount()
}
Invoice --o Restaurant
CheckOut --|> Invoice
@enduml