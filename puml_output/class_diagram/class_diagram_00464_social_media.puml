@startuml
skinparam monochrome true
skinparam defaultFontSize 13
abstract class Album {
  -long price
  -float type
  +sendActive()
  +saveActive()
}
class Report {
  -int amount
  -float status
  -boolean address
  -float phone
  -boolean id
  +cancelScore()
  +saveActive()
  +calculateCode()
}
interface Profile {
  +String updatedAt
  +long createdAt
  +sendActive()
  +createPhone()
  +createNote()
}
interface Group {
  -Date level
  +int address
  +cancelNote()
  +sendScore()
  +processUpdatedat()
}
class Post {
  #String score
  +String duration
  +savePhone()
  +validateQuantity()
}
class Story {
  #double name
  +double active
  #float email
  +findCreatedat()
  +findTotal()
  +deletePrice()
  +saveCode()
}
interface User {
  #String score
  +int email
  #int description
  -Date type
  #Date active
  +processDescription()
}
Report --* Post
Report --|> Album
Album --o Profile
note right of Album : Social Media domain
@enduml