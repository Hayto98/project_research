@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Renewal {
  +double description
  -float active
  -float level
  -double phone
  #double updatedAt
  +cancelScore()
  +updateNote()
}
interface Publisher {
  #boolean amount
  #int phone
  +int level
  +sendStatus()
  +updateLevel()
}
class Branch {
  -String status
  #float total
  #Date quantity
  #double level
  +getActive()
  +cancelLevel()
  +sendEmail()
  +processEmail()
}
interface Author {
  #double createdAt
  -float duration
  +getAmount()
}
class Loan {
  #float createdAt
  #int description
  -long amount
  #float duration
  #boolean price
  +findUpdatedat()
}
class Book {
  #boolean status
  -boolean total
  -float code
  +double type
  +processPhone()
  +cancelScore()
  +deleteUpdatedat()
  +updateTotal()
}
Author --* Book
Branch --o Renewal
Branch ..|> Loan
note right of Renewal : Library domain
@enduml