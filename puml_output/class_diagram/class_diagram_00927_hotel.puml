@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Guest {
  #String type
  #float description
  +findActive()
  +saveUpdatedat()
  +deleteScore()
}
class Invoice {
  -float description
  +long active
  -Date createdAt
  -long quantity
  -double duration
  +sendStatus()
}
abstract class CheckIn {
  +Date note
  +long createdAt
  +String active
  #double status
  -float type
  +processDuration()
}
abstract class Reservation {
  +Date type
  #float phone
  +long level
  -String duration
  +long active
  +findEmail()
  +updateQuantity()
}
class Room {
  #int address
  #float duration
  #boolean active
  +long email
  +sendId()
  +deletePrice()
  +calculateStatus()
}
class Payment {
  -Date duration
  #long name
  +processStatus()
  +sendActive()
  +findEmail()
  +setNote()
}
class Booking {
  #double duration
  -String address
  #boolean type
  +long amount
  +processUpdatedat()
  +cancelStatus()
  +processActive()
}
Payment --> Invoice : "1..*"
CheckIn --* Payment
Guest --|> Invoice
Booking ..|> Invoice
@enduml