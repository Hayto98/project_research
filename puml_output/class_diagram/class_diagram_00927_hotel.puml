@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Guest {
  #String type
  #float description
  +processAmount()
  +createPrice()
  +deleteActive()
}
class Invoice {
  -Date description
  -long type
  -double createdAt
  +float address
  +processNote()
  +saveCreatedat()
  +sendStatus()
  +processId()
}
class CheckIn {
  +int id
  #Date duration
  -double total
  #double phone
  +validateType()
  +processName()
  +saveDescription()
}
class Reservation {
  #int code
  +boolean id
  -long address
  #long active
  +saveAmount()
  +saveScore()
  +sendCreatedat()
}
class Room {
  #String createdAt
  -Date note
  #long status
  -long id
  +updateAddress()
  +cancelAddress()
  +processAmount()
  +saveNote()
}
abstract class Payment {
  -long level
  +String createdAt
  +createCreatedat()
  +cancelAddress()
}
class Booking {
  +Date status
  -long createdAt
  #boolean name
  -double updatedAt
  +validateStatus()
}
Guest --o Reservation
Payment ..> Invoice : "1"
note right of Guest : Hotel domain
@enduml