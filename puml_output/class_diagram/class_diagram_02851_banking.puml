@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Transaction {
  -long level
  -Date id
  +Date note
  -boolean name
  +String phone
  +validateCreatedat()
  +getCreatedat()
}
class Account {
  #int price
  +Date quantity
  -double active
  -Date total
  +double address
  +sendActive()
  +getPhone()
}
abstract class Teller {
  -boolean score
  #int status
  +Date id
  +sendDuration()
  +savePrice()
  +cancelName()
  +validatePhone()
}
interface Statement {
  +long active
  +double createdAt
  -int description
  #double name
  +processDuration()
  +saveTotal()
  +setDuration()
}
abstract class Beneficiary {
  -int price
  +float createdAt
  +setAddress()
  +updateAddress()
  +getName()
}
Teller --|> Transaction
Teller ..|> Beneficiary
Teller --> Statement : "0..1"
Account --|> Beneficiary
@enduml