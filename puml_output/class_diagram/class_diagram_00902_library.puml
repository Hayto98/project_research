@startuml
skinparam monochrome true
class Loan {
  +String quantity
  #float total
  +int id
  #Date name
  +validateEmail()
}
abstract class Member {
  +double score
  +String code
  +String description
  #int address
  +processActive()
  +calculateCode()
  +findDescription()
  +updateCreatedat()
}
class Renewal {
  +long name
  -double score
  #double address
  #Date code
  +setCreatedat()
  +getCode()
  +processDuration()
}
interface Librarian {
  -String amount
  +double name
  #float status
  #int total
  +validateCreatedat()
}
Librarian --|> Loan
Member ..|> Loan
note right of Loan : Library domain
@enduml