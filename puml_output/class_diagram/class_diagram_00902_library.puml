@startuml
skinparam monochrome true
class Loan {
  +String quantity
  #float total
  +int id
  #Date name
  +getStatus()
}
class Member {
  +Date note
  -int address
  -float score
  +String code
  +validateId()
}
interface Renewal {
  -String type
  #int duration
  +int active
  +calculatePhone()
}
class Librarian {
  -float code
  #double id
  #Date phone
  -String email
  +setName()
  +createAddress()
}
Renewal --|> Loan
Loan --* Member
Loan --o Librarian
@enduml