@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Invoice {
  +double score
  #String status
  -double address
  +updateActive()
}
class Reservation {
  -long duration
  +double email
  +findActive()
}
class Service {
  -String score
  +double note
  +savePrice()
}
class Staff {
  +Date name
  #String note
  +double quantity
  -Date level
  +calculateUpdatedat()
  +deleteCode()
}
class CheckOut {
  +float status
  +boolean email
  +setStatus()
  +updateAddress()
}
interface Booking {
  #Date address
  #String email
  +deleteId()
  +setAddress()
}
CheckOut --|> Staff
Service --> Invoice : "1"
Staff --* Invoice
note right of Invoice : Hotel domain
@enduml