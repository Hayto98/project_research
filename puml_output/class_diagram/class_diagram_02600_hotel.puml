@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Invoice {
  +double score
  #String status
  -double address
  +cancelNote()
}
interface Reservation {
  -int code
  -String email
  #boolean address
  +sendQuantity()
  +validateId()
}
interface Service {
  #float quantity
  -float status
  -float code
  #long price
  +double name
  +sendDuration()
  +deletePrice()
  +sendId()
}
class Staff {
  #int total
  -int quantity
  +createAddress()
  +getUpdatedat()
}
class CheckOut {
  +float status
  +boolean email
  +createPhone()
  +updateScore()
}
class Booking {
  -Date address
  #Date code
  +boolean duration
  +saveAddress()
  +updatePrice()
}
Service --> Reservation : "*"
Invoice --|> Service
@enduml