@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Invoice {
  -Date phone
  +boolean id
  -float price
  -int quantity
  +double duration
  +getAmount()
  +setPhone()
  +updateUpdatedat()
  +getCode()
}
class Cart {
  +Date active
  #Date quantity
  +setActive()
  +setPhone()
  +saveAddress()
}
class Order {
  -String quantity
  -String code
  -double level
  +float status
  +updateNote()
}
class Category {
  -boolean score
  #float updatedAt
  #Date duration
  #float type
  +validateScore()
}
abstract class Product {
  -String note
  #long level
  -String duration
  +cancelDuration()
  +processLevel()
}
class Wishlist {
  +long duration
  #long id
  +createNote()
}
Order --* Wishlist
Invoice ..> Wishlist : "1"
Wishlist --* Cart
@enduml