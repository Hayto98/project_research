@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Patient {
  -float createdAt
  +Date amount
  +setLevel()
  +calculateId()
}
class MedicalRecord {
  +String amount
  -int description
  +updateQuantity()
  +getCreatedat()
  +calculateLevel()
  +deleteId()
}
class Prescription {
  #boolean email
  -int quantity
  +deleteLevel()
}
class Doctor {
  #boolean type
  +boolean phone
  +float score
  #int id
  +double level
  +calculateDuration()
  +sendDuration()
  +setNote()
  +deleteLevel()
}
class LabTest {
  -boolean address
  #double score
  +sendScore()
  +deleteActive()
}
interface Appointment {
  +String phone
  #Date status
  +validatePrice()
  +findCode()
  +processDescription()
}
MedicalRecord ..|> Patient
LabTest ..|> Prescription
Prescription ..> LabTest : "1..*"
Prescription --* Doctor
Prescription --> Appointment : "1"
@enduml