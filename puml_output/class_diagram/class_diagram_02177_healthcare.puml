@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Patient {
  -float createdAt
  +Date amount
  +deleteName()
  +createName()
}
class MedicalRecord {
  +Date createdAt
  -float status
  #float address
  +setEmail()
}
class Prescription {
  -long updatedAt
  #String code
  -Date amount
  #float type
  +cancelCode()
  +saveAmount()
}
class Doctor {
  -boolean total
  -boolean score
  #double duration
  +double amount
  -boolean name
  +findPhone()
}
class LabTest {
  #long id
  -float level
  #double address
  +setAmount()
  +sendQuantity()
}
class Appointment {
  -long score
  -boolean address
  #boolean level
  #Date price
  +processScore()
}
LabTest --|> Doctor
Patient --> MedicalRecord : "*"
note right of Patient : Healthcare domain
@enduml