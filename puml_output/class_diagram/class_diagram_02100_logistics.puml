@startuml
skinparam monochrome true
class Warehouse {
  +Date duration
  #float createdAt
  -long active
  +findStatus()
}
class FuelLog {
  -Date level
  #float phone
  #int address
  #float code
  +savePhone()
}
abstract class Tracking {
  #String id
  -float active
  +sendAmount()
  +findName()
  +validateQuantity()
  +findId()
}
class Package {
  #boolean updatedAt
  #long price
  +deleteLevel()
  +deleteScore()
  +processDescription()
  +cancelType()
}
abstract class Depot {
  +boolean total
  +long note
  +validateCode()
  +cancelDuration()
}
class DeliveryNote {
  #double description
  #float price
  #Date code
  +processAddress()
  +getScore()
  +calculateStatus()
  +createNote()
}
Tracking --o Warehouse
Package --o DeliveryNote
Depot ..|> DeliveryNote
Package --o Warehouse
@enduml