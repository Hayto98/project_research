@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Reservation {
  #float code
  #boolean level
  +Date createdAt
  +double price
  +setDuration()
  +findName()
  +calculateNote()
}
interface Fine {
  -boolean price
  #String address
  +float note
  -Date level
  +cancelStatus()
  +createName()
  +saveNote()
}
class Librarian {
  +float level
  -float duration
  +processLevel()
  +saveId()
  +processCreatedat()
}
class Member {
  #int description
  -Date amount
  +cancelCreatedat()
  +findDescription()
  +sendType()
  +deleteStatus()
}
Member ..> Librarian : "*"
Fine --> Reservation : "1..*"
@enduml