@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Reservation {
  #float code
  #boolean level
  +Date createdAt
  +double price
  +cancelCreatedat()
  +cancelActive()
  +cancelActive()
}
class Fine {
  #float address
  #String note
  +float score
  -Date duration
  -String phone
  +updateQuantity()
  +saveDuration()
  +getLevel()
  +cancelUpdatedat()
}
abstract class Librarian {
  +int total
  #int name
  -Date id
  -double code
  +processTotal()
}
class Member {
  #String active
  #int phone
  +processCode()
  +deleteEmail()
}
Reservation --> Librarian : "1..*"
Member --* Librarian
Fine --* Reservation
note right of Reservation : Library domain
@enduml