@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
interface Story {
  -String id
  #String level
  +validateCode()
}
class Report {
  #boolean createdAt
  -double level
  #long updatedAt
  +boolean quantity
  +updateId()
}
abstract class Group {
  #long amount
  #Date address
  #long price
  -long score
  +setId()
}
class Album {
  -Date createdAt
  +double name
  +sendNote()
}
class Message {
  -long total
  -boolean code
  #String email
  +getDescription()
  +calculateAmount()
}
class Profile {
  +long updatedAt
  #double createdAt
  -long description
  +long amount
  -Date price
  +validateDescription()
}
class Notification {
  -String email
  +long id
  +cancelId()
  +processCreatedat()
}
Notification ..> Report : "1"
Story ..|> Group
Profile --> Album : "1"
Notification --|> Profile
Group --* Profile
note right of Story : Social Media domain
@enduml