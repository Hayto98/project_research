@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
interface Story {
  -String id
  #String level
  +saveCreatedat()
}
class Report {
  -int active
  #int duration
  +getCreatedat()
  +findUpdatedat()
  +sendCode()
}
abstract class Group {
  +double amount
  -int active
  #long name
  -boolean createdAt
  +setPrice()
  +calculateDuration()
  +calculateName()
  +calculatePrice()
}
interface Album {
  +String phone
  #String email
  +String id
  -Date status
  +deleteActive()
  +setPrice()
}
interface Message {
  -int score
  -String note
  +createName()
  +cancelLevel()
  +saveScore()
}
class Profile {
  +int duration
  -int createdAt
  +findTotal()
  +findDuration()
}
abstract class Notification {
  #double createdAt
  +long description
  #double amount
  +sendPhone()
  +createCode()
  +cancelAddress()
  +createAmount()
}
Notification ..|> Group
Report --* Story
@enduml