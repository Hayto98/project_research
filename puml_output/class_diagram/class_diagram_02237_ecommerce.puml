@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Cart {
  +float amount
  +float quantity
  +Date price
  +createLevel()
  +getTotal()
  +saveCreatedat()
  +getPrice()
}
interface Return {
  -int email
  #Date total
  +String price
  #String type
  +float address
  +getAddress()
}
abstract class Category {
  +String level
  -float status
  +long price
  -double name
  -double updatedAt
  +updateActive()
  +updateName()
}
interface Review {
  +long address
  -long updatedAt
  +int level
  -long name
  #int active
  +sendLevel()
  +saveNote()
  +validateQuantity()
  +deleteName()
}
abstract class Warehouse {
  +double updatedAt
  #Date status
  -int score
  +getPhone()
  +sendNote()
  +calculateActive()
}
interface Wishlist {
  -float id
  #double email
  #Date description
  +getLevel()
}
class Supplier {
  #double active
  -String address
  +calculatePhone()
  +cancelCode()
}
Warehouse --o Wishlist
Wishlist ..> Review : "1"
Supplier --* Cart
@enduml