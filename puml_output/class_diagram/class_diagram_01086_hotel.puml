@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Guest {
  #double score
  #String email
  -long address
  +updateEmail()
  +findNote()
}
class Housekeeping {
  -long duration
  #float price
  -double total
  #int note
  +calculateNote()
  +deleteCreatedat()
  +createCreatedat()
  +cancelScore()
}
class Booking {
  -double type
  -boolean status
  +setType()
  +sendId()
}
interface Staff {
  #Date code
  #int address
  +setNote()
  +saveActive()
  +cancelId()
  +savePrice()
}
Staff ..|> Guest
Staff ..|> Housekeeping
Guest --* Housekeeping
@enduml