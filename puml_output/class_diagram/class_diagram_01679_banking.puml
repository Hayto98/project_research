@startuml
skinparam defaultFontSize 13
class Withdrawal {
  +double duration
  -long price
  +findEmail()
  +findCode()
}
class Beneficiary {
  -Date score
  +int type
  +updateEmail()
  +calculateId()
  +updateLevel()
}
interface Statement {
  -double quantity
  +long name
  -int status
  #Date price
  +validateDescription()
}
class Loan {
  +String duration
  +Date createdAt
  +Date status
  +sendName()
  +updateTotal()
  +findEmail()
}
abstract class Branch {
  +String total
  -double level
  +boolean address
  -long createdAt
  +getName()
  +sendType()
  +updateScore()
}
class Interest {
  +long level
  -long duration
  +processName()
  +getAmount()
  +calculateStatus()
  +processStatus()
}
class Deposit {
  -float createdAt
  #boolean quantity
  -int score
  +long address
  +getName()
  +createScore()
}
Beneficiary ..> Loan : "0..1"
Statement --> Interest : "0..1"
note right of Withdrawal : Banking domain
@enduml