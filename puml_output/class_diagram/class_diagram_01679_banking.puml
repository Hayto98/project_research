@startuml
skinparam defaultFontSize 13
class Withdrawal {
  +double duration
  -long price
  +validateType()
  +getActive()
}
class Beneficiary {
  #double name
  -Date status
  +updateDescription()
  +updateLevel()
}
class Statement {
  -float price
  +String id
  #float createdAt
  -double address
  +findId()
  +findScore()
  +updateEmail()
  +updateDescription()
}
interface Loan {
  +int address
  #int description
  +validateNote()
}
class Branch {
  +int updatedAt
  -Date phone
  -float score
  +calculateDuration()
  +findStatus()
  +processDescription()
  +deleteEmail()
}
abstract class Interest {
  -int createdAt
  #float updatedAt
  -long id
  #float address
  +updateDuration()
  +processQuantity()
  +getScore()
}
abstract class Deposit {
  #float score
  #int status
  -long code
  +setPrice()
  +processTotal()
  +findActive()
}
Withdrawal ..|> Interest
Loan --o Withdrawal
@enduml