@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Hospital {
  #int description
  #long score
  +boolean type
  +int price
  -double createdAt
  +deleteAddress()
  +processType()
  +createLevel()
}
abstract class Appointment {
  -float active
  -long score
  +processCreatedat()
  +findAddress()
  +cancelPrice()
}
abstract class Prescription {
  +String price
  +float description
  #Date quantity
  +boolean createdAt
  +processScore()
}
class LabTest {
  -double status
  #int phone
  +validateTotal()
}
class Nurse {
  #long price
  +String quantity
  +calculateStatus()
  +saveQuantity()
  +calculatePrice()
  +updateStatus()
}
class Treatment {
  -float id
  +String status
  +cancelLevel()
  +validateDescription()
  +setTotal()
  +setCreatedat()
}
class Diagnosis {
  -boolean phone
  -boolean active
  +float id
  #float note
  +updateStatus()
  +findTotal()
  +sendLevel()
  +validateQuantity()
}
Nurse ..|> Treatment
Hospital --> Diagnosis : "0..1"
@enduml