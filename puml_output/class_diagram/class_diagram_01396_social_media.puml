@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Profile {
  #float quantity
  -Date active
  -Date amount
  -float code
  +getDescription()
  +createDescription()
}
abstract class Post {
  +Date updatedAt
  -float total
  -long note
  +Date name
  +long amount
  +updateTotal()
}
class Hashtag {
  -int updatedAt
  +String quantity
  -float amount
  +deleteCreatedat()
  +processStatus()
  +setDescription()
}
interface Album {
  +Date duration
  +Date total
  +createType()
  +validateCode()
}
class Notification {
  #double duration
  -Date quantity
  +String address
  +updateTotal()
}
Notification ..|> Album
Album ..> Post : "*"
Album --* Profile
Notification --* Hashtag
@enduml