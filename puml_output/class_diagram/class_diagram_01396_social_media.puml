@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Profile {
  #float quantity
  -Date active
  -Date amount
  -float code
  +sendTotal()
  +findPrice()
}
class Post {
  -long note
  +Date name
  +long amount
  #Date level
  +long phone
  +updateUpdatedat()
  +createAmount()
  +processDescription()
}
class Hashtag {
  -long total
  +boolean address
  +cancelTotal()
}
class Album {
  #boolean amount
  #float description
  #int code
  +validateDuration()
  +calculateAddress()
  +findUpdatedat()
}
class Notification {
  -int phone
  -Date score
  +findNote()
  +saveType()
}
Profile ..> Hashtag : "1..*"
Hashtag ..> Post : "*"
Post ..> Album : "1..*"
Post ..> Notification : "*"
note right of Profile : Social Media domain
@enduml