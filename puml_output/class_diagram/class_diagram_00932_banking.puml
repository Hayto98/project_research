@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Deposit {
  #boolean updatedAt
  #boolean phone
  -double level
  -long total
  +Date amount
  +cancelType()
  +cancelActive()
}
class Withdrawal {
  #float active
  +long price
  #boolean description
  +String amount
  +findType()
  +updateAmount()
  +updateActive()
}
class Account {
  +double level
  #Date amount
  +float updatedAt
  +cancelPhone()
  +calculateUpdatedat()
}
class Customer {
  +double createdAt
  -float quantity
  -double active
  +float amount
  #String level
  +createStatus()
}
Customer ..|> Withdrawal
Account --> Customer : "*"
@enduml