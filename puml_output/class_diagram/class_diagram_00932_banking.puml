@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Deposit {
  #boolean updatedAt
  #boolean phone
  -double level
  -long total
  +Date amount
  +cancelCreatedat()
  +createActive()
}
abstract class Withdrawal {
  #boolean amount
  +String name
  #long email
  +getDuration()
}
class Account {
  -boolean level
  #int updatedAt
  #boolean status
  +createUpdatedat()
  +calculateCreatedat()
}
class Customer {
  -float quantity
  -double updatedAt
  +float note
  +setScore()
}
Customer ..|> Withdrawal
Account --> Customer : "*"
note right of Deposit : Banking domain
@enduml