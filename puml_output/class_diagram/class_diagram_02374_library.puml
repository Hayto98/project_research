@startuml
skinparam defaultFontSize 13
class Catalog {
  -long address
  -boolean level
  +sendActive()
}
class Shelf {
  +float score
  #boolean code
  +validateAmount()
}
abstract class Publisher {
  -long email
  -double note
  +validateScore()
}
class Fine {
  -boolean id
  #boolean updatedAt
  -Date price
  +String total
  #long note
  +cancelName()
  +cancelCode()
  +findNote()
}
class Book {
  +int price
  #String amount
  +String address
  +sendPrice()
}
class Loan {
  -String phone
  -String id
  +Date duration
  #float price
  +saveActive()
  +calculateName()
  +deleteAmount()
}
class Renewal {
  -long status
  #double description
  +getDescription()
  +calculateScore()
  +sendLevel()
  +calculateDescription()
}
Loan --* Book
Catalog --> Shelf : "*"
@enduml