@startuml
skinparam monochrome true
skinparam shadowing true
interface Hashtag {
  +double note
  #long active
  #int quantity
  +int phone
  +processDescription()
  +cancelType()
  +validateQuantity()
}
abstract class Report {
  +long level
  #double duration
  +saveStatus()
  +updateDuration()
  +deleteType()
  +processDuration()
}
abstract class Comment {
  -int email
  -float name
  -float note
  +findPrice()
  +cancelDuration()
  +calculateQuantity()
}
class Follower {
  +int name
  -double note
  -Date status
  +processDuration()
}
class Story {
  +String address
  #int active
  #float code
  #int note
  #long price
  +findId()
  +validateName()
  +processNote()
  +createActive()
}
interface Post {
  +double email
  #int amount
  +deleteCreatedat()
  +deletePhone()
}
class Profile {
  #Date email
  -long type
  -boolean status
  +int price
  #boolean address
  +calculateScore()
  +setCreatedat()
  +createCode()
}
Follower ..|> Post
Report --* Profile
@enduml