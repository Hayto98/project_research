@startuml
skinparam monochrome true
skinparam shadowing true
interface Hashtag {
  +double note
  #long active
  #int quantity
  +int phone
  +createAmount()
  +calculateCode()
  +cancelDuration()
}
interface Report {
  +Date phone
  +Date price
  -int level
  +getLevel()
  +processType()
  +deleteQuantity()
}
class Comment {
  +double active
  +int total
  +long address
  -long amount
  +updateQuantity()
}
abstract class Follower {
  +String active
  #int code
  #float note
  #int price
  +processAmount()
  +processAddress()
  +cancelStatus()
}
class Story {
  +boolean name
  +long price
  +boolean active
  +createType()
  +setPrice()
  +validateTotal()
  +createPrice()
}
interface Post {
  -Date amount
  +Date active
  +double email
  +updateCreatedat()
  +createAddress()
}
class Profile {
  +Date duration
  +String status
  +double type
  #double address
  +getPhone()
  +cancelDescription()
}
Report ..|> Follower
Post ..|> Follower
Follower ..> Post : "0..1"
Story --* Profile
Follower --> Hashtag : "*"
note right of Hashtag : Social Media domain
@enduml