@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
interface Loan {
  -double status
  -boolean createdAt
  -float active
  +saveTotal()
}
abstract class Account {
  +long address
  +String status
  +processAddress()
}
class Withdrawal {
  +String name
  #long email
  +saveCode()
  +sendScore()
  +createPrice()
}
class Transfer {
  #boolean status
  +Date score
  +savePrice()
}
class Deposit {
  #double active
  +boolean email
  +float note
  +String createdAt
  +setActive()
}
class Teller {
  #double description
  +float amount
  -long score
  +savePrice()
  +updateType()
}
class Transaction {
  #String duration
  #float status
  +int updatedAt
  +calculateDescription()
  +setLevel()
  +cancelName()
  +cancelTotal()
}
Account --|> Withdrawal
Withdrawal ..|> Transfer
@enduml