@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
interface Loan {
  -double status
  -boolean createdAt
  -float active
  +processStatus()
}
class Account {
  +String updatedAt
  +float phone
  +setName()
}
class Withdrawal {
  #Date code
  #long active
  -double phone
  +updateName()
  +setScore()
  +findScore()
  +getId()
}
interface Transfer {
  +Date address
  -String active
  #String email
  +String note
  +setCreatedat()
}
class Deposit {
  +float score
  -long duration
  +boolean note
  +deleteCreatedat()
  +cancelStatus()
}
class Teller {
  +boolean active
  #boolean status
  +findDescription()
  +findId()
  +setAmount()
  +createStatus()
}
class Transaction {
  -double createdAt
  #Date description
  #int duration
  -float note
  +float email
  +updateUpdatedat()
}
Teller --* Account
Transaction ..|> Account
Transaction --* Deposit
Transfer --> Loan : "*"
note right of Loan : Banking domain
@enduml