@startuml
skinparam ArrowColor #555555
class Transfer {
  +String level
  -boolean updatedAt
  #float phone
  -double score
  +setActive()
  +saveQuantity()
  +deleteId()
  +calculateCode()
}
class Customer {
  #float description
  #double phone
  +saveId()
  +cancelQuantity()
}
interface Beneficiary {
  #int name
  -float phone
  +createActive()
  +processUpdatedat()
}
class Interest {
  -int id
  -long createdAt
  +int type
  +long name
  #double total
  +setPhone()
}
class Deposit {
  #double email
  -Date note
  +Date code
  +long level
  +cancelTotal()
}
Interest ..> Deposit : "1..*"
Deposit ..> Beneficiary : "1..*"
note right of Transfer : Banking domain
@enduml