@startuml
skinparam ArrowColor #555555
class Transfer {
  +String level
  -boolean updatedAt
  #float phone
  -double score
  +cancelEmail()
  +saveType()
  +getScore()
  +validatePrice()
}
class Customer {
  #String id
  #boolean total
  +int code
  +deleteEmail()
  +cancelAmount()
  +findEmail()
}
interface Beneficiary {
  +long updatedAt
  #int id
  -float quantity
  +float active
  -boolean code
  +createScore()
  +savePhone()
  +saveType()
  +setActive()
}
abstract class Interest {
  #float createdAt
  +double type
  +setType()
  +createName()
  +createQuantity()
}
class Deposit {
  -float code
  #Date email
  +float score
  +deleteTotal()
}
Beneficiary --* Customer
Beneficiary --|> Interest
Interest --* Deposit
Transfer --* Deposit
@enduml