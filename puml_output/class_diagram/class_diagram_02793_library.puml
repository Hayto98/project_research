@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
abstract class Catalog {
  -double address
  #double id
  #String phone
  +double description
  +findStatus()
  +cancelType()
}
class Shelf {
  +float status
  #String address
  +getActive()
  +calculateActive()
  +deleteId()
  +sendStatus()
}
class Author {
  #boolean updatedAt
  -double id
  -boolean quantity
  +String active
  -float createdAt
  +deleteDescription()
  +setAddress()
}
abstract class Book {
  +long type
  #double id
  -boolean level
  +int active
  -int address
  +deleteScore()
  +createNote()
}
Shelf --> Book : "*"
Book --o Author
note right of Catalog : Library domain
@enduml