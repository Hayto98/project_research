@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
abstract class Catalog {
  -double address
  #double id
  #String phone
  +double description
  +saveDescription()
  +createPhone()
}
interface Shelf {
  #String updatedAt
  #Date name
  -String status
  #double address
  #int amount
  +sendAmount()
}
class Author {
  +long note
  #int updatedAt
  +getStatus()
  +calculateQuantity()
  +sendAddress()
}
interface Book {
  +int name
  #int quantity
  +saveCreatedat()
}
Book --|> Shelf
Catalog --* Author
Catalog --> Shelf : "*"
@enduml