@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Category {
  +float active
  +int amount
  -int quantity
  -Date name
  +processUpdatedat()
  +updateActive()
  +processNote()
  +createEmail()
}
class Shipment {
  -float name
  +double total
  +float price
  +saveName()
  +cancelEmail()
  +saveDuration()
}
class Coupon {
  -boolean email
  +float note
  +String active
  #int description
  #double code
  +findType()
  +setAmount()
}
abstract class Cart {
  +int description
  -float createdAt
  +double status
  +boolean price
  +validateStatus()
  +processDuration()
  +findNote()
  +processActive()
}
interface Review {
  #float amount
  +double price
  #int quantity
  -double status
  +cancelActive()
}
class Invoice {
  +int price
  -boolean active
  -Date updatedAt
  -long status
  +processId()
  +deleteNote()
  +sendNote()
  +getLevel()
}
class Return {
  +Date duration
  -int name
  +setName()
  +findEmail()
}
Invoice ..> Category : "1"
Review ..> Return : "1"
Invoice ..> Review : "1"
Cart --o Category
@enduml