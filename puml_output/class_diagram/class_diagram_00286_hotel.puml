@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class CheckOut {
  -long duration
  -int score
  #float description
  #int active
  #String note
  +cancelQuantity()
  +processAddress()
}
class Housekeeping {
  +float total
  -String duration
  +validateType()
}
abstract class Amenity {
  +long amount
  +double description
  #double createdAt
  #String level
  +cancelCreatedat()
  +createDuration()
  +cancelDescription()
  +saveStatus()
}
class Reservation {
  +long active
  +long description
  +calculateQuantity()
  +updateScore()
}
abstract class Payment {
  #int phone
  #long code
  +boolean duration
  -int price
  #long id
  +sendStatus()
}
interface CheckIn {
  -String amount
  +int type
  +String duration
  #double createdAt
  +boolean status
  +processDuration()
  +getAddress()
}
abstract class Booking {
  -Date email
  +int address
  #double level
  -long quantity
  +double duration
  +deletePhone()
  +calculateDescription()
  +validateScore()
}
Housekeeping --> CheckOut : "0..1"
CheckOut --> Reservation : "1..*"
@enduml