@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Inventory {
  +boolean price
  +double description
  -float updatedAt
  +updateTotal()
}
class Driver {
  +long score
  #float price
  +long amount
  -Date total
  +calculatePhone()
  +calculateType()
  +processCode()
  +processCreatedat()
}
class Tracking {
  +Date name
  -boolean phone
  -String email
  -long level
  #double duration
  +deleteName()
  +findQuantity()
  +getActive()
  +saveLevel()
}
class Route {
  +String amount
  +Date createdAt
  +float updatedAt
  +boolean phone
  +boolean note
  +createLevel()
  +cancelStatus()
  +sendAmount()
  +saveEmail()
}
class Warehouse {
  -int duration
  +float total
  #boolean createdAt
  +int amount
  +saveEmail()
  +sendCode()
}
Inventory ..> Tracking : "0..1"
Warehouse --|> Route
note right of Inventory : Logistics domain
@enduml