@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Inventory {
  +boolean price
  +double description
  -float updatedAt
  +processDuration()
}
abstract class Driver {
  -int score
  -int email
  -boolean duration
  +deleteCode()
}
abstract class Tracking {
  +double total
  +Date phone
  -Date price
  #double type
  #String note
  +deleteCreatedat()
  +updateQuantity()
  +deleteCode()
}
class Route {
  +double type
  -boolean score
  -double phone
  +deleteNote()
  +saveDescription()
}
class Warehouse {
  +double active
  +int level
  +saveDuration()
  +cancelPrice()
}
Tracking ..|> Route
Inventory ..> Driver : "1"
Driver --> Warehouse : "*"
Tracking --> Inventory : "0..1"
@enduml