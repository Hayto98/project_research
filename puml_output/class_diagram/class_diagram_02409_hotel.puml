@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Staff {
  -Date active
  +long phone
  -long address
  -float type
  #double duration
  +sendAddress()
  +saveNote()
  +processUpdatedat()
  +setCreatedat()
}
abstract class Housekeeping {
  +Date description
  +int createdAt
  -String duration
  +Date note
  +validateStatus()
}
class Reservation {
  +long email
  +double active
  +sendCode()
}
interface Restaurant {
  -String level
  -Date note
  -float quantity
  -Date updatedAt
  +createTotal()
  +createScore()
  +saveStatus()
}
abstract class Amenity {
  #String address
  +double email
  -String level
  -double note
  +findAmount()
  +saveId()
  +sendEmail()
}
class Guest {
  -boolean id
  #long price
  -float total
  +Date score
  +sendActive()
}
class Service {
  #boolean code
  #double quantity
  #double price
  +getName()
  +getPrice()
  +getDescription()
  +validateTotal()
}
Housekeeping --|> Restaurant
Housekeeping --* Guest
Staff ..|> Amenity
Guest --|> Housekeeping
Reservation --* Restaurant
Housekeeping --o Staff
@enduml