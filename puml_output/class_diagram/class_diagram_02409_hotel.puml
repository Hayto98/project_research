@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Staff {
  -Date active
  +long phone
  -long address
  -float type
  #double duration
  +createCreatedat()
  +deleteType()
  +sendActive()
  +findAddress()
}
class Housekeeping {
  #String description
  +float note
  -String amount
  +findStatus()
  +createName()
}
class Reservation {
  -String quantity
  -Date description
  +cancelNote()
  +createUpdatedat()
  +processName()
}
class Restaurant {
  -long note
  -double quantity
  #String updatedAt
  +double type
  -String email
  +processQuantity()
  +calculateName()
  +updateStatus()
}
interface Amenity {
  -boolean id
  #long price
  -float total
  +Date score
  +cancelStatus()
}
class Guest {
  #boolean quantity
  #double price
  +calculateScore()
  +deleteTotal()
  +setUpdatedat()
  +saveQuantity()
}
class Service {
  -long createdAt
  +String name
  -double address
  +findQuantity()
}
Staff ..|> Reservation
Guest ..|> Service
Reservation --* Service
note right of Staff : Hotel domain
@enduml