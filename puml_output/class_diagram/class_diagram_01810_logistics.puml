@startuml
skinparam shadowing true
interface Route {
  #String duration
  +Date address
  +cancelScore()
}
class Inventory {
  #String note
  +float createdAt
  #float phone
  +long duration
  +updateTotal()
  +cancelId()
  +processAddress()
}
class Tracking {
  +double phone
  +double total
  +int price
  -float amount
  +deleteTotal()
}
abstract class Vehicle {
  #float price
  -int updatedAt
  +long description
  +getType()
  +saveCreatedat()
  +calculateQuantity()
  +calculatePhone()
}
abstract class FuelLog {
  +Date description
  #boolean price
  +updateTotal()
  +deleteAmount()
  +sendDescription()
}
class Depot {
  +long code
  #String quantity
  #boolean updatedAt
  +deleteDescription()
  +validateNote()
  +savePrice()
  +findName()
}
Vehicle --* Route
Tracking --> Route : "0..1"
Tracking --* Depot
@enduml