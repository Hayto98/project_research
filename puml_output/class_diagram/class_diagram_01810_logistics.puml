@startuml
skinparam shadowing true
interface Route {
  #String duration
  +Date address
  +saveUpdatedat()
}
class Inventory {
  +float createdAt
  #float phone
  +long note
  -long active
  -float id
  +findPhone()
  +validateTotal()
  +calculateAmount()
}
class Tracking {
  +float id
  -boolean price
  +double duration
  +int updatedAt
  #float quantity
  +updateAmount()
  +validateType()
  +setAddress()
}
abstract class Vehicle {
  +Date price
  #boolean status
  -long description
  -float duration
  +deleteCode()
}
class FuelLog {
  #boolean code
  -boolean phone
  +boolean duration
  +calculateStatus()
  +validatePhone()
  +getLevel()
}
class Depot {
  #double id
  +long quantity
  #double email
  +String address
  +sendName()
  +validateDescription()
  +setAddress()
  +deleteTotal()
}
Depot ..|> Tracking
Vehicle --> Inventory : "*"
note right of Route : Logistics domain
@enduml