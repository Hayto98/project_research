@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
interface Order {
  -Date code
  #long type
  +cancelTotal()
}
abstract class Customer {
  -float amount
  #String type
  -String phone
  -long quantity
  +findCreatedat()
  +sendCreatedat()
  +sendUpdatedat()
  +deleteName()
}
class Payment {
  +String name
  +Date description
  -boolean active
  +double address
  +float price
  +getPhone()
}
abstract class Cart {
  +boolean address
  +String updatedAt
  -String id
  #int description
  +calculateNote()
}
class Invoice {
  #int name
  #long phone
  +createCreatedat()
  +createLevel()
}
Order --> Payment : "1"
Cart --|> Order
note right of Order : Ecommerce domain
@enduml