@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Transfer {
  #float email
  -float phone
  #String name
  +boolean description
  +updateScore()
  +validateAddress()
}
class Branch {
  #int email
  #long active
  -String quantity
  +cancelId()
  +cancelType()
  +findTotal()
  +setUpdatedat()
}
abstract class Beneficiary {
  #boolean description
  -long note
  -double level
  +updateLevel()
  +findName()
}
class Customer {
  -long duration
  #int name
  -Date score
  #float updatedAt
  +processAmount()
  +processStatus()
  +updateScore()
}
class Account {
  #int score
  -long code
  -Date amount
  +createAddress()
}
interface Teller {
  +double email
  -int amount
  +validateAddress()
  +validateDescription()
}
Branch ..|> Account
Account --|> Teller
Transfer --o Account
Transfer --o Customer
@enduml