@startuml
skinparam defaultFontSize 11
class Group {
  +String name
  +String type
  -String level
  +String id
  #String total
  +validateStatus()
  +createEmail()
  +validateScore()
}
class Story {
  -Date code
  -boolean description
  +float total
  #double name
  +sendId()
}
class Report {
  +boolean level
  #double phone
  +processScore()
}
interface Post {
  #Date address
  #String amount
  +double updatedAt
  -long status
  +deleteLevel()
  +findNote()
}
class User {
  -float note
  -long description
  -String price
  +getUpdatedat()
  +processUpdatedat()
  +saveStatus()
  +sendPhone()
}
abstract class Message {
  +double quantity
  +boolean duration
  #String description
  -int type
  +validateType()
  +processCode()
  +cancelUpdatedat()
}
Report ..|> Story
Message ..|> Post
Post ..> Report : "1"
Message --o Group
@enduml