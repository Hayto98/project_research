@startuml
skinparam defaultFontSize 11
class Group {
  +String name
  +String type
  -String level
  +String id
  #String total
  +validateStatus()
  +createCode()
  +deleteTotal()
}
class Story {
  +int note
  +String level
  #boolean name
  #long duration
  +sendLevel()
  +processName()
}
interface Report {
  #Date address
  #String amount
  +double updatedAt
  -long status
  +setStatus()
  +deleteNote()
}
class Post {
  -float type
  +float address
  -float phone
  #Date price
  -boolean id
  +createQuantity()
  +deleteDuration()
  +processAmount()
}
abstract class User {
  +double score
  +long duration
  +findScore()
}
class Message {
  -float amount
  -Date description
  +float type
  #String duration
  +calculateLevel()
  +cancelQuantity()
  +validatePhone()
  +cancelAddress()
}
Report --|> Post
Post ..|> Group
Story ..|> Group
Post --> Report : "*"
Report --o Message
note right of Group : Social Media domain
@enduml