@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
abstract class Customer {
  +float price
  +String code
  +cancelStatus()
  +cancelAmount()
  +findType()
  +saveDuration()
}
class Vehicle {
  +double duration
  #String level
  -long createdAt
  +setTotal()
  +validateDescription()
}
class DeliveryNote {
  -long duration
  -float type
  +boolean price
  +saveUpdatedat()
  +saveId()
}
class FuelLog {
  -double description
  -long quantity
  +long amount
  +String level
  #boolean createdAt
  +createAddress()
}
interface Inventory {
  #double id
  #Date email
  +processType()
  +calculateEmail()
  +sendPhone()
  +processQuantity()
}
FuelLog --> Customer : "0..1"
Vehicle ..|> DeliveryNote
Vehicle --|> Customer
note right of Customer : Logistics domain
@enduml