@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
abstract class Customer {
  +float price
  +String code
  +setPhone()
  +updateName()
  +deleteDescription()
  +updateType()
}
abstract class Vehicle {
  -Date duration
  +double updatedAt
  -Date createdAt
  #Date score
  +cancelEmail()
  +validateTotal()
}
abstract class DeliveryNote {
  -double description
  -double phone
  +boolean amount
  +Date type
  +processCreatedat()
  +cancelScore()
}
class FuelLog {
  -Date total
  +long description
  -long quantity
  -int amount
  +deleteNote()
  +cancelStatus()
  +updateAmount()
}
interface Inventory {
  #boolean email
  +float address
  +cancelPhone()
}
FuelLog --o Inventory
DeliveryNote --o Inventory
DeliveryNote --o FuelLog
@enduml