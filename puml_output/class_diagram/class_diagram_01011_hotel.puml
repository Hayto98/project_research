@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Amenity {
  -boolean amount
  +boolean total
  +float score
  #String phone
  +long email
  +sendUpdatedat()
  +findPhone()
}
interface Restaurant {
  #Date updatedAt
  -String status
  +getName()
  +processId()
  +deleteEmail()
}
abstract class Guest {
  #long amount
  #int email
  -int status
  +sendDuration()
  +sendPrice()
  +processActive()
  +findPrice()
}
interface Service {
  -int code
  #long note
  -int type
  #Date id
  #long active
  +cancelDuration()
  +findTotal()
  +validateId()
  +deleteNote()
}
class Payment {
  #double price
  -boolean updatedAt
  +Date address
  +deleteQuantity()
  +updateEmail()
  +getCode()
}
class Room {
  -double score
  -int active
  -int code
  +updateActive()
  +validateType()
}
interface Housekeeping {
  #String code
  +double level
  #float amount
  #boolean name
  +cancelAmount()
  +processStatus()
}
Payment --* Service
Restaurant ..> Payment : "1..*"
Housekeeping ..> Payment : "0..1"
Amenity --* Payment
@enduml