@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Amenity {
  -boolean amount
  +boolean total
  +float score
  #String phone
  +long email
  +findDescription()
  +cancelStatus()
}
class Restaurant {
  +float score
  -float phone
  +cancelDescription()
  +deleteEmail()
  +setLevel()
  +createCreatedat()
}
class Guest {
  #Date note
  #double createdAt
  +double active
  +saveId()
  +findScore()
  +getPhone()
  +deleteLevel()
}
class Service {
  #Date amount
  -int email
  -Date price
  #int status
  -boolean name
  +processScore()
  +getEmail()
  +setTotal()
  +cancelAddress()
}
class Payment {
  -int type
  -int note
  +getScore()
  +createCode()
}
interface Room {
  -boolean name
  #boolean id
  #int updatedAt
  +savePhone()
  +cancelTotal()
  +validateCreatedat()
}
interface Housekeeping {
  +float active
  #Date updatedAt
  +String status
  #long quantity
  +updatePhone()
  +updateAmount()
  +deleteTotal()
  +setDuration()
}
Housekeeping --|> Restaurant
Guest --o Amenity
Room --o Restaurant
note right of Amenity : Hotel domain
@enduml