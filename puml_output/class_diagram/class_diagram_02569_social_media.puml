@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Story {
  #int amount
  #float email
  +String price
  -String active
  #float address
  +getActive()
}
class Like {
  #String name
  +Date note
  #float description
  +updatePhone()
  +getNote()
  +deleteDuration()
}
class Group {
  -long code
  -int score
  -long duration
  -float type
  #Date description
  +deleteEmail()
  +saveAddress()
  +createNote()
}
abstract class Report {
  #double email
  -Date score
  #float id
  #long description
  +cancelName()
  +sendType()
  +sendPhone()
}
Group --|> Story
Like ..|> Group
Group --* Report
note right of Story : Social Media domain
@enduml