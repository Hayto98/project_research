@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Story {
  #int amount
  #float email
  +String price
  -String active
  #float address
  +calculateId()
}
interface Like {
  #String createdAt
  +Date name
  #float note
  -int description
  +calculateEmail()
  +sendCode()
  +saveAddress()
}
interface Group {
  +double price
  +double code
  -long score
  +calculateAmount()
  +createNote()
}
class Report {
  -double active
  -float email
  -long description
  #boolean level
  #float address
  +createCreatedat()
}
Report ..> Group : "1..*"
Group --|> Report
@enduml