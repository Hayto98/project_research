@startuml
skinparam shadowing true
abstract class DeliveryNote {
  -double level
  #long amount
  -float name
  +deleteCreatedat()
  +saveQuantity()
  +saveTotal()
}
class Shipment {
  #float total
  +boolean price
  +validateName()
  +getActive()
  +createPhone()
}
class Inventory {
  +long id
  -String score
  +boolean active
  -String quantity
  -Date note
  +getStatus()
  +saveNote()
}
abstract class Vehicle {
  #long level
  #boolean updatedAt
  #boolean address
  +findName()
  +setTotal()
}
interface Warehouse {
  #Date total
  +String score
  +int updatedAt
  -boolean amount
  +findAmount()
}
abstract class Customer {
  +float email
  +int score
  -String status
  +String duration
  +deleteQuantity()
  +getLevel()
  +processActive()
}
class Tracking {
  -String description
  +double address
  #boolean createdAt
  -long note
  +cancelDuration()
  +cancelTotal()
  +updatePrice()
}
DeliveryNote --|> Shipment
Inventory --o Customer
Inventory --o Tracking
Vehicle ..|> Shipment
Customer --* Tracking
Customer --* Inventory
@enduml