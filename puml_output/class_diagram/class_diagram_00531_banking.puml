@startuml
skinparam ArrowColor #555555
class Statement {
  +int active
  -Date id
  #int price
  #long total
  #String score
  +calculateEmail()
}
abstract class Teller {
  +Date total
  -int level
  +setStatus()
  +getActive()
  +validateActive()
}
class Beneficiary {
  -int quantity
  -double total
  +boolean description
  +Date price
  +sendTotal()
  +findAmount()
  +saveStatus()
  +calculateCreatedat()
}
interface Loan {
  +boolean price
  +int phone
  +int email
  -long active
  +getCreatedat()
  +cancelUpdatedat()
  +validateAddress()
}
interface Customer {
  +Date email
  +String code
  +String id
  #float note
  +calculateName()
  +processQuantity()
  +setType()
}
Teller --* Customer
Beneficiary --* Loan
@enduml