@startuml
skinparam ArrowColor #555555
class Statement {
  +int active
  -Date id
  #int price
  #long total
  #String score
  +getNote()
}
class Teller {
  +Date level
  #int code
  -long email
  -boolean createdAt
  +double phone
  +updatePrice()
  +calculateName()
  +sendStatus()
}
abstract class Beneficiary {
  #Date total
  #long address
  +validateEmail()
  +findActive()
  +deleteLevel()
  +setCreatedat()
}
class Loan {
  #Date price
  -boolean address
  -long phone
  +getNote()
}
class Customer {
  #float status
  #long id
  -String name
  +setAmount()
  +deleteEmail()
}
Loan --o Beneficiary
Beneficiary --o Teller
note right of Statement : Banking domain
@enduml