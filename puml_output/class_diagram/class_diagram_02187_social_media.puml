@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
interface User {
  #boolean name
  +boolean total
  -long status
  +int createdAt
  +deleteEmail()
  +sendId()
}
abstract class Post {
  +long amount
  +long duration
  #long status
  +validateCode()
  +processCreatedat()
  +validateType()
}
class Profile {
  #int email
  -double phone
  -float active
  +String total
  #double note
  +sendDescription()
  +savePhone()
}
interface Like {
  +long active
  #long id
  +String quantity
  +boolean note
  +setAmount()
}
class Follower {
  -boolean phone
  +double duration
  -int updatedAt
  -Date active
  +createCreatedat()
}
Follower --|> Profile
User ..> Post : "*"
Post ..> User : "*"
Follower ..> User : "1..*"
@enduml