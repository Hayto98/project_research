@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Message {
  #int duration
  #float score
  -double description
  +Date quantity
  +float active
  +processType()
  +deleteEmail()
}
class Profile {
  #float description
  #Date name
  #Date id
  +Date updatedAt
  -double createdAt
  +setDuration()
}
abstract class Report {
  +long price
  #String updatedAt
  #boolean level
  -float code
  +validateDescription()
}
class User {
  #String id
  +float code
  +String description
  -String quantity
  -int type
  +sendDescription()
}
abstract class Post {
  #String status
  +int name
  #String email
  +sendType()
  +processEmail()
  +processAddress()
  +savePhone()
}
abstract class Follower {
  #long amount
  #String note
  -float quantity
  +cancelDescription()
}
Report --* Profile
Profile ..> Post : "1..*"
@enduml