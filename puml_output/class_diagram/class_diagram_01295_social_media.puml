@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Message {
  #int duration
  #float score
  -double description
  +Date quantity
  +float active
  +calculateQuantity()
  +calculateDescription()
}
class Profile {
  #float updatedAt
  #Date createdAt
  +findEmail()
}
abstract class Report {
  -int total
  +String phone
  +validateName()
  +saveScore()
}
abstract class User {
  -String phone
  +int level
  +processStatus()
  +updateAmount()
  +getEmail()
}
class Post {
  +String createdAt
  -Date status
  +float price
  +int amount
  +processLevel()
}
class Follower {
  #String updatedAt
  -float amount
  +Date note
  +long quantity
  +long active
  +sendAddress()
  +validateQuantity()
}
Follower ..|> Post
Post --* Follower
Post ..> User : "0..1"
Profile --> User : "1"
Post ..|> Message
note right of Message : Social Media domain
@enduml