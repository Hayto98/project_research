@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
abstract class Loan {
  #int updatedAt
  +float description
  #Date active
  #double createdAt
  +setId()
}
class Transaction {
  #Date price
  -String score
  +sendCode()
  +processAddress()
}
class Account {
  +double quantity
  +int email
  +String description
  #long amount
  #boolean createdAt
  +findType()
  +processStatus()
  +createAmount()
}
class Deposit {
  -double description
  #long total
  #int name
  +processStatus()
  +findDescription()
}
class Customer {
  -int email
  #double score
  +int status
  +getStatus()
  +findActive()
  +cancelLevel()
  +cancelAddress()
}
Loan ..> Customer : "1"
Loan --|> Deposit
Account ..> Transaction : "*"
@enduml