@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
abstract class Shelf {
  #boolean type
  +long level
  -String duration
  +sendStatus()
  +sendId()
  +deleteType()
}
abstract class Branch {
  #Date note
  #int id
  +deleteAddress()
  +calculateAddress()
  +validateStatus()
  +cancelDuration()
}
class Librarian {
  #int createdAt
  +double score
  -double quantity
  +processAmount()
  +sendId()
  +getDescription()
  +cancelType()
}
class Reservation {
  -boolean phone
  +float updatedAt
  +sendCode()
  +createCode()
  +processDescription()
}
Branch ..> Reservation : "1..*"
Librarian --|> Reservation
@enduml