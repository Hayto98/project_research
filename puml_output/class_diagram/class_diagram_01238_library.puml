@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Branch {
  +long name
  #String id
  -int code
  #long status
  +getPhone()
}
class Book {
  #Date phone
  -double address
  +calculateAmount()
}
abstract class Member {
  #boolean amount
  +float phone
  +int description
  #Date level
  +updateStatus()
}
class Shelf {
  +long active
  #int type
  +sendAmount()
}
class Reservation {
  #int createdAt
  #float description
  +sendCreatedat()
  +calculatePrice()
  +createDuration()
  +createAddress()
}
Member --|> Shelf
Member --* Branch
Book --> Member : "1..*"
@enduml