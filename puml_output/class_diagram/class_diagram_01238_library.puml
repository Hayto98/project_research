@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Branch {
  +long name
  #String id
  -int code
  #long status
  +calculateAddress()
}
class Book {
  +double address
  #double active
  #long quantity
  +Date price
  +deletePhone()
  +findDuration()
  +setCreatedat()
}
class Member {
  +boolean updatedAt
  -String code
  +saveUpdatedat()
  +setScore()
  +setDuration()
}
class Shelf {
  #float description
  #double score
  -boolean duration
  +setNote()
  +createActive()
  +calculateId()
  +validateLevel()
}
interface Reservation {
  -boolean email
  #long description
  +saveStatus()
  +cancelDuration()
  +saveAmount()
  +createName()
}
Reservation ..> Shelf : "*"
Branch ..> Member : "*"
Shelf --> Reservation : "1..*"
note right of Branch : Library domain
@enduml