@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Branch {
  #long duration
  -Date createdAt
  #int description
  +long status
  +calculatePrice()
  +sendType()
  +calculateCode()
  +findActive()
}
class Loan {
  -int total
  +long price
  +createNote()
}
class Customer {
  #int price
  #boolean updatedAt
  +long total
  #int duration
  +updateTotal()
  +sendPhone()
  +deleteCreatedat()
  +calculateNote()
}
class Statement {
  -Date address
  -String note
  #String price
  +updateLevel()
  +createTotal()
  +createQuantity()
  +deleteStatus()
}
abstract class Beneficiary {
  -double email
  -String score
  +updateTotal()
  +calculateCode()
  +calculateType()
  +processLevel()
}
interface Withdrawal {
  +long status
  #String address
  +setDuration()
}
Statement --o Loan
Customer ..|> Branch
@enduml