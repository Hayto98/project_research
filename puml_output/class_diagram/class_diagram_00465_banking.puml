@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Branch {
  #long duration
  -Date createdAt
  #int description
  +long status
  +sendPrice()
  +processUpdatedat()
  +findCode()
  +calculatePrice()
}
class Loan {
  +Date amount
  #int quantity
  #long score
  +updateTotal()
  +calculateDescription()
  +sendActive()
  +deleteQuantity()
}
interface Customer {
  -int price
  +Date phone
  +long level
  +calculatePrice()
  +findAddress()
  +setCode()
  +calculateQuantity()
}
class Statement {
  -long note
  +double name
  -double email
  -boolean quantity
  +setAddress()
}
class Beneficiary {
  +double id
  -Date code
  +int description
  -String type
  +validateDescription()
  +validateActive()
}
abstract class Withdrawal {
  +int amount
  -int code
  #long updatedAt
  +setScore()
}
Beneficiary ..|> Branch
Statement --o Branch
note right of Branch : Banking domain
@enduml