@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Hospital {
  +Date active
  -Date createdAt
  +sendQuantity()
  +deleteUpdatedat()
  +updateUpdatedat()
}
interface Insurance {
  +int amount
  #boolean duration
  +findScore()
  +updateDuration()
  +getCreatedat()
  +sendLevel()
}
interface Prescription {
  -String amount
  -double active
  #boolean level
  #long total
  #String quantity
  +createCode()
  +findPhone()
}
class Nurse {
  -float duration
  #int active
  #long email
  -double description
  #String createdAt
  +setLevel()
  +setCreatedat()
  +sendName()
}
Hospital --* Insurance
Hospital --> Prescription : "1..*"
Nurse --|> Hospital
@enduml