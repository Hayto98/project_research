@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Student {
  +float score
  +float amount
  +int phone
  +deleteTotal()
  +updatePrice()
  +processName()
}
abstract class Classroom {
  +Date quantity
  -String duration
  -double note
  +int address
  +String status
  +updatePhone()
}
interface Book {
  #long type
  #float total
  #double description
  +setName()
  +updateTotal()
  +getActive()
}
interface Grade {
  +int description
  +int id
  +processPrice()
  +cancelUpdatedat()
  +validateCreatedat()
  +validatePhone()
}
class Attendance {
  +long description
  #float status
  +cancelActive()
  +getLevel()
  +validateAmount()
}
Classroom --> Book : "1..*"
Classroom ..|> Student
@enduml