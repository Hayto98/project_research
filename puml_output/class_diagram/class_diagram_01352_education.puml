@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Student {
  +float score
  +float amount
  +int phone
  +getId()
  +processDuration()
  +processQuantity()
}
class Classroom {
  -double address
  +int status
  +String description
  +Date duration
  #int code
  +calculateDescription()
  +cancelEmail()
  +sendActive()
  +processQuantity()
}
class Book {
  +int level
  +int status
  -int description
  #int id
  +setId()
}
class Grade {
  #float code
  -boolean address
  +createCreatedat()
}
class Attendance {
  +int level
  #boolean phone
  #boolean createdAt
  +Date status
  +findId()
  +updateStatus()
  +cancelAddress()
}
Attendance --|> Classroom
Student ..> Classroom : "*"
Attendance ..|> Student
note right of Student : Education domain
@enduml