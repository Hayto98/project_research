@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Report {
  #boolean name
  -double status
  -double level
  +calculateDuration()
  +getCode()
  +processUpdatedat()
  +sendEmail()
}
interface Hashtag {
  #Date code
  -boolean level
  +calculatePhone()
  +setScore()
  +sendQuantity()
  +processTotal()
}
abstract class Profile {
  +long phone
  -boolean type
  +findType()
  +validateActive()
  +findPrice()
}
class Group {
  +Date email
  -float total
  +Date score
  +saveNote()
  +findName()
  +saveCreatedat()
}
interface Comment {
  #float note
  -double type
  +String id
  #String status
  +int price
  +setName()
  +getStatus()
  +createTotal()
  +sendPrice()
}
abstract class User {
  #float createdAt
  #boolean amount
  -Date score
  +int address
  +saveType()
  +processQuantity()
}
abstract class Like {
  +double total
  -String createdAt
  +calculateAddress()
  +calculateCreatedat()
}
Like --o Report
Like --o Comment
Hashtag ..> Like : "1..*"
Report --* Comment
Profile ..|> Hashtag
note right of Report : Social Media domain
@enduml