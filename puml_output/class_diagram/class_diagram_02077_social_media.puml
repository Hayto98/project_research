@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Report {
  #boolean name
  -double status
  -double level
  +saveCode()
  +setId()
  +updateDuration()
  +getType()
}
abstract class Hashtag {
  #boolean score
  +Date email
  +boolean active
  +createStatus()
  +calculateQuantity()
  +saveName()
  +deleteCode()
}
class Profile {
  -double note
  +long total
  -boolean duration
  -Date name
  +findLevel()
  +findCode()
  +saveDescription()
  +calculateActive()
}
abstract class Group {
  -Date createdAt
  #String email
  +deleteTotal()
  +sendNote()
  +calculateUpdatedat()
  +createId()
}
class Comment {
  #double name
  +String createdAt
  -boolean score
  -double price
  +String note
  +createPhone()
}
class User {
  -boolean code
  -double name
  #long id
  +int status
  #long email
  +findStatus()
  +sendNote()
  +processDuration()
  +setDuration()
}
interface Like {
  -String type
  -int note
  +double quantity
  +calculateEmail()
  +findId()
  +findAmount()
  +validateScore()
}
Hashtag --|> Group
Group --o Comment
Hashtag ..> Like : "1..*"
Report --* Comment
Profile ..|> Hashtag
@enduml