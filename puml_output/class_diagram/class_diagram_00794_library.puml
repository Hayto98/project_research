@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Author {
  +double active
  +String code
  +double price
  +getAmount()
}
interface Book {
  +float amount
  #String total
  -double duration
  +String level
  +cancelQuantity()
  +deleteName()
  +getStatus()
  +calculateName()
}
class Fine {
  #String level
  #double price
  -int updatedAt
  +Date type
  +boolean active
  +processNote()
  +findLevel()
  +setDescription()
  +findEmail()
}
class Librarian {
  #int note
  #Date address
  #float duration
  -boolean name
  -double phone
  +processType()
  +sendCode()
}
class Member {
  +long id
  -double code
  +long address
  -long type
  -double price
  +findPrice()
  +setType()
  +setEmail()
}
class Loan {
  +Date score
  +boolean description
  #String duration
  -Date email
  +deleteScore()
  +setAddress()
}
Loan ..|> Librarian
Librarian ..|> Fine
Member --o Librarian
Librarian --> Author : "*"
note right of Author : Library domain
@enduml