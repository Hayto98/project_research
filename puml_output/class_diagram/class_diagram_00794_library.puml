@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Author {
  +double active
  +String code
  +double price
  +calculateEmail()
}
class Book {
  +float amount
  #String total
  -double duration
  +String level
  +findUpdatedat()
  +updateLevel()
  +setQuantity()
  +calculateAddress()
}
class Fine {
  #String status
  -Date price
  +setScore()
  +findName()
  +createDuration()
  +processAddress()
}
class Librarian {
  +Date type
  +boolean status
  -double duration
  -Date note
  #Date updatedAt
  +validateCode()
}
class Member {
  -float active
  +Date type
  #long note
  #int address
  +findDescription()
  +calculateCreatedat()
  +saveName()
  +deleteScore()
}
abstract class Loan {
  +Date score
  #boolean code
  -Date phone
  -double type
  +long id
  +calculateCode()
  +deleteScore()
  +cancelAddress()
}
Fine --o Loan
Fine --|> Librarian
Librarian --* Author
Fine --* Member
Member --> Book : "1..*"
@enduml