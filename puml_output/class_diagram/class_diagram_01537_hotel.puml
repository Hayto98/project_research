@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Room {
  #int level
  #int note
  +long active
  +sendActive()
  +deleteNote()
  +createDuration()
  +findNote()
}
interface Payment {
  -float quantity
  #double level
  +long email
  -boolean score
  +deleteLevel()
  +createLevel()
}
abstract class Booking {
  +boolean price
  +double amount
  -String address
  +cancelEmail()
  +cancelDuration()
  +saveDescription()
}
class Invoice {
  #boolean phone
  -int duration
  +long total
  #long type
  +saveDuration()
  +setActive()
  +updatePhone()
}
interface Restaurant {
  -double active
  +long id
  -String type
  -long total
  #long note
  +processNote()
  +getId()
  +sendId()
}
Room ..|> Booking
Payment ..> Booking : "1"
Restaurant --* Booking
@enduml