@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
abstract class Attendance {
  +double address
  +boolean note
  +Date duration
  +processStatus()
  +saveAmount()
}
class Teacher {
  -double updatedAt
  #Date amount
  +updateName()
  +findPrice()
}
class Exam {
  +Date id
  -double createdAt
  +findNote()
}
class Schedule {
  #boolean status
  #int code
  +int quantity
  +saveScore()
  +processPrice()
}
class Book {
  -long price
  -long code
  #boolean active
  +findDuration()
  +calculateId()
}
interface Classroom {
  +Date price
  #boolean status
  +validateQuantity()
  +createNote()
  +saveCode()
}
interface Assignment {
  #Date name
  -float amount
  #String createdAt
  +setCreatedat()
  +sendDescription()
  +setActive()
}
Schedule ..|> Assignment
Teacher --o Book
Exam ..> Schedule : "1"
Classroom --* Schedule
@enduml