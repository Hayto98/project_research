@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
interface Customer {
  -String duration
  #long updatedAt
  -Date description
  +processPrice()
  +processQuantity()
  +findStatus()
  +cancelDuration()
}
abstract class Supplier {
  +String quantity
  -String type
  +calculateUpdatedat()
  +calculatePrice()
  +processCode()
}
interface Payment {
  -long total
  #int phone
  #int price
  -float note
  +cancelLevel()
  +processAddress()
}
class Return {
  +long address
  +int id
  #double level
  -Date quantity
  +sendEmail()
  +validateStatus()
}
interface Shipment {
  #Date description
  #int duration
  #String price
  +calculateId()
  +sendCreatedat()
  +saveId()
}
abstract class Category {
  +double type
  +int amount
  -String description
  +setDescription()
}
class Invoice {
  +long id
  #String description
  #String updatedAt
  #float code
  -long createdAt
  +updateCode()
}
Customer --> Invoice : "0..1"
Category --* Return
Customer --|> Shipment
Category ..> Invoice : "*"
Return ..> Supplier : "1..*"
@enduml