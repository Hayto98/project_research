@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Cart {
  #double id
  -double duration
  -int status
  +boolean amount
  +String type
  +updateActive()
  +sendLevel()
  +processDescription()
  +getAmount()
}
class Customer {
  #long amount
  +float phone
  -long code
  -long note
  +updateType()
  +deleteStatus()
  +saveCode()
}
interface Supplier {
  +String id
  #float description
  #double score
  +cancelCreatedat()
  +calculateDescription()
}
class Review {
  +double type
  -boolean phone
  +String name
  +double createdAt
  -float amount
  +setTotal()
}
Supplier ..|> Cart
Review ..> Supplier : "*"
@enduml