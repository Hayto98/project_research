@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Category {
  -String createdAt
  #int address
  -double duration
  #int id
  -Date updatedAt
  +processPhone()
  +setScore()
  +createNote()
}
abstract class Warehouse {
  -float address
  +boolean score
  +saveTotal()
}
abstract class Payment {
  -String id
  -boolean description
  +long score
  #float price
  +createDuration()
}
class Cart {
  -String name
  -boolean description
  -long active
  +validateAddress()
  +updateAddress()
  +createCode()
}
Cart --* Warehouse
Category --o Cart
note right of Category : Ecommerce domain
@enduml