@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Category {
  -String createdAt
  #int address
  -double duration
  #int id
  -Date updatedAt
  +cancelCode()
  +findTotal()
  +processStatus()
}
class Warehouse {
  -Date note
  #double price
  +boolean score
  #String code
  +sendUpdatedat()
  +deleteDuration()
  +setAddress()
  +deleteCreatedat()
}
class Payment {
  +double score
  #int price
  -boolean total
  +findCreatedat()
}
interface Cart {
  -String description
  -boolean name
  -long duration
  #long active
  +getStatus()
  +createActive()
  +createScore()
}
Payment --|> Category
Cart --* Warehouse
Category --o Cart
@enduml