@startuml

abstract class Like {
  +int duration
  +Date level
  +long id
  +String updatedAt
  -Date createdAt
  +calculateActive()
  +calculateAddress()
  +deleteTotal()
}
abstract class Notification {
  -long code
  +Date total
  +String duration
  +findStatus()
}
class Album {
  #float description
  +int amount
  +float note
  -Date price
  +setPhone()
  +createQuantity()
  +updatePrice()
}
interface User {
  +long price
  -String phone
  #boolean status
  +int id
  -boolean updatedAt
  +setUpdatedat()
  +updateId()
  +calculatePrice()
  +cancelPrice()
}
class Profile {
  #Date description
  -boolean quantity
  #double createdAt
  #boolean status
  -float id
  +validateType()
  +saveType()
  +deleteCreatedat()
}
abstract class Report {
  -boolean level
  -long address
  #double quantity
  +long createdAt
  +calculateDescription()
  +processScore()
}
class Follower {
  +float type
  -long address
  +saveActive()
  +findQuantity()
}
Profile ..> Report : "0..1"
Album --> Like : "0..1"
Album ..|> Follower
Report --* Follower
@enduml