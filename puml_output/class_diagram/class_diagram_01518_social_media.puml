@startuml

abstract class Like {
  +int duration
  +Date level
  +long id
  +String updatedAt
  -Date createdAt
  +sendAmount()
  +processDescription()
  +setTotal()
}
class Notification {
  +Date quantity
  #long createdAt
  #long name
  +float code
  +processLevel()
  +saveDuration()
}
abstract class Album {
  #long updatedAt
  #long status
  +boolean quantity
  +calculatePhone()
  +setId()
  +cancelDuration()
  +updateCreatedat()
}
class User {
  +double code
  #boolean score
  #double level
  +Date name
  +processDescription()
  +createCreatedat()
}
interface Profile {
  #Date duration
  -boolean id
  +cancelActive()
  +processQuantity()
  +createNote()
  +findEmail()
}
interface Report {
  #double quantity
  -Date level
  -String createdAt
  -int total
  +setType()
}
class Follower {
  #long phone
  #long address
  #Date updatedAt
  +validateId()
  +cancelUpdatedat()
}
Album ..> Notification : "1..*"
Report ..> Notification : "0..1"
Follower --* User
Report ..|> User
note right of Like : Social Media domain
@enduml