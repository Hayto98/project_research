@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Follower {
  #String level
  -int createdAt
  +String phone
  +deleteNote()
  +calculateType()
  +createPhone()
}
abstract class Report {
  -int id
  -float code
  +String price
  +float address
  -long total
  +cancelCreatedat()
  +deleteAddress()
  +cancelAddress()
  +cancelAmount()
}
abstract class Group {
  -float description
  -String status
  +long price
  -Date level
  -int name
  +getUpdatedat()
  +getUpdatedat()
  +updateQuantity()
  +setId()
}
abstract class Comment {
  -int duration
  #Date email
  +String createdAt
  +validateAddress()
  +processPhone()
  +createDescription()
  +setTotal()
}
Group --> Report : "0..1"
Report --|> Follower
note right of Follower : Social Media domain
@enduml