@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Follower {
  #String level
  -int createdAt
  +String phone
  +getStatus()
  +validateCreatedat()
  +validateType()
}
abstract class Report {
  +String type
  -Date quantity
  -boolean phone
  #Date price
  -double active
  +createQuantity()
  +setQuantity()
}
class Group {
  -float createdAt
  -boolean total
  +setType()
  +validateDuration()
}
interface Comment {
  +String duration
  #double amount
  +String type
  -float score
  +findNote()
  +createCreatedat()
  +calculatePhone()
}
Comment --> Follower : "*"
Follower ..> Group : "0..1"
Follower ..|> Comment
@enduml