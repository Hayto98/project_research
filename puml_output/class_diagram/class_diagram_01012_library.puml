@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Catalog {
  +Date address
  -float note
  #int type
  #long name
  #int status
  +validateScore()
}
abstract class Reservation {
  +double score
  +String price
  #int name
  #boolean amount
  #int type
  +processActive()
  +deleteName()
  +getUpdatedat()
  +processActive()
}
class Branch {
  +Date level
  #boolean updatedAt
  -int status
  #double note
  +deleteActive()
}
class Librarian {
  +double id
  -long createdAt
  -int total
  #Date score
  +sendAmount()
  +findTotal()
  +findQuantity()
}
abstract class Fine {
  #int email
  +int name
  -Date updatedAt
  #long quantity
  -boolean createdAt
  +createNote()
  +updateEmail()
}
Fine --* Reservation
note right of Catalog : Library domain
@enduml