@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Catalog {
  +Date address
  -float note
  #int type
  #long name
  #int status
  +validateScore()
}
interface Reservation {
  #int active
  #float total
  #double score
  +double price
  +String name
  +findName()
  +getQuantity()
}
class Branch {
  +double type
  #float active
  +long amount
  #Date name
  +float level
  +sendCode()
}
class Librarian {
  #long description
  #boolean score
  -String type
  +double status
  #double duration
  +updateEmail()
  +getStatus()
}
class Fine {
  #double email
  #long description
  #float quantity
  -double amount
  +processCreatedat()
  +savePhone()
  +sendNote()
}
Branch --> Reservation : "0..1"
Reservation --o Fine
Fine --o Branch
Fine --* Reservation
@enduml