@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
interface Schedule {
  -float amount
  #boolean address
  -String status
  -float email
  -String createdAt
  +findName()
}
abstract class Enrollment {
  +double createdAt
  +double score
  -String id
  +long description
  +int active
  +deleteCreatedat()
}
class Exam {
  #double description
  -Date email
  #int type
  +processActive()
  +deleteStatus()
  +calculateTotal()
}
class Teacher {
  -Date note
  #boolean phone
  #String status
  #String type
  #double active
  +createDuration()
  +createNote()
  +getCode()
}
class Classroom {
  -boolean address
  -float amount
  +createPhone()
}
class Book {
  +double price
  #int id
  +float phone
  +updateCreatedat()
  +processPrice()
}
class Course {
  -String quantity
  -long phone
  -boolean amount
  +cancelPrice()
  +cancelScore()
}
Schedule --|> Enrollment
Classroom --> Book : "*"
@enduml