@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
interface Schedule {
  -float amount
  #boolean address
  -String status
  -float email
  -String createdAt
  +cancelTotal()
}
abstract class Enrollment {
  #int duration
  +float score
  +double id
  +calculatePrice()
}
class Exam {
  +float phone
  +long code
  +saveUpdatedat()
  +deleteEmail()
}
abstract class Teacher {
  #String total
  -Date score
  #double description
  -String phone
  -double createdAt
  +saveActive()
  +cancelId()
  +findName()
}
interface Classroom {
  +long phone
  #long price
  +String amount
  +int name
  -String address
  +getTotal()
  +cancelCreatedat()
  +getDescription()
}
class Book {
  +long amount
  +double quantity
  -double phone
  +saveId()
  +getUpdatedat()
}
class Course {
  #Date phone
  -long active
  #String total
  #double address
  #long name
  +saveActive()
  +createActive()
}
