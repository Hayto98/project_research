@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
abstract class MedicalRecord {
  #boolean address
  -boolean quantity
  -String price
  -double id
  +cancelAddress()
}
class Prescription {
  #long name
  +boolean amount
  #long email
  +Date total
  #Date phone
  +processName()
  +calculateScore()
  +validateAmount()
  +createLevel()
}
abstract class Doctor {
  +float active
  +Date description
  -String id
  +processNote()
  +getName()
  +deleteLevel()
  +validateTotal()
}
class LabTest {
  #int id
  -String level
  +processDuration()
  +updateEmail()
  +processQuantity()
}
class Nurse {
  +Date code
  #double status
  #boolean email
  #Date type
  +getQuantity()
  +cancelId()
  +getActive()
}
Nurse ..> LabTest : "*"
Nurse --|> MedicalRecord
Prescription --* LabTest
@enduml