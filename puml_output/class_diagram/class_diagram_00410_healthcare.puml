@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
abstract class MedicalRecord {
  #boolean address
  -boolean quantity
  -String price
  -double id
  +createPhone()
}
interface Prescription {
  #long name
  +boolean amount
  #long email
  +Date total
  #Date phone
  +getEmail()
  +createPrice()
  +updateActive()
  +deleteDuration()
}
class Doctor {
  -Date name
  #String address
  +float duration
  +cancelDuration()
}
class LabTest {
  +int code
  #long address
  +String updatedAt
  -Date total
  +getDuration()
  +calculateLevel()
  +cancelDuration()
  +saveEmail()
}
interface Nurse {
  #String total
  +float level
  +float price
  -float duration
  +cancelActive()
  +processPrice()
  +setPhone()
}
Prescription --o MedicalRecord
Doctor --* LabTest
note right of MedicalRecord : Healthcare domain
@enduml