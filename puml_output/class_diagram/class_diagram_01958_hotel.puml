@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
interface Reservation {
  -double code
  #boolean quantity
  +saveId()
  +validateCode()
  +setCreatedat()
  +calculatePrice()
}
interface Housekeeping {
  #long name
  +long note
  +findName()
  +createId()
}
class Amenity {
  +int duration
  -String code
  +updateName()
  +createEmail()
}
class Room {
  -String description
  +double updatedAt
  +createDescription()
}
Reservation --> Housekeeping : "*"
Housekeeping --* Room
Housekeeping --* Reservation
note right of Reservation : Hotel domain
@enduml