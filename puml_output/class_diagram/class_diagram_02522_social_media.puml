@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Like {
  #String code
  +int description
  #int price
  +setEmail()
}
interface Report {
  +double createdAt
  -String updatedAt
  +getAddress()
  +processTotal()
}
class Album {
  #float createdAt
  -int description
  #double updatedAt
  +float price
  +String active
  +processId()
}
abstract class Hashtag {
  #float email
  -float price
  #Date code
  +double active
  #long phone
  +cancelPrice()
}
interface Profile {
  #boolean active
  +Date status
  +double note
  +processId()
  +createAmount()
  +calculateCreatedat()
  +validateAddress()
}
abstract class User {
  -boolean score
  -double code
  -int total
  #float name
  +long id
  +validateQuantity()
}
Report ..|> Profile
User ..> Report : "1"
Hashtag --> Album : "1"
note right of Like : Social Media domain
@enduml