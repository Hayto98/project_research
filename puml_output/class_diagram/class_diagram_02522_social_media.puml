@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Like {
  #String code
  +int description
  #int price
  +processCreatedat()
}
class Report {
  +double score
  -String status
  +String createdAt
  -double updatedAt
  +updatePrice()
  +findAmount()
  +calculateNote()
  +validateCode()
}
class Album {
  +String price
  +double email
  +double description
  -Date duration
  -Date amount
  +cancelStatus()
  +findDuration()
  +findCode()
  +processId()
}
class Hashtag {
  #Date note
  #float level
  +boolean quantity
  +getCode()
  +calculateType()
  +updateStatus()
  +findPrice()
}
class Profile {
  -double level
  +long active
  +double name
  +long amount
  #Date type
  +deleteStatus()
  +validateName()
  +setNote()
}
interface User {
  +long total
  #double name
  +updateEmail()
  +updateDescription()
  +validateActive()
  +sendStatus()
}
Album --* Like
User ..|> Album
@enduml