@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
interface MedicalRecord {
  #Date description
  +long type
  +getDuration()
  +deleteNote()
  +findPhone()
}
class Insurance {
  -boolean id
  -boolean note
  +double code
  +int name
  +calculatePhone()
  +createActive()
}
class Billing {
  #Date score
  +float amount
  #long status
  #double updatedAt
  +int name
  +calculateAmount()
  +setActive()
  +cancelType()
  +updateAddress()
}
class Treatment {
  +double name
  -String duration
  +String phone
  +processAddress()
  +updatePrice()
}
interface Hospital {
  +String total
  -String level
  -long name
  #Date active
  +double status
  +createStatus()
  +getType()
}
class Ward {
  #float note
  +boolean address
  -int createdAt
  -float code
  #String description
  +calculatePrice()
  +cancelAddress()
  +setType()
  +getAddress()
}
class Patient {
  +long total
  +Date email
  +deleteDescription()
  +setDescription()
  +calculateDuration()
  +calculateDescription()
}
Treatment --|> Insurance
Treatment --> Hospital : "1"
MedicalRecord ..|> Hospital
@enduml