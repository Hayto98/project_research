@startuml

class Comment {
  #float level
  #float address
  +getScore()
  +updateNote()
  +findCode()
}
interface Profile {
  #Date code
  -long id
  +createQuantity()
}
interface Notification {
  -float address
  -Date note
  +Date duration
  -long id
  #float quantity
  +deleteLevel()
  +calculateCode()
  +setQuantity()
  +validateType()
}
class Group {
  -String note
  -float price
  +boolean code
  #String status
  +calculateScore()
  +cancelPhone()
  +deleteTotal()
}
Comment --|> Group
Group --o Notification
@enduml