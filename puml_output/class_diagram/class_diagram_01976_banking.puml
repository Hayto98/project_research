@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Withdrawal {
  -long amount
  +float type
  +setPrice()
  +updateActive()
  +saveScore()
  +sendTotal()
}
abstract class Statement {
  -String description
  #long updatedAt
  +long id
  +long type
  +findDescription()
}
class Customer {
  #long description
  #double type
  -long status
  +Date note
  -float total
  +validateAmount()
  +deleteName()
}
class Interest {
  -double updatedAt
  +float phone
  +sendAddress()
}
class Teller {
  -String description
  -float code
  +boolean id
  -float total
  -double price
  +setLevel()
  +calculateUpdatedat()
}
class Transfer {
  #int name
  -float email
  +int id
  +saveAddress()
}
abstract class Loan {
  +int score
  +Date updatedAt
  +float note
  #int name
  +validateCreatedat()
}
Withdrawal --* Interest
Interest ..> Customer : "0..1"
Interest --o Withdrawal
Loan --o Interest
Loan --> Customer : "*"
Customer --|> Withdrawal
@enduml