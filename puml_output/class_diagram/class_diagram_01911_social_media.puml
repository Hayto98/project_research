@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Notification {
  +long email
  +long code
  +long id
  +setTotal()
  +cancelStatus()
}
class Album {
  -Date id
  +float phone
  -float email
  +long level
  +processScore()
  +validateQuantity()
  +deletePhone()
}
class Follower {
  +int score
  -int price
  #Date active
  +boolean total
  +int name
  +deleteNote()
  +updatePhone()
  +updateAddress()
}
class Like {
  -String name
  #long type
  +int createdAt
  +double total
  +cancelName()
  +processStatus()
}
interface Post {
  -long type
  -long id
  #int price
  -float code
  -int amount
  +updateAmount()
  +createActive()
}
Album --|> Follower
Post --> Like : "1"
Like --* Notification
note right of Notification : Social Media domain
@enduml