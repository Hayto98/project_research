@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Notification {
  +long email
  +long code
  +long id
  +setDescription()
  +processLevel()
}
interface Album {
  #String description
  -Date quantity
  +findCode()
  +getPhone()
  +deleteStatus()
}
class Follower {
  #long status
  #Date address
  -int phone
  -long type
  +sendAmount()
  +sendScore()
  +sendPrice()
  +findPrice()
}
abstract class Like {
  -int code
  #Date createdAt
  +deleteDescription()
}
class Post {
  +float address
  #long description
  +long note
  +validateAmount()
  +calculateLevel()
  +saveId()
}
Album --o Like
Notification ..|> Follower
Album --o Notification
@enduml