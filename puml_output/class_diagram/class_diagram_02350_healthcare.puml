@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class MedicalRecord {
  #long quantity
  -float duration
  +saveTotal()
  +findId()
  +findActive()
  +setAmount()
}
interface Nurse {
  +Date level
  #long total
  -boolean duration
  +calculateActive()
  +cancelDescription()
}
class Prescription {
  -boolean active
  #String name
  +int description
  +double amount
  +validatePrice()
  +createCode()
  +saveDescription()
  +saveTotal()
}
abstract class Ward {
  +boolean phone
  +long level
  #String total
  +validatePhone()
  +createDuration()
  +findPhone()
}
abstract class Treatment {
  #float email
  -long phone
  +Date amount
  +createId()
  +deleteStatus()
}
Ward --o Nurse
MedicalRecord --* Nurse
@enduml