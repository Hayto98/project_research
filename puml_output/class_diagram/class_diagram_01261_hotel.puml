@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
abstract class Restaurant {
  #String description
  -double address
  +validateStatus()
}
class Service {
  -String amount
  -double id
  +updatePrice()
  +setId()
  +validateLevel()
}
class Payment {
  -String duration
  +float email
  #boolean description
  #double updatedAt
  -double active
  +createPrice()
  +setId()
  +updateAmount()
  +getTotal()
}
class Staff {
  #double type
  #long score
  +getName()
}
Staff --> Restaurant : "1..*"
Payment ..|> Staff
@enduml