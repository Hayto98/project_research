@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Coupon {
  #int total
  #float code
  +processLevel()
}
class Wishlist {
  -Date address
  #long score
  -long total
  +getId()
  +cancelPrice()
  +findPhone()
  +findDescription()
}
abstract class Cart {
  +String score
  -String description
  -Date name
  #float email
  +updateAddress()
  +cancelId()
  +setLevel()
}
interface Warehouse {
  #double level
  +String phone
  #boolean createdAt
  #float note
  +updateCode()
  +cancelDescription()
}
class Category {
  -double description
  +long createdAt
  +sendLevel()
  +deleteDescription()
  +cancelType()
  +updateId()
}
Category ..|> Warehouse
Coupon --> Category : "0..1"
@enduml