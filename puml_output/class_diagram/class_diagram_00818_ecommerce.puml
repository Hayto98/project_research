@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Coupon {
  #int total
  #float code
  +calculateAmount()
}
class Wishlist {
  -long score
  -double total
  #int quantity
  #float phone
  +saveQuantity()
  +sendDescription()
  +getEmail()
  +deleteStatus()
}
abstract class Cart {
  -Date email
  -int score
  +cancelPhone()
  +updateNote()
  +cancelNote()
}
class Warehouse {
  #float active
  +float duration
  +sendStatus()
  +deleteCreatedat()
  +validatePrice()
}
class Category {
  +String note
  #int id
  +int duration
  -boolean updatedAt
  +saveType()
  +setPrice()
  +createPrice()
  +sendScore()
}
Wishlist --|> Warehouse
Category --o Warehouse
note right of Coupon : Ecommerce domain
@enduml