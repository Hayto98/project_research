@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
abstract class Insurance {
  -int amount
  +Date createdAt
  +long phone
  -Date description
  +updateEmail()
}
abstract class Treatment {
  +String price
  +int description
  #float quantity
  #Date name
  #Date amount
  +cancelCreatedat()
}
class Billing {
  +double id
  #Date name
  #int total
  +sendLevel()
}
class Doctor {
  -boolean note
  #Date level
  +Date address
  #double type
  #double active
  +setTotal()
}
class Diagnosis {
  -String email
  -double note
  -Date price
  +Date score
  +calculateUpdatedat()
  +getAmount()
  +validateScore()
  +calculateQuantity()
}
Treatment --o Insurance
Billing ..> Diagnosis : "*"
Doctor --* Billing
@enduml