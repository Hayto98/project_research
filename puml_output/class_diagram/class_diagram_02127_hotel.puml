@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
abstract class Booking {
  #double amount
  +int description
  -double score
  #String quantity
  -long email
  +cancelLevel()
  +sendId()
  +deleteType()
}
abstract class Staff {
  #Date duration
  +String price
  #Date quantity
  #String address
  +saveEmail()
  +setNote()
  +cancelQuantity()
}
interface Room {
  -int code
  +long id
  +boolean amount
  +long type
  #double active
  +saveId()
  +sendName()
  +processLevel()
  +createPrice()
}
class CheckOut {
  +float quantity
  #Date amount
  +float type
  +processDescription()
}
class CheckIn {
  +long active
  -long name
  +String quantity
  +setDuration()
}
class Reservation {
  #String total
  +String active
  +setDuration()
}
CheckIn --* Reservation
Reservation --o CheckIn
CheckOut ..|> Booking
@enduml