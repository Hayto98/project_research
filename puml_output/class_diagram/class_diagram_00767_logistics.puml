@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Package {
  #int description
  -float code
  +float price
  -int id
  +cancelPhone()
  +sendUpdatedat()
  +saveNote()
}
class Inventory {
  +double duration
  #Date price
  #double address
  #long email
  +findEmail()
  +saveNote()
  +findTotal()
}
class Shipment {
  #boolean note
  #long updatedAt
  +String level
  +saveTotal()
  +calculateStatus()
}
class FuelLog {
  -double description
  +int amount
  +long score
  +setEmail()
  +cancelAddress()
  +setTotal()
}
abstract class Warehouse {
  +boolean amount
  #String createdAt
  -String description
  +calculateId()
  +processAmount()
  +deleteCode()
}
class Manifest {
  #int createdAt
  +double name
  #double type
  +createAddress()
  +cancelLevel()
}
class Driver {
  -int id
  #int total
  +processUpdatedat()
  +setUpdatedat()
  +cancelDescription()
  +cancelAddress()
}
FuelLog --* Manifest
Manifest ..> FuelLog : "0..1"
Inventory --> FuelLog : "1..*"
Manifest ..|> Shipment
Warehouse ..> Driver : "*"
@enduml