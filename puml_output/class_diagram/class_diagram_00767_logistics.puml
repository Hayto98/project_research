@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Package {
  #int description
  -float code
  +float price
  -int id
  +createCreatedat()
  +validateLevel()
  +findEmail()
}
interface Inventory {
  #long address
  -int email
  +int description
  -int price
  +float type
  +getCode()
  +findCreatedat()
  +findStatus()
}
class Shipment {
  -int amount
  +int score
  -long type
  +createQuantity()
  +savePrice()
  +findDescription()
}
class FuelLog {
  +double description
  +long status
  +String active
  +createActive()
  +deleteCreatedat()
  +getType()
}
class Warehouse {
  +long price
  +String note
  -long createdAt
  +sendUpdatedat()
  +processAmount()
}
class Manifest {
  #int type
  +double total
  #long quantity
  #long price
  +sendDuration()
  +saveType()
}
class Driver {
  #String updatedAt
  +String email
  -double price
  -int type
  +sendActive()
}
Inventory --* FuelLog
Manifest ..|> Driver
note right of Package : Logistics domain
@enduml