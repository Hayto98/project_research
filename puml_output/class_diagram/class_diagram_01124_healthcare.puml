@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
abstract class Prescription {
  -float quantity
  -float score
  +float address
  +long note
  #String active
  +saveUpdatedat()
  +deletePhone()
  +findDescription()
}
interface Patient {
  -double createdAt
  #int quantity
  #Date total
  #float id
  +boolean email
  +validateCode()
  +calculateLevel()
  +sendTotal()
  +createAddress()
}
class LabTest {
  -long phone
  -long address
  #boolean quantity
  #boolean total
  -float code
  +cancelDuration()
  +cancelQuantity()
  +findStatus()
}
class Treatment {
  -Date score
  +Date name
  #int createdAt
  +double duration
  #double active
  +sendId()
  +saveCode()
  +createScore()
  +validateId()
}
class Billing {
  -Date createdAt
  #int email
  +findCode()
  +processName()
  +processEmail()
}
interface Hospital {
  +Date level
  +Date phone
  #double note
  #float id
  +getScore()
  +cancelTotal()
  +cancelName()
}
class Doctor {
  -long quantity
  +String amount
  +validateAddress()
  +cancelAddress()
}
Prescription --o Hospital
Hospital --o Billing
note right of Prescription : Healthcare domain
@enduml