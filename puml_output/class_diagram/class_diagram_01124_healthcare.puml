@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
abstract class Prescription {
  -float quantity
  -float score
  +float address
  +long note
  #String active
  +deleteStatus()
  +findAddress()
  +processAddress()
}
class Patient {
  +boolean description
  -double level
  #float active
  +long type
  +findAmount()
  +setQuantity()
  +sendActive()
  +cancelNote()
}
interface LabTest {
  -String level
  -float type
  +sendAddress()
  +findQuantity()
  +getDescription()
  +setLevel()
}
abstract class Treatment {
  -long address
  -long quantity
  #boolean total
  #boolean code
  +updateCode()
  +validateScore()
  +getQuantity()
}
interface Billing {
  #float status
  +float address
  +int total
  -Date name
  +sendDuration()
  +processPhone()
}
class Hospital {
  -boolean type
  +float duration
  +findScore()
}
interface Doctor {
  -long id
  #boolean description
  +Date code
  -Date createdAt
  +validateName()
}
Treatment --> LabTest : "1..*"
Hospital --* Billing
@enduml