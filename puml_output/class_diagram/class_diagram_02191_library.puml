@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
abstract class Reservation {
  +Date status
  -String score
  +int id
  +long level
  #int phone
  +validateTotal()
  +setPrice()
  +validateId()
}
class Author {
  #long id
  -Date phone
  -String description
  +String level
  +setTotal()
  +calculateName()
  +createPrice()
}
abstract class Publisher {
  #int status
  #float createdAt
  +double address
  #int total
  #Date code
  +sendDuration()
  +cancelCreatedat()
  +findType()
  +getPrice()
}
class Book {
  #boolean createdAt
  +long description
  +getActive()
  +processEmail()
  +sendPhone()
}
interface Member {
  -float code
  +Date quantity
  +saveCode()
}
class Branch {
  #boolean type
  #double duration
  +double amount
  +double score
  +processDescription()
  +calculateCreatedat()
}
Book --|> Publisher
Publisher --|> Reservation
Publisher --* Author
note right of Reservation : Library domain
@enduml