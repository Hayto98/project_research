@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
abstract class Reservation {
  +Date status
  -String score
  +int id
  +long level
  #int phone
  +cancelId()
  +cancelCreatedat()
  +setStatus()
}
abstract class Author {
  #float id
  #long createdAt
  +long address
  #long duration
  +cancelPrice()
  +cancelCreatedat()
  +cancelStatus()
}
class Publisher {
  -float phone
  -String code
  +sendScore()
  +deleteAmount()
  +saveCode()
}
class Book {
  #int address
  #float total
  +double code
  +processId()
  +cancelDuration()
}
abstract class Member {
  -Date type
  +Date id
  +int price
  +updateLevel()
  +calculateCreatedat()
}
class Branch {
  +long email
  -float active
  +Date phone
  +Date level
  +int name
  +deleteActive()
  +getId()
  +processNote()
}
Branch ..> Author : "*"
Author --|> Book
Book --o Author
@enduml