@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Guest {
  +double email
  +int description
  +double code
  +deleteQuantity()
  +deleteAmount()
}
interface Payment {
  +boolean address
  #String score
  +cancelCode()
}
class CheckOut {
  #String type
  -double code
  #String email
  #int quantity
  +getName()
  +updateUpdatedat()
}
interface CheckIn {
  #Date score
  -float level
  #float status
  +float name
  #Date duration
  +createPrice()
  +processStatus()
  +createStatus()
  +validateType()
}
Guest --|> Payment
CheckOut --o Guest
CheckIn --* Guest
@enduml