@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
abstract class Order {
  #int price
  +boolean createdAt
  +findAmount()
}
class Customer {
  -boolean price
  -long id
  +Date code
  +boolean score
  +getLevel()
}
class Wishlist {
  #double total
  #long price
  #int score
  +calculateEmail()
  +setLevel()
  +deleteLevel()
}
class Category {
  -double status
  #double id
  -int address
  #double updatedAt
  #Date name
  +cancelEmail()
  +sendAddress()
}
class Coupon {
  -String address
  +String type
  #int note
  +getType()
  +validatePrice()
  +calculateDuration()
}
class Review {
  #String score
  +long quantity
  #boolean id
  -double amount
  +processAmount()
}
Review ..|> Coupon
Customer --> Coupon : "1..*"
Wishlist ..> Order : "0..1"
Wishlist ..|> Category
@enduml