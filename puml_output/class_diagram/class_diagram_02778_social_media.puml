@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Profile {
  -boolean phone
  -int email
  +float status
  #long name
  #String price
  +getUpdatedat()
  +createScore()
  +calculateQuantity()
}
class Post {
  -boolean total
  #float score
  -float phone
  -double note
  -long createdAt
  +createUpdatedat()
  +setEmail()
  +findAmount()
}
interface Report {
  #int score
  #boolean type
  #int address
  -String duration
  +Date createdAt
  +createId()
  +createStatus()
  +deleteNote()
  +processPhone()
}
class Comment {
  #float updatedAt
  +float quantity
  +double address
  +createStatus()
}
Report --> Post : "1"
Report --|> Comment
Profile ..> Report : "1..*"
note right of Profile : Social Media domain
@enduml