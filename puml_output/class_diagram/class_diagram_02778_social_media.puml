@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Profile {
  -boolean phone
  -int email
  +float status
  #long name
  #String price
  +updatePrice()
  +processPrice()
  +getNote()
}
interface Post {
  -float quantity
  #Date code
  #int type
  -boolean total
  #float phone
  +setQuantity()
  +saveStatus()
  +setEmail()
  +saveAmount()
}
class Report {
  -Date quantity
  #float duration
  +boolean updatedAt
  -boolean status
  +findQuantity()
  +setEmail()
  +getAmount()
  +sendEmail()
}
class Comment {
  #double quantity
  -String id
  -String updatedAt
  +cancelDescription()
  +processTotal()
}
Report ..|> Comment
Post --* Profile
@enduml