@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Beneficiary {
  +Date email
  +double code
  +createPhone()
  +sendActive()
  +getCreatedat()
  +createType()
}
class Loan {
  +int type
  #double note
  #boolean amount
  +processLevel()
  +findActive()
}
class Teller {
  -double name
  +String price
  +saveDuration()
  +findStatus()
}
class Transfer {
  +String quantity
  #Date name
  +saveAmount()
  +calculateEmail()
  +findTotal()
}
abstract class Deposit {
  -double phone
  -boolean id
  +Date level
  -double type
  -Date active
  +validatePrice()
  +getActive()
  +calculateDuration()
}
abstract class Interest {
  #double price
  #float amount
  -boolean description
  +saveAmount()
}
Beneficiary --* Deposit
Interest --o Beneficiary
Transfer ..|> Interest
@enduml