@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
abstract class Transaction {
  -float total
  #Date level
  #String phone
  #String amount
  +cancelLevel()
  +updateDuration()
  +calculateAddress()
}
abstract class Statement {
  #int quantity
  +Date address
  #int type
  +Date amount
  +sendQuantity()
  +updateActive()
  +saveNote()
  +calculateCode()
}
abstract class Loan {
  #int active
  -int price
  +double total
  +Date phone
  #boolean createdAt
  +createLevel()
}
interface Beneficiary {
  +double description
  -int note
  -double score
  #float level
  +findPhone()
  +updateDuration()
}
Beneficiary --> Transaction : "0..1"
Statement --o Beneficiary
@enduml