@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
abstract class Transaction {
  -float total
  #Date level
  #String phone
  #String amount
  +getAmount()
  +processAddress()
  +findQuantity()
}
class Statement {
  #float amount
  -boolean createdAt
  +int duration
  +double updatedAt
  -boolean name
  +sendPrice()
  +calculateDuration()
  +validateCreatedat()
  +sendDescription()
}
class Loan {
  #float amount
  #boolean total
  +Date createdAt
  +deleteNote()
  +cancelScore()
  +processStatus()
}
abstract class Beneficiary {
  +String amount
  +float phone
  #boolean type
  #Date description
  +getScore()
  +updateCreatedat()
  +calculatePrice()
  +findCreatedat()
}
Loan ..> Transaction : "0..1"
Statement --* Transaction
note right of Transaction : Banking domain
@enduml