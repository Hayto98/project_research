@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Vehicle {
  #float amount
  #String level
  #long name
  #int duration
  -int id
  +deletePrice()
}
class Depot {
  -boolean updatedAt
  -double quantity
  #String status
  #float total
  -String id
  +validateAmount()
  +getType()
}
class FuelLog {
  #String code
  +long address
  +boolean id
  #int description
  +getActive()
}
interface Manifest {
  +boolean phone
  -double createdAt
  -boolean email
  +calculateQuantity()
  +updateAddress()
  +findUpdatedat()
  +cancelName()
}
FuelLog --> Vehicle : "0..1"
Manifest --o Depot
Vehicle ..> FuelLog : "*"
note right of Vehicle : Logistics domain
@enduml