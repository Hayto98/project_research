@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Vehicle {
  #float amount
  #String level
  #long name
  #int duration
  -int id
  +validateCreatedat()
}
abstract class Depot {
  #Date total
  -String updatedAt
  +getActive()
  +setQuantity()
  +cancelType()
  +updateDuration()
}
abstract class FuelLog {
  +Date price
  +long id
  +String active
  -float total
  +createType()
}
class Manifest {
  #int address
  #String id
  +calculateScore()
}
Depot ..> FuelLog : "1"
Vehicle --> FuelLog : "0..1"
@enduml