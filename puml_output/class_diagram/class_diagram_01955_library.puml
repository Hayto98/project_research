@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
abstract class Branch {
  +long duration
  -String code
  +processNote()
  +createType()
}
class Loan {
  +Date id
  #String code
  +String phone
  -String price
  #double updatedAt
  +saveScore()
  +cancelTotal()
  +processAmount()
}
class Publisher {
  -Date price
  +long note
  -long status
  -boolean description
  #Date level
  +saveNote()
}
class Member {
  -Date address
  -double createdAt
  +double score
  #boolean amount
  -double total
  +deletePhone()
  +processPhone()
}
Loan --|> Branch
Publisher ..|> Branch
note right of Branch : Library domain
@enduml