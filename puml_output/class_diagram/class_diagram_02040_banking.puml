@startuml
skinparam shadowing true
interface Transaction {
  +int note
  -long total
  #float price
  +long active
  #double status
  +saveId()
}
class Branch {
  +double score
  #boolean name
  +float total
  #int address
  +double active
  +validateDescription()
  +validateQuantity()
}
interface Interest {
  -Date duration
  +int code
  +processEmail()
  +deleteAmount()
  +getId()
  +updateAmount()
}
interface Deposit {
  -long status
  #double level
  +createAddress()
  +createEmail()
  +validateEmail()
  +createLevel()
}
class Customer {
  +double amount
  +String level
  -long createdAt
  +boolean email
  +createAddress()
  +saveAmount()
  +cancelUpdatedat()
  +calculateType()
}
class Teller {
  #boolean active
  #double total
  +float createdAt
  -int name
  +float amount
  +saveNote()
  +processQuantity()
  +processActive()
}
abstract class Account {
  -double active
  +long email
  +cancelEmail()
  +setPhone()
  +findId()
  +validateEmail()
}
Teller ..> Deposit : "1..*"
Customer --|> Account
Account --> Deposit : "1"
Customer ..> Teller : "1..*"
Deposit ..|> Branch
Customer ..> Transaction : "1..*"
@enduml