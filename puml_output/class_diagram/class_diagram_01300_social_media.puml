@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Post {
  #float quantity
  -String score
  +findScore()
  +getActive()
  +validateCreatedat()
  +saveAddress()
}
class Like {
  #Date level
  +double amount
  +setCode()
}
interface Group {
  -Date score
  +String createdAt
  +String level
  +createActive()
  +getQuantity()
  +createAddress()
}
class Profile {
  +long score
  -int level
  #String email
  +setAddress()
  +saveNote()
  +cancelId()
}
class Hashtag {
  -long total
  #int status
  -String amount
  #String note
  +processId()
}
Post --|> Like
Hashtag --* Profile
Post --o Profile
Hashtag --|> Group
note right of Post : Social Media domain
@enduml