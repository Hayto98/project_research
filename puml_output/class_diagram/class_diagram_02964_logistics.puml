@startuml
skinparam monochrome true
abstract class Manifest {
  +long updatedAt
  -Date id
  +double note
  #double quantity
  -String name
  +getEmail()
  +updateNote()
}
class Package {
  +long code
  +String updatedAt
  +Date phone
  #double status
  +cancelAmount()
  +calculateEmail()
  +cancelLevel()
  +setName()
}
class Tracking {
  #String name
  +float code
  #double status
  +double price
  #Date description
  +cancelId()
  +getType()
  +processCode()
  +sendId()
}
abstract class Route {
  +Date active
  #int phone
  +int email
  +findPrice()
}
interface Depot {
  -double note
  +long total
  +sendScore()
}
Package ..|> Tracking
Depot --> Route : "1..*"
Tracking ..|> Depot
@enduml