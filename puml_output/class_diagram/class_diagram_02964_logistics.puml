@startuml
skinparam monochrome true
abstract class Manifest {
  +long updatedAt
  -Date id
  +double note
  #double quantity
  -String name
  +deleteActive()
  +getEmail()
}
class Package {
  +long level
  +String phone
  +Date status
  +saveDuration()
  +findNote()
  +sendName()
  +getUpdatedat()
}
abstract class Tracking {
  -Date code
  #Date status
  +cancelStatus()
  +getActive()
}
abstract class Route {
  -long total
  +String score
  +Date level
  +saveCreatedat()
  +sendPhone()
  +createDescription()
  +saveDescription()
}
class Depot {
  #Date id
  +double active
  #float level
  +calculateTotal()
  +deleteAddress()
  +findLevel()
  +setPrice()
}
Package ..|> Tracking
Depot --> Route : "1..*"
Tracking ..|> Depot
note right of Manifest : Logistics domain
@enduml