@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Attendance {
  -String active
  -String name
  -String status
  -int total
  +sendCreatedat()
  +processPrice()
  +processQuantity()
}
class Exam {
  +int description
  #float code
  +int score
  +cancelStatus()
  +createNote()
  +getName()
}
class Schedule {
  +long total
  #Date level
  -int type
  #boolean updatedAt
  #int email
  +findStatus()
  +validateUpdatedat()
}
class Student {
  +long createdAt
  #boolean score
  +findDuration()
}
Exam --> Schedule : "1..*"
Schedule --|> Student
@enduml