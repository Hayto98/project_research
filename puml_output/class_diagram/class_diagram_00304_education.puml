@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Attendance {
  -String active
  -String name
  -String status
  -int total
  +processUpdatedat()
  +getAmount()
  +updateDescription()
}
class Exam {
  -String description
  -double code
  -boolean createdAt
  +updateEmail()
  +getPhone()
  +cancelType()
  +deleteDuration()
}
interface Schedule {
  #boolean createdAt
  +int type
  #boolean code
  +createScore()
}
class Student {
  #float updatedAt
  +boolean phone
  +boolean quantity
  +validateTotal()
  +setId()
  +deleteNote()
  +updateId()
}
Student ..> Attendance : "*"
Student --> Exam : "*"
note right of Attendance : Education domain
@enduml