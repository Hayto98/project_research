@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Branch {
  -int phone
  -long status
  +double duration
  #Date type
  +saveAddress()
  +setDescription()
}
interface Fine {
  #int description
  +float quantity
  -String level
  -boolean updatedAt
  +int address
  +sendEmail()
  +calculateAmount()
  +deleteEmail()
}
class Author {
  +Date name
  #double amount
  +calculateTotal()
  +findId()
}
class Shelf {
  -double id
  +boolean name
  +sendStatus()
}
interface Catalog {
  -double id
  +float quantity
  #double total
  +processPrice()
}
interface Member {
  +Date quantity
  #String address
  +calculateActive()
  +processStatus()
  +deleteActive()
}
class Loan {
  +boolean email
  #float code
  -Date updatedAt
  -long createdAt
  -int total
  +saveScore()
  +setCreatedat()
  +createDuration()
  +updatePhone()
}
Branch ..|> Shelf
Catalog ..|> Author
Loan --|> Catalog
Member --* Shelf
Shelf ..> Member : "1"
note right of Branch : Library domain
@enduml