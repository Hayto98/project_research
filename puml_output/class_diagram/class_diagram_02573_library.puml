@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Branch {
  -int phone
  -long status
  +double duration
  #Date type
  +processAddress()
  +findTotal()
}
class Fine {
  -int description
  -long active
  +validateDuration()
  +calculateDuration()
}
class Author {
  -boolean price
  +int id
  +getCreatedat()
  +sendAddress()
  +getPhone()
}
class Shelf {
  +int email
  +Date amount
  #double status
  +sendStatus()
  +sendScore()
}
abstract class Catalog {
  +float id
  +long status
  +getName()
  +saveAddress()
  +createStatus()
  +cancelScore()
}
class Member {
  +long duration
  -long updatedAt
  +validateEmail()
  +getDescription()
  +setDuration()
  +processAddress()
}
interface Loan {
  -float code
  -String type
  #Date price
  +long active
  -float name
  +updateUpdatedat()
  +calculateAddress()
  +updateNote()
  +validateDuration()
}
Author --|> Member
Fine --o Loan
Branch ..> Catalog : "*"
Member --* Author
Loan ..|> Author
@enduml