@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Publisher {
  #String createdAt
  #long amount
  +cancelLevel()
  +updateId()
  +calculateEmail()
  +sendDuration()
}
interface Fine {
  #int amount
  -long price
  #double name
  +cancelScore()
  +getNote()
  +deleteQuantity()
  +createActive()
}
class Member {
  +Date active
  #String email
  +processEmail()
  +processName()
  +saveLevel()
}
class Reservation {
  -boolean updatedAt
  +double code
  #long description
  -float total
  #String name
  +deletePhone()
}
abstract class Loan {
  #float active
  -double code
  -int name
  #double type
  -boolean level
  +findDescription()
  +processUpdatedat()
  +getType()
}
class Catalog {
  -boolean type
  -Date phone
  +Date note
  +setPrice()
  +findId()
  +deleteCode()
  +createAddress()
}
interface Author {
  +long email
  -Date description
  -boolean id
  +float total
  +deletePrice()
  +sendCode()
  +validateLevel()
}
Member --o Catalog
Loan --> Publisher : "*"
Catalog ..|> Reservation
Reservation ..> Member : "*"
note right of Publisher : Library domain
@enduml