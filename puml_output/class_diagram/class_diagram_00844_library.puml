@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Publisher {
  #String createdAt
  #long amount
  +setAmount()
  +sendDescription()
  +findTotal()
  +findName()
}
interface Fine {
  #Date id
  #boolean total
  #int email
  +saveCode()
  +validateTotal()
}
class Member {
  #double email
  #Date phone
  #boolean type
  +saveAmount()
}
class Reservation {
  #long quantity
  +Date active
  #String amount
  -double status
  +deleteLevel()
  +validateUpdatedat()
  +getDuration()
}
class Loan {
  -String note
  -boolean updatedAt
  +double code
  #long description
  +deleteLevel()
  +validateLevel()
  +saveActive()
}
class Catalog {
  -double amount
  #String phone
  +findActive()
}
class Author {
  -boolean note
  -Date duration
  +double updatedAt
  +String total
  +createAddress()
  +validateCode()
  +setCreatedat()
  +findActive()
}
Reservation --> Author : "*"
Catalog ..> Publisher : "*"
Author --o Publisher
@enduml