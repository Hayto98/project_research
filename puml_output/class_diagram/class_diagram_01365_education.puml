@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Grade {
  -double total
  #int amount
  +findAmount()
  +setCreatedat()
}
interface Classroom {
  +float createdAt
  -double phone
  #long address
  +findStatus()
  +sendQuantity()
}
class Course {
  -double quantity
  #double price
  -Date type
  #String active
  +saveDescription()
  +updateAmount()
  +processEmail()
  +findNote()
}
abstract class Exam {
  #String duration
  +String level
  +int phone
  #int email
  -int note
  +validateType()
  +updatePhone()
}
class Assignment {
  +int id
  #float level
  +setPhone()
  +deleteName()
}
class Student {
  -int note
  -int type
  +double updatedAt
  +getLevel()
  +savePhone()
  +calculateScore()
}
interface Attendance {
  +int level
  #String id
  +double amount
  -Date code
  +cancelEmail()
}
Grade --|> Assignment
Attendance ..> Course : "*"
Student --|> Classroom
@enduml