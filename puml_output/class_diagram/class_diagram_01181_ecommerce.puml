@startuml
skinparam defaultFontSize 13
class Invoice {
  #long id
  #String active
  +setPhone()
  +saveId()
  +saveScore()
}
class Order {
  -boolean id
  -long status
  +cancelNote()
  +findId()
  +processAddress()
}
class Supplier {
  #float level
  -String id
  #long name
  -Date amount
  +getTotal()
  +updateTotal()
  +createCreatedat()
  +createDescription()
}
class Customer {
  #boolean score
  #double quantity
  +String total
  #int email
  +validateLevel()
}
class Product {
  #boolean createdAt
  #boolean type
  +validateId()
  +updateQuantity()
}
abstract class Shipment {
  +boolean address
  #long active
  +long name
  #boolean phone
  +calculateNote()
  +saveName()
}
Customer --|> Order
Order --> Product : "*"
Customer --|> Shipment
@enduml