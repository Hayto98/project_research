@startuml
skinparam defaultFontSize 13
class Invoice {
  #long id
  #String active
  +cancelName()
  +validateName()
  +cancelStatus()
}
class Order {
  -long email
  -int level
  +saveEmail()
  +cancelAddress()
}
interface Supplier {
  +float level
  #float name
  +getScore()
  +createPhone()
  +findPrice()
}
class Customer {
  #long description
  -long active
  #boolean amount
  #double address
  +getActive()
  +updateName()
}
class Product {
  #boolean createdAt
  #boolean type
  +setTotal()
  +validateAddress()
}
interface Shipment {
  #Date phone
  -float updatedAt
  +createActive()
}
Order --> Customer : "1..*"
Customer --|> Order
Order --> Product : "*"
note right of Invoice : Ecommerce domain
@enduml