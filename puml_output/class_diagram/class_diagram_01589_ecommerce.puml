@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
abstract class Review {
  -String duration
  #Date updatedAt
  #boolean quantity
  +updateCode()
}
interface Category {
  +float address
  #int createdAt
  #long code
  #String note
  +updateAmount()
  +findCode()
  +createDuration()
  +processDescription()
}
class Order {
  #int code
  #float id
  -float description
  -Date type
  +long status
  +validateStatus()
}
class Customer {
  -String active
  -Date name
  +getPrice()
  +setScore()
  +findNote()
  +createScore()
}
class Coupon {
  -boolean status
  #String total
  +int updatedAt
  +updateCreatedat()
}
interface Wishlist {
  +boolean quantity
  -Date phone
  +String level
  +processUpdatedat()
  +saveName()
}
class Shipment {
  -Date name
  #int score
  #double updatedAt
  +saveNote()
}
Coupon --* Review
Order --o Coupon
@enduml