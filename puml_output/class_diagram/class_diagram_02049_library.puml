@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
abstract class Member {
  -long status
  +boolean address
  -int level
  -int score
  +float createdAt
  +validateDuration()
}
abstract class Loan {
  +Date active
  #boolean description
  -int type
  +getPhone()
  +findActive()
  +validateActive()
}
class Fine {
  +boolean quantity
  #String name
  #String createdAt
  -String score
  +setTotal()
  +getActive()
  +deleteId()
}
interface Renewal {
  #int status
  +int description
  -String level
  #int quantity
  #String name
  +deleteQuantity()
  +deleteEmail()
  +cancelDescription()
}
class Branch {
  #boolean level
  #boolean amount
  -double type
  +validateType()
  +cancelUpdatedat()
  +getCode()
  +deleteDuration()
}
Branch --o Loan
Renewal ..|> Fine
@enduml