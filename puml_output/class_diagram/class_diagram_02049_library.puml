@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
abstract class Member {
  -long status
  +boolean address
  -int level
  -int score
  +float createdAt
  +validatePrice()
}
class Loan {
  #double type
  +boolean code
  -double active
  +cancelUpdatedat()
  +validateQuantity()
  +findName()
  +saveLevel()
}
class Fine {
  +float status
  -String name
  -long active
  +setDescription()
  +findDescription()
  +createName()
  +findUpdatedat()
}
class Renewal {
  #String email
  -String code
  #Date amount
  +updateLevel()
  +deleteType()
  +cancelLevel()
}
interface Branch {
  -Date type
  -boolean duration
  -int note
  #Date description
  #boolean active
  +setStatus()
  +sendPhone()
  +processCode()
}
Member --|> Branch
Fine ..> Branch : "1"
note right of Member : Library domain
@enduml