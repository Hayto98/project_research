@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
abstract class Package {
  #float note
  #boolean name
  #boolean duration
  -String total
  -double email
  +findScore()
  +setName()
  +setName()
}
class Route {
  #boolean duration
  -String amount
  +setType()
  +createCode()
  +createType()
  +updateId()
}
abstract class Manifest {
  #float name
  +Date level
  -int price
  +updateDuration()
}
class Depot {
  #int name
  #long note
  -Date price
  +createDescription()
  +saveEmail()
  +calculateCode()
}
class Driver {
  +String price
  +boolean status
  +double active
  +long description
  #double type
  +validatePrice()
  +calculatePhone()
}
class Customer {
  #int score
  -Date active
  -int duration
  +sendPrice()
  +deleteQuantity()
  +deleteCreatedat()
}
Driver --o Depot
Manifest --|> Driver
Manifest --o Package
Route --> Driver : "0..1"
note right of Package : Logistics domain
@enduml