@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
abstract class Package {
  #float note
  #boolean name
  #boolean duration
  -String total
  -double email
  +updateId()
  +calculateDuration()
  +getPrice()
}
class Route {
  +boolean status
  #float name
  +setId()
}
class Manifest {
  +long id
  -int price
  +double code
  +String type
  #float quantity
  +getDescription()
  +processEmail()
  +setQuantity()
  +getDuration()
}
class Depot {
  +double description
  -boolean name
  +boolean createdAt
  -float updatedAt
  -Date active
  +cancelAddress()
  +findPhone()
  +findEmail()
}
class Driver {
  #boolean code
  #boolean duration
  +float type
  -String price
  +String status
  +cancelCode()
  +processUpdatedat()
}
class Customer {
  -float updatedAt
  +boolean phone
  #Date price
  #Date score
  #boolean level
  +setActive()
  +findTotal()
}
Customer ..|> Manifest
Manifest --o Driver
Route ..|> Manifest
@enduml