@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
interface Notification {
  +long description
  +Date price
  #int code
  +float type
  #int active
  +processNote()
}
interface Comment {
  +double address
  #Date note
  #double id
  +validateAmount()
  +findUpdatedat()
  +validateStatus()
  +setName()
}
interface Post {
  #double score
  +Date address
  #float updatedAt
  +processCreatedat()
}
abstract class Hashtag {
  #double phone
  +int type
  +String name
  +double duration
  +findTotal()
}
abstract class Group {
  -float email
  #float price
  +Date level
  +Date amount
  -double description
  +calculateQuantity()
  +deleteScore()
}
Hashtag --> Notification : "1"
Notification ..> Post : "1"
Post --* Notification
@enduml