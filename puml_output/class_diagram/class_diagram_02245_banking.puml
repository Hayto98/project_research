@startuml

class Statement {
  -double name
  -String email
  #int type
  -float id
  +calculateName()
  +findStatus()
  +createStatus()
}
abstract class Card {
  -float code
  #String status
  +Date duration
  #Date score
  -long note
  +cancelCode()
  +deleteEmail()
  +getTotal()
}
interface Interest {
  #Date note
  +Date score
  +float email
  +deleteScore()
  +validateEmail()
}
class Teller {
  -double id
  -long phone
  -String duration
  +validateNote()
}
class Transfer {
  +String active
  #long description
  +float amount
  #float code
  +updatePhone()
  +calculateQuantity()
  +calculateId()
}
Transfer ..|> Statement
Interest --> Transfer : "*"
Transfer ..> Card : "1"
@enduml