@startuml

class Statement {
  -double name
  -String email
  #int type
  -float id
  +validateScore()
  +calculateTotal()
  +setStatus()
}
class Card {
  -float score
  #String note
  +findTotal()
}
class Interest {
  -Date type
  #long createdAt
  #Date active
  +Date amount
  +updateAmount()
  +setName()
}
class Teller {
  -double phone
  -long id
  +getStatus()
  +updateDescription()
  +createActive()
  +deleteLevel()
}
class Transfer {
  #long updatedAt
  +float name
  +saveTotal()
  +getAddress()
  +cancelStatus()
}
Interest --> Transfer : "*"
Transfer ..> Card : "1"
note right of Statement : Banking domain
@enduml