@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Staff {
  #String active
  #String phone
  #String email
  +deleteTotal()
  +getPrice()
  +processEmail()
  +getPhone()
}
abstract class Amenity {
  -double score
  -double active
  -float total
  +long price
  #int code
  +getLevel()
  +processPrice()
  +setPrice()
}
class Restaurant {
  +double note
  -int amount
  -double code
  -int quantity
  #long score
  +saveScore()
  +deletePhone()
  +cancelPrice()
}
class Room {
  #float price
  +String updatedAt
  #String status
  #Date level
  +createActive()
  +validateAmount()
}
class CheckIn {
  -int description
  -Date quantity
  -boolean total
  +createDuration()
  +validateType()
  +deleteDuration()
  +setDuration()
}
Restaurant --|> CheckIn
CheckIn ..|> Amenity
CheckIn --o Staff
@enduml