@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
abstract class Course {
  #double createdAt
  -boolean score
  +calculateId()
  +setTotal()
}
class Student {
  +double name
  -double total
  +float email
  +int status
  +validatePrice()
  +updateLevel()
  +createDuration()
}
class Assignment {
  +double quantity
  +String active
  -int amount
  +double total
  +validateTotal()
}
class Exam {
  +long phone
  -Date description
  +String type
  -String amount
  +cancelStatus()
  +sendPrice()
  +setPhone()
}
interface Grade {
  +long total
  #float type
  #boolean phone
  +int code
  +saveCreatedat()
  +deleteQuantity()
  +setCreatedat()
  +validateLevel()
}
Assignment --|> Course
Grade ..> Exam : "1..*"
Grade --> Course : "1..*"
note right of Course : Education domain
@enduml