@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
abstract class Course {
  #double createdAt
  -boolean score
  +setNote()
  +processName()
}
class Student {
  +float status
  +double address
  -double name
  +float total
  +int email
  +cancelType()
  +saveScore()
  +updateAmount()
}
abstract class Assignment {
  -long level
  #boolean quantity
  +double amount
  +sendName()
  +processDuration()
}
class Exam {
  -Date createdAt
  -String name
  -long total
  #int status
  +deleteScore()
  +calculateNote()
  +validateAmount()
  +calculateTotal()
}
class Grade {
  #long code
  #Date quantity
  #String name
  +createAddress()
  +cancelLevel()
  +deleteCode()
  +getScore()
}
Exam --* Grade
Course --* Student
Grade ..|> Student
@enduml