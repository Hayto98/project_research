@startuml
skinparam monochrome true
skinparam ArrowColor #555555
abstract class Group {
  -int phone
  +int address
  +sendAddress()
  +sendCreatedat()
  +updateId()
}
class Report {
  -long score
  -float amount
  +getTotal()
}
abstract class User {
  +double score
  -int price
  +float quantity
  +calculateLevel()
  +saveDuration()
}
class Like {
  +double name
  +boolean status
  -int code
  -double email
  +saveScore()
}
Like ..|> Report
Report --* User
@enduml