@startuml
skinparam monochrome true
skinparam ArrowColor #555555
abstract class Group {
  -int phone
  +int address
  +createType()
  +findCode()
  +getScore()
}
class Report {
  #double quantity
  #int duration
  #double code
  -int createdAt
  +createDescription()
  +getDescription()
  +cancelDescription()
  +validateName()
}
class User {
  -String email
  #long description
  +validateType()
  +setPhone()
}
class Like {
  -Date quantity
  +boolean amount
  #Date createdAt
  #float duration
  +Date email
  +createActive()
  +getId()
  +getTotal()
}
Report --> User : "1..*"
Group --o User
Like ..> Group : "0..1"
note right of Group : Social Media domain
@enduml