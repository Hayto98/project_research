@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
interface Prescription {
  #String type
  -Date status
  +double name
  -double code
  +findType()
  +validateTotal()
}
class Insurance {
  #long id
  #long createdAt
  #long total
  -Date duration
  +deleteNote()
  +validatePhone()
}
class Hospital {
  +String note
  #float address
  -long description
  +double quantity
  -int duration
  +saveAmount()
}
class Billing {
  -double type
  #Date createdAt
  -long price
  +Date email
  -String note
  +calculateTotal()
  +getScore()
  +findNote()
}
Hospital --> Insurance : "*"
Prescription --> Insurance : "1..*"
@enduml