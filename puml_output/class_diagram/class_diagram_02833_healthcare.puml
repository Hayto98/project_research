@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Ward {
  +Date total
  +int updatedAt
  #int name
  #double description
  +setPhone()
  +createUpdatedat()
  +processActive()
  +saveAddress()
}
class MedicalRecord {
  -Date id
  #int amount
  -String score
  -int status
  -int price
  +calculateType()
}
class LabTest {
  #double id
  -long note
  #String code
  #boolean description
  +createEmail()
}
class Hospital {
  +long total
  -String price
  +createEmail()
  +deleteActive()
}
abstract class Doctor {
  -long type
  -float score
  +String description
  +updateEmail()
  +sendUpdatedat()
  +cancelDescription()
}
Ward --* Doctor
MedicalRecord ..|> Hospital
Doctor --* Hospital
note right of Ward : Healthcare domain
@enduml