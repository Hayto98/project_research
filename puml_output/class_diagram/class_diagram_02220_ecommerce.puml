@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Supplier {
  +int total
  -String updatedAt
  -Date level
  #boolean name
  +deleteScore()
  +setNote()
  +calculateId()
}
interface Customer {
  -String level
  -String price
  -Date description
  +saveStatus()
  +processAddress()
  +setStatus()
  +getTotal()
}
abstract class Return {
  +boolean updatedAt
  -float level
  -float code
  #String duration
  #String active
  +calculateLevel()
  +cancelAmount()
  +calculateNote()
}
class Payment {
  -boolean status
  +String active
  +calculateDescription()
  +findPhone()
}
class Order {
  -Date level
  +float type
  -boolean name
  #long address
  +createActive()
  +cancelLevel()
}
class Wishlist {
  -Date total
  #int note
  +int id
  +calculateStatus()
}
Payment ..|> Customer
Payment ..|> Supplier
Wishlist --|> Order
@enduml