@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Profile {
  -float address
  -int score
  +String description
  #Date createdAt
  +int note
  +getDuration()
  +validateDuration()
  +calculateAmount()
}
class Follower {
  +boolean duration
  -double email
  #float price
  -double phone
  #double type
  +createName()
  +findType()
}
interface Post {
  #int score
  +String address
  +long amount
  +findScore()
}
abstract class Story {
  +boolean amount
  -double createdAt
  -double description
  +findScore()
}
interface Album {
  -boolean level
  +boolean score
  -double id
  +long note
  +validateCode()
  +deleteStatus()
}
class Hashtag {
  #float duration
  +long price
  +updateDescription()
  +createType()
  +calculateLevel()
  +validateDuration()
}
class Message {
  -long duration
  +String level
  #float id
  #float note
  -float code
  +calculateAmount()
  +calculateTotal()
}
Follower --* Message
Follower --> Story : "1"
Message --o Post
@enduml