@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Profile {
  -float address
  -int score
  +String description
  #Date createdAt
  +int note
  +validateNote()
  +deleteNote()
  +cancelEmail()
}
abstract class Follower {
  #float type
  -double code
  #double email
  #float duration
  +processScore()
  +sendUpdatedat()
}
interface Post {
  +String amount
  -String score
  -double description
  +Date status
  +updateDescription()
  +updateActive()
}
abstract class Story {
  #Date type
  #String total
  -double status
  #String quantity
  #long phone
  +updatePhone()
  +findCreatedat()
  +deleteCode()
  +setDuration()
}
abstract class Album {
  #float address
  -Date note
  +float createdAt
  +findDuration()
  +cancelDuration()
  +getNote()
  +findCode()
}
class Hashtag {
  #boolean code
  +double duration
  #int active
  +int note
  +deleteType()
  +cancelId()
  +validateType()
}
abstract class Message {
  -String total
  +double phone
  -boolean type
  +String level
  +sendDuration()
}
Profile --|> Message
Hashtag ..> Album : "1"
Profile --* Follower
note right of Profile : Social Media domain
@enduml