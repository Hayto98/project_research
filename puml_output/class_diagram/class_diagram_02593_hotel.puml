@startuml
skinparam defaultFontSize 13
class Housekeeping {
  -float score
  #int address
  -String updatedAt
  +boolean code
  +processScore()
  +calculateNote()
}
class Staff {
  +long id
  #float level
  +double amount
  #float duration
  +updateTotal()
  +processStatus()
}
class Booking {
  -float updatedAt
  +Date id
  +long phone
  #boolean name
  +saveActive()
}
interface Room {
  +long note
  #String createdAt
  +findName()
}
interface CheckOut {
  #String level
  -double duration
  +long price
  +deletePrice()
  +deleteId()
  +updateType()
  +createAmount()
}
Staff ..|> Housekeeping
Booking --|> CheckOut
note right of Housekeeping : Hotel domain
@enduml