@startuml
skinparam defaultFontSize 13
class Housekeeping {
  -float score
  #int address
  -String updatedAt
  +boolean code
  +findActive()
  +getStatus()
}
interface Staff {
  +String note
  -boolean createdAt
  +double address
  #float id
  +int amount
  +sendName()
  +setStatus()
  +updateName()
  +findCode()
}
class Booking {
  +double phone
  +Date level
  +findCreatedat()
}
interface Room {
  -int active
  +long status
  +validateLevel()
}
class CheckOut {
  #float score
  #double updatedAt
  +calculateName()
}
Housekeeping ..> Booking : "*"
Staff ..|> Room
Housekeeping --o Staff
@enduml