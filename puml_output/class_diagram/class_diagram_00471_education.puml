@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Department {
  +boolean quantity
  #long note
  #int level
  #int description
  +createPrice()
  +getDuration()
  +createScore()
}
abstract class Schedule {
  #Date total
  +int status
  #int description
  -float score
  #int email
  +deleteLevel()
  +sendCode()
}
class Classroom {
  +double total
  -double createdAt
  +float updatedAt
  +float code
  #Date level
  +sendStatus()
  +setUpdatedat()
  +sendAmount()
  +savePrice()
}
class Teacher {
  -Date createdAt
  +String email
  +setEmail()
  +processPrice()
}
class Exam {
  -boolean phone
  #long level
  -double createdAt
  -boolean score
  +long amount
  +sendActive()
  +processAddress()
  +sendTotal()
  +saveName()
}
class Grade {
  -String quantity
  -String phone
  -Date status
  -float total
  +String code
  +updateCreatedat()
}
interface Attendance {
  +String code
  -long status
  -boolean address
  -boolean total
  +long phone
  +setPrice()
  +deleteAddress()
  +cancelId()
}
Department --|> Attendance
Grade --o Classroom
Attendance --> Exam : "0..1"
Classroom --> Attendance : "0..1"
Grade ..> Department : "1..*"
@enduml