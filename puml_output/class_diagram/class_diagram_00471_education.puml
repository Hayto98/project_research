@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Department {
  +boolean quantity
  #long note
  #int level
  #int description
  +calculateUpdatedat()
  +calculateTotal()
  +calculateStatus()
}
class Schedule {
  #int duration
  +boolean email
  +double score
  +saveDescription()
  +processCode()
}
abstract class Classroom {
  -double createdAt
  -int updatedAt
  +float code
  #Date duration
  -float active
  +sendLevel()
}
class Teacher {
  -Date createdAt
  +String email
  +validateUpdatedat()
  +createNote()
}
class Exam {
  #Date createdAt
  -double amount
  -long phone
  +createLevel()
  +cancelType()
}
interface Grade {
  -float price
  -float name
  +setTotal()
  +setQuantity()
  +getQuantity()
}
class Attendance {
  +Date type
  +long createdAt
  #boolean status
  -float code
  -String price
  +validateAddress()
}
Exam --> Classroom : "0..1"
Classroom ..|> Attendance
Classroom --|> Teacher
Department ..> Attendance : "1..*"
Teacher --> Exam : "0..1"
note right of Department : Education domain
@enduml