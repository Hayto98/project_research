@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
interface Assignment {
  +float phone
  +int address
  +double level
  #String createdAt
  +validateStatus()
  +createDuration()
}
abstract class Grade {
  -boolean level
  #boolean duration
  #String status
  +findAmount()
  +getNote()
}
abstract class Student {
  -String total
  +long price
  +deleteCode()
  +calculatePrice()
  +deleteDuration()
}
interface Department {
  +Date email
  +int updatedAt
  +long address
  +getAddress()
  +calculateDescription()
  +getPhone()
}
class Attendance {
  +float updatedAt
  -Date status
  #double name
  +cancelPhone()
}
class Teacher {
  +float type
  #String note
  -long duration
  +updateLevel()
  +deleteDescription()
  +createQuantity()
}
interface Schedule {
  #float updatedAt
  +long description
  +getAddress()
}
Attendance --|> Teacher
Schedule --o Grade
Student --> Assignment : "*"
note right of Assignment : Education domain
@enduml