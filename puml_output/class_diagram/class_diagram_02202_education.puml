@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
interface Assignment {
  +float phone
  +int address
  +double level
  #String createdAt
  +deleteCode()
  +getActive()
}
class Grade {
  -boolean duration
  #boolean note
  #String description
  #Date status
  +createLevel()
  +saveDescription()
}
class Student {
  +Date note
  #float price
  +saveName()
  +updateAmount()
  +updateQuantity()
  +findCreatedat()
}
class Department {
  -int email
  +double level
  +findPhone()
  +setPhone()
  +getTotal()
  +getDuration()
}
class Attendance {
  +int address
  -long amount
  +float status
  +getPhone()
  +validateCode()
  +saveId()
}
class Teacher {
  +float description
  +String updatedAt
  +cancelDescription()
  +updateNote()
  +processLevel()
  +validateType()
}
class Schedule {
  -int updatedAt
  #String description
  -long type
  #long note
  +sendLevel()
  +saveDuration()
}
Grade --* Student
Attendance --|> Teacher
Schedule ..> Teacher : "0..1"
@enduml