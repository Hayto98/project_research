@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class MedicalRecord {
  -String total
  +boolean note
  #String updatedAt
  +processPrice()
  +createAddress()
  +sendStatus()
  +saveAmount()
}
class Nurse {
  +long duration
  -int description
  -boolean note
  +sendNote()
  +updateActive()
  +updateType()
}
interface Treatment {
  -int duration
  +boolean active
  -String name
  #boolean email
  +Date description
  +validateActive()
}
class LabTest {
  #float phone
  +int amount
  #double description
  +saveAmount()
  +saveAddress()
}
class Patient {
  #int amount
  #double total
  +getUpdatedat()
  +deleteId()
  +createTotal()
}
interface Diagnosis {
  +int level
  +Date phone
  #long score
  +findAddress()
  +deletePrice()
}
MedicalRecord --* Treatment
MedicalRecord ..|> Patient
@enduml