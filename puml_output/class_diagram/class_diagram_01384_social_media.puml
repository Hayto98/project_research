@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Album {
  -boolean code
  #long description
  +processAddress()
  +setActive()
  +processStatus()
  +calculateCode()
}
class Story {
  +double description
  +long phone
  -String active
  +updateNote()
  +setNote()
}
class User {
  +String price
  -int score
  +getId()
}
class Hashtag {
  +double createdAt
  -int type
  +double price
  -double phone
  +float total
  +validateDuration()
  +setNote()
}
class Notification {
  -long active
  +float note
  -Date total
  +int quantity
  #int status
  +savePhone()
}
Notification --* Story
Hashtag --* Album
note right of Album : Social Media domain
@enduml