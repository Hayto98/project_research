@startuml
skinparam shadowing true
interface Return {
  #Date createdAt
  -long email
  +long level
  #int score
  +deleteCreatedat()
  +findDescription()
  +getQuantity()
  +cancelStatus()
}
class Customer {
  #float level
  #String amount
  #String createdAt
  #boolean updatedAt
  #boolean code
  +getScore()
}
abstract class Wishlist {
  #boolean status
  -String active
  +createDuration()
  +createEmail()
  +cancelPhone()
  +deleteQuantity()
}
interface Cart {
  +int phone
  #boolean score
  +float address
  -String description
  +getEmail()
  +cancelEmail()
  +sendPhone()
}
class Review {
  -String status
  -double duration
  -String score
  #double total
  +processPhone()
  +sendCreatedat()
}
class Invoice {
  #int phone
  #Date code
  +saveQuantity()
}
abstract class Shipment {
  +String phone
  #double total
  +boolean level
  +setQuantity()
  +processEmail()
}
Wishlist --|> Invoice
Wishlist ..> Return : "1..*"
Shipment --|> Return
Customer ..> Return : "0..1"
@enduml