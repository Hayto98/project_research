@startuml
skinparam shadowing true
interface Return {
  #Date createdAt
  -long email
  +long level
  #int score
  +createDuration()
  +cancelCode()
  +saveAddress()
  +calculateLevel()
}
class Customer {
  #float level
  #String updatedAt
  #String code
  +sendTotal()
}
class Wishlist {
  #float active
  -String level
  +calculateEmail()
  +setActive()
  +validatePhone()
  +sendAddress()
}
class Cart {
  -String createdAt
  #long code
  +setPhone()
  +updatePhone()
}
class Review {
  -double duration
  +long score
  +validateName()
  +findType()
  +saveAmount()
  +processPhone()
}
class Invoice {
  #Date code
  +int score
  -boolean amount
  +long active
  +calculateDescription()
  +getPrice()
  +deleteScore()
  +deleteLevel()
}
class Shipment {
  +String id
  +String email
  #int code
  #int phone
  +updateId()
  +findCode()
  +findStatus()
}
Wishlist ..> Return : "1"
Shipment ..|> Customer
Cart ..|> Wishlist
note right of Return : Ecommerce domain
@enduml