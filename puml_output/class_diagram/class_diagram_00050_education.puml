@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Assignment {
  +double phone
  +float quantity
  +float id
  +saveAmount()
  +getDescription()
}
interface Enrollment {
  -Date address
  +int updatedAt
  +getLevel()
  +sendStatus()
  +findType()
  +findType()
}
class Classroom {
  -float phone
  +Date status
  +getAmount()
  +getLevel()
  +validateNote()
}
interface Book {
  #double quantity
  +boolean description
  -float note
  +double createdAt
  +calculateLevel()
  +calculatePhone()
  +processUpdatedat()
  +deleteScore()
}
class Attendance {
  -boolean active
  #double note
  -boolean createdAt
  +sendQuantity()
}
class Teacher {
  #float status
  -Date phone
  +updateLevel()
  +getLevel()
}
abstract class Course {
  +int email
  +Date id
  +setPrice()
  +findDuration()
  +saveStatus()
  +getCode()
}
Book --> Assignment : "1"
Attendance --|> Assignment
note right of Assignment : Education domain
@enduml