@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Assignment {
  +double phone
  +float quantity
  +float id
  +setScore()
  +calculateStatus()
}
class Enrollment {
  +long description
  +long score
  +findId()
}
abstract class Classroom {
  #String level
  #Date score
  +validateTotal()
  +sendCreatedat()
  +sendId()
  +createPhone()
}
class Book {
  #boolean address
  -String amount
  +sendTotal()
  +saveDescription()
}
interface Attendance {
  +Date note
  -int score
  #double phone
  +boolean quantity
  +setAmount()
  +createCode()
  +createDuration()
  +getQuantity()
}
abstract class Teacher {
  +boolean level
  -int total
  #boolean phone
  -int type
  -boolean updatedAt
  +getPhone()
  +createDescription()
  +saveTotal()
  +validateStatus()
}
class Course {
  #float quantity
  -Date status
  +int level
  #Date phone
  +savePrice()
}
Assignment --|> Classroom
Assignment --|> Enrollment
Teacher --> Attendance : "*"
Assignment ..> Book : "1"
Assignment --|> Teacher
@enduml