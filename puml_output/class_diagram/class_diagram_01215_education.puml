@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
interface Student {
  #String id
  +String note
  #Date code
  #boolean address
  #double level
  +sendStatus()
}
class Teacher {
  -String updatedAt
  #double name
  #double price
  +deleteLevel()
  +validateActive()
  +createId()
  +sendNote()
}
class Library {
  +int name
  +String amount
  -String score
  #String code
  #boolean duration
  +sendEmail()
  +findAddress()
  +savePhone()
}
class Classroom {
  #double duration
  -Date email
  #int level
  #int type
  +getCreatedat()
}
Teacher ..|> Classroom
Student --> Teacher : "1..*"
@enduml