@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
interface Student {
  #String id
  +String note
  #Date code
  #boolean address
  #double level
  +saveAmount()
}
interface Teacher {
  -String updatedAt
  #double name
  #double price
  +cancelUpdatedat()
  +validateNote()
  +getAmount()
  +sendScore()
}
class Library {
  +String updatedAt
  -String amount
  +saveLevel()
}
class Classroom {
  -boolean updatedAt
  -float name
  #long duration
  +cancelPrice()
  +createCreatedat()
  +saveCreatedat()
  +getScore()
}
Teacher ..|> Classroom
Student --> Teacher : "1..*"
note right of Student : Education domain
@enduml