@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Package {
  +long name
  #int price
  -long code
  +float address
  +int amount
  +processTotal()
  +processDescription()
  +findPrice()
  +sendTotal()
}
class DeliveryNote {
  +long price
  #boolean total
  +findAmount()
}
interface FuelLog {
  -String description
  -double active
  +saveId()
}
class Vehicle {
  -long name
  -String id
  #int total
  -float createdAt
  +sendCode()
  +deleteActive()
  +findScore()
  +deleteAddress()
}
class Route {
  -double active
  +int quantity
  -double updatedAt
  +calculateCode()
  +calculatePrice()
  +calculateAddress()
}
class Manifest {
  #long address
  +long phone
  -double id
  +double score
  +String quantity
  +deleteStatus()
  +sendTotal()
  +validateTotal()
  +cancelStatus()
}
Package --* FuelLog
FuelLog --|> Vehicle
@enduml