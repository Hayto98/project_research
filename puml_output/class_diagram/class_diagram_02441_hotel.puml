@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Payment {
  -Date email
  +float id
  #float total
  +double type
  +deleteDescription()
  +setAddress()
}
interface Reservation {
  #boolean email
  +long name
  +double price
  +float total
  +setCode()
  +cancelPhone()
  +sendEmail()
}
abstract class Service {
  +float description
  #double address
  +cancelPrice()
  +deletePhone()
  +getActive()
}
abstract class Invoice {
  -double name
  #int description
  +boolean email
  +String createdAt
  +calculateQuantity()
  +calculateDuration()
  +deleteAmount()
}
class Housekeeping {
  +Date name
  +float amount
  -int id
  -double status
  +validateQuantity()
  +calculatePhone()
}
class Restaurant {
  +String level
  #double status
  +validateCode()
  +validateId()
  +saveDescription()
  +getAddress()
}
Payment --> Service : "0..1"
Housekeeping --> Payment : "0..1"
Housekeeping --> Reservation : "*"
@enduml