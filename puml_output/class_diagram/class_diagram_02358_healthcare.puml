@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Treatment {
  -Date type
  +String note
  +double updatedAt
  -boolean phone
  +validateTotal()
  +createPhone()
}
class LabTest {
  -double score
  +double id
  +Date level
  #double amount
  +updateAmount()
  +saveUpdatedat()
}
class Diagnosis {
  +Date id
  +String createdAt
  +int price
  +cancelEmail()
  +calculatePhone()
}
class Billing {
  #double status
  +double score
  +double amount
  +Date updatedAt
  +deleteQuantity()
  +processCode()
  +setNote()
}
Treatment --> Billing : "*"
LabTest --|> Treatment
@enduml