@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Treatment {
  -Date type
  +String note
  +double updatedAt
  -boolean phone
  +findStatus()
  +deleteAddress()
}
interface LabTest {
  +long level
  -String id
  +getNote()
  +updateAmount()
  +findDescription()
  +getDuration()
}
class Diagnosis {
  #Date name
  #int description
  +long duration
  #Date level
  +long updatedAt
  +sendAmount()
}
class Billing {
  #long name
  +String total
  -float status
  #int level
  +int amount
  +deleteDescription()
  +getUpdatedat()
  +sendPhone()
  +savePhone()
}
LabTest --|> Diagnosis
Billing ..> Treatment : "1..*"
note right of Treatment : Healthcare domain
@enduml