@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Customer {
  #boolean id
  #int email
  +setCreatedat()
}
class Coupon {
  -float name
  #float createdAt
  #Date phone
  -int note
  -String email
  +validateAddress()
  +saveAddress()
  +calculatePrice()
}
interface Product {
  +long level
  -Date duration
  +calculateEmail()
  +setQuantity()
  +saveLevel()
  +deleteName()
}
class Shipment {
  +boolean description
  +String name
  -boolean email
  #int address
  -float total
  +sendStatus()
}
Shipment --> Coupon : "1"
Customer --* Coupon
@enduml