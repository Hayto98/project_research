@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Customer {
  #boolean id
  #int email
  +findCode()
}
abstract class Coupon {
  -boolean createdAt
  #long phone
  +sendPrice()
  +deleteQuantity()
  +setLevel()
  +cancelEmail()
}
class Product {
  #boolean score
  +long duration
  -Date id
  +getEmail()
  +findId()
  +calculateDescription()
  +getEmail()
}
class Shipment {
  -float status
  +float name
  #int id
  #float note
  -double createdAt
  +setQuantity()
}
Customer --> Shipment : "1"
Customer ..> Coupon : "1..*"
Shipment --* Customer
note right of Customer : Ecommerce domain
@enduml