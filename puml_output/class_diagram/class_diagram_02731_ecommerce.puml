@startuml
skinparam ArrowColor #555555
class Coupon {
  -String phone
  -long score
  +long email
  +int price
  #float status
  +createType()
  +processId()
  +findLevel()
}
class Invoice {
  -long duration
  #long description
  -String note
  +createQuantity()
  +cancelUpdatedat()
  +sendDescription()
  +validateCreatedat()
}
class Wishlist {
  -boolean quantity
  +float duration
  #float updatedAt
  -Date active
  +getCode()
  +setEmail()
}
class Product {
  -String level
  -String createdAt
  +createPhone()
  +saveDuration()
}
abstract class Supplier {
  #int duration
  -String phone
  -Date status
  -double email
  +calculateEmail()
  +findLevel()
  +processCode()
}
class Order {
  -long type
  #float description
  +validateId()
  +setNote()
  +setActive()
  +sendCode()
}
class Shipment {
  +Date price
  #String description
  -double duration
  +String updatedAt
  +getDuration()
  +getPhone()
  +sendDescription()
}
Shipment --> Product : "0..1"
Supplier --* Product
Invoice ..|> Coupon
Supplier ..|> Order
@enduml