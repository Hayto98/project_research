@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Warehouse {
  -boolean level
  +long code
  #String id
  +float quantity
  #Date address
  +updateName()
  +cancelActive()
  +deleteTotal()
}
class Inventory {
  +Date status
  #long phone
  -float note
  -double active
  +saveCreatedat()
  +calculateDuration()
  +findDescription()
}
class DeliveryNote {
  +boolean active
  -float email
  -String type
  -int score
  +createName()
  +createName()
  +getUpdatedat()
}
abstract class Driver {
  -boolean description
  +Date note
  +validateStatus()
  +processQuantity()
}
interface Vehicle {
  +int createdAt
  +float description
  #int address
  +validateLevel()
}
abstract class Depot {
  +boolean score
  -String quantity
  #boolean type
  #boolean updatedAt
  +setActive()
  +updatePhone()
}
Warehouse --|> Vehicle
Driver ..|> Depot
Depot --* Driver
note right of Warehouse : Logistics domain
@enduml