@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Warehouse {
  -boolean level
  +long code
  #String id
  +float quantity
  #Date address
  +cancelNote()
  +deleteNote()
  +validateActive()
}
interface Inventory {
  +long total
  -boolean updatedAt
  #boolean phone
  +processNote()
}
class DeliveryNote {
  -boolean phone
  #Date total
  +long address
  -boolean createdAt
  +cancelCode()
  +createEmail()
  +getId()
}
class Driver {
  -Date price
  +long id
  +String email
  +double createdAt
  +Date phone
  +deleteTotal()
  +createTotal()
}
abstract class Vehicle {
  -String active
  -Date name
  -boolean score
  +int createdAt
  +saveCreatedat()
  +calculateEmail()
}
class Depot {
  +long active
  #double updatedAt
  +sendAmount()
  +getNote()
  +updateCreatedat()
}
Depot --|> Inventory
Vehicle --|> DeliveryNote
Vehicle ..> Depot : "0..1"
Warehouse ..|> Vehicle
DeliveryNote --|> Depot
@enduml