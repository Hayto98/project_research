@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
interface Nurse {
  +double createdAt
  -boolean email
  -Date duration
  -boolean code
  +getEmail()
}
interface Patient {
  -double score
  #boolean note
  -double duration
  +calculateId()
  +createEmail()
  +processAddress()
  +findCode()
}
class Appointment {
  +float score
  -float createdAt
  -Date duration
  -boolean code
  +String status
  +calculateDuration()
  +processType()
  +cancelDescription()
}
abstract class Billing {
  +float address
  -int code
  #float note
  #boolean status
  +validateNote()
  +cancelPrice()
}
class Prescription {
  #long description
  #long address
  -boolean note
  +findAddress()
  +createNote()
}
class LabTest {
  -Date status
  +Date price
  +float quantity
  #int note
  +int id
  +findQuantity()
}
Prescription --* LabTest
Nurse ..> Billing : "0..1"
@enduml