@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
interface Nurse {
  +double createdAt
  -boolean email
  -Date duration
  -boolean code
  +deleteActive()
}
interface Patient {
  -double score
  #boolean note
  -double duration
  +getPhone()
  +saveAddress()
  +processScore()
  +updateScore()
}
class Appointment {
  -Date name
  -boolean type
  +getEmail()
}
interface Billing {
  +String price
  -int address
  #float level
  #boolean code
  #int note
  +saveCreatedat()
  +cancelAmount()
}
class Prescription {
  #Date note
  +int quantity
  -double email
  #String total
  +cancelQuantity()
  +sendNote()
  +getAddress()
  +findUpdatedat()
}
class LabTest {
  -String updatedAt
  #float duration
  #long code
  +processCreatedat()
}
Prescription ..> Patient : "*"
Nurse ..> Billing : "1..*"
note right of Nurse : Healthcare domain
@enduml