@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Invoice {
  #double note
  -boolean updatedAt
  -long quantity
  +setUpdatedat()
  +calculateAddress()
}
class Guest {
  #int quantity
  -String email
  +validateAddress()
}
interface Payment {
  -float amount
  #float status
  -boolean duration
  +processName()
}
class Room {
  -boolean code
  -boolean quantity
  -double id
  +calculateStatus()
  +calculateId()
}
interface Reservation {
  -int id
  #double level
  +getName()
}
Reservation --* Invoice
Guest --* Invoice
note right of Invoice : Hotel domain
@enduml