@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Invoice {
  #double note
  -boolean updatedAt
  -long quantity
  +getLevel()
  +processDuration()
}
abstract class Guest {
  #int status
  -String code
  +long quantity
  -boolean email
  +findId()
  +setStatus()
}
class Payment {
  +int quantity
  +long status
  +double note
  #double name
  +saveAmount()
  +cancelNote()
  +getPhone()
}
class Room {
  #double id
  +String code
  +int duration
  #String total
  -Date amount
  +sendPrice()
  +sendTotal()
}
class Reservation {
  +long createdAt
  -Date price
  #String id
  -Date name
  +updatePhone()
  +deleteCreatedat()
  +processPhone()
}
Invoice --|> Payment
Guest --o Invoice
@enduml