@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Loan {
  -float status
  +int note
  +String description
  +calculateId()
  +setEmail()
  +processScore()
  +createAmount()
}
class Account {
  #int status
  #double id
  -int type
  #float active
  -float name
  +saveQuantity()
  +getAmount()
  +validateCode()
  +deleteScore()
}
class Card {
  +float description
  #boolean phone
  +savePhone()
  +cancelId()
  +findType()
}
class Teller {
  #Date name
  +long total
  +validatePrice()
  +validatePrice()
}
interface Withdrawal {
  -float phone
  +int description
  +int price
  +float code
  +createCode()
  +cancelTotal()
  +calculateAmount()
}
class Transfer {
  +String note
  -boolean address
  +deleteDescription()
}
Loan --* Card
Loan --> Transfer : "1..*"
Teller --> Transfer : "1..*"
Transfer --|> Card
note right of Loan : Banking domain
@enduml