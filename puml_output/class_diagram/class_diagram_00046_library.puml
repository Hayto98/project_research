@startuml
skinparam shadowing true
class Member {
  -boolean status
  +float type
  +calculateUpdatedat()
}
class Publisher {
  +boolean id
  #long email
  -double note
  -String active
  +validateQuantity()
}
class Renewal {
  +Date price
  #Date code
  #boolean quantity
  +setAmount()
}
class Reservation {
  -Date score
  #boolean name
  +deleteType()
}
interface Book {
  #float type
  #double score
  -boolean note
  #double total
  +boolean price
  +processStatus()
  +cancelLevel()
}
Book --|> Renewal
Reservation --* Publisher
Renewal --|> Book
@enduml