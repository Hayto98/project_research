@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
abstract class Branch {
  +String code
  +double total
  +long active
  +Date note
  #double createdAt
  +setPhone()
  +cancelLevel()
}
class Shelf {
  -double score
  #int quantity
  -double type
  +int createdAt
  #int status
  +getId()
  +calculateEmail()
}
interface Member {
  -String note
  -float name
  +saveId()
  +validatePrice()
  +sendScore()
}
class Reservation {
  #boolean score
  -float note
  #long duration
  -long type
  +calculatePrice()
}
class Renewal {
  -float createdAt
  -double status
  +String quantity
  -double address
  +updateEmail()
  +findAmount()
}
interface Book {
  #long note
  #boolean updatedAt
  +int amount
  +calculateQuantity()
  +calculateLevel()
  +validateId()
}
class Publisher {
  #float duration
  +boolean active
  -int createdAt
  +boolean level
  -boolean status
  +updateTotal()
}
Book ..|> Reservation
Reservation --o Book
Renewal --* Book
note right of Branch : Library domain
@enduml