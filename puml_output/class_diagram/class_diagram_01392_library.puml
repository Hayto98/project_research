@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
abstract class Branch {
  +String code
  +double total
  +long active
  +Date note
  #double createdAt
  +validateDescription()
  +validateId()
}
class Shelf {
  -int duration
  +long note
  -boolean score
  +double quantity
  +processQuantity()
  +createScore()
  +cancelDuration()
  +processDuration()
}
class Member {
  -boolean id
  +double total
  +createDuration()
}
class Reservation {
  -boolean email
  -float id
  #double address
  #boolean price
  -float quantity
  +calculateType()
  +createName()
  +calculateScore()
}
class Renewal {
  -Date price
  #long code
  -float quantity
  -double createdAt
  +String status
  +setNote()
  +calculateTotal()
  +cancelDescription()
}
class Book {
  +double email
  +int amount
  #long score
  +calculateAddress()
  +getStatus()
}
class Publisher {
  -boolean quantity
  #float price
  +float phone
  #String id
  #float amount
  +findDuration()
}
Shelf --> Publisher : "*"
Renewal ..|> Branch
Reservation ..> Shelf : "*"
Shelf ..> Reservation : "*"
Renewal --* Book
@enduml