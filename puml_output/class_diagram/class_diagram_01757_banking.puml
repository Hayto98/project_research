@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Withdrawal {
  #float quantity
  #boolean id
  -boolean score
  -int level
  -int active
  +getCode()
  +deleteId()
  +saveStatus()
  +createTotal()
}
class Loan {
  +int score
  #long createdAt
  #int type
  +double updatedAt
  #Date name
  +getUpdatedat()
}
class Deposit {
  #double status
  #Date address
  +int quantity
  -long level
  +processType()
  +setDescription()
  +getTotal()
  +savePhone()
}
interface Account {
  #double phone
  #int amount
  #Date duration
  #String address
  -int id
  +cancelScore()
  +updateId()
}
interface Beneficiary {
  #long code
  +double name
  +float status
  +createCreatedat()
  +findType()
  +processScore()
  +saveTotal()
}
class Transfer {
  -boolean address
  +long updatedAt
  -String type
  +float quantity
  #int total
  +validateAmount()
  +updateStatus()
  +saveDescription()
}
Account --|> Deposit
Beneficiary --|> Account
Beneficiary ..|> Loan
Account ..|> Withdrawal
Loan ..|> Account
note right of Withdrawal : Banking domain
@enduml