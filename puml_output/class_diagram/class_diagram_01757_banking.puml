@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Withdrawal {
  #float quantity
  #boolean id
  -boolean score
  -int level
  -int active
  +saveEmail()
  +createTotal()
  +findNote()
  +saveQuantity()
}
class Loan {
  -Date email
  -Date total
  +validateUpdatedat()
  +sendNote()
}
class Deposit {
  +double description
  #Date address
  +String amount
  +setDuration()
  +findScore()
}
class Account {
  -boolean address
  -boolean quantity
  +validateCreatedat()
  +deleteCode()
}
class Beneficiary {
  -Date type
  -float duration
  #boolean status
  -long description
  +float name
  +updatePhone()
  +createType()
  +validateDuration()
}
class Transfer {
  +boolean createdAt
  #boolean active
  +float id
  +Date type
  #int updatedAt
  +deleteNote()
}
Beneficiary ..|> Deposit
Account --o Loan
@enduml