@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Insurance {
  #String level
  +int price
  -int code
  +updateType()
  +cancelCreatedat()
  +validatePrice()
  +calculateNote()
}
class Hospital {
  -Date amount
  #String active
  -Date description
  -String phone
  +double total
  +createUpdatedat()
  +setId()
  +saveQuantity()
}
class Doctor {
  +double price
  -int status
  +String active
  #String address
  +saveTotal()
}
class Prescription {
  -boolean amount
  +String active
  -String phone
  -float createdAt
  +getActive()
}
interface MedicalRecord {
  #float duration
  -float name
  #double status
  -float address
  +processAmount()
  +cancelPhone()
  +updatePrice()
}
class Patient {
  -boolean score
  +String active
  +updateStatus()
  +deleteAmount()
  +calculateUpdatedat()
  +processScore()
}
abstract class LabTest {
  -boolean total
  -int email
  +sendEmail()
  +getAmount()
  +deleteTotal()
}
Insurance --* Doctor
LabTest ..|> Patient
LabTest --> Prescription : "1"
note right of Insurance : Healthcare domain
@enduml