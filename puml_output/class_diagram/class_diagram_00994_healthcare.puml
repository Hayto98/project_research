@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Insurance {
  #String level
  +int price
  -int code
  +updateStatus()
  +createId()
  +saveUpdatedat()
  +sendCreatedat()
}
interface Hospital {
  -String phone
  -int price
  #float level
  +calculateDescription()
  +saveScore()
}
abstract class Doctor {
  +int active
  -long name
  -Date email
  +String note
  +cancelScore()
}
class Prescription {
  #float address
  -int price
  -long status
  +String active
  +deleteType()
}
class MedicalRecord {
  -int total
  #long updatedAt
  +validateScore()
  +getCreatedat()
}
class Patient {
  -float price
  +float code
  +updateNote()
}
interface LabTest {
  #float duration
  -float name
  #double status
  -float address
  +findActive()
  +validateQuantity()
  +setQuantity()
}
Doctor --o Hospital
Hospital --> Insurance : "*"
MedicalRecord --|> Insurance
MedicalRecord ..|> Prescription
Insurance ..|> Hospital
Prescription --o Hospital
@enduml