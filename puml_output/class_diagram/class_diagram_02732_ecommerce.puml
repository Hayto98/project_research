@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Warehouse {
  -double address
  #boolean note
  +double code
  -int type
  -int createdAt
  +getName()
  +cancelTotal()
}
abstract class Invoice {
  #Date email
  #Date duration
  #long level
  -float createdAt
  +deleteType()
  +processCreatedat()
  +createId()
}
abstract class Shipment {
  -Date amount
  +boolean note
  +int level
  -String createdAt
  #int type
  +updateScore()
  +validateCode()
  +updateUpdatedat()
  +validateQuantity()
}
abstract class Cart {
  #double id
  -float quantity
  +boolean total
  #float amount
  +double note
  +createAmount()
  +createNote()
}
class Customer {
  #int duration
  +String status
  +processCode()
  +sendLevel()
  +calculateActive()
  +cancelCode()
}
interface Coupon {
  +int level
  -boolean email
  +long name
  -float type
  +createPhone()
  +processLevel()
  +setDescription()
}
abstract class Supplier {
  +boolean type
  #int amount
  #float score
  #Date level
  #Date createdAt
  +createDescription()
  +deleteEmail()
  +getAmount()
  +updateCode()
}
Supplier --* Cart
Shipment --|> Customer
Customer --* Supplier
Shipment --* Coupon
Coupon --|> Customer
@enduml