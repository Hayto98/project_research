@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
abstract class Shipment {
  +float description
  #double phone
  +getStatus()
}
class Depot {
  -boolean level
  -int status
  -boolean quantity
  -float code
  +cancelCreatedat()
  +processPhone()
}
interface Customer {
  +float duration
  +long updatedAt
  +updateDescription()
}
class Warehouse {
  +String status
  -long total
  +getScore()
  +deleteLevel()
  +processDescription()
  +calculateAmount()
}
class FuelLog {
  #double quantity
  -Date code
  +findScore()
  +saveActive()
  +cancelEmail()
  +sendScore()
}
class Tracking {
  #String active
  #Date status
  -boolean note
  #long score
  +deleteAmount()
  +createAmount()
}
Shipment --> Warehouse : "1"
Warehouse --> Depot : "1..*"
FuelLog ..|> Shipment
Shipment --|> FuelLog
@enduml