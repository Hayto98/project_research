@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
abstract class Branch {
  #String score
  -double phone
  #Date updatedAt
  +long address
  +setQuantity()
  +processDuration()
}
abstract class Transfer {
  #int name
  -boolean quantity
  +deleteCreatedat()
  +updateDescription()
  +cancelDuration()
  +sendDuration()
}
class Deposit {
  -int price
  -String phone
  #Date level
  #String createdAt
  +processActive()
  +setAddress()
  +findDescription()
}
class Loan {
  #boolean score
  #double address
  #double price
  #boolean level
  +long status
  +validateDuration()
}
Transfer ..> Loan : "1..*"
Transfer --o Deposit
note right of Branch : Banking domain
@enduml