@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
abstract class Branch {
  #String score
  -double phone
  #Date updatedAt
  +long address
  +cancelStatus()
  +getPrice()
}
class Transfer {
  #int duration
  -boolean price
  #boolean code
  #double name
  +int quantity
  +validateCode()
  +processEmail()
}
interface Deposit {
  +double quantity
  +long price
  +Date phone
  #Date score
  +validateAddress()
}
abstract class Loan {
  -float address
  -Date description
  +deleteAmount()
  +findQuantity()
  +updateName()
}
Loan --> Deposit : "1"
Deposit --* Branch
Branch --* Loan
@enduml