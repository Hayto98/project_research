@startuml
skinparam monochrome true
class Shelf {
  +long phone
  -long amount
  -long description
  #long active
  +double id
  +setUpdatedat()
  +processTotal()
}
class Book {
  +double score
  #Date email
  +sendEmail()
}
class Catalog {
  -float price
  +long note
  -int score
  +long updatedAt
  +calculatePhone()
  +sendType()
  +getId()
  +getQuantity()
}
abstract class Branch {
  +long level
  -double total
  #float code
  +processDuration()
}
class Loan {
  #boolean duration
  #float updatedAt
  +saveQuantity()
  +processId()
  +updateEmail()
  +validateDescription()
}
abstract class Member {
  +int total
  -String active
  #Date note
  +double score
  #float amount
  +sendTotal()
}
Member --* Book
Shelf --> Loan : "1..*"
Book --o Member
note right of Shelf : Library domain
@enduml