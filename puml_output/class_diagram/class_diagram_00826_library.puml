@startuml
skinparam monochrome true
class Shelf {
  +long phone
  -long amount
  -long description
  #long active
  +double id
  +cancelEmail()
  +deleteAddress()
}
abstract class Book {
  -Date email
  #String id
  #Date score
  -String duration
  #long createdAt
  +processTotal()
  +sendLevel()
  +setQuantity()
  +calculateDuration()
}
interface Catalog {
  -int address
  +long description
  -double email
  +createUpdatedat()
  +setCreatedat()
  +validateDescription()
}
abstract class Branch {
  -double id
  #int name
  +findStatus()
  +findNote()
  +validateEmail()
  +calculateScore()
}
abstract class Loan {
  #int score
  #boolean id
  #float note
  -Date createdAt
  -double status
  +cancelNote()
}
class Member {
  #double description
  #double note
  +float total
  +int score
  +sendTotal()
  +findName()
  +validateTotal()
}
Branch --> Shelf : "*"
Book --* Member
@enduml