@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
interface Librarian {
  +boolean score
  +int note
  +cancelCode()
  +deleteId()
  +updateId()
  +getType()
}
class Author {
  -double name
  #double email
  +calculateLevel()
  +updateEmail()
}
class Book {
  +boolean active
  +boolean level
  #double quantity
  -long total
  -double type
  +deleteActive()
  +calculateType()
  +getActive()
  +processNote()
}
interface Member {
  #int updatedAt
  -long createdAt
  -float amount
  #long duration
  +validatePrice()
  +createScore()
  +deleteType()
  +updatePhone()
}
class Renewal {
  -int quantity
  -boolean status
  +cancelCode()
  +getNote()
  +saveId()
}
Book --* Author
Renewal ..|> Book
Librarian --* Book
@enduml