@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
interface Librarian {
  +boolean score
  +int note
  +processCode()
  +validateId()
  +getEmail()
  +processNote()
}
interface Author {
  -double createdAt
  +boolean total
  +boolean amount
  #double level
  -long quantity
  +processNote()
  +processActive()
  +createUpdatedat()
  +updateAmount()
}
class Book {
  #long type
  #Date quantity
  -Date address
  +findCreatedat()
  +getQuantity()
}
class Member {
  -String updatedAt
  -Date address
  -int phone
  -boolean type
  +updateId()
  +findPhone()
  +validateUpdatedat()
}
abstract class Renewal {
  +boolean active
  #double duration
  #long description
  +getAddress()
  +validateCreatedat()
  +deleteAddress()
  +createUpdatedat()
}
Member ..|> Author
note right of Librarian : Library domain
@enduml