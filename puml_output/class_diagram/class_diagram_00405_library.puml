@startuml
skinparam monochrome true
class Author {
  -float code
  #String id
  #boolean price
  +deletePrice()
  +createStatus()
}
abstract class Member {
  -double status
  +float level
  +float amount
  -int description
  +deleteCreatedat()
  +sendTotal()
  +processActive()
}
abstract class Book {
  #long score
  +double phone
  #String active
  +deleteScore()
}
class Shelf {
  +long description
  +double total
  +deleteEmail()
  +cancelLevel()
}
interface Librarian {
  #float id
  +int type
  +processCode()
}
class Catalog {
  #int quantity
  -String score
  +createId()
  +createEmail()
  +createTotal()
}
class Loan {
  #Date phone
  -float active
  -String updatedAt
  +boolean note
  +double code
  +saveName()
}
Member --|> Catalog
Author --|> Librarian
Librarian --* Book
note right of Author : Library domain
@enduml