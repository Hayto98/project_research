@startuml
skinparam monochrome true
class Author {
  -float code
  #String id
  #boolean price
  +deleteScore()
  +saveCode()
}
class Member {
  +boolean type
  +Date address
  +cancelId()
  +calculateAmount()
}
class Book {
  +int type
  #Date createdAt
  -double quantity
  +calculateUpdatedat()
  +findLevel()
  +createEmail()
  +createCode()
}
interface Shelf {
  #String active
  +int phone
  #Date amount
  -Date price
  +validateCode()
}
abstract class Librarian {
  -boolean email
  +int name
  +setPhone()
  +cancelActive()
  +calculateActive()
}
class Catalog {
  +int type
  +double active
  +validateEmail()
}
class Loan {
  -long score
  +long createdAt
  #long phone
  -double id
  +calculateCode()
  +findCode()
}
Member --|> Shelf
Librarian --* Catalog
Loan --|> Shelf
Member --|> Librarian
Shelf ..> Author : "1"
Member ..> Loan : "1"
@enduml