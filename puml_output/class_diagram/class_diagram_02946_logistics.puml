@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Vehicle {
  -boolean amount
  +long name
  #boolean total
  #double score
  +processAddress()
  +findStatus()
  +saveUpdatedat()
}
class Warehouse {
  +double code
  +double type
  #boolean updatedAt
  -boolean phone
  +getCreatedat()
  +sendAddress()
}
class Driver {
  -Date note
  +long updatedAt
  #long description
  #double createdAt
  #boolean price
  +sendDescription()
  +createQuantity()
  +getNote()
}
interface Inventory {
  #Date duration
  -float phone
  #int quantity
  +Date createdAt
  +cancelId()
  +findUpdatedat()
  +deletePrice()
  +setEmail()
}
abstract class Customer {
  -long note
  -float score
  +long price
  #int quantity
  -int status
  +calculateTotal()
  +findQuantity()
}
Customer --o Driver
Warehouse --|> Inventory
@enduml