@startuml
skinparam monochrome true
skinparam defaultFontSize 13
abstract class Course {
  -String total
  #double id
  #int quantity
  #boolean updatedAt
  +getActive()
  +validateActive()
}
interface Schedule {
  #int description
  #double createdAt
  +Date status
  #String phone
  +calculateDescription()
  +sendLevel()
  +validateStatus()
  +cancelType()
}
class Exam {
  -double id
  +String level
  +updateNote()
  +findAddress()
}
class Classroom {
  #boolean status
  #int amount
  -String quantity
  +cancelPrice()
  +updateScore()
  +calculateCode()
}
class Teacher {
  -float status
  -String phone
  +String id
  +sendAmount()
}
class Assignment {
  +float type
  +String createdAt
  -boolean quantity
  +setType()
  +sendDescription()
}
Teacher --* Assignment
Assignment --> Course : "*"
@enduml