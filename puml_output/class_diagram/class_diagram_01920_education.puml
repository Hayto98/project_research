@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Schedule {
  #Date createdAt
  -long duration
  #long note
  #Date name
  +saveAmount()
  +saveLevel()
  +setQuantity()
}
class Course {
  #int price
  +double quantity
  +Date phone
  +cancelActive()
  +calculateCode()
  +createAmount()
  +cancelNote()
}
class Grade {
  #long note
  #boolean phone
  +processAddress()
  +savePrice()
  +setActive()
  +updateAmount()
}
class Enrollment {
  -Date quantity
  +boolean id
  #String score
  +boolean name
  +setId()
}
class Library {
  -boolean level
  #double description
  +deleteTotal()
  +cancelTotal()
  +deleteAmount()
  +getPhone()
}
Enrollment --* Schedule
Enrollment --* Library
@enduml