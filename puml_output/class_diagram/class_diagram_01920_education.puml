@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Schedule {
  #Date createdAt
  -long duration
  #long note
  #Date name
  +processAmount()
  +updatePrice()
  +createPhone()
}
interface Course {
  #double updatedAt
  #double type
  -int description
  +setNote()
  +cancelPhone()
  +saveQuantity()
}
interface Grade {
  #float level
  #String address
  -Date email
  +boolean quantity
  #String id
  +sendName()
}
interface Enrollment {
  #Date code
  -Date level
  -float description
  +double quantity
  +setTotal()
  +getQuantity()
  +processPrice()
  +createScore()
}
class Library {
  #long email
  -int active
  +float id
  #double amount
  +deletePhone()
  +validateNote()
}
Schedule --> Grade : "1..*"
Grade ..> Schedule : "1..*"
note right of Schedule : Education domain
@enduml