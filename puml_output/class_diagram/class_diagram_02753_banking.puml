@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
interface Statement {
  +float code
  +float total
  +long createdAt
  #int status
  +findNote()
  +validateLevel()
}
interface Withdrawal {
  +boolean type
  +Date amount
  -float quantity
  -boolean name
  +calculateCode()
}
class Transaction {
  -boolean level
  #long code
  +validateAddress()
  +deleteNote()
}
class Branch {
  -long email
  +Date active
  #boolean phone
  +setPrice()
  +updateTotal()
  +saveAddress()
  +validateName()
}
class Account {
  #int active
  +long score
  +setNote()
  +validateScore()
  +getCode()
}
class Interest {
  #int price
  +int status
  +createDuration()
  +cancelCode()
  +calculatePrice()
}
class Teller {
  -float address
  +int description
  -boolean note
  #int quantity
  +cancelAmount()
}
Branch --|> Statement
Branch --* Account
@enduml