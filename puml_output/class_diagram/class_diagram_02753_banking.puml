@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
interface Statement {
  +float code
  +float total
  +long createdAt
  #int status
  +setActive()
  +validateType()
}
class Withdrawal {
  #double name
  -boolean updatedAt
  #String score
  -int amount
  +cancelCode()
}
abstract class Transaction {
  +long description
  #float email
  #long name
  -long level
  +saveActive()
  +calculatePhone()
}
class Branch {
  +long amount
  -double active
  -boolean name
  #Date level
  -String description
  +setLevel()
  +updateUpdatedat()
  +deleteEmail()
  +calculateType()
}
abstract class Account {
  +float quantity
  #double address
  +validateCreatedat()
  +updateTotal()
  +cancelActive()
}
class Interest {
  -String score
  +double name
  +saveActive()
  +cancelType()
  +validateActive()
}
class Teller {
  +double total
  +double createdAt
  +getUpdatedat()
  +setStatus()
  +findPhone()
  +getAmount()
}
Statement --> Transaction : "1"
Branch ..|> Interest
note right of Statement : Banking domain
@enduml