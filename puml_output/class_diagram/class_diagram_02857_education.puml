@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Department {
  #long amount
  +double updatedAt
  +double note
  +String phone
  -float description
  +cancelName()
  +setCode()
  +deleteDescription()
}
class Assignment {
  -boolean code
  #float duration
  -String name
  +int level
  +cancelActive()
  +cancelScore()
}
class Schedule {
  +double total
  +float id
  -Date active
  +processActive()
}
class Attendance {
  -Date address
  #int level
  -Date name
  +cancelAmount()
}
Assignment ..|> Schedule
Schedule --* Assignment
Attendance ..> Schedule : "1..*"
@enduml