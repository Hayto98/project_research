@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Department {
  #long amount
  +double updatedAt
  +double note
  +String phone
  -float description
  +findDuration()
  +deleteActive()
  +createCode()
}
class Assignment {
  #boolean code
  -String email
  +deleteScore()
}
interface Schedule {
  -String level
  #int email
  -int createdAt
  +saveCode()
  +updateDescription()
  +updateAddress()
  +saveLevel()
}
class Attendance {
  +float amount
  #int quantity
  #long name
  -long note
  +saveEmail()
  +createAmount()
  +setScore()
  +saveName()
}
Attendance --> Schedule : "1"
Schedule ..|> Attendance
Assignment ..|> Attendance
note right of Department : Education domain
@enduml