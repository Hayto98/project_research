@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
interface Album {
  +double price
  #boolean amount
  #Date name
  +findQuantity()
  +createUpdatedat()
  +processScore()
  +processName()
}
class Hashtag {
  +Date phone
  -int total
  +createType()
  +cancelPrice()
  +deleteUpdatedat()
}
interface User {
  #int quantity
  -long total
  #int amount
  -double type
  #String email
  +setDuration()
  +createLevel()
}
abstract class Like {
  #float level
  +boolean id
  -float status
  +float active
  -String description
  +processId()
  +validateId()
  +createAmount()
}
abstract class Notification {
  #int type
  +float amount
  +long quantity
  +double updatedAt
  +createLevel()
}
abstract class Profile {
  #float description
  -String code
  +getUpdatedat()
  +updateActive()
  +processScore()
}
class Message {
  #long price
  -long name
  +float status
  -long type
  +double email
  +getType()
  +saveDuration()
  +processAmount()
  +sendTotal()
}
Profile --o Message
Profile --* Notification
Like --|> Profile
Profile --|> Album
Notification --|> Message
note right of Album : Social Media domain
@enduml