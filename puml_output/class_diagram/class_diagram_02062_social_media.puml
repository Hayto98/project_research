@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
interface Album {
  +double price
  #boolean amount
  #Date name
  +sendUpdatedat()
  +updateLevel()
  +deleteName()
  +createLevel()
}
class Hashtag {
  -Date score
  -int note
  #float name
  -int code
  -long duration
  +deleteDescription()
  +updateId()
  +setQuantity()
  +processType()
}
class User {
  #double duration
  +double type
  -Date quantity
  +validateAmount()
  +sendAddress()
}
class Like {
  #double note
  #float id
  -boolean amount
  +String code
  #boolean email
  +findType()
  +sendQuantity()
}
class Notification {
  +long name
  +float phone
  -int code
  #double quantity
  -Date note
  +createEmail()
  +updateType()
  +cancelAddress()
  +validateActive()
}
class Profile {
  +double updatedAt
  +long id
  #double quantity
  +validateCreatedat()
}
class Message {
  +float status
  #double address
  #long name
  -double updatedAt
  +setStatus()
}
Message --> User : "1..*"
User ..|> Message
User --o Album
Like --o Album
@enduml