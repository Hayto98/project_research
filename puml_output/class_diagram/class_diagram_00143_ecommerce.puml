@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Review {
  +boolean name
  -String phone
  -int id
  +int description
  +findNote()
}
class Shipment {
  +long address
  -double updatedAt
  #float createdAt
  +updateScore()
  +cancelQuantity()
  +processName()
}
class Return {
  +double score
  #float quantity
  #float amount
  #String level
  +cancelDuration()
  +sendCode()
  +deleteAmount()
  +createQuantity()
}
class Order {
  #boolean type
  +String address
  -long description
  +int duration
  -Date note
  +findActive()
  +createCreatedat()
  +saveTotal()
  +findAmount()
}
interface Warehouse {
  -int updatedAt
  -double quantity
  +sendDuration()
  +cancelId()
  +findPrice()
  +setDuration()
}
interface Category {
  +float name
  +String updatedAt
  #Date address
  +String status
  +createCreatedat()
  +createId()
}
class Cart {
  #long price
  +String score
  +String active
  -double address
  +processEmail()
}
Order --o Warehouse
Category --|> Warehouse
@enduml