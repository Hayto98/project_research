@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
interface Insurance {
  +long total
  +float active
  +cancelDuration()
}
abstract class Prescription {
  +String name
  +int type
  -double total
  +getName()
  +deleteLevel()
}
abstract class Nurse {
  #double email
  #int amount
  -int price
  +createQuantity()
  +saveActive()
}
class Hospital {
  -float duration
  +double score
  -Date total
  +calculateDuration()
  +setDescription()
}
class Doctor {
  #int quantity
  +long address
  -String id
  +saveUpdatedat()
}
Prescription --|> Hospital
Insurance ..> Doctor : "*"
note right of Insurance : Healthcare domain
@enduml