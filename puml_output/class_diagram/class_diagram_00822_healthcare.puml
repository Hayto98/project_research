@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
interface Insurance {
  +long total
  +float active
  +processEmail()
}
interface Prescription {
  +String level
  +int description
  -double name
  +String type
  +float total
  +saveDuration()
  +updateCreatedat()
}
abstract class Nurse {
  #double email
  #int amount
  -int price
  +deleteName()
  +processDescription()
}
interface Hospital {
  #boolean level
  #Date description
  +validateScore()
  +getPrice()
  +cancelEmail()
  +cancelCode()
}
abstract class Doctor {
  #int price
  #int status
  #float description
  +sendDuration()
  +validateDuration()
  +cancelType()
}
Prescription --* Doctor
Nurse --|> Insurance
@enduml