@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
abstract class Invoice {
  #int amount
  -boolean duration
  -boolean description
  +sendPhone()
  +calculatePhone()
}
interface Guest {
  -int createdAt
  -double note
  #float total
  +createLevel()
}
abstract class Amenity {
  -Date name
  +double level
  #double address
  +deleteDescription()
  +calculateLevel()
  +updateScore()
  +findCreatedat()
}
class CheckOut {
  +float duration
  -double id
  -String phone
  +float level
  -Date amount
  +sendCode()
  +createUpdatedat()
  +createDuration()
}
CheckOut --* Guest
Invoice ..> Amenity : "1..*"
note right of Invoice : Hotel domain
@enduml