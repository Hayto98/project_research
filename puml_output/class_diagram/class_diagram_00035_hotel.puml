@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
abstract class Invoice {
  #int amount
  -boolean duration
  -boolean description
  +sendAmount()
  +saveScore()
}
abstract class Guest {
  -double duration
  +float createdAt
  -double level
  #float note
  +updateLevel()
}
interface Amenity {
  -boolean createdAt
  -double name
  +int address
  -boolean phone
  +boolean description
  +cancelNote()
  +processTotal()
}
interface CheckOut {
  +float phone
  +float id
  +processType()
  +processLevel()
  +setStatus()
}
Amenity --* CheckOut
Invoice ..> Guest : "0..1"
@enduml