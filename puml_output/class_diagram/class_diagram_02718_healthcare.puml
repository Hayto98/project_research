@startuml
skinparam monochrome true
class MedicalRecord {
  +Date code
  -boolean name
  +findPhone()
  +processCreatedat()
  +validateQuantity()
  +deleteAmount()
}
class Doctor {
  -double address
  #String type
  +calculateCreatedat()
  +sendNote()
}
class Treatment {
  #long level
  +int quantity
  +cancelQuantity()
  +processDescription()
}
class Insurance {
  +long createdAt
  +boolean status
  +double quantity
  #float name
  +long id
  +sendLevel()
  +updateLevel()
}
interface Billing {
  #long address
  #String quantity
  #boolean status
  +getScore()
  +saveDescription()
}
class Prescription {
  -long description
  +long quantity
  +long id
  +processType()
  +saveAddress()
  +calculateQuantity()
  +createPhone()
}
Billing ..|> MedicalRecord
MedicalRecord --o Doctor
Insurance --* Billing
@enduml