@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Return {
  +long id
  #double status
  #long level
  +updateLevel()
  +sendNote()
  +setDuration()
  +saveUpdatedat()
}
class Category {
  #float score
  +boolean phone
  +double status
  +boolean note
  +long active
  +savePhone()
  +cancelName()
  +calculateAddress()
}
class Review {
  #Date createdAt
  +float note
  -int address
  +calculatePrice()
  +updateScore()
}
class Coupon {
  -float amount
  #boolean createdAt
  +calculateTotal()
  +cancelDuration()
}
class Shipment {
  #String email
  #float score
  +float address
  +findAmount()
  +cancelPrice()
  +saveStatus()
  +processScore()
}
class Customer {
  #float code
  +boolean score
  +calculateDescription()
}
interface Order {
  +Date amount
  #long name
  #Date description
  +getAddress()
  +updateType()
}
Return ..|> Order
Category ..> Return : "*"
Review --* Shipment
Customer --|> Coupon
Coupon ..> Category : "0..1"
@enduml