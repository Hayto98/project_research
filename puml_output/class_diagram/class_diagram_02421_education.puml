@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
interface Department {
  -double name
  -String note
  +long price
  +saveStatus()
  +saveCreatedat()
}
class Student {
  -double duration
  #Date address
  #Date amount
  +deleteLevel()
  +createCode()
  +sendScore()
  +processCreatedat()
}
interface Grade {
  #double status
  -boolean duration
  +float address
  #boolean phone
  +processUpdatedat()
}
abstract class Teacher {
  +float createdAt
  +String total
  #int type
  #long quantity
  +getType()
  +findType()
}
class Assignment {
  -int name
  #int type
  +Date createdAt
  +boolean score
  +deleteQuantity()
  +setPrice()
  +processEmail()
  +createLevel()
}
interface Course {
  #Date score
  -float createdAt
  #String level
  +String status
  -double name
  +sendCreatedat()
  +processDescription()
}
class Attendance {
  #Date type
  -float amount
  +boolean updatedAt
  +updateDescription()
  +updateEmail()
  +calculateTotal()
  +validateLevel()
}
Grade ..|> Student
Attendance --|> Department
Student --o Assignment
Assignment ..|> Grade
Teacher --o Grade
@enduml