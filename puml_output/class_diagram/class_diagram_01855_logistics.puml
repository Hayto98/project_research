@startuml
skinparam monochrome true
class FuelLog {
  #long address
  -float duration
  -double type
  +updateAmount()
  +processNote()
  +processDescription()
}
class Route {
  -double address
  -int quantity
  -Date name
  +processLevel()
  +createActive()
  +createDuration()
}
class Shipment {
  +boolean email
  -long level
  #boolean status
  +float score
  +updateScore()
  +createQuantity()
  +getAddress()
}
class DeliveryNote {
  +Date type
  #float duration
  #Date score
  +double quantity
  -float address
  +sendScore()
  +validateCode()
  +updateDescription()
}
DeliveryNote --|> FuelLog
Route --|> Shipment
DeliveryNote --|> Shipment
@enduml