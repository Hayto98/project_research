@startuml
skinparam monochrome true
class FuelLog {
  #long address
  -float duration
  -double type
  +saveQuantity()
  +createUpdatedat()
  +validateQuantity()
}
class Route {
  #float note
  -double total
  -double createdAt
  +long price
  +cancelStatus()
  +saveStatus()
  +deleteActive()
}
abstract class Shipment {
  -String level
  #double updatedAt
  -float email
  -boolean quantity
  +saveAddress()
  +getDuration()
  +findStatus()
}
abstract class DeliveryNote {
  -boolean score
  #double phone
  +String price
  +boolean description
  +double createdAt
  +calculateType()
}
DeliveryNote --o Route
Route --> DeliveryNote : "0..1"
note right of FuelLog : Logistics domain
@enduml