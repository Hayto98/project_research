@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
interface Loan {
  -Date quantity
  -boolean status
  #int phone
  -double total
  +long amount
  +findUpdatedat()
}
class Shelf {
  -Date price
  +boolean duration
  -long status
  +updateAddress()
  +calculateActive()
  +validateScore()
  +calculateCreatedat()
}
class Librarian {
  -boolean createdAt
  -long address
  +findTotal()
  +cancelAmount()
  +saveTotal()
  +sendQuantity()
}
interface Reservation {
  #float type
  -String note
  #double price
  +long updatedAt
  -double email
  +setLevel()
  +getScore()
  +cancelUpdatedat()
}
Reservation --o Loan
Loan ..> Reservation : "1..*"
Loan --o Librarian
note right of Loan : Library domain
@enduml