@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
interface Loan {
  -Date quantity
  -boolean status
  #int phone
  -double total
  +long amount
  +createTotal()
}
class Shelf {
  #double description
  #String price
  +updateAddress()
  +deleteLevel()
  +getName()
}
class Librarian {
  #float address
  -boolean note
  -int updatedAt
  +String duration
  +long price
  +cancelActive()
  +createEmail()
  +cancelPhone()
  +calculateCreatedat()
}
abstract class Reservation {
  #double duration
  -double amount
  -int total
  -boolean active
  -String quantity
  +setLevel()
  +calculateCreatedat()
  +getAddress()
  +createDuration()
}
Loan --|> Librarian
Shelf ..> Librarian : "*"
Reservation --o Loan
@enduml