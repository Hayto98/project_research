@startuml
skinparam shadowing true
abstract class Message {
  #int price
  #long note
  -String phone
  #Date updatedAt
  +sendEmail()
  +setPrice()
  +findActive()
}
interface User {
  -String level
  +boolean createdAt
  +updateEmail()
  +calculateName()
  +findAddress()
  +getPhone()
}
abstract class Follower {
  #long quantity
  +Date level
  +Date duration
  +calculateId()
}
interface Report {
  #Date amount
  #float score
  +long createdAt
  -double updatedAt
  +sendCreatedat()
  +validateType()
  +deleteLevel()
}
abstract class Group {
  #float score
  -double name
  -boolean status
  +calculatePrice()
  +saveNote()
}
Message --o Report
Report --|> User
Group ..|> Follower
@enduml