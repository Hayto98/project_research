@startuml
skinparam shadowing true
abstract class Message {
  #int price
  #long note
  -String phone
  #Date updatedAt
  +updateType()
  +cancelLevel()
  +getLevel()
}
class User {
  +double id
  -float updatedAt
  +long price
  #long total
  #long address
  +saveDescription()
}
class Follower {
  -int duration
  #Date active
  +updateDuration()
  +setEmail()
}
class Report {
  +Date quantity
  -double type
  -boolean price
  +boolean amount
  +boolean name
  +calculateType()
}
abstract class Group {
  +double id
  +Date level
  #Date quantity
  +calculateId()
  +setType()
}
Follower --* User
Group --* Follower
note right of Message : Social Media domain
@enduml