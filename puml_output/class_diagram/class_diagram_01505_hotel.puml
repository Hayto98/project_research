@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
abstract class Room {
  #boolean price
  +double type
  #long phone
  +Date updatedAt
  #long level
  +deleteStatus()
  +sendDuration()
}
class Restaurant {
  +Date id
  +double email
  +long address
  +findPhone()
  +getNote()
  +updateActive()
}
interface Housekeeping {
  #String quantity
  +double id
  +double score
  +boolean status
  +long email
  +cancelId()
  +getScore()
  +updateType()
  +saveQuantity()
}
abstract class Booking {
  +String total
  #float id
  +long note
  +int address
  +double description
  +saveStatus()
  +findScore()
  +sendEmail()
}
class Service {
  #float score
  -double description
  +Date id
  #double type
  +setId()
}
Restaurant --o Booking
Booking ..> Housekeeping : "*"
Booking --|> Room
note right of Room : Hotel domain
@enduml