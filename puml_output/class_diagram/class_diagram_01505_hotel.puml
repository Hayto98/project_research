@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
abstract class Room {
  #boolean price
  +double type
  #long phone
  +Date updatedAt
  #long level
  +saveQuantity()
  +findEmail()
}
class Restaurant {
  +Date createdAt
  +double id
  +long email
  -Date address
  +setUpdatedat()
  +processTotal()
  +getTotal()
}
interface Housekeeping {
  #String quantity
  +double id
  +double score
  +boolean status
  +long email
  +setPhone()
  +sendLevel()
  +updatePrice()
  +calculateId()
}
interface Booking {
  -double type
  +Date quantity
  #double duration
  +getEmail()
  +saveType()
  +createScore()
}
class Service {
  +double email
  -float updatedAt
  #Date amount
  +setActive()
}
Service --|> Housekeeping
Housekeeping ..> Restaurant : "1"
Booking --o Housekeeping
Restaurant --|> Booking
@enduml