@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Branch {
  +int quantity
  #int phone
  +sendStatus()
  +deleteLevel()
}
class Author {
  -Date name
  +String description
  +setType()
  +sendActive()
}
class Librarian {
  -String address
  -String active
  +double id
  #Date score
  +findActive()
  +findScore()
}
class Member {
  -float createdAt
  -boolean type
  +cancelName()
  +deleteId()
  +setDescription()
  +deleteAddress()
}
class Renewal {
  #String score
  #long address
  +createQuantity()
  +getLevel()
}
abstract class Reservation {
  -boolean address
  -float updatedAt
  -float quantity
  +double note
  +sendAddress()
  +findDescription()
  +saveAmount()
  +createActive()
}
interface Fine {
  #int id
  #long price
  +double status
  -Date code
  #int createdAt
  +findActive()
  +createDuration()
  +sendPhone()
}
Author ..> Reservation : "0..1"
Reservation --|> Member
Renewal --|> Branch
Member ..|> Fine
Fine ..|> Branch
@enduml