@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class User {
  #int code
  #boolean createdAt
  #int quantity
  #int address
  -String duration
  +cancelCode()
  +processDescription()
  +saveCreatedat()
  +getActive()
}
class Message {
  -boolean type
  #double amount
  #long email
  -long total
  +createLevel()
  +saveEmail()
  +cancelActive()
  +savePrice()
}
abstract class Like {
  +Date name
  #Date phone
  -float status
  #int createdAt
  -long updatedAt
  +validateAddress()
  +saveQuantity()
}
abstract class Report {
  +boolean level
  #float type
  #String email
  #float amount
  +getDuration()
  +cancelType()
}
User --o Like
User ..|> Message
Like ..> Report : "1"
@enduml