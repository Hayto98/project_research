@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class User {
  #int code
  #boolean createdAt
  #int quantity
  #int address
  -String duration
  +processQuantity()
  +validateCode()
  +createType()
  +deleteEmail()
}
abstract class Message {
  -long score
  -Date level
  +boolean type
  #double address
  +findName()
  +validateStatus()
  +updateUpdatedat()
  +getActive()
}
class Like {
  -int type
  -boolean email
  -boolean amount
  +createAmount()
  +setDuration()
  +findName()
  +cancelUpdatedat()
}
abstract class Report {
  +float score
  -int price
  +findCode()
  +validateCreatedat()
  +findNote()
}
Message --|> User
Like ..> Report : "1..*"
note right of User : Social Media domain
@enduml