@startuml
skinparam defaultFontSize 13
interface DeliveryNote {
  -String price
  -Date total
  +Date status
  +validateDuration()
  +processCreatedat()
  +getCode()
}
class Package {
  +Date type
  #boolean name
  -double createdAt
  #long quantity
  -double email
  +saveLevel()
  +calculateCode()
  +validateName()
  +processName()
}
interface Manifest {
  #String quantity
  -boolean phone
  +float total
  +cancelDescription()
}
abstract class Vehicle {
  -double address
  #boolean duration
  -int amount
  #int createdAt
  +deleteEmail()
}
class Driver {
  +double active
  +boolean status
  -double note
  +long code
  -String total
  +findPrice()
  +updateAddress()
  +getStatus()
}
Package --|> DeliveryNote
@enduml