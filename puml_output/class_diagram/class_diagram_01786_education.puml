@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Enrollment {
  +double quantity
  #double duration
  +Date description
  +Date price
  #double total
  +createCreatedat()
}
class Course {
  +float phone
  #int active
  +updateId()
  +validateEmail()
}
interface Department {
  +boolean email
  +float phone
  +long duration
  #float id
  +validatePhone()
  +findLevel()
  +updateType()
  +updateCreatedat()
}
class Classroom {
  +boolean description
  #float status
  +double code
  +updateScore()
  +validateScore()
  +calculateTotal()
}
class Assignment {
  -long quantity
  #int name
  +getUpdatedat()
}
Classroom --* Assignment
Course --o Department
Enrollment --|> Department
note right of Enrollment : Education domain
@enduml