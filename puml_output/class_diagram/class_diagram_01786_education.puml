@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Enrollment {
  +double quantity
  #double duration
  +Date description
  +Date price
  #double total
  +deleteId()
}
class Course {
  -Date email
  #int level
  #int status
  +deleteTotal()
  +getName()
}
class Department {
  #Date phone
  -float email
  +calculateStatus()
  +updateAddress()
  +calculateTotal()
}
class Classroom {
  +long id
  #float description
  -long score
  -Date createdAt
  +sendPrice()
  +getPrice()
}
abstract class Assignment {
  #int createdAt
  +String description
  +boolean updatedAt
  +setNote()
}
Assignment ..|> Department
Assignment --o Classroom
Enrollment --* Assignment
@enduml