@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class FuelLog {
  #boolean name
  #long status
  +double score
  +boolean address
  +processActive()
  +updateCreatedat()
  +processScore()
}
class Depot {
  -boolean total
  -long quantity
  +createDescription()
  +validateTotal()
}
class Driver {
  -long level
  #boolean phone
  #float total
  +cancelNote()
  +findPrice()
  +createDescription()
}
interface Package {
  -long active
  #boolean description
  #int note
  +Date type
  +createId()
  +sendUpdatedat()
  +calculateActive()
  +createNote()
}
class Vehicle {
  +long updatedAt
  #Date phone
  #long price
  +findCode()
  +getCode()
  +getTotal()
}
class DeliveryNote {
  #float description
  -float active
  #double quantity
  -float level
  +deleteCode()
}
interface Inventory {
  -float duration
  -float type
  #boolean id
  +boolean phone
  +float amount
  +saveLevel()
  +calculateCode()
  +deleteScore()
}
Driver ..> DeliveryNote : "*"
Inventory --|> DeliveryNote
DeliveryNote --* Vehicle
Vehicle ..> Depot : "1..*"
Depot --|> Package
@enduml