@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Beneficiary {
  #double phone
  #double type
  +boolean email
  +boolean createdAt
  -Date duration
  +setAddress()
}
interface Transaction {
  +String name
  -double code
  +getQuantity()
  +findAmount()
  +updateTotal()
}
abstract class Loan {
  +String code
  #long level
  -double id
  +long note
  +boolean updatedAt
  +processPhone()
  +processEmail()
  +getAddress()
  +findPhone()
}
class Withdrawal {
  -Date status
  #double updatedAt
  -String level
  +deleteStatus()
}
Loan --> Withdrawal : "1"
Withdrawal --> Transaction : "0..1"
Beneficiary --* Loan
@enduml