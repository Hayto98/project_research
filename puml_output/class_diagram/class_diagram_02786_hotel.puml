@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Guest {
  +float createdAt
  +boolean description
  -long status
  +getPhone()
  +updateTotal()
}
abstract class Payment {
  +int status
  #boolean type
  -long updatedAt
  +processTotal()
  +cancelId()
  +findEmail()
  +calculateQuantity()
}
class Service {
  -double amount
  -int id
  +int updatedAt
  #String description
  -boolean total
  +calculateNote()
}
class Staff {
  +Date createdAt
  #Date code
  +String note
  +long duration
  +cancelDuration()
  +processPhone()
  +processUpdatedat()
}
Service --o Payment
Service --o Guest
Guest --o Payment
@enduml