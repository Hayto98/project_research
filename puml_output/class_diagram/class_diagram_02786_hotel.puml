@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Guest {
  +float createdAt
  +boolean description
  -long status
  +calculatePhone()
  +calculateUpdatedat()
}
class Payment {
  -double updatedAt
  -double status
  #int duration
  -int total
  +boolean email
  +deleteScore()
  +calculateTotal()
}
abstract class Service {
  -boolean updatedAt
  +int duration
  +long description
  +String code
  +updateStatus()
  +saveId()
  +setName()
  +createPhone()
}
class Staff {
  -String phone
  -double note
  -boolean total
  #String email
  #float id
  +calculateNote()
}
Service ..|> Staff
Guest --o Service
Guest --> Staff : "0..1"
note right of Guest : Hotel domain
@enduml