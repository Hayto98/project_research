@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
abstract class Coupon {
  #long description
  +String address
  +int duration
  +boolean total
  +String note
  +findTotal()
  +updateLevel()
  +calculateNote()
}
interface Shipment {
  -float email
  #float updatedAt
  #double code
  #String createdAt
  +String phone
  +findEmail()
}
class Cart {
  #String total
  #int status
  +double quantity
  -double updatedAt
  +validateScore()
  +deleteLevel()
  +findScore()
}
class Wishlist {
  -String id
  #Date name
  +String description
  #float quantity
  +validateQuantity()
  +processDuration()
  +calculateEmail()
  +updateDuration()
}
class Warehouse {
  -double address
  +long code
  #String amount
  +findType()
  +calculateCode()
  +setQuantity()
}
class Customer {
  -int note
  -boolean price
  +Date active
  +processAmount()
  +cancelCode()
  +setCode()
  +saveUpdatedat()
}
class Order {
  #String active
  +float description
  +createName()
  +createDuration()
}
Shipment ..|> Warehouse
Wishlist --> Cart : "1"
Coupon --> Warehouse : "0..1"
Warehouse --* Shipment
Coupon --> Wishlist : "1"
Customer --o Cart
@enduml