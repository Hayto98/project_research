@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
abstract class Coupon {
  #long description
  +String address
  +int duration
  +boolean total
  +String note
  +createCreatedat()
  +sendScore()
  +processEmail()
}
class Shipment {
  -float createdAt
  #float phone
  +saveName()
  +setStatus()
  +setName()
  +savePhone()
}
abstract class Cart {
  #String quantity
  #int updatedAt
  +processPrice()
  +processPhone()
}
class Wishlist {
  +float code
  -double address
  +Date id
  #String name
  +findNote()
}
class Warehouse {
  +long name
  +Date id
  +double duration
  +updateEmail()
  +sendName()
  +createPrice()
  +createUpdatedat()
}
abstract class Customer {
  #float active
  -String type
  -Date description
  #String email
  +float createdAt
  +saveName()
  +updateLevel()
}
class Order {
  -boolean price
  +String score
  #boolean description
  #int amount
  #float note
  +validateCode()
  +calculateScore()
}
Customer --o Cart
Coupon ..> Warehouse : "0..1"
note right of Coupon : Ecommerce domain
@enduml