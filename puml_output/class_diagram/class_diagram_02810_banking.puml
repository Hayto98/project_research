@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Customer {
  #Date address
  +int updatedAt
  +saveAddress()
  +getCode()
  +calculateDuration()
  +processNote()
}
abstract class Interest {
  +boolean id
  #int level
  #double score
  +Date createdAt
  +boolean email
  +setNote()
  +updateActive()
}
class Deposit {
  #boolean quantity
  +int price
  #String email
  +long total
  #long amount
  +cancelEmail()
  +validateQuantity()
  +createDescription()
  +saveId()
}
abstract class Branch {
  -boolean score
  -long note
  -float total
  -double createdAt
  +boolean email
  +setEmail()
  +validateUpdatedat()
}
abstract class Teller {
  -float createdAt
  +double id
  +float code
  +getStatus()
  +sendTotal()
}
abstract class Transaction {
  #long amount
  -double type
  +float score
  +processEmail()
}
interface Withdrawal {
  -long total
  #long updatedAt
  +createUpdatedat()
  +createPrice()
  +deleteScore()
  +setCode()
}
Withdrawal --o Interest
Customer --o Branch
Customer --o Transaction
@enduml