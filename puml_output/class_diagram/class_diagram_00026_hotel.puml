@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Housekeeping {
  -long type
  #String code
  -String status
  +findType()
  +setNote()
  +validateActive()
}
class Guest {
  #long price
  -boolean description
  +setNote()
  +getLevel()
  +deleteEmail()
}
interface Staff {
  #long quantity
  #boolean phone
  +float address
  -int id
  #Date total
  +validateActive()
  +saveScore()
  +setNote()
}
class Booking {
  -Date quantity
  -double active
  +getCreatedat()
  +setEmail()
  +saveQuantity()
}
Housekeeping --> Staff : "1..*"
note right of Housekeeping : Hotel domain
@enduml