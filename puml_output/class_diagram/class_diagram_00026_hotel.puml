@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Housekeeping {
  -long type
  #String code
  -String status
  +getStatus()
  +createLevel()
  +getPrice()
}
abstract class Guest {
  #int note
  #String phone
  +findType()
  +updateQuantity()
  +validateCode()
  +getDescription()
}
class Staff {
  #int score
  -boolean email
  -long status
  -long note
  +double id
  +saveUpdatedat()
  +saveActive()
  +sendTotal()
}
abstract class Booking {
  #Date active
  #String address
  #double phone
  +getQuantity()
  +validatePhone()
  +cancelAddress()
}
Staff --* Guest
Housekeeping --|> Booking
Staff ..> Booking : "1..*"
@enduml