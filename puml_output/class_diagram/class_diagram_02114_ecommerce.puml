@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Shipment {
  +boolean code
  #long status
  +boolean address
  #Date quantity
  -long level
  +findUpdatedat()
  +processName()
  +updateCode()
  +cancelId()
}
interface Cart {
  +long active
  -String updatedAt
  +boolean quantity
  +String score
  +deleteCode()
  +findId()
}
abstract class Order {
  #boolean name
  #long email
  -float createdAt
  -int description
  #boolean note
  +savePhone()
  +setCreatedat()
  +createDescription()
  +sendCreatedat()
}
interface Invoice {
  +String level
  #long code
  #double status
  -String price
  +createStatus()
  +findUpdatedat()
  +calculateAmount()
}
Invoice ..> Cart : "1"
Shipment --o Order
Invoice --o Shipment
@enduml