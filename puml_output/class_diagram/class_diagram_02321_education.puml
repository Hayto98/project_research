@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Course {
  +double note
  #Date code
  #String createdAt
  +findAddress()
}
class Department {
  -boolean status
  #String total
  #int score
  +updateLevel()
  +validatePhone()
}
interface Attendance {
  #boolean createdAt
  +Date total
  +long name
  +deleteId()
}
class Library {
  +long level
  #long score
  +saveDescription()
  +getUpdatedat()
}
class Assignment {
  +double price
  +float duration
  #double address
  -Date amount
  +double updatedAt
  +sendActive()
  +findAmount()
}
interface Exam {
  #String name
  -Date price
  +boolean duration
  #Date email
  +int address
  +getId()
  +validateDuration()
}
Assignment --|> Department
Assignment --* Exam
Attendance --* Exam
note right of Course : Education domain
@enduml