@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Course {
  +double note
  #Date code
  #String createdAt
  +saveDescription()
}
class Department {
  -boolean updatedAt
  #double status
  +getScore()
}
class Attendance {
  -float createdAt
  #int level
  +double phone
  +cancelDescription()
}
interface Library {
  +int name
  +String phone
  +processId()
}
interface Assignment {
  +Date address
  #int email
  +processPrice()
}
class Exam {
  +double price
  +float duration
  #double address
  -Date amount
  +double updatedAt
  +saveStatus()
  +createDescription()
}
Exam ..> Assignment : "*"
Course --> Library : "1"
Attendance --> Exam : "1"
@enduml