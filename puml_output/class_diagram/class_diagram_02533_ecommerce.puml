@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Return {
  +String status
  +long description
  #String note
  -float quantity
  +float active
  +cancelId()
  +deleteId()
}
interface Supplier {
  -boolean code
  #boolean amount
  +processScore()
  +findPrice()
  +updateLevel()
  +getCreatedat()
}
class Shipment {
  #double code
  +float address
  +getLevel()
  +setPhone()
  +updatePhone()
}
class Coupon {
  #Date total
  +int id
  +setCode()
  +updateDuration()
  +createStatus()
  +validateDuration()
}
class Warehouse {
  #double name
  #boolean description
  +boolean type
  +double total
  +calculateAddress()
  +sendDescription()
  +updateNote()
  +cancelId()
}
interface Order {
  +boolean type
  +long level
  +calculateScore()
}
Return --o Coupon
Supplier ..> Warehouse : "1..*"
Order ..> Supplier : "1..*"
Return --o Order
@enduml