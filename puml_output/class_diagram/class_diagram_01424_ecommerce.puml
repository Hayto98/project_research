@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Wishlist {
  +boolean amount
  +double total
  +deleteCode()
  +validatePrice()
  +createPrice()
}
class Order {
  #double quantity
  +float id
  #float address
  +double createdAt
  +savePhone()
  +processName()
  +calculateTotal()
  +validateCreatedat()
}
class Payment {
  -long updatedAt
  #double level
  -Date total
  #double note
  +calculateCreatedat()
  +calculateTotal()
}
interface Review {
  -Date type
  #long address
  -boolean total
  -Date active
  #long amount
  +setCreatedat()
  +deleteDescription()
}
Payment --> Review : "*"
Review --> Payment : "*"
Wishlist --o Review
@enduml