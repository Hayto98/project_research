@startuml
skinparam monochrome true
skinparam ArrowColor #555555
interface DeliveryNote {
  +Date type
  +long quantity
  +setTotal()
  +processAmount()
  +cancelAddress()
  +calculateStatus()
}
class Depot {
  #String type
  #double address
  #String score
  #Date updatedAt
  +deleteId()
  +validateTotal()
  +getStatus()
  +sendCreatedat()
}
class Warehouse {
  -float type
  +Date address
  #boolean duration
  +findStatus()
}
class Manifest {
  +float type
  +String address
  -long description
  -float total
  #String id
  +setCreatedat()
  +calculateCode()
}
class Tracking {
  -float total
  -int score
  +float address
  +processDuration()
  +getLevel()
  +cancelEmail()
  +sendActive()
}
class Inventory {
  #Date active
  #Date phone
  +processCreatedat()
  +validateDuration()
  +setCode()
}
class Package {
  -Date quantity
  #Date address
  +boolean id
  +long status
  +String total
  +findStatus()
}
Depot --|> Tracking
Tracking ..|> Warehouse
Package ..> Warehouse : "1"
@enduml