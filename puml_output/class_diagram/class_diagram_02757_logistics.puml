@startuml
skinparam monochrome true
skinparam ArrowColor #555555
interface DeliveryNote {
  +Date type
  +long quantity
  +createCode()
  +createAddress()
  +validateType()
  +cancelAddress()
}
interface Depot {
  #String level
  #Date id
  -Date price
  +createDuration()
  +cancelCreatedat()
  +processAddress()
  +processPhone()
}
class Warehouse {
  -long description
  +double note
  +getName()
}
class Manifest {
  #double quantity
  -boolean duration
  #int status
  #double active
  #Date amount
  +calculateQuantity()
  +deleteDescription()
  +processUpdatedat()
}
class Tracking {
  +Date duration
  #long id
  +validateCode()
  +sendScore()
  +cancelScore()
}
abstract class Inventory {
  -Date address
  #Date id
  +boolean status
  +long total
  +getCode()
}
class Package {
  +float level
  -Date name
  +double phone
  +validateAddress()
}
Package --o Inventory
Inventory ..|> DeliveryNote
DeliveryNote --> Tracking : "1"
DeliveryNote --> Manifest : "1"
note right of DeliveryNote : Logistics domain
@enduml