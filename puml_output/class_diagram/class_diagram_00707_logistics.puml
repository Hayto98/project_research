@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
abstract class Inventory {
  -Date email
  -int address
  +sendNote()
  +getNote()
  +processDuration()
}
interface Route {
  +float description
  #int price
  +sendAddress()
  +processCode()
  +processLevel()
  +processPrice()
}
interface Manifest {
  -double email
  #double address
  #boolean price
  +Date code
  +boolean updatedAt
  +setQuantity()
}
class Shipment {
  #float level
  +Date active
  #long price
  +cancelDescription()
  +findDuration()
  +updateName()
}
abstract class Vehicle {
  #long score
  +Date level
  +long updatedAt
  +setScore()
  +sendId()
}
Manifest --o Vehicle
Manifest --|> Route
@enduml