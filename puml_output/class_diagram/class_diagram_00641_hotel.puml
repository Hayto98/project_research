@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
abstract class Amenity {
  -Date duration
  #long createdAt
  +updateCreatedat()
  +saveQuantity()
}
class Service {
  -long total
  +long email
  +validateName()
}
class CheckOut {
  +String name
  #long note
  -long status
  -boolean code
  -String phone
  +processStatus()
  +setPrice()
}
class Booking {
  #String name
  #long status
  +long id
  +updateCode()
  +findLevel()
  +calculateUpdatedat()
  +processStatus()
}
class Payment {
  -double id
  -String createdAt
  +sendDuration()
  +findStatus()
  +getId()
}
abstract class Invoice {
  +Date createdAt
  +double note
  +double phone
  -double amount
  +cancelId()
  +saveStatus()
}
class CheckIn {
  +boolean level
  -boolean email
  -int score
  +setAddress()
}
Invoice --* Amenity
CheckIn --|> Amenity
note right of Amenity : Hotel domain
@enduml