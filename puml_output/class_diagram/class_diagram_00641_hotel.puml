@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
abstract class Amenity {
  -Date duration
  #long createdAt
  +deleteLevel()
  +validateNote()
}
class Service {
  -long address
  +long id
  #boolean total
  #String email
  +processQuantity()
  +processAmount()
  +deletePrice()
}
class CheckOut {
  #long status
  -long code
  -boolean phone
  -String duration
  +double active
  +processAmount()
}
abstract class Booking {
  +boolean createdAt
  +Date name
  +cancelUpdatedat()
}
class Payment {
  +String address
  #boolean note
  +validateNote()
  +deleteActive()
  +deleteQuantity()
  +validateStatus()
}
class Invoice {
  -double id
  -String createdAt
  +getCreatedat()
  +setId()
  +updateId()
}
class CheckIn {
  -Date id
  +double total
  +updateType()
  +findId()
  +cancelDuration()
}
Booking --o Amenity
Booking ..|> CheckIn
Payment ..> Amenity : "1"
@enduml