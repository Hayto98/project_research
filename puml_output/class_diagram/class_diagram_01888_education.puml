@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Library {
  -int email
  #float code
  +calculateId()
  +getStatus()
}
interface Department {
  -Date id
  +Date updatedAt
  +sendUpdatedat()
  +saveDuration()
  +createDescription()
}
class Classroom {
  +float level
  -Date amount
  -double code
  -boolean email
  #boolean quantity
  +createUpdatedat()
  +validateStatus()
  +cancelActive()
  +validateCode()
}
class Enrollment {
  #double updatedAt
  +float amount
  +cancelAddress()
  +createCode()
}
class Assignment {
  #double name
  +boolean note
  #String active
  +validateCode()
  +sendDescription()
}
class Book {
  +Date phone
  -Date address
  -String code
  +Date price
  +deleteId()
  +updatePhone()
  +createEmail()
  +getTotal()
}
Assignment ..> Classroom : "1"
Book --o Assignment
Book ..|> Department
Department --* Book
@enduml