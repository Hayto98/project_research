@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Library {
  -int email
  #float code
  +getActive()
  +setId()
}
class Department {
  -boolean amount
  #int address
  +long active
  -int level
  +findType()
  +processPrice()
  +cancelScore()
  +calculateActive()
}
interface Classroom {
  +boolean phone
  -int id
  #int updatedAt
  +deleteUpdatedat()
  +findCreatedat()
  +getNote()
}
interface Enrollment {
  -long createdAt
  -String id
  -String amount
  #double description
  #long level
  +getTotal()
}
class Assignment {
  #float duration
  #int phone
  +int code
  +long price
  +getLevel()
}
interface Book {
  +int updatedAt
  -String status
  +findQuantity()
  +setTotal()
}
Classroom ..|> Department
Book ..> Enrollment : "*"
note right of Library : Education domain
@enduml