@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
abstract class Attendance {
  +long active
  #int name
  +updateActive()
  +getTotal()
  +deleteCode()
  +calculateName()
}
class Course {
  -double description
  +double score
  #int level
  +float updatedAt
  #double status
  +cancelId()
}
class Student {
  #Date total
  +boolean address
  -long phone
  -Date name
  +getEmail()
  +calculateQuantity()
  +validateQuantity()
}
class Enrollment {
  +double type
  #double note
  #int phone
  -float email
  +int code
  +cancelCode()
}
class Teacher {
  -Date status
  -float email
  +calculateLevel()
  +calculateDescription()
  +saveDuration()
}
Attendance ..|> Student
Student --> Enrollment : "0..1"
@enduml