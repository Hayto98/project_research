@startuml
skinparam defaultFontSize 11
class Author {
  +int note
  #int total
  +boolean address
  #float phone
  -String type
  +getCreatedat()
  +setDuration()
  +processScore()
  +calculatePrice()
}
class Fine {
  +long quantity
  -Date email
  +sendCreatedat()
  +updateEmail()
  +updateType()
}
interface Shelf {
  -double amount
  -Date address
  #Date phone
  #Date active
  +updatePhone()
  +getAmount()
}
class Renewal {
  +double duration
  -boolean type
  -float active
  #boolean total
  -long address
  +findActive()
  +sendCode()
}
abstract class Publisher {
  -boolean name
  #Date email
  +setQuantity()
  +createLevel()
  +savePrice()
  +cancelEmail()
}
class Reservation {
  #double name
  #double active
  #Date quantity
  +setType()
}
Author --* Fine
Fine --* Author
Publisher --o Author
Author ..> Publisher : "1..*"
Publisher --> Renewal : "0..1"
@enduml