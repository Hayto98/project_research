@startuml
skinparam monochrome true
interface Interest {
  +int updatedAt
  -boolean phone
  #Date level
  -float total
  +saveDescription()
}
abstract class Loan {
  #boolean duration
  -String total
  +getDuration()
}
abstract class Transaction {
  +double type
  +Date address
  -double note
  +deleteAmount()
}
class Account {
  #int active
  #double phone
  +double price
  +int score
  +String duration
  +updateLevel()
  +validateTotal()
}
class Transfer {
  -Date id
  +float description
  +createTotal()
  +processPrice()
  +findStatus()
}
abstract class Deposit {
  #long code
  -int score
  #float phone
  #long email
  +sendQuantity()
  +cancelQuantity()
  +calculateId()
  +getCreatedat()
}
Account --|> Interest
Loan ..> Interest : "1"
note right of Interest : Banking domain
@enduml