@startuml
skinparam monochrome true
interface Interest {
  +int updatedAt
  -boolean phone
  #Date level
  -float total
  +findStatus()
}
class Loan {
  +String name
  #double total
  #int active
  -long quantity
  -String duration
  +deleteQuantity()
  +saveUpdatedat()
  +cancelId()
  +createName()
}
class Transaction {
  #long amount
  -Date id
  #double note
  +findDescription()
  +processUpdatedat()
  +createDescription()
  +calculateAmount()
}
class Account {
  +boolean amount
  -Date createdAt
  -int level
  +String status
  #float duration
  +deleteDuration()
  +findStatus()
}
class Transfer {
  #Date quantity
  +Date total
  -long note
  #Date price
  +sendStatus()
}
interface Deposit {
  -int level
  #float email
  #long active
  -boolean quantity
  +deleteUpdatedat()
  +getNote()
  +processType()
}
Interest --|> Loan
Account --|> Interest
@enduml