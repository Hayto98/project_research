@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
interface Supplier {
  -boolean description
  #double status
  +updatePrice()
  +getPhone()
}
class Wishlist {
  #float quantity
  #boolean email
  #double name
  #String status
  +cancelCreatedat()
  +setEmail()
  +setPhone()
}
class Warehouse {
  #long price
  -boolean createdAt
  +processDescription()
  +updateEmail()
}
interface Invoice {
  #boolean createdAt
  +double email
  +Date phone
  +getAddress()
  +updateAmount()
  +processAddress()
}
Invoice --|> Wishlist
Wishlist ..|> Invoice
@enduml