@startuml
skinparam shadowing true
class Restaurant {
  +double price
  +int code
  +findName()
  +cancelTotal()
  +saveLevel()
  +sendTotal()
}
abstract class Staff {
  -boolean type
  +Date id
  +int createdAt
  #int note
  +updateUpdatedat()
  +updateType()
}
class Service {
  #long note
  +double amount
  #long phone
  -boolean email
  +calculateDuration()
  +saveTotal()
}
interface Invoice {
  -long email
  -String active
  -String quantity
  #int updatedAt
  +sendDuration()
  +cancelTotal()
  +sendCreatedat()
  +saveDescription()
}
class CheckIn {
  +long code
  #Date active
  -String description
  +boolean id
  +createAddress()
  +getEmail()
  +findLevel()
  +setLevel()
}
abstract class Amenity {
  -String total
  +double id
  +validateDuration()
  +getCreatedat()
  +sendCode()
}
abstract class Booking {
  -Date code
  +int createdAt
  -boolean level
  +Date quantity
  -double duration
  +setDuration()
}
Booking --> Service : "1"
Invoice ..|> Service
Restaurant ..> Amenity : "0..1"
Booking ..> CheckIn : "*"
@enduml