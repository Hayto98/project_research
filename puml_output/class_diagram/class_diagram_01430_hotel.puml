@startuml
skinparam shadowing true
class Restaurant {
  +double price
  +int code
  +cancelId()
  +getNote()
  +sendAddress()
  +processId()
}
class Staff {
  #int total
  #boolean score
  +String updatedAt
  +String createdAt
  -double description
  +validateLevel()
  +cancelEmail()
}
interface Service {
  #Date status
  +boolean note
  #Date email
  -float score
  +sendQuantity()
  +updateAddress()
  +createType()
}
class Invoice {
  -Date code
  -boolean score
  #boolean description
  -float price
  +Date id
  +getName()
  +createDuration()
}
abstract class CheckIn {
  +int code
  +double note
  +calculateId()
}
class Amenity {
  #long status
  -boolean type
  +findTotal()
  +processCode()
  +updateCreatedat()
  +createCode()
}
class Booking {
  +Date createdAt
  -double type
  #String score
  +validateLevel()
  +setPrice()
  +createAmount()
}
Amenity ..> Booking : "0..1"
Booking ..> CheckIn : "*"
note right of Restaurant : Hotel domain
@enduml