@startuml
skinparam defaultFontSize 11
class Warehouse {
  -int duration
  -double price
  #Date level
  #int active
  +long updatedAt
  +getAmount()
  +updateQuantity()
  +updateDescription()
}
class Inventory {
  -Date duration
  +float email
  -Date id
  +cancelUpdatedat()
  +deleteCode()
}
interface Route {
  #int description
  -int level
  +updateQuantity()
}
class Manifest {
  #int score
  +Date price
  +String name
  +validateDuration()
  +getPrice()
}
class Tracking {
  +float level
  #Date email
  +double status
  #float quantity
  +createEmail()
  +findNote()
  +setDescription()
  +processName()
}
interface DeliveryNote {
  +float type
  +Date total
  -float address
  #long phone
  +validateAmount()
}
Route --o Inventory
DeliveryNote ..|> Warehouse
DeliveryNote --|> Route
note right of Warehouse : Logistics domain
@enduml