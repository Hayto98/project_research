@startuml
skinparam defaultFontSize 11
class Warehouse {
  -int duration
  -double price
  #Date level
  #int active
  +long updatedAt
  +saveLevel()
  +deleteEmail()
  +calculateEmail()
}
class Inventory {
  -int quantity
  #long createdAt
  #String description
  +createType()
  +calculateTotal()
  +updateDescription()
  +setQuantity()
}
class Route {
  +boolean duration
  #String updatedAt
  +float amount
  +createName()
  +processActive()
}
interface Manifest {
  +Date updatedAt
  +Date quantity
  +deleteType()
  +savePhone()
  +updatePhone()
  +createCode()
}
class Tracking {
  -boolean status
  +double updatedAt
  +validateAmount()
  +validateType()
  +savePrice()
}
class DeliveryNote {
  #Date quantity
  +double status
  +cancelPhone()
  +deleteName()
  +setQuantity()
  +cancelUpdatedat()
}
Warehouse --o Inventory
Warehouse ..> Tracking : "1..*"
Manifest --* DeliveryNote
Route --|> Warehouse
DeliveryNote ..> Route : "1..*"
@enduml