@startuml
skinparam defaultFontSize 11
class Loan {
  +double email
  +String note
  +cancelType()
  +processStatus()
  +validateDescription()
}
class Deposit {
  #long code
  +float amount
  #boolean phone
  +double type
  +double price
  +cancelPrice()
  +cancelId()
  +saveUpdatedat()
}
abstract class Account {
  #long address
  -float phone
  +calculateName()
  +createDescription()
}
abstract class Interest {
  -String id
  #long quantity
  #boolean level
  +String note
  +cancelNote()
}
class Card {
  #int email
  -long updatedAt
  -double type
  +float price
  -int active
  +findCode()
}
interface Withdrawal {
  -float active
  #long address
  +updatePrice()
}
Loan ..|> Account
Withdrawal --* Card
note right of Loan : Banking domain
@enduml