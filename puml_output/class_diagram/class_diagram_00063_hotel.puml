@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
abstract class Housekeeping {
  +boolean note
  +boolean active
  #Date type
  +updateDescription()
  +cancelCreatedat()
}
interface Staff {
  +float createdAt
  #int duration
  #String level
  #double address
  +getQuantity()
}
class CheckOut {
  +double status
  #Date score
  +boolean total
  -float address
  +int amount
  +updateDescription()
  +createName()
  +findAmount()
  +deleteLevel()
}
interface Room {
  -double price
  +double address
  #long total
  +validateScore()
}
abstract class CheckIn {
  +String createdAt
  +float type
  -long updatedAt
  #Date id
  #int phone
  +validateCreatedat()
  +deleteAmount()
}
class Service {
  -long active
  +float status
  #String email
  -long quantity
  +calculateLevel()
}
CheckOut --|> Service
CheckOut --* Staff
Service ..> Staff : "0..1"
Staff --|> Service
Service --> CheckOut : "1"
@enduml