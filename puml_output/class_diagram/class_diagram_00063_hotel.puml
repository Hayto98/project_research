@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
abstract class Housekeeping {
  +boolean note
  +boolean active
  #Date type
  +updateTotal()
  +sendLevel()
}
class Staff {
  +float createdAt
  #int duration
  #String address
  +setDuration()
  +createType()
  +saveStatus()
  +findScore()
}
interface CheckOut {
  #double address
  +int amount
  -int description
  -double note
  #int status
  +validateTotal()
  +createPrice()
  +deleteNote()
  +cancelQuantity()
}
class Room {
  +String price
  #long type
  +String createdAt
  +float level
  +createDuration()
  +findScore()
  +updateUpdatedat()
  +deletePrice()
}
class CheckIn {
  -long active
  +float status
  #String email
  -long quantity
  +calculateEmail()
}
class Service {
  -Date phone
  +Date createdAt
  +updateAmount()
  +getPhone()
}
Staff ..> Service : "1..*"
Staff --o CheckIn
note right of Housekeeping : Hotel domain
@enduml