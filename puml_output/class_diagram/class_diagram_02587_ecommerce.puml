@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Wishlist {
  +float note
  +double id
  -String createdAt
  +float price
  +calculateDuration()
  +cancelAddress()
  +validateCode()
}
abstract class Invoice {
  #Date address
  +String active
  +boolean duration
  -boolean note
  -float phone
  +cancelDescription()
}
abstract class Customer {
  +double id
  +double description
  +validateActive()
  +setName()
  +deletePhone()
}
class Cart {
  +int price
  -Date quantity
  #Date level
  #long email
  +findNote()
}
class Order {
  -boolean address
  #boolean code
  #long quantity
  #double name
  +findAddress()
  +updateUpdatedat()
  +saveCreatedat()
}
class Warehouse {
  -double description
  +float name
  +sendId()
  +deleteNote()
}
Order --|> Wishlist
Invoice ..|> Cart
note right of Wishlist : Ecommerce domain
@enduml