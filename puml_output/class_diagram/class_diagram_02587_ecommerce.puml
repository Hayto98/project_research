@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Wishlist {
  +float note
  +double id
  -String createdAt
  +float price
  +updateCreatedat()
  +setNote()
  +setId()
}
interface Invoice {
  -boolean phone
  -double code
  -Date type
  #int note
  +updateStatus()
}
interface Customer {
  -String duration
  #Date price
  +int score
  +double status
  +double description
  +findType()
  +processCreatedat()
  +calculateLevel()
}
class Cart {
  -int name
  #long amount
  +updateLevel()
  +setDuration()
  +createQuantity()
  +setCreatedat()
}
interface Order {
  #Date code
  +Date createdAt
  -float price
  +Date email
  +setCreatedat()
  +saveCreatedat()
  +setDescription()
}
interface Warehouse {
  #double score
  -Date name
  -float type
  +int address
  +sendId()
  +saveActive()
}
Invoice --* Wishlist
Cart ..|> Wishlist
@enduml