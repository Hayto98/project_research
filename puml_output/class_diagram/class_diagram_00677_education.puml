@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
interface Student {
  -float description
  -boolean type
  -long duration
  +updateCreatedat()
  +findAddress()
  +createScore()
}
interface Assignment {
  #float createdAt
  +String address
  #float description
  -double id
  +setType()
  +getLevel()
}
class Attendance {
  #int status
  -float description
  -float active
  +calculatePrice()
  +getAddress()
}
class Enrollment {
  #double price
  +Date id
  +float description
  +cancelQuantity()
  +calculateQuantity()
  +saveDuration()
  +updateTotal()
}
class Exam {
  -boolean score
  +int name
  -int level
  -float email
  +cancelPrice()
  +deleteAddress()
}
Assignment --|> Attendance
Attendance --|> Exam
@enduml