@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
interface Student {
  -float description
  -boolean type
  -long duration
  +updateUpdatedat()
  +sendDuration()
  +cancelPhone()
}
class Assignment {
  +float description
  #float id
  -double active
  +int level
  +saveCreatedat()
}
class Attendance {
  #int description
  -float active
  +updateScore()
  +calculateCode()
  +sendAmount()
  +calculateId()
}
class Enrollment {
  #long amount
  +long id
  #float type
  #boolean note
  +String total
  +validateLevel()
  +updateCreatedat()
  +createDescription()
}
abstract class Exam {
  #boolean updatedAt
  #long code
  +long description
  +getUpdatedat()
  +cancelType()
  +calculateAddress()
}
Attendance --o Assignment
Enrollment --> Assignment : "1..*"
Exam --* Attendance
note right of Student : Education domain
@enduml