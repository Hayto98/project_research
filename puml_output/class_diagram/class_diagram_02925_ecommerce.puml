@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Warehouse {
  -int name
  #Date code
  -long duration
  +findName()
}
class Shipment {
  -int code
  +double status
  +savePrice()
  +getPrice()
  +sendUpdatedat()
  +processDescription()
}
interface Invoice {
  +float duration
  #double active
  -int createdAt
  #float note
  +long id
  +findStatus()
  +validateScore()
}
class Return {
  #int quantity
  +int type
  +int note
  +createQuantity()
  +setType()
  +deleteAddress()
}
class Cart {
  +double type
  #double phone
  +validateCode()
  +getPrice()
  +sendDescription()
  +deleteCode()
}
Shipment ..> Warehouse : "0..1"
Return --* Cart
@enduml