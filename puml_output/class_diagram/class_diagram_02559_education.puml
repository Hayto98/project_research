@startuml
skinparam defaultFontSize 11
interface Department {
  #long level
  -Date total
  -double duration
  #long amount
  #Date name
  +cancelTotal()
  +calculateId()
}
class Attendance {
  -long id
  -long level
  #boolean email
  #boolean price
  -String code
  +processUpdatedat()
}
class Book {
  -Date phone
  +int duration
  #String name
  +createScore()
}
class Classroom {
  #double total
  +int code
  -long type
  -int address
  -float note
  +updateScore()
  +getStatus()
  +setScore()
}
interface Course {
  #Date name
  +String phone
  #long score
  +sendUpdatedat()
  +calculateCreatedat()
}
Department ..> Classroom : "1"
Department --o Course
Classroom --|> Department
note right of Department : Education domain
@enduml