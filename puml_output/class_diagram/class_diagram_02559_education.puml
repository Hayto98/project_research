@startuml
skinparam defaultFontSize 11
interface Department {
  #long level
  -Date total
  -double duration
  #long amount
  #Date name
  +processEmail()
  +getAddress()
}
abstract class Attendance {
  -String code
  #float active
  +setCreatedat()
  +deleteAmount()
  +getType()
}
class Book {
  +String note
  -int address
  -Date score
  +long level
  +saveEmail()
  +processType()
  +sendPrice()
}
class Classroom {
  #long name
  -double code
  +double email
  +deletePrice()
  +updateNote()
  +getAddress()
}
class Course {
  +long total
  -int quantity
  #String price
  +createAddress()
}
Course --|> Attendance
Book --|> Department
Course ..|> Book
@enduml