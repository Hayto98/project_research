@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Comment {
  #long address
  #float quantity
  +validateUpdatedat()
}
abstract class Group {
  +long amount
  #boolean description
  +createQuantity()
  +saveName()
}
class Message {
  -long duration
  #double name
  #int code
  +float score
  +String createdAt
  +setCreatedat()
  +updateCreatedat()
}
abstract class Post {
  #Date score
  #long note
  +getNote()
}
interface User {
  -long duration
  #float level
  -Date amount
  +cancelDescription()
  +getAddress()
}
class Notification {
  #int duration
  -String level
  +Date score
  +Date code
  #int status
  +processPhone()
  +sendScore()
  +sendEmail()
}
class Hashtag {
  -double updatedAt
  #long duration
  #double amount
  #int level
  +processStatus()
  +processAmount()
  +saveId()
  +calculateNote()
}
Message --> Group : "1"
Group ..> Comment : "1"
Post --o Comment
Post --* Notification
note right of Comment : Social Media domain
@enduml