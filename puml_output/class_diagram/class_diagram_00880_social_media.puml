@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Comment {
  #long address
  #float quantity
  +processCreatedat()
}
class Group {
  #int total
  +long name
  #boolean amount
  +calculateScore()
  +findScore()
}
class Message {
  +double note
  -boolean name
  -Date code
  +int score
  +findNote()
}
class Post {
  +Date createdAt
  -String updatedAt
  +sendLevel()
  +sendDuration()
  +saveDescription()
  +saveActive()
}
class User {
  #boolean id
  +boolean note
  +getStatus()
  +validateName()
}
class Notification {
  -boolean amount
  #boolean description
  +boolean name
  #float address
  +boolean duration
  +getAddress()
  +processCode()
}
class Hashtag {
  -float updatedAt
  #float quantity
  +saveType()
  +deleteEmail()
  +calculateActive()
}
Hashtag --* User
Message ..> Hashtag : "0..1"
Notification ..|> Group
Hashtag ..|> Notification
Hashtag --o Post
User --> Message : "*"
@enduml