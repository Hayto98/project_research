@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Review {
  #int level
  +long id
  -String phone
  +Date code
  -String email
  +createScore()
  +createPrice()
  +saveName()
  +setActive()
}
class Return {
  -int note
  +double id
  #boolean total
  +deleteScore()
  +sendDescription()
  +sendUpdatedat()
}
class Wishlist {
  +float code
  +double quantity
  +sendAddress()
}
interface Payment {
  -double name
  -String email
  -Date status
  +Date createdAt
  +findActive()
  +calculateActive()
  +cancelActive()
  +updateScore()
}
class Invoice {
  +double address
  -long note
  +setPhone()
  +validateAmount()
}
interface Cart {
  +boolean quantity
  #int type
  +String address
  -long code
  #float phone
  +deleteTotal()
  +validateName()
  +findName()
}
class Category {
  #boolean email
  +int duration
  +setPhone()
  +deletePrice()
  +deleteLevel()
  +sendUpdatedat()
}
Review --o Wishlist
Cart ..> Review : "0..1"
Review --* Cart
Invoice --* Wishlist
@enduml