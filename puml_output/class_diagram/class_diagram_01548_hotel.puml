@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
interface Payment {
  -String note
  +Date phone
  -Date status
  -int duration
  +sendAmount()
  +cancelDescription()
  +getUpdatedat()
}
class Housekeeping {
  -double status
  -int updatedAt
  #long amount
  -double note
  +float type
  +updateCode()
}
class Booking {
  #Date phone
  -long note
  +createQuantity()
  +calculatePrice()
  +findUpdatedat()
}
class Staff {
  -float code
  #String id
  +calculateAmount()
  +findUpdatedat()
  +findEmail()
  +deletePrice()
}
interface Room {
  #int amount
  +float status
  +String score
  +long updatedAt
  -int description
  +setLevel()
  +getId()
  +findId()
  +createTotal()
}
interface Invoice {
  #float active
  -long updatedAt
  -Date price
  #boolean id
  #String status
  +findScore()
  +updateCode()
}
Housekeeping --* Invoice
Staff ..|> Booking
Room --|> Booking
@enduml