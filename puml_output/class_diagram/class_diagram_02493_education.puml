@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
abstract class Grade {
  #boolean status
  +int duration
  +long score
  -long updatedAt
  +updateAddress()
  +setScore()
  +getName()
}
class Assignment {
  #String level
  -long createdAt
  +double email
  +setCode()
  +sendAddress()
}
class Teacher {
  #long updatedAt
  #boolean id
  -float score
  #boolean quantity
  -long phone
  +saveUpdatedat()
  +createScore()
}
abstract class Exam {
  #String email
  -int score
  +int type
  #double note
  #double description
  +deleteStatus()
  +findActive()
  +savePhone()
}
Exam --|> Assignment
Assignment --> Teacher : "1..*"
note right of Grade : Education domain
@enduml