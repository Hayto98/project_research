@startuml
skinparam defaultFontSize 13
class Beneficiary {
  #String address
  #Date amount
  -int phone
  -double code
  +cancelCreatedat()
}
class Loan {
  -Date createdAt
  #String total
  +savePhone()
}
class Deposit {
  +Date duration
  -boolean phone
  +Date level
  -boolean name
  #boolean score
  +updateActive()
  +processTotal()
}
class Statement {
  #float note
  +Date duration
  #Date phone
  +calculatePrice()
  +processId()
  +processNote()
  +updateStatus()
}
abstract class Withdrawal {
  -String name
  +double code
  +findType()
  +deletePrice()
  +cancelUpdatedat()
}
Withdrawal ..|> Beneficiary
Deposit ..|> Loan
Withdrawal --* Statement
@enduml