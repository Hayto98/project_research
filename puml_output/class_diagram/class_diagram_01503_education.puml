@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
abstract class Course {
  +boolean code
  #double address
  +int quantity
  +cancelDuration()
  +saveActive()
}
abstract class Classroom {
  +int level
  +boolean email
  -boolean createdAt
  +cancelCreatedat()
}
abstract class Library {
  +double quantity
  #double status
  -double note
  -int address
  +Date id
  +createQuantity()
  +calculateEmail()
}
class Student {
  +float updatedAt
  -float level
  +calculateDuration()
  +deleteDuration()
  +setType()
}
class Book {
  -Date address
  #Date code
  -int quantity
  -boolean createdAt
  +saveLevel()
  +updateDescription()
}
interface Assignment {
  +int code
  -double updatedAt
  +Date total
  +setName()
  +deletePhone()
  +getPrice()
  +setEmail()
}
class Department {
  #boolean active
  #String phone
  +boolean id
  +validateTotal()
  +saveStatus()
  +getDescription()
  +setStatus()
}
Course ..|> Department
Assignment --* Department
Assignment ..|> Library
Library --* Book
@enduml