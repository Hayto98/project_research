@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
abstract class Course {
  +boolean code
  #double address
  +int quantity
  +saveScore()
  +processActive()
}
class Classroom {
  #long createdAt
  #String updatedAt
  -float amount
  -Date name
  +createStatus()
  +processAddress()
  +getAmount()
  +calculateActive()
}
abstract class Library {
  -String price
  +String note
  +boolean createdAt
  +float description
  -float updatedAt
  +sendNote()
  +deleteDescription()
  +createAddress()
}
class Student {
  -boolean createdAt
  +float price
  +boolean note
  #int duration
  +updateTotal()
}
class Book {
  #double type
  +float note
  -String name
  +sendPhone()
  +getDuration()
}
class Assignment {
  #float duration
  +Date note
  +getId()
  +updatePhone()
  +findEmail()
  +deleteAddress()
}
class Department {
  +boolean type
  +String active
  -boolean quantity
  +Date name
  +getStatus()
  +getStatus()
  +cancelId()
  +createQuantity()
}
Student ..> Course : "0..1"
Library --> Department : "1..*"
Assignment --> Library : "*"
Library --o Classroom
Book --> Student : "0..1"
note right of Course : Education domain
@enduml