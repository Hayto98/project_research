@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Prescription {
  +Date amount
  -int address
  +double description
  #int note
  +String status
  +sendCode()
  +deleteLevel()
  +cancelLevel()
  +sendQuantity()
}
class Patient {
  #Date price
  +long id
  +Date updatedAt
  +createEmail()
}
interface Diagnosis {
  #boolean phone
  -boolean description
  +boolean createdAt
  +Date type
  +findPhone()
  +calculatePrice()
  +setScore()
}
class LabTest {
  #String quantity
  #long code
  +boolean name
  -int id
  -double active
  +cancelUpdatedat()
}
class Insurance {
  +String createdAt
  +int score
  -int duration
  #float price
  +createAmount()
  +calculateId()
  +getScore()
}
class Doctor {
  +Date score
  #long name
  #int total
  -boolean active
  -boolean description
  +createPrice()
  +validateQuantity()
  +findNote()
}
Patient --|> LabTest
Doctor --|> Prescription
note right of Prescription : Healthcare domain
@enduml