@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Prescription {
  +Date amount
  -int address
  +double description
  #int note
  +String status
  +sendAmount()
  +createAddress()
  +saveAddress()
  +processEmail()
}
interface Patient {
  #int code
  #Date amount
  +long price
  +Date id
  +getNote()
}
class Diagnosis {
  #boolean phone
  -boolean description
  +boolean createdAt
  +Date type
  +sendUpdatedat()
  +saveScore()
  +deleteAmount()
}
abstract class LabTest {
  #double score
  -String name
  +cancelDuration()
}
class Insurance {
  #long level
  +boolean id
  +findPhone()
  +calculateCode()
  +saveName()
  +createDescription()
}
class Doctor {
  #int createdAt
  -float quantity
  +String duration
  +deleteScore()
  +deleteDuration()
}
Insurance --* Diagnosis
Patient --|> LabTest
Prescription --|> Insurance
@enduml