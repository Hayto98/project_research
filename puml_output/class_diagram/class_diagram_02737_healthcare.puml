@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Diagnosis {
  #int code
  #long createdAt
  +calculateStatus()
}
abstract class MedicalRecord {
  -int phone
  #float quantity
  -int total
  -double price
  #float createdAt
  +saveAddress()
  +setUpdatedat()
  +processEmail()
}
interface Hospital {
  -String phone
  #long id
  #float amount
  +boolean level
  +double type
  +createUpdatedat()
}
class Appointment {
  -Date quantity
  +long id
  -boolean total
  +double name
  #boolean type
  +findStatus()
  +createCode()
}
class Treatment {
  -double type
  -int active
  #int quantity
  +sendNote()
  +saveQuantity()
}
class Patient {
  -float note
  #boolean code
  #double score
  +calculateCode()
  +updateQuantity()
}
Patient --* Appointment
Appointment --> Hospital : "1..*"
@enduml