@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Diagnosis {
  #int code
  #long createdAt
  +findType()
}
abstract class MedicalRecord {
  -int quantity
  #float total
  -int price
  -double createdAt
  +deleteName()
  +cancelLevel()
  +calculatePhone()
}
interface Hospital {
  -double amount
  +boolean id
  +sendAmount()
  +sendStatus()
  +processId()
}
interface Appointment {
  -String price
  #double quantity
  -Date id
  +createQuantity()
  +cancelAmount()
}
abstract class Treatment {
  -boolean amount
  -double status
  -long description
  +cancelUpdatedat()
  +deleteUpdatedat()
}
class Patient {
  #boolean amount
  #double note
  +double code
  +Date quantity
  +validateTotal()
  +createScore()
  +validateNote()
  +createName()
}
Diagnosis --o Hospital
Appointment --> Diagnosis : "1..*"
Appointment ..|> MedicalRecord
Patient --> Treatment : "1"
note right of Diagnosis : Healthcare domain
@enduml