@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Follower {
  -long duration
  -float note
  +boolean name
  -Date code
  -long total
  +processCreatedat()
  +updateAmount()
  +findId()
}
class Group {
  #String total
  #boolean description
  +findAddress()
  +updateAmount()
  +cancelName()
}
abstract class Notification {
  +Date phone
  +boolean description
  #float updatedAt
  +cancelDuration()
  +findActive()
  +cancelQuantity()
  +createNote()
}
class Message {
  #int total
  -int createdAt
  +getEmail()
  +updateEmail()
  +getActive()
}
class User {
  #float price
  -String phone
  +Date type
  -double updatedAt
  +createTotal()
  +calculateStatus()
}
Notification --|> Group
Notification ..> Follower : "1"
note right of Follower : Social Media domain
@enduml