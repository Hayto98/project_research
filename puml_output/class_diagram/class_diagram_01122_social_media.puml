@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Follower {
  -long duration
  -float note
  +boolean name
  -Date code
  -long total
  +validateUpdatedat()
  +calculateUpdatedat()
  +calculateNote()
}
class Group {
  -float id
  #Date createdAt
  +boolean name
  +calculateLevel()
}
interface Notification {
  #double address
  #int updatedAt
  -int amount
  +int name
  +createStatus()
}
interface Message {
  +boolean level
  #String active
  #double quantity
  #int score
  #int note
  +deleteId()
  +saveQuantity()
  +processStatus()
  +updatePrice()
}
class User {
  +long email
  -long name
  -int active
  +createAddress()
  +findLevel()
  +calculateId()
}
Message ..> User : "0..1"
Notification --o Message
Follower --* Message
Group ..> Follower : "1..*"
@enduml