@startuml
skinparam monochrome true
skinparam shadowing true
class Wishlist {
  #double createdAt
  -Date description
  +float code
  +calculateId()
  +getDescription()
  +getAddress()
}
class Invoice {
  +float phone
  +String code
  +long note
  #String quantity
  +createScore()
  +calculateQuantity()
  +setCreatedat()
  +processTotal()
}
class Warehouse {
  #float email
  +long type
  +findAddress()
  +saveCreatedat()
  +sendActive()
}
class Order {
  #float level
  +long createdAt
  #long amount
  -int address
  +validateStatus()
  +processAmount()
}
Invoice --* Wishlist
Order --|> Warehouse
Invoice --* Order
note right of Wishlist : Ecommerce domain
@enduml