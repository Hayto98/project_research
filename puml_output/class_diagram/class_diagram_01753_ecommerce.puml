@startuml
skinparam monochrome true
skinparam shadowing true
class Wishlist {
  #double createdAt
  -Date description
  +float code
  +calculateQuantity()
  +updateCreatedat()
  +sendTotal()
}
class Invoice {
  -float name
  -Date address
  +float duration
  +createQuantity()
  +setLevel()
  +setActive()
  +validateCreatedat()
}
class Warehouse {
  -boolean phone
  -long status
  +int type
  +setCode()
  +getAddress()
  +processQuantity()
  +calculateEmail()
}
class Order {
  #int score
  #boolean amount
  +long phone
  #boolean quantity
  +float address
  +validateDuration()
  +validateActive()
}
Warehouse --* Order
Order ..> Wishlist : "0..1"
@enduml