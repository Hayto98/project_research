@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Publisher {
  +long address
  #String amount
  +int duration
  +calculateDuration()
  +deleteEmail()
}
class Catalog {
  +long id
  #int duration
  +createTotal()
  +processLevel()
}
interface Librarian {
  +boolean level
  +String amount
  #String address
  -long active
  +processCreatedat()
}
class Reservation {
  -int createdAt
  -boolean updatedAt
  +String note
  -int description
  +processUpdatedat()
}
class Book {
  #double amount
  #String quantity
  #Date code
  -long total
  -Date email
  +cancelAmount()
}
class Author {
  +float duration
  +int score
  +createDescription()
  +findQuantity()
  +updateCreatedat()
  +updateCreatedat()
}
class Fine {
  +String description
  +double total
  #Date quantity
  +String status
  -long createdAt
  +processStatus()
  +processScore()
  +findQuantity()
}
Book --o Publisher
Fine --> Librarian : "*"
Catalog --o Author
Catalog ..> Librarian : "*"
note right of Publisher : Library domain
@enduml