@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Student {
  +boolean amount
  +int email
  #int id
  -boolean total
  +deleteQuantity()
  +updateCreatedat()
  +deleteDuration()
  +getLevel()
}
class Department {
  #long address
  #boolean total
  -long duration
  #float level
  +int description
  +sendAmount()
  +cancelCreatedat()
  +saveDuration()
}
class Enrollment {
  +float total
  +String id
  +long amount
  -int note
  +deleteAmount()
  +sendCreatedat()
  +createTotal()
  +cancelEmail()
}
class Teacher {
  #double price
  #String quantity
  +float id
  +float level
  +cancelId()
  +getCreatedat()
}
abstract class Grade {
  -boolean name
  -boolean total
  +long email
  +setNote()
}
class Exam {
  -boolean code
  -float phone
  +getType()
  +findTotal()
  +saveLevel()
}
class Assignment {
  #double level
  +boolean total
  #String quantity
  #Date note
  +String name
  +findPhone()
  +getPhone()
}
Student --|> Department
Teacher --* Assignment
Exam ..|> Grade
note right of Student : Education domain
@enduml