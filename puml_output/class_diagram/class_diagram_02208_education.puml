@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Student {
  +boolean amount
  +int email
  #int id
  -boolean total
  +validateCode()
  +calculateLevel()
  +getNote()
  +updateDescription()
}
class Department {
  -long duration
  -long id
  -int quantity
  +getCreatedat()
  +createDescription()
  +calculateCreatedat()
}
class Enrollment {
  +boolean updatedAt
  +Date email
  #long active
  +updateEmail()
  +sendTotal()
  +updateId()
}
class Teacher {
  -int id
  -int duration
  +boolean status
  +long amount
  -boolean email
  +findId()
  +calculatePhone()
  +processAddress()
}
abstract class Grade {
  #String id
  +float quantity
  +float score
  +boolean price
  +calculateId()
}
class Exam {
  #float amount
  -boolean name
  +long total
  +String email
  -long quantity
  +getName()
}
class Assignment {
  -Date email
  -Date note
  #int quantity
  -float name
  +cancelAddress()
  +calculateAmount()
  +saveUpdatedat()
  +findTotal()
}
Student --o Grade
Department ..> Grade : "1"
Grade ..|> Exam
Student ..> Department : "1..*"
Assignment --* Student
Assignment --|> Department
@enduml