@startuml

class Librarian {
  +float level
  #float price
  +Date phone
  +processStatus()
  +calculateScore()
  +cancelType()
}
class Author {
  +String amount
  +double note
  -boolean quantity
  +float phone
  +sendCode()
}
class Member {
  #Date phone
  +int quantity
  -String createdAt
  +double level
  -boolean name
  +setAmount()
}
class Shelf {
  +float amount
  +long duration
  +sendDuration()
  +updateQuantity()
  +updateAmount()
  +deletePrice()
}
Shelf --o Author
Member --|> Librarian
Shelf --o Member
note right of Librarian : Library domain
@enduml