@startuml

class Librarian {
  +float level
  #float price
  +Date phone
  +getStatus()
  +validateName()
  +deleteQuantity()
}
abstract class Author {
  -String address
  +float phone
  +double amount
  -boolean note
  +float quantity
  +createStatus()
}
class Member {
  -int price
  -boolean phone
  +calculateDescription()
}
class Shelf {
  -long note
  #Date name
  +String code
  +saveAddress()
  +deleteNote()
}
Author ..|> Librarian
Member --> Author : "0..1"
@enduml