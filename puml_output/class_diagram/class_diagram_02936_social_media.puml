@startuml
skinparam ArrowColor #555555
abstract class Follower {
  #String quantity
  +String status
  #int updatedAt
  #double createdAt
  #long name
  +saveQuantity()
  +processEmail()
  +createLevel()
}
interface Group {
  +boolean score
  #int description
  +long quantity
  -boolean updatedAt
  +int id
  +processPhone()
  +findPhone()
  +updateScore()
  +createId()
}
class Message {
  +double total
  -int type
  -boolean note
  -String email
  +updateStatus()
}
interface Story {
  #Date phone
  +boolean active
  +long address
  -int duration
  #double name
  +updateEmail()
  +updateLevel()
  +sendType()
  +deleteDuration()
}
Group --|> Story
Group --o Message
Story ..|> Group
note right of Follower : Social Media domain
@enduml