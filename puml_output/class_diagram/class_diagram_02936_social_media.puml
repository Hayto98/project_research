@startuml
skinparam ArrowColor #555555
abstract class Follower {
  #String quantity
  +String status
  #int updatedAt
  #double createdAt
  #long name
  +sendPrice()
  +setTotal()
  +validateName()
}
class Group {
  -int level
  #boolean active
  +int price
  #Date description
  +updateType()
  +createQuantity()
}
class Message {
  -long amount
  #long note
  +cancelAmount()
  +createQuantity()
}
class Story {
  -long phone
  +double total
  -int type
  +findName()
  +findAmount()
  +validatePhone()
}
Group --> Follower : "*"
Message --> Story : "1..*"
@enduml