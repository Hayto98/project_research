@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
interface Amenity {
  -double email
  -double total
  #boolean level
  -long address
  +boolean description
  +saveQuantity()
}
class Reservation {
  -float address
  -float amount
  -double code
  #Date active
  +sendActive()
  +calculateStatus()
}
class Room {
  -long name
  +String id
  +getCode()
  +deleteEmail()
  +updatePhone()
  +saveEmail()
}
class Restaurant {
  +boolean code
  -String total
  #float active
  +setCode()
}
Restaurant ..|> Room
Amenity --* Reservation
Amenity ..|> Room
@enduml