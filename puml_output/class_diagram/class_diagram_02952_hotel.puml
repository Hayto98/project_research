@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
interface Amenity {
  -double email
  -double total
  #boolean level
  -long address
  +boolean description
  +deleteAmount()
}
interface Reservation {
  -float address
  -float amount
