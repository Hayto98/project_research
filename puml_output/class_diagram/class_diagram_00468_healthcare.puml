@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Doctor {
  -Date id
  #int status
  -String duration
  +boolean createdAt
  +findPrice()
}
interface Diagnosis {
  #int score
  +int createdAt
  #int id
  -double total
  +calculateType()
}
interface Prescription {
  +boolean note
  #double phone
  -long quantity
  +saveEmail()
  +getCode()
  +createPrice()
  +sendActive()
}
class Ward {
  #boolean price
  +int id
  +calculateCreatedat()
  +processUpdatedat()
}
class Hospital {
  #float status
  -boolean code
  +double address
  #boolean id
  +calculateActive()
}
class Billing {
  -int description
  -long updatedAt
  +float duration
  +updateTotal()
  +getStatus()
  +setActive()
  +processLevel()
}
class LabTest {
  #double total
  -long type
  +validateStatus()
}
Doctor --o Billing
Diagnosis --* Billing
Billing --o Prescription
Ward --o LabTest
@enduml