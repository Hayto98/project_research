@startuml
skinparam defaultFontSize 13
interface Branch {
  -Date createdAt
  #float price
  #boolean total
  +calculatePrice()
  +findPrice()
  +findCode()
}
class Publisher {
  -float address
  -Date id
  #Date name
  +updateStatus()
  +processNote()
}
class Catalog {
  #String price
  -double active
  -boolean note
  +Date name
  -int updatedAt
  +validateActive()
  +sendScore()
  +validateAmount()
}
class Book {
  #long amount
  -int level
  +Date id
  #double name
  +calculateQuantity()
  +sendDuration()
}
interface Renewal {
  -Date status
  #float code
  -int amount
  #float note
  -float total
  +cancelDescription()
}
abstract class Shelf {
  #double type
  #String price
  +boolean email
  #float note
  -float id
  +updateNote()
  +sendType()
  +processUpdatedat()
  +getAmount()
}
class Author {
  +boolean active
  -long note
  -boolean email
  +long level
  +Date quantity
  +processCode()
}
Book --|> Author
Branch ..> Author : "*"
Book --> Shelf : "1..*"
note right of Branch : Library domain
@enduml