@startuml
skinparam defaultFontSize 13
interface Branch {
  -Date createdAt
  #float price
  #boolean total
  +processType()
  +deleteAmount()
  +cancelName()
}
abstract class Publisher {
  -String id
  +long updatedAt
  +updateAddress()
  +setId()
  +createTotal()
}
interface Catalog {
  -Date createdAt
  -Date status
  #double type
  +sendQuantity()
  +deleteType()
  +createName()
  +sendActive()
}
class Book {
  -boolean code
  +Date price
  -int type
  +createActive()
  +processAddress()
  +createDescription()
}
interface Renewal {
  #String amount
  #String quantity
  #long email
  -int duration
  +saveDescription()
  +updatePhone()
}
abstract class Shelf {
  #boolean price
  #Date quantity
  #double active
  +findNote()
}
class Author {
  +boolean total
  +double price
  #double duration
  #Date updatedAt
  -double phone
  +sendType()
  +cancelQuantity()
  +updatePrice()
}
Book --|> Renewal
Branch ..> Renewal : "*"
Author ..|> Book
Book ..|> Author
Branch --|> Publisher
@enduml