@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Nurse {
  -long updatedAt
  +int status
  #int phone
  +long active
  +processActive()
  +sendStatus()
  +validateId()
  +createLevel()
}
class LabTest {
  #double address
  -boolean type
  #boolean total
  +double note
  #float description
  +validateCode()
  +processEmail()
  +saveCreatedat()
}
interface Ward {
  -Date quantity
  +boolean updatedAt
  -boolean price
  +calculateCreatedat()
  +findAmount()
}
class Patient {
  -String level
  +Date note
  #boolean quantity
  +String createdAt
  -boolean code
  +calculateTotal()
  +updateLevel()
  +cancelDuration()
}
abstract class Hospital {
  #double active
  #int address
  #int note
  +calculateType()
  +findAmount()
  +updateId()
  +createQuantity()
}
Nurse --|> LabTest
Ward --* Nurse
@enduml