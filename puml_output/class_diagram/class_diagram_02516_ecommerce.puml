@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Warehouse {
  -float description
  +long code
  +boolean phone
  +updateNote()
  +processAddress()
  +getPhone()
  +calculateCreatedat()
}
class Category {
  #boolean duration
  -long updatedAt
  +getNote()
  +createId()
}
abstract class Return {
  +Date type
  -float active
  #boolean address
  +float score
  +validateEmail()
}
class Cart {
  #boolean address
  +Date createdAt
  #boolean level
  -float type
  -int active
  +saveUpdatedat()
  +createName()
  +validatePrice()
}
class Supplier {
  #String createdAt
  -Date name
  #double updatedAt
  -long price
  +updateQuantity()
}
class Product {
  -float quantity
  +long updatedAt
  +double id
  #boolean description
  +Date note
  +validateActive()
  +sendEmail()
}
Supplier --* Product
Warehouse --|> Supplier
@enduml