@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Warehouse {
  -float description
  +long code
  +boolean phone
  +sendTotal()
  +validateCreatedat()
  +cancelCode()
  +findDuration()
}
class Category {
  -float phone
  #long updatedAt
  -String quantity
  #long type
  #boolean email
  +getStatus()
  +createType()
}
class Return {
  #boolean createdAt
  +Date type
  #boolean level
  +createDescription()
  +cancelEmail()
  +saveNote()
}
class Cart {
  #String createdAt
  -Date name
  #double updatedAt
  -long price
  +validateNote()
}
class Supplier {
  -float id
  +long description
  +double note
  +saveAmount()
  +cancelCreatedat()
}
class Product {
  -boolean status
  -long id
  +String name
  #boolean updatedAt
  +validateDescription()
  +cancelAmount()
  +processUpdatedat()
  +deleteId()
}
Return --|> Category
Supplier --* Cart
Category --o Supplier
note right of Warehouse : Ecommerce domain
@enduml