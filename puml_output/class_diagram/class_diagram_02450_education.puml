@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Enrollment {
  +long price
  #Date active
  -Date id
  #double level
  -String description
  +getEmail()
  +setStatus()
  +getName()
}
abstract class Department {
  +long price
  -Date type
  #int score
  #String id
  #Date code
  +calculateNote()
  +calculateCreatedat()
  +createScore()
}
class Library {
  #Date description
  #Date email
  #boolean quantity
  +Date price
  +saveCreatedat()
  +findQuantity()
}
class Book {
  #boolean status
  #long updatedAt
  #boolean address
  +int score
  +sendType()
  +updateAmount()
  +getDuration()
}
class Classroom {
  -int note
  +float level
  +int active
  #float quantity
  #double code
  +findActive()
  +createCreatedat()
  +getDuration()
}
Department --> Classroom : "0..1"
Library ..|> Enrollment
Library --|> Classroom
Enrollment ..|> Book
@enduml