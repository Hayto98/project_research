@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Enrollment {
  +long price
  #Date active
  -Date id
  #double level
  -String description
  +deleteStatus()
  +processTotal()
  +calculateType()
}
interface Department {
  -float code
  -Date name
  +sendStatus()
  +sendPhone()
}
class Library {
  -long updatedAt
  -boolean amount
  #Date address
  #float description
  +saveScore()
  +updateAddress()
}
class Book {
  #String duration
  +long email
  +cancelLevel()
  +savePhone()
  +findScore()
}
class Classroom {
  -boolean address
  #long createdAt
  +double price
  +deleteUpdatedat()
  +updateNote()
}
Book ..> Department : "0..1"
Classroom --> Department : "0..1"
Library ..|> Enrollment
note right of Enrollment : Education domain
@enduml