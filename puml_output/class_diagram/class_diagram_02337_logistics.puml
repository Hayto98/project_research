@startuml

abstract class Inventory {
  #long score
  +Date code
  #String type
  +String description
  +sendCreatedat()
  +createName()
}
abstract class Manifest {
  +int score
  -float quantity
  +getNote()
  +cancelAddress()
  +cancelAmount()
}
class Vehicle {
  +long total
  +boolean address
  #long email
  #long description
  +saveActive()
  +cancelId()
}
interface Route {
  #float email
  +boolean phone
  +double address
  #long price
  #float level
  +setQuantity()
  +setLevel()
}
Vehicle --* Manifest
Route --* Manifest
Route ..> Inventory : "1..*"
note right of Inventory : Logistics domain
@enduml