@startuml

abstract class Inventory {
  #long score
  +Date code
  #String type
  +String description
  +sendDescription()
  +sendAmount()
}
class Manifest {
  #float name
  -String note
  +long score
  -String status
  +setPhone()
  +setEmail()
  +validateActive()
  +calculateAddress()
}
class Vehicle {
  +long total
  +boolean address
  #long email
  #long description
  +getAmount()
  +findDuration()
}
interface Route {
  -long active
  -float total
  +processStatus()
  +saveDescription()
  +sendStatus()
  +saveEmail()
}
Route --* Vehicle
Manifest ..> Inventory : "1..*"
@enduml