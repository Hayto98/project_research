@startuml
skinparam shadowing true
class Nurse {
  -String total
  -double createdAt
  #boolean score
  -int price
  +createActive()
  +deleteLevel()
  +sendType()
  +sendUpdatedat()
}
class Doctor {
  #int duration
  +boolean price
  +createEmail()
  +updateQuantity()
  +findAddress()
}
abstract class Billing {
  #Date phone
  #double status
  +sendActive()
  +findNote()
  +cancelNote()
}
interface MedicalRecord {
  +boolean type
  -double quantity
  +calculateType()
  +setAmount()
  +updateDuration()
  +getEmail()
}
interface Hospital {
  #double address
  +Date createdAt
  +boolean phone
  -float name
  +saveCreatedat()
  +calculateTotal()
  +saveUpdatedat()
  +createNote()
}
class Diagnosis {
  +String note
  #double amount
  +savePrice()
}
class Ward {
  +long type
  #double quantity
  #Date address
  +setStatus()
  +getUpdatedat()
}
Billing ..> MedicalRecord : "*"
Hospital --|> MedicalRecord
Ward ..|> MedicalRecord
Diagnosis --> Doctor : "*"
Hospital --> Diagnosis : "1..*"
@enduml