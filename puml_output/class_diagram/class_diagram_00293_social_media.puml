@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Story {
  +String score
  -float address
  -Date quantity
  +processPrice()
  +getName()
  +getPrice()
  +getAddress()
}
class Group {
  -boolean name
  +boolean active
  +boolean email
  #double score
  -long amount
  +cancelEmail()
}
class Message {
  #boolean price
  +boolean score
  -double note
  +double level
  +Date email
  +setDescription()
}
class Report {
  +String status
  -boolean score
  +setId()
  +updatePrice()
  +processUpdatedat()
  +getName()
}
class Follower {
  +int status
  +int address
  #String price
  -long quantity
  #long duration
  +processName()
  +createCode()
  +createPrice()
  +deleteDescription()
}
abstract class Profile {
  #Date active
  +String level
  +createDuration()
  +calculateScore()
  +processDescription()
}
class Like {
  +double price
  -Date email
  +boolean note
  +findActive()
  +sendEmail()
  +calculateAddress()
  +cancelAmount()
}
Follower ..|> Profile
Profile --> Report : "*"
Profile --|> Follower
Follower ..> Story : "0..1"
Report --> Follower : "*"
Follower --* Group
@enduml