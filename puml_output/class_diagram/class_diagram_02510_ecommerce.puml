@startuml
skinparam shadowing true
interface Return {
  #float price
  -long phone
  -int quantity
  +updateCode()
  +saveLevel()
  +findId()
  +processPrice()
}
class Category {
  #String score
  -boolean note
  +cancelPrice()
}
class Cart {
  -boolean quantity
  #int id
  +Date address
  +float total
  +deleteTotal()
}
class Shipment {
  #double phone
  -int price
  +saveId()
}
class Coupon {
  #long score
  -int type
  #int createdAt
  -Date description
  +processNote()
  +cancelDuration()
  +setPhone()
  +getCreatedat()
}
interface Order {
  +long name
  -String total
  #Date price
  #String quantity
  #float phone
  +deleteTotal()
}
abstract class Warehouse {
  -int email
  -float name
  -String price
  +float level
  +validateDescription()
  +processStatus()
  +getEmail()
  +deleteName()
}
Return ..|> Shipment
Cart ..|> Shipment
Warehouse --o Order
note right of Return : Ecommerce domain
@enduml