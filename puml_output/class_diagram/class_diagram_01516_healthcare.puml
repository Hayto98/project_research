@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Prescription {
  -long code
  -double quantity
  +saveQuantity()
  +deleteScore()
}
class Ward {
  #boolean type
  +boolean quantity
  #String duration
  -boolean note
  +cancelStatus()
  +sendLevel()
  +createActive()
}
abstract class Treatment {
  #boolean code
  +double phone
  #boolean active
  #long name
  +saveId()
  +deleteStatus()
  +setNote()
  +processAmount()
}
class MedicalRecord {
  -boolean updatedAt
  +int score
  +long note
  +float level
  +updatePrice()
  +saveId()
  +sendActive()
}
abstract class Patient {
  -double email
  -int score
  +long price
  #long updatedAt
  -boolean quantity
  +updatePhone()
  +saveUpdatedat()
  +findAddress()
  +saveId()
}
Patient --|> Ward
Prescription --|> Treatment
MedicalRecord --o Treatment
@enduml