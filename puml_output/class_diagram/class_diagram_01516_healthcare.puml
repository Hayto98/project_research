@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Prescription {
  -long code
  -double quantity
  +deleteAmount()
  +createAddress()
}
abstract class Ward {
  #float type
  #String score
  -boolean note
  #long status
  +validateTotal()
}
class Treatment {
  +boolean phone
  #int active
  +saveScore()
  +saveAddress()
  +sendType()
  +getTotal()
}
class MedicalRecord {
  -double email
  #String updatedAt
  +String score
  -int note
  +getName()
  +cancelNote()
  +processEmail()
}
interface Patient {
  +String updatedAt
  -Date quantity
  -double address
  #Date note
  #double phone
  +getNote()
  +sendUpdatedat()
}
Prescription --|> Treatment
MedicalRecord --o Treatment
note right of Prescription : Healthcare domain
@enduml