@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Staff {
  -boolean active
  +boolean id
  -String email
  +calculateCreatedat()
  +sendEmail()
}
class Booking {
  #Date note
  #int phone
  -double description
  -String type
  -long total
  +findStatus()
}
class Restaurant {
  -int name
  -boolean level
  +sendActive()
  +getLevel()
  +deleteStatus()
}
class Housekeeping {
  +int description
  +Date status
  +createName()
}
class Invoice {
  -int status
  +int name
  -float level
  #String total
  +saveId()
  +validateTotal()
}
interface Payment {
  #long createdAt
  #double type
  -float level
  +getQuantity()
  +calculateLevel()
  +saveName()
}
class CheckIn {
  +long code
  #int id
  +float name
  #int duration
  +double amount
  +validateEmail()
  +createCreatedat()
}
Payment ..> CheckIn : "0..1"
Staff ..> Restaurant : "0..1"
Housekeeping --o CheckIn
Payment --|> Invoice
Restaurant --o Booking
Booking ..> Housekeeping : "1..*"
@enduml