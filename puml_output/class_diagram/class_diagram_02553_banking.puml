@startuml
skinparam defaultFontSize 11
interface Branch {
  +double score
  #String price
  +createPrice()
  +findNote()
  +cancelCode()
  +getDuration()
}
class Transaction {
  -boolean address
  #long duration
  -int status
  #Date id
  -long phone
  +sendActive()
  +findNote()
}
class Statement {
  +int price
  -double quantity
  -float phone
  +long score
  +String note
  +cancelPhone()
}
class Customer {
  #double type
  -float price
  #double phone
  +getId()
  +deleteAmount()
}
Branch ..|> Transaction
Statement ..|> Transaction
note right of Branch : Banking domain
@enduml