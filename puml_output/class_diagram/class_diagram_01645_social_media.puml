@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
abstract class Notification {
  +float quantity
  -long phone
  -float name
  -float code
  +calculateUpdatedat()
}
class Album {
  -double address
  -double score
  +deleteId()
}
class Follower {
  -boolean code
  -boolean updatedAt
  +float status
  +setUpdatedat()
  +processName()
  +deleteCreatedat()
  +cancelCode()
}
interface Group {
  -long active
  -boolean description
  -boolean quantity
  #double name
  +getStatus()
  +sendPhone()
}
class Post {
  -boolean score
  +String type
  +setScore()
  +findAddress()
  +setDuration()
  +createScore()
}
class Hashtag {
  -double active
  +Date level
  +validateCreatedat()
  +calculateId()
  +saveUpdatedat()
  +setStatus()
}
class Like {
  #String code
  #float description
  -long address
  -long type
  +float level
  +updateQuantity()
  +createDuration()
  +processPrice()
}
Album --> Post : "*"
Follower --* Like
Notification --* Like
Notification --> Follower : "1"
Like --|> Hashtag
Like --o Notification
note right of Notification : Social Media domain
@enduml