@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
abstract class Notification {
  +float quantity
  -long phone
  -float name
  -float code
  +calculateQuantity()
}
class Album {
  -double code
  -double address
  +int score
  +sendLevel()
}
class Follower {
  -boolean code
  -boolean updatedAt
  +float status
  +validatePhone()
  +validateNote()
  +processTotal()
  +processQuantity()
}
class Group {
  -boolean duration
  +float code
  -String score
  +sendAddress()
  +getPhone()
  +findDuration()
  +deleteTotal()
}
abstract class Post {
  +boolean createdAt
  -long id
  #String status
  +double phone
  +boolean duration
  +setDescription()
  +createId()
  +validateActive()
}
class Hashtag {
  +Date status
  #boolean active
  #boolean quantity
  -long type
  +getName()
  +cancelCreatedat()
}
class Like {
  #double code
  +int status
  -double updatedAt
  +getScore()
  +updateName()
}
Follower --* Like
Notification ..> Post : "1..*"
Album ..> Hashtag : "1..*"
Follower --o Post
@enduml