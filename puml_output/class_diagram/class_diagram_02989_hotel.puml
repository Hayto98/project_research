@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class CheckIn {
  -double createdAt
  +double status
  #int level
  +cancelNote()
  +processStatus()
}
class Reservation {
  #double id
  #int score
  +long price
  +float duration
  +updateActive()
  +calculateAddress()
  +cancelActive()
}
interface Restaurant {
  +Date status
  +boolean amount
  +validateCreatedat()
  +processName()
}
class CheckOut {
  -boolean status
  -String id
  #long phone
  -double note
  +Date score
  +createUpdatedat()
  +validateActive()
  +findPrice()
}
interface Amenity {
  #String status
  #Date code
  -int quantity
  #int active
  +getLevel()
  +sendAddress()
}
class Room {
  #Date score
  #String phone
  +findPrice()
}
class Staff {
  -boolean description
  +Date note
  #String address
  #String level
  +String amount
  +cancelLevel()
  +deletePrice()
  +createCode()
}
CheckOut --* Restaurant
Reservation --|> Room
Room --|> Restaurant
Room --|> Staff
note right of CheckIn : Hotel domain
@enduml