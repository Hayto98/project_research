@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class CheckIn {
  -double createdAt
  +double status
  #int level
  +validateActive()
  +calculateAmount()
}
abstract class Reservation {
  +boolean code
  #Date address
  +validateType()
  +findLevel()
  +saveDuration()
  +updateScore()
}
class Restaurant {
  +boolean description
  -long code
  #boolean quantity
  #String updatedAt
  +int email
  +findStatus()
}
class CheckOut {
  +float phone
  +double createdAt
  +String type
  +createName()
  +updateTotal()
  +setActive()
}
class Amenity {
  +Date status
  -long quantity
  #int phone
  -boolean type
  +validateStatus()
  +getCode()
  +deleteCreatedat()
  +createPhone()
}
class Room {
  +Date active
  +float level
  +float code
  +boolean price
  +cancelLevel()
  +calculateStatus()
  +validateStatus()
}
class Staff {
  #Date score
  #String phone
  +sendUpdatedat()
}
Reservation ..> CheckOut : "0..1"
Room --* CheckOut
CheckOut --o Reservation
Amenity ..> CheckIn : "1"
@enduml