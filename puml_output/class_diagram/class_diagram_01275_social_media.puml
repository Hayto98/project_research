@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Comment {
  -float quantity
  -float email
  +long status
  #float id
  #int description
  +processId()
  +validateStatus()
  +sendDescription()
  +cancelType()
}
class Profile {
  #boolean phone
  #boolean id
  -Date type
  +boolean address
  +float email
  +deleteAddress()
}
class Message {
  #double code
  +long note
  #boolean description
  +calculateDescription()
  +calculateEmail()
  +validateLevel()
}
abstract class User {
  +double phone
  -String name
  #double status
  #String createdAt
  +float updatedAt
  +processUpdatedat()
}
Comment ..|> User
Profile --> Comment : "1..*"
Profile --* User
@enduml