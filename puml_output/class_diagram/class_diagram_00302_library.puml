@startuml
skinparam monochrome true
class Reservation {
  +double price
  +double email
  +cancelPhone()
  +deletePhone()
}
class Catalog {
  #boolean createdAt
  #double total
  +calculatePhone()
  +processPhone()
}
class Fine {
  #String active
  #boolean email
  +sendDescription()
  +updateTotal()
}
class Librarian {
  #boolean description
  -Date id
  +long score
  #int quantity
  +getDescription()
  +createNote()
  +findQuantity()
  +deleteDuration()
}
Librarian --> Reservation : "*"
Librarian --|> Catalog
note right of Reservation : Library domain
@enduml