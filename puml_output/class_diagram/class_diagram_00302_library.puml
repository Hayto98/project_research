@startuml
skinparam monochrome true
class Reservation {
  +double price
  +double email
  +setPhone()
  +createAmount()
}
class Catalog {
  -Date updatedAt
  #boolean score
  -Date code
  +double createdAt
  +cancelQuantity()
  +setCreatedat()
  +sendPhone()
}
class Fine {
  #String active
  #boolean email
  +calculateActive()
  +deleteType()
}
class Librarian {
  +Date total
  +float address
  #long email
  +saveDescription()
  +findEmail()
  +getDescription()
}
Fine ..|> Librarian
Librarian ..|> Reservation
@enduml