@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Classroom {
  -boolean code
  #long name
  #boolean level
  +createNote()
  +createDescription()
  +deleteEmail()
  +findUpdatedat()
}
class Attendance {
  -Date price
  -float createdAt
  -int active
  -long quantity
  -float type
  +findEmail()
  +findPrice()
  +sendName()
  +createCreatedat()
}
class Assignment {
  -String email
  -String name
  +double active
  +processScore()
  +deleteUpdatedat()
  +validateStatus()
  +updatePhone()
}
class Course {
  +boolean id
  #long address
  +processId()
}
abstract class Enrollment {
  -String score
  #boolean description
  #Date code
  +updatePhone()
  +getAmount()
}
Attendance --o Classroom
Course ..|> Classroom
Classroom --* Attendance
Enrollment --> Attendance : "1..*"
@enduml