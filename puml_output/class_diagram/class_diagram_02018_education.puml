@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Classroom {
  -boolean code
  #long name
  #boolean level
  +sendDuration()
  +findPhone()
  +cancelPrice()
  +savePrice()
}
class Attendance {
  +long type
  -double address
  #double quantity
  #double email
  +createDescription()
  +createName()
}
interface Assignment {
  -float name
  #float address
  #long id
  #Date duration
  +String type
  +updateActive()
  +sendQuantity()
  +sendName()
}
interface Course {
  +Date createdAt
  #Date score
  #int description
  #Date code
  #int total
  +calculateTotal()
}
class Enrollment {
  -boolean status
  +float active
  #long amount
  +createPhone()
  +findNote()
  +cancelStatus()
  +getScore()
}
Attendance ..> Classroom : "1"
Enrollment --|> Course
note right of Classroom : Education domain
@enduml