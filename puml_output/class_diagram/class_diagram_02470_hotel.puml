@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class CheckIn {
  +long status
  #String updatedAt
  -Date duration
  +getActive()
  +calculateNote()
  +saveType()
  +deleteScore()
}
class CheckOut {
  #double price
  +int level
  #long id
  +calculateUpdatedat()
  +calculateCreatedat()
  +createPhone()
}
abstract class Room {
  -float updatedAt
  #double phone
  +int total
  +findCode()
  +validateCreatedat()
  +findNote()
}
interface Payment {
  +String description
  +boolean duration
  #boolean status
  #Date email
  +long type
  +processPhone()
  +cancelTotal()
}
class Housekeeping {
  -int phone
  +Date amount
  +int note
  #boolean code
  -boolean total
  +updateAddress()
  +deleteStatus()
}
class Staff {
  +float note
  -int quantity
  #double id
  -boolean price
  -int status
  +updateEmail()
  +deleteTotal()
}
class Booking {
  #double email
  -double type
  #long phone
  +processType()
  +sendCreatedat()
}
CheckOut --o Payment
Payment --> Booking : "1..*"
Staff ..|> CheckOut
@enduml