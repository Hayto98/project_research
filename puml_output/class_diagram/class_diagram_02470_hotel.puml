@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class CheckIn {
  +long status
  #String updatedAt
  -Date duration
  +findCreatedat()
  +deleteAddress()
  +sendDescription()
  +calculateLevel()
}
class CheckOut {
  #long updatedAt
  +double description
  #Date score
  +int email
  -Date address
  +createActive()
  +processDescription()
  +updateQuantity()
  +validateDescription()
}
class Room {
  +String description
  +boolean duration
  #boolean status
  #Date email
  +long type
  +getPhone()
  +processPhone()
}
class Payment {
  #float code
  +int total
  #boolean phone
  -boolean description
  +Date duration
  +calculateNote()
  +createId()
  +cancelPrice()
}
class Housekeeping {
  -boolean phone
  -int description
  +double note
  +updateEmail()
  +cancelType()
}
class Staff {
  -double price
  #int type
  +double active
  -double email
  -boolean updatedAt
  +saveCreatedat()
  +updateQuantity()
  +sendCreatedat()
}
class Booking {
  -long status
  -boolean name
  +String duration
  +setPhone()
  +saveDuration()
  +createAddress()
  +cancelDescription()
}
Room --> CheckIn : "0..1"
Staff --|> Housekeeping
Staff --o Payment
note right of CheckIn : Hotel domain
@enduml