@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
interface Shelf {
  -String email
  +String price
  +float type
  +findPrice()
}
class Publisher {
  #float score
  #Date code
  -int quantity
  #float updatedAt
  +processPrice()
  +setId()
  +savePhone()
}
class Author {
  +Date status
  -float quantity
  +findEmail()
  +validatePrice()
  +createStatus()
}
class Fine {
  +Date score
  +boolean code
  #double createdAt
  #Date id
  +Date description
  +validateLevel()
  +calculateNote()
  +createTotal()
  +deleteCode()
}
class Member {
  +long description
  #long phone
  #boolean duration
  #String code
  +deleteCode()
}
class Catalog {
  -int id
  -float name
  +double createdAt
  -int email
  +Date address
  +processLevel()
  +processCode()
  +createEmail()
}
Member --* Shelf
Shelf --> Fine : "1..*"
note right of Shelf : Library domain
@enduml