@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
interface Shelf {
  -String email
  +String price
  +float type
  +setCreatedat()
}
abstract class Publisher {
  -boolean email
  +Date score
  #Date code
  +sendId()
  +getScore()
  +saveType()
  +sendActive()
}
class Author {
  +Date price
  #String status
  -int id
  #long phone
  -float score
  +findCode()
  +deleteId()
  +saveName()
}
class Fine {
  -boolean description
  #float active
  +sendId()
}
class Member {
  #double createdAt
  #Date id
  +Date active
  +saveLevel()
  +updateAmount()
  +calculateName()
  +savePrice()
}
abstract class Catalog {
  -int quantity
  -int total
  +int description
  -boolean code
  -Date name
  +validateId()
}
Shelf --o Catalog
Catalog ..> Shelf : "1"
Publisher --* Author
@enduml