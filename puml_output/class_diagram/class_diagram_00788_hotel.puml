@startuml
skinparam monochrome true
class Payment {
  +long duration
  +String price
  #float id
  +int quantity
  +sendCreatedat()
  +setAmount()
  +createPrice()
  +validateDescription()
}
abstract class Room {
  -double createdAt
  +String code
  #long address
  #boolean status
  +deletePrice()
  +validateStatus()
}
class CheckIn {
  #String email
  +boolean name
  #String duration
  +createName()
  +updateEmail()
  +cancelScore()
}
class Housekeeping {
  +String total
  -boolean level
  +calculateUpdatedat()
  +saveNote()
  +saveUpdatedat()
  +updatePrice()
}
abstract class Restaurant {
  -long phone
  #boolean note
  -double address
  +Date level
  +setPrice()
  +processType()
  +validateCode()
}
class Service {
  +float code
  +boolean type
  #long note
  +Date level
  #double status
  +findId()
}
class Amenity {
  +float type
  -double code
  +float description
  +cancelPrice()
}
Room ..> Amenity : "1"
Room --|> Housekeeping
Amenity ..|> Room
Restaurant ..> Room : "0..1"
@enduml