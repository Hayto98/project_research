@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Reservation {
  +double createdAt
  +float quantity
  #double id
  +cancelActive()
  +processName()
  +getEmail()
}
class Room {
  #String score
  #int note
  +saveNote()
  +getAddress()
}
interface Amenity {
  +long status
  +int amount
  +long active
  -Date quantity
  +cancelPhone()
  +saveCreatedat()
}
class Guest {
  +String amount
  -int email
  -double price
  +long code
  +deleteCreatedat()
}
interface Booking {
  #double updatedAt
  -long createdAt
  +int address
  +float duration
  #Date name
  +calculateStatus()
}
Reservation --* Guest
Booking --|> Amenity
Amenity --> Room : "1"
@enduml