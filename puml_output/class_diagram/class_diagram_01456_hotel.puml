@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Reservation {
  +double createdAt
  +float quantity
  #double id
  +cancelId()
  +deleteDescription()
  +sendLevel()
}
class Room {
  -boolean id
  #long active
  +int amount
  #long createdAt
  +long level
  +updateName()
}
class Amenity {
  -int active
  -double createdAt
  #Date email
  #String address
  +String amount
  +updateAddress()
  +processCreatedat()
  +validateStatus()
}
class Guest {
  #double updatedAt
  -long createdAt
  +int address
  +float duration
  #Date name
  +findNote()
}
class Booking {
  +boolean quantity
  +String active
  #long email
  #long status
  +int duration
  +sendType()
}
Guest ..|> Amenity
Amenity --> Room : "*"
Reservation ..|> Amenity
note right of Reservation : Hotel domain
@enduml