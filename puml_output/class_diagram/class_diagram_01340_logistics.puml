@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class DeliveryNote {
  -double duration
  -Date description
  -float phone
  +createCode()
}
interface Manifest {
  -double phone
  +String note
  #boolean price
  +sendDescription()
}
class Inventory {
  #String status
  +int active
  -int id
  +boolean updatedAt
  +calculateStatus()
  +sendQuantity()
}
interface Vehicle {
  #double price
  #long level
  -float score
  +getScore()
  +setName()
}
class Tracking {
  -float price
  #long quantity
  +createType()
  +calculateEmail()
  +validateActive()
}
abstract class Route {
  -boolean description
  -String address
  +cancelEmail()
  +createNote()
  +deletePhone()
  +processScore()
}
Tracking --* DeliveryNote
Vehicle --o Tracking
Inventory --o Vehicle
Vehicle --> DeliveryNote : "*"
@enduml