@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class DeliveryNote {
  -double duration
  -Date description
  -float phone
  +deleteLevel()
}
class Manifest {
  +String note
  #boolean price
  +float quantity
  -float duration
  +setActive()
  +getUpdatedat()
  +saveCode()
}
class Inventory {
  #boolean phone
  #int description
  #boolean level
  +calculateLevel()
  +findScore()
}
interface Vehicle {
  #String duration
  #float phone
  +String price
  -long active
  -float createdAt
  +cancelScore()
  +validateName()
  +cancelPrice()
}
class Tracking {
  +double address
  +float email
  -boolean phone
  +validateTotal()
}
interface Route {
  #Date email
  -float note
  +double total
  #boolean level
  #String code
  +processAmount()
}
Tracking ..|> Route
Inventory --o Route
note right of DeliveryNote : Logistics domain
@enduml