@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
interface User {
  -float description
  #long level
  -String id
  +cancelAddress()
  +deleteUpdatedat()
  +findDescription()
}
class Message {
  +boolean email
  #float address
  #boolean updatedAt
  +int active
  -String code
  +saveName()
}
interface Report {
  -String address
  -String phone
  #Date name
  +sendAmount()
  +getEmail()
  +sendEmail()
  +findCreatedat()
}
class Follower {
  -boolean active
  +boolean createdAt
  #int level
  +cancelAmount()
  +findNote()
}
abstract class Profile {
  -int score
  -Date quantity
  #String name
  +int total
  #int active
  +savePhone()
  +getName()
  +validateId()
}
interface Album {
  +float active
  +Date amount
  +calculateNote()
}
Report ..|> User
Follower ..|> User
Profile --> Report : "1..*"
@enduml