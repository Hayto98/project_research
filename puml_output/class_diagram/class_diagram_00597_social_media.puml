@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
interface User {
  -float description
  #long level
  -String id
  +createLevel()
  +cancelAddress()
  +calculateEmail()
}
class Message {
  #Date active
  #boolean code
  +int status
  +setLevel()
  +findCode()
  +calculateScore()
  +updateAddress()
}
class Report {
  -String price
  #Date id
  +sendDescription()
  +updateEmail()
  +setCreatedat()
  +sendCreatedat()
}
class Follower {
  -Date active
  -Date code
  #long createdAt
  +boolean amount
  -double level
  +deleteQuantity()
  +findCode()
  +updateUpdatedat()
}
interface Profile {
  #boolean phone
  +boolean name
  +int status
  +saveName()
  +updateDescription()
}
class Album {
  +float amount
  +boolean price
  +sendPhone()
  +calculatePhone()
  +processActive()
}
Message --> Report : "0..1"
User --|> Report
Follower --* Album
note right of User : Social Media domain
@enduml