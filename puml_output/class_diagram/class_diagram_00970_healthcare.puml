@startuml
skinparam monochrome true
skinparam shadowing true
class Doctor {
  +long score
  #Date email
  #float total
  +String price
  #float level
  +sendType()
  +findTotal()
}
class Appointment {
  #float active
  +float address
  #double duration
  -int code
  -boolean description
  +validateTotal()
  +createDescription()
  +createAmount()
}
class Insurance {
  -int id
  #boolean score
  +double quantity
  #boolean level
  +cancelUpdatedat()
  +validateTotal()
  +findDuration()
}
abstract class LabTest {
  -float address
  +Date type
  -String description
  -String id
  +createQuantity()
  +saveAddress()
  +findId()
}
LabTest --o Insurance
LabTest ..> Doctor : "1"
@enduml