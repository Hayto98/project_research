@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
abstract class Enrollment {
  +long note
  +double updatedAt
  +sendEmail()
  +findAmount()
  +processEmail()
}
class Student {
  -long quantity
  -String total
  +getCreatedat()
}
class Library {
  +int note
  +Date phone
  +long quantity
  +createStatus()
  +getAmount()
  +getId()
}
interface Schedule {
  -boolean phone
  +String type
  -long quantity
  +getEmail()
  +findNote()
  +getAmount()
  +getType()
}
Schedule --* Student
Enrollment --* Library
@enduml