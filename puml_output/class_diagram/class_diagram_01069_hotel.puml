@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Restaurant {
  -float status
  -int id
  +deletePrice()
  +setPhone()
  +setStatus()
  +processId()
}
class Housekeeping {
  #long amount
  #boolean quantity
  -boolean email
  #long name
  #boolean phone
  +processPhone()
}
class Guest {
  -int note
  +String address
  -String price
  -Date total
  #float code
  +validateNote()
  +setAddress()
  +processDuration()
}
abstract class Invoice {
  -String quantity
  +int type
  +cancelLevel()
  +saveStatus()
  +calculateDuration()
  +validateCode()
}
class Service {
  +int duration
  -boolean name
  -boolean note
  +String email
  +updateDuration()
  +updateCreatedat()
  +deleteQuantity()
  +validateDuration()
}
abstract class CheckIn {
  #Date amount
  #float email
  +long id
  +String type
  +findAddress()
  +getPrice()
  +validatePhone()
  +calculateDuration()
}
Housekeeping --|> Restaurant
Service ..> CheckIn : "*"
Housekeeping --* Guest
Invoice --* Housekeeping
@enduml