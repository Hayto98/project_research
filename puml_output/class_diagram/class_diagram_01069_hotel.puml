@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Restaurant {
  -float status
  -int id
  +processDuration()
  +setLevel()
  +validateLevel()
  +calculateAmount()
}
class Housekeeping {
  #Date name
  -Date phone
  #String quantity
  +float note
  +processAddress()
  +calculateTotal()
  +setPrice()
  +updateUpdatedat()
}
class Guest {
  -float name
  +float address
  -double phone
  -String updatedAt
  +int active
  +sendDescription()
  +createEmail()
  +cancelName()
  +processEmail()
}
class Invoice {
  #String address
  +Date score
  #boolean phone
  +getStatus()
  +validatePrice()
  +validateAmount()
  +createId()
}
abstract class Service {
  -int phone
  +boolean description
  -int id
  +setActive()
}
interface CheckIn {
  -float description
  #double phone
  -Date address
  #String total
  +String duration
  +processType()
}
Guest ..> CheckIn : "0..1"
CheckIn ..> Guest : "*"
Housekeeping ..> Restaurant : "1..*"
note right of Restaurant : Hotel domain
@enduml