@startuml
skinparam defaultFontSize 11
class Treatment {
  #float status
  +float level
  +processStatus()
  +calculateType()
  +cancelPhone()
  +sendPhone()
}
class Ward {
  #boolean duration
  -double quantity
  -long type
  +createDuration()
  +validateNote()
  +deleteScore()
  +cancelPrice()
}
class Billing {
  +String address
  #int type
  -Date id
  -boolean description
  #Date level
  +saveScore()
  +saveAmount()
  +getUpdatedat()
}
abstract class Diagnosis {
  #String code
  +String quantity
  +int level
  +updateEmail()
}
abstract class Hospital {
  -boolean score
  -boolean amount
  +deleteCreatedat()
}
Hospital ..> Billing : "1..*"
Diagnosis ..|> Treatment
@enduml