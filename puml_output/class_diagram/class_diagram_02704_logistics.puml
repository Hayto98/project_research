@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Warehouse {
  -boolean description
  +long updatedAt
  +Date level
  -long type
  #double total
  +deleteDuration()
  +updateDuration()
  +getUpdatedat()
  +validateActive()
}
class Driver {
  -double phone
  #double createdAt
  +int note
  +deleteActive()
}
interface FuelLog {
  +String address
  +float quantity
  -long level
  +createNote()
  +sendPhone()
  +getLevel()
  +validateEmail()
}
class Tracking {
  -boolean updatedAt
  +String score
  +int address
  -double type
  +createDuration()
  +setStatus()
  +cancelAmount()
  +saveAddress()
}
class Package {
  +float type
  -boolean name
  +float status
  #int address
  #float updatedAt
  +setCreatedat()
  +saveTotal()
  +cancelCode()
}
class Route {
  #long code
  #boolean price
  -boolean amount
  #Date description
  +double email
  +deleteQuantity()
  +createLevel()
  +saveDescription()
}
Route --> FuelLog : "*"
Tracking --* Route
@enduml