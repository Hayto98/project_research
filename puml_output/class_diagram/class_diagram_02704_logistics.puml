@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Warehouse {
  -boolean description
  +long updatedAt
  +Date level
  -long type
  #double total
  +processId()
  +cancelUpdatedat()
  +sendUpdatedat()
  +validateCreatedat()
}
abstract class Driver {
  +double note
  #int level
  -long price
  -float status
  +String updatedAt
  +calculateQuantity()
}
abstract class FuelLog {
  +boolean code
  -Date status
  -double createdAt
  #String address
  +deleteAmount()
}
abstract class Tracking {
  #boolean total
  #double price
  #double status
  +Date amount
  +long score
  +updateQuantity()
  +sendCode()
}
interface Package {
  #float level
  -double email
  #Date type
  +calculateAmount()
}
class Route {
  #Date address
  +double score
  -String duration
  #Date active
  +findQuantity()
}
Tracking --* Route
Warehouse ..> Tracking : "0..1"
Route --|> Driver
Warehouse --> Route : "0..1"
Route --|> Package
note right of Warehouse : Logistics domain
@enduml