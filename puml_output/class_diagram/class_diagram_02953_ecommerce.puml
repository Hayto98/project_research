@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Coupon {
  #long address
  #Date total
  -Date duration
  +Date description
  -boolean createdAt
  +sendLevel()
}
class Order {
  #int quantity
  -int email
  +deleteName()
  +saveType()
}
class Shipment {
  #double score
  #Date active
  #boolean createdAt
  -int code
  +String level
  +processDuration()
  +deleteDuration()
  +updateDescription()
  +updateAmount()
}
abstract class Payment {
  +double price
  -boolean note
  #int status
  #Date amount
  +createDuration()
  +getAddress()
  +cancelAddress()
  +getName()
}
class Customer {
  -long id
  +boolean name
  +Date duration
  +calculateAmount()
  +setQuantity()
}
abstract class Review {
  +boolean score
  #boolean type
  -Date status
  #int code
  #Date note
  +sendAddress()
  +processDescription()
}
Payment --* Coupon
Customer ..|> Shipment
Customer --o Coupon
@enduml