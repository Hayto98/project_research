@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Coupon {
  #long address
  #Date total
  -Date duration
  +Date description
  -boolean createdAt
  +validateName()
}
class Order {
  +long duration
  -double amount
  #boolean note
  #int level
  +setScore()
}
abstract class Shipment {
  -int amount
  -long status
  #double level
  #double type
  +boolean updatedAt
  +getNote()
  +createActive()
}
class Payment {
  +String price
  +long total
  -int quantity
  #String email
  #Date updatedAt
  +processPrice()
  +calculateScore()
}
abstract class Customer {
  +boolean code
  #boolean note
  +findLevel()
  +deleteScore()
  +saveUpdatedat()
  +createQuantity()
}
class Review {
  #Date status
  +double address
  -long active
  +int level
  #String amount
  +createLevel()
  +sendUpdatedat()
}
Payment --> Order : "1"
Customer --* Shipment
note right of Coupon : Ecommerce domain
@enduml