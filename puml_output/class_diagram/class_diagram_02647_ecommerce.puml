@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Customer {
  -float type
  -int active
  +int description
  -int email
  +sendDuration()
  +sendActive()
}
class Coupon {
  -float duration
  #long note
  +setScore()
}
class Cart {
  +Date createdAt
  -double code
  +cancelUpdatedat()
  +savePrice()
}
class Supplier {
  +double code
  +float duration
  +getAmount()
  +processUpdatedat()
  +createScore()
}
interface Product {
  +double type
  +Date total
  +createLevel()
}
class Wishlist {
  #long active
  #int updatedAt
  +String price
  -double quantity
  +updateId()
  +deleteCode()
}
class Shipment {
  -float score
  -String type
  #float createdAt
  +long duration
  +getName()
  +calculateAmount()
  +updateName()
  +sendCreatedat()
}
Cart --> Wishlist : "1"
Coupon ..|> Cart
@enduml