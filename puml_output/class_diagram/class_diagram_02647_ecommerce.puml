@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Customer {
  -float type
  -int active
  +int description
  -int email
  +saveDuration()
  +saveAddress()
}
interface Coupon {
  -float duration
  #long note
  +saveId()
}
interface Cart {
  +Date createdAt
  -double code
  +findLevel()
  +createId()
}
class Supplier {
  +float status
  #boolean price
  +saveAmount()
  +updateActive()
  +saveName()
}
abstract class Product {
  -boolean createdAt
  #Date price
  +boolean code
  -long id
  #long phone
  +updateId()
  +createTotal()
}
interface Wishlist {
  #Date phone
  -Date updatedAt
  +int quantity
  +processStatus()
  +findDescription()
  +createTotal()
  +processStatus()
}
abstract class Shipment {
  +int address
  -int level
  +findActive()
}
Coupon --* Product
Coupon ..|> Wishlist
Shipment --|> Product
note right of Customer : Ecommerce domain
@enduml