@startuml
skinparam monochrome true
abstract class Like {
  -boolean level
  +float duration
  +String amount
  -String id
  +updateDescription()
  +validateDuration()
  +saveDescription()
  +calculateTotal()
}
class Comment {
  -long score
  +int createdAt
  #long total
  +cancelNote()
  +cancelTotal()
  +getCode()
}
class Story {
  +long createdAt
  +double duration
  -Date active
  +calculateDuration()
  +deleteStatus()
}
interface Album {
  #int id
  -double note
  -long quantity
  +setScore()
  +cancelDuration()
  +findStatus()
  +deleteLevel()
}
Comment --> Story : "1..*"
Like ..|> Album
@enduml