@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Cart {
  -Date note
  #Date price
  #long level
  +validateEmail()
  +createUpdatedat()
  +createType()
}
class Customer {
  +boolean level
  #float description
  #float id
  +double amount
  +processStatus()
}
class Invoice {
  +String quantity
  #int updatedAt
  -float type
  -int name
  +findDescription()
  +setEmail()
}
class Shipment {
  -String price
  -int note
  #float code
  #Date level
  +deleteQuantity()
}
class Review {
  #double type
  -long note
  -int id
  +deleteDescription()
}
class Order {
  +String updatedAt
  -float description
  #boolean duration
  -double total
  +boolean id
  +sendPrice()
  +processPrice()
  +createId()
  +findCode()
}
Customer ..|> Cart
Order --o Review
note right of Cart : Ecommerce domain
@enduml