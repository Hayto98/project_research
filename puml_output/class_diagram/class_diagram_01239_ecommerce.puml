@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Cart {
  -Date note
  #Date price
  #long level
  +sendPhone()
  +sendAddress()
  +setQuantity()
}
class Customer {
  -float quantity
  #int type
  +boolean status
  +updateStatus()
  +saveDuration()
}
interface Invoice {
  #Date total
  +float name
  -boolean note
  +calculatePhone()
  +createScore()
  +sendCreatedat()
}
class Shipment {
  -float id
  -int level
  +Date description
  +calculateLevel()
  +updateQuantity()
}
class Review {
  +double amount
  -String address
  -int price
  #float note
  +createCode()
}
class Order {
  -boolean active
  -boolean duration
  +Date amount
  +calculateName()
  +updateTotal()
  +findAmount()
  +updateStatus()
}
Customer --* Order
Review ..|> Shipment
@enduml