@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Teller {
  #float duration
  +String active
  -String updatedAt
  -double description
  +sendEmail()
  +createAmount()
}
class Interest {
  +String type
  #boolean address
  +cancelPrice()
  +updateLevel()
  +calculateActive()
  +createName()
}
class Statement {
  #boolean address
  -boolean price
  +Date type
  +findName()
  +findDescription()
  +sendQuantity()
}
class Transfer {
  -float id
  #Date score
  +Date amount
  +String description
  -String price
  +getDuration()
}
Teller ..|> Transfer
note right of Teller : Banking domain
@enduml