@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Teller {
  #float duration
  +String active
  -String updatedAt
  -double description
  +saveLevel()
  +cancelAmount()
}
class Interest {
  #long amount
  +String phone
  #boolean status
  -boolean type
  +deleteAddress()
  +processEmail()
  +saveName()
  +cancelName()
}
interface Statement {
  -double name
  #boolean amount
  -boolean level
  +Date address
  +updateScore()
  +saveId()
  +cancelDescription()
}
class Transfer {
  +double id
  -float price
  #Date duration
  +Date amount
  +setName()
  +updateQuantity()
}
Teller --|> Statement
Teller ..|> Transfer
@enduml