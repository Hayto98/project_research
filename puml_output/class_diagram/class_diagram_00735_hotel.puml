@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Service {
  -long description
  -boolean status
  +long code
  +setType()
}
class Guest {
  #boolean level
  +long phone
  #Date code
  #Date price
  +setEmail()
  +sendType()
  +findNote()
}
interface Invoice {
  +int level
  -float type
  -int id
  +calculateQuantity()
  +validateScore()
  +createCreatedat()
  +cancelUpdatedat()
}
interface Room {
  #Date type
  +boolean price
  +deleteScore()
  +sendUpdatedat()
}
class Amenity {
  -long active
  #float createdAt
  +createType()
  +sendDescription()
  +calculatePhone()
  +getPrice()
}
class Booking {
  #long updatedAt
  +Date note
  +boolean active
  -long price
  +cancelCode()
  +createLevel()
  +updateAmount()
}
interface Reservation {
  -Date code
  #long description
  #long status
  #boolean price
  +calculateUpdatedat()
}
Invoice --o Reservation
Guest --> Invoice : "1"
Room --* Guest
@enduml