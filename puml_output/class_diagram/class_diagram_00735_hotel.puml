@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Service {
  -long description
  -boolean status
  +long code
  +deleteStatus()
}
class Guest {
  -boolean code
  #boolean price
  #boolean active
  -long createdAt
  +cancelAmount()
}
interface Invoice {
  +boolean id
  -double duration
  -int createdAt
  #Date price
  #float type
  +processPrice()
}
interface Room {
  #float active
  #long createdAt
  +float amount
  +validateEmail()
  +cancelType()
}
class Amenity {
  -boolean quantity
  -int updatedAt
  #int note
  #long active
  +validateType()
  +findScore()
  +validateCode()
}
class Booking {
  -long level
  #boolean score
  +saveEmail()
  +cancelDuration()
  +saveCode()
}
class Reservation {
  #String quantity
  -int price
  -String description
  +Date email
  +findId()
  +calculateNote()
  +validatePrice()
  +createName()
}
Guest ..|> Amenity
Service ..|> Reservation
note right of Service : Hotel domain
@enduml