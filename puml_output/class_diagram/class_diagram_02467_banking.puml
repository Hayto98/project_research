@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
interface Branch {
  +float address
  #double name
  +sendNote()
  +setScore()
  +validateUpdatedat()
  +processPhone()
}
interface Transfer {
  +Date score
  #Date active
  #Date level
  -int id
  #int createdAt
  +getEmail()
  +setId()
  +deleteEmail()
  +createType()
}
class Statement {
  +float type
  -long description
  +createName()
  +sendQuantity()
  +cancelPrice()
  +sendAmount()
}
class Customer {
  -float price
  -long note
  +long active
  +boolean quantity
  #float amount
  +findAmount()
}
Transfer ..|> Statement
Customer --> Branch : "*"
note right of Branch : Banking domain
@enduml