@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Grade {
  #float code
  #String score
  +float note
  +deleteActive()
  +updatePrice()
}
class Exam {
  +Date description
  +int active
  -boolean email
  +findUpdatedat()
  +createActive()
  +findQuantity()
  +setScore()
}
class Library {
  #Date note
  #double address
  +int active
  -int createdAt
  +saveDescription()
  +createDescription()
  +createPhone()
  +cancelStatus()
}
class Course {
  +Date price
  +float duration
  +long name
  +processDescription()
  +getActive()
}
Grade --|> Course
Library --|> Grade
note right of Grade : Education domain
@enduml