@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Grade {
  #float code
  #String score
  +float note
  +setLevel()
  +createDescription()
}
class Exam {
  +Date status
  +int amount
  -boolean description
  -Date active
  +long email
  +deleteQuantity()
  +calculateDuration()
  +getStatus()
}
class Library {
  #Date note
  #double address
  +int active
  -int createdAt
  +cancelDuration()
  +updateId()
  +sendDuration()
  +setType()
}
class Course {
  +boolean email
  +double phone
  -String status
  +calculateUpdatedat()
}
Exam ..|> Course
Course --|> Grade
@enduml