@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
abstract class Transaction {
  +double active
  -int code
  +deleteDescription()
}
class Card {
  +long price
  -long phone
  +double level
  +updateScore()
  +createNote()
  +savePhone()
  +getName()
}
class Branch {
  #Date total
  #double phone
  #Date createdAt
  #Date level
  +createCreatedat()
  +processDuration()
}
class Customer {
  #String amount
  #Date duration
  -String type
  +saveCode()
  +calculateTotal()
  +setType()
  +findLevel()
}
Transaction --o Customer
Customer --o Branch
@enduml