@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
abstract class Guest {
  -boolean description
  -double name
  #long status
  +findQuantity()
}
class Housekeeping {
  -Date total
  -Date createdAt
  #int score
  +deleteTotal()
  +validateLevel()
  +getAmount()
  +sendCreatedat()
}
interface Booking {
  #String level
  -int description
  #float score
  +createScore()
  +saveStatus()
  +getPhone()
}
abstract class CheckOut {
  #long score
  #int updatedAt
  +sendCode()
  +updateAmount()
  +updateStatus()
}
class Payment {
  -float total
  +boolean status
  +deleteName()
  +createPrice()
  +updateEmail()
  +deleteActive()
}
CheckOut --o Guest
CheckOut ..|> Housekeeping
CheckOut --> Payment : "*"
Payment ..|> Guest
@enduml