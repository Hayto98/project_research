@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Room {
  -String amount
  +double score
  #int type
  +createCode()
  +processQuantity()
  +savePhone()
  +updateActive()
}
class Guest {
  +long email
  #Date address
  -long createdAt
  +setCode()
  +setPrice()
  +setScore()
  +calculateScore()
}
interface Service {
  -double status
  +boolean createdAt
  +boolean type
  +boolean phone
  +cancelAddress()
  +calculatePhone()
  +getActive()
}
abstract class Housekeeping {
  #String score
  #Date status
  #int level
  +updatePhone()
  +setDescription()
  +deleteCreatedat()
  +validateCode()
}
class Restaurant {
  #float note
  +int score
  -String amount
  #String duration
  -double description
  +setUpdatedat()
  +sendAddress()
  +processDescription()
}
class Amenity {
  +float createdAt
  #boolean price
  +getActive()
  +findAmount()
  +deleteActive()
  +cancelPhone()
}
class Invoice {
  -boolean level
  #long amount
  +findName()
  +setScore()
  +createTotal()
  +getAddress()
}
Room ..|> Guest
Guest --o Invoice
@enduml