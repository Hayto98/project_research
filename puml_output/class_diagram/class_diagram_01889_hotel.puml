@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Room {
  -String amount
  +double score
  #int type
  +deleteName()
  +getId()
  +findCode()
  +updateEmail()
}
class Guest {
  -float status
  -Date quantity
  #long note
  +setCreatedat()
  +processPhone()
  +processPrice()
}
class Service {
  #Date active
  -long amount
  -Date duration
  +deleteScore()
  +setStatus()
  +saveStatus()
  +sendDescription()
}
abstract class Housekeeping {
  +Date email
  -double description
  +processDescription()
  +saveAmount()
}
class Restaurant {
  +long code
  -float duration
  #int price
  +int type
  -int email
  +findTotal()
  +processEmail()
  +updateName()
  +cancelAmount()
}
class Amenity {
  +float total
  +int level
  +int duration
  -boolean id
  +setUpdatedat()
  +deleteAmount()
  +createScore()
}
class Invoice {
  +int email
  +Date status
  -long total
  -Date active
  +deleteDuration()
  +setDuration()
  +getUpdatedat()
}
Amenity --> Housekeeping : "0..1"
Amenity --o Guest
Service --> Room : "0..1"
note right of Room : Hotel domain
@enduml