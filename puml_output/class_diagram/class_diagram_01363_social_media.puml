@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Story {
  #int id
  #long quantity
  +double updatedAt
  +findAddress()
  +deletePhone()
}
class Like {
  #float price
  +String note
  #String name
  +boolean description
  +long total
  +calculateCode()
  +deleteNote()
}
class Report {
  +int updatedAt
  #Date phone
  #boolean duration
  -Date active
  +updateCreatedat()
  +getStatus()
}
class Profile {
  +int email
  +float amount
  +long name
  -double description
  +calculateAddress()
}
Like --* Story
Report --o Story
note right of Story : Social Media domain
@enduml