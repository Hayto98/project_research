@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Story {
  #int id
  #long quantity
  +double updatedAt
  +setCreatedat()
  +calculateName()
}
class Like {
  #String quantity
  +double type
  #float price
  +String note
  +setUpdatedat()
}
interface Report {
  #String quantity
  +double description
  +long price
  +validatePrice()
  +updateTotal()
}
class Profile {
  -Date updatedAt
  #int active
  +int score
  +cancelEmail()
}
Report ..|> Like
Story ..|> Report
@enduml