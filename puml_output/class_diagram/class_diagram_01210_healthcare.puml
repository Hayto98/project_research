@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Prescription {
  +double id
  -String score
  #Date price
  -long status
  +validateQuantity()
  +setTotal()
  +processDescription()
}
class Nurse {
  +long amount
  #boolean name
  #long note
  +long description
  +calculateStatus()
  +findType()
}
class Billing {
  +String score
  #Date quantity
  -Date phone
  #Date createdAt
  +saveDescription()
  +setPrice()
}
class Insurance {
  -long level
  -boolean quantity
  +int id
  #long type
  +processCreatedat()
  +calculateAddress()
  +cancelLevel()
}
interface Doctor {
  #float score
  +long createdAt
  +validateActive()
}
class Diagnosis {
  #String code
  -boolean level
  #boolean note
  -float id
  #Date duration
  +findNote()
  +findCode()
  +findEmail()
  +validateQuantity()
}
class Treatment {
  #String duration
  #float id
  #long active
  -boolean phone
  #int code
  +deleteAddress()
  +cancelScore()
}
Nurse --|> Billing
Prescription --|> Treatment
@enduml