@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Prescription {
  +double id
  -String score
  #Date price
  -long status
  +deleteQuantity()
  +createEmail()
  +validateAmount()
}
class Nurse {
  +long description
  +Date updatedAt
  +long email
  #long active
  #float score
  +updateStatus()
  +getScore()
  +savePhone()
}
class Billing {
  #float quantity
  -double level
  -double duration
  #float id
  +deleteLevel()
  +validateDuration()
}
class Insurance {
  #Date score
  +boolean name
  +long duration
  +cancelEmail()
}
abstract class Doctor {
  +String level
  #String note
  +cancelScore()
  +createType()
  +setPhone()
}
class Diagnosis {
  -float active
  #String price
  #String id
  #float duration
  +processScore()
  +saveCreatedat()
  +deleteUpdatedat()
}
class Treatment {
  +float phone
  +double name
  -float id
  +updatePrice()
  +findAmount()
  +updateCreatedat()
  +processId()
}
Doctor ..> Nurse : "0..1"
Prescription --o Treatment
note right of Prescription : Healthcare domain
@enduml