@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Guest {
  -double updatedAt
  -String total
  #Date amount
  +long code
  -float quantity
  +findDuration()
  +calculateName()
  +calculateQuantity()
}
class CheckIn {
  +boolean code
  +int level
  #String name
  +double id
  -long description
  +saveType()
}
class Housekeeping {
  #String price
  -double email
  #boolean level
  +createDuration()
  +sendAmount()
  +saveCreatedat()
  +deleteAmount()
}
class Booking {
  #long type
  +Date duration
  #double createdAt
  +Date quantity
  #String email
  +processDuration()
  +findAddress()
  +sendId()
}
class Service {
  #int note
  -Date address
  #Date active
  -double duration
  +processCreatedat()
  +deleteUpdatedat()
  +validatePrice()
}
class Amenity {
  +int duration
  +long description
  +cancelActive()
}
abstract class Reservation {
  -boolean status
  -long score
  +sendUpdatedat()
  +setLevel()
}
CheckIn --|> Guest
Housekeeping --> Booking : "*"
@enduml