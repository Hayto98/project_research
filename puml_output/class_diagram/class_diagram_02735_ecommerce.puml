@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Cart {
  -float total
  -long status
  +float description
  #int email
  -double name
  +saveAddress()
  +deleteAmount()
  +calculatePrice()
}
class Product {
  #long amount
  #long score
  #String updatedAt
  +boolean id
  +updateId()
  +cancelAddress()
  +saveNote()
  +processName()
}
class Supplier {
  -double duration
  +long id
  +boolean status
  +sendStatus()
  +saveDuration()
}
interface Payment {
  +boolean active
  +boolean id
  +Date quantity
  -float phone
  +deleteNote()
  +calculateName()
  +sendPhone()
}
class Coupon {
  -int amount
  +double type
  #float price
  -Date quantity
  +sendCode()
  +cancelQuantity()
  +getPrice()
  +sendNote()
}
Payment ..|> Supplier
Cart ..|> Product
Cart --|> Payment
note right of Cart : Ecommerce domain
@enduml