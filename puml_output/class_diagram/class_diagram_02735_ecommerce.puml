@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Cart {
  -float total
  -long status
  +float description
  #int email
  -double name
  +getAmount()
  +calculateStatus()
  +saveCreatedat()
}
class Product {
  -int price
  #int duration
  #String quantity
  +findName()
  +cancelPhone()
  +updateNote()
}
class Supplier {
  #float level
  #double score
  +deletePhone()
  +sendPrice()
}
class Payment {
  +Date note
  #float duration
  #String name
  #String amount
  +validateLevel()
  +findEmail()
  +updateEmail()
  +getEmail()
}
class Coupon {
  #String active
  #boolean createdAt
  +findDuration()
  +processName()
  +setQuantity()
}
Supplier --> Cart : "0..1"
Coupon ..> Cart : "*"
Supplier --o Product
@enduml