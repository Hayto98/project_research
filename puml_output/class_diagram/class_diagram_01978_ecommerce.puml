@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Order {
  -double description
  #double active
  +String name
  +processType()
  +findActive()
}
class Warehouse {
  +String duration
  #double createdAt
  #Date phone
  +updateUpdatedat()
  +findCode()
  +savePrice()
}
abstract class Review {
  #boolean id
  +int phone
  +getType()
}
abstract class Supplier {
  -long type
  -int address
  #String phone
  #int status
  +setType()
  +deleteDuration()
  +validateTotal()
}
Order --* Warehouse
Supplier --|> Order
@enduml