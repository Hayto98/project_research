@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Order {
  -double description
  #double active
  +String name
  +calculateType()
  +savePhone()
}
class Warehouse {
  #double phone
  #Date description
  #Date code
  +setPhone()
  +cancelPrice()
  +setId()
}
class Review {
  #double createdAt
  -double code
  -boolean level
  +setType()
  +validatePhone()
  +deleteCode()
}
class Supplier {
  -long description
  #Date note
  -String type
  +String status
  +cancelAddress()
  +setUpdatedat()
  +sendDuration()
  +updateQuantity()
}
Supplier --* Order
Warehouse --* Order
note right of Order : Ecommerce domain
@enduml