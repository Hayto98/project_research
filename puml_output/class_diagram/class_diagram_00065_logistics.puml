@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Vehicle {
  -String phone
  -long address
  #boolean total
  +createCode()
  +updatePhone()
  +sendType()
  +calculateCreatedat()
}
interface Package {
  #String address
  #Date description
  +validateId()
  +cancelAddress()
  +calculateEmail()
  +savePrice()
}
class Manifest {
  #boolean address
  +long description
  +int type
  -long name
  +long amount
  +processNote()
  +updateDescription()
  +setPrice()
}
interface Route {
  -boolean level
  #Date note
  +getName()
  +cancelTotal()
}
Package ..> Vehicle : "0..1"
Vehicle ..|> Package
Manifest --> Vehicle : "0..1"
@enduml