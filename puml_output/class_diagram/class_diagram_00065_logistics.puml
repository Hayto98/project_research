@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Vehicle {
  -String phone
  -long address
  #boolean total
  +deleteAddress()
  +sendScore()
  +setAddress()
  +deleteLevel()
}
class Package {
  #boolean status
  #Date duration
  -float quantity
  #float name
  -int updatedAt
  +getAmount()
  +sendActive()
  +getQuantity()
  +deleteUpdatedat()
}
abstract class Manifest {
  #boolean description
  #String address
  #double email
  -boolean createdAt
  +getPhone()
  +updateStatus()
}
class Route {
  #float email
  #long createdAt
  +cancelAmount()
}
Manifest --> Vehicle : "0..1"
Package --o Vehicle
Route ..> Vehicle : "1"
note right of Vehicle : Logistics domain
@enduml