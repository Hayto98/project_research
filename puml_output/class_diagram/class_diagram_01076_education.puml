@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Classroom {
  +float name
  #String email
  -boolean updatedAt
  +findActive()
}
class Course {
  -int active
  +boolean address
  -long level
  +float updatedAt
  -float score
  +saveQuantity()
  +deleteLevel()
}
class Student {
  -String address
  -double quantity
  +double createdAt
  +createName()
  +sendStatus()
  +validateUpdatedat()
  +sendCreatedat()
}
class Department {
  -String address
  #Date score
  #float name
  -double amount
  +saveCreatedat()
  +processAmount()
  +calculateNote()
  +findPrice()
}
class Exam {
  -String name
  #int total
  #Date note
  -float address
  +String amount
  +updateNote()
  +findDescription()
  +cancelId()
  +getScore()
}
class Attendance {
  #int email
  #boolean phone
  +long duration
  +saveScore()
  +calculateCode()
  +getActive()
}
class Book {
  +float description
  +double amount
  #boolean phone
  #String code
  #Date quantity
  +deleteName()
  +sendNote()
  +calculateTotal()
}
Exam ..|> Course
Exam ..|> Department
Department --> Attendance : "1"
Classroom --o Attendance
note right of Classroom : Education domain
@enduml