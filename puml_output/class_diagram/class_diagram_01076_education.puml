@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Classroom {
  +float name
  #String email
  -boolean updatedAt
  +cancelUpdatedat()
}
interface Course {
  -long active
  #float score
  +float note
  #long duration
  +sendNote()
  +createCode()
  +setPhone()
  +findScore()
}
class Student {
  #float quantity
  -int createdAt
  +setId()
  +sendNote()
}
class Department {
  -String createdAt
  -double note
  -float name
  #Date phone
  +createDescription()
}
class Exam {
  -long updatedAt
  #float score
  +int createdAt
  -String name
  +findActive()
  +createTotal()
  +sendCode()
}
class Attendance {
  #double amount
  +double price
  #double note
  -int level
  -String id
  +processNote()
  +validateTotal()
}
class Book {
  +Date id
  -Date note
  +processId()
  +processName()
}
Exam ..|> Course
Student ..> Book : "1..*"
@enduml