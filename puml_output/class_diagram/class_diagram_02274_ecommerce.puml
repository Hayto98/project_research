@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Review {
  -String address
  #int quantity
  +float level
  +setNote()
  +deleteCode()
  +updateCode()
  +calculateQuantity()
}
class Payment {
  -float score
  +int note
  +findNote()
  +deleteId()
  +getCode()
  +findActive()
}
class Customer {
  #boolean note
  -double score
  +Date type
  +double duration
  -boolean updatedAt
  +findActive()
  +getActive()
  +processLevel()
  +sendCode()
}
class Product {
  +int total
  -Date createdAt
  -String code
  +cancelPhone()
  +updatePrice()
}
interface Supplier {
  #Date price
  -double total
  +String createdAt
  -float quantity
  +saveType()
  +updateTotal()
  +processActive()
}
Payment ..|> Product
Supplier --> Review : "1"
Customer ..|> Product
Customer ..|> Supplier
@enduml