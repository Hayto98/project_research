@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Review {
  -String address
  #int quantity
  +float level
  +calculatePhone()
  +calculateCode()
  +getScore()
  +cancelNote()
}
abstract class Payment {
  #double description
  -double total
  -boolean code
  +processUpdatedat()
  +sendLevel()
  +calculateType()
  +updateName()
}
abstract class Customer {
  -int active
  +double note
  +String type
  +int total
  +findNote()
  +getDescription()
  +createId()
}
interface Product {
  #Date price
  -double total
  +String createdAt
  -float quantity
  +validateCreatedat()
  +sendCreatedat()
  +processCreatedat()
}
interface Supplier {
  -Date active
  #Date name
  +deletePhone()
  +createCreatedat()
  +createActive()
  +setUpdatedat()
}
Review ..|> Product
Customer ..> Product : "0..1"
Customer ..|> Payment
note right of Review : Ecommerce domain
@enduml