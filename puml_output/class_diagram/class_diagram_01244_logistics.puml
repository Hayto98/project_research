@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Tracking {
  -boolean duration
  -String total
  #long phone
  +int quantity
  -boolean email
  +saveNote()
  +cancelActive()
  +validateDuration()
  +findNote()
}
class DeliveryNote {
  #String createdAt
  -long note
  +long quantity
  +double amount
  +float level
  +setName()
  +createTotal()
  +calculatePrice()
}
class Inventory {
  #String address
  -float email
  +cancelStatus()
  +createPrice()
}
class Vehicle {
  #int name
  +float price
  +sendActive()
  +processLevel()
  +getType()
  +createPrice()
}
class Driver {
  +Date phone
  #Date description
  +processAmount()
  +cancelScore()
}
interface Customer {
  -double price
  +String description
  #Date address
  +String id
  -float level
  +cancelNote()
}
class Package {
  -double email
  -int amount
  #double status
  -double address
  #String description
  +calculateDuration()
  +calculateName()
  +saveName()
}
Inventory --|> Tracking
DeliveryNote ..|> Vehicle
note right of Tracking : Logistics domain
@enduml