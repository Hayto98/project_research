@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Tracking {
  -boolean duration
  -String total
  #long phone
  +int quantity
  -boolean email
  +cancelPrice()
  +setDuration()
  +processTotal()
  +deleteUpdatedat()
}
interface DeliveryNote {
  +Date duration
  #double note
  -int name
  -boolean level
  +sendScore()
}
class Inventory {
  -int address
  -String code
  +setTotal()
}
abstract class Vehicle {
  #String price
  -float address
  +boolean id
  +long level
  -int email
  +saveEmail()
}
abstract class Driver {
  #boolean description
  -boolean score
  +double note
  +saveCode()
  +setAmount()
  +saveEmail()
}
class Customer {
  +boolean description
  #boolean id
  -double createdAt
  +float note
  +saveType()
  +setName()
  +calculateType()
}
class Package {
  +long total
  +boolean updatedAt
  -int status
  -long score
  +validateId()
  +deleteStatus()
}
Customer --> Inventory : "0..1"
Inventory --* Vehicle
DeliveryNote --o Customer
Vehicle ..> Package : "1"
Driver --|> Vehicle
@enduml