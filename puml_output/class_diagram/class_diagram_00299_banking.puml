@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Transaction {
  -int note
  #double duration
  #float active
  -boolean createdAt
  #String quantity
  +createName()
}
class Interest {
  #long type
  -float createdAt
  #double id
  #long duration
  +processType()
  +sendTotal()
  +setActive()
}
class Account {
  +int active
  #int total
  +Date name
  +deleteCreatedat()
  +findQuantity()
}
interface Withdrawal {
  #boolean price
  +int level
  +Date score
  #boolean updatedAt
  +cancelNote()
  +getPhone()
}
interface Statement {
  #boolean id
  +double status
  +saveType()
  +cancelCreatedat()
}
class Customer {
  #String note
  #boolean quantity
  -double total
  #long description
  +updateActive()
  +getId()
}
Withdrawal --o Customer
Account ..> Transaction : "*"
Customer --> Transaction : "1"
Statement ..|> Account
note right of Transaction : Banking domain
@enduml