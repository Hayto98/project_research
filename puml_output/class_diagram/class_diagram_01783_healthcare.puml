@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Insurance {
  +long duration
  #float address
  -double price
  +findActive()
  +getStatus()
  +sendActive()
}
abstract class Patient {
  +int note
  +int email
  +double price
  +cancelPrice()
  +processName()
  +validateUpdatedat()
}
interface Hospital {
  -double amount
  #double updatedAt
  -String email
  #Date code
  -long type
  +deleteNote()
  +sendUpdatedat()
  +updateId()
  +sendQuantity()
}
abstract class Appointment {
  -long total
  +String level
  +String quantity
  #boolean amount
  +createQuantity()
  +calculateScore()
  +processName()
}
class Doctor {
  -int code
  #long amount
  +saveType()
}
abstract class LabTest {
  -boolean score
  +int duration
  +setTotal()
  +setLevel()
}
interface Treatment {
  -Date note
  +double total
  #int duration
  -Date level
  #boolean status
  +createDuration()
  +validateLevel()
  +updateScore()
  +validateDescription()
}
Insurance ..> Doctor : "1"
Hospital --|> Insurance
@enduml