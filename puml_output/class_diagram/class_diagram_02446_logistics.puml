@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Vehicle {
  -Date email
  -float description
  +saveEmail()
  +updatePhone()
  +saveCreatedat()
}
class FuelLog {
  #boolean address
  +Date price
  -double active
  +findUpdatedat()
  +saveDescription()
  +saveCode()
}
abstract class Depot {
  #long status
  #String active
  #int price
  +boolean code
  -String quantity
  +updateNote()
  +cancelPhone()
  +calculateNote()
  +saveAmount()
}
abstract class DeliveryNote {
  +int email
  #long price
  +deletePhone()
}
class Manifest {
  -boolean id
  -int phone
  -long email
  -boolean duration
  +createStatus()
  +createTotal()
}
DeliveryNote ..> Manifest : "0..1"
Manifest ..> DeliveryNote : "*"
@enduml