@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Enrollment {
  #Date updatedAt
  +long price
  +String amount
  +double createdAt
  +validateTotal()
  +deleteDuration()
  +getQuantity()
}
class Student {
  +Date price
  -boolean status
  -int email
  -boolean quantity
  #String total
  +updateUpdatedat()
  +setStatus()
}
class Teacher {
  +boolean note
  -String description
  +int level
  #float active
  #Date email
  +sendId()
  +calculateNote()
  +deleteDuration()
  +validateUpdatedat()
}
abstract class Library {
  #Date score
  +String email
  +boolean id
  +cancelNote()
  +getUpdatedat()
}
Teacher --o Student
Library ..|> Teacher
note right of Enrollment : Education domain
@enduml