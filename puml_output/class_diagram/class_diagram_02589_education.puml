@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Enrollment {
  #Date updatedAt
  +long price
  +String amount
  +double createdAt
  +calculateName()
  +findAmount()
  +setLevel()
}
interface Student {
  -double quantity
  +long description
  +getAddress()
  +processActive()
  +cancelScore()
}
abstract class Teacher {
  +float createdAt
  +float type
  +long code
  -double updatedAt
  +Date active
  +getScore()
  +saveLevel()
}
class Library {
  +float duration
  +int note
  +createDescription()
  +cancelPrice()
  +processCode()
  +updateEmail()
}
Student --* Teacher
Student --> Library : "0..1"
Teacher ..> Enrollment : "1"
@enduml