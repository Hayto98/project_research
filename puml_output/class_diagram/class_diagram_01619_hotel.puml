@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
abstract class CheckIn {
  #String address
  #boolean active
  +validateDescription()
  +createStatus()
  +sendStatus()
}
abstract class Booking {
  #String score
  #Date name
  +getTotal()
}
class Payment {
  +int email
  +int active
  -long id
  +long amount
  +Date name
  +cancelPhone()
}
abstract class Amenity {
  -long total
  #int updatedAt
  #Date description
  +sendType()
}
abstract class Reservation {
  +boolean updatedAt
  #Date name
  +findName()
}
class Staff {
  +double updatedAt
  -double createdAt
  +saveLevel()
  +createPhone()
  +saveType()
  +validateUpdatedat()
}
Payment --* Booking
Payment ..> Reservation : "1"
Reservation --> Booking : "0..1"
note right of CheckIn : Hotel domain
@enduml