@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
abstract class CheckIn {
  #String address
  #boolean active
  +calculateCreatedat()
  +findPhone()
  +getNote()
}
class Booking {
  +boolean total
  +float score
  +validateActive()
}
class Payment {
  #double total
  -boolean email
  +calculateAddress()
}
class Amenity {
  +long amount
  -float code
  +findScore()
}
class Reservation {
  -boolean duration
  +double phone
  +findPhone()
  +createAmount()
}
class Staff {
  -double level
  +float code
  #float active
  +saveEmail()
  +sendStatus()
}
Reservation ..> Staff : "1"
Staff ..> CheckIn : "1"
CheckIn ..> Booking : "0..1"
@enduml