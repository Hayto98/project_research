@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Hospital {
  -Date createdAt
  -float status
  +cancelScore()
  +findType()
  +createPhone()
  +calculateAddress()
}
class Ward {
  #Date address
  -long status
  +validateCode()
  +getEmail()
  +getScore()
  +setId()
}
abstract class Patient {
  #float level
  #boolean code
  +String phone
  +String amount
  -String address
  +setDescription()
  +calculateCreatedat()
  +sendAmount()
}
class Prescription {
  -long level
  -Date code
  +saveNote()
  +setType()
}
interface Appointment {
  #long score
  -boolean name
  #boolean description
  #boolean phone
  #int address
  +validateName()
  +deleteScore()
  +validateDuration()
  +processStatus()
}
Patient --|> Ward
Ward --o Hospital
Ward ..> Appointment : "1"
Appointment --* Hospital
@enduml