@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
interface Staff {
  +float name
  +String email
  +getName()
}
class Room {
  -double quantity
  -double phone
  -String total
  +boolean name
  -long updatedAt
  +processUpdatedat()
}
abstract class Booking {
  -Date active
  -String code
  -long price
  +saveDescription()
  +createEmail()
  +deleteUpdatedat()
}
interface Invoice {
  #long note
  +long active
  #long duration
  +updateDuration()
  +calculateScore()
  +setTotal()
  +cancelActive()
}
class Guest {
  -float amount
  +String note
  +deleteName()
  +validateName()
  +saveType()
}
Booking --> Invoice : "1"
Invoice --* Room
note right of Staff : Hotel domain
@enduml