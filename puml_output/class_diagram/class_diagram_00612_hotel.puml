@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
interface Staff {
  +float name
  +String email
  +setUpdatedat()
}
class Room {
  -String total
  +float quantity
  -double phone
  +saveName()
  +updateCreatedat()
  +findActive()
  +getType()
}
class Booking {
  -int phone
  #Date code
  #float note
  #Date updatedAt
  +getPrice()
}
abstract class Invoice {
  -Date type
  +long status
  -int email
  +boolean score
  +processTotal()
  +getPrice()
}
interface Guest {
  +boolean phone
  -boolean updatedAt
  +double duration
  #boolean address
  #int note
  +updateType()
}
Invoice --|> Room
Booking --|> Room
Booking ..> Staff : "*"
@enduml