@startuml
skinparam monochrome true
class Billing {
  -String email
  -float code
  +Date score
  #String note
  #int phone
  +createScore()
  +updateStatus()
  +calculateQuantity()
}
class Insurance {
  +String createdAt
  #boolean id
  +processEmail()
}
interface Appointment {
  #boolean level
  -long updatedAt
  -Date code
  #boolean address
  +findDuration()
  +updateCode()
  +saveUpdatedat()
  +saveDescription()
}
class Treatment {
  -Date phone
  +Date createdAt
  +sendDuration()
  +updateCreatedat()
}
class Ward {
  +double description
  +String address
  +long code
  +int price
  +validateAddress()
  +validatePrice()
}
class Doctor {
  -double active
  -boolean total
  #int amount
  +float duration
  +setPhone()
}
class MedicalRecord {
  +boolean level
  #Date email
  #boolean note
  -Date status
  #double price
  +findQuantity()
  +createName()
  +findScore()
}
Treatment --* MedicalRecord
Billing --|> Doctor
Insurance ..> Appointment : "1..*"
@enduml