@startuml
skinparam monochrome true
class Billing {
  -String email
  -float code
  +Date score
  #String note
  #int phone
  +updateUpdatedat()
  +calculateName()
  +saveId()
}
class Insurance {
  #boolean id
  #String status
  +cancelUpdatedat()
  +setAddress()
  +findLevel()
}
class Appointment {
  #float address
  #Date active
  #float level
  +String note
  +updateNote()
  +saveAmount()
  +saveCreatedat()
}
class Treatment {
  +double description
  +String address
  +long code
  +int price
  +createPhone()
  +createActive()
}
abstract class Ward {
  -boolean active
  #int price
  +float note
  +cancelCode()
}
abstract class Doctor {
  #Date note
  #Date status
  #double price
  #Date code
  +createAddress()
  +processQuantity()
  +deleteNote()
  +processAddress()
}
class MedicalRecord {
  #long createdAt
  +float quantity
  +calculateTotal()
  +calculatePrice()
}
Doctor --|> Ward
Treatment --> Ward : "0..1"
Billing ..|> Doctor
note right of Billing : Healthcare domain
@enduml