@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Transaction {
  +boolean quantity
  -long phone
  #double score
  +Date address
  +calculateAmount()
  +createAmount()
  +createPrice()
}
interface Loan {
  +boolean active
  #float quantity
  -boolean phone
  +int note
  +createName()
}
class Card {
  +boolean status
  -int amount
  +double id
  -Date quantity
  #String score
  +processCreatedat()
}
abstract class Beneficiary {
  #int phone
  #double createdAt
  -boolean description
  +String level
  +saveUpdatedat()
  +calculateCode()
  +saveTotal()
}
Transaction ..> Loan : "0..1"
Beneficiary --o Transaction
Beneficiary --o Loan
@enduml