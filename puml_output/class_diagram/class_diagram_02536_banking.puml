@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Transaction {
  +boolean quantity
  -long phone
  #double score
  +Date address
  +processPhone()
  +calculateScore()
  +validateActive()
}
class Loan {
  #int note
  +Date description
  +double active
  +double address
  +saveAmount()
}
class Card {
  +int id
  -long updatedAt
  #boolean active
  +String note
  +createPhone()
  +findCreatedat()
  +deleteDuration()
  +updateDescription()
}
abstract class Beneficiary {
  -Date level
  +long createdAt
  #Date id
  #int quantity
  -int price
  +saveType()
  +createNote()
  +createTotal()
  +saveScore()
}
Loan --o Transaction
Beneficiary --> Card : "0..1"
note right of Transaction : Banking domain
@enduml