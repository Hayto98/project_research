@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Driver {
  +double note
  #Date code
  #double total
  +deleteTotal()
  +getActive()
}
class FuelLog {
  +Date address
  +double email
  +boolean amount
  +Date price
  +setAddress()
  +processName()
  +findUpdatedat()
}
class Depot {
  -float level
  #Date price
  -String amount
  +createPrice()
  +calculateNote()
}
abstract class Route {
  -String code
  #int email
  #boolean level
  #float address
  +setActive()
}
abstract class DeliveryNote {
  +int price
  +long duration
  #float score
  +Date code
  +int updatedAt
  +updateDuration()
  +setLevel()
  +setPrice()
  +saveLevel()
}
Depot ..> DeliveryNote : "1"
Route --|> FuelLog
note right of Driver : Logistics domain
@enduml