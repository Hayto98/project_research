@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Driver {
  +double note
  #Date code
  #double total
  +setType()
  +cancelType()
}
abstract class FuelLog {
  #long active
  -long email
  +createPrice()
  +findNote()
}
class Depot {
  -double code
  +float score
  #int createdAt
  +int email
  #float status
  +deleteScore()
  +createActive()
  +processAddress()
  +calculateDescription()
}
class Route {
  -float updatedAt
  -double quantity
  +validatePrice()
  +cancelAddress()
  +setDescription()
  +findType()
}
class DeliveryNote {
  #boolean address
  #float price
  #Date status
  +String updatedAt
  +sendScore()
  +updateCode()
  +createPrice()
  +getDuration()
}
Route ..> Driver : "0..1"
FuelLog --|> DeliveryNote
Depot ..> FuelLog : "1"
FuelLog ..|> Route
@enduml