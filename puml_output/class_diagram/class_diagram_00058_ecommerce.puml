@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
interface Customer {
  -long duration
  -float id
  +boolean amount
  +processStatus()
}
class Wishlist {
  +Date score
  #int code
  -long level
  -int total
  +cancelAddress()
}
class Cart {
  +double status
  -Date phone
  +deleteDescription()
  +findStatus()
  +getActive()
  +findScore()
}
class Order {
  +String id
  #double duration
  +String amount
  -Date type
  +deleteTotal()
  +cancelUpdatedat()
  +calculateCode()
}
abstract class Warehouse {
  #long type
  #long amount
  -String id
  #Date code
  +double address
  +saveUpdatedat()
  +setAmount()
}
Customer ..> Warehouse : "*"
Warehouse ..|> Cart
note right of Customer : Ecommerce domain
@enduml