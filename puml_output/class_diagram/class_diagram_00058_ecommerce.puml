@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
interface Customer {
  -long duration
  -float id
  +boolean amount
  +validateUpdatedat()
}
class Wishlist {
  #String active
  +double address
  +updatePhone()
}
class Cart {
  #long email
  +String quantity
  #String updatedAt
  -String active
  -float id
  +setCode()
  +saveDuration()
  +sendName()
  +createCode()
}
class Order {
  #boolean id
  -long active
  +setPrice()
}
interface Warehouse {
  +String amount
  #double type
  +cancelEmail()
  +deleteName()
}
Cart ..> Wishlist : "*"
Warehouse --o Wishlist
Customer --o Order
Order --|> Wishlist
@enduml