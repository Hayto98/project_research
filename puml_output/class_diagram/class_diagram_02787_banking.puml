@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Interest {
  +double code
  #double phone
  +long level
  +boolean name
  +getCreatedat()
}
class Transfer {
  #String phone
  +long code
  +boolean note
  +String duration
  +long type
  +getNote()
  +findDuration()
}
class Account {
  +String type
  -int score
  -double quantity
  +findDuration()
  +findAddress()
  +deleteEmail()
}
class Loan {
  +float score
  #int type
  +float note
  #float quantity
  +setEmail()
}
interface Branch {
  #boolean level
  +String amount
  -boolean address
  +saveScore()
  +validateNote()
}
interface Card {
  -String quantity
  #long id
  +saveStatus()
}
Interest --> Account : "0..1"
Branch --> Account : "1..*"
Loan --* Transfer
Card ..|> Interest
@enduml