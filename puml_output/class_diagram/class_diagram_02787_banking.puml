@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Interest {
  +double code
  #double phone
  +long level
  +boolean name
  +sendEmail()
}
abstract class Transfer {
  #String code
  +long note
  +boolean phone
  +String type
  +validateScore()
  +sendDescription()
}
class Account {
  #boolean amount
  -float type
  +getNote()
}
class Loan {
  +long total
  #long level
  #double phone
  -long active
  +findCreatedat()
}
class Branch {
  +boolean address
  #int level
  +sendActive()
  +deleteCode()
  +validateLevel()
}
class Card {
  #Date updatedAt
  +double level
  +Date code
  -String quantity
  +getPhone()
  +sendAmount()
  +sendEmail()
}
Loan --* Transfer
Card ..|> Interest
Account --* Interest
Card --* Account
note right of Interest : Banking domain
@enduml