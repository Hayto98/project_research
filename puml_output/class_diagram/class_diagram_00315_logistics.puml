@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Depot {
  +boolean name
  -double amount
  #int updatedAt
  #double type
  +findCode()
}
class Driver {
  #Date updatedAt
  +int total
  +validateCode()
  +setScore()
  +calculateAmount()
  +findPhone()
}
class Package {
  #double quantity
  +int description
  #boolean code
  #double name
  +String phone
  +sendDuration()
}
class Warehouse {
  #String note
  -Date phone
  +boolean address
  -int code
  +cancelPrice()
}
abstract class Manifest {
  #int id
  -String createdAt
  +boolean description
  +validateUpdatedat()
}
Warehouse --o Driver
Package ..|> Driver
note right of Depot : Logistics domain
@enduml