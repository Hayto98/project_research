@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Depot {
  +boolean name
  -double amount
  #int updatedAt
  #double type
  +updateScore()
}
class Driver {
  -Date id
  #int updatedAt
  +createName()
  +setEmail()
}
class Package {
  +Date score
  -int total
  +createQuantity()
  +updateCreatedat()
  +processAddress()
  +findPhone()
}
class Warehouse {
  #double level
  +int phone
  +processAmount()
  +saveEmail()
  +findType()
  +calculateDuration()
}
class Manifest {
  +float address
  #String note
  -Date phone
  +boolean duration
  +findPhone()
  +setPhone()
  +getActive()
}
Manifest --o Warehouse
Driver ..|> Depot
@enduml