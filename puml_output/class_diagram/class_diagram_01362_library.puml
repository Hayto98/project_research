@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Librarian {
  #String level
  +Date code
  #boolean name
  -boolean phone
  #float description
  +savePrice()
  +setName()
  +saveCode()
  +getEmail()
}
class Member {
  -Date email
  -float note
  +double active
  #Date name
  +sendAddress()
  +findType()
  +validateQuantity()
}
interface Catalog {
  +float status
  -Date duration
  #int address
  -Date level
  #long email
  +sendAddress()
  +setName()
  +deleteDuration()
}
abstract class Branch {
  -double updatedAt
  -boolean status
  -long score
  +cancelQuantity()
  +deleteAddress()
  +setScore()
}
Branch --o Catalog
Branch --o Librarian
Member --o Branch
@enduml