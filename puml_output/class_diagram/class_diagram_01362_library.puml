@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Librarian {
  #String level
  +Date code
  #boolean name
  -boolean phone
  #float description
  +cancelId()
  +calculateDescription()
  +validateEmail()
  +createNote()
}
interface Member {
  +double address
  #Date type
  +createAmount()
  +saveActive()
  +processStatus()
}
class Catalog {
  #boolean status
  +double email
  #Date updatedAt
  -long price
  +getNote()
  +savePrice()
  +cancelCreatedat()
}
class Branch {
  -long score
  #double total
  +createNote()
  +updateLevel()
  +validateTotal()
}
Branch --o Librarian
Member --o Branch
Librarian --|> Catalog
note right of Librarian : Library domain
@enduml