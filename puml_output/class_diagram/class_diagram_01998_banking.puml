@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Interest {
  +int description
  +int type
  #long score
  +calculateName()
  +findPhone()
  +processScore()
}
interface Transaction {
  #boolean active
  #boolean updatedAt
  -String code
  +String id
  +float description
  +calculatePhone()
  +cancelTotal()
  +updateNote()
  +getTotal()
}
class Withdrawal {
  +double quantity
  #boolean updatedAt
  +findQuantity()
  +updateAmount()
  +cancelName()
  +cancelActive()
}
interface Statement {
  -float email
  +float total
  +float name
  +findDescription()
  +deleteTotal()
  +validateAddress()
}
class Beneficiary {
  -Date duration
  #Date id
  -Date active
  +updateQuantity()
  +calculateAmount()
  +sendScore()
}
abstract class Account {
  -long amount
  +String createdAt
  +int address
  +processType()
}
class Deposit {
  #long duration
  +float status
  +Date id
  +setName()
  +saveUpdatedat()
  +validateCreatedat()
}
Transaction --o Statement
Account --> Beneficiary : "1..*"
Withdrawal --* Beneficiary
Statement --* Interest
@enduml