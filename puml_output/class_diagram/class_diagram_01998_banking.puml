@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Interest {
  +int description
  +int type
  #long score
  +validateDescription()
  +cancelNote()
  +sendDuration()
}
class Transaction {
  #boolean id
  #boolean description
  +setUpdatedat()
  +setAmount()
  +calculateQuantity()
  +getActive()
}
class Withdrawal {
  +int name
  -Date quantity
  +validateLevel()
  +cancelUpdatedat()
  +createTotal()
  +getEmail()
}
class Statement {
  -boolean score
  -String level
  +findDuration()
  +findId()
}
interface Beneficiary {
  +int total
  +long quantity
  -long note
  +String price
  +int duration
  +calculateId()
}
class Account {
  +float id
  +Date address
  +getDescription()
  +validateCreatedat()
  +processType()
}
interface Deposit {
  -int phone
  #long duration
  -int note
  +float name
  +getAddress()
}
Deposit --o Withdrawal
Account --|> Deposit
note right of Interest : Banking domain
@enduml