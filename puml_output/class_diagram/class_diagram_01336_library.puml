@startuml
skinparam monochrome true
skinparam defaultFontSize 13
interface Publisher {
  #boolean quantity
  #Date address
  +validateActive()
  +setActive()
  +calculateEmail()
}
class Librarian {
  #boolean level
  +double score
  +updateQuantity()
}
class Author {
  +Date quantity
  +double active
  -Date score
  #double total
  -float email
  +setName()
  +createLevel()
  +cancelPhone()
  +updateId()
}
class Member {
  -boolean level
  #long note
  +validateActive()
  +createScore()
}
Librarian ..|> Publisher
Librarian --> Member : "1"
@enduml