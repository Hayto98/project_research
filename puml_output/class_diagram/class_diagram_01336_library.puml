@startuml
skinparam monochrome true
skinparam defaultFontSize 13
interface Publisher {
  #boolean quantity
  #Date address
  +cancelName()
  +updateDuration()
  +getLevel()
}
interface Librarian {
  +double price
  -boolean code
  +saveLevel()
  +createDescription()
  +findCreatedat()
  +processType()
}
interface Author {
  +boolean total
  #float note
  -double id
  #boolean email
  -Date name
  +cancelUpdatedat()
  +sendCreatedat()
}
class Member {
  #String createdAt
  -boolean updatedAt
  -double address
  +deleteActive()
  +createPhone()
  +validatePhone()
}
Librarian ..|> Author
Publisher --|> Member
note right of Publisher : Library domain
@enduml