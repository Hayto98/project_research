@startuml
skinparam monochrome true
class Branch {
  +boolean updatedAt
  -Date description
  +updateAddress()
  +updatePhone()
}
class Deposit {
  -boolean score
  +double total
  #long price
  +updateNote()
}
class Interest {
  -float createdAt
  -Date phone
  +Date type
  +int note
  -Date quantity
  +updateName()
}
class Teller {
  #boolean price
  #String updatedAt
  +int type
  #double description
  +cancelEmail()
  +setTotal()
  +setId()
}
class Withdrawal {
  +double email
  #String duration
  #float createdAt
  +updateDescription()
  +createDescription()
  +calculateAmount()
  +calculatePrice()
}
class Transfer {
  #long price
  #double phone
  +sendPhone()
  +validatePrice()
  +saveType()
}
Transfer ..|> Deposit
Withdrawal --* Teller
Transfer --|> Interest
@enduml