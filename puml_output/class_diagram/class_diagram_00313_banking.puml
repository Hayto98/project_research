@startuml
skinparam monochrome true
class Branch {
  +boolean updatedAt
  -Date description
  +saveUpdatedat()
  +cancelUpdatedat()
}
interface Deposit {
  #long level
  +boolean price
  +float email
  #boolean createdAt
  -float note
  +validateType()
  +processQuantity()
}
class Interest {
  +long createdAt
  -double updatedAt
  +Date amount
  -int quantity
  #boolean id
  +updateCreatedat()
}
interface Teller {
  -Date quantity
  -Date status
  +String duration
  -boolean id
  +float createdAt
  +updateActive()
  +processScore()
  +createActive()
  +setPrice()
}
class Withdrawal {
  +Date price
  +float phone
  +boolean level
  -long active
  +getName()
  +findEmail()
  +createTotal()
}
class Transfer {
  +double active
  -long address
  #double code
  +setDuration()
  +deleteScore()
  +cancelCode()
  +calculateActive()
}
Deposit --* Transfer
Deposit --* Teller
Interest --o Branch
note right of Branch : Banking domain
@enduml