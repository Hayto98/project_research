@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Coupon {
  #boolean createdAt
  +long address
  -boolean email
  -boolean amount
  +savePrice()
}
abstract class Category {
  #Date price
  -int active
  +createPhone()
  +processScore()
}
abstract class Shipment {
  +double email
  -boolean address
  +String duration
  -Date score
  +int id
  +cancelUpdatedat()
  +createTotal()
  +sendType()
  +updateCreatedat()
}
class Customer {
  #Date note
  #long createdAt
  +String phone
  +findScore()
}
interface Order {
  #long total
  +String code
  #boolean status
  -Date amount
  +deleteAddress()
  +createUpdatedat()
  +deletePhone()
  +setUpdatedat()
}
class Return {
  #Date price
  #boolean type
  +cancelEmail()
}
class Wishlist {
  -float email
  +int level
  -int note
  #double createdAt
  +boolean type
  +updateType()
  +processQuantity()
}
Coupon --o Customer
Wishlist --> Customer : "1"
Return ..> Customer : "1"
Shipment --> Order : "1"
Category --* Order
note right of Coupon : Ecommerce domain
@enduml