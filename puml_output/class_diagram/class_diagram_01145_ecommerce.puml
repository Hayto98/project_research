@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Coupon {
  #boolean createdAt
  +long address
  -boolean email
  -boolean amount
  +calculateUpdatedat()
}
abstract class Category {
  +long status
  -double price
  #double active
  -long level
  #long createdAt
  +updateAddress()
  +validateTotal()
  +setPrice()
}
class Shipment {
  -boolean updatedAt
  +String note
  +setScore()
  +saveQuantity()
  +processUpdatedat()
  +processEmail()
}
abstract class Customer {
  -int email
  #Date total
  +long score
  +saveAmount()
  +processActive()
}
class Order {
  #boolean id
  +float code
  #boolean score
  #boolean active
  +deleteEmail()
  +setNote()
  +cancelStatus()
}
class Return {
  #boolean phone
  -Date id
  -int code
  +getNote()
  +sendNote()
  +validateCreatedat()
}
class Wishlist {
  #float updatedAt
  #String phone
  +setCode()
  +sendName()
  +deleteUpdatedat()
  +deleteStatus()
}
Coupon --* Order
Wishlist --o Shipment
Shipment --o Order
Wishlist ..> Category : "*"
Shipment ..|> Category
@enduml