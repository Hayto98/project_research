@startuml
skinparam monochrome true
skinparam ArrowColor #555555
abstract class Payment {
  +double duration
  #String address
  #String score
  +createNote()
  +validateQuantity()
  +getType()
}
class Coupon {
  -long active
  -Date code
  #float address
  +boolean updatedAt
  +deleteScore()
  +setDescription()
}
class Category {
  -Date code
  -Date quantity
  -double address
  #Date amount
  -long duration
  +updateActive()
  +saveId()
}
interface Order {
  #String quantity
  +Date address
  +updateUpdatedat()
  +calculateCode()
}
interface Warehouse {
  +int total
  +int email
  -float code
  #double duration
  +getCreatedat()
}
class Return {
  #Date active
  #double quantity
  +long note
  +calculateUpdatedat()
  +findType()
  +setTotal()
}
class Invoice {
  #double total
  -Date email
  #boolean amount
  -double quantity
  +updateTotal()
  +sendNote()
  +processDescription()
  +cancelType()
}
Warehouse --* Category
Category --|> Order
@enduml