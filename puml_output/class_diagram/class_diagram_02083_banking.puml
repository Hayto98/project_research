@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
abstract class Customer {
  -long updatedAt
  -int status
  +float code
  +String type
  +cancelPhone()
  +updateStatus()
}
interface Transaction {
  -float name
  -String updatedAt
  -int email
  +float phone
  +updateScore()
  +createPrice()
  +validateQuantity()
  +saveTotal()
}
class Branch {
  +long description
  -Date address
  +sendName()
  +createType()
  +calculateStatus()
  +findDuration()
}
abstract class Card {
  #float address
  +String phone
  -String description
  -String quantity
  #int note
  +getName()
  +validateActive()
  +sendAmount()
}
interface Teller {
  -String price
  +int amount
  +sendId()
  +updateQuantity()
  +setActive()
}
class Statement {
  -float createdAt
  #Date score
  #String note
  +findAmount()
  +sendCreatedat()
  +updatePrice()
}
Statement --o Transaction
Card --o Branch
@enduml