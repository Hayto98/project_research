@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Catalog {
  +int amount
  #boolean description
  -String quantity
  -boolean name
  +cancelCreatedat()
  +calculateCreatedat()
  +findCreatedat()
}
class Librarian {
  -Date email
  -Date total
  +createPrice()
  +updateScore()
  +setId()
  +deleteScore()
}
interface Book {
  +boolean createdAt
  +float status
  -String level
  #double quantity
  +boolean type
  +deleteNote()
  +deletePrice()
  +updateAmount()
}
class Member {
  -double description
  #Date createdAt
  -String score
  +boolean address
  +sendDescription()
}
class Publisher {
  #String note
  #String score
  #int active
  #Date email
  #int id
  +setActive()
  +deleteQuantity()
  +saveId()
}
class Reservation {
  -String active
  +String quantity
  +Date status
  +calculateName()
  +processActive()
  +updateName()
}
Book --o Publisher
Publisher ..|> Librarian
@enduml