@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Catalog {
  +int amount
  #boolean description
  -String quantity
  -boolean name
  +calculateAddress()
  +createEmail()
  +cancelId()
}
class Librarian {
  #Date total
  #Date type
  -int price
  +String score
  -double amount
  +sendCode()
}
class Book {
  +boolean score
  -String type
  +setQuantity()
  +saveDescription()
  +saveCreatedat()
  +sendAddress()
}
class Member {
  #String active
  #double phone
  -boolean id
  #boolean name
  -String status
  +sendStatus()
}
class Publisher {
  +float email
  +Date status
  #long name
  +createCode()
}
class Reservation {
  -int name
  +String phone
  +findDuration()
  +calculateScore()
  +saveDescription()
}
Librarian ..|> Catalog
Reservation ..> Librarian : "*"
Reservation --|> Publisher
note right of Catalog : Library domain
@enduml