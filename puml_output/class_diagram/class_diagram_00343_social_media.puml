@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Hashtag {
  -boolean createdAt
  +long address
  +updateEmail()
  +findNote()
  +setEmail()
  +updateDescription()
}
class Message {
  +boolean note
  -Date status
  +sendActive()
  +validateAddress()
  +getStatus()
}
class User {
  +long active
  #double status
  +updateAmount()
  +sendQuantity()
  +createAddress()
}
class Comment {
  #boolean status
  #boolean code
  +processScore()
  +calculateType()
  +setCode()
}
class Story {
  -String price
  +Date note
  #double level
  -String email
  +calculateDescription()
  +setEmail()
  +updateCode()
}
class Group {
  #Date email
  -double name
  #Date status
  +saveDescription()
  +sendNote()
  +cancelUpdatedat()
}
Message ..|> Hashtag
User --> Comment : "1..*"
Hashtag ..> Comment : "*"
Message ..|> Story
@enduml