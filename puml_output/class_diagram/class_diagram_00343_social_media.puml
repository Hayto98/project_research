@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Hashtag {
  -boolean createdAt
  +long address
  +calculateCode()
  +validateCreatedat()
  +getStatus()
  +processStatus()
}
class Message {
  +long quantity
  #double email
  -boolean status
  +int name
  +String score
  +saveDuration()
}
interface User {
  -boolean createdAt
  -double phone
  +float price
  +Date note
  +processName()
  +saveEmail()
  +findAddress()
  +deleteDescription()
}
class Comment {
  -Date status
  #long total
  +findTotal()
  +updateName()
}
class Story {
  #double price
  +Date email
  -int status
  #int type
  +sendId()
}
class Group {
  #double id
  +String note
  +setName()
  +calculateScore()
  +createDescription()
}
Hashtag --o Message
Story --|> Message
Group --> Story : "1"
Group ..|> Hashtag
note right of Hashtag : Social Media domain
@enduml