@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
interface Review {
  #float price
  #float code
  +sendNote()
  +processType()
}
class Category {
  -String name
  -String address
  #double active
  +updateQuantity()
  +createQuantity()
  +findType()
}
abstract class Payment {
  -double price
  +String status
  #int score
  #String duration
  -float quantity
  +calculateNote()
}
class Customer {
  -Date score
  #float active
  #int price
  #double quantity
  #double phone
  +getAddress()
  +setTotal()
  +updateScore()
}
class Shipment {
  +boolean phone
  #int active
  -long createdAt
  +updatePrice()
}
class Order {
  -String total
  -long name
  -float note
  +boolean description
  +createActive()
  +findCode()
  +sendPhone()
}
class Product {
  #Date amount
  #double email
  +Date address
  #int createdAt
  -boolean id
  +updateId()
  +deleteTotal()
  +getId()
  +findDescription()
}
Review --* Category
Category --|> Shipment
Payment ..> Order : "1..*"
Category --> Order : "*"
@enduml