@startuml
skinparam shadowing true
class Order {
  +double note
  +float price
  +saveId()
  +updateUpdatedat()
}
interface Supplier {
  #double createdAt
  -Date duration
  +boolean description
  +findDescription()
  +validateName()
}
class Review {
  +double price
  -double type
  -boolean id
  +long phone
  #Date amount
  +saveCreatedat()
  +setScore()
  +sendQuantity()
}
class Invoice {
  -int price
  #String level
  -float description
  #int type
  +sendPhone()
  +createNote()
  +processNote()
}
Supplier ..|> Review
Order --* Invoice
@enduml