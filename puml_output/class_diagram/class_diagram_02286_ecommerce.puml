@startuml
skinparam shadowing true
class Order {
  +double note
  +float price
  +getStatus()
  +sendUpdatedat()
}
class Supplier {
  #String description
  #float type
  +boolean quantity
  +createTotal()
  +calculateType()
  +getPhone()
  +cancelActive()
}
interface Review {
  -double updatedAt
  #String type
  -Date quantity
  +validateActive()
  +validateDuration()
  +validatePrice()
}
interface Invoice {
  #String type
  -float phone
  #int amount
  +validateScore()
  +processUpdatedat()
  +sendDescription()
}
Order ..|> Supplier
note right of Order : Ecommerce domain
@enduml