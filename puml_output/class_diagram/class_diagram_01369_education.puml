@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
interface Grade {
  -boolean description
  #long note
  -String id
  +saveLevel()
  +updateUpdatedat()
  +deleteCode()
  +setPhone()
}
class Attendance {
  +boolean address
  #float updatedAt
  -double note
  -boolean price
  +sendPhone()
  +calculatePhone()
  +createUpdatedat()
  +calculateLevel()
}
abstract class Exam {
  #float duration
  -float name
  -boolean quantity
  +saveLevel()
  +saveDescription()
  +processActive()
  +deleteScore()
}
interface Student {
  +boolean note
  #int status
  +sendAmount()
  +setPhone()
  +updateDescription()
}
abstract class Schedule {
  #int score
  +int status
  -double active
  +setType()
}
interface Enrollment {
  #float phone
  -String address
  +updateActive()
  +getPhone()
  +saveDuration()
}
Attendance --|> Exam
Student --* Grade
@enduml