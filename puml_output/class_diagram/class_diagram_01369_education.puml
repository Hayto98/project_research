@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
interface Grade {
  -boolean description
  #long note
  -String id
  +setPhone()
  +cancelCreatedat()
  +savePhone()
  +findAddress()
}
class Attendance {
  -boolean price
  #double code
  -long active
  #float total
  -boolean type
  +cancelName()
  +findQuantity()
}
interface Exam {
  +boolean total
  +double active
  +String score
  #Date note
  +long createdAt
  +processDescription()
  +sendStatus()
}
interface Student {
  -String id
  +boolean description
  #String type
  +validateType()
  +getQuantity()
  +getTotal()
}
interface Schedule {
  +double updatedAt
  +long email
  +getCode()
}
class Enrollment {
  +double amount
  -int status
  #float score
  #long type
  +calculatePrice()
  +sendCreatedat()
  +calculatePrice()
}
Grade --> Schedule : "0..1"
Student ..|> Attendance
note right of Grade : Education domain
@enduml