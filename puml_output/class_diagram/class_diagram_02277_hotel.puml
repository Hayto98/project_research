@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Invoice {
  #float note
  +String description
  #long amount
  -double total
  +calculateNote()
  +calculateType()
  +validateActive()
}
class Reservation {
  -int status
  +Date code
  +double quantity
  +Date active
  +createUpdatedat()
}
interface CheckIn {
  #boolean type
  -String note
  #boolean price
  -boolean email
  +int phone
  +setPhone()
  +processDuration()
  +calculateDescription()
}
interface Housekeeping {
  +float description
  #Date type
  +calculateQuantity()
}
CheckIn ..> Housekeeping : "0..1"
Housekeeping ..> CheckIn : "*"
@enduml