@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
abstract class Classroom {
  +Date status
  -boolean active
  -int description
  -boolean createdAt
  #long note
  +setStatus()
  +updatePrice()
  +savePhone()
  +processAmount()
}
abstract class Teacher {
  +String duration
  +double status
  +long updatedAt
  #float active
  +deleteNote()
  +calculateDescription()
  +updateId()
}
abstract class Grade {
  -double level
  -Date total
  +String code
  +int note
  +saveLevel()
  +saveNote()
  +setNote()
  +sendNote()
}
interface Book {
  -float status
  #double amount
  +findScore()
}
interface Student {
  #float phone
  +int level
  +boolean score
  #boolean active
  +setDuration()
  +calculateDuration()
  +saveId()
}
class Department {
  #boolean score
  #boolean note
  #String amount
  +long code
  +processEmail()
  +findPrice()
  +getId()
}
class Assignment {
  -float score
  +long id
  -int level
  #long createdAt
  -int status
  +processStatus()
  +saveAmount()
  +updateLevel()
  +updateAddress()
}
Book --|> Teacher
Grade ..> Student : "1"
@enduml