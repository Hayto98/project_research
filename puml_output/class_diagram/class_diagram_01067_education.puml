@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
abstract class Classroom {
  +Date status
  -boolean active
  -int description
  -boolean createdAt
  #long note
  +setId()
  +getCode()
  +calculatePhone()
  +cancelStatus()
}
class Teacher {
  -int code
  -boolean updatedAt
  +getPrice()
  +createLevel()
  +calculateDuration()
}
interface Grade {
  -long note
  #int duration
  +setCreatedat()
}
abstract class Book {
  #Date total
  #String updatedAt
  #float score
  +deleteAddress()
}
abstract class Student {
  -long quantity
  #boolean level
  +deleteAmount()
  +sendScore()
}
interface Department {
  #double score
  +String name
  #boolean id
  #boolean email
  +getAddress()
}
class Assignment {
  +float status
  +long price
  +long score
  -int id
  #long active
  +deleteTotal()
  +validateNote()
  +createStatus()
  +calculateUpdatedat()
}
Grade ..> Student : "1"
Assignment --* Department
note right of Classroom : Education domain
@enduml