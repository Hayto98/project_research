@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Depot {
  #String total
  -int code
  -int status
  #boolean address
  +float phone
  +calculateQuantity()
  +getScore()
}
class Manifest {
  #Date status
  +Date address
  #int email
  +validateId()
}
interface Shipment {
  #String total
  -float active
  #float level
  +getName()
  +processPrice()
  +getName()
  +findDuration()
}
interface Package {
  +float phone
  +int name
  +long id
  #float status
  +processAmount()
  +sendId()
}
class Driver {
  -boolean name
  #long type
  +processCreatedat()
  +sendPhone()
  +deleteName()
}
class Vehicle {
  +String active
  +double createdAt
  -double note
  +calculateCode()
  +deleteType()
  +validatePrice()
  +getDuration()
}
Package --o Shipment
Manifest --|> Shipment
Manifest --o Vehicle
Driver ..|> Shipment
note right of Depot : Logistics domain
@enduml