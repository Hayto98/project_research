@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Depot {
  #String total
  -int code
  -int status
  #boolean address
  +float phone
  +sendScore()
  +cancelAddress()
}
class Manifest {
  -float description
  #Date status
  +Date address
  +cancelScore()
  +saveId()
}
class Shipment {
  -boolean level
  #boolean updatedAt
  +calculateCreatedat()
}
abstract class Package {
  #double name
  +String type
  +updateTotal()
  +processQuantity()
  +createEmail()
}
class Driver {
  +String createdAt
  -boolean name
  +deleteActive()
  +createCode()
}
interface Vehicle {
  +String address
  -long level
  +findScore()
  +sendName()
  +updateDescription()
}
Manifest ..|> Depot
Manifest ..|> Driver
Package --|> Manifest
Depot --* Package
@enduml