@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
abstract class Return {
  +float status
  +boolean id
  -double duration
  #boolean price
  +getName()
  +updateName()
  +updateCreatedat()
}
abstract class Warehouse {
  -float address
  #int amount
  #String email
  +calculateAmount()
}
class Customer {
  #boolean description
  +double code
  +String active
  +long status
  +getAmount()
  +calculateDuration()
  +updateType()
}
interface Payment {
  +Date quantity
  -long email
  +updateAmount()
  +createUpdatedat()
  +getStatus()
  +createName()
}
Payment --|> Customer
Warehouse ..|> Return
note right of Return : Ecommerce domain
@enduml