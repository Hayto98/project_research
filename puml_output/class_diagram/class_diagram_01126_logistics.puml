@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Warehouse {
  +Date quantity
  -float updatedAt
  +double note
  +sendQuantity()
  +createActive()
  +cancelAddress()
}
class Depot {
  +float updatedAt
  +double phone
  +String status
  +sendPrice()
  +calculateDescription()
  +processDuration()
}
class Package {
  +int id
  +double note
  +cancelScore()
  +saveActive()
}
class Inventory {
  #float quantity
  #float address
  +Date createdAt
  +Date score
  +processUpdatedat()
  +createPrice()
}
Inventory ..> Depot : "1"
Warehouse --|> Package
note right of Warehouse : Logistics domain
@enduml