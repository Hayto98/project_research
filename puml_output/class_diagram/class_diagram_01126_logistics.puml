@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Warehouse {
  +Date quantity
  -float updatedAt
  +double note
  +setAddress()
  +processDescription()
  +cancelAddress()
}
interface Depot {
  #String amount
  +float description
  +double updatedAt
  +String phone
  +getCreatedat()
  +processType()
  +getPhone()
}
class Package {
  +int duration
  +double address
  #int name
  #boolean id
  #boolean note
  +findCreatedat()
  +processDescription()
  +validateScore()
}
class Inventory {
  #Date duration
  #int amount
  -int createdAt
  +calculateCode()
  +createPrice()
  +cancelUpdatedat()
}
Package --|> Inventory
Inventory --|> Depot
Warehouse --o Depot
@enduml