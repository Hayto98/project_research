@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
interface Doctor {
  -int quantity
  +long name
  -String phone
  -long duration
  +createActive()
}
abstract class Treatment {
  #boolean active
  #int status
  -boolean id
  -double description
  +calculateNote()
}
class LabTest {
  -String status
  +String id
  +Date score
  -String price
  +getScore()
  +updateNote()
}
class Appointment {
  -float createdAt
  #float duration
  +int name
  #int address
  +calculateCode()
  +processScore()
  +updatePhone()
  +processActive()
}
Treatment --* Appointment
Doctor --* Treatment
Doctor --* LabTest
note right of Doctor : Healthcare domain
@enduml