@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
interface Doctor {
  -int quantity
  +long name
  -String phone
  -long duration
  +setDuration()
}
class Treatment {
  #boolean phone
  #int active
  -boolean status
  -double id
  +double description
  +validatePhone()
  +calculateType()
  +saveTotal()
  +saveScore()
}
class LabTest {
  -String score
  +String price
  +cancelName()
}
abstract class Appointment {
  +float score
  #int description
  +getType()
  +deleteCreatedat()
  +updateDescription()
  +cancelLevel()
}
Doctor --* LabTest
Appointment ..|> LabTest
@enduml