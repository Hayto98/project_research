@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Book {
  -long id
  -Date level
  #float name
  #String amount
  +String note
  +findDescription()
  +findTotal()
  +processScore()
  +processTotal()
}
class Teacher {
  -float name
  #float type
  -Date email
  +sendPrice()
  +calculateAmount()
  +createCreatedat()
}
class Classroom {
  +float createdAt
  +float address
  +createType()
  +findNote()
  +createActive()
}
class Attendance {
  +long phone
  #boolean total
  #long status
  #boolean active
  +updateName()
}
class Enrollment {
  +String address
  -long type
  +processPhone()
  +saveUpdatedat()
  +sendName()
}
class Department {
  +Date name
  #int code
  #float email
  -String price
  #double createdAt
  +processScore()
}
class Assignment {
  -long description
  #String status
  #float duration
  +findId()
  +deleteDuration()
  +getUpdatedat()
  +calculateId()
}
Attendance --* Book
Classroom ..|> Department
Assignment ..|> Department
Enrollment ..|> Assignment
note right of Book : Education domain
@enduml