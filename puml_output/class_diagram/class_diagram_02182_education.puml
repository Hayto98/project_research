@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Book {
  -long id
  -Date level
  #float name
  #String amount
  +String note
  +sendUpdatedat()
  +createCreatedat()
  +cancelName()
  +cancelCreatedat()
}
abstract class Teacher {
  -long total
  #float phone
  -Date updatedAt
  -boolean name
  #double type
  +updateType()
  +cancelPhone()
  +getTotal()
  +processName()
}
class Classroom {
  #float address
  #long name
  -double id
  +validateAddress()
  +findDuration()
  +processQuantity()
  +saveScore()
}
class Attendance {
  #boolean status
  +int active
  +long updatedAt
  +long quantity
  -int email
  +getPrice()
}
class Enrollment {
  #int active
  #String quantity
  +Date note
  #double phone
  +setDuration()
}
class Department {
  +float price
  #float createdAt
  -String amount
  #double active
  +sendCreatedat()
}
interface Assignment {
  -long description
  #String duration
  #float status
  #boolean level
  +cancelUpdatedat()
  +updateQuantity()
  +sendTotal()
  +createCode()
}
Book --o Teacher
Book --o Classroom
Classroom ..|> Department
Assignment ..|> Department
Enrollment ..|> Assignment
@enduml