@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Customer {
  #int quantity
  -long amount
  +setAddress()
}
interface Shipment {
  #double status
  #boolean name
  +Date active
  -float duration
  +calculateActive()
  +processActive()
  +createScore()
}
abstract class Inventory {
  -float name
  -String amount
  +double createdAt
  +cancelTotal()
  +deleteCreatedat()
  +validateActive()
}
abstract class Depot {
  -double createdAt
  -float score
  +getAddress()
  +saveQuantity()
}
abstract class Manifest {
  #int score
  #double status
  +findUpdatedat()
  +deleteName()
}
Shipment --* Depot
Customer --> Shipment : "*"
Shipment --|> Inventory
@enduml