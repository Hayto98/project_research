@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Customer {
  #int quantity
  -long amount
  +sendDuration()
}
class Shipment {
  #Date name
  +boolean active
  +findActive()
  +getAddress()
  +findQuantity()
  +sendCreatedat()
}
class Inventory {
  -float duration
  -String amount
  +double name
  #Date level
  -String createdAt
  +cancelTotal()
  +getCreatedat()
  +sendQuantity()
}
abstract class Depot {
  +boolean amount
  +Date total
  +Date description
  -float level
  +cancelEmail()
  +cancelCreatedat()
}
abstract class Manifest {
  #int code
  #int createdAt
  -String type
  +String status
  +processEmail()
  +getCreatedat()
  +deleteDuration()
}
Manifest ..> Depot : "1..*"
Depot --> Customer : "1"
Manifest --* Inventory
note right of Customer : Logistics domain
@enduml