@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Hospital {
  -boolean name
  -long active
  -float createdAt
  +cancelType()
  +updateUpdatedat()
}
class Patient {
  -String name
  #boolean price
  +int type
  -float note
  +createActive()
  +setAddress()
}
abstract class Nurse {
  #double quantity
  +int code
  #String status
  +setNote()
  +validateCreatedat()
  +calculateDescription()
}
class Treatment {
  #float total
  #long phone
  +processUpdatedat()
  +processNote()
  +setNote()
}
class Doctor {
  #boolean amount
  -int address
  -int quantity
  +long name
  +double code
  +validateDescription()
  +cancelDescription()
  +processType()
  +cancelAmount()
}
interface Ward {
  #long phone
  +int quantity
  #Date duration
  -int address
  +calculateDuration()
  +updateCode()
  +setQuantity()
  +deletePrice()
}
class Prescription {
  -float amount
  +boolean name
  +double note
  #double createdAt
  #boolean score
  +validatePhone()
}
Patient --* Treatment
Patient --o Prescription
Nurse ..> Ward : "1..*"
Patient --> Ward : "1..*"
Nurse --> Treatment : "1..*"
note right of Hospital : Healthcare domain
@enduml