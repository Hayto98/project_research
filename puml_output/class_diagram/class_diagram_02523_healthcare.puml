@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Hospital {
  -boolean name
  -long active
  -float createdAt
  +validateStatus()
  +saveDuration()
}
abstract class Patient {
  +double updatedAt
  -double description
  -String email
  +saveAddress()
  +deleteTotal()
}
class Nurse {
  #long quantity
  -int active
  -float code
  +saveLevel()
}
class Treatment {
  +Date amount
  -float createdAt
  -int active
  -int id
  +float phone
  +findAmount()
}
class Doctor {
  -float phone
  +float type
  -Date updatedAt
  +double level
  +validateScore()
  +updateCode()
}
class Ward {
  #double code
  +long score
  +saveAddress()
  +calculateScore()
}
class Prescription {
  #double total
  #int address
  #boolean description
  -long score
  -long type
  +updateId()
  +sendPhone()
  +saveQuantity()
}
Prescription ..> Doctor : "*"
Patient --o Treatment
Ward ..|> Doctor
@enduml