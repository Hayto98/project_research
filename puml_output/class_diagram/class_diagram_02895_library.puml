@startuml
skinparam monochrome true
skinparam shadowing true
interface Fine {
  -float active
  #float type
  #Date createdAt
  -float updatedAt
  +cancelDescription()
  +updateEmail()
  +saveName()
}
interface Reservation {
  +boolean level
  #int phone
  -String total
  +boolean email
  +getName()
  +deleteCode()
  +calculateLevel()
  +cancelType()
}
interface Librarian {
  +int code
  #float address
  #int score
  +boolean createdAt
  #float amount
  +deleteStatus()
  +calculatePhone()
  +createType()
  +validateLevel()
}
class Member {
  -String name
  -boolean address
  +getPhone()
  +validateName()
  +findDuration()
  +saveType()
}
class Book {
  +String price
  +String status
  +deleteScore()
  +findName()
  +createDescription()
}
Member ..> Fine : "1"
Book --o Member
Book --|> Librarian
@enduml