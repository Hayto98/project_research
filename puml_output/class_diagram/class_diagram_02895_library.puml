@startuml
skinparam monochrome true
skinparam shadowing true
interface Fine {
  -float active
  #float type
  #Date createdAt
  -float updatedAt
  +findTotal()
  +calculateDuration()
  +createLevel()
}
class Reservation {
  +String email
  #double name
  -float active
  #double description
  +long quantity
  +cancelAmount()
  +setUpdatedat()
}
interface Librarian {
  -Date description
  -Date level
  +Date active
  +saveName()
}
class Member {
  #float status
  #Date note
  #Date level
  +boolean total
  #String type
  +findStatus()
  +deleteName()
  +getCode()
  +findPhone()
}
class Book {
  -Date total
  #long id
  +Date name
  #long duration
  +validateAmount()
  +calculateTotal()
  +processPhone()
  +getAddress()
}
Librarian ..|> Reservation
Book --|> Reservation
Member ..> Book : "1"
Librarian --> Fine : "1"
note right of Fine : Library domain
@enduml