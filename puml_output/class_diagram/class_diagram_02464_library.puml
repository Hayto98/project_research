@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Catalog {
  +Date status
  -boolean total
  -int id
  +createAddress()
  +sendTotal()
}
class Shelf {
  +boolean createdAt
  +boolean name
  +createType()
  +cancelStatus()
  +processCreatedat()
  +createUpdatedat()
}
abstract class Publisher {
  +double type
  #boolean total
  +float description
  +calculatePrice()
}
class Loan {
  #int updatedAt
  +boolean total
  +cancelTotal()
  +findEmail()
  +deleteQuantity()
  +findScore()
}
class Fine {
  #long email
  +int price
  #int total
  #long address
  +deleteCreatedat()
}
interface Reservation {
  +boolean duration
  +int createdAt
  +Date type
  +processStatus()
}
Fine --* Loan
Publisher ..> Reservation : "0..1"
@enduml