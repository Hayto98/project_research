@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Catalog {
  +Date status
  -boolean total
  -int id
  +setId()
  +createId()
}
class Shelf {
  #double id
  #String amount
  +saveScore()
  +deleteType()
  +saveTotal()
  +deleteCreatedat()
}
abstract class Publisher {
  #float status
  #String score
  +float quantity
  +findAmount()
  +deleteActive()
  +processId()
  +setQuantity()
}
class Loan {
  #long email
  +int price
  #int total
  #long address
  +createScore()
}
interface Fine {
  +boolean duration
  +int createdAt
  +Date type
  +validateName()
}
interface Reservation {
  +String quantity
  -boolean email
  #double duration
  -boolean updatedAt
  -int note
  +getEmail()
  +deleteDescription()
  +validateEmail()
}
Loan --> Shelf : "1"
Shelf --* Fine
Shelf ..> Catalog : "1..*"
note right of Catalog : Library domain
@enduml