@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
interface Catalog {
  #String name
  #int price
  +saveLevel()
  +calculateCreatedat()
  +processId()
  +findTotal()
}
abstract class Author {
  -int status
  +boolean updatedAt
  #String price
  +validateDuration()
  +processId()
}
class Reservation {
  +double description
  -float address
  +saveScore()
  +updateCode()
  +processDescription()
  +calculateUpdatedat()
}
class Member {
  +double phone
  -double level
  -int address
  -double email
  +findActive()
  +saveQuantity()
  +calculateStatus()
}
abstract class Book {
  -double type
  +float level
  +boolean createdAt
  -float description
  +validateDuration()
  +saveName()
  +sendTotal()
  +validateActive()
}
Author --|> Member
Member --* Author
@enduml