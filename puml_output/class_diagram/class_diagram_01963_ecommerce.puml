@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Wishlist {
  +String createdAt
  +int quantity
  -boolean email
  -float type
  +cancelNote()
  +findNote()
}
abstract class Return {
  #boolean duration
  +double score
  +findPrice()
}
class Category {
  -boolean description
  +boolean createdAt
  +boolean price
  +long name
  +createId()
  +deleteScore()
  +saveDescription()
  +validateQuantity()
}
interface Cart {
  +float phone
  -long updatedAt
  #long price
  +saveCode()
}
class Invoice {
  #double id
  #long address
  #float updatedAt
  -int score
  #String level
  +validateLevel()
  +sendActive()
}
Return --|> Wishlist
Invoice --o Wishlist
@enduml