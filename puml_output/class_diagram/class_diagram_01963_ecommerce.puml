@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Wishlist {
  +String createdAt
  +int quantity
  -boolean email
  -float type
  +updateCode()
  +processDuration()
}
interface Return {
  #boolean duration
  +double score
  +sendCreatedat()
}
interface Category {
  -boolean description
  +boolean createdAt
  +boolean price
  +long name
  +deleteAmount()
  +saveActive()
  +sendDescription()
  +validateUpdatedat()
}
abstract class Cart {
  +double email
  +double address
  +long phone
  +sendUpdatedat()
  +validatePrice()
}
class Invoice {
  +String amount
  #String code
  -int duration
  +boolean name
  -double createdAt
  +getQuantity()
  +updateScore()
  +updateType()
}
Wishlist ..> Return : "1"
Category ..|> Cart
note right of Wishlist : Ecommerce domain
@enduml