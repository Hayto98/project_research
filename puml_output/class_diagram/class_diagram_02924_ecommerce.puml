@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Wishlist {
  #long total
  +boolean amount
  +validateAmount()
  +saveEmail()
  +sendDescription()
}
class Review {
  +Date price
  -boolean amount
  -Date level
  +saveUpdatedat()
  +updatePhone()
}
class Payment {
  -Date level
  #String type
  +String total
  +getPhone()
  +processTotal()
  +findTotal()
}
class Supplier {
  +String description
  -String status
  #float level
  #float createdAt
  #float active
  +updateCreatedat()
  +processAmount()
  +setPhone()
}
Payment ..|> Review
Wishlist ..> Payment : "0..1"
@enduml