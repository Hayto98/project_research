@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Guest {
  -Date name
  -double code
  -String status
  +boolean amount
  #Date level
  +setUpdatedat()
  +cancelCode()
  +sendName()
  +saveEmail()
}
abstract class Payment {
  -double address
  -String amount
  +double score
  #String updatedAt
  +savePhone()
  +setStatus()
  +sendDescription()
  +deleteDuration()
}
abstract class Service {
  -String amount
  +Date name
  -int duration
  -Date code
  #Date total
  +sendTotal()
}
abstract class Amenity {
  -double score
  #double description
  -long level
  #int id
  +deleteScore()
  +cancelId()
}
class CheckOut {
  -float code
  +float description
  +findCreatedat()
}
class CheckIn {
  +double level
  +double price
  -boolean phone
  +getPrice()
  +updateLevel()
}
Guest --> CheckIn : "*"
Amenity --o CheckIn
Guest --o Service
CheckOut ..|> Guest
CheckOut --o Payment
note right of Guest : Hotel domain
@enduml