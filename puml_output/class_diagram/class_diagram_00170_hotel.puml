@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Guest {
  -Date name
  -double code
  -String status
  +boolean amount
  #Date level
  +processAddress()
  +validateId()
  +processPrice()
  +findUpdatedat()
}
class Payment {
  -long email
  #Date total
  +setAddress()
  +createScore()
}
abstract class Service {
  -Date total
  -String code
  +boolean status
  +int type
  #double id
  +createCode()
  +deleteNote()
  +processUpdatedat()
  +deleteEmail()
}
class Amenity {
  -Date type
  #Date code
  #String id
  #double price
  -boolean createdAt
  +sendType()
  +findStatus()
  +updatePhone()
}
interface CheckOut {
  -boolean description
  -double id
  -Date quantity
  +saveQuantity()
  +setType()
}
interface CheckIn {
  +int code
  -float id
  +saveLevel()
  +findDescription()
}
CheckIn ..> Payment : "1"
Payment --> CheckOut : "*"
@enduml