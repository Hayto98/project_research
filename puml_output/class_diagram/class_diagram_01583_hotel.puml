@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
interface Reservation {
  +Date quantity
  -String price
  +String updatedAt
  #String phone
  +deleteActive()
  +saveId()
}
class Amenity {
  -boolean total
  -double amount
  +boolean type
  #float id
  +long code
  +validateTotal()
  +processLevel()
  +deleteNote()
}
class Booking {
  #boolean duration
  #long status
  +validateQuantity()
}
class Restaurant {
  #boolean duration
  +float code
  #float id
  +findDescription()
  +createActive()
}
class CheckOut {
  +boolean score
  #double description
  +calculateCode()
  +saveLevel()
  +saveAddress()
  +createAddress()
}
class CheckIn {
  #String score
  +String name
  -float createdAt
  -float duration
  +cancelAmount()
  +deleteActive()
  +saveStatus()
}
abstract class Staff {
  -boolean name
  -int createdAt
  +deleteAmount()
}
Staff --o Booking
Amenity --o Restaurant
Booking --> CheckIn : "1..*"
@enduml