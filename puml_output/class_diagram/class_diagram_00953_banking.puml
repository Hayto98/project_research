@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Withdrawal {
  -double price
  -Date type
  -long id
  +setPrice()
  +calculatePrice()
  +sendPrice()
  +savePhone()
}
abstract class Statement {
  +int type
  #float active
  +boolean address
  #Date status
  -double description
  +createDescription()
  +getAddress()
  +processDuration()
  +updatePrice()
}
class Card {
  +boolean duration
  #boolean name
  -Date active
  +float status
  +getPrice()
  +sendType()
  +calculateLevel()
  +setCode()
}
class Beneficiary {
  -int level
  -float amount
  +double email
  +saveScore()
}
abstract class Teller {
  +Date score
  #Date phone
  #String quantity
  +getTotal()
  +processTotal()
}
class Loan {
  -boolean id
  -int amount
  +Date duration
  #boolean price
  +boolean name
  +validateTotal()
  +validateDuration()
}
interface Branch {
  -Date score
  #int address
  +Date description
  +deletePhone()
  +saveScore()
  +deleteDescription()
}
Statement --> Withdrawal : "1..*"
Loan --> Teller : "1..*"
@enduml