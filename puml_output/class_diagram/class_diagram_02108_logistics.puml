@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
abstract class Depot {
  +Date active
  #boolean amount
  +findDescription()
  +getPhone()
  +validateAddress()
}
class Manifest {
  #double email
  +float updatedAt
  +setUpdatedat()
  +validateScore()
  +validateLevel()
  +findCode()
}
class Inventory {
  -float quantity
  -boolean total
  #String active
  +updateStatus()
  +saveCreatedat()
  +setCreatedat()
}
class Warehouse {
  -String id
  +long quantity
  +int email
  +validateType()
  +validateCode()
  +findQuantity()
}
Inventory --* Warehouse
Manifest --> Warehouse : "1..*"
Depot --o Manifest
note right of Depot : Logistics domain
@enduml