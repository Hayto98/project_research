@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
abstract class Depot {
  +Date active
  #boolean amount
  +setCode()
  +cancelDuration()
  +validateCode()
}
class Manifest {
  -Date phone
  +boolean address
  -String status
  -float code
  +sendDescription()
}
class Inventory {
  +long score
  -Date address
  #double code
  -boolean status
  +updateQuantity()
}
class Warehouse {
  #Date status
  +float createdAt
  +int code
  +cancelAddress()
}
Inventory --|> Depot
Manifest --* Warehouse
@enduml