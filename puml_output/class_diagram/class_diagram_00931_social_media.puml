@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
abstract class Profile {
  #int code
  +float duration
  -long total
  -double active
  +processCreatedat()
}
interface Like {
  +float level
  +double price
  +Date amount
  +validatePhone()
  +sendPrice()
  +setCode()
  +cancelPhone()
}
class Notification {
  -Date email
  #Date id
  #boolean duration
  +boolean level
  +setAddress()
  +findActive()
}
class Album {
  -float createdAt
  +int address
  -double quantity
  +validateDescription()
  +validateName()
}
Notification ..|> Album
Notification --> Like : "1..*"
note right of Profile : Social Media domain
@enduml