@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
interface Wishlist {
  -int active
  -int quantity
  +String createdAt
  +findLevel()
  +sendAddress()
}
interface Review {
  -String updatedAt
  -boolean id
  +deleteQuantity()
  +findEmail()
  +setDescription()
}
class Supplier {
  -long score
  +float amount
  +setStatus()
  +calculateNote()
  +deleteActive()
  +validateType()
}
interface Category {
  -Date total
  -float level
  +getPhone()
}
Wishlist ..> Supplier : "1"
Review --o Wishlist
note right of Wishlist : Ecommerce domain
@enduml