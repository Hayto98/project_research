@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
interface Wishlist {
  -int active
  -int quantity
  +String createdAt
  +saveLevel()
  +cancelName()
}
interface Review {
  -String active
  -boolean id
  -int updatedAt
  -Date level
  +cancelLevel()
  +validatePhone()
  +createCreatedat()
}
class Supplier {
  -long score
  +float amount
  +getPrice()
  +updateName()
  +validateId()
  +deleteEmail()
}
abstract class Category {
  -boolean description
  -Date active
  -float phone
  #Date type
  +float name
  +saveLevel()
}
Wishlist --> Category : "1"
Review --o Wishlist
Supplier --|> Category
@enduml