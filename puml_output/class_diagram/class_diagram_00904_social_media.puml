@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Hashtag {
  +Date updatedAt
  -String note
  -int email
  -double duration
  +setPhone()
  +processEmail()
  +createDuration()
  +deletePhone()
}
class User {
  #String duration
  -boolean level
  +saveStatus()
  +createDescription()
  +deleteCode()
}
abstract class Comment {
  -Date address
  #int note
  #Date updatedAt
  #long quantity
  +deleteNote()
  +processId()
  +createUpdatedat()
  +cancelLevel()
}
abstract class Post {
  #int name
  +double quantity
  +long id
  +updatePrice()
  +calculatePhone()
  +getTotal()
  +processDuration()
}
interface Profile {
  -String code
  #boolean address
  +double name
  #int description
  +setPhone()
  +processNote()
  +updateUpdatedat()
  +setType()
}
class Story {
  -double type
  #String email
  +setAddress()
  +cancelTotal()
  +processActive()
  +validateCode()
}
Comment --|> Hashtag
Post --* Hashtag
User ..|> Hashtag
@enduml