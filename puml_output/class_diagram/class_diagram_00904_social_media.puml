@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Hashtag {
  +Date updatedAt
  -String note
  -int email
  -double duration
  +cancelLevel()
  +calculateDescription()
  +setDuration()
  +cancelActive()
}
class User {
  #long score
  #long address
  -int active
  -long phone
  #Date type
  +cancelAddress()
  +cancelType()
}
class Comment {
  +double updatedAt
  +long name
  -String quantity
  -int id
  +Date amount
  +saveCode()
  +validateDuration()
  +findName()
}
class Post {
  #int id
  -boolean score
  #String updatedAt
  +long note
  +processEmail()
}
class Profile {
  +double code
  -String type
  +float score
  -String id
  -String createdAt
  +deleteStatus()
  +deleteAmount()
  +findName()
}
interface Story {
  +String createdAt
  #Date amount
  +saveAddress()
  +deleteActive()
  +sendPrice()
}
User ..|> Hashtag
Profile ..> Story : "1..*"
User --|> Story
note right of Hashtag : Social Media domain
@enduml