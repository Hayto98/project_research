@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Loan {
  #boolean email
  #long total
  -String code
  #long updatedAt
  +processLevel()
  +updateName()
}
class Branch {
  -boolean code
  #float updatedAt
  #int level
  +String price
  -Date createdAt
  +deleteCreatedat()
}
abstract class Book {
  +Date id
  -int phone
  +createAddress()
  +createScore()
  +getNote()
}
class Catalog {
  +double code
  #float amount
  #double active
  -Date status
  -long note
  +cancelEmail()
  +sendCode()
  +sendDescription()
  +processQuantity()
}
Branch --* Catalog
Loan --o Book
note right of Loan : Library domain
@enduml