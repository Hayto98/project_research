@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Insurance {
  +int score
  #int email
  -int total
  +String description
  +deletePhone()
  +updateUpdatedat()
}
abstract class Prescription {
  +float level
  #long id
  +calculateAddress()
}
class Treatment {
  +long name
  +int id
  #int duration
  +int status
  +processDuration()
  +setAmount()
  +findUpdatedat()
}
class Appointment {
  +String amount
  #int total
  +int updatedAt
  -String active
  +getAmount()
}
class Nurse {
  +double updatedAt
  #float note
  -String active
  +String duration
  +boolean price
  +findAmount()
  +setNote()
}
class LabTest {
  +int code
  +Date updatedAt
  #float name
  -long total
  +deleteAmount()
}
Prescription --* Nurse
Treatment --o LabTest
note right of Insurance : Healthcare domain
@enduml