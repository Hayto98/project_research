@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Insurance {
  +int score
  #int email
  -int total
  +String description
  +createCreatedat()
  +deleteCode()
}
class Prescription {
  +float type
  #long status
  +double id
  +getNote()
  +cancelAddress()
  +deleteTotal()
}
class Treatment {
  +long name
  +int status
  +createCreatedat()
  +sendNote()
}
interface Appointment {
  +long type
  +double status
  +boolean amount
  +String updatedAt
  +getType()
  +sendNote()
}
class Nurse {
  +String status
  -int name
  +calculateActive()
  +processDuration()
  +createDuration()
  +updateUpdatedat()
}
abstract class LabTest {
  #float status
  #float id
  +Date level
  +float duration
  +deleteDuration()
}
Treatment ..|> Insurance
Insurance ..|> Appointment
Prescription ..> LabTest : "1..*"
@enduml