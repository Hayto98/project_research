@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class User {
  +boolean name
  #String createdAt
  +validateName()
}
class Group {
  #Date quantity
  #float createdAt
  +float total
  +boolean phone
  +setTotal()
  +setQuantity()
}
class Story {
  -Date createdAt
  #Date email
  #String type
  +boolean score
  +findUpdatedat()
  +saveType()
  +sendLevel()
}
class Report {
  #Date id
  +double active
  -int amount
  -boolean updatedAt
  #boolean email
  +deleteUpdatedat()
  +findEmail()
  +findNote()
}
abstract class Album {
  #long duration
  -boolean quantity
  -float status
  #Date code
  +cancelName()
  +getAddress()
  +saveScore()
}
Group --> User : "0..1"
Report ..> Album : "1..*"
Album --|> Report
Report --> User : "1..*"
@enduml