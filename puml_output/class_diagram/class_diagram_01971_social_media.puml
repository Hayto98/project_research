@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class User {
  +boolean name
  #String createdAt
  +processStatus()
}
interface Group {
  #Date quantity
  #float createdAt
  +float total
  +boolean phone
  +createName()
  +createCreatedat()
}
class Story {
  #Date level
  #Date duration
  +String score
  #long type
  #float phone
  +saveType()
}
class Report {
  #String updatedAt
  -long email
  +long score
  +cancelCode()
  +processAddress()
  +cancelQuantity()
}
class Album {
  #long email
  #Date quantity
  +findTotal()
  +validateLevel()
  +updateName()
}
Group --o Report
Story --|> Report
Report --> User : "1..*"
User ..|> Report
note right of User : Social Media domain
@enduml