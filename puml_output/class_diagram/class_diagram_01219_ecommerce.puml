@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Shipment {
  -String address
  +long updatedAt
  #Date note
  -double duration
  +float total
  +calculateAddress()
  +deleteStatus()
}
class Category {
  #long amount
  +double duration
  +setScore()
  +validateLevel()
  +sendAddress()
}
class Customer {
  +long createdAt
  #Date amount
  +setPhone()
  +saveActive()
  +validateTotal()
  +createStatus()
}
class Return {
  #String amount
  +Date phone
  -Date description
  +double active
  #String quantity
  +updateName()
  +deleteId()
}
class Review {
  #Date status
  -float email
  +Date level
  +deleteLevel()
  +sendNote()
  +sendQuantity()
  +cancelNote()
}
abstract class Order {
  #String updatedAt
  +double id
  +boolean price
  +saveName()
  +setPhone()
}
class Warehouse {
  +long phone
  +long type
  +int address
  -double amount
  -String level
  +createPhone()
  +sendStatus()
  +setActive()
  +cancelPrice()
}
Return ..> Review : "1..*"
Warehouse ..> Return : "*"
Category --|> Order
Warehouse --|> Shipment
Category --|> Return
@enduml