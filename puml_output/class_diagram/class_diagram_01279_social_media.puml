@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
abstract class Story {
  -float level
  #double name
  +savePhone()
  +saveStatus()
  +setQuantity()
  +deleteScore()
}
abstract class Hashtag {
  #int amount
  #boolean name
  +findPrice()
  +sendNote()
  +updateActive()
}
abstract class Message {
  -float active
  #String duration
  -String email
  +validateScore()
  +updateLevel()
  +deleteAmount()
  +updateDuration()
}
abstract class Group {
  #boolean phone
  -double description
  -Date updatedAt
  +Date price
  +processCreatedat()
  +cancelName()
  +createLevel()
}
Message --* Group
Group ..> Message : "0..1"
@enduml