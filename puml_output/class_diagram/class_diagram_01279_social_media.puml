@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
abstract class Story {
  -float level
  #double name
  +getAmount()
  +saveTotal()
  +getAmount()
  +getDuration()
}
class Hashtag {
  +Date active
  #boolean updatedAt
  #Date id
  -double note
  +createId()
}
abstract class Message {
  -long quantity
  +float price
  #int id
  -Date level
  +processEmail()
  +findUpdatedat()
  +savePhone()
}
class Group {
  #long level
  -double email
  #String price
  #long description
  +saveStatus()
  +setAmount()
}
Message ..> Story : "0..1"
Story --* Group
Group --o Hashtag
note right of Story : Social Media domain
@enduml