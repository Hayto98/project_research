@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
interface DeliveryNote {
  #long amount
  +double updatedAt
  +double score
  +int createdAt
  -float name
  +cancelType()
  +calculatePrice()
  +saveEmail()
}
class Inventory {
  +boolean note
  +int active
  +long level
  #Date type
  +sendCreatedat()
}
class Package {
  +double amount
  #String phone
  #long createdAt
  #String score
  +updatePhone()
}
class Shipment {
  +long score
  +float note
  +String type
  +findNote()
  +validateDescription()
  +findUpdatedat()
  +getCode()
}
interface Manifest {
  #float description
  +Date createdAt
  +String amount
  +createAddress()
  +updateEmail()
}
class FuelLog {
  +long score
  -Date active
  -int quantity
  -long email
  #boolean address
  +createTotal()
  +createType()
  +deleteLevel()
}
Manifest --|> FuelLog
FuelLog ..|> Inventory
Inventory --|> Shipment
Inventory --> DeliveryNote : "0..1"
Inventory --|> Manifest
@enduml