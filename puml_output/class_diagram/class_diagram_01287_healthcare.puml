@startuml
skinparam monochrome true
abstract class Doctor {
  -long code
  #double name
  +String level
  #String duration
  +setEmail()
  +cancelNote()
}
class Appointment {
  -int createdAt
  -double duration
  +calculateUpdatedat()
}
abstract class LabTest {
  -float type
  -float email
  #int updatedAt
  -float total
  +int note
  +validateStatus()
  +getAmount()
  +findPhone()
  +createDescription()
}
interface Billing {
  #float createdAt
  +long active
  +double note
  #int updatedAt
  -String level
  +sendStatus()
}
abstract class Ward {
  #int id
  -float status
  #double address
  #Date description
  #float email
  +saveDescription()
  +deleteUpdatedat()
  +updatePhone()
  +saveStatus()
}
interface Patient {
  +float total
  #String description
  +processNote()
}
class Prescription {
  -float type
  #Date active
  -String total
  #Date level
  +sendUpdatedat()
  +cancelType()
  +deleteScore()
}
Billing --o Ward
Doctor ..|> Ward
Patient ..|> LabTest
Prescription --o Patient
note right of Doctor : Healthcare domain
@enduml