@startuml
skinparam monochrome true
abstract class Doctor {
  -long code
  #double name
  +String level
  #String duration
  +createAddress()
  +validateAddress()
}
interface Appointment {
  #boolean address
  #float active
  +long level
  +long id
  -String createdAt
  +processPrice()
  +deleteAmount()
  +updateEmail()
  +validatePrice()
}
abstract class LabTest {
  -float updatedAt
  -float score
  #int total
  -float note
  +createCreatedat()
  +sendCode()
}
class Billing {
  #long id
  -Date amount
  +cancelPrice()
  +validateStatus()
}
interface Ward {
  #float createdAt
  +long active
  +double note
  #int updatedAt
  -String level
  +calculateActive()
}
class Patient {
  -float price
  #int id
  -float status
  #double address
  #Date description
  +updatePhone()
  +setLevel()
  +validateCreatedat()
  +updateStatus()
}
class Prescription {
  +float status
  +float level
  #String code
  #String total
  +createName()
  +setScore()
  +deleteScore()
  +cancelActive()
}
Billing ..> Ward : "*"
Ward ..> Billing : "*"
Doctor ..> Ward : "1..*"
Ward --> Appointment : "*"
@enduml