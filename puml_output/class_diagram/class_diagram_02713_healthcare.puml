@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Diagnosis {
  +float total
  #double address
  +float status
  +String code
  +createAmount()
  +createDescription()
}
class Prescription {
  #Date duration
  #float code
  +String name
  +float description
  +sendActive()
}
abstract class Insurance {
  +double email
  -Date price
  +createCreatedat()
  +updateId()
}
interface LabTest {
  +Date total
  #float level
  +Date email
  +validateDuration()
  +savePhone()
  +validatePhone()
  +findTotal()
}
class Billing {
  +String phone
  #double address
  +double id
  -boolean description
  -float type
  +sendPrice()
  +setType()
  +getType()
  +cancelEmail()
}
Diagnosis --o LabTest
Insurance --> Prescription : "0..1"
@enduml