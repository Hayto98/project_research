@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Treatment {
  +boolean description
  #double createdAt
  #double id
  +saveDescription()
}
class Hospital {
  -int type
  +float address
  #double active
  #long description
  +findNote()
  +processNote()
  +deleteType()
}
class Diagnosis {
  +long status
  #Date updatedAt
  +createName()
}
class LabTest {
  +float createdAt
  #boolean id
  +cancelAddress()
  +getId()
}
class Prescription {
  #String score
  #String quantity
  +int description
  #boolean code
  +createNote()
  +findCode()
  +findDuration()
}
abstract class Patient {
  +Date note
  +boolean status
  +getDescription()
}
Patient --|> Diagnosis
Diagnosis --> LabTest : "*"
@enduml