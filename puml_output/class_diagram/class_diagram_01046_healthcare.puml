@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Treatment {
  +boolean description
  #double createdAt
  #double id
  +findCode()
}
class Hospital {
  +float address
  #double active
  #long description
  -String duration
  #Date createdAt
  +setStatus()
  +updateName()
  +createDuration()
}
class Diagnosis {
  #boolean description
  #int code
  -double createdAt
  -boolean id
  -float level
  +deleteCode()
  +saveName()
  +saveName()
}
class LabTest {
  #double score
  +float email
  -float phone
  +deleteStatus()
}
interface Prescription {
  +long name
  -boolean phone
  +saveNote()
  +getCode()
  +validatePhone()
  +deleteScore()
}
class Patient {
  -Date description
  +int address
  +double code
  -boolean level
  #String status
  +setQuantity()
  +calculateAddress()
}
Treatment --> Patient : "*"
LabTest ..> Diagnosis : "1"
note right of Treatment : Healthcare domain
@enduml