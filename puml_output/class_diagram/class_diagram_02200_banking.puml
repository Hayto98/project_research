@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Customer {
  -int price
  -Date note
  -double type
  +int createdAt
  +int phone
  +findUpdatedat()
  +setCreatedat()
}
class Loan {
  +boolean quantity
  -String createdAt
  +long code
  +processName()
}
class Interest {
  +double address
  #long id
  -String score
  #long description
  #double email
  +updateId()
}
class Account {
  #int name
  #int type
  +String email
  +long active
  +findAddress()
}
class Statement {
  #Date updatedAt
  -double total
  #long quantity
  +boolean address
  +calculateEmail()
  +sendScore()
  +calculateActive()
  +processUpdatedat()
}
class Withdrawal {
  #boolean name
  -boolean amount
  +float status
  +Date price
  +setId()
  +setCreatedat()
  +getType()
  +validateType()
}
Customer --o Loan
Loan --* Interest
Withdrawal --* Loan
Account ..> Loan : "1..*"
@enduml