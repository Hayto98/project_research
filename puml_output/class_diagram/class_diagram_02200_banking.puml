@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Customer {
  -int price
  -Date note
  -double type
  +int createdAt
  +int phone
  +cancelPhone()
  +deleteQuantity()
}
class Loan {
  +int updatedAt
  -float note
  +getEmail()
}
interface Interest {
  +double address
  #long id
  -String score
  #long description
  #double email
  +findName()
}
class Account {
  #Date type
  +Date email
  +getName()
  +getEmail()
}
class Statement {
  -Date amount
  #float quantity
  -long updatedAt
  +calculateDuration()
  +validateName()
  +cancelLevel()
}
abstract class Withdrawal {
  +Date price
  #float active
  +validateName()
  +deleteStatus()
}
Statement --* Withdrawal
Statement --|> Customer
Withdrawal --> Account : "1"
Withdrawal --* Statement
Customer --o Loan
note right of Customer : Banking domain
@enduml