@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Nurse {
  #double note
  +float duration
  -Date phone
  #long email
  #long status
  +deleteActive()
}
interface Billing {
  #Date email
  +float name
  +long phone
  -double address
  +createDescription()
  +updateTotal()
  +processUpdatedat()
  +createType()
}
class Patient {
  #boolean active
  #String total
  #int amount
  -String code
  +String createdAt
  +saveId()
}
class Diagnosis {
  +boolean updatedAt
  #Date score
  -float price
  #Date createdAt
  +int duration
  +setId()
  +deleteTotal()
  +createEmail()
  +deleteStatus()
}
Diagnosis --|> Patient
Patient ..|> Nurse
@enduml