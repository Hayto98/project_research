@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Housekeeping {
  +long code
  -long level
  -Date description
  +boolean quantity
  +boolean name
  +createTotal()
  +cancelEmail()
  +deletePhone()
  +updateAddress()
}
interface Invoice {
  -Date type
  -int id
  +float note
  +createAmount()
}
class Amenity {
  #Date id
  #int status
  +long duration
  #int description
  -String code
  +calculateUpdatedat()
  +processAmount()
  +getId()
  +createPrice()
}
class Room {
  -double updatedAt
  -long total
  +getAmount()
}
class Guest {
  #boolean active
  -String email
  +String id
  +String createdAt
  +updateQuantity()
  +validateNote()
  +deleteDescription()
}
abstract class Restaurant {
  #long email
  +int level
  -boolean active
  #float name
  +updateLevel()
  +validateNote()
  +cancelType()
}
Housekeeping --* Restaurant
Restaurant --* Room
@enduml