@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Reservation {
  -double type
  -double createdAt
  +Date score
  #float level
  +String name
  +calculateAmount()
  +calculateCode()
}
class Room {
  +String level
  #Date active
  +double phone
  #double address
  -float name
  +validateName()
}
class Service {
  -double type
  -String active
  -long amount
  +processAmount()
  +getName()
  +deleteEmail()
}
abstract class CheckOut {
  -boolean phone
  #double amount
  +sendAddress()
  +findEmail()
  +getAmount()
}
class Guest {
  -float code
  +double createdAt
  +double active
  #double description
  +getTotal()
  +findUpdatedat()
}
class Amenity {
  #Date updatedAt
  +float email
  +double code
  #boolean level
  -double type
  +setUpdatedat()
  +findCreatedat()
  +calculateDescription()
  +sendScore()
}
Reservation --* CheckOut
Service ..> Reservation : "1..*"
CheckOut --* Service
@enduml