@startuml
skinparam ArrowColor #555555
class Department {
  #double score
  #String updatedAt
  +getDuration()
  +updateType()
  +sendAddress()
}
class Grade {
  #long amount
  +int code
  #String phone
  +createEmail()
  +createId()
  +saveDescription()
  +sendCode()
}
interface Course {
  #String amount
  +String total
  +saveType()
  +calculateType()
  +calculatePrice()
  +findPrice()
}
class Enrollment {
  +long price
  #double phone
  #long type
  #float updatedAt
  +calculateScore()
  +processStatus()
  +setPrice()
}
Enrollment --|> Course
Course ..> Department : "0..1"
Department --o Course
note right of Department : Education domain
@enduml