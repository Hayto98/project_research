@startuml
skinparam ArrowColor #555555
class Department {
  #double score
  #String updatedAt
  +saveEmail()
  +calculateTotal()
  +findDescription()
}
class Grade {
  +float active
  -boolean address
  -String description
  +boolean score
  +float amount
  +calculatePhone()
  +deleteName()
  +cancelAddress()
  +calculateLevel()
}
class Course {
  +float active
  +float code
  -Date score
  +processAmount()
}
class Enrollment {
  #float type
  -String total
  #long duration
  -long level
  -float price
  +updateType()
  +validateDuration()
}
Course --* Enrollment
Enrollment --> Course : "*"
Department --o Enrollment
@enduml