@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
interface Transfer {
  #String status
  #int phone
  -Date code
  #String address
  +createCode()
}
class Deposit {
  #boolean updatedAt
  #Date total
  +getDescription()
  +setPrice()
  +processActive()
}
class Loan {
  -String id
  #String amount
  -int active
  -int name
  +int address
  +processActive()
  +savePhone()
  +updatePhone()
}
class Customer {
  #double code
  +boolean email
  +cancelCode()
}
class Statement {
  -long description
  +double email
  +deleteEmail()
  +calculateScore()
}
Customer --o Loan
Statement ..|> Transfer
@enduml