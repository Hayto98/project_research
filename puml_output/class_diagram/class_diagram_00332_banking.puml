@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
interface Transfer {
  #String status
  #int phone
  -Date code
  #String address
  +deleteAmount()
}
class Deposit {
  #Date total
  -float level
  +int active
  +getAmount()
  +findActive()
  +findName()
  +findAddress()
}
class Loan {
  -int level
  -int name
  +deletePhone()
}
class Customer {
  +long id
  #double code
  +sendStatus()
  +processUpdatedat()
}
class Statement {
  +double email
  +long address
  +double phone
  +calculateScore()
  +setAmount()
  +sendAmount()
}
Statement --o Loan
Loan --|> Customer
note right of Transfer : Banking domain
@enduml