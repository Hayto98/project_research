@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Return {
  -double status
  #String updatedAt
  #long email
  -String quantity
  +findScore()
  +saveCreatedat()
  +processNote()
}
class Invoice {
  -int id
  -long amount
  +getAmount()
  +calculateDuration()
}
class Supplier {
  +float price
  -double level
  #float updatedAt
  -float code
  +String createdAt
  +cancelAmount()
}
interface Coupon {
  +double type
  +boolean createdAt
  #long price
  +String updatedAt
  #float active
  +sendStatus()
  +validateStatus()
  +processAmount()
}
class Shipment {
  +double code
  +long createdAt
  +updateQuantity()
  +getActive()
  +calculateId()
  +validateType()
}
class Wishlist {
  +double createdAt
  +float status
  +int description
  +Date updatedAt
  -int quantity
  +setId()
  +cancelQuantity()
  +updateType()
  +calculateQuantity()
}
class Payment {
  +int duration
  -Date address
  -Date active
  #String note
  +getType()
  +calculateId()
  +processNote()
  +cancelUpdatedat()
}
Supplier --|> Return
Wishlist --> Coupon : "*"
Return ..> Shipment : "1"
Coupon ..> Shipment : "0..1"
Wishlist ..|> Invoice
@enduml