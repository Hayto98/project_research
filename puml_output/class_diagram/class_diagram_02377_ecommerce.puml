@startuml
skinparam monochrome true
interface Coupon {
  #String name
  +boolean code
  +Date email
  -double id
  +sendType()
}
class Supplier {
  #long updatedAt
  #int amount
  +String createdAt
  +getLevel()
}
class Invoice {
  #Date id
  +String code
  #boolean active
  +double description
  -boolean type
  +deleteDuration()
}
class Customer {
  +double quantity
  +double type
  -String phone
  -long address
  +createNote()
  +sendPhone()
}
class Wishlist {
  +long total
  #double amount
  +getPrice()
  +calculateNote()
  +saveTotal()
  +deleteTotal()
}
class Order {
  #Date status
  +float active
  #boolean score
  +getDuration()
}
class Payment {
  +float type
  #int amount
  +long updatedAt
  -int description
  #boolean duration
  +sendNote()
  +saveEmail()
  +setActive()
  +cancelId()
}
Customer ..|> Coupon
Payment --> Supplier : "1"
Supplier --o Customer
Coupon --> Customer : "*"
@enduml