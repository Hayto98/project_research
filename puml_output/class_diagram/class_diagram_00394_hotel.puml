@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Service {
  +float quantity
  -String level
  #Date type
  -String phone
  +sendPhone()
}
interface Booking {
  +int duration
  +float quantity
  #float id
  +deleteCreatedat()
}
class Invoice {
  -Date id
  #String total
  +saveLevel()
  +deleteDescription()
  +processDuration()
  +calculateScore()
}
abstract class Guest {
  +long status
  #String address
  +boolean quantity
  +double description
  +findPhone()
  +setEmail()
  +createAddress()
  +getStatus()
}
interface Amenity {
  #String note
  -long status
  #String updatedAt
  +updateDuration()
  +setAddress()
  +sendType()
  +createStatus()
}
class Restaurant {
  +boolean duration
  #long amount
  #boolean total
  +createAmount()
  +updateCode()
  +setName()
}
class Staff {
  -float duration
  #float price
  #int updatedAt
  +String type
  +boolean address
  +updateType()
  +sendId()
}
Service --|> Booking
Restaurant --> Service : "0..1"
Restaurant --o Guest
Invoice --> Service : "1..*"
Guest ..|> Staff
note right of Service : Hotel domain
@enduml