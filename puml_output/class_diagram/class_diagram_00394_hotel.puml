@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Service {
  +float quantity
  -String level
  #Date type
  -String phone
  +sendQuantity()
}
class Booking {
  +int duration
  +float quantity
  #float id
  +findPhone()
}
class Invoice {
  -long code
  #Date id
  +getAddress()
}
interface Guest {
  #double description
  #boolean note
  -String price
  +deleteLevel()
  +updateCode()
  +processDescription()
}
class Amenity {
  #int address
  -boolean status
  #boolean updatedAt
  +updateScore()
  +saveScore()
  +findNote()
  +validateAmount()
}
class Restaurant {
  -Date name
  #String status
  #int score
  #String description
  +calculateName()
  +setCreatedat()
  +updateUpdatedat()
  +saveDescription()
}
abstract class Staff {
  #double duration
  -String code
  -int address
  +getAddress()
  +setName()
}
Staff --* Restaurant
Staff --> Amenity : "1..*"
Invoice ..|> Booking
Service --|> Staff
Booking ..> Guest : "*"
Booking ..> Restaurant : "*"
@enduml