@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
abstract class Appointment {
  +String duration
  +String description
  +long name
  +validateTotal()
  +createDuration()
}
class Billing {
  +boolean note
  #Date score
  +cancelTotal()
}
class Treatment {
  -boolean createdAt
  #String phone
  #int code
  +deleteId()
  +sendQuantity()
}
class Nurse {
  #Date amount
  +long note
  +deletePrice()
  +deleteUpdatedat()
}
Billing ..> Nurse : "0..1"
Treatment ..> Nurse : "1"
@enduml