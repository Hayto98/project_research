@startuml
skinparam monochrome true
class Assignment {
  #String id
  #long name
  -float status
  +saveId()
  +updatePrice()
}
interface Student {
  #long address
  +int price
  +float duration
  #int id
  -int score
  +saveQuantity()
  +updateUpdatedat()
  +processAddress()
}
class Enrollment {
  +int id
  +int active
  +deleteNote()
  +deleteLevel()
}
class Book {
  +Date price
  #long active
  #boolean note
  #Date email
  -long updatedAt
  +sendPhone()
  +createEmail()
}
class Department {
  +String updatedAt
  #float total
  +validateCode()
  +getActive()
}
Student ..|> Book
Department --* Student
Book ..|> Department
@enduml