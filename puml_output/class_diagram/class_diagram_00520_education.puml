@startuml
skinparam monochrome true
class Assignment {
  #String id
  #long name
  -float status
  +getId()
  +cancelPrice()
}
class Student {
  +int address
  +float id
  #int active
  -int duration
  #long quantity
  +setUpdatedat()
  +setId()
}
interface Enrollment {
  +int amount
  +float code
  +calculatePrice()
}
interface Book {
  -int email
  -float updatedAt
  -String createdAt
  +double address
  +String total
  +deletePhone()
  +saveCreatedat()
}
abstract class Department {
  #double score
  -int updatedAt
  #double address
  +createCreatedat()
  +updateLevel()
}
Book --|> Enrollment
Enrollment ..|> Book
Enrollment --* Student
note right of Assignment : Education domain
@enduml