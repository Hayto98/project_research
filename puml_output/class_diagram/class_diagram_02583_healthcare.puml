@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
interface Appointment {
  #boolean quantity
  -Date active
  +double note
  +int amount
  +updateQuantity()
  +findAddress()
  +getCode()
}
class Diagnosis {
  #Date updatedAt
  +long status
  +calculateScore()
}
class Prescription {
  -float phone
  #Date updatedAt
  #boolean price
  +updateUpdatedat()
  +processStatus()
  +getUpdatedat()
}
class Ward {
  -boolean amount
  -float createdAt
  +setStatus()
  +setCode()
}
interface Nurse {
  -double address
  #double name
  -float phone
  -double note
  +boolean code
  +calculateScore()
  +cancelId()
}
Nurse ..|> Diagnosis
Ward --o Appointment
Diagnosis ..> Prescription : "1"
@enduml