@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
interface Appointment {
  #boolean quantity
  -Date active
  +double note
  +int amount
  +updateLevel()
  +setActive()
  +cancelId()
}
class Diagnosis {
  #float id
  +long quantity
  +deletePhone()
  +updatePrice()
}
class Prescription {
  +Date status
  +double phone
  #long amount
  +String name
  +validateName()
  +validateNote()
  +setPrice()
  +calculateDuration()
}
abstract class Ward {
  -long type
  -boolean note
  +int code
  -boolean createdAt
  +processAmount()
}
class Nurse {
  #boolean type
  -float name
  +setDuration()
}
Prescription --|> Appointment
Nurse --o Appointment
note right of Appointment : Healthcare domain
@enduml