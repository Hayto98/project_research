@startuml
skinparam monochrome true
skinparam shadowing true
class Inventory {
  #float status
  #double updatedAt
  +setName()
}
class Package {
  #float score
  +long note
  +setPrice()
  +cancelCode()
}
class Customer {
  #Date price
  #String updatedAt
  -float duration
  +createPrice()
  +updateDescription()
  +deleteAddress()
  +processUpdatedat()
}
interface Tracking {
  -long active
  #Date code
  +Date updatedAt
  +calculateActive()
  +sendStatus()
  +deleteAddress()
}
Inventory --|> Package
Customer ..> Package : "1"
Tracking ..|> Package
@enduml