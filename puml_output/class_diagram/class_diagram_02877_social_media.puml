@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
abstract class Story {
  #float duration
  -String address
  #Date amount
  +updateType()
  +calculateName()
  +getDuration()
  +cancelId()
}
abstract class Hashtag {
  -double score
  +Date price
  #boolean phone
  +getType()
  +cancelQuantity()
  +validateStatus()
}
interface Message {
  +String updatedAt
  -double quantity
  -String code
  +setType()
}
class Like {
  +int level
  +int quantity
  +double score
  +setAddress()
  +getType()
}
class Notification {
  +String quantity
  -float email
  -Date createdAt
  +calculateTotal()
  +setId()
}
abstract class Post {
  #long active
  +double score
  +int name
  #boolean createdAt
  -double phone
  +saveActive()
  +cancelId()
  +sendLevel()
}
Hashtag --* Like
Story --* Like
@enduml