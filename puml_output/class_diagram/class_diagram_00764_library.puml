@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Member {
  -String quantity
  +double duration
  +int score
  -int price
  +String createdAt
  +processDuration()
  +deleteStatus()
}
class Loan {
  #String total
  #long duration
  #boolean type
  #int note
  +double quantity
  +processNote()
}
class Publisher {
  +long score
  -Date phone
  #Date updatedAt
  -int level
  #Date description
  +cancelCode()
  +saveActive()
  +findPrice()
}
class Reservation {
  #Date address
  -int code
  #boolean duration
  -String email
  +updateName()
  +setAddress()
}
Loan --o Member
Member ..|> Reservation
note right of Member : Library domain
@enduml