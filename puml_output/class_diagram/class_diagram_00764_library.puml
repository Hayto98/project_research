@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Member {
  -String quantity
  +double duration
  +int score
  -int price
  +String createdAt
  +sendCode()
  +updateAddress()
}
interface Loan {
  #double status
  -Date email
  -double score
  +updateLevel()
  +deleteType()
  +cancelStatus()
  +getUpdatedat()
}
interface Publisher {
  -Date duration
  +double score
  -int amount
  #double level
  +createScore()
  +updateTotal()
  +validateCode()
}
class Reservation {
  #String price
  #Date email
  #float createdAt
  #Date quantity
  +createEmail()
  +updateAmount()
  +getPrice()
  +cancelStatus()
}
Publisher --* Member
Publisher ..> Reservation : "1..*"
Loan --> Publisher : "*"
@enduml