@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Account {
  +int address
  +Date email
  #int total
  +updateActive()
  +processStatus()
}
class Branch {
  #double email
  #String quantity
  #long price
  -double amount
  +deleteType()
}
interface Transfer {
  +boolean status
  -Date name
  #boolean type
  #Date id
  +saveEmail()
  +saveAmount()
  +createCreatedat()
  +updateQuantity()
}
class Withdrawal {
  #Date phone
  #boolean address
  -Date amount
  +float updatedAt
  +updateCode()
  +updateUpdatedat()
  +getEmail()
  +sendName()
}
Account ..|> Transfer
Transfer --> Branch : "0..1"
Withdrawal --* Account
@enduml