@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Account {
  +int address
  +Date email
  #int total
  +getPhone()
  +setPhone()
}
class Branch {
  #long price
  -double amount
  +Date total
  #long name
  +getDuration()
}
abstract class Transfer {
  -Date updatedAt
  #boolean active
  +getNote()
  +deleteAddress()
  +createPhone()
  +validateAmount()
}
interface Withdrawal {
  #float score
  +float level
  #double email
  +deleteType()
}
Account ..|> Transfer
Transfer --> Branch : "0..1"
Withdrawal --* Account
note right of Account : Banking domain
@enduml