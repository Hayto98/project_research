@startuml
skinparam monochrome true
skinparam ArrowColor #555555
abstract class Transfer {
  #int status
  #Date address
  -double phone
  -String email
  +createTotal()
  +createPhone()
}
abstract class Withdrawal {
  +String address
  #Date score
  -Date price
  -double createdAt
  +processEmail()
  +updateCreatedat()
  +getDuration()
  +saveAddress()
}
abstract class Statement {
  +long createdAt
  +int amount
  +findAmount()
  +setQuantity()
  +updateName()
}
class Deposit {
  #float type
  #boolean total
  -Date description
  #String code
  +float phone
  +calculateEmail()
}
class Teller {
  +Date description
  #double name
  +String createdAt
  +setLevel()
  +validateQuantity()
  +updatePhone()
}
class Loan {
  -int duration
  -int code
  #String active
  -String updatedAt
  -Date quantity
  +saveTotal()
  +calculateName()
  +calculateId()
  +processCode()
}
class Customer {
  #double quantity
  -int email
  +float total
  #Date note
  +double id
  +validateDuration()
  +cancelUpdatedat()
  +sendStatus()
}
Loan ..|> Teller
Teller --|> Deposit
Statement ..|> Deposit
Statement ..|> Customer
Transfer --> Teller : "*"
@enduml