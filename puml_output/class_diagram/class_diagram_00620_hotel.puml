@startuml
skinparam monochrome true
skinparam shadowing true
interface Restaurant {
  +long total
  #float name
  #int active
  +findDescription()
  +updateUpdatedat()
  +saveCreatedat()
}
class Guest {
  #Date level
  +double price
  -boolean note
  -boolean phone
  +updatePhone()
}
class CheckIn {
  #Date email
  -boolean phone
  #float id
  +cancelName()
  +findEmail()
  +setType()
  +calculateAmount()
}
class CheckOut {
  +String description
  -double email
  +sendStatus()
}
Restaurant --|> CheckIn
Guest --* Restaurant
@enduml