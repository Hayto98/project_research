@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Route {
  -double level
  +String duration
  #double address
  #int active
  -long createdAt
  +processNote()
}
abstract class Tracking {
  +double description
  -double code
  #long total
  #double amount
  +setQuantity()
  +createDescription()
  +deleteScore()
  +cancelStatus()
}
abstract class FuelLog {
  -long duration
  +Date quantity
  #double total
  +int email
  +createLevel()
  +deleteEmail()
  +validateAmount()
}
class Depot {
  #boolean level
  -boolean score
  -double duration
  -float id
  -float address
  +deletePrice()
  +deleteAddress()
}
class Driver {
  +float code
  #double updatedAt
  +double level
  +getNote()
}
FuelLog ..|> Route
Tracking --* Driver
FuelLog --* Depot
@enduml