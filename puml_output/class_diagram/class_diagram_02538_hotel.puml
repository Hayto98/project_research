@startuml
skinparam monochrome true
class Housekeeping {
  #String createdAt
  -String name
  -boolean id
  +getCode()
  +validateActive()
}
interface CheckIn {
  -boolean email
  #boolean phone
  -double note
  -long quantity
  +updateLevel()
  +cancelEmail()
}
class Invoice {
  -float name
  -int createdAt
  #double price
  +int score
  #String level
  +validateQuantity()
  +createDescription()
  +processLevel()
  +setActive()
}
class Service {
  #float name
  -boolean amount
  #String price
  #double total
  +getId()
  +processScore()
  +updateQuantity()
}
class CheckOut {
  +String id
  +String name
  +float createdAt
  +Date description
  #float phone
  +findNote()
  +createLevel()
  +setCreatedat()
}
Housekeeping ..> Invoice : "1"
CheckOut ..> Housekeeping : "1..*"
@enduml