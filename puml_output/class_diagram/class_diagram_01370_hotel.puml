@startuml

abstract class Amenity {
  #String note
  +boolean phone
  +processDuration()
  +cancelUpdatedat()
  +deleteActive()
}
class Booking {
  #int id
  -long email
  +String createdAt
  +processCreatedat()
}
interface CheckOut {
  -double quantity
  #boolean updatedAt
  +double phone
  +boolean code
  +long status
  +saveId()
  +createScore()
  +setQuantity()
}
class Invoice {
  -long note
  #int code
  #Date email
  #float amount
  +setPhone()
  +updateId()
  +saveAddress()
  +setDuration()
}
CheckOut ..> Amenity : "*"
Booking --o Invoice
note right of Amenity : Hotel domain
@enduml