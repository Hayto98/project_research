@startuml

abstract class Amenity {
  #String note
  +boolean phone
  +processTotal()
  +setId()
  +findUpdatedat()
}
class Booking {
  +long active
  +boolean code
  +double updatedAt
  +updateDescription()
  +savePhone()
  +calculateId()
}
abstract class CheckOut {
  #float active
  +long type
  #float quantity
  +updateName()
}
abstract class Invoice {
  -long level
  #String name
  -boolean price
  +Date id
  -float updatedAt
  +processDescription()
}
Amenity ..|> Booking
Invoice --> Booking : "0..1"
Invoice --* Amenity
@enduml