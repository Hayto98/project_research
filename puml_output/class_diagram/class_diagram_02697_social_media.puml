@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Comment {
  -float amount
  -int status
  -boolean createdAt
  +updateAddress()
}
interface Group {
  #long quantity
  -boolean amount
  -double total
  +int description
  #double type
  +cancelNote()
  +validateDescription()
  +validateCode()
  +updateQuantity()
}
class Hashtag {
  #double type
  +int level
  -float total
  +cancelName()
  +cancelPhone()
  +deleteActive()
}
class Message {
  -Date createdAt
  -Date score
  #long name
  +int level
  +validateStatus()
}
class Post {
  #double score
  #long amount
  #boolean type
  -double quantity
  +float id
  +saveCode()
  +setDescription()
  +saveActive()
  +sendStatus()
}
abstract class Album {
  -float email
  -long address
  +createCreatedat()
  +setName()
}
Post --o Message
Hashtag --* Comment
Message --> Comment : "0..1"
note right of Comment : Social Media domain
@enduml