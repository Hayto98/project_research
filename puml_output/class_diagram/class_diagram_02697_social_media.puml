@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Comment {
  -float amount
  -int status
  -boolean createdAt
  +findAddress()
}
class Group {
  #long quantity
  -boolean amount
  -double total
  +int description
  #double type
  +deleteUpdatedat()
  +saveAmount()
  +createId()
  +createAmount()
}
class Hashtag {
  +double code
  #double createdAt
  #double quantity
  +int description
  +calculateLevel()
  +findQuantity()
  +findName()
}
class Message {
  #int amount
  #String active
  +double name
  #long email
  +updatePrice()
  +calculateNote()
  +calculateEmail()
}
class Post {
  #int amount
  -float total
  +findDescription()
  +findDuration()
  +processAddress()
}
class Album {
  #String quantity
  +int phone
  #boolean type
  #String updatedAt
  -float price
  +getPrice()
}
Hashtag --o Message
Hashtag --* Group
Group ..> Comment : "1"
Post --* Album
@enduml