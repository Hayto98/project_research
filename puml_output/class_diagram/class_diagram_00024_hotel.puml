@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
abstract class Housekeeping {
  +int price
  #Date createdAt
  +double active
  +deleteStatus()
}
abstract class CheckOut {
  +String status
  -boolean createdAt
  +int description
  #float note
  +boolean duration
  +getStatus()
  +savePrice()
  +createAddress()
  +calculateLevel()
}
interface Service {
  #float note
  -boolean active
  +processDescription()
  +findStatus()
  +createName()
  +getPrice()
}
class Room {
  -boolean note
  +String type
  +processEmail()
  +updateId()
  +sendScore()
  +cancelLevel()
}
interface Payment {
  #String id
  #Date email
  -double code
  +processAddress()
  +sendPrice()
}
Room --|> CheckOut
Housekeeping ..> Room : "0..1"
Housekeeping --> Payment : "1..*"
@enduml