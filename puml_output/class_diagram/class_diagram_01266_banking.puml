@startuml
skinparam ArrowColor #555555
interface Customer {
  #long code
  #String active
  -float amount
  +long duration
  +saveEmail()
  +setDuration()
}
class Branch {
  +long score
  -boolean type
  #long active
  +double status
  +saveTotal()
  +validateName()
  +cancelAddress()
}
abstract class Teller {
  +int note
  -boolean quantity
  -String score
  +calculateType()
  +calculateId()
}
interface Statement {
  #int note
  #float type
  +int level
  +Date address
  +processLevel()
}
Customer --* Statement
Statement --|> Branch
@enduml