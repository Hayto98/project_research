@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Patient {
  -String createdAt
  +double price
  #String status
  #String active
  -long phone
  +getTotal()
  +createActive()
}
class Appointment {
  +boolean type
  -long name
  +float quantity
  +long id
  +Date active
  +validateId()
  +getDuration()
}
class Insurance {
  +int email
  -boolean total
  +String score
  +getDuration()
  +calculateScore()
  +findCreatedat()
  +sendUpdatedat()
}
class Treatment {
  +String score
  +String note
  +int phone
  +processCode()
  +createDuration()
  +sendName()
  +createTotal()
}
class Doctor {
  +int amount
  #float price
  +Date updatedAt
  #long active
  -double duration
  +getUpdatedat()
}
Insurance ..|> Treatment
Doctor ..> Treatment : "*"
Treatment ..> Patient : "*"
Insurance --o Appointment
@enduml