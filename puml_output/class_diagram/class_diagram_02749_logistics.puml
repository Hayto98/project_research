@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class DeliveryNote {
  #boolean createdAt
  -float address
  #String score
  -String active
  +findPhone()
  +calculateName()
  +updateAmount()
}
class FuelLog {
  +int type
  +boolean id
  +setAmount()
  +createEmail()
  +updateQuantity()
}
interface Shipment {
  -boolean createdAt
  #long id
  +sendAmount()
  +getEmail()
  +getStatus()
  +saveDuration()
}
interface Warehouse {
  -double updatedAt
  +Date code
  +saveId()
}
abstract class Tracking {
  -double id
  -Date updatedAt
  -String createdAt
  +boolean price
  +int note
  +processStatus()
}
DeliveryNote --|> Tracking
Tracking ..|> Warehouse
@enduml