@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class DeliveryNote {
  #boolean createdAt
  -float address
  #String score
  -String active
  +deleteAddress()
  +updateStatus()
  +processId()
}
class FuelLog {
  +String id
  -boolean address
  #long status
  +sendDescription()
  +cancelScore()
  +getUpdatedat()
  +setEmail()
}
abstract class Shipment {
  -String name
  #int duration
  +double note
  +createPrice()
  +processPrice()
  +setUpdatedat()
  +sendDescription()
}
class Warehouse {
  +String phone
  +boolean id
  +deletePhone()
  +createName()
  +sendDescription()
  +setName()
}
class Tracking {
  #float quantity
  +boolean total
  +processCode()
  +createAmount()
}
Shipment --* Warehouse
Tracking --|> Warehouse
note right of DeliveryNote : Logistics domain
@enduml