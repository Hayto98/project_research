@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Shipment {
  -double updatedAt
  -boolean address
  +createTotal()
}
abstract class Coupon {
  -int status
  #Date active
  -String duration
  +String email
  +sendCreatedat()
  +findPhone()
  +cancelCreatedat()
}
interface Wishlist {
  -String quantity
  +String duration
  -float status
  +findAddress()
}
interface Order {
  +float duration
  +String updatedAt
  +updateCode()
}
class Return {
  #long duration
  +double status
  -double active
  +cancelType()
  +setScore()
  +deleteDuration()
}
interface Category {
  +double price
  #String status
  -long duration
  #float phone
  +getUpdatedat()
  +processActive()
  +createAddress()
  +calculateLevel()
}
Coupon --> Category : "1"
Return --|> Wishlist
Order ..> Wishlist : "0..1"
Category --> Wishlist : "0..1"
note right of Shipment : Ecommerce domain
@enduml