@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Shipment {
  -double updatedAt
  -boolean address
  +deleteName()
}
abstract class Coupon {
  -int email
  #Date status
  -String active
  +String level
  -boolean duration
  +cancelDescription()
  +findCode()
}
interface Wishlist {
  #long level
  +long createdAt
  +int quantity
  +deleteName()
}
interface Order {
  +Date address
  #int level
  +saveLevel()
}
class Return {
  +Date id
  #long createdAt
  +setPhone()
  +cancelEmail()
}
interface Category {
  -boolean id
  #double total
  +boolean level
  +Date type
  +calculateCode()
  +createPhone()
  +createTotal()
}
Coupon ..> Order : "1"
Order ..> Wishlist : "*"
Shipment --o Coupon
Return --* Wishlist
@enduml