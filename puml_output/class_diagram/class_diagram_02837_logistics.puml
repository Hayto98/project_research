@startuml
skinparam defaultFontSize 11
abstract class Inventory {
  -int id
  -String address
  -long duration
  #float updatedAt
  +saveUpdatedat()
  +updateName()
  +getCreatedat()
}
class Vehicle {
  -long address
  #long id
  #double price
  #double email
  +findEmail()
  +findDuration()
  +processTotal()
}
class Customer {
  #String description
  +Date quantity
  #Date name
  #float level
  #String total
  +sendType()
  +calculateDuration()
}
class DeliveryNote {
  #double note
  #long id
  +setEmail()
  +deleteEmail()
  +findScore()
}
DeliveryNote ..> Customer : "1"
Customer ..> Vehicle : "1..*"
note right of Inventory : Logistics domain
@enduml