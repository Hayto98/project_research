@startuml
skinparam defaultFontSize 11
abstract class Inventory {
  -int id
  -String address
  -long duration
  #float updatedAt
  +cancelPrice()
  +sendLevel()
  +updateStatus()
}
class Vehicle {
  +Date name
  -long createdAt
  +createDuration()
}
class Customer {
  -Date address
  -float email
  #Date total
  #double type
  +getAmount()
  +updateName()
  +findActive()
  +cancelDuration()
}
class DeliveryNote {
  #String name
  +Date score
  #Date quantity
  #float total
  +getEmail()
}
DeliveryNote --|> Customer
Inventory --o Customer
@enduml