@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Booking {
  +String status
  #float price
  #float score
  -float quantity
  #int email
  +cancelDescription()
  +sendLevel()
}
abstract class Invoice {
  -long phone
  -double quantity
  +cancelNote()
  +sendAmount()
  +getEmail()
}
class Amenity {
  #long duration
  -String price
  -String quantity
  -String amount
  +deleteCreatedat()
  +validateUpdatedat()
}
interface Room {
  +float duration
  +Date address
  -float phone
  +float type
  +getEmail()
}
class Payment {
  -boolean name
  #boolean id
  -String createdAt
  #int amount
  +deleteType()
  +processName()
}
class Restaurant {
  #double code
  +double type
  -String score
  -boolean note
  +updateScore()
  +createUpdatedat()
  +sendActive()
  +setTotal()
}
interface CheckIn {
  +boolean level
  -String address
  +updateType()
  +deleteScore()
}
CheckIn --o Booking
Room ..|> Booking
Room --|> CheckIn
Invoice --o Booking
CheckIn ..|> Amenity
Booking ..> Room : "1"
@enduml