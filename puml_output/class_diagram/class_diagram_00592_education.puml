@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Assignment {
  +Date duration
  +float code
  #int note
  +processStatus()
  +saveDuration()
  +sendLevel()
  +deleteCode()
}
class Exam {
  -String name
  +float type
  +cancelStatus()
}
class Department {
  #float total
  +Date duration
  +int description
  #float address
  +sendUpdatedat()
  +sendPhone()
  +findEmail()
  +createTotal()
}
class Enrollment {
  #String code
  #double level
  #Date id
  +updateCode()
  +saveAddress()
}
class Classroom {
  #Date id
  +boolean active
  -String total
  -int type
  +processQuantity()
  +validateTotal()
  +findCode()
}
Enrollment --* Assignment
Classroom --> Exam : "1..*"
Assignment --> Enrollment : "1..*"
note right of Assignment : Education domain
@enduml