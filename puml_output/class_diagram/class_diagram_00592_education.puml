@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Assignment {
  +Date duration
  +float code
  #int note
  +sendCode()
  +cancelEmail()
  +sendDescription()
  +cancelPrice()
}
interface Exam {
  +boolean code
  -long amount
  +int status
  +getCode()
}
class Department {
  -float phone
  #float total
  +Date level
  +int description
  +cancelAmount()
  +calculateDescription()
  +deleteAddress()
  +getScore()
}
class Enrollment {
  +boolean quantity
  #Date total
  +boolean name
  +Date amount
  +calculateStatus()
  +cancelDuration()
  +sendActive()
  +createNote()
}
class Classroom {
  #long code
  +boolean address
  -double quantity
  +validateLevel()
}
Enrollment --o Assignment
Exam --o Department
Department --o Classroom
Assignment --|> Enrollment
@enduml