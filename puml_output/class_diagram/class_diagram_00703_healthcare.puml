@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Hospital {
  +int code
  +boolean phone
  +setEmail()
  +saveCode()
  +cancelQuantity()
}
interface Diagnosis {
  +double note
  +long quantity
  -float level
  -double status
  +boolean type
  +updateDescription()
  +calculateNote()
  +cancelActive()
}
class Billing {
  -Date id
  -String status
  -Date address
  -long total
  +deleteNote()
}
abstract class Prescription {
  -boolean type
  -float code
  +cancelAmount()
  +createAddress()
  +findScore()
}
class Patient {
  +boolean name
  #boolean score
  +boolean phone
  +float code
  +cancelNote()
  +updateStatus()
  +saveStatus()
}
class Ward {
  #int email
  -Date type
  +processEmail()
  +updateDescription()
  +createId()
}
abstract class Appointment {
  #boolean phone
  #String createdAt
  #float id
  -String status
  #Date code
  +validatePhone()
  +createId()
  +findNote()
}
Appointment ..> Hospital : "*"
Appointment --> Prescription : "*"
Diagnosis ..> Patient : "1"
Ward --|> Diagnosis
Appointment ..|> Diagnosis
Patient --> Appointment : "*"
@enduml