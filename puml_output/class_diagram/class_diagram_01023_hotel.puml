@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Guest {
  +String active
  -Date description
  +long email
  #double price
  +cancelEmail()
  +sendTotal()
  +validateUpdatedat()
  +deleteStatus()
}
class Service {
  #float email
  #String total
  +String note
  +float address
  -String duration
  +sendTotal()
}
class Reservation {
  #boolean total
  +float quantity
  +processDuration()
  +saveStatus()
  +sendAddress()
  +setEmail()
}
class Booking {
  +float active
  #long phone
  +savePhone()
  +setAddress()
}
class CheckIn {
  +long updatedAt
  -Date amount
  +findAddress()
  +getActive()
  +updatePhone()
}
interface Invoice {
  -String active
  -double duration
  -double address
  -String type
  +setQuantity()
  +findPhone()
  +cancelQuantity()
  +saveType()
}
interface Amenity {
  -int address
  #boolean id
  +createEmail()
  +cancelDuration()
  +calculatePrice()
  +processCreatedat()
}
Service --o CheckIn
Booking ..|> Invoice
@enduml