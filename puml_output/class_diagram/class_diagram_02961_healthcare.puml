@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Prescription {
  +boolean quantity
  #int active
  +calculateActive()
}
abstract class Diagnosis {
  +double score
  +String description
  -String quantity
  +validateType()
  +calculateId()
  +processStatus()
}
class LabTest {
  -Date name
  -int quantity
  -float active
  +createTotal()
}
class MedicalRecord {
  +Date total
  -float amount
  #long price
  #String createdAt
  #Date type
  +saveNote()
}
class Hospital {
  +String address
  #float id
  #float createdAt
  +calculateCreatedat()
  +deleteId()
}
class Doctor {
  -String phone
  +String amount
  +double type
  -String duration
  #long score
  +setDuration()
  +validateQuantity()
}
class Insurance {
  +boolean note
  #Date active
  #long total
  +float phone
  +findPhone()
  +updatePrice()
  +saveDescription()
}
Diagnosis --* LabTest
Hospital --> Doctor : "1"
Doctor --|> LabTest
@enduml