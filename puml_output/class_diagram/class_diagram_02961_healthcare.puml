@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Prescription {
  +boolean quantity
  #int active
  +sendNote()
}
class Diagnosis {
  -String level
  +float quantity
  -String updatedAt
  +getPhone()
  +validateUpdatedat()
  +getQuantity()
}
interface LabTest {
  #String address
  -Date amount
  -Date total
  +Date status
  +saveCreatedat()
  +findType()
  +getTotal()
  +findQuantity()
}
class MedicalRecord {
  #int createdAt
  #long code
  +updateUpdatedat()
}
class Hospital {
  -int address
  -long status
  -float price
  +getCreatedat()
  +getCreatedat()
  +calculatePhone()
}
class Doctor {
  -boolean description
  -boolean amount
  -int duration
  #Date quantity
  +deleteEmail()
  +deleteId()
  +findDescription()
}
class Insurance {
  +long quantity
  #String level
  -float status
  -Date phone
  +getDuration()
}
Insurance --|> Hospital
Diagnosis --> MedicalRecord : "1..*"
Doctor ..> Diagnosis : "0..1"
Hospital --* Diagnosis
Insurance ..|> Diagnosis
MedicalRecord --|> LabTest
note right of Prescription : Healthcare domain
@enduml