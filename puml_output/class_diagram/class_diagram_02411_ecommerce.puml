@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Supplier {
  +double name
  -float note
  -Date level
  +savePhone()
}
interface Wishlist {
  +float address
  -long active
  +validatePrice()
  +calculateUpdatedat()
  +findCreatedat()
  +setAddress()
}
class Review {
  +double level
  -String active
  #int address
  #String total
  #int id
  +setDescription()
}
class Product {
  -String phone
  #float updatedAt
  -float amount
  +float email
  #Date note
  +updateUpdatedat()
  +saveAmount()
  +updateId()
  +saveNote()
}
class Cart {
  -long active
  -float address
  +findDuration()
  +getActive()
}
Product --|> Review
Product ..|> Wishlist
@enduml