@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Supplier {
  +double name
  -float note
  -Date level
  +getLevel()
}
class Wishlist {
  -Date active
  #long name
  #long address
  #double email
  +cancelTotal()
  +getId()
  +calculateNote()
}
class Review {
  +String level
  -double name
  -int createdAt
  +createNote()
  +processId()
}
class Product {
  -Date note
  +long status
  +sendAddress()
}
class Cart {
  #double note
  #long amount
  +double active
  +int code
  +deleteDuration()
}
Cart --* Wishlist
Wishlist --> Supplier : "0..1"
Product ..|> Wishlist
note right of Supplier : Ecommerce domain
@enduml