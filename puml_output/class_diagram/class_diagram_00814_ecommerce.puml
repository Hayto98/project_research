@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
interface Customer {
  #String createdAt
  -long total
  +saveNote()
  +findDescription()
  +findActive()
  +deleteAddress()
}
interface Review {
  #long description
  #long amount
  -boolean createdAt
  #float note
  +deleteScore()
  +saveUpdatedat()
}
abstract class Invoice {
  +double note
  #int active
  +validateTotal()
  +validateId()
  +saveEmail()
}
interface Product {
  +double phone
  +Date note
  +processName()
  +deleteCreatedat()
}
class Shipment {
  -boolean id
  #String updatedAt
  #String type
  +cancelDescription()
}
Review ..|> Shipment
Product --|> Customer
@enduml