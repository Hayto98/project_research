@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
interface Customer {
  #String createdAt
  -long total
  +updateDuration()
  +processUpdatedat()
  +cancelEmail()
  +deleteAmount()
}
interface Review {
  #long score
  -boolean note
  #float phone
  +deleteType()
  +cancelStatus()
}
abstract class Invoice {
  +long note
  #String score
  +sendStatus()
}
class Product {
  -long id
  +String note
  +Date amount
  #double description
  -boolean duration
  +sendStatus()
}
class Shipment {
  +double amount
  +String updatedAt
  +calculateDescription()
  +getId()
  +getLevel()
  +cancelEmail()
}
Review --|> Invoice
Customer ..> Product : "1"
Invoice --|> Customer
note right of Customer : Ecommerce domain
@enduml