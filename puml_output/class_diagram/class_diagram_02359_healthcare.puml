@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Doctor {
  #int price
  #double updatedAt
  #String amount
  +String address
  +createCreatedat()
  +deleteId()
  +findAmount()
}
class Prescription {
  #Date address
  -String type
  +Date note
  #long updatedAt
  +String price
  +updateAmount()
}
abstract class LabTest {
  -int updatedAt
  +Date createdAt
  #double address
  +saveAmount()
  +setId()
  +validateDescription()
}
class Insurance {
  #String duration
  -int amount
  #int note
  +float status
  +deletePrice()
  +sendName()
  +updateDescription()
}
class Treatment {
  #double status
  +int score
  +float price
  +cancelAddress()
  +updateAddress()
  +calculateAddress()
  +updatePrice()
}
class Hospital {
  #double score
  -boolean createdAt
  +int active
  #long total
  #Date phone
  +createPrice()
  +createLevel()
  +createTotal()
  +calculateEmail()
}
Insurance --o Prescription
Hospital ..|> Insurance
note right of Doctor : Healthcare domain
@enduml