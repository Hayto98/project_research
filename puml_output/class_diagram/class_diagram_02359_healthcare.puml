@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Doctor {
  #int price
  #double updatedAt
  #String amount
  +String address
  +getNote()
  +sendEmail()
  +createCode()
}
class Prescription {
  -float createdAt
  -int note
  -boolean address
  +calculateId()
  +calculateTotal()
  +cancelNote()
  +saveDescription()
}
class LabTest {
  +Date name
  #int id
  +processPrice()
  +sendNote()
  +processActive()
  +findQuantity()
}
class Insurance {
  #int description
  +String note
  -int address
  +sendAddress()
  +findDescription()
  +processUpdatedat()
}
abstract class Treatment {
  +float id
  #int phone
  +validateDescription()
  +findScore()
}
class Hospital {
  +float score
  +boolean name
  -Date createdAt
  -String description
  +String amount
  +findName()
  +saveCreatedat()
  +updateDescription()
  +calculateCreatedat()
}
LabTest --o Prescription
Doctor --> Insurance : "0..1"
Treatment ..> Insurance : "1..*"
Hospital --* Insurance
Treatment ..|> Doctor
@enduml