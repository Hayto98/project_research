@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Publisher {
  +Date quantity
  +float duration
  +Date id
  +getLevel()
  +saveQuantity()
}
class Book {
  -float active
  +double id
  +deleteNote()
  +findDescription()
}
class Shelf {
  #double id
  -int amount
  +boolean score
  +long code
  +boolean duration
  +deleteType()
}
class Member {
  -long total
  +float description
  +boolean amount
  +setPhone()
  +validateAddress()
  +createEmail()
}
interface Branch {
  +String quantity
  -double createdAt
  +Date score
  -boolean note
  +saveAmount()
  +getType()
  +sendTotal()
  +deleteQuantity()
}
Shelf ..|> Book
Branch --o Publisher
Shelf ..> Publisher : "*"
@enduml