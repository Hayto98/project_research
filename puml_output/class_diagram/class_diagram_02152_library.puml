@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Publisher {
  +Date quantity
  +float duration
  +Date id
  +setDescription()
  +updateName()
}
interface Book {
  -int type
  +boolean description
  +calculateId()
  +deleteScore()
  +sendCode()
}
class Shelf {
  +boolean type
  +Date updatedAt
  +int level
  -Date createdAt
  +Date quantity
  +calculateAddress()
  +getId()
}
interface Member {
  #int duration
  #Date email
  -String phone
  +double quantity
  +setEmail()
  +cancelType()
  +processCode()
  +getStatus()
}
class Branch {
  -Date createdAt
  #String updatedAt
  #double name
  -String total
  +saveType()
  +setUpdatedat()
  +processLevel()
}
Shelf --o Branch
Shelf --> Book : "*"
Book ..> Member : "*"
Member ..|> Book
note right of Publisher : Library domain
@enduml