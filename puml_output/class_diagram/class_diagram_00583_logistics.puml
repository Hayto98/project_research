@startuml
skinparam monochrome true
skinparam shadowing true
class DeliveryNote {
  +Date score
  +float duration
  +long quantity
  +float note
  #long email
  +validateQuantity()
  +sendUpdatedat()
  +updateNote()
}
abstract class Tracking {
  #long note
  -double email
  -boolean quantity
  +createAmount()
}
abstract class Package {
  -long id
  #Date code
  #boolean name
  +getPrice()
}
class FuelLog {
  -long phone
  -boolean quantity
  -long name
  +Date level
  +createActive()
  +setQuantity()
}
abstract class Vehicle {
  -int amount
  +double code
  +findDescription()
}
class Depot {
  +int score
  -double level
  +sendCode()
  +validateTotal()
  +getTotal()
}
class Manifest {
  -long phone
  #float type
  -Date status
  +createNote()
  +updateAddress()
}
Vehicle --o Package
Depot --o Package
Tracking --* Manifest
@enduml