@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
abstract class Librarian {
  +Date quantity
  +double score
  #String note
  #boolean type
  +boolean duration
  +calculateStatus()
  +getAmount()
  +saveLevel()
}
class Book {
  -String total
  #long phone
  #Date id
  +cancelAmount()
  +getId()
  +sendActive()
  +sendLevel()
}
class Author {
  +Date id
  -long type
  #String code
  +createCreatedat()
  +updateAddress()
  +saveNote()
  +setPhone()
}
class Catalog {
  +int type
  +String duration
  -float note
  -Date total
  +updateUpdatedat()
  +validateActive()
  +findScore()
}
abstract class Reservation {
  +float address
  #float amount
  +float level
  -double name
  +setQuantity()
  +createPhone()
}
class Publisher {
  -double updatedAt
  -Date level
  #String score
  +float email
  +saveAddress()
  +cancelQuantity()
}
interface Renewal {
  +long active
  #boolean id
  -String updatedAt
  #String description
  #float status
  +findCreatedat()
}
Renewal --> Reservation : "0..1"
Author ..|> Catalog
Catalog --> Reservation : "1..*"
@enduml