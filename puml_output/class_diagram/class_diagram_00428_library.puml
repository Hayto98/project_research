@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Renewal {
  #float description
  +Date score
  #float address
  +setCode()
  +cancelCode()
}
class Loan {
  #boolean status
  -Date active
  +processAmount()
  +updateName()
  +deleteLevel()
  +sendActive()
}
class Branch {
  +float type
  -double note
  -long duration
  +createAmount()
}
abstract class Publisher {
  +long level
  -int code
  +Date status
  -boolean amount
  +saveCode()
  +saveActive()
  +deleteCode()
}
Branch ..|> Publisher
Branch --> Renewal : "*"
Renewal --|> Branch
@enduml