@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Notification {
  #boolean amount
  -String name
  #long quantity
  +findPhone()
  +getPhone()
}
class Post {
  -float description
  +int email
  +double createdAt
  +createCreatedat()
  +sendDuration()
  +createType()
  +createAmount()
}
abstract class Like {
  -float createdAt
  +String total
  -double score
  -int email
  +cancelName()
  +calculateCode()
  +setAddress()
  +cancelActive()
}
class Profile {
  #long amount
  -float createdAt
  #boolean level
  #long duration
  +setAddress()
}
class Group {
  -Date type
  -String address
  #String id
  -Date status
  +updateEmail()
}
class Album {
  #long description
  -float note
  #double duration
  +createStatus()
  +updateDuration()
  +getEmail()
}
Profile --* Album
Post --o Like
Profile ..> Group : "1..*"
Group --> Like : "1..*"
Album ..|> Notification
@enduml