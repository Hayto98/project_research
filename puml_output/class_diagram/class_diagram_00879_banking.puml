@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Deposit {
  #int total
  #String duration
  #String createdAt
  +createActive()
  +findNote()
}
class Customer {
  -long code
  +int email
  -double updatedAt
  #boolean price
  +calculateEmail()
  +sendAmount()
  +validateTotal()
  +validateTotal()
}
class Beneficiary {
  -Date level
  #boolean duration
  -float amount
  +float total
  -boolean address
  +validateDescription()
  +sendCreatedat()
  +sendDescription()
}
interface Account {
  -long email
  -Date score
  -long level
  #int address
  +sendScore()
  +getPhone()
  +cancelTotal()
  +saveName()
}
abstract class Card {
  +boolean code
  #Date duration
  +long createdAt
  #long score
  #long status
  +findActive()
}
class Statement {
  +boolean code
  -long description
  -double price
  +sendStatus()
}
Statement --|> Deposit
Deposit --o Account
Deposit --> Card : "0..1"
note right of Deposit : Banking domain
@enduml