@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Deposit {
  #int total
  #String duration
  #String createdAt
  +processDescription()
  +createDescription()
}
abstract class Customer {
  -float email
  #int code
  +sendCreatedat()
  +saveScore()
  +deleteAddress()
  +setLevel()
}
abstract class Beneficiary {
  -float duration
  -long note
  -String price
  -boolean email
  #int amount
  +findEmail()
  +createActive()
  +getPhone()
  +updatePhone()
}
interface Account {
  -int updatedAt
  #int type
  #int active
  #Date phone
  +cancelPhone()
  +createStatus()
  +getCreatedat()
}
class Card {
  #int quantity
  -boolean price
  #boolean level
  +long address
  +cancelPrice()
  +saveEmail()
  +deletePhone()
  +findActive()
}
abstract class Statement {
  #int duration
  #int code
  +saveId()
}
Beneficiary --* Card
Statement --|> Beneficiary
@enduml