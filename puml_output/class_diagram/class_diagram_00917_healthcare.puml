@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Doctor {
  +String quantity
  +double updatedAt
  -Date description
  +saveCode()
  +processActive()
  +createDuration()
}
class Hospital {
  +Date total
  #long amount
  +double active
  +updateCode()
  +getActive()
  +createQuantity()
  +setScore()
}
class Diagnosis {
  +int duration
  -String phone
  +float score
  -int amount
  #long updatedAt
  +cancelDuration()
}
interface Billing {
  #int score
  -String amount
  #double code
  +savePrice()
  +setAddress()
  +processCode()
}
class MedicalRecord {
  -double score
  -int createdAt
  +Date active
  -String price
  #double updatedAt
  +validateAmount()
  +calculatePrice()
  +deleteName()
  +calculateAmount()
}
Billing --> Doctor : "0..1"
Hospital --* MedicalRecord
Diagnosis --* MedicalRecord
note right of Doctor : Healthcare domain
@enduml