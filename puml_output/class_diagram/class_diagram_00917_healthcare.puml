@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Doctor {
  +String quantity
  +double updatedAt
  -Date description
  +updatePhone()
  +validatePhone()
  +getId()
}
interface Hospital {
  +boolean duration
  +Date email
  #long updatedAt
  +double total
  +processPrice()
  +cancelStatus()
  +processName()
  +findPrice()
}
class Diagnosis {
  #float code
  #Date score
  #long createdAt
  #float total
  +processPrice()
  +saveAddress()
}
class Billing {
  +boolean id
  #boolean createdAt
  +boolean quantity
  +String amount
  #int address
  +findNote()
  +getAmount()
  +saveName()
  +processStatus()
}
abstract class MedicalRecord {
  +int address
  #Date type
  +calculateTotal()
  +calculatePrice()
  +sendEmail()
  +calculateActive()
}
Hospital --o Diagnosis
Diagnosis ..|> Hospital
Diagnosis --> Doctor : "*"
@enduml