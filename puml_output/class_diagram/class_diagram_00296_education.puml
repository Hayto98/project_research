@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
abstract class Grade {
  #float phone
  #int level
  -float duration
  #int total
  +sendId()
  +deleteLevel()
  +sendId()
}
class Teacher {
  #double status
  +String code
  +sendPrice()
  +calculateStatus()
}
class Course {
  +long status
  #boolean level
  -long address
  #boolean note
  #double description
  +cancelUpdatedat()
}
interface Assignment {
  -float description
  #double level
  #String email
  +getScore()
  +processAddress()
  +findTotal()
}
abstract class Student {
  +boolean score
  +int phone
  +int note
  -long address
  +double quantity
  +validateType()
  +updatePrice()
}
abstract class Library {
  -float email
  -Date status
  +processPhone()
  +updateEmail()
  +processType()
}
class Attendance {
  +long description
  -boolean createdAt
  +calculateUpdatedat()
  +calculateName()
}
Student --* Attendance
Teacher --|> Assignment
Library ..|> Student
note right of Grade : Education domain
@enduml