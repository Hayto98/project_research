@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
abstract class Grade {
  #float phone
  #int level
  -float duration
  #int total
  +saveActive()
  +getPrice()
  +updateDuration()
}
class Teacher {
  +String phone
  #double code
  +calculateId()
}
class Course {
  #boolean price
  -float status
  -boolean name
  +String total
  -float level
  +deleteCode()
  +getUpdatedat()
  +updateCode()
  +updateAddress()
}
interface Assignment {
  #boolean id
  #long level
  -float updatedAt
  #double amount
  #String description
  +deleteTotal()
  +calculateEmail()
  +calculatePrice()
}
abstract class Student {
  #float total
  -long duration
  #Date price
  #long phone
  +processId()
}
class Library {
  -int id
  -int updatedAt
  -double total
  +setCreatedat()
  +sendScore()
}
abstract class Attendance {
  -float email
  -Date status
  +saveAmount()
  +createAmount()
  +deleteAddress()
}
Attendance --o Assignment
Library --|> Grade
Teacher ..|> Attendance
Course --> Attendance : "0..1"
@enduml