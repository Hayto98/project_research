@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class MedicalRecord {
  +long duration
  +float type
  #float name
  +Date code
  #long score
  +findCreatedat()
  +saveScore()
}
class Patient {
  +double createdAt
  #String name
  +processPrice()
  +processPhone()
  +findAmount()
  +processDescription()
}
class LabTest {
  -Date updatedAt
  +double code
  -Date address
  -float description
  +updateScore()
}
class Insurance {
  -int type
  -float note
  -double phone
  +String id
  +int name
  +deleteLevel()
}
interface Diagnosis {
  +float code
  +double active
  -Date type
  +findActive()
  +cancelType()
  +saveScore()
}
class Prescription {
  -float updatedAt
  -Date active
  #Date status
  -int name
  #float code
  +findStatus()
  +validateName()
}
LabTest --* MedicalRecord
MedicalRecord --> Patient : "1"
Insurance --* Diagnosis
Insurance --> Patient : "1..*"
Diagnosis --o LabTest
@enduml