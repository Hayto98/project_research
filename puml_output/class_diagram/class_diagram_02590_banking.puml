@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Loan {
  #boolean description
  #long score
  -Date type
  +boolean active
  +createId()
  +sendNote()
  +cancelScore()
}
abstract class Account {
  +long amount
  +String score
  +String type
  +float price
  +getPrice()
  +sendQuantity()
  +deleteId()
}
class Statement {
  +Date score
  +String type
  +long email
  +int duration
  +float price
  +calculateNote()
  +cancelCreatedat()
  +sendName()
}
interface Teller {
  -double address
  +float price
  #boolean score
  #int total
  -Date phone
  +validateCode()
}
Account --o Loan
Loan ..> Account : "0..1"
@enduml