@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Loan {
  #boolean description
  #long score
  -Date type
  +boolean active
  +updatePrice()
  +findPhone()
  +deleteScore()
}
abstract class Account {
  +float createdAt
  +float phone
  -float status
  #String score
  #double description
  +createEmail()
  +calculateId()
  +findStatus()
  +setDescription()
}
class Statement {
  -int updatedAt
  -double createdAt
  +validatePrice()
  +sendDuration()
  +calculatePhone()
  +processType()
}
class Teller {
  +boolean quantity
  #int name
  +double description
  +validateActive()
}
Account ..|> Statement
note right of Loan : Banking domain
@enduml