@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
interface Comment {
  -Date code
  #long name
  +String description
  +saveDescription()
  +sendName()
  +setLevel()
  +updateCreatedat()
}
abstract class Story {
  -double description
  #long score
  +calculateName()
  +updateType()
  +deleteId()
  +setType()
}
interface User {
  -long description
  #double quantity
  +sendAddress()
  +sendNote()
  +getUpdatedat()
  +setType()
}
class Message {
  -boolean address
  +double email
  -Date level
  +updateEmail()
  +createAddress()
  +sendDescription()
}
Comment --* User
Message --> Story : "1..*"
User --> Message : "1..*"
note right of Comment : Social Media domain
@enduml