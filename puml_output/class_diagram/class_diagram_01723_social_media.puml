@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
interface Comment {
  -Date code
  #long name
  +String description
  +updatePhone()
  +getEmail()
  +createStatus()
  +processQuantity()
}
class Story {
  +Date createdAt
  #long total
  -boolean id
  +sendName()
  +cancelCreatedat()
  +deleteNote()
}
class User {
  +long amount
  -long id
  #double status
  -float type
  #long name
  +setActive()
  +updateActive()
  +createScore()
  +cancelLevel()
}
class Message {
  -boolean name
  +double description
  -Date address
  -int email
  #float active
  +deleteName()
  +sendLevel()
  +setEmail()
}
User ..> Comment : "1..*"
Message --> Story : "1..*"
@enduml