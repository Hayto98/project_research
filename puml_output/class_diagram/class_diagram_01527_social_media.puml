@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
interface Comment {
  #long id
  +String score
  +int type
  +float note
  +deleteAmount()
  +saveAmount()
  +saveAddress()
}
class User {
  -double duration
  #Date phone
  +long updatedAt
  #long type
  -int createdAt
  +processEmail()
  +findUpdatedat()
}
class Like {
  +boolean score
  #double type
  +validateAddress()
  +validatePrice()
  +validateTotal()
}
interface Group {
  +String amount
  #float score
  #Date updatedAt
  -long phone
  -float active
  +findPrice()
  +createUpdatedat()
}
interface Notification {
  -boolean level
  +int duration
  +long address
  -boolean note
  +cancelStatus()
  +findEmail()
}
Group --|> User
Group --o Comment
User --> Comment : "1"
Group ..|> Like
note right of Comment : Social Media domain
@enduml