@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Cart {
  -Date amount
  -Date phone
  +calculateDescription()
  +updateEmail()
}
abstract class Payment {
  -boolean createdAt
  -String email
  +deleteUpdatedat()
  +updatePrice()
}
class Invoice {
  +Date email
  +long duration
  #double createdAt
  +Date address
  +Date type
  +calculateUpdatedat()
  +updateAmount()
  +cancelEmail()
}
class Supplier {
  -boolean status
  -float price
  +Date description
  +double level
  +String note
  +processNote()
  +processDuration()
  +createPrice()
}
class Order {
  -long active
  #Date type
  +getAddress()
  +findPrice()
}
class Return {
  +int status
  -String code
  +calculatePhone()
  +processTotal()
}
interface Review {
  #double active
  +boolean description
  +processDescription()
  +validateName()
  +sendAddress()
}
Review --> Return : "1"
Review ..|> Cart
Supplier ..|> Order
Supplier --o Payment
Payment ..|> Order
Return --* Cart
@enduml