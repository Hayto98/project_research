@startuml
skinparam shadowing true
interface Assignment {
  -String level
  #double score
  #String address
  -long price
  +calculateDescription()
}
interface Attendance {
  +boolean phone
  #boolean type
  -String name
  +Date code
  +findStatus()
  +findAmount()
  +saveQuantity()
  +setDescription()
}
abstract class Teacher {
  #boolean id
  #String score
  +createStatus()
  +setTotal()
  +cancelStatus()
  +calculateEmail()
}
interface Student {
  -String updatedAt
  #Date phone
  #double id
  +calculateActive()
  +sendLevel()
}
Assignment ..> Student : "*"
Teacher ..|> Assignment
@enduml