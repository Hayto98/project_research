@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Product {
  +int duration
  +int id
  +createAddress()
  +findDescription()
  +validateUpdatedat()
  +calculateStatus()
}
class Payment {
  -long price
  +float active
  +double type
  -Date description
  +setActive()
  +findId()
  +setId()
}
interface Customer {
  +String amount
  -String address
  +getDescription()
  +cancelCreatedat()
}
abstract class Return {
  +Date type
  #long price
  +String address
  +calculatePhone()
  +findDescription()
}
Product --* Return
Return --> Product : "1..*"
@enduml