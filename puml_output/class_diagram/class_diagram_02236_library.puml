@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Publisher {
  -int id
  -double address
  #Date type
  +int total
  +String phone
  +createActive()
  +calculateAmount()
  +cancelName()
  +saveLevel()
}
abstract class Fine {
  #Date total
  -String price
  +createCode()
}
interface Shelf {
  +int price
  #long email
  -boolean phone
  +boolean amount
  +findPhone()
}
class Reservation {
  #double amount
  +long status
  +createId()
  +calculateScore()
  +updateLevel()
}
interface Catalog {
  -float level
  #double address
  +setAddress()
  +calculateDescription()
  +processAmount()
}
class Loan {
  -Date duration
  +float createdAt
  +getName()
}
Reservation --> Shelf : "*"
Publisher ..|> Reservation
note right of Publisher : Library domain
@enduml