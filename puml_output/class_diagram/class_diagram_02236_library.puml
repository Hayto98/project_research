@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Publisher {
  -int id
  -double address
  #Date type
  +int total
  +String phone
  +deleteName()
  +createUpdatedat()
  +validateType()
  +createDuration()
}
class Fine {
  #String level
  -double price
  +processCode()
  +cancelEmail()
  +cancelAddress()
}
class Shelf {
  +int price
  #long email
  -boolean phone
  +boolean amount
  +cancelDescription()
}
class Reservation {
  #double code
  +long amount
  #long status
  +updateActive()
  +updateEmail()
  +validateType()
}
interface Catalog {
  #long level
  -float duration
  #double name
  +createAddress()
  +saveCreatedat()
  +saveCode()
}
class Loan {
  #int amount
  #String code
  +String id
  +float createdAt
  -long email
  +getPrice()
  +setUpdatedat()
  +deleteType()
  +processTotal()
}
Shelf --|> Reservation
Publisher --o Reservation
Shelf ..|> Catalog
@enduml