@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
interface Route {
  -float price
  -int level
  +processTotal()
  +calculateTotal()
  +saveType()
}
abstract class Warehouse {
  -float createdAt
  -float note
  -int description
  #long id
  +cancelStatus()
  +deleteAmount()
  +deleteDuration()
}
class DeliveryNote {
  -int email
  #int total
  +saveType()
}
interface Depot {
  -long price
  #long duration
  +cancelCode()
}
class Manifest {
  #long address
  +float status
  +double createdAt
  +processScore()
  +cancelId()
}
class Shipment {
  -int quantity
  +boolean price
  +String score
  +cancelQuantity()
  +cancelCreatedat()
  +saveScore()
}
class Inventory {
  #String code
  #Date updatedAt
  +cancelStatus()
  +setStatus()
}
Shipment --> Manifest : "1..*"
Manifest ..|> Warehouse
Warehouse ..> Manifest : "1..*"
DeliveryNote ..> Manifest : "1"
Inventory ..> Manifest : "1"
@enduml