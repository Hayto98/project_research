@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
interface Route {
  -float price
  -int level
  +processTotal()
  +createCreatedat()
  +processDescription()
}
class Warehouse {
  -String type
  -double note
  #long createdAt
  +long phone
  +calculateAmount()
  +saveCreatedat()
  +saveStatus()
  +cancelName()
}
abstract class DeliveryNote {
  +int quantity
  -String address
  +float email
  #long id
  +float type
  +processDescription()
  +validateEmail()
}
class Depot {
  +boolean price
  +String score
  -double phone
  -long updatedAt
  +getCode()
}
class Manifest {
  +double description
  #boolean code
  +cancelDescription()
  +updateUpdatedat()
  +cancelScore()
}
class Shipment {
  #String active
  -String level
  +float code
  +int duration
  +cancelQuantity()
  +getAmount()
}
abstract class Inventory {
  -int score
  +double total
  -float id
  -boolean phone
  +int amount
  +getAddress()
  +findCreatedat()
  +findTotal()
}
Depot --|> Shipment
Warehouse --> Depot : "*"
Shipment ..|> Warehouse
Shipment --|> Inventory
Manifest ..|> DeliveryNote
note right of Route : Logistics domain
@enduml