@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Reservation {
  +boolean name
  -long status
  +int description
  -long type
  +cancelUpdatedat()
  +updateTotal()
}
interface Staff {
  -boolean active
  -boolean email
  #boolean address
  -long price
  -float code
  +processCreatedat()
  +validateCode()
  +updatePhone()
  +setDescription()
}
class Restaurant {
  -double score
  +boolean amount
  +calculateName()
  +findName()
}
class CheckIn {
  -long price
  -float name
  -float amount
  +int address
  -boolean code
  +setEmail()
}
abstract class Room {
  +String price
  #String updatedAt
  +Date type
  -String status
  -String level
  +createPhone()
  +setEmail()
}
interface CheckOut {
  +boolean address
  #int amount
  +float name
  #long email
  +getName()
  +cancelNote()
  +cancelType()
  +findScore()
}
CheckOut --|> Restaurant
Reservation ..|> CheckOut
Staff --* Restaurant
@enduml