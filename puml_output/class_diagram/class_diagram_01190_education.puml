@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Course {
  -float email
  +Date phone
  +calculateAddress()
}
abstract class Classroom {
  +Date type
  #float quantity
  #float note
  #Date phone
  +saveActive()
}
interface Assignment {
  -int phone
  -int id
  +int total
  -Date active
  +cancelDescription()
  +cancelLevel()
  +sendScore()
  +getId()
}
abstract class Student {
  -float note
  -int level
  #double duration
  -double address
  #double name
  +calculateStatus()
  +calculateCode()
}
class Library {
  #long amount
  +int code
  +updateActive()
  +getName()
}
interface Department {
  +int address
  -String level
  #boolean type
  -int email
  #int score
  +saveEmail()
  +setDuration()
}
Classroom --|> Library
Course --|> Library
Assignment --> Library : "0..1"
@enduml