@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Course {
  -float email
  +Date phone
  +deleteType()
}
interface Classroom {
  +Date type
  #float quantity
  #float note
  #Date phone
  +sendLevel()
}
class Assignment {
  +long id
  +int total
  +double active
  #boolean price
  +findPrice()
  +processNote()
  +calculateNote()
  +cancelNote()
}
class Student {
  +Date email
  -double quantity
  +cancelNote()
  +deletePrice()
  +createLevel()
  +setAmount()
}
class Library {
  #double status
  -boolean createdAt
  -float level
  #long id
  +getCreatedat()
  +createCode()
  +cancelLevel()
  +calculateUpdatedat()
}
interface Department {
  +Date description
  #float name
  +float email
  +findScore()
  +setDuration()
}
Assignment --> Library : "0..1"
note right of Course : Education domain
@enduml