@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
abstract class Reservation {
  -boolean type
  +boolean description
  -float duration
  +double address
  +Date score
  +getDuration()
  +processStatus()
  +saveType()
}
class Author {
  #long type
  -int price
  +calculateScore()
  +sendScore()
}
interface Publisher {
  +String createdAt
  +float phone
  +getPrice()
  +calculateDescription()
  +deleteActive()
  +cancelUpdatedat()
}
interface Member {
  -int price
  -double updatedAt
  -boolean phone
  +sendCreatedat()
  +cancelTotal()
  +deleteAddress()
}
class Librarian {
  +Date amount
  #Date phone
  -Date level
  -double score
  +calculateCreatedat()
}
abstract class Shelf {
  -float quantity
  #boolean phone
  -double updatedAt
  #long active
  +calculateLevel()
}
Publisher --o Reservation
Shelf ..|> Librarian
Member --|> Reservation
note right of Reservation : Library domain
@enduml