@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
abstract class Reservation {
  -boolean type
  +boolean description
  -float duration
  +double address
  +Date score
  +savePhone()
  +getActive()
  +deleteDescription()
}
abstract class Author {
  +double type
  -boolean quantity
  +updateEmail()
  +processPrice()
  +validateType()
}
class Publisher {
  +Date score
  -int duration
  +int level
  -String active
  -double name
  +updateCreatedat()
  +findPhone()
}
interface Member {
  #float level
  #int amount
  -long price
  +createActive()
  +validateUpdatedat()
}
class Librarian {
  -String active
  -int createdAt
  #long total
  -long amount
  +updateId()
  +setPrice()
}
class Shelf {
  #long type
  -long name
  +boolean total
  -float createdAt
  #boolean score
  +sendName()
  +getAmount()
  +updateLevel()
}
Member ..|> Librarian
Publisher --o Reservation
@enduml