@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Cart {
  -Date createdAt
  +boolean note
  -double score
  +calculateLevel()
  +getStatus()
  +processDescription()
}
class Invoice {
  #long code
  #boolean duration
  +saveTotal()
  +deleteQuantity()
  +sendStatus()
  +findScore()
}
interface Review {
  +float name
  -double level
  #long id
  -int address
  -Date phone
  +cancelLevel()
  +processType()
}
interface Order {
  +long updatedAt
  #String status
  #double note
  +saveName()
  +validatePrice()
  +saveUpdatedat()
  +sendName()
}
class Product {
  #String address
  -String duration
  +sendPhone()
  +saveUpdatedat()
  +setQuantity()
  +sendUpdatedat()
}
Product ..|> Review
Invoice ..> Product : "1..*"
@enduml