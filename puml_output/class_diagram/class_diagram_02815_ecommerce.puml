@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Cart {
  -Date createdAt
  +boolean note
  -double score
  +createAmount()
  +setCode()
  +setEmail()
}
interface Invoice {
  #String status
  #long quantity
  -String active
  -double note
  #long name
  +deletePrice()
  +saveCreatedat()
  +calculateLevel()
  +updateUpdatedat()
}
class Review {
  -Date amount
  #double email
  +float id
  #float total
  +long note
  +findId()
  +calculateName()
  +sendDuration()
}
abstract class Order {
  +Date createdAt
  #Date score
  +Date email
  -float description
  +saveAddress()
  +calculatePrice()
  +savePhone()
}
interface Product {
  +float type
  +Date amount
  #long duration
  +sendActive()
  +updateCode()
  +createPhone()
  +deleteTotal()
}
Review --* Product
Cart --|> Order
Order --|> Review
note right of Cart : Ecommerce domain
@enduml