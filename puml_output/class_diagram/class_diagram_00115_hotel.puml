@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
abstract class Reservation {
  #double duration
  +boolean name
  +setPhone()
  +createPhone()
  +calculateCode()
}
abstract class Restaurant {
  -double description
  -String note
  +String score
  +validateActive()
}
class Amenity {
  #float phone
  -double quantity
  -Date active
  +sendAmount()
  +findAmount()
  +deleteEmail()
  +cancelPhone()
}
class Payment {
  #double duration
  #String address
  +boolean status
  #int name
  +calculateType()
  +saveName()
}
abstract class Guest {
  #double updatedAt
  #double name
  +int id
  +updateId()
  +setPhone()
  +processLevel()
}
Payment ..|> Restaurant
Reservation --* Guest
Amenity --> Guest : "*"
@enduml