@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Card {
  #Date note
  -double amount
  -boolean type
  +String price
  #float status
  +processNote()
  +setScore()
}
class Loan {
  +Date updatedAt
  -boolean phone
  +setUpdatedat()
  +cancelCreatedat()
  +saveDescription()
  +validateName()
}
class Account {
  #float updatedAt
  -int type
  +savePhone()
  +sendUpdatedat()
  +validateAmount()
}
class Transaction {
  +long address
  #boolean createdAt
  -double description
  #float duration
  +sendTotal()
  +sendDuration()
}
Account ..> Loan : "*"
Transaction --o Account
Transaction --> Card : "*"
note right of Card : Banking domain
@enduml