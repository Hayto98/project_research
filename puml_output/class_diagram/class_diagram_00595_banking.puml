@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Card {
  #Date note
  -double amount
  -boolean type
  +String price
  #float status
  +cancelQuantity()
  +processTotal()
}
class Loan {
  #double name
  #double updatedAt
  +int phone
  #Date amount
  +validateStatus()
  +cancelPrice()
}
class Account {
  #double name
  #float amount
  -int id
  -Date updatedAt
  +updateNote()
  +processPrice()
  +calculateCreatedat()
}
class Transaction {
  +float duration
  #float phone
  +long address
  +deleteName()
  +cancelScore()
}
Transaction ..|> Account
Account --* Transaction
@enduml