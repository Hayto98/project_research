@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Loan {
  -Date code
  +long type
  -String description
  +cancelName()
}
class Customer {
  +boolean amount
  +boolean duration
  -double email
  +setPrice()
  +deleteUpdatedat()
  +createUpdatedat()
  +processAddress()
}
abstract class Interest {
  +long phone
  #double updatedAt
  +float quantity
  +setLevel()
  +cancelPhone()
  +saveDescription()
}
abstract class Branch {
  #float price
  -float updatedAt
  +deleteScore()
}
Interest --o Loan
Customer --> Branch : "1..*"
Interest --* Customer
note right of Loan : Banking domain
@enduml