@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Loan {
  -Date code
  +long type
  -String description
  +processPhone()
}
interface Customer {
  +int updatedAt
  -int amount
  +findName()
  +sendPhone()
}
abstract class Interest {
  +double status
  -float price
  #float amount
  -int updatedAt
  -float quantity
  +getNote()
  +createPhone()
}
class Branch {
  -boolean amount
  +float email
  -int code
  #float phone
  -float description
  +createCreatedat()
}
Interest --o Loan
Customer --> Branch : "1..*"
Interest --* Customer
@enduml