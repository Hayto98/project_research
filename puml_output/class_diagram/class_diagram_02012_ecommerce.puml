@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Return {
  +double status
  +boolean createdAt
  +validatePrice()
}
class Coupon {
  #Date duration
  +String price
  #double address
  -long score
  +sendScore()
  +validateEmail()
  +saveNote()
  +deleteTotal()
}
class Invoice {
  #String status
  -Date description
  +createPrice()
  +createDescription()
}
interface Order {
  #float type
  #boolean level
  #Date active
  +setStatus()
}
class Review {
  -Date level
  #int email
  +boolean duration
  +Date updatedAt
  #long total
  +updateDescription()
  +sendTotal()
  +calculateType()
  +deleteAddress()
}
interface Payment {
  +boolean duration
  #double phone
  +updateName()
}
Review ..|> Coupon
Invoice ..|> Review
Order --> Review : "*"
@enduml