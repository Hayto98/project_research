@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Notification {
  #long active
  +String email
  -long code
  +double phone
  +cancelId()
  +validatePhone()
  +setDescription()
}
interface Group {
  -String score
  +long status
  +setEmail()
}
abstract class Message {
  #float name
  #double email
  -double level
  -double duration
  +sendPrice()
  +sendAmount()
  +processUpdatedat()
}
interface Report {
  -float createdAt
  -float type
  +validateActive()
  +deleteAmount()
  +getUpdatedat()
  +createEmail()
}
abstract class Story {
  -int address
  #double duration
  -double score
  #String active
  +updateAmount()
  +deleteActive()
  +createUpdatedat()
  +saveNote()
}
abstract class Profile {
  #boolean address
  -boolean quantity
  #long description
  +float total
  +sendId()
}
Message --o Story
Profile --* Message
Notification --> Message : "1..*"
@enduml