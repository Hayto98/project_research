@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
abstract class Package {
  +float duration
  -long address
  -int email
  -float description
  +createName()
  +deleteCode()
}
class Driver {
  +long total
  +float score
  +float code
  +saveTotal()
  +calculateLevel()
  +cancelAmount()
  +createAmount()
}
interface Tracking {
  -String address
  -long level
  +findActive()
  +updateUpdatedat()
}
class Route {
  -Date id
  #long description
  -long email
  #float total
  -Date note
  +cancelDescription()
  +calculateCreatedat()
  +processEmail()
  +sendPhone()
}
abstract class Depot {
  -Date quantity
  -String duration
  +Date createdAt
  +double level
  #int description
  +processUpdatedat()
  +cancelCode()
  +sendPrice()
  +setCode()
}
Depot --> Route : "1"
Driver --* Route
Route --o Package
@enduml