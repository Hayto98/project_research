@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
abstract class Package {
  +float duration
  -long address
  -int email
  -float description
  +processPhone()
  +setAmount()
}
abstract class Driver {
  +float description
  +float quantity
  +sendPhone()
  +sendCode()
  +validateLevel()
  +processName()
}
abstract class Tracking {
  #Date updatedAt
  #Date type
  #double status
  #float quantity
  +deleteEmail()
}
abstract class Route {
  #float total
  -Date score
  -Date address
  -boolean type
  -Date email
  +processQuantity()
  +createCreatedat()
  +cancelQuantity()
  +saveDescription()
}
abstract class Depot {
  -int name
  -Date status
  #long updatedAt
  #boolean note
  #double description
  +updateTotal()
}
Route --o Package
Driver --> Package : "1..*"
Package ..> Depot : "0..1"
note right of Package : Logistics domain
@enduml