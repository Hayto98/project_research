@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Customer {
  +Date amount
  -String price
  +saveDescription()
}
abstract class Product {
  +Date active
  #long duration
  -boolean note
  +sendActive()
  +calculateStatus()
}
abstract class Cart {
  #float status
  -boolean type
  #int createdAt
  +validateEmail()
  +deleteStatus()
  +cancelCode()
  +validateTotal()
}
class Category {
  -int active
  +float createdAt
  +setCreatedat()
}
class Supplier {
  #Date status
  -double note
  +long active
  #int price
  +getId()
  +validateType()
  +deleteActive()
}
class Review {
  +boolean duration
  -String quantity
  -Date status
  -double price
  +deleteScore()
  +sendNote()
  +setType()
}
Cart --* Customer
Cart --> Supplier : "*"
Supplier --|> Product
@enduml