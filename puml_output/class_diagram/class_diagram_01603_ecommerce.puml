@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Customer {
  +Date amount
  -String price
  +findNote()
}
interface Product {
  +Date active
  #long duration
  -boolean note
  +cancelTotal()
  +deleteStatus()
}
abstract class Cart {
  #double level
  +Date type
  -Date updatedAt
  +saveDuration()
  +setActive()
}
class Category {
  #long description
  -String amount
  -boolean active
  -float id
  +processCreatedat()
  +validateAmount()
  +findQuantity()
  +processType()
}
class Supplier {
  +boolean duration
  -String quantity
  -Date status
  -double price
  +deleteUpdatedat()
  +deleteAmount()
  +createId()
}
class Review {
  +float active
  +float duration
  +String total
  +String createdAt
  +findType()
  +sendActive()
}
Category --* Product
Review --* Customer
Review --* Supplier
note right of Customer : Ecommerce domain
@enduml