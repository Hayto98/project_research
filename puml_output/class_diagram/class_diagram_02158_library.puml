@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Member {
  +boolean price
  -boolean total
  +saveDescription()
  +sendType()
  +updatePrice()
}
abstract class Loan {
  +Date address
  -Date description
  +String score
  +boolean updatedAt
  -float amount
  +createTotal()
}
interface Branch {
  -double active
  -long updatedAt
  -Date status
  +String id
  +sendNote()
  +cancelAmount()
  +validateDescription()
  +calculateAmount()
}
class Fine {
  +int type
  +int level
  -boolean updatedAt
  +validateDuration()
  +findCode()
  +sendScore()
  +cancelActive()
}
class Shelf {
  -float description
  -int code
  +float createdAt
  +Date note
  #double updatedAt
  +createPhone()
  +saveScore()
  +getCode()
  +calculateEmail()
}
class Catalog {
  +long code
  #int email
  #double description
  +updateActive()
  +calculateNote()
  +processPrice()
}
class Renewal {
  -String email
  +long amount
  #float updatedAt
  +createStatus()
  +processPhone()
}
Shelf --o Loan
Member --o Branch
Shelf --|> Renewal
Catalog ..> Shelf : "*"
@enduml