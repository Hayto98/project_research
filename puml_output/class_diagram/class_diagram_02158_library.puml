@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Member {
  +boolean price
  -boolean total
  +findId()
  +calculateNote()
  +validateDescription()
}
interface Loan {
  #String amount
  +int id
  #float address
  +sendId()
  +findActive()
  +createActive()
}
class Branch {
  -long id
  -double phone
  +setScore()
}
abstract class Fine {
  +float score
  -float note
  #int updatedAt
  +updateName()
}
class Shelf {
  -double active
  #String level
  -Date total
  +String address
  +processUpdatedat()
  +createPhone()
}
class Catalog {
  -double updatedAt
  +long level
  +updateUpdatedat()
}
class Renewal {
  #double description
  -String createdAt
  +int quantity
  +Date amount
  +createAmount()
  +updateNote()
}
Member --> Branch : "0..1"
Shelf --> Branch : "0..1"
note right of Member : Library domain
@enduml