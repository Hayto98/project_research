@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
abstract class Publisher {
  #long score
  #long phone
  #float price
  #int level
  +getCode()
  +cancelTotal()
  +cancelAddress()
  +savePrice()
}
interface Branch {
  -Date updatedAt
  +boolean active
  #int phone
  +float email
  +validateCode()
  +validatePhone()
  +findStatus()
  +findId()
}
abstract class Fine {
  -String score
  +double description
  +validateType()
  +cancelTotal()
  +saveLevel()
}
class Book {
  +boolean amount
  #double active
  +String level
  +long total
  #Date address
  +validatePrice()
  +sendCreatedat()
}
class Catalog {
  -String code
  +int level
  +processType()
  +updateNote()
  +setDuration()
  +saveDuration()
}
abstract class Librarian {
  #String total
  -long amount
  -String status
  +cancelAmount()
  +deletePhone()
}
class Shelf {
  -float price
  #int total
  +saveLevel()
  +sendQuantity()
  +calculateCreatedat()
  +validateCode()
}
Shelf --|> Branch
Shelf --> Book : "1"
Shelf ..> Fine : "1..*"
Shelf --o Publisher
Branch ..> Publisher : "1..*"
Publisher ..|> Shelf
@enduml