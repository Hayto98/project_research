@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
abstract class Publisher {
  #long score
  #long phone
  #float price
  #int level
  +cancelId()
  +createLevel()
  +sendAddress()
  +saveUpdatedat()
}
interface Branch {
  +String email
  #double total
  +String id
  #int active
  +setScore()
  +deleteAddress()
  +setName()
  +calculatePhone()
}
class Fine {
  #Date note
  #Date amount
  +validateAmount()
  +cancelScore()
  +calculateDescription()
  +setCreatedat()
}
class Book {
  +boolean type
  -String id
  +int name
  +calculateActive()
  +cancelPrice()
  +updateTotal()
  +findAmount()
}
class Catalog {
  -String address
  +boolean quantity
  +sendStatus()
}
abstract class Librarian {
  +float quantity
  #float amount
  +String note
  -boolean active
  +float address
  +saveEmail()
  +getNote()
  +updateName()
}
class Shelf {
  +long status
  -String description
  +processActive()
  +processLevel()
  +deleteActive()
}
Branch --|> Librarian
Publisher --* Fine
note right of Publisher : Library domain
@enduml