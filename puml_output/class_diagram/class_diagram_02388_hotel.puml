@startuml
skinparam defaultFontSize 11
class Housekeeping {
  #boolean note
  #boolean phone
  +updateQuantity()
  +processStatus()
  +sendDescription()
}
abstract class Guest {
  +boolean type
  -long phone
  #int note
  -double name
  +validateAmount()
  +cancelScore()
}
abstract class Reservation {
  +boolean updatedAt
  #float level
  +double name
  #double amount
  +double quantity
  +saveEmail()
}
class Booking {
  +float score
  -String amount
  +long id
  -float total
  +validateNote()
  +sendUpdatedat()
  +getDuration()
}
class Amenity {
  #Date id
  +boolean total
  +float level
  +processCreatedat()
  +updateDescription()
  +deleteAddress()
}
class Room {
  +Date status
  +String code
  #String address
  -String name
  +String note
  +updateAmount()
  +setName()
  +sendTotal()
  +cancelType()
}
class CheckOut {
  +long note
  +Date type
  +updateTotal()
  +calculateLevel()
}
Housekeeping ..|> Amenity
Amenity --* Guest
Booking --* Reservation
Guest ..> Amenity : "*"
@enduml