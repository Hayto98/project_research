@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Appointment {
  -int type
  +int amount
  +Date note
  #long createdAt
  +saveUpdatedat()
}
class Patient {
  -Date amount
  #Date email
  -float level
  #double updatedAt
  #float id
  +sendStatus()
}
class Prescription {
  #boolean quantity
  #int email
  -double address
  #boolean description
  +deleteUpdatedat()
  +deleteDuration()
  +updatePhone()
  +cancelPhone()
}
class MedicalRecord {
  +int code
  +int id
  -Date status
  +findQuantity()
  +saveStatus()
  +validateCreatedat()
  +findType()
}
interface Hospital {
  #long total
  +double price
  +setNote()
  +getType()
  +deleteName()
  +updateEmail()
}
Patient --o Hospital
Hospital --|> Appointment
Prescription --o Appointment
Hospital ..|> MedicalRecord
@enduml