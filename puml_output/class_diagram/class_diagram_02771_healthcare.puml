@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Doctor {
  -int amount
  +Date note
  -String duration
  #double score
  #double code
  +setPhone()
  +saveType()
  +deleteName()
  +savePhone()
}
abstract class Nurse {
  +Date type
  +String code
  +int createdAt
  +updateQuantity()
  +processDuration()
}
abstract class Hospital {
  #long note
  +long phone
  #double status
  #Date type
  -double name
  +deletePhone()
  +updateUpdatedat()
  +processName()
}
interface LabTest {
  #Date createdAt
  -float total
  +Date description
  -String id
  #int phone
  +deleteAmount()
  +findStatus()
}
abstract class Appointment {
  +float name
  -Date updatedAt
  #float price
  #String createdAt
  #float amount
  +sendDuration()
  +saveScore()
  +calculateType()
}
abstract class Billing {
  +float address
  #int price
  +processId()
}
Billing ..|> Hospital
Doctor ..|> LabTest
Hospital --|> Doctor
LabTest ..|> Billing
note right of Doctor : Healthcare domain
@enduml