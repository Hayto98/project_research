@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Doctor {
  -int amount
  +Date note
  -String duration
  #double score
  #double code
  +saveStatus()
  +cancelEmail()
  +cancelId()
  +setScore()
}
abstract class Nurse {
  +double name
  +int phone
  +Date total
  +processName()
}
class Hospital {
  -boolean createdAt
  #double duration
  -Date quantity
  +saveScore()
  +sendType()
  +createNote()
  +updateUpdatedat()
}
abstract class LabTest {
  +long level
  #double address
  +getAddress()
  +createId()
  +setEmail()
  +validateType()
}
class Appointment {
  #float updatedAt
  -float duration
  +Date type
  #float name
  +setLevel()
  +setActive()
  +processName()
  +deleteCode()
}
abstract class Billing {
  #int price
  #float code
  +saveAddress()
  +deleteScore()
}
LabTest --|> Billing
Nurse ..> LabTest : "0..1"
@enduml