@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
interface Restaurant {
  -int amount
  +String duration
  +saveActive()
  +deleteActive()
}
class Reservation {
  +String total
  -long address
  -double id
  #String createdAt
  +validateStatus()
  +updateStatus()
}
class Room {
  +String createdAt
  -int note
  +createDuration()
  +cancelPrice()
  +processAddress()
  +saveCode()
}
abstract class Amenity {
  -float updatedAt
  #float price
  -long amount
  -int score
  +cancelStatus()
  +deleteQuantity()
  +setNote()
}
interface Housekeeping {
  -Date name
  +String duration
  #int code
  +processAmount()
  +setEmail()
  +updateCode()
  +setUpdatedat()
}
Housekeeping --> Restaurant : "0..1"
Amenity --|> Restaurant
Restaurant --o Reservation
Room --|> Restaurant
@enduml