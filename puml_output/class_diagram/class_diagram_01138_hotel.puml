@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
interface Restaurant {
  -int amount
  +String duration
  +sendType()
  +deleteAddress()
}
abstract class Reservation {
  -long id
  -double createdAt
  #String code
  +float status
  +setName()
  +updateNote()
}
class Room {
  -double address
  #float updatedAt
  +saveNote()
  +validateUpdatedat()
  +findPrice()
  +deleteAmount()
}
abstract class Amenity {
  +double quantity
  #boolean phone
  +String createdAt
  +String duration
  -Date code
  +setDuration()
  +updatePrice()
}
class Housekeeping {
  #boolean name
  +Date score
  #double active
  #boolean id
  +setStatus()
}
Reservation --* Amenity
Restaurant --|> Housekeeping
Amenity --o Room
note right of Restaurant : Hotel domain
@enduml