@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
abstract class Customer {
  +long type
  -String updatedAt
  #float id
  -double score
  #double description
  +sendPhone()
}
abstract class DeliveryNote {
  +String email
  #double price
  +Date total
  +String duration
  -String phone
  +deletePrice()
  +findCode()
  +validateScore()
}
abstract class Depot {
  +boolean description
  -boolean id
  +updateLevel()
  +calculateScore()
  +findEmail()
}
abstract class Driver {
  #int createdAt
  -double status
  +float id
  #float updatedAt
  +setDuration()
}
Depot --|> Driver
Driver --|> Depot
note right of Customer : Logistics domain
@enduml