@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
abstract class Customer {
  +long type
  -String updatedAt
  #float id
  -double score
  #double description
  +calculateActive()
}
class DeliveryNote {
  -int note
  +boolean email
  -int price
  #String total
  +long level
  +deleteCreatedat()
}
class Depot {
  #float code
  +Date address
  +String score
  #float price
  -boolean id
  +sendNote()
  +cancelActive()
  +createDuration()
}
interface Driver {
  #boolean type
  +int phone
  #int createdAt
  -double status
  +updateCreatedat()
}
Customer ..> Depot : "0..1"
Depot --|> Driver
@enduml