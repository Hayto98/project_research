@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
abstract class Like {
  #float note
  #boolean total
  #double description
  -long amount
  +String duration
  +updateUpdatedat()
  +createCreatedat()
  +updateTotal()
}
class Report {
  #float duration
  +long createdAt
  +deleteLevel()
  +createStatus()
  +deleteId()
}
abstract class Post {
  #String duration
  +boolean phone
  -int status
  +long price
  +float updatedAt
  +cancelUpdatedat()
  +createAmount()
  +calculateCreatedat()
  +createTotal()
}
interface Follower {
  #long name
  +double total
  -Date note
  #long address
  #float amount
  +setId()
  +savePhone()
  +setCode()
}
abstract class Group {
  #long code
  -String price
  #String name
  +setScore()
  +sendLevel()
  +sendActive()
}
Like --> Group : "1..*"
Like ..> Post : "*"
Report ..|> Group
Group ..|> Like
@enduml