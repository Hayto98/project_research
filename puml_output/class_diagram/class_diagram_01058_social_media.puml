@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
abstract class Like {
  #float note
  #boolean total
  #double description
  -long amount
  +String duration
  +setDescription()
  +validateCreatedat()
  +setDuration()
}
class Report {
  #double phone
  -boolean email
  +setPrice()
  +updateId()
  +updateScore()
}
class Post {
  -Date description
  -long phone
  #boolean status
  +getTotal()
  +processAddress()
  +deleteEmail()
  +deletePrice()
}
abstract class Follower {
  +double phone
  +float name
  #long total
  -String description
  +createDuration()
}
interface Group {
  #boolean name
  -String active
  +saveNote()
  +saveUpdatedat()
  +deleteCreatedat()
}
Like --o Report
Post --o Follower
Follower --o Like
note right of Like : Social Media domain
@enduml