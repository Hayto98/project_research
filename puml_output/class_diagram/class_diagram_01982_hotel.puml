@startuml
skinparam defaultFontSize 13
class Restaurant {
  #float total
  #long createdAt
  +Date active
  +processDescription()
  +deleteQuantity()
  +createActive()
  +createStatus()
}
class Guest {
  -double active
  -long address
  #long updatedAt
  +createPhone()
}
class Invoice {
  -String id
  -String name
  #float total
  +Date amount
  +boolean type
  +sendQuantity()
  +updateQuantity()
  +updatePrice()
}
interface Housekeeping {
  +float name
  +Date address
  +String status
  +setEmail()
  +deleteCode()
  +sendDuration()
  +sendAmount()
}
Invoice ..> Restaurant : "1..*"
Guest --o Housekeeping
note right of Restaurant : Hotel domain
@enduml