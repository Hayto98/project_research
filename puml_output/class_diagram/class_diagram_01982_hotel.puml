@startuml
skinparam defaultFontSize 13
class Restaurant {
  #float total
  #long createdAt
  +Date active
  +getStatus()
  +validateName()
  +saveStatus()
  +saveType()
}
class Guest {
  -String quantity
  +int email
  #Date active
  +getCode()
  +cancelDuration()
  +saveType()
}
class Invoice {
  -long note
  +double price
  +String address
  -int score
  #double name
  +getLevel()
  +validateDuration()
  +updateDuration()
  +getActive()
}
class Housekeeping {
  #long duration
  +long address
  +deleteAmount()
  +sendAmount()
}
Restaurant --* Invoice
Restaurant --|> Housekeeping
@enduml