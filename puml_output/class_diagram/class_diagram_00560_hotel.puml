@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Staff {
  #boolean level
  #String price
  +String updatedAt
  +int note
  +calculateId()
  +deletePhone()
  +createPrice()
  +findDescription()
}
interface Amenity {
  +boolean total
  +Date price
  -int email
  -double duration
  +getAmount()
  +cancelUpdatedat()
  +validateQuantity()
  +deleteEmail()
}
interface Guest {
  #Date price
  +boolean description
  +processType()
}
interface Restaurant {
  #String updatedAt
  #float type
  +findPhone()
}
interface Housekeeping {
  #long description
  #float id
  #boolean amount
  +Date level
  +float duration
  +getStatus()
  +processCreatedat()
  +updateQuantity()
}
class Room {
  #boolean level
  +boolean code
  +findCreatedat()
  +sendDescription()
  +createDescription()
}
Guest --> Housekeeping : "*"
Restaurant ..> Housekeeping : "*"
@enduml