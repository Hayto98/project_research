@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Staff {
  #boolean level
  #String price
  +String updatedAt
  +int note
  +getPrice()
  +cancelScore()
  +createTotal()
  +calculateEmail()
}
abstract class Amenity {
  #long level
  +double description
  +processAmount()
  +cancelCode()
  +calculateDescription()
  +findUpdatedat()
}
interface Guest {
  +float price
  +double score
  +saveCode()
}
class Restaurant {
  #long description
  #float id
  #boolean amount
  +Date level
  +float duration
  +saveName()
  +findStatus()
  +cancelCode()
}
interface Housekeeping {
  #float duration
  +long quantity
  #float email
  +processDuration()
  +saveNote()
  +updateUpdatedat()
  +createQuantity()
}
class Room {
  #int phone
  -Date name
  +findDuration()
}
Room ..|> Restaurant
note right of Staff : Hotel domain
@enduml