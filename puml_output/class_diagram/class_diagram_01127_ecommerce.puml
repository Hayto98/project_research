@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Order {
  #String email
  -String address
  #Date score
  +String phone
  +updateAmount()
}
class Warehouse {
  #String price
  +float level
  #long duration
  #int total
  +cancelPrice()
  +processDuration()
  +setType()
  +findStatus()
}
abstract class Invoice {
  +double id
  -double active
  +boolean total
  #Date score
  -double level
  +createName()
  +validateId()
  +validateStatus()
}
interface Wishlist {
  -int updatedAt
  +int amount
  +String phone
  +sendName()
}
class Customer {
  -boolean code
  #long updatedAt
  +setDuration()
}
interface Shipment {
  #Date type
  -float description
  -boolean name
  #String active
  +updateDuration()
}
interface Review {
  +Date score
  +int name
  +int note
  +Date createdAt
  +findId()
  +validateUpdatedat()
  +deleteAddress()
}
Invoice ..> Warehouse : "0..1"
Invoice ..> Review : "1..*"
Customer --|> Shipment
Warehouse --|> Order
@enduml