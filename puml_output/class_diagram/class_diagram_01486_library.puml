@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
abstract class Publisher {
  -Date level
  +float code
  #int status
  #Date total
  -int id
  +deleteDuration()
}
abstract class Fine {
  -double type
  #boolean phone
  +deleteEmail()
  +saveNote()
  +validateType()
  +getPhone()
}
abstract class Catalog {
  +double email
  #boolean duration
  +getId()
  +sendPhone()
}
interface Book {
  #long id
  +Date phone
  +cancelCreatedat()
  +processAmount()
  +setAmount()
  +createNote()
}
class Member {
  #int active
  +Date type
  -String phone
  #String id
  #double level
  +findTotal()
}
interface Loan {
  #boolean active
  -double email
  +long quantity
  +float total
  +getScore()
  +calculateDuration()
  +findStatus()
}
Catalog --* Fine
Book --> Fine : "0..1"
Member --> Publisher : "0..1"
Catalog --o Book
Loan ..|> Book
@enduml