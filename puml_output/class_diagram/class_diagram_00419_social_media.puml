@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Notification {
  #float quantity
  #long price
  #Date amount
  +Date status
  -double updatedAt
  +cancelLevel()
}
class Report {
  +float name
  +double score
  -long price
  +double id
  +calculateQuantity()
  +validateStatus()
  +setDescription()
}
abstract class Story {
  +Date createdAt
  -int phone
  +boolean active
  +getLevel()
  +saveDuration()
  +updateId()
  +findTotal()
}
class Comment {
  +int updatedAt
  -float phone
  +int createdAt
  -long active
  -float price
  +findAmount()
  +saveAmount()
  +validateDescription()
}
class Hashtag {
  -int createdAt
  #long status
  +sendName()
  +saveActive()
  +findCode()
  +validateQuantity()
}
Report --> Hashtag : "0..1"
Hashtag ..|> Story
note right of Notification : Social Media domain
@enduml