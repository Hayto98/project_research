@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Notification {
  #float quantity
  #long price
  #Date amount
  +Date status
  -double updatedAt
  +setId()
}
interface Report {
  +String quantity
  +double name
  -long score
  +double price
  +findEmail()
  +updateEmail()
  +cancelAddress()
}
class Story {
  -int status
  +long description
  +deleteType()
  +sendType()
}
class Comment {
  +boolean createdAt
  #boolean level
  +String total
  +sendDuration()
  +cancelStatus()
  +findActive()
  +findAddress()
}
class Hashtag {
  +long active
  +int price
  -long description
  +validateDescription()
  +validateAmount()
  +validateTotal()
  +processUpdatedat()
}
Report ..|> Story
Story ..> Notification : "0..1"
Notification ..|> Story
Story --> Comment : "1"
@enduml