@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Member {
  #float createdAt
  -Date updatedAt
  +validateNote()
  +calculateLevel()
  +deleteStatus()
  +calculateNote()
}
class Fine {
  #String level
  #double type
  #int code
  -long name
  +validateStatus()
  +saveUpdatedat()
}
class Librarian {
  -long id
  +String address
  +createScore()
  +findCreatedat()
}
class Renewal {
  #int createdAt
  #long type
  -int updatedAt
  +double email
  +long score
  +sendQuantity()
  +processPhone()
  +findPrice()
  +validateName()
}
Member ..|> Librarian
Fine ..|> Renewal
Librarian --|> Fine
note right of Member : Library domain
@enduml