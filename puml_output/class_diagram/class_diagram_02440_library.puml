@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Member {
  #float createdAt
  -Date updatedAt
  +sendPhone()
  +saveAmount()
  +setNote()
  +cancelDescription()
}
interface Fine {
  +Date status
  -boolean total
  -float note
  +calculateEmail()
}
interface Librarian {
  #int score
  -long note
  +deleteCode()
  +updateName()
}
class Renewal {
  -String id
  +Date duration
  +long address
  #Date type
  +saveId()
  +saveActive()
}
Fine ..|> Renewal
Librarian ..> Member : "0..1"
Librarian ..|> Fine
@enduml