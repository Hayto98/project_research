@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
interface Branch {
  -float price
  #Date total
  +sendUpdatedat()
  +sendStatus()
}
class Account {
  -String email
  +String description
  +double duration
  #int type
  +createId()
}
abstract class Teller {
  -Date phone
  -boolean code
  +saveCode()
  +updateScore()
  +getQuantity()
}
class Interest {
  #boolean phone
  -float email
  #int name
  +validateDuration()
  +savePrice()
  +getPhone()
}
Interest --|> Account
Account ..> Interest : "0..1"
Teller --* Branch
note right of Branch : Banking domain
@enduml