@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Reservation {
  +Date email
  #long status
  #Date phone
  +createUpdatedat()
  +calculatePhone()
  +calculateId()
}
class Staff {
  -long phone
  +long description
  #boolean note
  +findStatus()
  +cancelCode()
}
interface Amenity {
  #long name
  -String id
  +long description
  +boolean duration
  +createCode()
  +validateType()
  +calculateEmail()
  +setActive()
}
interface Invoice {
  #String quantity
  #Date phone
  #int active
  -boolean amount
  +sendDuration()
  +cancelQuantity()
  +deleteActive()
  +deleteId()
}
class Booking {
  #long email
  #long address
  #int phone
  +updateCode()
  +getQuantity()
}
class Room {
  -int description
  -float price
  +createScore()
  +findLevel()
  +validateActive()
}
Invoice --|> Staff
Booking --o Reservation
Invoice ..> Reservation : "1"
Reservation ..|> Amenity
@enduml