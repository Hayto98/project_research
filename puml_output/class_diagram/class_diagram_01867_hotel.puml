@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Reservation {
  +Date email
  #long status
  #Date phone
  +sendQuantity()
  +getPhone()
  +updatePhone()
}
class Staff {
  #double email
  #boolean phone
  -String createdAt
  +int duration
  +float description
  +createStatus()
  +setEmail()
  +updateDuration()
}
abstract class Amenity {
  -long name
  #int score
  #String quantity
  +createScore()
  +processNote()
}
abstract class Invoice {
  #long createdAt
  #long email
  #int address
  +float phone
  +getDescription()
  +calculateAddress()
}
class Booking {
  +double email
  +boolean updatedAt
  #String note
  -double type
  +Date amount
  +setEmail()
}
class Room {
  -boolean phone
  #Date status
  #String active
  #float createdAt
  +calculateAmount()
  +sendNote()
  +findAddress()
  +validateTotal()
}
Amenity --* Room
Reservation ..> Staff : "1"
note right of Reservation : Hotel domain
@enduml