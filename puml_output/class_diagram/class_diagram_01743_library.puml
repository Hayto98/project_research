@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Book {
  -Date price
  -int total
  +setQuantity()
  +deleteAddress()
  +cancelCode()
  +findPrice()
}
class Author {
  -int note
  -double code
  +double type
  #Date id
  +float total
  +cancelDuration()
  +getScore()
}
abstract class Shelf {
  #float note
  #double phone
  #boolean id
  -float score
  +Date level
  +setCreatedat()
  +sendDuration()
}
abstract class Fine {
  +double level
  -float status
  -long createdAt
  #boolean description
  +validateLevel()
}
interface Renewal {
  -float amount
  -String name
  +processQuantity()
}
abstract class Branch {
  +double type
  #String description
  #float total
  #double note
  +boolean level
  +processPhone()
}
Shelf ..> Renewal : "0..1"
Branch --|> Shelf
Renewal --o Branch
Book ..|> Author
note right of Book : Library domain
@enduml