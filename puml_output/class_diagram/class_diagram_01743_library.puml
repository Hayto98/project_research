@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Book {
  -Date price
  -int total
  +validateEmail()
  +saveDescription()
  +processScore()
  +createQuantity()
}
class Author {
  -float level
  -boolean code
  +boolean price
  -String phone
  +saveCreatedat()
  +updateStatus()
  +processLevel()
  +sendScore()
}
class Shelf {
  -Date createdAt
  -String updatedAt
  +long id
  #float type
  #double note
  +createEmail()
  +updateName()
  +sendType()
}
class Fine {
  #boolean createdAt
  -long active
  +processActive()
}
class Renewal {
  -long note
  #boolean type
  +deletePhone()
}
class Branch {
  -float amount
  -String name
  +cancelCode()
}
Fine --o Branch
Author --o Fine
Author --o Branch
Renewal ..> Book : "*"
@enduml