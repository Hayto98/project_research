@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
interface Order {
  #float quantity
  -String type
  +double phone
  -Date name
  +setStatus()
  +createEmail()
  +createActive()
}
abstract class Wishlist {
  -String id
  -float score
  +calculateTotal()
  +setStatus()
}
class Category {
  #boolean status
  +Date email
  #boolean note
  +Date duration
  +setTotal()
}
class Review {
  #float name
  -double phone
  #float total
  +int updatedAt
  +saveName()
  +cancelDescription()
  +validateTotal()
  +sendId()
}
abstract class Product {
  +String status
  -boolean name
  +String code
  +cancelDescription()
}
class Invoice {
  -int active
  +Date code
  +setActive()
}
Invoice ..|> Review
Order ..|> Review
Order --|> Product
Category --> Review : "1..*"
@enduml