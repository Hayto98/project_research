@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
interface Classroom {
  #long total
  -String updatedAt
  -int status
  #long id
  -Date active
  +processAddress()
}
class Exam {
  #double level
  -Date amount
  -int type
  +Date createdAt
  +sendAmount()
  +findCode()
  +createQuantity()
}
class Course {
  +double active
  +boolean level
  -boolean address
  #long quantity
  -boolean amount
  +getStatus()
  +validateStatus()
}
class Grade {
  #boolean name
  +int email
  #int phone
  +deleteActive()
}
Course ..|> Grade
Classroom --> Exam : "0..1"
Classroom --o Course
note right of Classroom : Education domain
@enduml