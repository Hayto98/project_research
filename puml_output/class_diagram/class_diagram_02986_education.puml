@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
interface Classroom {
  #long total
  -String updatedAt
  -int status
  #long id
  -Date active
  +deletePrice()
}
class Exam {
  -int address
  #double level
  -Date amount
  +validateCode()
  +getType()
  +cancelLevel()
}
interface Course {
  #Date score
  -String amount
  #boolean code
  #Date quantity
  +sendQuantity()
  +savePrice()
  +validateScore()
  +calculatePhone()
}
interface Grade {
  #double updatedAt
  #Date price
  -double code
  +updateCreatedat()
  +getDuration()
}
Classroom --|> Exam
Course --|> Classroom
@enduml