@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Account {
  +double name
  -long phone
  +Date duration
  +Date type
  -Date score
  +updateName()
  +setAddress()
  +getCreatedat()
  +sendNote()
}
interface Transfer {
  -boolean total
  -float note
  -float score
  #float id
  +int status
  +saveName()
  +sendDescription()
  +updateType()
}
abstract class Beneficiary {
  +String email
  -long createdAt
  +savePhone()
  +validateUpdatedat()
}
class Interest {
  -double code
  #double createdAt
  -long note
  #float active
  #float updatedAt
  +processPrice()
  +processStatus()
  +createNote()
}
class Loan {
  #long quantity
  -int description
  +processName()
  +createLevel()
}
Account --* Transfer
Transfer --o Account
Account --o Loan
@enduml