@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Account {
  +double name
  -long phone
  +Date duration
  +Date type
  -Date score
  +setScore()
  +sendUpdatedat()
  +findDuration()
  +cancelType()
}
abstract class Transfer {
  #long level
  -float score
  #float id
  +int status
  -double price
  +processStatus()
  +createCreatedat()
}
class Beneficiary {
  #float phone
  #boolean duration
  +getType()
  +getScore()
}
abstract class Interest {
  #int createdAt
  -double note
  +createPhone()
  +findScore()
  +validateUpdatedat()
  +validateCreatedat()
}
interface Loan {
  #long quantity
  -int description
  +getId()
  +cancelAmount()
}
Transfer --o Account
Account --o Loan
note right of Account : Banking domain
@enduml