@startuml
skinparam ArrowColor #555555
interface Review {
  +long createdAt
  #String note
  -boolean quantity
  #float amount
  +calculateTotal()
  +processLevel()
  +sendTotal()
  +createNote()
}
class Category {
  #boolean status
  +float createdAt
  -int address
  +processAmount()
  +createAmount()
}
class Product {
  +String note
  #String id
  +cancelCode()
  +validateCreatedat()
}
class Customer {
  -boolean description
  +boolean amount
  #double email
  +deleteAddress()
}
class Shipment {
  -long amount
  #boolean phone
  -long id
  +calculateDescription()
  +sendName()
  +deleteTotal()
}
Review --> Shipment : "1..*"
Product --|> Customer
@enduml