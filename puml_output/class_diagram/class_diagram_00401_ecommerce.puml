@startuml
skinparam ArrowColor #555555
interface Review {
  +long createdAt
  #String note
  -boolean quantity
  #float amount
  +calculateId()
  +findStatus()
  +sendUpdatedat()
  +setCreatedat()
}
class Category {
  +long price
  -String amount
  -String description
  +setScore()
}
class Product {
  +int type
  +long description
  -boolean level
  +cancelTotal()
  +getUpdatedat()
}
class Customer {
  -long amount
  #boolean phone
  -long id
  +findType()
  +deleteStatus()
  +setDuration()
}
class Shipment {
  +long price
  -double status
  +double note
  #long createdAt
  +validateQuantity()
  +getDescription()
  +processAmount()
  +createPhone()
}
Shipment ..|> Category
Product --|> Review
note right of Review : Ecommerce domain
@enduml