@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Interest {
  +float description
  -double address
  +boolean email
  +sendAddress()
  +createDuration()
  +findCode()
  +getCode()
}
class Loan {
  #boolean updatedAt
  +boolean duration
  +calculateActive()
  +updateLevel()
  +cancelDuration()
}
interface Transaction {
  -float price
  +int createdAt
  #int level
  -double active
  +createCode()
  +deleteCreatedat()
}
class Teller {
  +int address
  -String createdAt
  +double total
  -String duration
  -int status
  +saveAmount()
  +createPhone()
  +getQuantity()
}
interface Customer {
  +long total
  +double createdAt
  #boolean phone
  -double note
  #double email
  +setId()
  +sendAmount()
}
class Withdrawal {
  -float total
  #float level
  +createQuantity()
  +createDuration()
  +saveCode()
  +validateId()
}
class Deposit {
  #String address
  #int phone
  +String price
  +float quantity
  +updateQuantity()
}
Customer --|> Transaction
Withdrawal ..> Teller : "1..*"
Loan --o Withdrawal
@enduml