@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Interest {
  +float description
  -double address
  +boolean email
  +createPrice()
  +validateLevel()
  +deleteId()
  +updateUpdatedat()
}
interface Loan {
  #long active
  #boolean email
  +calculateDuration()
  +updateCreatedat()
  +sendEmail()
}
class Transaction {
  #float createdAt
  #int address
  +long price
  +saveActive()
  +processAddress()
  +updateTotal()
}
class Teller {
  -String name
  +double amount
  +setNote()
  +updateActive()
  +createNote()
}
class Customer {
  +long total
  +double createdAt
  #boolean phone
  -double note
  #double email
  +cancelScore()
  +createStatus()
}
abstract class Withdrawal {
  +float duration
  #Date type
  #long quantity
  #boolean price
  #float active
  +validatePhone()
  +calculateQuantity()
  +sendName()
}
interface Deposit {
  #float description
  +float code
  +boolean amount
  +setPrice()
  +savePhone()
  +updatePrice()
}
Teller --|> Deposit
Interest ..|> Teller
Deposit ..|> Transaction
note right of Interest : Banking domain
@enduml