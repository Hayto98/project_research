@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
abstract class Reservation {
  #float name
  #String type
  #double email
  +String quantity
  +deleteQuantity()
  +deleteType()
  +createDescription()
}
class CheckIn {
  #long total
  +double email
  #int id
  +sendActive()
  +deleteActive()
}
interface CheckOut {
  +String email
  -int createdAt
  +setUpdatedat()
  +findLevel()
  +sendName()
  +updateScore()
}
abstract class Room {
  #float type
  #double note
  +sendDuration()
  +setName()
}
class Amenity {
  +Date address
  -String total
  +long phone
  +String duration
  #int price
  +findUpdatedat()
  +updateLevel()
  +sendQuantity()
  +findEmail()
}
class Booking {
  +long amount
  +Date quantity
  #int active
  +createPrice()
  +deletePhone()
  +sendStatus()
}
class Service {
  -long level
  -double address
  #float active
  +sendScore()
  +findScore()
}
Amenity --|> CheckIn
CheckOut --o Booking
Reservation --|> Room
@enduml