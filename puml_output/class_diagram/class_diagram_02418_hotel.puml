@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
abstract class Reservation {
  #float name
  #String type
  #double email
  +String quantity
  +setActive()
  +setUpdatedat()
  +calculateEmail()
}
class CheckIn {
  #double name
  #float note
  +float description
  -Date score
  +setId()
  +createUpdatedat()
}
abstract class CheckOut {
  #boolean type
  #String price
  +saveNote()
  +findLevel()
  +calculateCreatedat()
  +saveId()
}
class Room {
  +Date address
  -String total
  +long phone
  +String duration
  #int price
  +cancelQuantity()
  +sendStatus()
  +deleteAmount()
  +createActive()
}
class Amenity {
  -float status
  #long level
  +boolean createdAt
  -boolean phone
  +validateNote()
  +calculateDuration()
  +deletePrice()
  +createCreatedat()
}
interface Booking {
  +double code
  +boolean address
  -String note
  +sendStatus()
  +sendTotal()
  +sendId()
  +validateNote()
}
class Service {
  #float phone
  -long createdAt
  +findAmount()
  +findName()
  +createScore()
  +createDuration()
}
Room ..> Service : "1..*"
CheckIn --o Service
Reservation ..|> CheckOut
Service ..|> Booking
Reservation ..> Booking : "0..1"
Booking ..|> CheckOut
note right of Reservation : Hotel domain
@enduml