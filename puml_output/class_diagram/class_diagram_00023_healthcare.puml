@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
interface Treatment {
  #String code
  +double description
  +cancelStatus()
  +cancelNote()
}
class Appointment {
  -String note
  +Date address
  -long name
  #int amount
  +deleteName()
}
interface Prescription {
  +long active
  +int email
  #boolean total
  -String phone
  #boolean status
  +processAddress()
  +findActive()
  +validateActive()
}
abstract class LabTest {
  #Date active
  #int level
  +findTotal()
}
class MedicalRecord {
  -Date price
  +Date address
  #float note
  +setCreatedat()
  +createAmount()
  +getName()
  +saveCode()
}
interface Patient {
  -long active
  -double score
  +sendDuration()
  +validateAmount()
  +setAddress()
  +sendPhone()
}
Prescription ..|> Treatment
Patient --> MedicalRecord : "*"
MedicalRecord ..|> Patient
note right of Treatment : Healthcare domain
@enduml