@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
interface Treatment {
  #String code
  +double description
  +saveDuration()
  +updateName()
}
interface Appointment {
  +double address
  +int email
  #long note
  -boolean duration
  +String name
  +processQuantity()
  +sendQuantity()
}
abstract class Prescription {
  -String total
  +boolean phone
  #long status
  +Date createdAt
  +saveAmount()
  +createActive()
  +updateId()
}
interface LabTest {
  #boolean active
  #boolean type
  +Date status
  +Date duration
  +setDuration()
  +updateDescription()
  +findAddress()
  +saveTotal()
}
abstract class MedicalRecord {
  #boolean level
  -String note
  +long price
  +float description
  +deleteType()
}
class Patient {
  +boolean level
  #double score
  +processDescription()
  +saveAmount()
  +validateName()
}
Appointment ..> Treatment : "1..*"
MedicalRecord ..|> Prescription
Prescription ..|> Treatment
Patient --> MedicalRecord : "*"
@enduml