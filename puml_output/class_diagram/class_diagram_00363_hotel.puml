@startuml
skinparam shadowing true
class CheckIn {
  #float duration
  #String id
  +calculateScore()
}
class Room {
  +double level
  #float code
  -int id
  +boolean active
  +getNote()
  +validateUpdatedat()
}
class CheckOut {
  -String description
  +boolean id
  +deleteType()
  +findDescription()
  +updateName()
  +cancelCode()
}
class Amenity {
  #String level
  #double score
  #int phone
  +processQuantity()
}
class Housekeeping {
  -String total
  -double level
  +calculateCode()
  +deleteStatus()
  +processPrice()
  +processNote()
}
Amenity ..|> CheckOut
CheckOut --o CheckIn
@enduml