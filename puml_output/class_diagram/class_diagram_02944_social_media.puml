@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Notification {
  +Date total
  -long description
  -Date address
  -int phone
  -Date score
  +getActive()
}
class Follower {
  -int level
  #Date phone
  +validateName()
  +validateId()
}
class Report {
  #boolean type
  #double score
  #long duration
  -long code
  #Date address
  +setCode()
  +deleteActive()
  +calculateDescription()
}
interface Hashtag {
  +long description
  -long type
  +cancelEmail()
  +saveCreatedat()
  +getType()
  +findCode()
}
class Profile {
  #int active
  -float note
  +sendEmail()
  +cancelPhone()
  +calculateCode()
}
class Album {
  -Date updatedAt
  #boolean description
  #int quantity
  +int code
  #long status
  +deleteActive()
  +validateQuantity()
  +getQuantity()
  +calculateTotal()
}
abstract class Group {
  +long updatedAt
  #boolean price
  +saveNote()
  +saveScore()
  +processQuantity()
  +setDuration()
}
Follower ..> Profile : "1"
Profile ..|> Group
Report ..|> Profile
Follower --o Album
@enduml