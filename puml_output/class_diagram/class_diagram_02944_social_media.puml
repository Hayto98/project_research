@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Notification {
  +Date total
  -long description
  -Date address
  -int phone
  -Date score
  +findQuantity()
}
class Follower {
  +Date email
  +float description
  #double updatedAt
  -boolean type
  +findCode()
  +saveAddress()
  +findDuration()
  +findNote()
}
class Report {
  +double quantity
  +long address
  -long type
  -String code
  +setPhone()
  +deleteStatus()
  +sendNote()
}
interface Hashtag {
  -double email
  #int duration
  #Date createdAt
  +updateDescription()
  +findQuantity()
  +setStatus()
  +calculateActive()
}
interface Profile {
  -double name
  -int description
  #int active
  +setUpdatedat()
  +findPrice()
  +getEmail()
  +findActive()
}
interface Album {
  #Date createdAt
  +boolean phone
  #int name
  -boolean level
  +int duration
  +sendId()
  +deleteNote()
  +saveLevel()
  +setScore()
}
class Group {
  +int level
  +long updatedAt
  -int active
  #Date note
  -String total
  +validateDuration()
}
Notification --o Hashtag
Follower --* Group
note right of Notification : Social Media domain
@enduml