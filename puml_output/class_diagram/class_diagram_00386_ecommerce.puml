@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Invoice {
  -double createdAt
  #boolean level
  -double score
  +validatePhone()
  +cancelPrice()
  +processDescription()
}
interface Supplier {
  -boolean active
  +int score
  +Date phone
  -long description
  +deleteAddress()
  +processCreatedat()
}
abstract class Category {
  -int quantity
  +long email
  -String amount
  +setDescription()
  +updateAddress()
}
class Product {
  -int phone
  +long updatedAt
  +setName()
  +setTotal()
  +updateEmail()
}
interface Order {
  #float description
  -double score
  -Date status
  #Date createdAt
  +setDescription()
}
class Payment {
  +int description
  +boolean email
  +validateDescription()
  +calculateNote()
  +validateQuantity()
}
abstract class Shipment {
  #String amount
  #String phone
  -String email
  +updateScore()
  +findId()
}
Shipment --o Supplier
Invoice --* Supplier
Payment --* Product
note right of Invoice : Ecommerce domain
@enduml