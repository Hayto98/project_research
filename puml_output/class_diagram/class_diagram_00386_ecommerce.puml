@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Invoice {
  -double createdAt
  #boolean level
  -double score
  +calculateName()
  +createAmount()
  +validateActive()
}
abstract class Supplier {
  +float description
  -boolean level
  +int email
  +Date active
  -long phone
  +calculateAddress()
  +updateAddress()
}
class Category {
  +long createdAt
  +float price
  +long amount
  -String quantity
  +String email
  +updateCode()
  +findType()
}
class Product {
  -int createdAt
  +long name
  -String phone
  +String updatedAt
  +sendEmail()
  +deleteName()
  +cancelDescription()
  +cancelAmount()
}
class Order {
  #float score
  -double status
  -Date createdAt
  +validateId()
}
class Payment {
  +int code
  +boolean description
  #boolean email
  +calculateCreatedat()
  +sendDuration()
  +getEmail()
}
abstract class Shipment {
  -long phone
  #String quantity
  #String type
  -String createdAt
  #float amount
  +processDuration()
  +createType()
}
Payment --* Invoice
Shipment --o Supplier
Invoice --* Supplier
Payment --* Product
Product ..> Order : "0..1"
@enduml