@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
interface Depot {
  -int id
  #Date description
  +validatePhone()
  +getType()
  +cancelQuantity()
}
abstract class DeliveryNote {
  #String status
  -float active
  +double phone
  #float address
  +updateId()
  +cancelPrice()
  +findNote()
}
class Warehouse {
  +int amount
  -long status
  +updateUpdatedat()
  +cancelScore()
}
abstract class Customer {
  -long createdAt
  #long phone
  -double quantity
  #double updatedAt
  +Date id
  +savePhone()
  +cancelDuration()
  +getId()
}
class FuelLog {
  #boolean phone
  #boolean total
  #String createdAt
  #Date type
  +setTotal()
}
class Route {
  #Date amount
  +boolean duration
  -long price
  -float quantity
  +updateName()
  +createTotal()
  +createNote()
  +findEmail()
}
FuelLog --> Route : "0..1"
DeliveryNote ..|> Depot
FuelLog --|> Customer
DeliveryNote --o Customer
Depot --|> Warehouse
@enduml