@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Course {
  +boolean level
  #float total
  +cancelScore()
  +saveLevel()
  +createPhone()
}
interface Classroom {
  #float total
  -Date updatedAt
  #double status
  -boolean type
  -Date quantity
  +findEmail()
  +setScore()
  +createQuantity()
  +sendNote()
}
interface Assignment {
  #boolean quantity
  +double type
  +setQuantity()
  +calculateAddress()
  +sendCreatedat()
  +processDescription()
}
interface Student {
  -double id
  #Date price
  +float active
  #boolean amount
  #String description
  +saveCreatedat()
  +sendId()
  +updateScore()
  +setNote()
}
class Book {
  -boolean note
  -String price
  +validateQuantity()
}
class Library {
  #long note
  -int email
  +findType()
  +findPrice()
}
class Teacher {
  #double description
  #String quantity
  -double code
  +deleteName()
  +findDuration()
}
Library ..|> Teacher
Assignment ..> Course : "0..1"
Assignment --* Student
Assignment ..> Classroom : "1"
note right of Course : Education domain
@enduml