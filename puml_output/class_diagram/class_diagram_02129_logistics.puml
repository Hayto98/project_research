@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Warehouse {
  #long note
  #int description
  #double updatedAt
  +long duration
  #Date active
  +setCode()
  +validateId()
}
interface Depot {
  #Date duration
  -double quantity
  +String score
  +sendUpdatedat()
}
class Inventory {
  -String id
  #long type
  -boolean price
  +int score
  +findPrice()
}
class DeliveryNote {
  #double type
  -String quantity
  -long amount
  +findPrice()
  +getAmount()
}
class Package {
  +double type
  #long score
  +deleteName()
  +calculateTotal()
  +findPrice()
}
class FuelLog {
  +long level
  -long description
  +calculateCreatedat()
  +saveActive()
}
class Customer {
  +boolean name
  -String createdAt
  +sendNote()
  +sendAmount()
  +processLevel()
  +setAmount()
}
Package --> Depot : "0..1"
Warehouse --* Package
Warehouse --|> Inventory
Inventory --> FuelLog : "1..*"
@enduml