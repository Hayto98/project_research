@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Warehouse {
  #long note
  #int description
  #double updatedAt
  +long duration
  #Date active
  +findStatus()
  +cancelDescription()
}
interface Depot {
  +String score
  #long type
  -String note
  -double status
  +validateName()
  +cancelEmail()
  +calculateLevel()
  +setAmount()
}
class Inventory {
  -long level
  +boolean updatedAt
  +createCode()
  +calculatePhone()
  +updateActive()
  +saveAddress()
}
class DeliveryNote {
  -boolean score
  -String code
  #boolean price
  #Date address
  +int email
  +validateQuantity()
  +updateAddress()
  +sendPhone()
}
class Package {
  #long createdAt
  +boolean name
  +updateScore()
  +calculatePhone()
  +cancelDescription()
  +sendLevel()
}
class FuelLog {
  +long active
  +long address
  +processActive()
  +getCode()
  +sendQuantity()
}
class Customer {
  -String price
  -String quantity
  #int id
  +findActive()
}
Warehouse --> Package : "*"
Package --|> Warehouse
note right of Warehouse : Logistics domain
@enduml