@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Librarian {
  +String createdAt
  -String description
  #long quantity
  #double id
  #int code
  +processPrice()
  +processId()
  +saveType()
}
class Author {
  +int createdAt
  +Date status
  +double duration
  +setAmount()
  +setEmail()
  +calculateDuration()
  +updateType()
}
interface Catalog {
  -float level
  +long amount
  #float note
  #double description
  -Date active
  +updateType()
}
interface Reservation {
  #long name
  +boolean amount
  +updateAmount()
}
class Loan {
  #Date total
  +boolean price
  +findEmail()
}
class Member {
  +Date updatedAt
  -double active
  #long code
  +int createdAt
  +setNote()
  +updatePrice()
  +validateDuration()
}
Catalog --* Reservation
Member --o Catalog
Reservation --o Librarian
Librarian --|> Member
Catalog ..|> Librarian
note right of Librarian : Library domain
@enduml