@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Librarian {
  +String createdAt
  -String description
  #long quantity
  #double id
  #int code
  +setAmount()
  +calculateType()
  +deletePrice()
}
abstract class Author {
  +int id
  +int type
  +Date phone
  +double updatedAt
  #double createdAt
  +validateQuantity()
}
class Catalog {
  -boolean total
  +double createdAt
  #boolean type
  #Date active
  +saveDescription()
  +calculateUpdatedat()
}
class Reservation {
  -Date code
  #String quantity
  +double active
  #boolean total
  +savePhone()
}
class Loan {
  +Date id
  +long level
  #String score
  -double name
  +cancelAmount()
  +processAddress()
}
interface Member {
  -int email
  #String amount
  +updateType()
  +calculateDescription()
}
Reservation --* Loan
Author --* Member
Librarian ..|> Reservation
Reservation --> Catalog : "*"
@enduml