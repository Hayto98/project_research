@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Member {
  #String code
  +long note
  -Date phone
  +processType()
  +calculateCreatedat()
  +setLevel()
}
class Author {
  #int level
  #Date note
  -String type
  +validateStatus()
  +deleteCreatedat()
}
class Loan {
  -long email
  -String amount
  #float code
  #long status
  +setQuantity()
}
interface Librarian {
  #long createdAt
  -String email
  +boolean id
  #float note
  +long phone
  +processUpdatedat()
  +saveDuration()
  +setEmail()
  +findDescription()
}
interface Fine {
  -long phone
  -boolean name
  -Date description
  -String updatedAt
  +String duration
  +getEmail()
}
Loan ..|> Librarian
Member --o Librarian
@enduml