@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Member {
  #String code
  +long note
  -Date phone
  +calculateAddress()
  +deleteCode()
  +sendUpdatedat()
}
interface Author {
  +float type
  -long updatedAt
  -long active
  #int email
  #Date id
  +saveStatus()
}
class Loan {
  +float note
  #boolean code
  #double active
  +long phone
  +findNote()
}
class Librarian {
  -double address
  +boolean id
  -boolean createdAt
  #Date name
  +savePhone()
  +getDescription()
  +cancelUpdatedat()
  +validatePhone()
}
class Fine {
  +String score
  +int quantity
  +long phone
  -int id
  +processType()
}
Loan ..> Author : "1..*"
Loan --|> Member
Librarian ..|> Author
note right of Member : Library domain
@enduml