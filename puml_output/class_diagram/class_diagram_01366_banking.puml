@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
abstract class Branch {
  #int phone
  -Date description
  +float score
  +calculatePhone()
  +validateDuration()
  +saveNote()
  +cancelPrice()
}
class Transaction {
  +String duration
  -Date email
  +createQuantity()
}
class Customer {
  -int active
  +int id
  -String code
  -String address
  #float createdAt
  +findAmount()
  +getNote()
}
class Interest {
  +String email
  #boolean code
  #Date active
  +float type
  +double phone
  +cancelName()
  +deleteAddress()
  +validateCreatedat()
  +findPhone()
}
interface Statement {
  +boolean note
  +Date createdAt
  #String description
  -int duration
  -String type
  +setLevel()
  +saveName()
  +deletePhone()
}
interface Teller {
  +long note
  -long quantity
  +cancelDuration()
  +createActive()
  +updateName()
}
abstract class Withdrawal {
  +long quantity
  -long name
  -float status
  -double code
  #double address
  +processScore()
}
Customer ..|> Interest
Branch --o Statement
note right of Branch : Banking domain
@enduml