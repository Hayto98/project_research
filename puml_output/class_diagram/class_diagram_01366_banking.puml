@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
abstract class Branch {
  #int phone
  -Date description
  +float score
  +createEmail()
  +validateDescription()
  +findAmount()
  +findCode()
}
class Transaction {
  +String duration
  -Date price
  #boolean phone
  +long id
  -String email
  +createUpdatedat()
  +cancelTotal()
  +setDescription()
  +validateDuration()
}
interface Customer {
  +double type
  +double updatedAt
  +Date amount
  +getActive()
  +processUpdatedat()
}
class Interest {
  #long code
  +String type
  #boolean email
  #Date duration
  +float level
  +cancelCreatedat()
}
abstract class Statement {
  -int description
  #float address
  +calculateUpdatedat()
  +updateCreatedat()
  +cancelAmount()
}
abstract class Teller {
  +boolean createdAt
  +Date description
  #String note
  -int active
  -String type
  +calculateType()
  +findType()
  +setStatus()
}
interface Withdrawal {
  #String amount
  -long phone
  +validateDuration()
  +findLevel()
}
Customer --* Statement
Statement --* Withdrawal
Statement --|> Transaction
Interest --o Teller
@enduml