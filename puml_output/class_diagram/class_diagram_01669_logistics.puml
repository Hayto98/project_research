@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Inventory {
  #String active
  +float id
  +deleteUpdatedat()
  +getCreatedat()
  +setDuration()
}
class Manifest {
  #String updatedAt
  -double name
  #long level
  +long type
  +cancelNote()
  +setName()
  +findEmail()
  +deleteId()
}
class Customer {
  #String note
  #String level
  +saveNote()
  +getScore()
  +setDuration()
}
interface Tracking {
  +int id
  #int quantity
  -float price
  +deleteEmail()
  +saveTotal()
}
Tracking --|> Manifest
Inventory ..> Tracking : "1"
@enduml