@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Route {
  #double active
  +boolean price
  +double level
  #long description
  +boolean score
  +updateDuration()
  +processCreatedat()
  +cancelScore()
  +getStatus()
}
class Warehouse {
  +int email
  +float score
  +String note
  +processEmail()
  +sendPrice()
  +sendPhone()
}
class Shipment {
  #boolean quantity
  #float email
  #float total
  #double id
  +processAddress()
  +setStatus()
}
class Inventory {
  -String type
  -Date createdAt
  #long id
  +savePhone()
  +cancelScore()
}
Route --> Warehouse : "1..*"
Shipment ..> Inventory : "1..*"
Route --o Inventory
@enduml