@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Route {
  #double active
  +boolean price
  +double level
  #long description
  +boolean score
  +getUpdatedat()
  +updateEmail()
  +sendNote()
  +deleteAmount()
}
class Warehouse {
  -boolean status
  #long level
  +sendScore()
  +cancelQuantity()
}
class Shipment {
  +long total
  +double id
