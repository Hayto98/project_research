@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
abstract class Transaction {
  -int level
  +float name
  #boolean total
  -Date note
  +processPhone()
}
class Deposit {
  -int duration
  -String quantity
  -float level
  #double createdAt
  +createQuantity()
}
class Account {
  -boolean updatedAt
  +Date createdAt
  -double type
  -float score
  +String description
  +calculateLevel()
  +updatePrice()
  +setPhone()
}
class Transfer {
  #long phone
  +long address
  +float status
  #boolean name
  +calculateName()
  +deleteUpdatedat()
  +cancelEmail()
}
class Beneficiary {
  -boolean description
  #float address
  -String name
  -long note
  #long type
  +findCreatedat()
  +validateDuration()
  +getAddress()
}
abstract class Card {
  +long quantity
  +float price
  +cancelAmount()
  +createScore()
  +validateAddress()
  +getCreatedat()
}
Beneficiary ..|> Deposit
Deposit --|> Transfer
Account --o Beneficiary
Transaction --> Transfer : "*"
@enduml