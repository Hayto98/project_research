@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
abstract class Guest {
  #String price
  +float address
  +createDescription()
  +calculateName()
}
class Restaurant {
  -float id
  -boolean price
  -int phone
  +cancelTotal()
}
class CheckOut {
  +String description
  #String phone
  +processCode()
  +createDuration()
}
class Booking {
  #int total
  -long level
  -double type
  +String status
  +processCode()
  +getQuantity()
}
class Room {
  +Date price
  #Date active
  +Date score
  +processPrice()
  +deleteAmount()
  +sendCode()
  +validateAddress()
}
class Reservation {
  #long note
  -boolean updatedAt
  -double email
  -float total
  #String status
  +cancelName()
  +saveCreatedat()
  +processDescription()
}
class Staff {
  +float price
  -long active
  +findLevel()
  +setCode()
}
CheckOut --|> Restaurant
Guest ..> CheckOut : "1"
Room --* Reservation
CheckOut --* Guest
@enduml