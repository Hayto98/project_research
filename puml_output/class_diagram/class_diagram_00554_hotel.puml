@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
abstract class Guest {
  #String price
  +float address
  +sendAddress()
  +updateCreatedat()
}
class Restaurant {
  +String phone
  +String address
  +int type
  -String active
  +float note
  +findAmount()
}
class CheckOut {
  #int updatedAt
  -long email
  -double total
  +String type
  +String status
  +deletePrice()
}
interface Booking {
  +double description
  -long type
  +calculateNote()
  +updateEmail()
  +calculateScore()
}
interface Room {
  #double address
  -double quantity
  +createAddress()
}
class Reservation {
  -boolean active
  +float name
  +validateCreatedat()
  +findPhone()
  +createAmount()
}
class Staff {
  #Date email
  -long name
  +validateLevel()
}
Guest ..|> Restaurant
note right of Guest : Hotel domain
@enduml