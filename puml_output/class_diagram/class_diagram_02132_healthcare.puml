@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
interface Doctor {
  #double duration
  #boolean code
  +setName()
}
abstract class Prescription {
  -int score
  -boolean name
  -Date note
  -double id
  +deletePhone()
}
class Treatment {
  -Date id
  -String code
  -String active
  #int note
  +createUpdatedat()
  +processPrice()
}
class Ward {
  -boolean amount
  +long code
  +calculateAmount()
}
Prescription ..> Doctor : "0..1"
Ward --* Treatment
@enduml