@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Payment {
  #Date id
  #long amount
  -long active
  +updatePhone()
  +createPhone()
  +deleteAmount()
  +cancelAmount()
}
class Category {
  +float status
  #String note
  #Date total
  -boolean updatedAt
  +saveType()
  +cancelLevel()
  +saveActive()
  +cancelUpdatedat()
}
abstract class Coupon {
  +String score
  +Date active
  #Date createdAt
  -String description
  +sendStatus()
}
interface Warehouse {
  -String code
  -int status
  +cancelNote()
  +getUpdatedat()
}
class Order {
  +boolean level
  #float code
  +String id
  #String total
  -double active
  +validateDescription()
  +updateActive()
  +getLevel()
  +processPrice()
}
class Product {
  #boolean type
  -boolean address
  +setAmount()
}
Category --o Payment
Coupon --> Category : "0..1"
Category ..|> Coupon
Payment ..> Order : "0..1"
@enduml