@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
interface Booking {
  +double name
  +float score
  #double price
  -float email
  +double level
  +setType()
  +setActive()
  +updateUpdatedat()
}
interface Payment {
  #double updatedAt
  -float quantity
  +deleteTotal()
}
abstract class Room {
  #Date score
  +long quantity
  #float total
  #double email
  +cancelLevel()
}
class Restaurant {
  #float duration
  +double note
  +getCode()
  +validatePhone()
  +validateName()
  +sendType()
}
abstract class CheckIn {
  -String name
  +boolean score
  -boolean amount
  +float description
  +sendName()
  +getDuration()
}
class Reservation {
  -String type
  #float createdAt
  +deleteAmount()
}
Room --o CheckIn
Payment ..> Restaurant : "1..*"
CheckIn --> Restaurant : "*"
CheckIn --> Booking : "1"
@enduml