@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
interface Booking {
  +double name
  +float score
  #double price
  -float email
  +double level
  +deleteStatus()
  +cancelStatus()
  +updateQuantity()
}
interface Payment {
  -long phone
  #Date name
  +long type
  #float quantity
  #double active
  +validateCode()
}
interface Room {
  -long code
  +boolean price
  +float note
  +double duration
  +String type
  +sendStatus()
  +deleteType()
  +deleteStatus()
  +processCreatedat()
}
abstract class Restaurant {
  -long score
  -float code
  +deleteType()
  +findAddress()
  +sendPrice()
  +cancelActive()
}
abstract class CheckIn {
  +double level
  +boolean code
  +findPrice()
  +createScore()
  +createName()
  +saveQuantity()
}
class Reservation {
  #float total
  #double code
  #float description
  -String duration
  +createId()
}
Booking ..|> CheckIn
CheckIn --|> Payment
Reservation --> CheckIn : "0..1"
Restaurant ..> Room : "1..*"
note right of Booking : Hotel domain
@enduml