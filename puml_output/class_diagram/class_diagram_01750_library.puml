@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Catalog {
  +String address
  #Date type
  -int email
  +validateAddress()
  +cancelUpdatedat()
  +validatePrice()
  +processId()
}
class Shelf {
  +double quantity
  +String note
  -int updatedAt
  +double address
  +processPhone()
  +cancelAddress()
  +getAmount()
  +saveDuration()
}
interface Reservation {
  +double description
  -double active
  -double address
  +int email
  -long name
  +getQuantity()
  +getNote()
  +validatePhone()
}
class Publisher {
  #int id
  +int amount
  +saveUpdatedat()
}
interface Book {
  +long status
  #Date address
  +calculateNote()
  +createQuantity()
  +updateAmount()
}
Book --* Catalog
Book --> Reservation : "0..1"
Reservation --> Publisher : "1..*"
note right of Catalog : Library domain
@enduml