@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Catalog {
  +String address
  #Date type
  -int email
  +deleteCode()
  +findQuantity()
  +findDescription()
  +setCode()
}
class Shelf {
  #long price
  -double note
  +long id
  +double updatedAt
  +sendLevel()
}
class Reservation {
  -long amount
  #long description
  +int type
  #boolean score
  +cancelPrice()
  +createCreatedat()
  +findDuration()
  +createActive()
}
class Publisher {
  -double updatedAt
  -double price
  +setType()
}
class Book {
  -long quantity
  -Date id
  #float duration
  +String name
  +calculateAddress()
}
Shelf ..|> Catalog
Catalog --> Shelf : "1"
Catalog ..|> Reservation
Reservation --o Book
@enduml