@startuml

class Housekeeping {
  -float createdAt
  #boolean price
  #double code
  +createName()
  +setDuration()
  +saveActive()
}
class Reservation {
  #float email
  +Date code
  +int level
  -boolean total
  #int quantity
  +updateLevel()
}
class Room {
  +double duration
  #Date address
  #float active
  +processUpdatedat()
  +saveNote()
}
abstract class Service {
  +long score
  +Date code
  +String duration
  +deleteLevel()
}
class Payment {
  #int score
  +float quantity
  #float price
  +setStatus()
  +deleteDescription()
  +saveType()
}
class Invoice {
  -long type
  +long name
  +createUpdatedat()
  +updateCode()
  +savePhone()
}
Housekeeping ..> Invoice : "0..1"
Housekeeping --o Payment
Invoice --* Service
Payment --o Room
@enduml