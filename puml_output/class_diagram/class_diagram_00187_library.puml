@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
interface Catalog {
  -long note
  #float price
  +sendEmail()
  +sendPrice()
  +updateTotal()
}
interface Loan {
  +float note
  +double score
  #long address
  -int amount
  +saveActive()
}
interface Branch {
  +Date quantity
  -double amount
  #long description
  #float total
  +deleteName()
  +sendDescription()
}
class Shelf {
  -Date code
  -double quantity
  +savePhone()
  +findAmount()
  +createCreatedat()
  +sendStatus()
}
abstract class Author {
  #Date phone
  -boolean updatedAt
  #int name
  +validateCode()
  +cancelPhone()
  +createCode()
}
abstract class Publisher {
  #int id
  #float level
  +createNote()
  +sendTotal()
}
class Reservation {
  #long name
  -boolean total
  +float email
  -Date active
  +sendQuantity()
  +validateCode()
}
Publisher --> Branch : "1..*"
Reservation --|> Catalog
Shelf ..> Publisher : "0..1"
Shelf --> Loan : "1"
@enduml