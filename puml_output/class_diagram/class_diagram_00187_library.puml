@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
interface Catalog {
  -long note
  #float price
  +updatePhone()
  +cancelQuantity()
  +processScore()
}
class Loan {
  #long name
  -int createdAt
  +boolean note
  +createAmount()
  +findDescription()
  +calculateId()
}
class Branch {
  +long email
  -Date updatedAt
  -double duration
  #double amount
  +double name
  +findNote()
  +deletePhone()
}
class Shelf {
  #boolean level
  +long price
  +createAmount()
  +calculateId()
}
class Author {
  +long score
  -String duration
  #double amount
  +sendActive()
  +createPhone()
  +cancelCreatedat()
}
class Publisher {
  #long active
  #long description
  +String total
  +calculateUpdatedat()
}
abstract class Reservation {
  #int active
  #Date id
  #Date status
  +validateCreatedat()
}
Shelf --* Publisher
Shelf ..|> Loan
Author ..> Catalog : "1..*"
Branch ..> Reservation : "1"
Branch --* Loan
note right of Catalog : Library domain
@enduml