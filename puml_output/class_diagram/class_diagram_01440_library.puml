@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Branch {
  -boolean createdAt
  -float total
  -String description
  +long code
  +findQuantity()
  +createDescription()
}
interface Renewal {
  -Date amount
  +String active
  +findEmail()
}
class Reservation {
  #long updatedAt
  -int address
  #int id
  -long score
  +saveCode()
  +updateScore()
  +getCode()
}
interface Shelf {
  +Date active
  #int name
  #float quantity
  #boolean phone
  +sendDuration()
}
interface Loan {
  -Date updatedAt
  +Date email
  +sendLevel()
  +cancelUpdatedat()
  +getPhone()
}
Shelf --> Branch : "*"
Branch --|> Shelf
Reservation ..|> Loan
@enduml