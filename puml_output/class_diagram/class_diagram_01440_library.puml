@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Branch {
  -boolean createdAt
  -float total
  -String description
  +long code
  +validateActive()
  +sendName()
}
class Renewal {
  #int updatedAt
  -String code
  +boolean id
  -float score
  -int email
  +processPhone()
  +validatePrice()
}
interface Reservation {
  +Date active
  #int name
  #float quantity
  #boolean phone
  +saveLevel()
}
class Shelf {
  #long email
  #double quantity
  -double status
  +cancelType()
}
class Loan {
  +boolean id
  -boolean email
  +boolean level
  -String updatedAt
  #float type
  +updatePhone()
  +setDescription()
}
Renewal --> Loan : "1"
Shelf --> Branch : "1"
Branch --> Renewal : "*"
note right of Branch : Library domain
@enduml