@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class User {
  +double total
  #boolean updatedAt
  #float code
  -float price
  +cancelScore()
  +getDescription()
  +processAmount()
}
class Hashtag {
  #int status
  #float note
  +findStatus()
  +savePrice()
  +findStatus()
  +processNote()
}
abstract class Album {
  +float note
  #double name
  -double description
  -long type
  +updateStatus()
  +deleteDescription()
  +createName()
  +createAmount()
}
class Comment {
  #int address
  -int amount
  +saveUpdatedat()
  +processQuantity()
  +findId()
}
Album --|> Comment
User ..|> Album
Comment --o Hashtag
note right of User : Social Media domain
@enduml