@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class User {
  +double total
  #boolean updatedAt
  #float code
  -float price
  +getDuration()
  +deleteLevel()
  +deleteDescription()
}
interface Hashtag {
  +Date description
  +String type
  +cancelQuantity()
}
class Album {
  -long status
  -String price
  +Date duration
  #float type
  -String note
  +saveName()
  +calculateAmount()
  +createActive()
  +createNote()
}
abstract class Comment {
  -String status
  -int description
  #Date level
  +updateActive()
  +validateScore()
}
Hashtag ..|> Comment
Album ..|> Comment
@enduml