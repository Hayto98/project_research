@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
abstract class Room {
  #long type
  +float email
  -boolean total
  +float active
  -String description
  +findNote()
  +updateLevel()
}
abstract class Restaurant {
  #double createdAt
  -double description
  +long name
  #int updatedAt
  #String phone
  +createLevel()
  +cancelActive()
  +findAmount()
  +deleteCode()
}
class Payment {
  -Date address
  #float quantity
  #float active
  +String code
  -double amount
  +sendDescription()
  +saveUpdatedat()
  +calculateAmount()
  +calculateStatus()
}
interface Staff {
  -int address
  -double type
  +processDescription()
  +calculateDescription()
  +cancelUpdatedat()
  +getScore()
}
interface CheckOut {
  -double active
  #boolean score
  -double updatedAt
  +long note
  #String name
  +findPrice()
  +cancelPhone()
  +sendQuantity()
  +cancelScore()
}
abstract class Invoice {
  -float phone
  -float quantity
  #boolean level
  +String type
  +double code
  +createScore()
}
Room --> Invoice : "*"
Staff --> Invoice : "0..1"
Invoice --> Restaurant : "1"
Room ..|> Payment
@enduml