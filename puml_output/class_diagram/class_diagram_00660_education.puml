@startuml
skinparam ArrowColor #555555
interface Enrollment {
  #long active
  #float duration
  -double id
  #double createdAt
  +cancelUpdatedat()
  +processTotal()
}
class Department {
  #String updatedAt
  +String active
  #Date createdAt
  #String status
  -long type
  +validatePhone()
}
abstract class Classroom {
  #float type
  +Date code
  +int level
  +boolean status
  +deleteQuantity()
  +getId()
  +setUpdatedat()
}
class Schedule {
  #int price
  -boolean amount
  +int note
  +calculateType()
}
Classroom --o Schedule
Classroom --* Enrollment
Enrollment --o Department
@enduml