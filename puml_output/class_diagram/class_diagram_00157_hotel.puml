@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Guest {
  #Date code
  #float duration
  -boolean price
  -double quantity
  +int score
  +findUpdatedat()
  +sendCode()
  +sendDuration()
}
class Staff {
  +String note
  +long address
  +float code
  +validateName()
  +createActive()
  +setCode()
  +deleteQuantity()
}
abstract class CheckIn {
  -long type
  +long phone
  +float level
  +getActive()
  +processId()
  +getAddress()
}
interface Reservation {
  #Date duration
  #long code
  -Date note
  +createEmail()
  +deleteLevel()
}
class Payment {
  +String amount
  -long address
  -float price
  #double code
  +double note
  +findLevel()
}
class Room {
  +float description
  -double note
  #double id
  +double score
  -float address
  +cancelScore()
  +createNote()
  +findQuantity()
}
Guest ..> Staff : "1"
Guest --> CheckIn : "1"
Reservation --> CheckIn : "1"
Room --o Staff
@enduml