@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Teacher {
  -int description
  -boolean quantity
  +deletePhone()
  +cancelId()
}
class Classroom {
  #boolean name
  #boolean phone
  -float score
  #boolean duration
  +deleteAddress()
  +findTotal()
  +savePrice()
}
class Student {
  #String total
  -int quantity
  +deleteCreatedat()
}
class Grade {
  -boolean code
  +boolean level
  -boolean updatedAt
  +deleteNote()
  +getScore()
  +cancelDuration()
  +createCode()
}
Teacher --* Grade
Grade ..|> Classroom
@enduml