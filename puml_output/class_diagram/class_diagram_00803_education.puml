@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Teacher {
  -int description
  -boolean quantity
  +validateDescription()
  +validateName()
}
class Classroom {
  #double duration
  #boolean level
  +updateLevel()
  +deleteId()
  +findTotal()
}
interface Student {
  -int code
  +String note
  #float description
  #Date name
  +createDuration()
  +updateLevel()
}
abstract class Grade {
  +String name
  -double active
  -int amount
  -long level
  +long description
  +getActive()
  +findDescription()
  +validateScore()
}
Teacher --o Student
Teacher --|> Classroom
Student ..> Teacher : "*"
note right of Teacher : Education domain
@enduml