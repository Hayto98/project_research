@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
interface Teacher {
  #float score
  -float name
  -float createdAt
  +double updatedAt
  +saveNote()
  +getActive()
}
abstract class Student {
  -Date name
  +long amount
  +getQuantity()
}
abstract class Attendance {
  #String score
  #boolean createdAt
  -String description
  +setUpdatedat()
  +saveType()
  +setDescription()
}
abstract class Enrollment {
  -String code
  #String name
  -String status
  -long total
  +sendScore()
}
interface Grade {
  -int type
  #boolean id
  +calculatePrice()
  +updateName()
  +deleteScore()
}
Student --* Attendance
Enrollment ..|> Student
@enduml