@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
interface Category {
  #boolean amount
  -Date price
  +processStatus()
  +sendType()
}
class Shipment {
  +float score
  #int id
  #double type
  +cancelDuration()
}
interface Customer {
  #long note
  #Date updatedAt
  +double description
  +sendScore()
}
abstract class Invoice {
  -double updatedAt
  #double type
  +saveCode()
  +setEmail()
  +sendCode()
  +validateActive()
}
abstract class Wishlist {
  -Date type
  +String createdAt
  +String name
  #Date score
  +float level
  +setTotal()
  +findNote()
  +processQuantity()
  +processPhone()
}
Invoice ..> Wishlist : "0..1"
Wishlist --|> Customer
note right of Category : Ecommerce domain
@enduml