@startuml
skinparam defaultFontSize 11
class Shipment {
  #float total
  #float address
  +validateTotal()
  +createScore()
  +cancelCreatedat()
}
abstract class Depot {
  #boolean note
  #String description
  #float active
  #Date code
  -int amount
  +saveTotal()
}
abstract class Manifest {
  +double score
  #int total
  +updateQuantity()
  +cancelUpdatedat()
  +deleteDescription()
  +saveType()
}
class Inventory {
  +Date id
  -float price
  +findDuration()
}
class FuelLog {
  #float status
  #Date total
  #boolean amount
  +calculateCode()
  +getDescription()
  +validateCode()
  +createType()
}
abstract class Package {
  +long quantity
  +float status
  #double price
  +processNote()
}
interface Driver {
  #long amount
  #int total
  -String duration
  #long score
  +findEmail()
  +createId()
  +setAddress()
}
FuelLog --|> Shipment
Shipment ..> Manifest : "1"
FuelLog --o Inventory
Shipment --o FuelLog
@enduml