}
class Manifest {
  -Date score
  +boolean quantity
  #Date level
  +createQuantity()
  +updateTotal()
  +findPrice()
  +sendCreatedat()
}
Depot --o FuelLog
Manifest --> Depot : "*"
note right of Inventory : Logistics domain
@enduml