@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
abstract class Inventory {
  #double note
  #double status
  #long price
  +int code
  +deletePhone()
  +sendTotal()
}
class Depot {
  #float price
  #long type
  #long score
  #double duration
  +deleteScore()
}
interface FuelLog {
  #int total
  #long name
  #float amount
  +int phone
