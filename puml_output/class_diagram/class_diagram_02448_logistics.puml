@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
abstract class Inventory {
  #double note
  #double status
  #long price
  +int code
  +createCreatedat()
  +findCode()
}
interface Depot {
  #float id
  -boolean score
  #long address
  #long price
  #double type
  +findId()
}
interface FuelLog {
  #int total
  #long name
  #float amount
  +int phone
  -float email
  +deleteCreatedat()
}
class Manifest {
  -Date description
  +boolean score
  #Date quantity
  -long level
  +processActive()
  +calculateQuantity()
  +deleteType()
}
Depot --> Inventory : "0..1"
Manifest --o FuelLog
FuelLog --o Manifest
@enduml