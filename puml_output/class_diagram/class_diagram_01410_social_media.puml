@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Profile {
  +long createdAt
  +double status
  #double code
  +Date email
  +updateDuration()
  +findId()
  +processQuantity()
  +findId()
}
class Report {
  #boolean createdAt
  +long updatedAt
  -String code
  +validateDescription()
  +findId()
  +processPhone()
}
abstract class Follower {
  -Date score
  #boolean email
  #Date createdAt
  +long active
  +deletePrice()
}
abstract class Story {
  +boolean code
  -long active
  +cancelLevel()
  +calculateId()
  +deleteLevel()
}
class Hashtag {
  -boolean total
  #float duration
  #long name
  +saveQuantity()
  +validateCode()
}
interface Notification {
  +long id
  #int description
  +setNote()
}
Notification --|> Hashtag
Notification --o Profile
Story ..> Follower : "1..*"
note right of Profile : Social Media domain
@enduml