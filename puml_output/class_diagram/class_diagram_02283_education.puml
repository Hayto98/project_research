@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Teacher {
  #boolean status
  -double level
  +getTotal()
  +getLevel()
  +calculateNote()
}
abstract class Grade {
  -double phone
  #boolean quantity
  +processNote()
  +sendPrice()
}
class Schedule {
  +float note
  -float level
  #long name
  +updatePhone()
}
class Student {
  #double active
  +double duration
  +boolean price
  +double status
  #double level
  +cancelStatus()
}
Schedule --* Grade
Schedule --|> Teacher
note right of Teacher : Education domain
@enduml