@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Teacher {
  #boolean status
  -double level
  +processName()
  +getAddress()
  +calculateId()
}
interface Grade {
  -double note
  #boolean type
  +float id
  -double phone
  #double quantity
  +deleteEmail()
}
class Schedule {
  +int level
  #long name
  +Date description
  -boolean address
  #boolean quantity
  +setStatus()
  +processPhone()
  +deleteStatus()
  +processId()
}
class Student {
  #double id
  +boolean total
  +String createdAt
  #Date name
  -long price
  +processId()
  +getCreatedat()
  +createEmail()
}
Grade ..> Teacher : "0..1"
Schedule --|> Grade
Teacher --> Schedule : "1..*"
@enduml