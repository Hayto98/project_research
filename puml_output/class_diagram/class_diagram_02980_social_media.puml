@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Comment {
  #String quantity
  +int score
  +calculatePrice()
  +getStatus()
  +calculateDescription()
  +findStatus()
}
interface Follower {
  +String score
  -int name
  +double total
  -long type
  -Date level
  +validateScore()
}
class User {
  +float id
  #String code
  -double email
  +long score
  +cancelCode()
  +saveType()
  +processDuration()
}
class Post {
  -String note
  -long quantity
  +createAmount()
}
Post --o Comment
Comment ..> User : "*"
Post ..> Follower : "*"
note right of Comment : Social Media domain
@enduml