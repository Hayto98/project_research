@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Comment {
  #String quantity
  +int score
  +findTotal()
  +calculateQuantity()
  +deleteAmount()
  +updateActive()
}
class Follower {
  #float description
  -String status
  +String note
  -int name
  +double total
  +deleteCode()
  +calculateLevel()
  +deleteLevel()
  +validateDescription()
}
abstract class User {
  +float phone
  -Date score
  +getLevel()
}
interface Post {
  -String email
  -long code
  #Date level
  +Date note
  +calculateAmount()
  +validateActive()
  +updateName()
  +updateCode()
}
Post --* Follower
Comment --* Follower
@enduml