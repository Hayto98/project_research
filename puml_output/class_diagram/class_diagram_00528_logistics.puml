@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Shipment {
  -Date createdAt
  #Date price
  +String active
  +findEmail()
  +deleteTotal()
  +updateActive()
}
abstract class Customer {
  +Date quantity
  #Date total
  -boolean code
  -long duration
  +getUpdatedat()
  +getNote()
}
class Tracking {
  #boolean type
  #long name
  -Date id
  +updateLevel()
}
interface FuelLog {
  +double score
  +String id
  +processId()
  +findPrice()
}
class Manifest {
  #double name
  -String phone
  +int total
  +processDescription()
  +findScore()
  +findStatus()
  +cancelScore()
}
class Warehouse {
  -float status
  #boolean code
  +setLevel()
  +sendTotal()
  +sendCreatedat()
  +findLevel()
}
class Route {
  +String duration
  #float status
  -double active
  +float note
  #Date email
  +updateScore()
  +getDescription()
}
Manifest --o Tracking
FuelLog ..|> Shipment
Shipment --> Customer : "0..1"
note right of Shipment : Logistics domain
@enduml