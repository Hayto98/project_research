@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Shipment {
  -Date createdAt
  #Date price
  +String active
  +calculateStatus()
  +processCreatedat()
  +findCreatedat()
}
class Customer {
  #Date createdAt
  #double active
  +long price
  +Date quantity
  #Date level
  +deleteUpdatedat()
  +deleteEmail()
  +findCode()
  +findEmail()
}
class Tracking {
  -long name
  #Date updatedAt
  +double duration
  +validateStatus()
}
class FuelLog {
  #boolean note
  #String status
  +double createdAt
  +String id
  +processTotal()
  +processName()
}
abstract class Manifest {
  #double updatedAt
  #double name
  -String phone
  +processPrice()
  +getPhone()
}
abstract class Warehouse {
  +float score
  +String status
  +float duration
  +deletePhone()
  +deleteTotal()
  +deleteEmail()
}
interface Route {
  #boolean status
  -double level
  #Date active
  #String total
  #boolean createdAt
  +deleteDescription()
  +createId()
  +validateAddress()
  +deleteScore()
}
Warehouse --o FuelLog
Customer ..> Warehouse : "0..1"
@enduml