@startuml

interface Patient {
  -double code
  -String status
  #double note
  -Date address
  +String id
  +cancelPrice()
  +saveAddress()
  +findType()
}
class LabTest {
  +float description
  #int amount
  +validateDescription()
  +getScore()
}
abstract class Ward {
  #Date type
  #int phone
  +Date email
  -boolean score
  #int code
  +updateAddress()
}
abstract class Doctor {
  #boolean score
  #int total
  +float active
  -double updatedAt
  -String createdAt
  +getType()
}
class Appointment {
  -long status
  -float amount
  #String code
  +Date updatedAt
  -float duration
  +createType()
}
class Diagnosis {
  -float price
  #long level
  -long type
  +findAmount()
  +validateName()
  +cancelId()
  +setPrice()
}
LabTest --> Doctor : "*"
Ward --> Patient : "1"
Ward ..|> Appointment
Ward --o LabTest
@enduml