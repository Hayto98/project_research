@startuml

interface Patient {
  -double code
  -String status
  #double note
  -Date address
  +String id
  +saveAmount()
  +setId()
  +deleteAmount()
}
class LabTest {
  -double duration
  -float description
  #Date active
  +createEmail()
  +cancelCode()
  +findScore()
}
class Ward {
  +Date note
  +Date level
  -double score
  +sendUpdatedat()
  +cancelCreatedat()
  +saveActive()
  +sendDescription()
}
class Doctor {
  +String note
  -String phone
  +float status
  #boolean name
  +sendUpdatedat()
}
class Appointment {
  #long quantity
  #String note
  #int name
  +float status
  +saveDuration()
  +cancelType()
  +createLevel()
  +validateTotal()
}
class Diagnosis {
  #Date total
  -boolean type
  -long phone
  +boolean quantity
  #float amount
  +createLevel()
}
Ward --o LabTest
Appointment ..> Ward : "*"
LabTest --* Patient
note right of Patient : Healthcare domain
@enduml