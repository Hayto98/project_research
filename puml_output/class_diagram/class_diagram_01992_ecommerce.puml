@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Category {
  +float duration
  +String status
  +String email
  +calculateScore()
  +sendScore()
}
class Payment {
  +long price
  #String level
  #String createdAt
  +getQuantity()
  +sendId()
  +findDuration()
}
class Review {
  #boolean email
  #boolean amount
  #int code
  -double quantity
  +findName()
}
interface Shipment {
  -String price
  #int name
  #long amount
  +updateDescription()
  +setTotal()
  +setAmount()
  +saveStatus()
}
class Supplier {
  -boolean address
  #int level
  #float quantity
  +getAmount()
  +cancelStatus()
}
abstract class Wishlist {
  #String address
  #int quantity
  +sendPrice()
  +findEmail()
}
Shipment --o Supplier
@enduml