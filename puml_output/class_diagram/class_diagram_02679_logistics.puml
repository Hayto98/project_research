@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Driver {
  #double phone
  -long id
  +updateLevel()
  +sendCreatedat()
  +getAmount()
}
interface Depot {
  -float email
  -double code
  -boolean total
  +saveActive()
  +setAmount()
}
class Inventory {
  -int total
  -double code
  -boolean quantity
  -int price
  #long amount
  +deleteCode()
  +getLevel()
  +calculateStatus()
  +updateTotal()
}
interface Manifest {
  #double quantity
  -boolean score
  -long total
  #String level
  +deletePhone()
  +saveLevel()
}
class Route {
  #int address
  +double active
  +cancelPhone()
  +savePhone()
}
Depot --> Manifest : "1..*"
Manifest ..> Inventory : "1..*"
Depot --o Route
Driver --|> Manifest
@enduml