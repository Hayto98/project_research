@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
abstract class Follower {
  -long status
  +boolean createdAt
  -Date type
  #boolean phone
  -float score
  +createDuration()
  +validateUpdatedat()
  +processCreatedat()
}
class Post {
  #double total
  #double duration
  +setType()
  +validateType()
}
interface Group {
  +String total
  -int updatedAt
  +String quantity
  +boolean score
  +double note
  +findEmail()
  +calculateStatus()
  +sendAddress()
}
abstract class Comment {
  -long active
  -double name
  +String phone
  #double amount
  +calculateUpdatedat()
  +createAddress()
  +cancelId()
}
class User {
  #double email
  #long id
  -double active
  -String duration
  -long address
  +createQuantity()
}
class Profile {
  #String quantity
  #long amount
  -double id
  -boolean total
  +setScore()
  +getAddress()
  +updatePhone()
}
Follower --* User
User --> Group : "*"
note right of Follower : Social Media domain
@enduml