@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Report {
  -float duration
  +String status
  +Date email
  -long type
  +long description
  +setNote()
  +calculateAmount()
  +validateAddress()
}
abstract class Follower {
  +String level
  -double description
  +String name
  +float email
  +saveLevel()
  +calculateActive()
}
interface User {
  #long level
  -double amount
  #int quantity
  +validateAddress()
  +updateAmount()
  +deleteName()
}
interface Post {
  -int active
  +String price
  #String phone
  +setName()
  +calculateType()
}
abstract class Like {
  #long total
  -float code
  +long note
  #long duration
  +int price
  +processTotal()
  +updateName()
  +updateUpdatedat()
  +updateQuantity()
}
Report ..> Post : "0..1"
User --* Like
User ..|> Report
@enduml