@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Report {
  -float duration
  +String status
  +Date email
  -long type
  +long description
  +calculateNote()
  +createType()
  +createLevel()
}
interface Follower {
  +double name
  -int email
  +int id
  +sendDuration()
  +updateLevel()
}
class User {
  #int score
  -long phone
  -boolean price
  +boolean total
  +validateEmail()
  +updateCreatedat()
  +setActive()
  +getDuration()
}
interface Post {
  -String id
  -float total
  -double note
  +processCreatedat()
  +createScore()
  +validateUpdatedat()
}
class Like {
  -Date note
  #int status
  -long level
  -float price
  -String code
  +createPhone()
  +cancelLevel()
}
Report ..|> Post
Report --|> Follower
Report --> Like : "1"
note right of Report : Social Media domain
@enduml