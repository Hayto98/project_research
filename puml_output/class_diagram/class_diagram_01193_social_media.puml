@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
interface Story {
  -String phone
  -long level
  +long status
  #boolean note
  +createId()
  +cancelActive()
  +getCreatedat()
}
class Comment {
  #Date note
  +Date phone
  #String quantity
  -float active
  +saveCreatedat()
}
class Notification {
  -String score
  -Date address
  #Date price
  -Date active
  #String code
  +deleteAddress()
  +deleteNote()
}
abstract class Follower {
  #Date id
  #String amount
  #Date level
  +updateNote()
  +deletePhone()
}
abstract class Profile {
  -Date duration
  +Date quantity
  -double code
  #long id
  +long createdAt
  +createDescription()
  +findLevel()
  +deleteScore()
  +saveDescription()
}
class User {
  #int price
  +int description
  -Date quantity
  -int note
  +long email
  +calculateQuantity()
}
class Message {
  #String quantity
  #float type
  +float createdAt
  #double address
  -double name
  +sendUpdatedat()
}
Profile ..|> Comment
Follower --* Notification
@enduml