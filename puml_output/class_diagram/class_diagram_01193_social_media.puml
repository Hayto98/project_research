@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
interface Story {
  -String phone
  -long level
  +long status
  #boolean note
  +cancelScore()
  +createPhone()
  +saveNote()
}
class Comment {
  +long active
  +long level
  +boolean status
  -boolean duration
  +calculateActive()
  +sendDuration()
  +setPhone()
}
class Notification {
  +double email
  +String code
  +int description
  #Date updatedAt
  +findAmount()
}
interface Follower {
  -Date total
  +Date quantity
  -double code
  #long id
  +long createdAt
  +sendAmount()
  +findCreatedat()
  +savePrice()
  +calculateDescription()
}
class Profile {
  #long email
  +String description
  -float name
  #float level
  #String total
  +setType()
  +createType()
  +updateAddress()
  +saveName()
}
class User {
  +Date total
  +boolean type
  +int price
  +validateEmail()
  +validatePrice()
  +deleteAddress()
  +saveType()
}
class Message {
  +long level
  +float note
  +Date code
  -String createdAt
  +processLevel()
  +setType()
  +sendCreatedat()
  +setStatus()
}
Notification --o User
User --> Message : "0..1"
Story ..> User : "1"
note right of Story : Social Media domain
@enduml