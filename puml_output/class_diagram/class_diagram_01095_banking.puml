@startuml
skinparam monochrome true
skinparam shadowing true
class Teller {
  -String type
  +float createdAt
  -long name
  +cancelDescription()
  +cancelNote()
  +getNote()
}
class Card {
  -int address
  +double email
  +getCreatedat()
}
class Loan {
  #Date type
  +float createdAt
  -Date score
  -int code
  +processActive()
  +findScore()
}
class Statement {
  +boolean description
  -double price
  +long score
  #Date phone
  +validateCreatedat()
}
class Withdrawal {
  +int type
  #Date price
  -float name
  +findEmail()
  +processPrice()
  +cancelNote()
}
interface Branch {
  -Date amount
  -Date total
  +long duration
  -double quantity
  +Date updatedAt
  +getCreatedat()
  +setDescription()
  +setEmail()
  +findLevel()
}
Statement ..|> Teller
Loan ..> Statement : "1..*"
@enduml