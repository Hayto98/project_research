@startuml
skinparam monochrome true
skinparam shadowing true
class Teller {
  -String type
  +float createdAt
  -long name
  +findCreatedat()
  +createId()
  +saveName()
}
class Card {
  +boolean address
  -long amount
  -float level
  +boolean price
  +sendDescription()
}
class Loan {
  -float createdAt
  -Date description
  +double duration
  #boolean quantity
  +deleteDuration()
  +processNote()
  +getQuantity()
}
interface Statement {
  +double description
  -String amount
  +updatePrice()
}
interface Withdrawal {
  +double updatedAt
  #int createdAt
  #long active
  +long type
  +saveDescription()
  +validatePhone()
  +processName()
  +findTotal()
}
interface Branch {
  +double address
  +int score
  +calculateLevel()
  +cancelDuration()
  +validateStatus()
}
Statement ..|> Teller
Branch --* Teller
Loan ..|> Teller
note right of Teller : Banking domain
@enduml