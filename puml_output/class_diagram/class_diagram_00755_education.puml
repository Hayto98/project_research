@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
abstract class Course {
  +Date duration
  #boolean id
  +createLevel()
  +setQuantity()
  +deleteStatus()
  +deleteStatus()
}
class Exam {
  -int status
  -double amount
  +validateAmount()
}
class Student {
  -long updatedAt
  #float code
  +double total
  -double type
  +calculateTotal()
  +sendName()
  +createName()
  +createCode()
}
class Assignment {
  +int code
  -boolean type
  +double address
  +deleteCode()
}
class Attendance {
  +float address
  #String score
  +findCode()
}
class Enrollment {
  -int name
  #int note
  -boolean phone
  #float level
  +cancelActive()
}
class Department {
  -long address
  -float duration
  -float status
  +findAmount()
  +deleteLevel()
  +saveNote()
  +saveDescription()
}
Student --o Exam
Enrollment ..|> Exam
Department ..> Course : "1"
Attendance ..> Student : "1..*"
Assignment --> Exam : "0..1"
note right of Course : Education domain
@enduml