@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
abstract class Course {
  +Date duration
  #boolean id
  +updateQuantity()
  +calculatePhone()
  +deleteUpdatedat()
  +processAmount()
}
class Exam {
  #float status
  +String description
  +int duration
  +processPrice()
  +calculateName()
  +createDuration()
  +processId()
}
class Student {
  +double amount
  #float description
  -float phone
  -long updatedAt
  +cancelQuantity()
}
class Assignment {
  +float total
  -float duration
  #String level
  -boolean name
  +String quantity
  +findQuantity()
  +updateDuration()
  +getStatus()
  +validateCode()
}
class Attendance {
  +String price
  +boolean status
  +getDuration()
}
class Enrollment {
  +Date level
  +long status
  +savePhone()
  +saveAmount()
  +calculateStatus()
}
class Department {
  #boolean quantity
  #long updatedAt
  #Date createdAt
  +long price
  -boolean code
  +updateLevel()
}
Assignment --> Department : "*"
Enrollment ..|> Exam
Attendance --o Enrollment
@enduml