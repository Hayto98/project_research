@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
abstract class Post {
  #Date price
  #String amount
  +cancelEmail()
  +setUpdatedat()
  +setDuration()
}
class Profile {
  +Date code
  -long email
  -Date score
  -boolean phone
  #String description
  +getNote()
}
abstract class Story {
  -int createdAt
  #float id
  #float duration
  -String active
  #double updatedAt
  +findDuration()
  +processAmount()
}
interface Follower {
  +float level
  #double name
  -long status
  +cancelCreatedat()
  +deleteEmail()
  +calculateType()
}
class Group {
  #long id
  -int amount
  -double price
  +calculateId()
  +processName()
  +findDescription()
}
Follower --> Group : "0..1"
Profile --o Post
Group --> Profile : "1..*"
@enduml