@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Transfer {
  #float amount
  #Date level
  #int price
  +updateAddress()
  +saveCreatedat()
  +getCode()
}
interface Loan {
  -String id
  +boolean description
  #Date type
  +getAddress()
  +processCreatedat()
  +updateLevel()
  +getDescription()
}
class Deposit {
  +float address
  -long name
  -Date description
  #Date updatedAt
  +boolean amount
  +calculateLevel()
  +getUpdatedat()
  +processPhone()
}
class Withdrawal {
  -String type
  +boolean id
  -int createdAt
  -String total
  +saveTotal()
  +deleteScore()
  +cancelAddress()
  +calculateLevel()
}
Deposit --o Withdrawal
Loan --* Deposit
Transfer ..> Deposit : "*"
@enduml