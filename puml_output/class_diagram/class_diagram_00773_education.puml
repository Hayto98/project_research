@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Book {
  +double score
  +double phone
  +boolean description
  -long type
  +deleteQuantity()
  +findScore()
  +updateUpdatedat()
}
class Student {
  #boolean updatedAt
  -String active
  -long type
  +boolean duration
  #boolean quantity
  +getLevel()
  +setLevel()
  +sendScore()
  +findAmount()
}
abstract class Classroom {
  +int quantity
  -double duration
  +Date description
  +processScore()
  +validateNote()
  +deleteId()
  +getAddress()
}
interface Assignment {
  -boolean id
  #int description
  +sendName()
  +deleteNote()
  +getAddress()
  +findCreatedat()
}
interface Schedule {
  #int type
  -float active
  +calculateScore()
  +deleteType()
}
class Library {
  -double name
  +int type
  #int active
  #String description
  +sendCreatedat()
}
class Attendance {
  #double score
  +boolean note
  +saveCode()
}
Schedule --* Attendance
Book ..> Library : "*"
Classroom ..> Schedule : "1..*"
Student --* Book
Library --> Classroom : "1..*"
Book --* Assignment
@enduml