@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Book {
  +double score
  +double phone
  +boolean description
  -long type
  +setQuantity()
  +setAmount()
  +processUpdatedat()
}
interface Student {
  -String updatedAt
  #float quantity
  #boolean email
  #double id
  +int price
  +calculateNote()
  +updateQuantity()
  +createDescription()
  +deleteCreatedat()
}
abstract class Classroom {
  +int createdAt
  -boolean type
  #int updatedAt
  -double total
  +double status
  +sendStatus()
  +saveType()
  +sendUpdatedat()
}
class Assignment {
  +double email
  #boolean status
  +double phone
  +setDescription()
  +saveDescription()
  +saveCode()
  +getType()
}
class Schedule {
  #double score
  +boolean note
  +calculateActive()
}
interface Library {
  +String name
  -Date price
  -boolean quantity
  -String phone
  +createId()
  +deletePhone()
  +getActive()
  +createUpdatedat()
}
class Attendance {
  +double duration
  -String score
  -boolean phone
  #float quantity
  +double status
  +setActive()
  +cancelPhone()
  +findAddress()
}
Assignment ..|> Library
Book --> Student : "*"
note right of Book : Education domain
@enduml