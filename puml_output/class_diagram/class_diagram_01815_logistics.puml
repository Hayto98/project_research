@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Manifest {
  +double total
  #double phone
  -long price
  +String email
  +updateNote()
  +setActive()
  +getCreatedat()
  +saveDescription()
}
class DeliveryNote {
  +float amount
  +boolean duration
  +long status
  +findId()
  +cancelAmount()
  +processType()
  +cancelStatus()
}
interface FuelLog {
  #Date status
  #Date active
  +createLevel()
}
class Tracking {
  #Date address
  +long level
  +setTotal()
  +cancelPrice()
}
interface Customer {
  #float level
  #int createdAt
  -Date status
  +saveLevel()
}
class Package {
  -boolean description
  #double updatedAt
  #float level
  -boolean status
  +getActive()
  +getPrice()
  +setNote()
}
class Depot {
  -double createdAt
  -float name
  #float description
  +sendActive()
  +cancelPrice()
  +deleteEmail()
}
Package ..> Customer : "1"
Manifest --> DeliveryNote : "*"
Tracking --* FuelLog
Tracking ..|> Customer
@enduml