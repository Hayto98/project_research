@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Inventory {
  -float id
  +double email
  +boolean active
  -String note
  +setId()
  +calculatePhone()
  +createNote()
}
abstract class Vehicle {
  #long note
  +String active
  -int amount
  -boolean email
  +validatePhone()
}
interface Shipment {
  #double note
  #Date price
  #long address
  +updateUpdatedat()
  +getActive()
  +processCreatedat()
  +calculateScore()
}
class Warehouse {
  -int name
  #String quantity
  -String duration
  -Date createdAt
  +cancelId()
  +calculateDuration()
}
interface Route {
  +long id
  +String active
  +long score
  +updatePrice()
  +validateLevel()
  +createAmount()
  +cancelNote()
}
class Tracking {
  #double email
  #boolean description
  +deleteQuantity()
  +cancelDuration()
}
class Depot {
  -Date amount
  #double description
  +Date name
  +cancelNote()
  +findScore()
  +updateAmount()
}
Depot --o Route
Inventory --* Route
@enduml