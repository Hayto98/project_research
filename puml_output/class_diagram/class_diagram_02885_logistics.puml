@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Inventory {
  -float id
  +double email
  +boolean active
  -String note
  +cancelQuantity()
  +findTotal()
  +createNote()
}
interface Vehicle {
  +long email
  +float duration
  -boolean updatedAt
  +setScore()
}
class Shipment {
  #float price
  -String address
  #long total
  +boolean active
  -String quantity
  +findName()
  +findCreatedat()
  +validateCreatedat()
}
interface Warehouse {
  -Date type
  +long status
  +getDuration()
  +saveActive()
}
interface Route {
  +long quantity
  -String status
  -int level
  +setEmail()
  +deleteDuration()
}
abstract class Tracking {
  +int status
  +long quantity
  #float amount
  +setPhone()
  +updateQuantity()
  +setDuration()
  +calculateName()
}
interface Depot {
  -boolean id
  +Date active
  +int duration
  -double status
  +deleteActive()
  +cancelType()
  +setStatus()
}
Tracking --|> Route
Route --> Vehicle : "1"
note right of Inventory : Logistics domain
@enduml