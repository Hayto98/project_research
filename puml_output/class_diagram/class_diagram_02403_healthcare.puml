@startuml
skinparam monochrome true
skinparam defaultFontSize 13
abstract class Diagnosis {
  +Date phone
  -float duration
  -float total
  +deleteId()
  +sendType()
}
abstract class Patient {
  -float description
  -boolean createdAt
  +calculateStatus()
  +saveDuration()
  +validateQuantity()
  +findType()
}
class Appointment {
  -boolean duration
  -int quantity
  +long createdAt
  +long note
  +saveScore()
}
class Ward {
  +int status
  -String email
  #double active
  -double total
  #float code
  +processCreatedat()
  +validateDuration()
  +processLevel()
  +saveNote()
}
Appointment --o Patient
@enduml