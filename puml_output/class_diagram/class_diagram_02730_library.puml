@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Renewal {
  +String score
  +int quantity
  +processEmail()
}
class Book {
  +float name
  #long quantity
  -double status
  +float note
  +processActive()
}
interface Reservation {
  #String code
  -long note
  #double active
  -float description
  +int name
  +calculateTotal()
  +processCreatedat()
  +setUpdatedat()
  +sendPhone()
}
abstract class Catalog {
  -double amount
  -boolean code
  +Date id
  +updateNote()
  +processScore()
  +sendAmount()
}
class Shelf {
  +float name
  +float updatedAt
  #Date address
  -double code
  +saveCode()
}
Reservation ..> Catalog : "1..*"
Shelf ..|> Book
@enduml