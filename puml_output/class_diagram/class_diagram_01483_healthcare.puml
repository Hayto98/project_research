@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Prescription {
  -int phone
  -float name
  +deleteType()
  +setType()
}
class Hospital {
  #String code
  +float level
  +long createdAt
  #long updatedAt
  +processDescription()
}
interface Ward {
  +double note
  #double price
  #String updatedAt
  +float active
  #float id
  +createLevel()
  +cancelId()
  +getLevel()
}
class Billing {
  #float email
  +long updatedAt
  +updateName()
  +deleteCode()
}
Billing --|> Ward
Prescription --o Ward
note right of Prescription : Healthcare domain
@enduml