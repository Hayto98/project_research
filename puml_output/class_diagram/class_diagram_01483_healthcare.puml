@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Prescription {
  -int phone
  -float name
  +deletePhone()
  +createCode()
}
abstract class Hospital {
  #long type
  +boolean amount
  +updateStatus()
  +validateActive()
}
class Ward {
  +double status
  +boolean email
  #float phone
  +saveStatus()
  +calculateStatus()
  +updateAddress()
  +calculateLevel()
}
abstract class Billing {
  #double updatedAt
  #String active
  +float id
  #float status
  #Date type
  +calculateLevel()
  +findCreatedat()
  +findEmail()
}
Prescription --* Ward
Prescription ..|> Hospital
@enduml