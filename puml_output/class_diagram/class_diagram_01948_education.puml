@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Schedule {
  -long id
  #boolean email
  #float active
  #boolean duration
  #boolean code
  +processName()
  +updateId()
  +calculateAmount()
}
class Exam {
  +int active
  #int quantity
  #int phone
  +int updatedAt
  +calculateAddress()
  +validateEmail()
  +getLevel()
  +saveScore()
}
abstract class Student {
  #float total
  -long code
  +Date level
  -Date address
  +sendName()
  +sendId()
  +validateType()
}
interface Course {
  +boolean score
  +boolean note
  +setName()
  +findNote()
  +getCode()
  +saveTotal()
}
Student ..> Course : "0..1"
Exam ..|> Schedule
@enduml