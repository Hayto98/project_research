@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Schedule {
  -long id
  #boolean email
  #float active
  #boolean duration
  #boolean code
  +getNote()
  +deleteActive()
  +cancelEmail()
}
interface Exam {
  #int phone
  #int updatedAt
  +int level
  -int createdAt
  +setPhone()
}
abstract class Student {
  #float total
  -long code
  +Date level
  -Date address
  +processCreatedat()
  +cancelActive()
  +cancelId()
}
interface Course {
  +String description
  #String level
  -Date id
  #int active
  +String price
  +getId()
  +cancelScore()
}
Schedule ..|> Exam
Course --o Student
Exam --|> Student
note right of Schedule : Education domain
@enduml