@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Category {
  #float active
  +float email
  +long description
  +createPrice()
}
class Coupon {
  #long status
  +String updatedAt
  +deleteStatus()
}
abstract class Return {
  -double status
  -boolean type
  -long address
  #boolean total
  +cancelUpdatedat()
  +getId()
}
class Wishlist {
  -float address
  +Date phone
  -String duration
  #String total
  +findNote()
  +findDuration()
  +validateAmount()
  +createAddress()
}
class Supplier {
  +long note
  +float email
  +boolean description
  +long status
  -double quantity
  +getStatus()
  +createNote()
  +updateId()
}
interface Cart {
  +String email
  -boolean phone
  +long status
  +double description
  +boolean updatedAt
  +setDescription()
  +validateQuantity()
  +processScore()
}
class Shipment {
  +Date level
  +boolean status
  +float duration
  +findNote()
  +findTotal()
  +createScore()
}
Return ..|> Shipment
Shipment --o Cart
Return ..> Cart : "1"
Wishlist --|> Cart
Wishlist ..> Return : "1..*"
note right of Category : Ecommerce domain
@enduml