@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Category {
  #float active
  +float email
  +long description
  +updateQuantity()
}
class Coupon {
  +String amount
  #String status
  +String level
  -boolean updatedAt
  -String email
  +findTotal()
  +findDescription()
  +validateType()
  +validateDuration()
}
abstract class Return {
  -boolean note
  #float quantity
  +boolean score
  +String address
  +cancelType()
}
class Wishlist {
  -float address
  +Date phone
  -String duration
  #String total
  +getDuration()
  +cancelName()
  +cancelQuantity()
  +updateScore()
}
interface Supplier {
  #double amount
  -float email
  -Date address
  +boolean phone
  +setTotal()
}
class Cart {
  -double code
  -Date duration
  -String active
  +long name
  +processPrice()
  +processCode()
  +sendQuantity()
  +processType()
}
class Shipment {
  +String status
  -boolean description
  +long active
  +double updatedAt
  +createStatus()
}
Shipment ..> Cart : "1..*"
Category --* Coupon
Shipment --o Return
Supplier ..|> Category
Category ..> Shipment : "0..1"
@enduml