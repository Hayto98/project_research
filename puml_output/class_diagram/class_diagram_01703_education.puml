@startuml
skinparam monochrome true
skinparam defaultFontSize 11
interface Student {
  +float score
  -boolean status
  +calculateTotal()
  +cancelEmail()
  +processScore()
  +findAmount()
}
abstract class Library {
  #int price
  -String email
  +long updatedAt
  +updateId()
  +saveDescription()
  +getCreatedat()
}
abstract class Enrollment {
  #double description
  #double updatedAt
  +int id
  +double code
  +updateCreatedat()
  +validatePrice()
}
class Assignment {
  +float phone
  -Date updatedAt
  +boolean name
  +float email
  +processScore()
  +savePrice()
  +cancelDescription()
}
interface Grade {
  +int quantity
  -String score
  -double active
  +long createdAt
  +getType()
  +setScore()
  +processActive()
  +updateId()
}
class Teacher {
  +int phone
  #String updatedAt
  -String createdAt
  -String level
  +calculateDescription()
  +getAmount()
}
Library --> Enrollment : "*"
Assignment ..|> Grade
Enrollment --> Assignment : "1"
note right of Student : Education domain
@enduml