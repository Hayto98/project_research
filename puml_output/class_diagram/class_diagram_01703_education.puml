@startuml
skinparam monochrome true
skinparam defaultFontSize 11
interface Student {
  +float score
  -boolean status
  +getAddress()
  +setNote()
  +findDescription()
  +validateAmount()
}
abstract class Library {
  -float total
  +Date amount
  +float price
  +setName()
  +updateUpdatedat()
  +deleteCreatedat()
  +saveUpdatedat()
}
class Enrollment {
  +Date id
  -long description
  +int name
  +processCreatedat()
}
class Assignment {
  -Date score
  +int price
  +long name
  -int amount
  #float updatedAt
  +findEmail()
  +sendType()
  +cancelId()
}
class Grade {
  -Date email
  +boolean amount
  +findTotal()
  +sendDuration()
}
class Teacher {
  #boolean score
  #boolean price
  #Date description
  +String phone
  +float quantity
  +processQuantity()
  +getPhone()
  +deleteActive()
  +processAmount()
}
Grade --|> Assignment
Assignment --> Student : "*"
Grade --|> Library
Library --* Enrollment
@enduml