@startuml

class Book {
  -float address
  -double type
  +calculateQuantity()
  +updateNote()
  +createUpdatedat()
}
class Assignment {
  +boolean amount
  +Date createdAt
  -String type
  +getDuration()
}
class Teacher {
  -long total
  +boolean phone
  -String score
  +setPrice()
  +deleteDuration()
  +createTotal()
}
abstract class Course {
  +Date note
  -float amount
  -double phone
  +processEmail()
  +sendStatus()
  +cancelTotal()
  +calculateCreatedat()
}
class Library {
  -int createdAt
  +float code
  #int price
  +saveCode()
  +deleteAddress()
  +sendActive()
  +getLevel()
}
class Classroom {
  #float score
  +String quantity
  #float type
  +deleteType()
  +saveAmount()
  +getAddress()
}
Teacher ..|> Book
Classroom --|> Assignment
Classroom ..|> Book
@enduml