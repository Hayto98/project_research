@startuml

class Book {
  -float address
  -double type
  +calculateActive()
  +sendCreatedat()
  +cancelUpdatedat()
}
class Assignment {
  +Date type
  -String status
  +float score
  +updateTotal()
  +validateScore()
  +calculateAddress()
}
class Teacher {
  #Date id
  +double quantity
  #int note
  -String score
  +validateNote()
  +saveTotal()
  +cancelId()
  +validateQuantity()
}
class Course {
  +String code
  #int price
  -double level
  +cancelCode()
  +getDescription()
}
interface Library {
  #double type
  -int id
  -String level
  +Date email
  +getStatus()
  +updateType()
}
class Classroom {
  +String type
  +double name
  +createTotal()
}
Library ..|> Classroom
Teacher --* Course
note right of Book : Education domain
@enduml