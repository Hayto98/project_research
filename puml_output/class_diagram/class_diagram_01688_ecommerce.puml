@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
interface Order {
  +long price
  -double address
  -float score
  +deleteNote()
  +saveActive()
  +validateScore()
}
class Wishlist {
  +int duration
  -Date note
  +double id
  +float total
  +Date code
  +saveAmount()
  +findActive()
  +cancelQuantity()
  +saveNote()
}
class Invoice {
  #String score
  +int email
  -float note
  #boolean total
  -float id
  +processLevel()
  +findDuration()
  +cancelLevel()
}
abstract class Product {
  +Date id
  +int description
  #String amount
  #long total
  -int status
  +setId()
  +validateId()
  +sendPhone()
}
interface Return {
  -Date amount
  -long status
  +float type
  +savePrice()
}
Invoice ..> Wishlist : "*"
Wishlist ..> Return : "1"
Product --|> Invoice
@enduml