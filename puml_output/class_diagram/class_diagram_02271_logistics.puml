@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Route {
  #Date createdAt
  +Date name
  #float type
  #String code
  +deleteAmount()
  +sendTotal()
  +validateTotal()
  +deletePrice()
}
class Vehicle {
  #int address
  #long id
  +Date active
  #double note
  +long quantity
  +calculateDescription()
}
class Package {
  #float amount
  #Date duration
  +String score
  +Date description
  +double name
  +createCreatedat()
  +findName()
}
abstract class FuelLog {
  +Date status
  -float email
  #long total
  +sendNote()
}
Vehicle --* Route
Vehicle --* FuelLog
note right of Route : Logistics domain
@enduml