@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Route {
  #Date createdAt
  +Date name
  #float type
  #String code
  +processScore()
  +findPhone()
  +calculateAddress()
  +cancelAmount()
}
abstract class Vehicle {
  -Date total
  -boolean description
  +boolean price
  -long level
  +sendQuantity()
  +processStatus()
}
class Package {
  -double status
  +int email
  #int duration
  #String price
  #float description
  +processAmount()
}
class FuelLog {
  +Date total
  #float createdAt
  +double quantity
  +deleteStatus()
  +deleteQuantity()
}
FuelLog ..> Route : "1..*"
Package --|> FuelLog
@enduml