@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
abstract class Assignment {
  #double amount
  -float type
  +boolean description
  +updatePhone()
}
interface Attendance {
  +Date total
  -boolean phone
  -long code
  +findName()
  +getName()
  +getStatus()
  +getPhone()
}
class Classroom {
  +float active
  -boolean duration
  +String email
  #Date note
  +processUpdatedat()
}
class Schedule {
  +long id
  #int quantity
  #int note
  +long description
  -String type
  +createLevel()
  +getCreatedat()
  +getCode()
}
Schedule --> Classroom : "*"
Classroom ..|> Schedule
note right of Assignment : Education domain
@enduml