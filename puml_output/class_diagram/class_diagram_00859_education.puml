@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
abstract class Assignment {
  #double amount
  -float type
  +boolean description
  +deleteAddress()
}
class Attendance {
  +Date total
  -boolean phone
  -long code
  +validateTotal()
  +saveEmail()
  +calculateId()
  +setUpdatedat()
}
class Classroom {
  +boolean name
  #long phone
  +processTotal()
  +validateNote()
  +validateDescription()
}
class Schedule {
  -float status
  +String level
  #boolean duration
  +cancelName()
  +processName()
  +setTotal()
  +calculateUpdatedat()
}
Attendance ..|> Schedule
Classroom ..|> Schedule
Attendance --* Assignment
@enduml