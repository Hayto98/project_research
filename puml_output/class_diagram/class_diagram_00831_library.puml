@startuml
skinparam defaultFontSize 11
class Shelf {
  -int note
  -int address
  +float updatedAt
  +createTotal()
  +sendQuantity()
  +saveTotal()
  +getPrice()
}
class Loan {
  +Date type
  -boolean price
  +int email
  -int quantity
  #long name
  +validateStatus()
}
class Renewal {
  +int active
  -int type
  #Date quantity
  -int phone
  +cancelDescription()
  +processActive()
}
class Member {
  #float note
  +long price
  -String updatedAt
  -float address
  +sendQuantity()
  +validateLevel()
}
class Reservation {
  #float phone
  +float total
  +String updatedAt
  #boolean active
  +createQuantity()
}
Reservation ..> Member : "1..*"
Renewal --o Loan
Reservation ..> Shelf : "0..1"
Member --> Renewal : "1..*"
note right of Shelf : Library domain
@enduml