@startuml
skinparam defaultFontSize 11
class Shelf {
  -int note
  -int address
  +float updatedAt
  +calculatePhone()
  +calculateQuantity()
  +cancelAmount()
  +cancelAddress()
}
abstract class Loan {
  -double price
  -long amount
  +processQuantity()
  +sendEmail()
  +createLevel()
}
class Renewal {
  #long createdAt
  +long type
  +String updatedAt
  +getScore()
  +saveType()
  +deleteLevel()
}
abstract class Member {
  +long score
  +float level
  #Date phone
  -int code
  +getQuantity()
  +getPrice()
}
class Reservation {
  +long active
  #float name
  +long address
  -String note
  -float price
  +calculateActive()
  +saveType()
}
Renewal --* Loan
Renewal --> Member : "0..1"
Reservation --|> Loan
@enduml