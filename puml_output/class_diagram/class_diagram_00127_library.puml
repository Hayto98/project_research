@startuml
skinparam defaultFontSize 11
interface Member {
  +long description
  -double quantity
  #long total
  +float phone
  +double id
  +updateDescription()
}
interface Fine {
  #int createdAt
  -boolean active
  +updateNote()
  +calculatePhone()
  +getPrice()
  +savePrice()
}
abstract class Librarian {
  +double phone
  -Date active
  +sendDescription()
  +cancelPrice()
}
interface Renewal {
  #long updatedAt
  #double active
  +setLevel()
  +getDuration()
  +getUpdatedat()
  +processAddress()
}
class Book {
  -String createdAt
  #boolean price
  +long amount
  #boolean note
  +getPrice()
  +validateName()
  +sendId()
}
interface Loan {
  #boolean name
  -String address
  -Date code
  -double createdAt
  +processName()
  +getLevel()
  +setDescription()
}
Renewal ..> Book : "1..*"
Renewal --> Member : "0..1"
Book --> Fine : "1..*"
@enduml