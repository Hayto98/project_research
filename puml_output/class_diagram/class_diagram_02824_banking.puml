@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Interest {
  +String active
  -boolean description
  +boolean createdAt
  +int price
  +int duration
  +calculateCode()
  +processCode()
  +findPrice()
}
class Beneficiary {
  +boolean level
  +boolean description
  #Date email
  +sendCode()
  +validateCreatedat()
  +createAmount()
  +setQuantity()
}
interface Branch {
  -int email
  +float active
  +long updatedAt
  -String name
  +setCreatedat()
  +deleteTotal()
}
class Deposit {
  #double email
  -int createdAt
  #double code
  -boolean address
  #long active
  +savePrice()
  +cancelActive()
  +saveCreatedat()
}
interface Statement {
  +String score
  #long address
  +updateNote()
}
Interest ..|> Deposit
Deposit --> Branch : "*"
note right of Interest : Banking domain
@enduml