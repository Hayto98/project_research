@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Interest {
  +String active
  -boolean description
  +boolean createdAt
  +int price
  +int duration
  +getStatus()
  +cancelCreatedat()
  +createAddress()
}
abstract class Beneficiary {
  +boolean price
  +long code
  +validateActive()
  +cancelEmail()
}
interface Branch {
  +String score
  -Date code
  #Date address
  -long createdAt
  #Date quantity
  +saveEmail()
  +setTotal()
}
class Deposit {
  +int code
  +int quantity
  +float email
  +processUpdatedat()
  +sendCode()
  +findCreatedat()
  +sendId()
}
interface Statement {
  -Date level
  -double address
  +cancelAmount()
  +deleteDuration()
}
Statement ..> Branch : "1..*"
Deposit --> Beneficiary : "1"
@enduml