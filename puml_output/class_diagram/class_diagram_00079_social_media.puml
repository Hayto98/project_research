@startuml
skinparam shadowing true
class User {
  +Date updatedAt
  +boolean description
  +String quantity
  #float active
  +int status
  +validateDuration()
  +findAmount()
  +cancelNote()
  +deleteTotal()
}
abstract class Message {
  #float price
  #boolean duration
  +updateAddress()
  +updateStatus()
  +processDuration()
}
class Comment {
  #Date type
  +int id
  -Date note
  +updateDuration()
}
class Hashtag {
  -int status
  #String updatedAt
  #String type
  #double createdAt
  +findNote()
  +updatePhone()
}
User ..|> Hashtag
Message --* User
Message --|> Comment
@enduml