@startuml
skinparam shadowing true
class User {
  +Date updatedAt
  +boolean description
  +String quantity
  #float active
  +int status
  +validateTotal()
  +updatePrice()
  +setPrice()
  +calculateActive()
}
interface Message {
  -String updatedAt
  #float duration
  -boolean code
  #String amount
  +validateStatus()
  +getAddress()
}
class Comment {
  #boolean updatedAt
  #int type
  +deleteLevel()
  +setDuration()
  +getType()
}
class Hashtag {
  +float price
  +int code
  +createCreatedat()
  +cancelStatus()
}
Comment ..> User : "1..*"
Hashtag ..> Message : "0..1"
note right of User : Social Media domain
@enduml