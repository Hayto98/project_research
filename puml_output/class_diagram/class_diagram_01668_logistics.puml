@startuml
skinparam shadowing true
interface Manifest {
  #Date phone
  +String description
  +String score
  +int createdAt
  -int status
  +validateDuration()
  +findPhone()
  +saveTotal()
  +deleteCreatedat()
}
class Customer {
  +int amount
  +float note
  #boolean type
  +saveStatus()
  +createCode()
  +findEmail()
  +setCode()
}
abstract class Package {
  +Date quantity
  #double name
  +calculateQuantity()
  +saveStatus()
  +calculateEmail()
}
class Route {
  -float level
  #Date price
  +findStatus()
  +processCode()
  +calculateUpdatedat()
  +setType()
}
class Depot {
  #float code
  +Date description
  +setType()
  +setAddress()
}
class Vehicle {
  +boolean description
  #boolean note
  #Date price
  +findNote()
  +saveUpdatedat()
  +setAddress()
}
Route --* Customer
Vehicle --|> Package
note right of Manifest : Logistics domain
@enduml