@startuml
skinparam shadowing true
interface Manifest {
  #Date phone
  +String description
  +String score
  +int createdAt
  -int status
  +processStatus()
  +findTotal()
  +findUpdatedat()
  +deleteType()
}
class Customer {
  #double description
  -int createdAt
  +String level
  #boolean updatedAt
  -float amount
  +validateAddress()
}
class Package {
  #long code
  +int duration
  #boolean total
  -long level
  +getStatus()
  +processDescription()
  +sendPrice()
  +setStatus()
}
abstract class Route {
  #Date createdAt
  -Date code
  #float price
  +double email
  +saveName()
}
class Depot {
  #String type
  +int status
  +createLevel()
  +findAddress()
}
class Vehicle {
  -double status
  +boolean address
  #boolean amount
  #Date description
  -Date active
  +getPrice()
  +findStatus()
  +deleteAddress()
  +createAddress()
}
Manifest ..> Route : "0..1"
Package --|> Vehicle
Customer --o Route
Depot --|> Route
@enduml