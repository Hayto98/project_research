@startuml
skinparam defaultFontSize 11
class Comment {
  +boolean name
  +long amount
  #double description
  #Date code
  +Date createdAt
  +calculateAddress()
  +updateDescription()
}
class Like {
  -Date name
  #int active
  #String level
  +sendUpdatedat()
  +sendPrice()
  +processUpdatedat()
  +processEmail()
}
class Message {
  #long email
  +long id
  #int amount
  +String score
  -double level
  +sendDuration()
  +createCreatedat()
}
class Album {
  -int total
  -long createdAt
  +int status
  +Date price
  +cancelLevel()
  +createAmount()
  +getQuantity()
  +saveCreatedat()
}
Comment --|> Like
Message --* Comment
@enduml