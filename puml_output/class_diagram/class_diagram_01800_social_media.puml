@startuml
skinparam defaultFontSize 11
class Comment {
  +boolean name
  +long amount
  #double description
  #Date code
  +Date createdAt
  +deleteCreatedat()
  +deleteUpdatedat()
}
class Like {
  #Date level
  +boolean createdAt
  +double active
  -String status
  +Date price
  +getAddress()
  +deleteAddress()
}
class Message {
  +Date status
  +Date address
  -long total
  +updateLevel()
  +setPrice()
  +calculateUpdatedat()
  +validateAddress()
}
class Album {
  #long amount
  #float note
  +String phone
  +setActive()
  +sendQuantity()
  +getPhone()
}
Comment --> Like : "*"
Message --|> Like
note right of Comment : Social Media domain
@enduml