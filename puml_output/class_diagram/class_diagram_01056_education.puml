@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
abstract class Attendance {
  #String description
  -String phone
  +float price
  +boolean total
  +saveCode()
  +getAddress()
}
abstract class Department {
  -String email
  +int type
  +updateCode()
  +getDescription()
  +setUpdatedat()
}
interface Enrollment {
  +boolean duration
  #float phone
  +getUpdatedat()
}
class Student {
  +double id
  -Date status
  +getEmail()
}
interface Teacher {
  +String total
  #long note
  +long phone
  #Date name
  +createScore()
  +saveStatus()
}
Student --o Teacher
Student ..> Enrollment : "*"
@enduml