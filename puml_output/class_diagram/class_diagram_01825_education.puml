@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
interface Attendance {
  +String level
  -boolean type
  +boolean quantity
  #String duration
  +String createdAt
  +cancelQuantity()
  +getCreatedat()
  +saveTotal()
  +getPhone()
}
interface Grade {
  +String updatedAt
  -long total
  #float level
  +float name
  #Date email
  +sendEmail()
  +setDuration()
  +setTotal()
  +calculateType()
}
class Course {
  #long description
  +Date level
  +validateAmount()
  +setLevel()
  +setTotal()
}
class Teacher {
  +int createdAt
  +int total
  -long id
  -Date description
  +getEmail()
  +setLevel()
  +getPhone()
  +createTotal()
}
Attendance ..> Teacher : "0..1"
Attendance --|> Course
note right of Attendance : Education domain
@enduml