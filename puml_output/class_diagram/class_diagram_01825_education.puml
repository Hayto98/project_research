@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
interface Attendance {
  +String level
  -boolean type
  +boolean quantity
  #String duration
  +String createdAt
  +sendStatus()
  +findDescription()
  +processDescription()
  +sendTotal()
}
class Grade {
  -float id
  +long phone
  +String type
  -long updatedAt
  #float total
  +deleteTotal()
  +setId()
}
abstract class Course {
  -String status
  +int duration
  #Date total
  -String price
  +calculateName()
  +deleteId()
  +sendLevel()
}
class Teacher {
  -long level
  -int code
  +updateDuration()
  +getEmail()
  +setType()
  +validateNote()
}
Grade --* Teacher
Course ..> Teacher : "*"
@enduml