@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
interface Patient {
  +double status
  #float price
  +double duration
  -float level
  +createUpdatedat()
  +getActive()
  +sendLevel()
}
interface MedicalRecord {
  +boolean amount
  -int createdAt
  #int status
  #long total
  -String level
  +deleteCode()
  +findId()
}
class Diagnosis {
  +boolean name
  #boolean note
  -long email
  -boolean level
  +processPhone()
  +getLevel()
  +calculateStatus()
}
class Doctor {
  +Date description
  #boolean status
  #boolean total
  -long updatedAt
  #boolean score
  +updateNote()
}
Diagnosis ..|> Patient
MedicalRecord ..> Diagnosis : "*"
@enduml