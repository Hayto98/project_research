@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
interface Patient {
  +double status
  #float price
  +double duration
  -float level
  +sendActive()
  +cancelPrice()
  +deleteCreatedat()
}
interface MedicalRecord {
  +boolean total
  -int createdAt
  +findPhone()
  +validateId()
}
class Diagnosis {
  #double amount
  -Date createdAt
  -int email
  #Date name
  +createAddress()
  +sendEmail()
  +setPhone()
}
interface Doctor {
  +Date description
  #boolean status
  #boolean total
  -long updatedAt
  #boolean score
  +sendLevel()
}
Diagnosis ..|> Patient
MedicalRecord ..> Diagnosis : "*"
note right of Patient : Healthcare domain
@enduml