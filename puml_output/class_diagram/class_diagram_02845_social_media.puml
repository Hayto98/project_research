@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Notification {
  -boolean quantity
  #double updatedAt
  +updateActive()
  +createCreatedat()
  +deleteType()
  +deleteAddress()
}
abstract class Group {
  -Date note
  -int email
  +String duration
  #Date code
  +setPhone()
}
interface Profile {
  +int duration
  +double phone
  +boolean status
  #int email
  +cancelType()
  +saveId()
  +saveNote()
  +createPhone()
}
abstract class Follower {
  #float amount
  -float code
  +saveAddress()
}
abstract class Report {
  -String price
  #boolean score
  #long level
  +long email
  +deleteAddress()
  +cancelUpdatedat()
  +getPhone()
}
class Comment {
  #boolean score
  +String quantity
  +boolean phone
  +validateActive()
  +deleteAmount()
}
class Hashtag {
  +long status
  -double note
  +cancelType()
  +updateNote()
}
Hashtag ..> Report : "1..*"
Report --* Hashtag
Comment --o Profile
Profile --* Hashtag
Comment --o Follower
@enduml