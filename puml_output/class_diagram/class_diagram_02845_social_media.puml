@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Notification {
  -boolean quantity
  #double updatedAt
  +getDescription()
  +findUpdatedat()
  +processQuantity()
  +processEmail()
}
abstract class Group {
  +int total
  +float quantity
  +cancelDuration()
}
interface Profile {
  +int duration
  +double phone
  +boolean status
  #int email
  +getCreatedat()
  +setPrice()
  +getAmount()
  +setNote()
}
class Follower {
  #boolean type
  #long address
  -String price
  +getEmail()
  +createUpdatedat()
  +findTotal()
}
class Report {
  #boolean score
  +String quantity
  +boolean phone
  +cancelPrice()
  +saveDescription()
}
class Comment {
  +long duration
  -double note
  +sendDuration()
  +cancelPhone()
}
interface Hashtag {
  -long address
  -Date type
  -double email
  -float quantity
  +calculateDescription()
  +saveUpdatedat()
  +getNote()
  +getCode()
}
Profile --|> Comment
Follower --|> Group
Hashtag ..> Comment : "*"
note right of Notification : Social Media domain
@enduml