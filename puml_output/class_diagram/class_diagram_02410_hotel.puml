@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Reservation {
  +double phone
  #int updatedAt
  +sendCreatedat()
  +getType()
}
interface Amenity {
  +float createdAt
  -float code
  +findDuration()
}
abstract class Payment {
  -double createdAt
  #float name
  +cancelScore()
  +setCode()
}
interface Booking {
  #double updatedAt
  #float duration
  +double email
  -Date total
  +sendPrice()
  +cancelCreatedat()
  +saveCode()
  +validateLevel()
}
Amenity ..|> Payment
Payment --* Booking
@enduml