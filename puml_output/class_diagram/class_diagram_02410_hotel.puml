@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Reservation {
  +double phone
  #int updatedAt
  +processCode()
  +cancelId()
}
class Amenity {
  +boolean status
  #Date email
  +getCreatedat()
  +getPhone()
  +calculateCreatedat()
  +saveLevel()
}
class Payment {
  #double updatedAt
  #float email
  +double total
  +findPrice()
  +saveTotal()
  +calculateDescription()
  +saveAmount()
}
class Booking {
  #boolean duration
  #boolean phone
  -boolean email
  +int amount
  +saveDuration()
  +processPrice()
}
Payment --|> Booking
Reservation ..|> Payment
note right of Reservation : Hotel domain
@enduml