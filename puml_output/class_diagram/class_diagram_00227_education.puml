@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Library {
  +double status
  #double total
  +String score
  +cancelQuantity()
  +getType()
  +createStatus()
  +getDuration()
}
abstract class Department {
  -String score
  -boolean duration
  +long status
  #double price
  +validateQuantity()
}
abstract class Grade {
  +boolean total
  -float createdAt
  +long email
  +long level
  +cancelPhone()
  +cancelScore()
  +saveQuantity()
}
abstract class Teacher {
  -float quantity
  +Date type
  #String code
  +setId()
}
Library --* Grade
Grade --o Department
Teacher --|> Grade
@enduml