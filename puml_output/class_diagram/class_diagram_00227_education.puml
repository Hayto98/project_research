@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Library {
  +double status
  #double total
  +String score
  +processCode()
  +sendNote()
  +validateScore()
  +sendStatus()
}
interface Department {
  #double quantity
  +int id
  -float address
  -float description
  #Date phone
  +cancelCreatedat()
  +createCreatedat()
  +getLevel()
  +calculateDescription()
}
class Grade {
  #int address
  -int phone
  -Date email
  +setPhone()
  +setDuration()
  +getCode()
  +cancelType()
}
class Teacher {
  #String email
  -String phone
  -double price
  -Date score
  +findPrice()
}
Grade ..|> Teacher
Teacher --|> Library
note right of Library : Education domain
@enduml