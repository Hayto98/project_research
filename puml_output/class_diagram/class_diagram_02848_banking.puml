@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Deposit {
  +boolean name
  +double duration
  #String level
  +getStatus()
}
interface Transaction {
  +String createdAt
  +int type
  -int name
  +sendLevel()
  +createActive()
  +processCreatedat()
}
class Loan {
  +float status
  -float type
  #int updatedAt
  #float total
  -boolean name
  +saveStatus()
  +cancelAddress()
}
abstract class Account {
  -Date updatedAt
  +Date type
  +boolean status
  -String note
  -long code
  +createAddress()
  +calculateUpdatedat()
  +validateCode()
}
class Teller {
  +String email
  #float active
  #long level
  +validatePhone()
  +updateUpdatedat()
  +cancelCreatedat()
  +setUpdatedat()
}
class Interest {
  -boolean score
  -float status
  +long price
  -int updatedAt
  +calculateScore()
}
Deposit --o Transaction
Transaction --> Teller : "*"
Teller --* Account
Deposit --|> Loan
@enduml