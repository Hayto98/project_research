@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Deposit {
  +boolean name
  +double duration
  #String level
  +cancelLevel()
}
class Transaction {
  +int type
  +long name
  +Date level
  +validateCode()
  +processStatus()
  +processUpdatedat()
}
interface Loan {
  #float duration
  -boolean name
  +float createdAt
  -Date note
  -boolean score
  +updateType()
  +saveStatus()
  +processCode()
  +processCode()
}
class Account {
  +Date name
  +int email
  +long phone
  #boolean level
  +getDuration()
  +saveAddress()
}
abstract class Teller {
  +String status
  -boolean total
  +calculateUpdatedat()
}
abstract class Interest {
  +long createdAt
  -float address
  +int price
  -int description
  +cancelNote()
  +validateStatus()
  +createId()
  +deleteTotal()
}
Interest --o Account
Interest --|> Loan
Account --* Loan
note right of Deposit : Banking domain
@enduml