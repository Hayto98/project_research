@startuml
skinparam monochrome true
skinparam shadowing true
class Warehouse {
  #String name
  #boolean phone
  -long email
  #Date duration
  +calculateAmount()
  +findPhone()
  +createName()
}
abstract class Shipment {
  +long address
  -int phone
  -Date id
  +validateCode()
  +validateActive()
  +setCode()
}
class Customer {
  +double score
  -double note
  +deleteId()
  +updateCreatedat()
  +sendAddress()
  +processQuantity()
}
abstract class Order {
  +Date type
  +String status
  #String level
  #double name
  +deleteTotal()
}
abstract class Supplier {
  -int description
  +String quantity
  +boolean updatedAt
  #double code
  +calculateLevel()
  +deletePhone()
}
class Product {
  +Date email
  -String quantity
  +calculatePhone()
  +sendNote()
  +saveActive()
  +findPrice()
}
Warehouse --* Order
Warehouse --o Customer
@enduml