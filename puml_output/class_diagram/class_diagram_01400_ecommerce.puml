@startuml
skinparam monochrome true
skinparam shadowing true
class Warehouse {
  #String name
  #boolean phone
  -long email
  #Date duration
  +processDescription()
  +processPrice()
  +sendUpdatedat()
}
class Shipment {
  +long id
  #long updatedAt
  +boolean quantity
  #long email
  +sendNote()
}
class Customer {
  #float price
  -Date duration
  -double type
  +String email
  +int name
  +setCode()
}
interface Order {
  #int name
  #String total
  -int address
  +String description
  +boolean quantity
  +deleteId()
  +getEmail()
  +saveQuantity()
  +updateQuantity()
}
class Supplier {
  +double quantity
  -String updatedAt
  #long score
  -float active
  #float code
  +processActive()
  +calculateTotal()
}
class Product {
  +float type
  +boolean price
  +getAddress()
  +processAddress()
  +cancelActive()
  +updateId()
}
Product --o Order
Product ..|> Warehouse
Supplier --|> Product
note right of Warehouse : Ecommerce domain
@enduml