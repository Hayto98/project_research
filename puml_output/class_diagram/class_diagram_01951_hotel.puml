@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Housekeeping {
  #double createdAt
  #int phone
  -long score
  -int updatedAt
  +deleteCreatedat()
  +validateCreatedat()
  +calculateAddress()
  +createType()
}
class Reservation {
  -long total
  #long type
  +float amount
  +findUpdatedat()
  +createNote()
  +validateEmail()
  +cancelEmail()
}
class Restaurant {
  +boolean price
  -long createdAt
  +long active
  +float note
  +deleteDuration()
  +cancelDescription()
  +deletePhone()
}
class CheckOut {
  +float name
  +Date address
  +setUpdatedat()
  +sendPrice()
  +saveNote()
}
interface Payment {
  +int updatedAt
  -String note
  -float total
  #float phone
  +createCode()
  +calculateStatus()
  +updateName()
}
CheckOut --* Housekeeping
CheckOut --> Payment : "1"
Reservation --* Housekeeping
@enduml