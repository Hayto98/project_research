@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
interface Payment {
  -int description
  +String email
  +double active
  +cancelPrice()
  +cancelAmount()
  +getNote()
}
class CheckOut {
  #long status
  #int type
  +createStatus()
  +deleteTotal()
}
class CheckIn {
  +int status
  #boolean description
  #long address
  -boolean active
  +validateAddress()
}
abstract class Staff {
  -Date price
  -double active
  -long total
  #int code
  +sendPrice()
}
Payment --> CheckIn : "1"
Staff ..> Payment : "1..*"
note right of Payment : Hotel domain
@enduml