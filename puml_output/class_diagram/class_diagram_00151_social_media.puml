@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Album {
  -int amount
  -float id
  +deleteDuration()
  +getAmount()
}
class Follower {
  -boolean name
  -Date score
  -String address
  +int active
  #int phone
  +setPrice()
  +deleteNote()
}
abstract class Hashtag {
  -boolean code
  #Date score
  +double status
  #double price
  #Date id
  +setPhone()
  +saveNote()
  +deleteUpdatedat()
}
interface Notification {
  #double quantity
  +int score
  #Date level
  #boolean note
  #float id
  +validateUpdatedat()
}
interface Report {
  +float total
  +long active
  +calculateActive()
}
class Group {
  -Date address
  #String price
  +String code
  -Date id
  +String updatedAt
  +calculateActive()
}
class Profile {
  +boolean status
  #double price
  +calculateUpdatedat()
  +processNote()
}
Report --o Group
Follower --o Hashtag
Report --o Notification
note right of Album : Social Media domain
@enduml