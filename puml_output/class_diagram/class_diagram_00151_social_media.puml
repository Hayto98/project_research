@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Album {
  -int amount
  -float id
  +setType()
  +findDescription()
}
class Follower {
  #long description
  #long type
  -boolean name
  +updatePhone()
  +createName()
  +processCode()
}
class Hashtag {
  +String description
  -int active
  -double level
  +updateAddress()
  +cancelType()
  +createAddress()
  +cancelAmount()
}
class Notification {
  -float score
  #double duration
  #Date id
  -String quantity
  #Date name
  +calculateUpdatedat()
  +deleteDuration()
  +getEmail()
}
class Report {
  #double quantity
  +int score
  #Date level
  #boolean note
  #float id
  +cancelId()
}
class Group {
  +float total
  +long active
  +setNote()
}
interface Profile {
  #String note
  #String address
  +long price
  +findAddress()
}
Notification ..|> Group
Album --|> Report
@enduml