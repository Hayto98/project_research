@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Follower {
  #Date quantity
  #double total
  #Date id
  +savePhone()
}
class Hashtag {
  -float updatedAt
  -boolean price
  #String level
  -int createdAt
  #long description
  +processTotal()
  +saveId()
}
class Like {
  +Date amount
  -Date quantity
  +long address
  #boolean id
  +boolean updatedAt
  +createActive()
  +validateLevel()
}
abstract class User {
  -boolean email
  -boolean id
  +cancelAmount()
  +getCode()
}
abstract class Report {
  -int quantity
  -Date name
  +createAddress()
  +sendDuration()
  +saveAmount()
}
class Group {
  #float status
  -float type
  -long amount
  +saveDescription()
  +createUpdatedat()
  +cancelLevel()
  +findQuantity()
}
abstract class Story {
  #float price
  +String description
  +saveScore()
  +getDuration()
  +cancelDuration()
  +findActive()
}
Group --> User : "0..1"
Like --o Report
User --|> Follower
Follower ..> Report : "1..*"
Story ..|> Report
@enduml