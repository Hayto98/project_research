@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Follower {
  #Date quantity
  #double total
  #Date id
  +getStatus()
}
abstract class Hashtag {
  +long price
  -boolean duration
  #String createdAt
  +updateQuantity()
  +deleteNote()
  +getEmail()
  +calculateAmount()
}
class Like {
  #float id
  +long updatedAt
  #boolean createdAt
  +boolean total
  +validateNote()
  +getEmail()
}
class User {
  -String duration
  -int note
  -Date createdAt
  #float price
  -String name
  +setCreatedat()
  +setType()
  +saveDuration()
  +deleteType()
}
class Report {
  +double total
  #Date active
  +boolean address
  +String note
  +validateType()
  +processPrice()
  +cancelAmount()
  +createActive()
}
abstract class Group {
  +double name
  -Date status
  -boolean level
  #String email
  -Date updatedAt
  +createCode()
  +updateTotal()
  +cancelQuantity()
  +setType()
}
interface Story {
  #long name
  +long amount
  +setActive()
}
Story --o Follower
Story --* Report
Hashtag ..> Report : "1"
Like --> User : "1"
note right of Follower : Social Media domain
@enduml