@startuml
skinparam ArrowColor #555555
interface Comment {
  -Date amount
  #int description
  +Date score
  +int type
  +deleteQuantity()
}
abstract class Album {
  #String amount
  #float score
  +boolean note
  +getName()
}
interface Message {
  #int phone
  +String id
  -Date email
  -int name
  +cancelType()
  +calculateDescription()
  +createScore()
}
interface Like {
  #float note
  #String description
  +updateName()
  +findScore()
  +processScore()
}
class Report {
  -String address
  -float name
  +long id
  #boolean quantity
  +deleteLevel()
  +findType()
  +calculateActive()
}
class Story {
  -double description
  -String active
  +processDescription()
}
Story ..|> Like
Comment --> Story : "0..1"
Story ..|> Message
Report --|> Like
Comment --* Message
@enduml