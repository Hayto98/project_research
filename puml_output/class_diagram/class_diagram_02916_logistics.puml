@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
abstract class Vehicle {
  #long price
  #String updatedAt
  +processScore()
  +createQuantity()
  +createQuantity()
  +cancelTotal()
}
class Manifest {
  -String address
  -long createdAt
  -float email
  +float description
  +calculateCode()
  +sendLevel()
}
interface Depot {
  #boolean description
  #int active
  -boolean createdAt
  -int amount
  +calculateAddress()
}
abstract class FuelLog {
  +float total
  #Date level
  +saveType()
  +saveCode()
}
class Package {
  -int code
  +boolean level
  #String name
  #long amount
  +savePrice()
  +saveAmount()
}
interface Warehouse {
  +int duration
  -long level
  #float phone
  -Date description
  +processUpdatedat()
  +processCode()
  +calculatePhone()
  +cancelNote()
}
class DeliveryNote {
  +long note
  +double createdAt
  +int active
  +String amount
  +setType()
}
Package ..> DeliveryNote : "0..1"
Manifest --> Package : "*"
FuelLog ..> Package : "0..1"
note right of Vehicle : Logistics domain
@enduml