@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
abstract class Vehicle {
  #long price
  #String updatedAt
  +sendCode()
  +validatePrice()
  +setAddress()
  +getNote()
}
class Manifest {
  -int quantity
  #long total
  #int duration
  -String email
  +getNote()
  +cancelType()
  +processTotal()
  +updateCreatedat()
}
class Depot {
  #boolean total
  -int code
  #boolean score
  +setQuantity()
  +processUpdatedat()
}
interface FuelLog {
  +double email
  -double type
  +float updatedAt
  +processId()
  +calculateAddress()
  +saveLevel()
  +sendLevel()
}
class Package {
  +long code
  +int quantity
  #float level
  #String duration
  #long name
  +sendPrice()
  +processType()
}
class Warehouse {
  +int duration
  -long level
  #float phone
  -Date description
  +cancelCode()
  +updateCreatedat()
  +updateStatus()
  +calculateAmount()
}
class DeliveryNote {
  +boolean phone
  +int note
  -String duration
  -int score
  +int level
  +saveEmail()
}
FuelLog --> Manifest : "0..1"
Manifest --> Package : "*"
@enduml