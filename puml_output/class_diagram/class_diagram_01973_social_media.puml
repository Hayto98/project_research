@startuml
skinparam monochrome true
skinparam defaultFontSize 13
abstract class User {
  +int id
  -float quantity
  +createDescription()
  +validateAddress()
}
class Comment {
  #double active
  +String price
  -double description
  #long email
  +findUpdatedat()
  +saveName()
}
class Album {
  #double quantity
  #Date id
  #float duration
  +findCode()
}
class Message {
  #Date description
  +boolean total
  #double name
  +setUpdatedat()
  +validateType()
}
class Notification {
  -String phone
  +int total
  +findCreatedat()
  +findEmail()
  +saveScore()
}
interface Story {
  #String level
  -Date duration
  +calculateUpdatedat()
  +createAddress()
  +createTotal()
}
class Report {
  #double id
  -Date address
  -float updatedAt
  +validateAmount()
}
Report --* Comment
Message --o Album
Story ..|> Notification
Comment ..> Notification : "1"
Message --o User
Comment --> Story : "0..1"
@enduml