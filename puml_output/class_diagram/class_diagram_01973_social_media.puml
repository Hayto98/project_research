@startuml
skinparam monochrome true
skinparam defaultFontSize 13
abstract class User {
  +int id
  -float quantity
  +sendEmail()
  +validateEmail()
}
interface Comment {
  +long description
  -Date level
  -int email
  #double note
  +int id
  +findId()
  +createType()
  +cancelDuration()
}
class Album {
  +Date address
  #int amount
  #float description
  #double total
  +getName()
  +setPhone()
}
abstract class Message {
  -long name
  #String duration
  #boolean amount
  #String email
  +saveAddress()
  +saveCode()
  +findId()
  +deleteId()
}
class Notification {
  #long active
  +long total
  #float address
  +validateTotal()
  +validateType()
}
interface Story {
  -String amount
  -int active
  #float name
  +findType()
  +cancelEmail()
}
class Report {
  #String amount
  #float address
  +sendCode()
}
User --|> Report
Notification --> Comment : "*"
Notification --* Message
note right of User : Social Media domain
@enduml