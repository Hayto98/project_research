@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Course {
  #String phone
  #boolean score
  #Date address
  +updateQuantity()
  +calculateStatus()
  +sendActive()
}
abstract class Book {
  -boolean id
  +String description
  #int level
  -int total
  +Date code
  +updateName()
  +findPrice()
}
class Library {
  #long type
  #long email
  #long note
  #String total
  #String updatedAt
  +processDuration()
  +sendScore()
}
interface Department {
  +float code
  -float score
  #float address
  -int phone
  +createCreatedat()
  +getDescription()
  +validateScore()
}
Library --> Course : "0..1"
Department --> Course : "*"
Book ..|> Course
note right of Course : Education domain
@enduml