@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Course {
  #String phone
  #boolean score
  #Date address
  +cancelNote()
  +cancelAddress()
  +calculateQuantity()
}
class Book {
  #String price
  -boolean id
  +String description
  #int score
  -int total
  +saveTotal()
}
class Library {
  -double name
  -double price
  -int duration
  +deleteId()
  +updateAmount()
  +updateCreatedat()
}
interface Department {
  #boolean address
  +double name
  #boolean score
  #Date status
  +setDescription()
  +setActive()
  +sendAmount()
}
Library --* Course
Department --* Course
Library ..|> Department
@enduml