@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
abstract class Invoice {
  +double amount
  -boolean level
  +processQuantity()
  +setType()
  +saveEmail()
  +validateCode()
}
class Reservation {
  +long duration
  +double score
  +sendQuantity()
  +setCreatedat()
  +calculateName()
}
class Service {
  -String note
  -boolean amount
  -Date updatedAt
  #float email
  #String code
  +setType()
  +validateActive()
  +updateActive()
  +validatePhone()
}
class Restaurant {
  +String score
  +int id
  #double price
  +updateTotal()
  +cancelTotal()
  +processUpdatedat()
}
interface CheckIn {
  #long type
  -Date total
  +String email
  -Date duration
  +cancelDuration()
  +createAmount()
  +updateDescription()
  +createStatus()
}
class Room {
  #boolean address
  +String name
  +calculateAddress()
  +processScore()
}
class Housekeeping {
  #boolean email
  -long level
  +createName()
}
Invoice ..> Room : "0..1"
Service --* Housekeeping
@enduml