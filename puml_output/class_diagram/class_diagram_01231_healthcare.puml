@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
interface Doctor {
  #long createdAt
  -int type
  +getAmount()
}
abstract class Billing {
  +long code
  +float amount
  +Date score
  +deleteAmount()
  +findEmail()
  +cancelEmail()
  +validateScore()
}
interface Hospital {
  -double duration
  +double amount
  +float active
  +createLevel()
}
interface Appointment {
  +boolean code
  +double score
  #long description
  +setTotal()
  +saveAmount()
  +saveType()
  +saveDuration()
}
interface Patient {
  #long active
  #boolean level
  +Date email
  +Date price
  -Date amount
  +deleteNote()
}
class MedicalRecord {
  +int level
  -int status
  +updateLevel()
}
class Diagnosis {
  -long createdAt
  +boolean phone
  +setNote()
  +deleteAddress()
}
MedicalRecord --|> Diagnosis
Hospital --* Patient
Patient --> Appointment : "1..*"
@enduml