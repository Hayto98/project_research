@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Student {
  -long type
  +Date address
  #float description
  +processAddress()
  +createUpdatedat()
}
interface Assignment {
  -long price
  #float updatedAt
  +setNote()
  +processAmount()
  +updateUpdatedat()
  +sendCreatedat()
}
abstract class Classroom {
  #float duration
  #Date createdAt
  +updateType()
  +calculateName()
  +cancelDuration()
}
class Teacher {
  +Date score
  -Date type
  -double email
  +findAmount()
}
class Enrollment {
  -int level
  #int phone
  #float address
  +float status
  +calculateTotal()
}
class Schedule {
  +boolean active
  -Date type
  +cancelActive()
  +sendAmount()
}
interface Library {
  #double address
  +long score
  #Date type
  +findDescription()
  +processTotal()
  +setScore()
  +cancelPhone()
}
Library ..> Schedule : "*"
Assignment --|> Enrollment
Student --* Assignment
Student --|> Classroom
Assignment --o Classroom
note right of Student : Education domain
@enduml