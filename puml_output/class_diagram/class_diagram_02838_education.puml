@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Student {
  -long type
  +Date address
  #float description
  +processTotal()
  +calculateUpdatedat()
}
class Assignment {
  -long updatedAt
  #float code
  #double price
  +double duration
  +saveDescription()
  +saveLevel()
  +createCode()
  +calculateTotal()
}
class Classroom {
  +boolean active
  #float createdAt
  #int total
  +processPrice()
  +validateName()
  +createDuration()
}
class Teacher {
  +Date createdAt
  -Date score
  -double type
  +Date email
  +calculateScore()
  +calculateDescription()
}
class Enrollment {
  #int address
  #float status
  +float note
  +double description
  +createQuantity()
  +findNote()
  +getScore()
  +validateUpdatedat()
}
class Schedule {
  +boolean description
  +long level
  #float active
  -float score
  +validatePhone()
  +findCreatedat()
  +deleteStatus()
  +cancelDuration()
}
abstract class Library {
  #boolean note
  -Date total
  -float code
  +validateCode()
  +processEmail()
  +setName()
  +updatePrice()
}
Library --|> Classroom
Classroom ..|> Student
Classroom ..|> Teacher
@enduml