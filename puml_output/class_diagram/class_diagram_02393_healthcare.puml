@startuml
skinparam shadowing true
class Insurance {
  -boolean name
  -double amount
  #String email
  +String phone
  -int note
  +deleteDuration()
}
abstract class Appointment {
  #float code
  +float phone
  -String price
  -float updatedAt
  +getTotal()
}
class Patient {
  -int name
  #boolean quantity
  #float total
  +int address
  #float score
  +getName()
}
interface MedicalRecord {
  -long active
  -float id
  #String code
  #boolean address
  +sendType()
  +calculateAddress()
  +saveUpdatedat()
}
class Diagnosis {
  -Date address
  #long description
  -int code
  +sendAddress()
  +sendDescription()
  +cancelDescription()
}
MedicalRecord --> Appointment : "0..1"
Patient ..|> Insurance
@enduml