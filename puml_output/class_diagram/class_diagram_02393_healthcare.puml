@startuml
skinparam shadowing true
class Insurance {
  -boolean name
  -double amount
  #String email
  +String phone
  -int note
  +processTotal()
}
class Appointment {
  +float phone
  #float price
  +processCode()
  +validateName()
}
class Patient {
  -float type
  -long name
  +createUpdatedat()
  +saveLevel()
  +saveDescription()
  +deleteName()
}
interface MedicalRecord {
  -long active
  -float id
  #String code
  #boolean address
  +deleteCode()
  +updateAddress()
  +saveDescription()
}
class Diagnosis {
  #String quantity
  -int duration
  #boolean amount
  #int address
  -String email
  +setScore()
  +saveEmail()
}
Insurance --> MedicalRecord : "1..*"
MedicalRecord --o Patient
MedicalRecord --|> Diagnosis
note right of Insurance : Healthcare domain
@enduml