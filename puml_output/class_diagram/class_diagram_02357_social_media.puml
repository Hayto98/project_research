@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
interface User {
  -String active
  +int price
  +getName()
}
interface Profile {
  +float updatedAt
  +Date phone
  #String price
  -Date total
  +deleteId()
}
class Group {
  #long id
  #int total
  -float level
  #int note
  +int name
  +setName()
  +findId()
  +processUpdatedat()
}
class Comment {
  #Date status
  -float score
  -double updatedAt
  #boolean name
  -long phone
  +sendLevel()
  +createLevel()
  +getDuration()
  +sendDescription()
}
class Follower {
  #boolean score
  +boolean updatedAt
  #String name
  -int total
  +calculateName()
}
Comment --* Follower
Follower --|> User
note right of User : Social Media domain
@enduml