@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
interface User {
  -String active
  +int price
  +savePhone()
}
class Profile {
  +float updatedAt
  +Date phone
  #String price
  -Date total
  +setType()
}
class Group {
  -boolean type
  -Date id
  +Date total
  +setCreatedat()
  +validateCreatedat()
  +cancelQuantity()
}
class Comment {
  +Date createdAt
  +double email
  #int code
  +getPhone()
}
class Follower {
  -double name
  #boolean phone
  -long note
  +calculateActive()
  +processId()
  +getDescription()
  +findLevel()
}
Follower --> User : "0..1"
Group --> Follower : "0..1"
User --> Comment : "0..1"
@enduml