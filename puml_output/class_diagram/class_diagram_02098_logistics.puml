@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Package {
  #Date level
  +long note
  +processName()
}
abstract class DeliveryNote {
  +boolean createdAt
  #long code
  -int address
  +String type
  +setPhone()
  +getActive()
}
interface Customer {
  +float status
  #long updatedAt
  +sendTotal()
  +validateScore()
  +calculateQuantity()
  +processType()
}
interface Driver {
  +long createdAt
  +boolean code
  +double price
  +float note
  -float level
  +processEmail()
  +calculatePhone()
  +processTotal()
  +updateActive()
}
abstract class Inventory {
  -Date score
  #double price
  +processActive()
  +setAmount()
  +sendId()
  +validateTotal()
}
Customer --> Package : "0..1"
Package --* DeliveryNote
Inventory ..> Customer : "0..1"
Package ..> Inventory : "1..*"
@enduml