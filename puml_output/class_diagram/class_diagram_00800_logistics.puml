@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Package {
  #String price
  -double updatedAt
  -String phone
  +updateActive()
  +findLevel()
  +sendDuration()
}
class Shipment {
  +double duration
  #String active
  +boolean description
  +float code
  +updateCreatedat()
}
abstract class Depot {
  -String name
  #Date quantity
  +calculateCode()
}
abstract class Vehicle {
  -int type
  -long phone
  -double updatedAt
  +processUpdatedat()
  +findPhone()
}
abstract class Warehouse {
  +double createdAt
  -Date score
  -long updatedAt
  +long phone
  +updateCreatedat()
  +sendQuantity()
  +getAddress()
  +getTotal()
}
Package --o Vehicle
Shipment ..|> Depot
Vehicle --|> Depot
@enduml