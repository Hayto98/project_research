@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Package {
  #String price
  -double updatedAt
  -String phone
  +getPhone()
  +createDuration()
  +sendDescription()
}
interface Shipment {
  #String amount
  +boolean type
  +sendDuration()
  +getType()
}
class Depot {
  +boolean quantity
  #String note
  +calculateCreatedat()
  +processPhone()
  +updatePrice()
  +updateTotal()
}
class Vehicle {
  -float type
  +Date createdAt
  #int amount
  -int description
  -double duration
  +validateUpdatedat()
  +createType()
  +sendTotal()
}
class Warehouse {
  +double status
  #float price
  #long note
  +long updatedAt
  +String email
  +validateType()
}
Depot --|> Vehicle
Shipment ..> Package : "1..*"
Warehouse --> Package : "1..*"
note right of Package : Logistics domain
@enduml