@startuml
skinparam monochrome true
skinparam shadowing true
class Attendance {
  #float quantity
  +Date duration
  +String price
  +findNote()
  +findActive()
  +calculateType()
  +getNote()
}
class Library {
  #boolean address
  #String amount
  +boolean id
  #int score
  +sendCreatedat()
}
interface Schedule {
  -long phone
  #boolean total
  +boolean duration
  -String code
  -int createdAt
  +deleteStatus()
}
class Book {
  #String note
  #String updatedAt
  -Date id
  +updateDuration()
  +updateTotal()
  +cancelEmail()
}
Book ..> Attendance : "0..1"
Book ..|> Library
Attendance ..|> Library
note right of Attendance : Education domain
@enduml