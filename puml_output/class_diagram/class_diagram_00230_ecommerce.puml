@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
abstract class Order {
  +boolean name
  #Date id
  +setDescription()
  +deleteDescription()
  +calculatePhone()
  +findScore()
}
abstract class Warehouse {
  +Date total
  -String address
  +double price
  +boolean status
  +createAddress()
  +sendCreatedat()
  +saveEmail()
}
class Wishlist {
  #double phone
  -float total
  #Date duration
  +saveActive()
}
interface Review {
  +long active
  #int updatedAt
  -String duration
  +boolean type
  +processDescription()
  +processName()
}
abstract class Payment {
  +float score
  +boolean duration
  +findCode()
  +sendStatus()
  +setDescription()
}
interface Return {
  -float createdAt
  -Date amount
  +calculateName()
  +getScore()
  +setTotal()
  +setUpdatedat()
}
class Coupon {
  #long note
  +Date quantity
  +float total
  +processNote()
  +cancelDuration()
  +calculateUpdatedat()
  +createScore()
}
Order ..|> Coupon
Review --> Order : "*"
@enduml