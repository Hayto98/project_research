@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Course {
  -double quantity
  #double score
  +boolean phone
  +int level
  #boolean status
  +validateId()
}
class Teacher {
  +Date email
  #int code
  -String phone
  -double level
  +boolean price
  +sendEmail()
  +getNote()
  +deleteTotal()
}
class Attendance {
  +int amount
  #int total
  #double active
  +String status
  +createUpdatedat()
  +updateStatus()
}
class Classroom {
  +long note
  -boolean score
  +long price
  +boolean quantity
  +findActive()
  +processEmail()
  +cancelPhone()
  +saveCreatedat()
}
Attendance --|> Classroom
Classroom --o Course
Teacher ..|> Attendance
@enduml