@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Course {
  -double quantity
  #double score
  +boolean phone
  +int level
  #boolean status
  +setId()
}
abstract class Teacher {
  +Date code
  #int phone
  -String duration
  -double price
  +cancelEmail()
}
class Attendance {
  #Date name
  #boolean phone
  +int amount
  +boolean total
  +saveTotal()
  +deleteId()
}
class Classroom {
  -Date address
  #float active
  -long quantity
  +validateAddress()
}
Attendance --> Course : "*"
Classroom --* Attendance
note right of Course : Education domain
@enduml