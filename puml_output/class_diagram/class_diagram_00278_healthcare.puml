@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
abstract class Ward {
  +boolean price
  #Date phone
  #boolean id
  +boolean description
  +float amount
  +calculateStatus()
  +calculateType()
  +saveCreatedat()
}
class Patient {
  #int email
  #String duration
  +double type
  +sendNote()
}
class MedicalRecord {
  +double price
  #double createdAt
  -long email
  #String updatedAt
  -long total
  +deleteLevel()
  +setAmount()
}
class Doctor {
  +boolean total
  #String quantity
  +deleteCreatedat()
  +getEmail()
  +createQuantity()
}
class Billing {
  #int phone
  +boolean quantity
  #boolean total
  +getAmount()
  +setAmount()
  +cancelCode()
}
class Treatment {
  +float duration
  -float email
  #boolean quantity
  #double phone
  +savePrice()
  +sendActive()
  +setType()
  +updateCode()
}
Doctor ..> Treatment : "1"
Doctor --|> Patient
MedicalRecord ..|> Patient
note right of Ward : Healthcare domain
@enduml