@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
abstract class Ward {
  +boolean price
  #Date phone
  #boolean id
  +boolean description
  +float amount
  +saveName()
  +updateUpdatedat()
  +processLevel()
}
abstract class Patient {
  -double phone
  #int createdAt
  #String email
  +getId()
  +calculateDescription()
}
interface MedicalRecord {
  +double active
  -int note
  +setCode()
  +sendNote()
  +updateEmail()
}
class Doctor {
  -int total
  +boolean phone
  +int level
  +String code
  -long email
  +setId()
}
interface Billing {
  #Date email
  +String description
  +setQuantity()
  +validateStatus()
  +findScore()
}
class Treatment {
  -float createdAt
  -float phone
  +cancelType()
  +cancelTotal()
}
Ward --|> Patient
Patient --|> Billing
MedicalRecord ..> Treatment : "1..*"
@enduml