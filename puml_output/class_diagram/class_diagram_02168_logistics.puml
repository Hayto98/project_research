@startuml
skinparam monochrome true
skinparam ArrowColor #555555
interface Depot {
  +float code
  +float note
  -Date phone
  -Date createdAt
  +deleteActive()
  +calculateUpdatedat()
  +cancelActive()
}
class Vehicle {
  #Date score
  -double price
  +long description
  +cancelQuantity()
}
interface Package {
  +int email
  -Date code
  -String duration
  +sendId()
  +calculateAmount()
  +deleteCode()
}
class Warehouse {
  #int status
  +Date id
  +int createdAt
  +deleteActive()
  +cancelEmail()
}
interface Route {
  +boolean score
  -long price
  -double description
  +float quantity
  +boolean address
  +getEmail()
  +updateName()
}
class DeliveryNote {
  #boolean quantity
  -float amount
  +validateDescription()
  +getCode()
  +updateQuantity()
}
interface Tracking {
  -long code
  #float quantity
  -String total
  +boolean level
  -int name
  +sendActive()
  +cancelPhone()
  +deletePrice()
}
Tracking --> Warehouse : "0..1"
Warehouse ..> Tracking : "1..*"
@enduml