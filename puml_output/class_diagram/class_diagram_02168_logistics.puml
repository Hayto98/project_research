@startuml
skinparam monochrome true
skinparam ArrowColor #555555
interface Depot {
  +float code
  +float note
  -Date phone
  -Date createdAt
  +processLevel()
  +validateLevel()
  +saveCreatedat()
}
interface Vehicle {
  -String duration
  -boolean description
  +long phone
  +long type
  +int name
  +findTotal()
  +getQuantity()
  +updateNote()
}
class Package {
  #Date amount
  +boolean status
  +String id
  +updateDuration()
}
class Warehouse {
  -long status
  +boolean level
  -long price
  -double score
  +float description
  +sendAmount()
  +deleteStatus()
}
class Route {
  #boolean quantity
  -float amount
  +cancelScore()
  +saveActive()
  +calculateCode()
}
class DeliveryNote {
  +String quantity
  #float name
  -int type
  -boolean duration
  -double total
  +calculateLevel()
}
class Tracking {
  #boolean type
  #int email
  -float status
  -double address
  #double note
  +validateStatus()
}
Depot --o Vehicle
Warehouse ..|> Depot
note right of Depot : Logistics domain
@enduml