@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Reservation {
  #float quantity
  -String price
  +int level
  +setUpdatedat()
}
class Housekeeping {
  +boolean type
  #long score
  -String total
  +deleteDescription()
  +deleteQuantity()
  +calculateDuration()
  +getDescription()
}
abstract class Staff {
  #Date id
  #float note
  -boolean description
  +saveActive()
  +getPhone()
}
class Payment {
  #String description
  +String score
  #long status
  +calculateId()
  +saveNote()
  +validateName()
}
class Booking {
  -boolean duration
  +int code
  +validateNote()
  +createScore()
  +deleteQuantity()
}
Payment --|> Staff
Reservation --o Housekeeping
@enduml