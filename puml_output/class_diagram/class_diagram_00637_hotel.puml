@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Reservation {
  #float quantity
  -String price
  +int level
  +getQuantity()
}
class Housekeeping {
  +double score
  #String total
  #float updatedAt
  #double phone
  #boolean quantity
  +findId()
  +processDescription()
}
interface Staff {
  #boolean level
  #int updatedAt
  +boolean score
  +boolean total
  +int duration
  +sendAddress()
}
class Payment {
  -String createdAt
  #boolean type
  +calculateScore()
}
class Booking {
  +int quantity
  -long updatedAt
  +String level
  +calculateNote()
  +saveEmail()
}
Booking ..|> Housekeeping
Payment ..> Staff : "*"
note right of Reservation : Hotel domain
@enduml