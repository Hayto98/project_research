@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
interface Patient {
  +String updatedAt
  +long amount
  +sendStatus()
  +getScore()
  +cancelAddress()
}
abstract class Insurance {
  -int name
  +long email
  -long price
  +float id
  +validateNote()
  +saveEmail()
}
class Prescription {
  -double address
  -boolean type
  +processPrice()
  +setAddress()
  +cancelEmail()
}
class Doctor {
  -int score
  -float quantity
  +createNote()
  +getActive()
}
Doctor --|> Patient
Patient --|> Prescription
@enduml