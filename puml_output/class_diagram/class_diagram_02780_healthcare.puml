@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
interface Patient {
  +String updatedAt
  +long amount
  +sendQuantity()
  +calculateQuantity()
  +getEmail()
}
abstract class Insurance {
  +long price
  -long createdAt
  +cancelDescription()
  +updateName()
}
class Prescription {
  -double address
  -boolean type
  +updateScore()
  +setCode()
  +findName()
}
interface Doctor {
  #Date price
  #Date createdAt
  #Date duration
  +Date amount
  +setName()
  +setDuration()
  +getCreatedat()
  +cancelCode()
}
Prescription ..> Doctor : "0..1"
Insurance ..|> Prescription
Doctor ..|> Patient
note right of Patient : Healthcare domain
@enduml