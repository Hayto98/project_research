@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Branch {
  #double type
  -String status
  +float updatedAt
  +double duration
  +float level
  +getDuration()
  +getCreatedat()
  +createCode()
}
interface Publisher {
  #long score
  #float note
  #int level
  +String createdAt
  -boolean email
  +calculateCreatedat()
}
class Author {
  #double total
  -int phone
  -Date id
  -boolean email
  +calculateAddress()
  +findDescription()
  +updateLevel()
}
interface Shelf {
  +double score
  #String active
  -boolean updatedAt
  -long note
  +setDuration()
  +setName()
  +sendPrice()
  +calculateNote()
}
class Book {
  +String type
  #double score
  +long email
  +calculateLevel()
}
Shelf --* Author
Publisher ..|> Author
note right of Branch : Library domain
@enduml