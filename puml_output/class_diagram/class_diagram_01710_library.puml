@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Branch {
  #double type
  -String status
  +float updatedAt
  +double duration
  +float level
  +setDuration()
  +createId()
  +savePhone()
}
interface Publisher {
  +boolean createdAt
  -boolean email
  +saveTotal()
  +deleteDuration()
  +createLevel()
  +saveUpdatedat()
}
class Author {
  +long quantity
  #Date active
  #String amount
  -int updatedAt
  +validateStatus()
  +processNote()
  +validateDuration()
}
abstract class Shelf {
  -double id
  +float level
  -Date email
  -boolean active
  +findAmount()
  +validateScore()
  +saveDescription()
}
class Book {
  #boolean level
  +double score
  +double address
  +cancelId()
}
Shelf --> Author : "*"
Branch --|> Book
Book --o Shelf
Shelf ..|> Branch
@enduml