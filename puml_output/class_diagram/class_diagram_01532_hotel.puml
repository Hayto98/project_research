@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Housekeeping {
  +float id
  -float level
  +String description
  #float active
  +long createdAt
  +validateActive()
  +setCreatedat()
}
class Reservation {
  -String note
  +long description
  #String active
  #float price
  +String updatedAt
  +saveStatus()
  +sendTotal()
  +deleteTotal()
}
abstract class Restaurant {
  -int id
  #int total
  -Date amount
  -Date code
  +validateActive()
  +cancelPhone()
  +createActive()
  +deleteType()
}
class Invoice {
  +String id
  -long type
  #boolean duration
  +validateCode()
  +saveDuration()
}
Restaurant ..> Invoice : "*"
Housekeeping ..|> Invoice
Reservation --o Invoice
@enduml