@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Housekeeping {
  +float id
  -float level
  +String description
  #float active
  +long createdAt
  +cancelCreatedat()
  +calculateNote()
}
class Reservation {
  #String updatedAt
  #float email
  +String name
  -float amount
  +float level
  +cancelQuantity()
  +getTotal()
  +deleteCode()
  +processCreatedat()
}
class Restaurant {
  #int quantity
  +String score
  -Date price
  +int email
  +float address
  +validateActive()
  +saveCreatedat()
  +deleteLevel()
  +sendScore()
}
interface Invoice {
  +int address
  +long active
  -String total
  +float id
  +sendName()
  +processType()
  +sendType()
  +calculateCreatedat()
}
Housekeeping --o Restaurant
Reservation --o Invoice
note right of Housekeeping : Hotel domain
@enduml