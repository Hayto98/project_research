@startuml
skinparam monochrome true
skinparam shadowing true
class Book {
  -Date active
  #float phone
  #double email
  #double description
  #boolean level
  +setId()
  +sendUpdatedat()
  +calculateDuration()
}
class Teacher {
  #String type
  -int note
  #String updatedAt
  +deleteUpdatedat()
  +setDescription()
  +processDescription()
}
class Assignment {
  #long note
  +boolean active
  -int type
  +setAddress()
  +createAddress()
  +calculateName()
  +cancelPhone()
}
interface Enrollment {
  +float status
  #float id
  #long score
  +boolean quantity
  -boolean active
  +validatePrice()
}
Teacher ..|> Enrollment
Enrollment --* Teacher
@enduml