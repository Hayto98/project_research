@startuml
skinparam monochrome true
skinparam shadowing true
class Book {
  -Date active
  #float phone
  #double email
  #double description
  #boolean level
  +cancelScore()
  +setDescription()
  +processNote()
}
class Teacher {
  #String price
  -boolean description
  +createPhone()
}
class Assignment {
  +Date active
  #boolean type
  #Date phone
  #double name
  #String email
  +createDuration()
  +processStatus()
  +getScore()
}
class Enrollment {
  #long id
  #String score
  #int email
  +long createdAt
  +processQuantity()
  +validateName()
}
Teacher --> Book : "1"
Teacher --> Assignment : "1..*"
note right of Book : Education domain
@enduml