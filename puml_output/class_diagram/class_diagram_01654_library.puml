@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Publisher {
  +Date note
  +String email
  -int phone
  +deleteAmount()
}
class Loan {
  +String quantity
  #double active
  -String score
  +findActive()
  +createCode()
  +deleteId()
}
class Fine {
  +Date total
  +float type
  +validateDuration()
  +validateType()
}
class Librarian {
  +double createdAt
  -int phone
  +setStatus()
  +sendQuantity()
  +cancelScore()
}
class Member {
  #Date type
  +int duration
  #Date email
  +deletePhone()
  +setCreatedat()
  +sendNote()
  +saveEmail()
}
class Book {
  #int description
  +String address
  +String email
  #int id
  +validateAmount()
  +sendEmail()
  +createPrice()
  +cancelType()
}
Loan --> Librarian : "*"
Librarian ..> Book : "1..*"
Publisher --o Librarian
Book --o Loan
@enduml