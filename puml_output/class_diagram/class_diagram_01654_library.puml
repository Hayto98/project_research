@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Publisher {
  +Date note
  +String email
  -int phone
  +calculateName()
}
interface Loan {
  +String quantity
  #double active
  -String score
  +processAmount()
  +saveDescription()
  +cancelScore()
}
interface Fine {
  +Date total
  +float type
  +validateQuantity()
  +getCreatedat()
}
interface Librarian {
  -String id
  #Date note
  -int phone
  -float updatedAt
  +createStatus()
  +deleteDuration()
  +saveType()
  +findUpdatedat()
}
class Member {
  #Date level
  +boolean phone
  +createId()
  +findCreatedat()
  +updateStatus()
}
class Book {
  -long updatedAt
  +double level
  +updateType()
  +sendNote()
  +processPrice()
}
Publisher --o Librarian
Book --o Loan
Publisher ..|> Book
Member --o Book
note right of Publisher : Library domain
@enduml