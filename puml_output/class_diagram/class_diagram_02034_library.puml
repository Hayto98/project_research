@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Renewal {
  +boolean address
  +boolean code
  +updateCode()
  +setCode()
}
interface Loan {
  +String code
  +boolean type
  +sendScore()
  +updatePrice()
  +saveId()
}
class Member {
  -double price
  +double code
  +getType()
  +cancelTotal()
  +updateTotal()
  +getId()
}
class Book {
  #float id
  +String score
  -int total
  +double updatedAt
  +getCode()
  +validateAddress()
  +deleteStatus()
}
abstract class Catalog {
  +Date code
  +Date note
  +processTotal()
  +createType()
  +validateScore()
  +getStatus()
}
interface Fine {
  +int email
  #double code
  +float quantity
  +calculateName()
  +processCode()
}
interface Publisher {
  #long address
  #boolean duration
  #float phone
  +deleteUpdatedat()
  +updateDuration()
  +calculateQuantity()
  +deleteActive()
}
Fine ..> Renewal : "0..1"
Book --o Catalog
@enduml