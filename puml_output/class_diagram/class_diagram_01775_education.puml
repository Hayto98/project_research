@startuml
skinparam monochrome true
skinparam defaultFontSize 13
abstract class Schedule {
  +long status
  #Date duration
  +double quantity
  +processPhone()
  +cancelTotal()
}
abstract class Enrollment {
  #double name
  #boolean status
  +int email
  -String note
  +float address
  +saveId()
  +setAddress()
}
interface Course {
  #Date description
  #long phone
  +getType()
  +validatePhone()
  +saveDescription()
}
class Grade {
  -Date phone
  #boolean createdAt
  +int name
  +boolean price
  +validateQuantity()
  +setName()
}
Schedule --|> Grade
Schedule --|> Enrollment
@enduml