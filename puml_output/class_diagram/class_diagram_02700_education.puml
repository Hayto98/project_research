@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Classroom {
  #int name
  -long note
  -float status
  -boolean active
  -String total
  +findQuantity()
}
class Exam {
  +boolean updatedAt
  -Date duration
  +double id
  -long name
  +deleteId()
}
class Book {
  #int createdAt
  +double quantity
  #Date description
  -double code
  +Date id
  +calculateDescription()
}
class Student {
  #boolean amount
  +String note
  +Date type
  +int price
  #String id
  +calculateLevel()
  +processId()
  +createType()
  +cancelCreatedat()
}
abstract class Schedule {
  -double type
  +float email
  +processDuration()
  +calculateLevel()
  +findId()
  +setType()
}
class Grade {
  -float email
  #double type
  +findNote()
  +processScore()
  +processDescription()
  +getPrice()
}
Book ..> Schedule : "1..*"
Grade ..> Book : "1..*"
note right of Classroom : Education domain
@enduml