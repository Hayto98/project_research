@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Classroom {
  #int name
  -long note
  -float status
  -boolean active
  -String total
  +deleteType()
}
class Exam {
  +float quantity
  +boolean updatedAt
  -Date level
  +double id
  +calculateScore()
  +setStatus()
  +findId()
}
class Book {
  +String level
  #String note
  #int createdAt
  +double quantity
  +validateUpdatedat()
  +processPrice()
  +sendDuration()
  +updateActive()
}
abstract class Student {
  -double name
  #boolean type
  -String amount
  +updateActive()
  +saveAddress()
}
class Schedule {
  -Date active
  #double name
  +long total
  +findName()
  +sendEmail()
  +calculateAmount()
  +updateUpdatedat()
}
abstract class Grade {
  -boolean quantity
  -boolean note
  #String createdAt
  +double level
  +updateAddress()
  +setName()
}
Grade --o Student
Schedule --o Student
Student --o Schedule
@enduml