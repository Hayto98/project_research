@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
interface Catalog {
  #float quantity
  +Date phone
  -boolean name
  +long code
  +deleteTotal()
  +deleteLevel()
  +saveQuantity()
  +findPhone()
}
abstract class Shelf {
  #int code
  -String amount
  +Date updatedAt
  -boolean phone
  #long total
  +calculateCode()
}
class Reservation {
  #double duration
  #boolean email
  -int address
  #boolean phone
  +savePhone()
  +findCode()
  +createUpdatedat()
}
class Librarian {
  #long total
  +String code
  #String email
  -int level
  +createEmail()
}
interface Branch {
  +float description
  -int status
  +getLevel()
}
Branch --|> Librarian
Catalog --> Reservation : "*"
Shelf --* Reservation
Reservation --> Librarian : "1..*"
@enduml