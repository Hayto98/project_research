@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Customer {
  #String description
  -int createdAt
  #boolean phone
  +processAmount()
}
class Wishlist {
  +long note
  +boolean type
  +updateAmount()
  +validateDescription()
}
class Product {
  -double type
  #long updatedAt
  +calculateQuantity()
}
class Supplier {
  +int email
  #Date createdAt
  #double name
  #String total
  +double status
  +findDescription()
  +findAmount()
}
Wishlist ..> Product : "0..1"
Customer ..|> Product
@enduml