@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Customer {
  #String description
  -int createdAt
  #boolean phone
  +setQuantity()
}
interface Wishlist {
  +long note
  +boolean type
  +getCode()
  +processUpdatedat()
}
abstract class Product {
  -long score
  #int quantity
  +double name
  +String total
  +float email
  +sendId()
  +setType()
  +deleteDuration()
  +calculateDescription()
}
class Supplier {
  +int status
  +String amount
  +String name
  +saveQuantity()
  +validateScore()
  +findCode()
}
Wishlist --|> Supplier
Supplier ..> Customer : "*"
Product ..> Wishlist : "1..*"
note right of Customer : Ecommerce domain
@enduml