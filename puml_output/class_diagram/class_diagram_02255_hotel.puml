@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Restaurant {
  #String status
  -double address
  -int total
  -boolean id
  +setPrice()
}
class Housekeeping {
  #float note
  +float score
  +getEmail()
  +sendCode()
  +sendTotal()
  +setDuration()
}
abstract class Payment {
  +float score
  +String description
  +sendPrice()
  +getScore()
}
abstract class Room {
  +String email
  -int quantity
  +processType()
}
abstract class Reservation {
  -double name
  #boolean phone
  +String quantity
  -String total
  +processPhone()
}
abstract class Guest {
  -double description
  #String name
  -Date price
  #long active
  -boolean type
  +updateUpdatedat()
  +getPhone()
  +updateQuantity()
}
Room ..> Restaurant : "*"
Guest --> Room : "*"
Guest --o Reservation
note right of Restaurant : Hotel domain
@enduml