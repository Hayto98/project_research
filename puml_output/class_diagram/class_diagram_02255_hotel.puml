@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Restaurant {
  #String status
  -double address
  -int total
  -boolean id
  +validatePhone()
}
abstract class Housekeeping {
  #Date level
  #String active
  +createStatus()
  +validateTotal()
  +calculateType()
  +setName()
}
abstract class Payment {
  +float email
  #double active
  +getQuantity()
}
abstract class Room {
  +float score
  +String description
  +calculateDuration()
  +cancelName()
}
abstract class Reservation {
  +long score
  -int type
  +findType()
}
abstract class Guest {
  -Date id
  -String type
  -long level
  +createDuration()
  +calculateAmount()
  +cancelName()
  +getQuantity()
}
Restaurant --|> Payment
Guest --|> Reservation
@enduml