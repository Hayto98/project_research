@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class MedicalRecord {
  +boolean amount
  #Date phone
  +getLevel()
  +cancelEmail()
}
class Hospital {
  -String id
  #boolean active
  +int updatedAt
  +createId()
}
abstract class Insurance {
  +Date level
  #Date email
  -boolean type
  +updateQuantity()
}
abstract class Nurse {
  +float note
  +long amount
  -boolean address
  -float phone
  +Date status
  +validateName()
  +updateStatus()
  +setDuration()
}
abstract class Treatment {
  +boolean type
  +String quantity
  +int amount
  +setCode()
  +getName()
  +updateDescription()
}
MedicalRecord --|> Insurance
Nurse --> MedicalRecord : "1..*"
Nurse --|> Treatment
MedicalRecord --o Treatment
@enduml