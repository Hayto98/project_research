@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class MedicalRecord {
  +boolean amount
  #Date phone
  +setStatus()
  +createActive()
}
class Hospital {
  -String active
  #boolean updatedAt
  +deleteStatus()
}
abstract class Insurance {
  +Date level
  #Date email
  -boolean type
  +calculateNote()
}
abstract class Nurse {
  +int address
  +long score
  -boolean phone
  +deleteAddress()
  +processUpdatedat()
  +processScore()
  +sendActive()
}
class Treatment {
  +int quantity
  -Date amount
  +Date level
  +boolean id
  -String status
  +saveStatus()
  +cancelPhone()
  +calculateScore()
  +saveScore()
}
MedicalRecord --|> Treatment
Nurse --> Insurance : "*"
Treatment ..> Hospital : "1"
note right of MedicalRecord : Healthcare domain
@enduml