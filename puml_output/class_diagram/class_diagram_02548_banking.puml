@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Card {
  #float id
  #float updatedAt
  #boolean phone
  #int duration
  +updateDuration()
}
class Beneficiary {
  +Date createdAt
  +Date id
  -float status
  +double amount
  +getScore()
}
abstract class Loan {
  +Date price
  -String type
  +Date quantity
  -double createdAt
  -double code
  +calculateUpdatedat()
  +updateActive()
  +getCreatedat()
}
class Customer {
  +String price
  +long level
  #String amount
  +cancelName()
  +deleteActive()
}
Card --|> Customer
@enduml