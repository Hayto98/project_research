@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Card {
  #float id
  #float updatedAt
  #boolean phone
  #int duration
  +getEmail()
}
class Beneficiary {
  +int id
  #String status
  #long score
  +processCode()
}
interface Loan {
  +int note
  #double price
  +String type
  #double quantity
  -long createdAt
  +findQuantity()
  +saveId()
  +sendUpdatedat()
  +updatePrice()
}
interface Customer {
  -boolean code
  +float name
  +Date amount
  +getCode()
  +setId()
  +setDescription()
  +deletePrice()
}
Customer ..|> Card
Customer ..> Beneficiary : "1..*"
note right of Card : Banking domain
@enduml