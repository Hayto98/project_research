@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
interface Driver {
  -double createdAt
  -long total
  -boolean address
  +double score
  +calculateTotal()
  +updateQuantity()
  +findTotal()
}
interface Vehicle {
  -double quantity
  #float note
  +deleteCode()
  +processDuration()
  +findAddress()
}
class Depot {
  +int quantity
  #float createdAt
  +long score
  +float name
  +updateDuration()
  +findNote()
}
class Warehouse {
  -Date createdAt
  -float type
  #String status
  +setNote()
  +saveAmount()
  +cancelDescription()
  +saveAddress()
}
Driver --* Warehouse
Vehicle --* Driver
note right of Driver : Logistics domain
@enduml