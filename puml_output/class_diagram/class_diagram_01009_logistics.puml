@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
interface Driver {
  -double createdAt
  -long total
  -boolean address
  +double score
  +cancelCreatedat()
  +cancelScore()
  +processScore()
}
abstract class Vehicle {
  #String quantity
  #long total
  -long active
  +getStatus()
  +processPhone()
  +findPrice()
  +getDescription()
}
class Depot {
  -long code
  -int type
  #float address
  +validateStatus()
}
class Warehouse {
  #int id
  +Date phone
  #Date status
  +processStatus()
  +cancelType()
  +deleteId()
  +processDuration()
}
Warehouse --o Driver
Depot --|> Warehouse
@enduml