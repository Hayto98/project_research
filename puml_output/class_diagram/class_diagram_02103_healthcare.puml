@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
abstract class Ward {
  -String createdAt
  -long name
  #Date id
  -int total
  +validateLevel()
}
class Doctor {
  #Date type
  +double active
  +calculateName()
  +deleteAmount()
  +createEmail()
  +saveName()
}
interface MedicalRecord {
  #String status
  #Date description
  -long id
  #Date quantity
  -int code
  +setDescription()
  +setCode()
  +processNote()
  +cancelPhone()
}
abstract class Prescription {
  -boolean duration
  -double score
  #float phone
  -double amount
  +long total
  +getAddress()
  +sendStatus()
  +validatePhone()
}
interface Appointment {
  -int status
  -boolean phone
  +boolean description
  #double amount
  +getCode()
  +saveNote()
}
Prescription --> Doctor : "0..1"
Doctor --* MedicalRecord
Prescription --* Ward
Ward --* Doctor
@enduml