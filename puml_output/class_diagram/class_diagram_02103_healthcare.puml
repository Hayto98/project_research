@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
abstract class Ward {
  -String createdAt
  -long name
  #Date id
  -int total
  +deleteId()
}
abstract class Doctor {
  -float type
  -boolean note
  #double address
  +deleteId()
}
interface MedicalRecord {
  -Date code
  #long score
  +double duration
  +Date address
  +processNote()
  +cancelScore()
  +validateAmount()
}
abstract class Prescription {
  -int duration
  -long note
  -float total
  +boolean level
  +setPhone()
  +deleteAmount()
  +calculateUpdatedat()
}
abstract class Appointment {
  #int active
  #double price
  +boolean description
  +updateEmail()
  +validatePrice()
}
MedicalRecord ..|> Ward
note right of Ward : Healthcare domain
@enduml