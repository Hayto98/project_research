@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Librarian {
  -Date description
  #double quantity
  +int note
  -float type
  +saveTotal()
}
interface Member {
  +boolean duration
  -Date id
  #String price
  -double description
  +calculateActive()
}
abstract class Publisher {
  -Date phone
  #Date updatedAt
  #Date total
  #Date level
  +String createdAt
  +deletePhone()
  +sendName()
  +validateLevel()
  +validateStatus()
}
class Loan {
  #Date id
  +double level
  +int updatedAt
  +deleteNote()
  +getTotal()
  +updatePrice()
  +validateTotal()
}
class Renewal {
  +float active
  -boolean updatedAt
  #long address
  +processId()
  +updateName()
  +deleteDescription()
  +createUpdatedat()
}
Member ..> Loan : "*"
Loan ..|> Publisher
Member --> Librarian : "1"
Publisher --> Librarian : "0..1"
note right of Librarian : Library domain
@enduml