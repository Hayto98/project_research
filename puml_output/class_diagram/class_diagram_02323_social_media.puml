@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
abstract class Profile {
  +float status
  -double phone
  +findStatus()
  +deleteLevel()
  +deleteName()
}
abstract class Hashtag {
  +int status
  +double price
  -long note
  +boolean updatedAt
  +Date score
  +createPhone()
  +getActive()
}
class Message {
  +Date type
  #float level
  -boolean id
  #boolean active
  +boolean price
  +calculateQuantity()
  +findPhone()
  +findAddress()
  +deleteCode()
}
interface Notification {
  #Date total
  +Date quantity
  +long updatedAt
  -boolean status
  +long id
  +setCreatedat()
  +setPrice()
  +findQuantity()
}
abstract class Comment {
  -boolean note
  -float price
  #boolean amount
  +validateScore()
  +cancelUpdatedat()
  +createCreatedat()
  +saveCode()
}
Comment ..|> Profile
Hashtag --> Profile : "1"
Message --> Comment : "*"
@enduml