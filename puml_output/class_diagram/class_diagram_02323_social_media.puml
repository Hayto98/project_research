@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
abstract class Profile {
  +float status
  -double phone
  +saveEmail()
  +calculateLevel()
  +findDuration()
}
abstract class Hashtag {
  +boolean price
  -int note
  +deleteNote()
  +calculateEmail()
}
class Message {
  -double description
  #String status
  #boolean id
  +setActive()
  +validateDuration()
  +findDuration()
  +getScore()
}
abstract class Notification {
  -int description
  +float updatedAt
  +Date phone
  #int note
  #String total
  +validateActive()
  +getPhone()
  +validateAddress()
}
abstract class Comment {
  -boolean note
  -float price
  #boolean amount
  +validateDescription()
  +calculateType()
  +saveLevel()
  +getDescription()
}
Hashtag --> Profile : "1"
Message --> Comment : "*"
Hashtag ..> Notification : "1"
Message ..> Hashtag : "*"
note right of Profile : Social Media domain
@enduml