@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Book {
  #String updatedAt
  #float level
  +int total
  #Date phone
  +sendName()
  +createPrice()
  +createActive()
  +setScore()
}
interface Course {
  +int createdAt
  -long description
  +int email
  +processCode()
  +sendAmount()
}
class Attendance {
  #boolean name
  +long quantity
  +setCode()
}
class Exam {
  -int level
  #String total
  +deleteScore()
  +getNote()
  +deleteTotal()
  +setLevel()
}
class Library {
  +int email
  -float price
  -float level
  -long createdAt
  +createLevel()
  +deleteDuration()
  +setPrice()
}
class Classroom {
  +String duration
  #Date createdAt
  +int level
  +sendDescription()
}
Course --> Attendance : "0..1"
Library --* Book
Library ..|> Exam
Classroom ..> Course : "*"
@enduml