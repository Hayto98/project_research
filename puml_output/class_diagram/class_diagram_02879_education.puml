@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Book {
  #String updatedAt
  #float level
  +int total
  #Date phone
  +processPrice()
  +validateActive()
  +saveAmount()
  +findCreatedat()
}
class Course {
  +int status
  +String createdAt
  #int total
  +String email
  +sendDuration()
  +updateEmail()
  +getCreatedat()
}
class Attendance {
  -float total
  +int amount
  -long code
  -double duration
  +int level
  +processAddress()
  +validateEmail()
}
class Exam {
  +boolean code
  #String amount
  +String createdAt
  -float score
  +Date description
  +cancelUpdatedat()
  +cancelId()
  +createScore()
}
abstract class Library {
  #double updatedAt
  -float quantity
  -boolean description
  +validateType()
  +processActive()
  +validateName()
  +setDescription()
}
class Classroom {
  #float score
  #boolean name
  +validateCode()
  +saveDuration()
  +saveAmount()
  +calculateQuantity()
}
Course ..> Exam : "1..*"
Library --o Book
Classroom --* Attendance
Classroom --|> Exam
Attendance ..> Classroom : "1"
note right of Book : Education domain
@enduml