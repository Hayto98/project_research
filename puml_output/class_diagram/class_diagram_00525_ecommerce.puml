@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Wishlist {
  +double status
  #long name
  -double createdAt
  #String updatedAt
  +processLevel()
  +sendCode()
}
abstract class Category {
  -int updatedAt
  +long phone
  +validateDescription()
  +deleteEmail()
  +createLevel()
}
interface Return {
  +boolean duration
  #long level
  +int description
  #String amount
  +getDescription()
}
class Shipment {
  #long email
  -int note
  -boolean amount
  +String phone
  +findTotal()
}
class Warehouse {
  -double type
  +long address
  +findStatus()
}
class Review {
  #boolean level
  +float code
  #float score
  +Date address
  +Date createdAt
  +findNote()
  +createAmount()
  +cancelScore()
  +cancelNote()
}
Review --|> Wishlist
Category --> Return : "*"
Shipment ..|> Wishlist
Category --o Wishlist
note right of Wishlist : Ecommerce domain
@enduml