@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Wishlist {
  +double status
  #long name
  -double createdAt
  #String updatedAt
  +createName()
  +cancelActive()
}
interface Category {
  +boolean type
  -double status
  +getType()
  +setTotal()
}
class Return {
  #boolean description
  #Date amount
  -boolean email
  #Date score
  +deleteUpdatedat()
  +cancelPrice()
}
class Shipment {
  +int active
  #String duration
  +String quantity
  +calculateAddress()
  +updateLevel()
}
class Warehouse {
  -boolean amount
  +String phone
  +float address
  #double email
  +String updatedAt
  +validateDuration()
  +deleteCode()
  +updateEmail()
  +savePhone()
}
class Review {
  -boolean status
  +Date duration
  +calculateNote()
  +deleteUpdatedat()
  +cancelActive()
}
Review ..> Wishlist : "0..1"
Review ..> Shipment : "*"
Return --> Category : "*"
@enduml