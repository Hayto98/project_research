@startuml
skinparam monochrome true
interface FuelLog {
  #float level
  #boolean address
  +findId()
  +updateName()
  +calculateUpdatedat()
}
interface Package {
  -Date duration
  #String active
  -float code
  #long note
  #double address
  +updateScore()
}
abstract class Customer {
  +long createdAt
  +float level
  +double phone
  +String id
  +deleteQuantity()
}
interface Warehouse {
  -boolean note
  #double address
  -double type
  #float score
  +int updatedAt
  +updateQuantity()
  +saveScore()
  +deleteScore()
}
Customer ..> Package : "0..1"
Package --o Customer
Customer --o FuelLog
@enduml