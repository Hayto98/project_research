@startuml
skinparam monochrome true
interface FuelLog {
  #float level
  #boolean address
  +deleteStatus()
  +saveDuration()
  +savePrice()
}
interface Package {
  #long note
  -Date level
  +processPhone()
}
interface Customer {
  #float level
  #Date status
  #long note
  +int address
  -float createdAt
  +updatePrice()
  +setName()
}
class Warehouse {
  -long score
  -double type
  +createActive()
  +cancelPrice()
}
Warehouse ..|> Customer
Package --* Customer
Customer --* FuelLog
note right of FuelLog : Logistics domain
@enduml