@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
interface Hashtag {
  +int code
  -long price
  #float type
  -float email
  +int name
  +updatePrice()
  +validateDescription()
  +deleteTotal()
}
class Group {
  +int status
  +float total
  #long quantity
  #Date phone
  +updateCreatedat()
  +validateDuration()
  +createAddress()
  +validateActive()
}
class Album {
  +String total
  -double duration
  #String quantity
  +float level
  +boolean updatedAt
  +cancelStatus()
  +cancelScore()
}
class Profile {
  +boolean total
  +boolean price
  #long active
  +calculateDescription()
  +getAmount()
  +createStatus()
}
class User {
  #boolean level
  +float price
  #String createdAt
  #long type
  #Date updatedAt
  +updateType()
  +createEmail()
  +createStatus()
}
class Like {
  #Date note
  #String duration
  +float code
  #String address
  +cancelPhone()
}
Hashtag --|> Profile
Group ..> User : "0..1"
Album ..> Hashtag : "1..*"
note right of Hashtag : Social Media domain
@enduml