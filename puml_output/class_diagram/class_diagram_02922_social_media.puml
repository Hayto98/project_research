@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
interface Hashtag {
  +int code
  -long price
  #float type
  -float email
  +int name
  +saveNote()
  +createDuration()
  +setAmount()
}
class Group {
  #long amount
  +Date total
  -Date updatedAt
  +setCreatedat()
  +saveScore()
  +processCode()
}
class Album {
  #Date score
  -int phone
  +findCode()
  +deleteDescription()
}
class Profile {
  -double address
  #long active
  -float code
  +float note
  +deleteNote()
  +getNote()
}
abstract class User {
  #int amount
  #String duration
  +findLevel()
}
class Like {
  -double price
  +String active
  #int code
  -String name
  +Date phone
  +validateDescription()
  +savePrice()
  +saveName()
  +setPrice()
}
Profile --> Group : "0..1"
User ..> Hashtag : "1..*"
User ..|> Album
@enduml