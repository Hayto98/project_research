@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Vehicle {
  #Date status
  -Date description
  +float score
  +cancelStatus()
  +calculateUpdatedat()
  +validatePhone()
}
class Tracking {
  -String updatedAt
  +int address
  -float level
  +Date phone
  -long price
  +getAddress()
}
interface Warehouse {
  +long name
  +boolean email
  +deleteDescription()
}
class Shipment {
  #boolean note
  -double level
  +Date code
  +Date name
  +boolean address
  +calculateCreatedat()
  +cancelDuration()
  +cancelStatus()
  +createId()
}
Vehicle ..|> Warehouse
Warehouse --* Vehicle
Tracking --* Vehicle
@enduml