@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Vehicle {
  #Date status
  -Date description
  +float score
  +setCode()
  +updateTotal()
  +updateAddress()
}
class Tracking {
  +long price
  +Date quantity
  -long id
  #String score
  +cancelCode()
  +getEmail()
  +getEmail()
  +getActive()
}
class Warehouse {
  #long note
  #boolean duration
  -double code
  +Date name
  +saveCode()
  +sendNote()
}
class Shipment {
  #float price
  +long code
  +validateUpdatedat()
}
Warehouse --|> Shipment
Warehouse --> Tracking : "*"
note right of Vehicle : Logistics domain
@enduml