@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Service {
  -long updatedAt
  #float type
  +sendDescription()
  +findTotal()
  +sendDuration()
  +setCreatedat()
}
class Booking {
  #float active
  +int address
  +updateId()
  +findName()
  +calculateCreatedat()
  +deleteUpdatedat()
}
abstract class Payment {
  +boolean description
  -float updatedAt
  +double amount
  -long type
  +sendActive()
  +processNote()
  +getScore()
}
class CheckIn {
  #long level
  #Date description
  #boolean updatedAt
  -boolean phone
  +cancelAmount()
  +cancelDescription()
  +findActive()
}
class CheckOut {
  -boolean total
  #String name
  +processCreatedat()
}
CheckIn --* Booking
Service --* CheckOut
Payment ..> Service : "0..1"
@enduml