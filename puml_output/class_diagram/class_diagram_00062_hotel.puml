@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Service {
  -long updatedAt
  #float type
  +saveCode()
  +getActive()
  +cancelAddress()
  +cancelUpdatedat()
}
class Booking {
  +Date level
  +double address
  +boolean note
  -float quantity
  +double description
  +validateAddress()
  +cancelActive()
  +createDuration()
  +createLevel()
}
class Payment {
  -boolean phone
  #long address
  #Date score
  +createStatus()
  +saveTotal()
  +findName()
  +validateDuration()
}
interface CheckIn {
  #double id
  +long total
  +setPhone()
}
class CheckOut {
  +float updatedAt
  -boolean description
  +deleteStatus()
  +calculateStatus()
}
Service --* Payment
Payment --|> Service
note right of Service : Hotel domain
@enduml