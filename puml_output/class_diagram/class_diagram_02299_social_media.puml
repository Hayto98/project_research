@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class User {
  #int phone
  -boolean updatedAt
  +deleteEmail()
  +createDescription()
}
abstract class Post {
  -boolean price
  +double code
  +long total
  +float quantity
  +boolean score
  +updateAmount()
  +getEmail()
  +updateName()
}
interface Profile {
  +float amount
  #boolean level
  -String createdAt
  #int id
  -long duration
  +sendCode()
  +calculateName()
  +processEmail()
  +calculateId()
}
class Message {
  +Date quantity
  -int total
  +float status
  +float score
  +createDuration()
}
Message --> Profile : "*"
Message ..> User : "*"
Post --> Message : "*"
note right of User : Social Media domain
@enduml