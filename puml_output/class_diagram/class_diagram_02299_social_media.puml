@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class User {
  #int phone
  -boolean updatedAt
  +findLevel()
  +validateQuantity()
}
class Post {
  +double description
  -double total
  -boolean level
  +double price
  +findCode()
}
class Profile {
  +int active
  +long address
  +saveEmail()
  +deleteDescription()
}
abstract class Message {
  +String level
  #boolean createdAt
  -String id
  +createPrice()
  +findCreatedat()
}
User --|> Post
Message --o Post
User --* Message
@enduml