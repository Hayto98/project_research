@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
abstract class Tracking {
  #long phone
  -float level
  +sendDescription()
  +processCode()
  +setUpdatedat()
}
class Inventory {
  +float level
  -int active
  +cancelQuantity()
  +setEmail()
}
class FuelLog {
  +Date name
  -double id
  -float type
  +float level
  -double price
  +sendDescription()
  +updateLevel()
}
abstract class Manifest {
  #String code
  -int email
  +calculateDescription()
  +calculateCode()
  +processEmail()
  +validateAmount()
}
class Vehicle {
  +long address
  -int quantity
  -Date price
  -Date duration
  +boolean email
  +saveTotal()
  +findPrice()
  +createScore()
}
class Shipment {
  +Date score
  -long code
  -float level
  +getLevel()
  +savePhone()
  +deleteId()
}
Manifest --|> Vehicle
Vehicle --|> Manifest
Shipment ..> Tracking : "0..1"
@enduml