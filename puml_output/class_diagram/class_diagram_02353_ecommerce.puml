@startuml

abstract class Shipment {
  #String quantity
  -Date level
  +cancelTotal()
  +deleteUpdatedat()
}
abstract class Product {
  -boolean code
  -float quantity
  +calculateCreatedat()
  +saveAmount()
  +findType()
  +createAmount()
}
class Cart {
  +double total
  #int level
  +int description
  -long email
  #float code
  +setId()
  +calculateScore()
  +cancelType()
}
class Review {
  +float level
  +long quantity
  -String updatedAt
  #long status
  +createType()
  +findUpdatedat()
  +processDuration()
  +cancelPrice()
}
Product --> Review : "0..1"
Product --|> Shipment
note right of Shipment : Ecommerce domain
@enduml