@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
abstract class Department {
  +String level
  +String updatedAt
  +sendName()
  +getType()
  +updateCreatedat()
}
abstract class Teacher {
  -boolean type
  #String amount
  #float score
  +cancelEmail()
  +sendStatus()
  +findAmount()
}
abstract class Course {
  #Date id
  #String description
  -double status
  +Date level
  #int email
  +setPrice()
  +setAddress()
}
class Schedule {
  +Date quantity
  -boolean amount
  #String id
  -String email
  +String active
  +saveCreatedat()
  +updateAddress()
  +cancelScore()
  +sendNote()
}
Department --* Teacher
Department --* Schedule
Schedule ..> Department : "1..*"
note right of Department : Education domain
@enduml