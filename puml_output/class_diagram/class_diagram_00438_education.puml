@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
abstract class Department {
  +String level
  +String updatedAt
  +saveActive()
  +deleteId()
  +savePhone()
}
class Teacher {
  +boolean updatedAt
  -boolean createdAt
  #String note
  #float amount
  -boolean type
  +calculatePrice()
  +updateUpdatedat()
  +saveDescription()
}
class Course {
  -boolean note
  #Date id
  +long description
  -String status
  #float score
  +saveAddress()
  +getType()
}
abstract class Schedule {
  #double address
  -int createdAt
  +deleteName()
}
Teacher --o Course
Department --|> Teacher
Department --o Schedule
@enduml