@startuml
skinparam monochrome true
skinparam shadowing true
class Package {
  -long type
  #boolean quantity
  +long level
  #int score
  +createEmail()
  +cancelPrice()
  +updateNote()
}
class Shipment {
  -Date type
  +String address
  +double updatedAt
  +double phone
  +float total
  +processDescription()
}
class Vehicle {
  #float description
  +double quantity
  #Date price
  -long address
  -boolean name
  +calculateCreatedat()
}
class FuelLog {
  +float price
  -float note
  #float total
  +processAmount()
  +setAmount()
  +updateTotal()
  +cancelType()
}
interface Warehouse {
  -long type
  +float address
  -long amount
  -float active
  +double phone
  +validateAddress()
  +processAddress()
  +sendLevel()
}
class Tracking {
  -double quantity
  #String price
  +setDuration()
  +calculateAmount()
  +findTotal()
  +saveTotal()
}
interface Driver {
  +boolean total
  -long type
  -Date name
  #double description
  +sendTotal()
}
Shipment --> Package : "0..1"
Package --o Driver
@enduml