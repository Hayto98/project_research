@startuml
skinparam monochrome true
skinparam shadowing true
class Package {
  -long type
  #boolean quantity
  +long level
  #int score
  +saveActive()
  +deleteTotal()
  +processAddress()
}
class Shipment {
  +double total
  +double email
  +float code
  #String name
  +deleteTotal()
  +deleteQuantity()
  +calculateAddress()
}
class Vehicle {
  -boolean total
  +long note
  -int address
  +processLevel()
  +saveTotal()
  +deleteAddress()
  +saveNote()
}
class FuelLog {
  +float score
  #boolean type
  -double level
  -int address
  +createEmail()
  +deleteTotal()
  +validateEmail()
  +deleteStatus()
}
class Warehouse {
  -float email
  #long note
  -double active
  #String status
  +float level
  +sendAddress()
}
class Tracking {
  +boolean note
  +String id
  +double level
  +double code
  +float amount
  +getCreatedat()
  +validateStatus()
  +calculateType()
  +findLevel()
}
class Driver {
  #float status
  -float score
  +sendType()
  +findTotal()
}
Driver ..> Warehouse : "0..1"
FuelLog --o Warehouse
note right of Package : Logistics domain
@enduml