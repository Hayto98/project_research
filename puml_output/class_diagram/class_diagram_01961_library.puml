@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
interface Renewal {
  -Date duration
  #int level
  -int id
  #Date updatedAt
  +getAddress()
  +deleteStatus()
}
interface Branch {
  -double price
  #boolean total
  +deleteName()
  +processPhone()
  +sendLevel()
}
class Member {
  #boolean createdAt
  +Date name
  +boolean updatedAt
  +int score
  +deleteLevel()
}
interface Catalog {
  #boolean phone
  -long score
  +saveNote()
  +calculateCode()
  +updatePhone()
  +saveDescription()
}
class Fine {
  #Date active
  -Date price
  -long level
  -Date id
  -String updatedAt
  +cancelUpdatedat()
  +findAddress()
}
class Publisher {
  -float type
  #int total
  +float status
  -int price
  +saveDuration()
}
class Loan {
  -long amount
  -int description
  #float note
  #String score
  +validateType()
  +updateName()
}
Member --|> Publisher
Loan ..> Fine : "*"
@enduml