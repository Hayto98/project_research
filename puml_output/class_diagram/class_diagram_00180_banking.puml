@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Statement {
  #double id
  #Date level
  +Date updatedAt
  #float score
  -String phone
  +deleteCode()
}
class Transfer {
  +Date email
  +String quantity
  #boolean score
  #Date status
  +cancelType()
}
abstract class Withdrawal {
  #float amount
  -double address
  -float score
  #int email
  -String createdAt
  +sendName()
}
class Deposit {
  +String quantity
  +Date type
  +boolean name
  -float active
  +saveQuantity()
  +findCode()
}
class Interest {
  #int duration
  #float status
  #Date level
  #float email
  #float id
  +findScore()
  +processStatus()
  +deleteDuration()
}
class Teller {
  -float price
  #double phone
  #long quantity
  -boolean level
  #int amount
  +findCreatedat()
}
Deposit ..> Withdrawal : "*"
Teller ..> Withdrawal : "1"
Deposit ..|> Teller
note right of Statement : Banking domain
@enduml