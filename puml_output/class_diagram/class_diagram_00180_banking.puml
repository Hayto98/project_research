@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Statement {
  #double id
  #Date level
  +Date updatedAt
  #float score
  -String phone
  +validateCode()
}
class Transfer {
  -Date email
  #String duration
  +sendLevel()
  +calculateUpdatedat()
}
class Withdrawal {
  #Date duration
  +boolean score
  +sendCode()
  +sendActive()
  +sendScore()
  +updateType()
}
class Deposit {
  #int createdAt
  -String quantity
  +boolean price
  +float score
  +processDescription()
}
class Interest {
  #float name
  +boolean active
  -float createdAt
  +Date id
  -Date description
  +createId()
}
class Teller {
  #int duration
  #float status
  #Date level
  #float email
  #float id
  +updateId()
  +calculateDuration()
  +sendName()
}
Transfer --|> Interest
Interest ..> Deposit : "*"
@enduml