@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
interface Insurance {
  #long id
  +String name
  +double address
  +Date type
  +findType()
  +validateQuantity()
  +cancelLevel()
}
class Diagnosis {
  +boolean email
  -Date code
  #float createdAt
  +Date phone
  +createId()
  +sendUpdatedat()
  +findUpdatedat()
}
abstract class LabTest {
  #boolean name
  +float amount
  +double active
  -double level
  +createLevel()
  +findStatus()
  +processQuantity()
}
class Hospital {
  #boolean total
  #float phone
  #long amount
  #double updatedAt
  +findAddress()
  +validateStatus()
}
LabTest --* Diagnosis
Hospital --* Insurance
@enduml