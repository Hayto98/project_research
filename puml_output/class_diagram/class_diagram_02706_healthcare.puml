@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
interface Insurance {
  #long id
  +String name
  +double address
  +Date type
  +deleteAddress()
  +findDuration()
  +cancelEmail()
}
class Diagnosis {
  +boolean createdAt
  -Date phone
  +findEmail()
  +findDuration()
}
abstract class LabTest {
  #boolean name
  +float amount
  +double active
  -double level
  +findName()
  +updateQuantity()
  +findTotal()
}
class Hospital {
  #double updatedAt
  #int score
  +float quantity
  +createPhone()
  +validateDuration()
}
Insurance --o Diagnosis
Insurance --> Hospital : "1"
Hospital ..> LabTest : "1..*"
note right of Insurance : Healthcare domain
@enduml