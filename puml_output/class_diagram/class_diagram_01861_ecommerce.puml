@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Return {
  #int updatedAt
  -long total
  -double id
  -float level
  +processCode()
  +setNote()
}
class Category {
  +float type
  #boolean level
  +saveUpdatedat()
}
class Invoice {
  #String quantity
  +Date address
  +int type
  +calculateActive()
  +getScore()
}
class Wishlist {
  +boolean address
  +String duration
  -float price
  -String description
  +deletePhone()
}
Wishlist --o Category
Return --> Category : "1"
Wishlist ..> Invoice : "1"
note right of Return : Ecommerce domain
@enduml