@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Return {
  #int updatedAt
  -long total
  -double id
  -float level
  +deleteActive()
  +createAddress()
}
class Category {
  #int address
  -int id
  -long type
  #Date level
  #double code
  +deleteScore()
}
class Invoice {
  +boolean createdAt
  +long total
  -long active
  +sendDuration()
  +getEmail()
  +deleteQuantity()
  +setAddress()
}
class Wishlist {
  +String quantity
  +long price
  +processAddress()
  +setPhone()
  +processLevel()
}
Wishlist --o Return
Return --> Invoice : "*"
Return --|> Category
@enduml