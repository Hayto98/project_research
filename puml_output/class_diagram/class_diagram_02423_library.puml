@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Renewal {
  +double level
  -long phone
  #double id
  +processName()
  +cancelEmail()
  +saveCode()
  +findCode()
}
abstract class Shelf {
  +long name
  -int total
  +int duration
  -boolean id
  +validateDuration()
  +sendAmount()
}
interface Branch {
  +Date description
  +float phone
  +calculatePhone()
}
class Librarian {
  #long address
  +boolean active
  +double note
  +createLevel()
  +getDuration()
}
class Author {
  +int name
  +long createdAt
  +deleteActive()
  +findActive()
  +deleteName()
  +sendLevel()
}
abstract class Fine {
  -boolean name
  +boolean amount
  +createQuantity()
  +cancelEmail()
  +getDescription()
  +getUpdatedat()
}
Fine --> Renewal : "1"
Author --o Fine
Renewal ..> Librarian : "1"
Fine ..|> Shelf
@enduml