@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Renewal {
  +double level
  -long phone
  #double id
  +getStatus()
  +calculatePhone()
  +processEmail()
  +getTotal()
}
class Shelf {
  -int id
  +int address
  +cancelCreatedat()
  +validateScore()
  +cancelStatus()
  +deletePhone()
}
class Branch {
  +long status
  #boolean quantity
  -Date id
  +getLevel()
  +updateTotal()
  +deleteName()
}
class Librarian {
  +int createdAt
  -float code
  +processType()
  +createNote()
  +cancelName()
  +findName()
}
class Author {
  #float duration
  -long description
  +float score
  -Date active
  +sendStatus()
}
interface Fine {
  -Date id
  +int type
  -boolean score
  +String status
  +float code
  +processCode()
  +updateNote()
  +calculateStatus()
  +setTotal()
}
Branch ..> Renewal : "*"
Fine --* Branch
Branch --* Shelf
Branch ..|> Fine
note right of Renewal : Library domain
@enduml