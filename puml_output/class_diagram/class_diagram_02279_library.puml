@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Catalog {
  +int type
  #boolean id
  +float amount
  #long name
  #double phone
  +createQuantity()
  +cancelAmount()
  +getUpdatedat()
  +calculateCode()
}
interface Reservation {
  #float duration
  -long phone
  #long address
  +validatePhone()
  +saveCode()
  +getScore()
}
class Member {
  -Date updatedAt
  +long description
  +boolean phone
  +double active
  #Date name
  +saveName()
}
class Publisher {
  +float code
  +long email
  +findAmount()
  +deleteQuantity()
}
abstract class Shelf {
  -float duration
  +String code
  +deletePrice()
  +sendDuration()
  +sendTotal()
  +findStatus()
}
class Fine {
  #long active
  #double duration
  +sendStatus()
}
class Renewal {
  -double score
  +float description
  +float address
  -float total
  +processDuration()
  +calculateUpdatedat()
}
Catalog --o Publisher
Renewal --|> Catalog
Publisher --|> Reservation
note right of Catalog : Library domain
@enduml