@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Catalog {
  +int type
  #boolean id
  +float amount
  #long name
  #double phone
  +findCreatedat()
  +calculatePhone()
  +deleteUpdatedat()
  +validateQuantity()
}
class Reservation {
  +boolean total
  -long code
  #float active
  +findCreatedat()
  +cancelScore()
  +updateLevel()
  +saveScore()
}
class Member {
  -int code
  #int id
  #long score
  #String description
  +createType()
  +saveAddress()
  +validateLevel()
  +deleteCode()
}
class Publisher {
  #float type
  #String status
  +sendTotal()
}
class Shelf {
  #int id
  +long description
  -float phone
  +boolean createdAt
  +processDescription()
}
class Fine {
  -float price
  #boolean description
  +deleteType()
  +updateName()
  +sendLevel()
  +findAddress()
}
class Renewal {
  #int price
  #Date code
  #long active
  #Date status
  +saveCreatedat()
  +findAmount()
}
Publisher --|> Reservation
Renewal ..|> Member
Publisher --> Fine : "*"
Reservation --|> Renewal
@enduml