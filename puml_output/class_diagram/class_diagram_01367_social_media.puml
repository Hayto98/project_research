@startuml

interface Message {
  #Date code
  #String id
  #Date description
  #float type
  -double level
  +updateAddress()
  +validateLevel()
  +cancelLevel()
}
abstract class User {
  +boolean email
  #boolean total
  +double updatedAt
  +setUpdatedat()
  +saveActive()
  +getDescription()
}
interface Notification {
  #float email
  -float amount
  -String name
  +boolean phone
  -int level
  +processDuration()
  +setId()
  +validateQuantity()
}
interface Comment {
  +Date phone
  #int id
  #int description
  +cancelLevel()
}
Notification --|> Comment
Message --|> User
@enduml