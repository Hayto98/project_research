@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Transfer {
  #Date type
  +long price
  +double updatedAt
  #String level
  +cancelEmail()
}
interface Statement {
  #double createdAt
  #long address
  +float amount
  -long active
  -Date email
  +cancelQuantity()
}
abstract class Transaction {
  -String note
  -boolean email
  +boolean type
  #int duration
  +float score
  +getStatus()
}
abstract class Beneficiary {
  +boolean description
  #int amount
  +setCode()
  +getName()
  +createNote()
}
Beneficiary --* Transaction
Statement --* Transaction
@enduml