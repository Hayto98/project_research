@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Album {
  -double status
  #String note
  #String level
  +double email
  +findNote()
  +saveName()
  +validateName()
  +saveQuantity()
}
class Story {
  #Date email
  #int code
  +validateEmail()
  +saveScore()
  +getDuration()
}
class Post {
  +Date updatedAt
  +Date level
  +calculateAddress()
  +validateAddress()
  +cancelId()
  +createNote()
}
class Message {
  +int name
  #String price
  #Date email
  -long quantity
  +setUpdatedat()
  +cancelLevel()
  +getPrice()
  +cancelPrice()
}
Post --o Album
@enduml