@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Album {
  -double status
  #String note
  #String level
  +double email
  +setPrice()
  +processDescription()
  +saveAddress()
  +cancelName()
}
class Story {
  -String level
  -float description
  +setUpdatedat()
  +cancelStatus()
}
class Post {
  +double amount
  #long email
  -int phone
  +boolean duration
  +boolean address
  +validateNote()
  +getStatus()
  +validateDescription()
  +processEmail()
}
class Message {
  #float createdAt
  +long amount
  #boolean active
  #long phone
  +setLevel()
  +getEmail()
}
Story ..|> Album
Message --o Album
Post --> Message : "1..*"
note right of Album : Social Media domain
@enduml