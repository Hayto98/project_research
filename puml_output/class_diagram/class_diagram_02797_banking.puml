@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Branch {
  -double phone
  +String code
  +long createdAt
  +float description
  +calculateQuantity()
  +getType()
  +updateAddress()
  +sendDescription()
}
class Deposit {
  +float phone
  #int total
  +long address
  #float status
  +setAddress()
}
abstract class Loan {
  +Date address
  #String price
  -Date duration
  +updatePhone()
  +findPrice()
}
class Account {
  #double quantity
  #boolean name
  #double score
  +updateAddress()
  +cancelAmount()
}
Branch --|> Deposit
Deposit --* Account
Account ..|> Deposit
@enduml