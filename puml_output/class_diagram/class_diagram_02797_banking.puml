@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Branch {
  -double phone
  +String code
  +long createdAt
  +float description
  +calculateCode()
  +saveEmail()
  +createPhone()
  +calculateAddress()
}
class Deposit {
  #float updatedAt
  #Date description
  #String phone
  +updateAddress()
  +calculateAddress()
  +deleteLevel()
  +setAddress()
}
interface Loan {
  -String active
  #boolean description
  #double createdAt
  +deleteScore()
  +processStatus()
  +createCode()
  +deleteType()
}
class Account {
  +Date price
  #Date amount
  #float score
  #float createdAt
  +int quantity
  +updateAddress()
  +processDescription()
}
Deposit --> Loan : "*"
Account --|> Deposit
Deposit --> Branch : "1"
note right of Branch : Banking domain
@enduml