@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Housekeeping {
  +long score
  #float code
  -String email
  #long active
  +int level
  +cancelPrice()
  +saveType()
  +findLevel()
}
interface CheckIn {
  +boolean code
  -int email
  +long description
  +createCode()
}
abstract class Amenity {
  -float createdAt
  +Date score
  +int email
  -long description
  -boolean active
  +processScore()
  +updateDescription()
}
class Guest {
  #boolean note
  +Date status
  +createCode()
  +deleteEmail()
}
class Staff {
  +Date note
  #long email
  +getPrice()
  +findStatus()
}
Guest --o Amenity
Amenity --> Staff : "1"
@enduml