@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
abstract class User {
  #int price
  -Date updatedAt
  +Date level
  +validateNote()
  +deleteType()
}
class Follower {
  #int amount
  #long address
  +sendQuantity()
}
abstract class Profile {
  #boolean amount
  +int phone
  +long price
  +findDescription()
}
abstract class Notification {
  +boolean status
  +int score
  #long updatedAt
  +boolean amount
  +updateDescription()
  +createDescription()
  +processNote()
  +setUpdatedat()
}
abstract class Comment {
  #boolean duration
  -String name
  -Date note
  +deleteLevel()
}
class Like {
  +float amount
  -String price
  +updateScore()
}
abstract class Message {
  -int id
  #boolean duration
  #long score
  +createCreatedat()
}
Follower ..|> Message
Message --o User
@enduml