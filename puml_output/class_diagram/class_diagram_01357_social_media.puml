@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
abstract class User {
  #int price
  -Date updatedAt
  +Date level
  +updateCreatedat()
  +saveId()
}
class Follower {
  #double active
  +int updatedAt
  -double phone
  #boolean name
  +deleteName()
  +createId()
}
interface Profile {
  +boolean address
  +int status
  #long score
  +boolean updatedAt
  -int amount
  +calculateActive()
}
class Notification {
  #double note
  +long score
  +updateId()
}
class Comment {
  #boolean updatedAt
  +String phone
  +boolean code
  -int status
  #boolean type
  +getDescription()
  +saveName()
  +deleteCreatedat()
}
class Like {
  -String type
  -int quantity
  +setUpdatedat()
  +updateAmount()
}
class Message {
  #boolean price
  +Date quantity
  +String duration
  #String level
  #Date description
  +sendAddress()
  +deleteId()
}
Like --o Profile
Like ..|> Follower
User --o Follower
note right of User : Social Media domain
@enduml