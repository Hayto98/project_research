@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
interface Author {
  #boolean description
  -boolean total
  +long active
  +saveCode()
  +deleteTotal()
  +cancelActive()
}
abstract class Book {
  -double type
  -float active
  #int updatedAt
  -float total
  +saveNote()
  +sendActive()
}
abstract class Publisher {
  -boolean active
  #double address
  #int name
  -long note
  +validateActive()
  +cancelCreatedat()
  +getType()
}
class Librarian {
  +boolean id
  -Date duration
  +sendCode()
  +cancelDescription()
}
class Member {
  -float address
  -boolean createdAt
  +createAmount()
  +cancelCreatedat()
  +setEmail()
}
class Branch {
  #double type
  -Date amount
  #float score
  #String address
  -Date phone
  +setNote()
  +deleteAddress()
  +createCode()
  +getPrice()
}
class Reservation {
  #float name
  +float total
  -String note
  +String id
  -boolean type
  +processEmail()
}
Author ..> Book : "0..1"
Book --|> Librarian
Reservation --|> Publisher
Book --|> Reservation
note right of Author : Library domain
@enduml