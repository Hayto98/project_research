@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
interface Author {
  #boolean description
  -boolean total
  +long active
  +cancelPrice()
  +setQuantity()
  +cancelDuration()
}
class Book {
  -long total
  -float level
  #int active
  +setNote()
  +saveName()
  +findActive()
  +validateStatus()
}
interface Publisher {
  #boolean phone
  #Date updatedAt
  -long note
  +saveLevel()
  +findName()
  +processNote()
}
class Librarian {
  -long note
  #boolean duration
  +String amount
  -String level
  #String email
  +updateActive()
}
class Member {
  -boolean active
  +long createdAt
  +float score
  -float code
  -boolean description
  +findCreatedat()
  +calculateAddress()
  +findName()
}
class Branch {
  -double email
  +float description
  +updateAddress()
  +processNote()
  +updateTotal()
}
abstract class Reservation {
  +double id
  +long price
  -String score
  +double level
  +processTotal()
}
Reservation --o Librarian
Author --o Branch
@enduml