@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
abstract class Publisher {
  #float name
  #int description
  #float id
  +int code
  +getTotal()
}
interface Reservation {
  +float score
  +double phone
  +deleteAddress()
}
class Catalog {
  #String note
  -int address
  -String description
  +getStatus()
  +sendActive()
}
interface Shelf {
  #Date quantity
  #String duration
  +float address
  #String active
  +String amount
  +createEmail()
  +cancelAmount()
  +updateCreatedat()
  +processNote()
}
class Author {
  +int score
  #long createdAt
  #String phone
  +double code
  +double email
  +validateEmail()
  +saveName()
  +processScore()
}
interface Loan {
  +String description
  +float code
  +Date price
  #double total
  +deleteNote()
  +sendAddress()
  +validateAmount()
}
class Book {
  -double active
  #int address
  +String score
  +saveAmount()
  +getAddress()
}
Shelf ..|> Loan
Author --|> Reservation
Book --|> Shelf
note right of Publisher : Library domain
@enduml