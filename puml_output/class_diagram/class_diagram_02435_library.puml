@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
abstract class Publisher {
  #float name
  #int description
  #float id
  +int code
  +updatePrice()
}
abstract class Reservation {
  +float score
  +double phone
  +calculateAddress()
}
class Catalog {
  +Date createdAt
  +long note
  +long address
  +getScore()
}
class Shelf {
  #Date status
  #double active
  +createQuantity()
  +validateDescription()
  +validateScore()
}
interface Author {
  #String active
  +String id
  -long createdAt
  +updateCreatedat()
  +sendActive()
  +cancelDescription()
}
class Loan {
  -boolean createdAt
  -boolean type
  +long note
  +getDescription()
}
class Book {
  #String createdAt
  +double active
  +double phone
  +updateTotal()
  +validateAmount()
  +findStatus()
}
Shelf --> Author : "1..*"
Book ..|> Loan
@enduml