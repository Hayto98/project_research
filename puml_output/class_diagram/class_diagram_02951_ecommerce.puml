@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Return {
  -Date phone
  -boolean description
  +int active
  +getAmount()
  +updateCreatedat()
}
interface Warehouse {
  +long active
  -String address
  #Date description
  #long status
  +long updatedAt
  +saveDescription()
  +findAddress()
  +processPhone()
}
class Payment {
  +long amount
  +boolean createdAt
  -String email
  #double note
  -int level
  +saveLevel()
}
abstract class Cart {
  -String amount
  +Date status
  +String description
  +findId()
  +calculateLevel()
}
class Invoice {
  -Date note
  -int status
  #Date name
  #long quantity
  #double id
  +cancelCode()
}
class Shipment {
  #float updatedAt
  #long total
  +long name
  #double level
  +saveId()
  +updateEmail()
  +findQuantity()
}
Cart ..> Warehouse : "0..1"
Return --* Warehouse
@enduml