@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Return {
  -Date phone
  -boolean description
  +int active
  +saveActive()
  +calculateActive()
}
class Warehouse {
  -double status
  +boolean updatedAt
  #Date level
  +setQuantity()
  +validateUpdatedat()
  +createTotal()
}
class Payment {
  +String duration
  -float email
  +boolean note
  +getNote()
  +createDescription()
  +getType()
  +deleteAmount()
}
class Cart {
  #String phone
  +boolean code
  +int id
  +processNote()
  +setName()
  +createId()
}
class Invoice {
  -String updatedAt
  #long phone
  +Date active
  -float price
  +double id
  +deleteEmail()
  +findType()
  +validateName()
}
abstract class Shipment {
  +String code
  #Date note
  +long createdAt
  +double active
  +cancelCode()
  +calculatePrice()
  +getDuration()
}
Invoice --|> Cart
Cart --|> Shipment
note right of Return : Ecommerce domain
@enduml