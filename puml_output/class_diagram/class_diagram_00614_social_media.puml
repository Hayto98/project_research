@startuml
skinparam monochrome true
class Profile {
  -Date duration
  #Date quantity
  +cancelTotal()
  +validatePhone()
  +calculateLevel()
}
class Story {
  -long name
  -float status
  +createPrice()
}
class Post {
  -double id
  +Date type
  +Date note
  -int total
  -double score
  +deleteStatus()
}
class Comment {
  -String quantity
  +boolean price
  -int description
  +processQuantity()
  +setAddress()
}
Story --* Post
Comment --> Story : "0..1"
@enduml