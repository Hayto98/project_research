@startuml
skinparam monochrome true
class Profile {
  -Date duration
  #Date quantity
  +getCode()
  +validateName()
  +getStatus()
}
abstract class Story {
  -String address
  -double status
  -Date price
  -long updatedAt
  +getCreatedat()
  +saveEmail()
  +deleteTotal()
  +processCode()
}
class Post {
  -String quantity
  +boolean price
  -int description
  +getScore()
  +getCreatedat()
}
interface Comment {
  -boolean type
  -Date note
  #int amount
  -double code
  +getEmail()
  +createTotal()
}
Comment --* Post
Comment --|> Story
note right of Profile : Social Media domain
@enduml