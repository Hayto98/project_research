@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class FuelLog {
  -double updatedAt
  +int duration
  +long phone
  #String quantity
  +sendCode()
  +processCreatedat()
  +saveCode()
}
class Shipment {
  #Date score
  +int duration
  +long email
  +long note
  #boolean createdAt
  +deleteName()
}
class Customer {
  +String amount
  +boolean email
  #long code
  -Date createdAt
  +sendCode()
  +setAddress()
}
abstract class Manifest {
  -float total
  -long id
  #String address
  -float name
  -int price
  +createNote()
  +calculatePhone()
}
class Vehicle {
  #String duration
  -String note
  +long createdAt
  +Date status
  -boolean code
  +getPrice()
  +validatePrice()
}
abstract class DeliveryNote {
  #long amount
  -boolean price
  #String address
  +float active
  +saveAmount()
  +saveEmail()
  +setUpdatedat()
  +updateAddress()
}
Shipment --* FuelLog
DeliveryNote ..> Vehicle : "1..*"
Manifest --> FuelLog : "0..1"
@enduml