@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
abstract class Staff {
  #Date active
  #String score
  +cancelId()
  +sendActive()
  +deleteNote()
  +setEmail()
}
class Reservation {
  +long code
  #long duration
  -int type
  +long updatedAt
  +cancelAmount()
  +updateQuantity()
  +createAddress()
}
interface Invoice {
  #Date duration
  +int code
  +boolean id
  #long score
  -long updatedAt
  +getCode()
  +deleteScore()
  +saveDescription()
  +processCode()
}
class Room {
  #long status
  +String email
  -long createdAt
  +processStatus()
  +cancelQuantity()
  +findActive()
}
Invoice --o Room
Staff ..|> Reservation
note right of Staff : Hotel domain
@enduml