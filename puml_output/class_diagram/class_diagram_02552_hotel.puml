@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
abstract class Staff {
  #Date active
  #String score
  +validateActive()
  +processCode()
  +cancelLevel()
  +findDuration()
}
interface Reservation {
  +long note
  #String status
  +double email
  +deleteAddress()
  +sendAddress()
}
interface Invoice {
  -boolean type
  +int updatedAt
  -long id
  -boolean address
  +validateActive()
  +getLevel()
  +setAmount()
  +updatePrice()
}
class Room {
  #boolean updatedAt
  -float description
  -long amount
  +validateStatus()
  +updateDuration()
  +processAmount()
  +updateType()
}
Room ..|> Staff
Reservation --* Staff
@enduml