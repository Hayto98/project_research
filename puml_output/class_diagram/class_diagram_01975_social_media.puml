@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
abstract class User {
  #String updatedAt
  -float status
  #int level
  -String code
  +double duration
  +sendCreatedat()
  +processScore()
}
class Report {
  -float status
  +float phone
  +findCreatedat()
  +cancelCode()
}
abstract class Notification {
  -int quantity
  -double note
  +int phone
  -Date total
  +setTotal()
}
interface Post {
  +long level
  -boolean email
  #String code
  -Date active
  +processId()
  +processName()
  +findDescription()
}
interface Hashtag {
  -Date updatedAt
  -long quantity
  #double code
  #float phone
  #long type
  +calculateName()
}
interface Like {
  +String quantity
  +double price
  -Date amount
  +validateDescription()
}
Post ..|> Like
Like --|> User
@enduml