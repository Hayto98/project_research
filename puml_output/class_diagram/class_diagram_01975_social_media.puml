@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
abstract class User {
  #String updatedAt
  -float status
  #int level
  -String code
  +double duration
  +processStatus()
  +setStatus()
}
class Report {
  -long updatedAt
  -Date duration
  -Date email
  -boolean type
  +processAmount()
  +createPrice()
  +getUpdatedat()
  +processStatus()
}
class Notification {
  +long level
  -boolean email
  #String code
  -Date active
  +cancelId()
  +cancelScore()
  +processUpdatedat()
}
class Post {
  -Date phone
  -long type
  +findQuantity()
  +getAddress()
  +saveLevel()
  +cancelAmount()
}
class Hashtag {
  -Date amount
  +float description
  +double status
  -int duration
  #String type
  +getQuantity()
}
abstract class Like {
  -float quantity
  -long code
  -long name
  +updateAddress()
  +saveTotal()
}
Report --* Post
Post ..> Report : "*"
note right of User : Social Media domain
@enduml