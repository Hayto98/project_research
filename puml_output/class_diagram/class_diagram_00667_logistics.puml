@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Shipment {
  #long amount
  +int description
  +int type
  -float createdAt
  +updateScore()
  +processEmail()
}
interface Tracking {
  #double score
  -long phone
  #boolean address
  +Date email
  +findCode()
}
interface Manifest {
  #float duration
  #float phone
  +long level
  +long id
  +setQuantity()
}
class Driver {
  #boolean email
  -boolean amount
  #Date total
  -String updatedAt
  +float type
  +setDescription()
  +deleteCode()
  +sendAddress()
  +createPrice()
}
Manifest ..|> Tracking
Driver --o Manifest
Shipment ..|> Tracking
@enduml