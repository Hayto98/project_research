@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Shipment {
  #long amount
  +int description
  +int type
  -float createdAt
  +findLevel()
  +saveDuration()
}
class Tracking {
  -long address
  #boolean email
  +Date score
  #String type
  +cancelPhone()
  +cancelPhone()
  +validateDuration()
}
interface Manifest {
  +long status
  +float quantity
  +cancelPrice()
  +createAmount()
}
interface Driver {
  +String updatedAt
  -String level
  -long type
  -float total
  #boolean quantity
  +createPhone()
  +deleteType()
  +findType()
}
Driver --|> Shipment
Tracking --* Manifest
note right of Shipment : Logistics domain
@enduml