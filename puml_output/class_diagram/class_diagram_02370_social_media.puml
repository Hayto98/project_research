@startuml
skinparam monochrome true
class Story {
  #int phone
  +double name
  -long code
  +deleteTotal()
}
interface Like {
  -Date address
  #long level
  +updateDuration()
  +validatePhone()
  +validateType()
}
class Message {
  -boolean code
  #int note
  +calculateDescription()
  +deleteName()
  +updateUpdatedat()
}
interface Album {
  #long quantity
  +String note
  #long code
  -long id
  +int name
  +setPhone()
  +cancelAmount()
  +createId()
  +updateNote()
}
class Group {
  #Date id
  +int amount
  #String type
  +double name
  +processId()
  +getEmail()
  +updateAddress()
  +getType()
}
Album --* Like
Like --* Story
Story --* Album
Story --> Message : "0..1"
note right of Story : Social Media domain
@enduml