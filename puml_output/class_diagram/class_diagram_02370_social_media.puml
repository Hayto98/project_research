@startuml
skinparam monochrome true
class Story {
  #int phone
  +double name
  -long code
  +saveAddress()
}
abstract class Like {
  -Date address
  #long level
  +deleteTotal()
  +validateType()
  +processPrice()
}
interface Message {
  #String phone
  +double address
  -boolean type
  #int email
  +processType()
  +setAmount()
  +validateCreatedat()
}
class Album {
  #float createdAt
  -float updatedAt
  +createName()
  +getType()
  +deleteTotal()
}
class Group {
  +String level
  #long email
  +sendPhone()
  +processPrice()
  +saveNote()
}
Album ..> Story : "1..*"
Group --* Like
Story --o Like
Story ..> Message : "1"
@enduml