@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Reservation {
  -boolean address
  -float amount
  -Date quantity
  +sendPrice()
  +calculateNote()
}
interface Branch {
  #int id
  -int note
  +String quantity
  #int description
  +createAmount()
  +processActive()
  +validateEmail()
  +getTotal()
}
interface Publisher {
  -Date id
  +float price
  +double code
  #double active
  #Date note
  +calculateQuantity()
  +validateName()
  +sendUpdatedat()
}
class Author {
  -Date email
  #double amount
  +calculateAmount()
  +setDuration()
  +validateDescription()
}
class Book {
  #long address
  #long name
  +long type
  #int code
  -long phone
  +validateName()
  +createQuantity()
  +validatePhone()
}
Branch --o Book
Book --|> Reservation
@enduml