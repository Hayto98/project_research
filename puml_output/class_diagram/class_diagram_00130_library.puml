@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Reservation {
  -boolean address
  -float amount
  -Date quantity
  +saveCreatedat()
  +cancelEmail()
}
class Branch {
  +String quantity
  +Date score
  +float description
  -long updatedAt
  +String address
  +cancelLevel()
  +calculateId()
}
abstract class Publisher {
  -Date active
  +float note
  +processActive()
}
abstract class Author {
  -int total
  -Date type
  #double id
  -double name
  +processAddress()
  +getType()
  +setPhone()
}
class Book {
  -Date updatedAt
  #long phone
  -long duration
  +float total
  +updateUpdatedat()
  +calculateLevel()
}
Reservation --> Book : "1"
Publisher --o Book
note right of Reservation : Library domain
@enduml