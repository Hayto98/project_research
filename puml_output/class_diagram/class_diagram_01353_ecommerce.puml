@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
abstract class Return {
  +Date total
  +long level
  +double updatedAt
  +String price
  +float score
  +cancelCreatedat()
  +processDuration()
  +createCreatedat()
  +calculateEmail()
}
class Supplier {
  -Date level
  -boolean amount
  -long id
  +boolean phone
  +boolean active
  +findStatus()
  +cancelPhone()
}
class Product {
  +long name
  +boolean duration
  -String status
  +Date quantity
  +validateActive()
}
class Cart {
  #long id
  #double note
  +validateQuantity()
  +saveDuration()
}
interface Category {
  #String name
  +float price
  #long code
  +updateType()
  +findUpdatedat()
}
class Wishlist {
  +double address
  #String code
  #Date status
  #int active
  +long duration
  +processNote()
  +updateAddress()
  +getScore()
}
Return --* Cart
Supplier --* Wishlist
@enduml