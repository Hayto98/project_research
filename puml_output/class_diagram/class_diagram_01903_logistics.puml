@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Vehicle {
  -int note
  #double name
  -double price
  -Date email
  #int duration
  +setType()
  +updateType()
}
abstract class Route {
  +float status
  #long level
  -Date active
  +validateDescription()
  +sendDescription()
  +calculateType()
}
class Package {
  #boolean code
  +double score
  #long email
  #boolean address
  +getStatus()
  +createName()
  +sendPrice()
}
abstract class Driver {
  +int status
  +double createdAt
  +long type
  +boolean level
  +calculateNote()
  +getPhone()
  +updateUpdatedat()
  +cancelDescription()
}
Package --o Vehicle
Driver --o Package
@enduml