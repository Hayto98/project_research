@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Vehicle {
  -int note
  #double name
  -double price
  -Date email
  #int duration
  +deleteAmount()
  +processDescription()
}
class Route {
  +long email
  #String price
  #boolean address
  +validateDuration()
  +cancelAmount()
  +calculateActive()
}
class Package {
  +double note
  +int total
  +String phone
  -float status
  +createStatus()
}
interface Driver {
  +double createdAt
  -boolean total
  -double status
  #float description
  -float quantity
  +validatePrice()
  +deleteDuration()
  +cancelStatus()
}
Driver ..> Package : "1..*"
Route --> Driver : "*"
note right of Vehicle : Logistics domain
@enduml