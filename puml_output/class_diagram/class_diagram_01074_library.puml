@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Publisher {
  -String level
  #int phone
  -boolean score
  -double email
  #boolean amount
  +processAddress()
  +getDuration()
  +getTotal()
  +calculateLevel()
}
class Branch {
  -float description
  -float duration
  +String updatedAt
  +validateTotal()
  +validatePrice()
  +validateLevel()
}
class Catalog {
  #float price
  -Date note
  #double quantity
  +getCode()
}
abstract class Renewal {
  -boolean phone
  -long email
  #double active
  +Date duration
  +getStatus()
  +setAddress()
}
Catalog --|> Branch
Renewal ..> Branch : "0..1"
@enduml