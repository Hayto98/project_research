@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Publisher {
  -String level
  #int phone
  -boolean score
  -double email
  #boolean amount
  +updateAddress()
  +saveUpdatedat()
  +deleteDescription()
  +updateType()
}
abstract class Branch {
  #Date code
  -int active
  #double address
  +createLevel()
  +calculateActive()
  +calculateCode()
  +cancelPrice()
}
interface Catalog {
  -boolean phone
  -long email
  #double active
  +Date duration
  +sendNote()
  +validateAddress()
}
class Renewal {
  #Date note
  +long amount
  +boolean address
  -Date duration
  #String level
  +sendDescription()
  +processUpdatedat()
}
Branch --* Publisher
Publisher --|> Catalog
note right of Publisher : Library domain
@enduml