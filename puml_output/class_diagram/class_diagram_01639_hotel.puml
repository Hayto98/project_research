@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Invoice {
  #long name
  +double address
  -double score
  +updateAmount()
  +calculateId()
}
class Amenity {
  +int note
  #int level
  -String address
  -String code
  +updatePrice()
  +deletePhone()
  +updateType()
}
class Housekeeping {
  #Date active
  +boolean score
  +calculateDescription()
}
class CheckOut {
  +long email
  -int active
  +processActive()
  +deleteStatus()
}
class Restaurant {
  +String id
  #double active
  +createAddress()
  +cancelCreatedat()
  +sendCreatedat()
  +validateQuantity()
}
interface Guest {
  #boolean phone
  +Date description
  -String quantity
  +calculateCode()
}
Housekeeping --* Invoice
Guest --> Invoice : "0..1"
CheckOut --|> Housekeeping
@enduml