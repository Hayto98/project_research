@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
interface Return {
  -long score
  +int duration
  +Date price
  #Date phone
  +validateAddress()
  +calculatePhone()
}
interface Warehouse {
  -double type
  #double amount
  -int updatedAt
  -boolean createdAt
  +updateUpdatedat()
}
abstract class Shipment {
  +boolean createdAt
  -int active
  #Date amount
  -Date duration
  +validateId()
  +calculateId()
  +updateCreatedat()
}
class Review {
  #float total
  -double note
  +String email
  +validateStatus()
  +cancelAddress()
  +updateLevel()
}
interface Supplier {
  -double price
  +Date address
  +getPrice()
  +deleteQuantity()
}
abstract class Category {
  -boolean total
  -int email
  +int address
  -Date level
  +sendType()
}
Shipment --|> Category
Review ..|> Return
note right of Return : Ecommerce domain
@enduml