@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
interface Return {
  -long score
  +int duration
  +Date price
  #Date phone
  +sendPhone()
  +validateScore()
}
abstract class Warehouse {
  +int active
  -double address
  #double type
  -int amount
  +savePrice()
  +createPhone()
  +sendNote()
  +deleteTotal()
}
class Shipment {
  +boolean email
  -int createdAt
  #Date active
  -Date amount
  -float level
  +sendTotal()
  +createPrice()
  +processName()
}
class Review {
  -long phone
  #float amount
  -double total
  +setDescription()
  +cancelScore()
}
class Supplier {
  -long status
  -double address
  +Date createdAt
  #boolean id
  +saveEmail()
  +sendScore()
}
class Category {
  #boolean total
  #long email
  -long duration
  #float level
  +processUpdatedat()
  +updateStatus()
  +calculateAddress()
}
Category --> Return : "*"
Return --* Shipment
Return --|> Review
Warehouse --* Review
@enduml