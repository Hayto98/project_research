@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Reservation {
  -boolean price
  +double duration
  +findUpdatedat()
  +deleteCode()
  +getDuration()
  +getStatus()
}
class Fine {
  +double type
  #double id
  #int quantity
  #double price
  -Date address
  +saveLevel()
  +createLevel()
  +saveLevel()
}
class Publisher {
  #long duration
  #long total
  +deleteCreatedat()
  +deleteAmount()
}
class Loan {
  #double code
  #float quantity
  #float total
  #String level
  +setUpdatedat()
  +createAddress()
  +updateType()
}
abstract class Author {
  +boolean code
  #double duration
  +calculateNote()
  +validateDescription()
}
Reservation --o Publisher
Author ..|> Reservation
Author --|> Fine
note right of Reservation : Library domain
@enduml