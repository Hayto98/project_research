@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Reservation {
  -boolean price
  +double duration
  +getActive()
  +cancelUpdatedat()
  +validateNote()
  +validateQuantity()
}
class Fine {
  #Date duration
  +Date id
  +findAmount()
  +sendName()
}
class Publisher {
  #double price
  #int address
  #double updatedAt
  -Date total
  +findStatus()
  +getCode()
  +updateLevel()
}
interface Loan {
  #float duration
  -boolean status
  +getName()
  +createType()
  +setTotal()
}
class Author {
  -long createdAt
  +long description
  -long amount
  +getUpdatedat()
  +sendType()
  +getCreatedat()
  +saveType()
}
Author --* Reservation
Reservation --* Fine
Publisher --o Fine
Loan --|> Reservation
@enduml