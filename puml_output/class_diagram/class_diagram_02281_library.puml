@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
abstract class Member {
  #long address
  #double createdAt
  #Date phone
  #long code
  #int description
  +deleteEmail()
  +deleteCode()
  +getUpdatedat()
}
class Branch {
  +double status
  #int duration
  -boolean name
  +cancelAmount()
  +cancelPhone()
  +validateQuantity()
  +calculateId()
}
class Loan {
  -boolean note
  -Date active
  +setPrice()
}
class Catalog {
  +Date type
  +double quantity
  #int createdAt
  #float total
  #double description
  +calculatePhone()
}
interface Book {
  +long amount
  +boolean email
  +createLevel()
  +updatePrice()
  +savePhone()
  +updateName()
}
Catalog ..|> Book
Member --> Book : "0..1"
Book --* Member
note right of Member : Library domain
@enduml