@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
abstract class Member {
  #long address
  #double createdAt
  #Date phone
  #long code
  #int description
  +processUpdatedat()
  +deleteName()
  +saveAddress()
}
class Branch {
  +float updatedAt
  +Date status
  +processQuantity()
}
class Loan {
  #long level
  -long description
  -float note
  +long price
  +float amount
  +sendQuantity()
  +createQuantity()
  +processId()
  +createAmount()
}
class Catalog {
  -double price
  -int description
  +setType()
  +calculateId()
  +setDuration()
  +findEmail()
}
class Book {
  -boolean score
  #String amount
  +float total
  -String id
  -String price
  +processDescription()
  +processId()
  +validateNote()
  +calculateStatus()
}
Loan ..> Branch : "1"
Catalog --o Book
Branch --|> Member
@enduml