@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Reservation {
  +String name
  +double level
  +boolean createdAt
  +long type
  +double status
  +calculateEmail()
  +processAmount()
  +validateQuantity()
}
class Member {
  -String price
  +int amount
  +findName()
  +getStatus()
  +deleteLevel()
  +calculateDescription()
}
class Author {
  -int quantity
  #boolean description
  -boolean duration
  #String address
  -long email
  +validateActive()
  +createUpdatedat()
  +setNote()
  +deleteEmail()
}
class Catalog {
  #int address
  -int email
  -float score
  +deleteAmount()
}
class Librarian {
  -String description
  #boolean createdAt
  +Date email
  +validateQuantity()
}
Member --> Catalog : "*"
Author --* Reservation
@enduml