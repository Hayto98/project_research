@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Reservation {
  +String name
  +double level
  +boolean createdAt
  +long type
  +double status
  +getCode()
  +deleteName()
  +sendStatus()
}
abstract class Member {
  +double note
  #float code
  #int amount
  +createDescription()
  +findQuantity()
  +validateEmail()
  +processCreatedat()
}
interface Author {
  -boolean duration
  #double code
  +int email
  -long phone
  +createAmount()
  +calculateCode()
}
abstract class Catalog {
  -String updatedAt
  #boolean description
  +Date createdAt
  #boolean email
  +deleteEmail()
}
class Librarian {
  -String score
  +double note
  +Date address
  +int id
  +float duration
  +getAmount()
  +cancelType()
  +createNote()
}
Catalog --> Librarian : "1"
Member ..|> Author
note right of Reservation : Library domain
@enduml