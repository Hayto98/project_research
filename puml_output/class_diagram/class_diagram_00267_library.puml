@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Book {
  #double level
  -int code
  +float score
  -long description
  +boolean type
  +validateNote()
  +findPrice()
  +saveDescription()
}
class Fine {
  -double email
  +boolean type
  +saveTotal()
  +sendCreatedat()
  +cancelTotal()
  +processCreatedat()
}
class Librarian {
  -boolean duration
  -float code
  +getName()
  +validatePhone()
  +deleteLevel()
  +saveNote()
}
class Publisher {
  #String code
  #long email
  +double phone
  +getDescription()
  +calculateActive()
}
abstract class Loan {
  -boolean price
  #Date active
  +getDescription()
  +saveEmail()
  +sendId()
  +createScore()
}
interface Branch {
  #int name
  -String id
  #float email
  +saveQuantity()
  +createLevel()
}
class Member {
  +Date total
  #double quantity
  +long amount
  +validateDescription()
}
Book ..> Fine : "0..1"
Branch --|> Fine
Loan --> Fine : "1"
Member ..> Publisher : "*"
Member --* Loan
@enduml