@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Teacher {
  #long email
  -int quantity
  +createDescription()
  +getLevel()
}
class Department {
  +Date email
  +Date updatedAt
  -float price
  +sendCreatedat()
  +sendTotal()
  +calculateType()
}
class Classroom {
  -double phone
  +long amount
  #float level
  +cancelTotal()
}
interface Enrollment {
  -long createdAt
  +float total
  -Date code
  +float name
  +float address
  +saveEmail()
  +getAmount()
}
class Schedule {
  +Date duration
  -int price
  #long name
  +saveScore()
  +setAmount()
  +saveNote()
  +sendActive()
}
class Exam {
  +int duration
  -String level
  -String price
  #String active
  +getDuration()
  +setId()
  +saveLevel()
  +calculateScore()
}
class Student {
  +double address
  #float createdAt
  +float updatedAt
  +saveType()
}
Enrollment --* Teacher
Teacher --* Exam
Student --> Teacher : "1..*"
@enduml