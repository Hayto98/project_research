@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Teacher {
  #long email
  -int quantity
  +sendCode()
  +deleteUpdatedat()
}
class Department {
  #long price
  -double name
  +float updatedAt
  +deletePhone()
}
class Classroom {
  -Date type
  #String note
  +boolean updatedAt
  +updateTotal()
  +findCode()
  +findName()
  +validatePrice()
}
class Enrollment {
  +String total
  #int description
  #float level
  +cancelPrice()
  +getId()
}
abstract class Schedule {
  +boolean address
  +long total
  #boolean phone
  +sendId()
  +deleteAddress()
  +setEmail()
  +getScore()
}
class Exam {
  +int duration
  +double email
  #float code
  +float createdAt
  #String address
  +processId()
  +createName()
}
class Student {
  #long level
  -int email
  +processName()
  +getName()
}
Exam --o Department
Department ..|> Exam
Teacher --o Classroom
Classroom ..> Schedule : "*"
Schedule --o Exam
note right of Teacher : Education domain
@enduml