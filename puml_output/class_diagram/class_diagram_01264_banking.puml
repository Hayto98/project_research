@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
interface Teller {
  -boolean address
  +String price
  -Date active
  -Date duration
  -boolean level
  +processPhone()
  +validateNote()
  +findQuantity()
  +deleteCreatedat()
}
interface Account {
  +double address
  #int phone
  #boolean type
  +saveCode()
  +deleteStatus()
  +sendAmount()
  +getNote()
}
abstract class Interest {
  +boolean createdAt
  #long price
  -boolean type
  -Date note
  +saveType()
}
interface Customer {
  -String duration
  +Date level
  -float active
  +updateUpdatedat()
  +saveUpdatedat()
}
class Transfer {
  #boolean updatedAt
  -double active
  #boolean phone
  #float amount
  +validateUpdatedat()
  +deleteStatus()
  +processScore()
  +updateEmail()
}
abstract class Withdrawal {
  -float note
  +String id
  +double name
  +int address
  +validateLevel()
}
class Loan {
  -int id
  +boolean amount
  -Date quantity
  -String note
  +float description
  +getCreatedat()
  +calculateCreatedat()
}
Customer --> Withdrawal : "1"
Transfer --* Loan
Withdrawal --o Transfer
Withdrawal ..> Customer : "0..1"
Account --|> Transfer
Account --|> Withdrawal
@enduml