@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
interface Teller {
  -boolean address
  +String price
  -Date active
  -Date duration
  -boolean level
  +updateAddress()
  +createScore()
  +deleteAddress()
  +validateType()
}
class Account {
  #boolean active
  -double description
  -int score
  #double price
  -boolean duration
  +updateDuration()
  +sendQuantity()
  +processDuration()
  +validateCode()
}
interface Interest {
  -String duration
  +Date level
  -float active
  +setCreatedat()
  +createUpdatedat()
}
interface Customer {
  #boolean amount
  #float active
  #double address
  -Date total
  +calculateLevel()
  +validateNote()
  +getName()
  +cancelAddress()
}
class Transfer {
  +int id
  +long updatedAt
  -float type
  +deleteQuantity()
}
abstract class Withdrawal {
  #long phone
  #long updatedAt
  +float level
  +deleteScore()
  +validateScore()
}
abstract class Loan {
  -Date score
  #double active
  +findAmount()
  +deleteActive()
  +getUpdatedat()
  +findCode()
}
Transfer ..> Interest : "1"
Interest --> Account : "0..1"
note right of Teller : Banking domain
@enduml