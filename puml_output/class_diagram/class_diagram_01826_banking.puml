@startuml

class Beneficiary {
  #int price
  +float quantity
  #Date id
  +long email
  +double address
  +saveTotal()
  +sendAmount()
  +findDescription()
  +deleteCreatedat()
}
class Statement {
  -long score
  +float duration
  +Date code
  #double description
  +createAddress()
  +sendId()
  +saveUpdatedat()
  +deleteStatus()
}
class Customer {
  #long score
  #double level
  +calculateAmount()
}
interface Withdrawal {
  #int score
  +Date amount
  +float type
  +float email
  +cancelStatus()
}
interface Transfer {
  -Date total
  +float updatedAt
  +long code
  #Date score
  +setScore()
  +validateEmail()
  +findAmount()
  +createId()
}
Beneficiary --|> Transfer
Customer --|> Withdrawal
note right of Beneficiary : Banking domain
@enduml