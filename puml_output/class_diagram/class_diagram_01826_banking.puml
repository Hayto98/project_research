@startuml

class Beneficiary {
  #int price
  +float quantity
  #Date id
  +long email
  +double address
  +createType()
  +validateLevel()
  +setQuantity()
  +cancelCreatedat()
}
interface Statement {
  +boolean description
  -boolean amount
  #String createdAt
  +saveCreatedat()
  +findCode()
}
class Customer {
  -long score
  -boolean type
  +cancelScore()
}
class Withdrawal {
  #boolean status
  #long id
  #double name
  +findAmount()
}
class Transfer {
  #int score
  +Date amount
  +float type
  +float email
  +sendLevel()
}
Beneficiary --o Customer
Statement --> Beneficiary : "1"
Withdrawal ..|> Statement
Customer --|> Withdrawal
@enduml