@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
abstract class Attendance {
  +int active
  -long email
  -float score
  -Date price
  +getCreatedat()
  +saveDuration()
}
class Book {
  +float description
  #String note
  +Date amount
  +saveUpdatedat()
  +updateNote()
  +cancelTotal()
}
class Grade {
  -float email
  #Date updatedAt
  +long price
  +getName()
  +saveQuantity()
  +savePhone()
  +cancelNote()
}
interface Library {
  -String quantity
  -String duration
  #int type
  +String name
  #boolean amount
  +calculateAddress()
  +processScore()
  +processStatus()
}
Attendance ..> Grade : "*"
Grade --|> Library
Book --* Library
@enduml