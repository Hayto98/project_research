@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
abstract class Attendance {
  +int active
  -long email
  -float score
  -Date price
  +sendLevel()
  +getLevel()
}
class Book {
  #String note
  +Date amount
  -Date level
  +setDescription()
}
class Grade {
  -double price
  +String note
  +boolean createdAt
  +createDuration()
  +createType()
  +getActive()
  +sendAmount()
}
class Library {
  #int quantity
  +String name
  +deletePhone()
  +calculateId()
  +savePrice()
}
Attendance --o Library
Grade --* Attendance
Grade ..|> Library
note right of Attendance : Education domain
@enduml