@startuml
skinparam shadowing true
interface Housekeeping {
  +double name
  +int quantity
  #float amount
  #String description
  +Date address
  +deleteUpdatedat()
  +validateId()
}
interface Service {
  -int note
  +double duration
  +createCode()
  +setLevel()
  +findActive()
}
class Booking {
  +boolean phone
  #Date price
  -int name
  +long duration
  +findId()
}
class Reservation {
  #String createdAt
  +long level
  +double amount
  +setUpdatedat()
  +calculateQuantity()
}
class Restaurant {
  #double status
  -double address
  +boolean id
  -String type
  +getQuantity()
  +findNote()
  +processDuration()
  +deletePhone()
}
class Guest {
  +int description
  +Date type
  -Date note
  +sendStatus()
}
Housekeeping --|> Restaurant
Reservation --> Booking : "1..*"
@enduml