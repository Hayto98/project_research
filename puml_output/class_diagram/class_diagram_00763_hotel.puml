@startuml
skinparam shadowing true
interface Housekeeping {
  +double name
  +int quantity
  #float amount
  #String description
  +Date address
  +cancelStatus()
  +sendId()
}
abstract class Service {
  +int email
  -Date createdAt
  #int code
  -Date price
  -double duration
  +cancelPhone()
}
class Booking {
  +Date updatedAt
  -boolean createdAt
  +int quantity
  #int code
  +updateAddress()
}
class Reservation {
  +long amount
  +boolean name
  -boolean total
  -float phone
  -double active
  +sendAddress()
}
class Restaurant {
  #int duration
  +float code
  #double updatedAt
  -int score
  +int email
  +findStatus()
  +findCode()
  +setLevel()
  +getPrice()
}
class Guest {
  +String note
  -float status
  -double updatedAt
  +double id
  +setDuration()
  +validateStatus()
}
Guest ..|> Service
Booking ..|> Reservation
Restaurant --> Reservation : "1"
Reservation ..|> Service
note right of Housekeeping : Hotel domain
@enduml