@startuml

class Withdrawal {
  +boolean score
  +boolean amount
  +sendDuration()
  +processPhone()
  +updatePhone()
  +findAddress()
}
class Teller {
  -long phone
  +Date duration
  +sendNote()
  +cancelTotal()
}
class Customer {
  -long type
  -long description
  #String address
  #String createdAt
  #int score
  +setCreatedat()
  +calculateUpdatedat()
}
class Interest {
  -double description
  -float level
  +int duration
  -double total
  -double price
  +deleteDuration()
  +setScore()
  +createNote()
  +savePhone()
}
interface Deposit {
  #boolean id
  #Date score
  +int amount
  #long email
  +calculateUpdatedat()
}
Withdrawal ..> Teller : "0..1"
Teller --|> Customer
Teller --> Deposit : "*"
note right of Withdrawal : Banking domain
@enduml