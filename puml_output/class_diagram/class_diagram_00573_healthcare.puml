@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Billing {
  +long createdAt
  #double id
  #boolean status
  +Date active
  #long score
  +findLevel()
  +validateNote()
  +getAddress()
}
interface LabTest {
  -int phone
  +float code
  #int createdAt
  +String type
  +float score
  +createPhone()
  +cancelCreatedat()
  +validateTotal()
  +findId()
}
class Ward {
  +double type
  -boolean description
  +validateType()
}
interface Appointment {
  +int status
  +int note
  #Date price
  -long score
  +cancelDuration()
}
class Prescription {
  #float status
  #int phone
  -double total
  +setStatus()
}
Prescription --o Billing
LabTest ..|> Ward
LabTest --o Billing
note right of Billing : Healthcare domain
@enduml