@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Review {
  -double total
  #double updatedAt
  #Date createdAt
  +findTotal()
}
interface Customer {
  +Date status
  -String phone
  -float description
  +double amount
  #String address
  +validatePrice()
  +updateEmail()
  +updateUpdatedat()
  +updatePrice()
}
interface Supplier {
  #float address
  +float createdAt
  +double price
  +int level
  +findActive()
  +savePrice()
}
class Invoice {
  +int amount
  +boolean email
  -boolean address
  +int code
  #boolean status
  +deleteScore()
  +updateAddress()
  +cancelAddress()
  +createTotal()
}
class Order {
  -String id
  #int name
  +double duration
  +findQuantity()
  +deleteStatus()
  +getActive()
  +setName()
}
class Payment {
  -String active
  #String score
  -int level
  +deleteCreatedat()
  +sendNote()
}
Supplier --o Customer
Supplier ..|> Invoice
@enduml