@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Review {
  -double total
  #double updatedAt
  #Date createdAt
  +sendType()
}
class Customer {
  #float description
  -String amount
  -float address
  +double id
  +processTotal()
}
class Supplier {
  -int active
  -int quantity
  +updateType()
  +getUpdatedat()
}
class Invoice {
  -long level
  #String createdAt
  +String score
  +String price
  #double amount
  +updateDuration()
  +processAmount()
}
class Order {
  #String updatedAt
  -String id
  #int name
  +calculateNote()
}
class Payment {
  #boolean updatedAt
  #float amount
  +setScore()
  +setEmail()
  +deleteCreatedat()
}
Customer --|> Order
Supplier --o Customer
Supplier ..|> Invoice
note right of Review : Ecommerce domain
@enduml