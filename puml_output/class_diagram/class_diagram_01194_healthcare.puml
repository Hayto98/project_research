@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
interface Diagnosis {
  +double status
  +long createdAt
  +Date type
  -double price
  +float address
  +saveAmount()
  +processAmount()
  +saveId()
  +findDuration()
}
class Patient {
  -Date name
  #float score
  -String amount
  +int price
  +deleteStatus()
  +createPrice()
  +setTotal()
}
interface Appointment {
  -long duration
  #float score
  +double createdAt
  +setUpdatedat()
  +cancelAmount()
}
class Hospital {
  #Date address
  +Date email
  #int note
  -float total
  +deleteNote()
  +sendName()
}
class Billing {
  #String total
  +int price
  +boolean quantity
  -Date updatedAt
  #Date active
  +saveId()
  +processNote()
}
interface Nurse {
  +int active
  +int type
  +float score
  +cancelCreatedat()
  +processActive()
  +getAmount()
  +deleteStatus()
}
Nurse ..> Appointment : "1"
Hospital --o Nurse
Appointment --* Nurse
@enduml