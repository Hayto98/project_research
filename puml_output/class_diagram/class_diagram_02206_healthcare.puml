@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
interface Ward {
  -long score
  #int phone
  -double amount
  +validateQuantity()
  +cancelAmount()
  +validateType()
}
interface Diagnosis {
  -boolean id
  -long createdAt
  -long address
  +long description
  +boolean price
  +sendTotal()
  +saveCreatedat()
  +getPrice()
  +findAmount()
}
abstract class MedicalRecord {
  -int quantity
  +Date active
  +sendPhone()
  +saveStatus()
}
class Prescription {
  -float total
  #String quantity
  +sendDuration()
}
class Billing {
  #double createdAt
  +double active
  -double status
  +validateAddress()
}
Billing ..> Prescription : "1"
Billing --* Ward
Billing --o MedicalRecord
Ward --|> Prescription
@enduml