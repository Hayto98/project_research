@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
abstract class Category {
  #String score
  +float level
  -Date amount
  +cancelId()
}
class Payment {
  #float amount
  +long createdAt
  -long active
  +sendCreatedat()
  +getTotal()
  +cancelQuantity()
  +sendActive()
}
interface Review {
  +double updatedAt
  +String active
  +getEmail()
  +validateNote()
  +deleteTotal()
  +getName()
}
interface Customer {
  +boolean level
  -int note
  +sendLevel()
}
class Supplier {
  -boolean code
  -float type
  +calculateType()
}
class Coupon {
  +Date type
  #float duration
  +Date updatedAt
  +Date phone
  #String total
  +calculateCode()
  +setCreatedat()
  +updateTotal()
}
Review --* Payment
Review --* Supplier
Review ..|> Category
@enduml