@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
abstract class Category {
  #String score
  +float level
  -Date amount
  +validateStatus()
}
class Payment {
  #float duration
  +long createdAt
  -long active
  +processCreatedat()
  +processDuration()
  +findScore()
  +sendStatus()
}
class Review {
  -int price
  +float description
  #boolean code
  +cancelNote()
}
class Customer {
  -long updatedAt
  #long name
  #String amount
  -double code
  -double active
  +validateTotal()
  +deleteScore()
}
class Supplier {
  -double level
  #long code
  +createAmount()
  +validateEmail()
  +cancelEmail()
}
class Coupon {
  +long updatedAt
  #int quantity
  +updatePrice()
  +processPhone()
}
Customer --> Category : "1"
Customer --* Supplier
Customer ..> Review : "1"
Payment --> Supplier : "1..*"
note right of Category : Ecommerce domain
@enduml