@startuml

class Appointment {
  +Date status
  -boolean email
  #boolean code
  +sendPhone()
  +sendQuantity()
  +saveAddress()
}
class Hospital {
  -int amount
  +long quantity
  +saveActive()
  +createDescription()
  +getNote()
  +validateDescription()
}
interface Nurse {
  +Date description
  -long name
  -boolean price
  +boolean active
  +deleteStatus()
  +processEmail()
  +validateDuration()
}
class MedicalRecord {
  -boolean id
  #String score
  -Date note
  +processScore()
  +updateId()
}
class Ward {
  #String price
  #boolean duration
  #long name
  +processAmount()
}
Appointment --o Hospital
Nurse ..|> Ward
@enduml