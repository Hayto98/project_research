@startuml
skinparam monochrome true
class Interest {
  #String score
  #String address
  -double email
  #int price
  +sendCreatedat()
  +sendPrice()
  +saveStatus()
}
class Transfer {
  +boolean score
  #double email
  +double active
  +float status
  -boolean address
  +findNote()
  +getDescription()
}
class Card {
  -boolean quantity
  +Date level
  #float email
  -float id
  +getAddress()
}
interface Transaction {
  #String email
  #String price
  -int updatedAt
  +deleteActive()
  +processLevel()
  +getTotal()
  +getTotal()
}
class Branch {
  -float description
  -String total
  #Date amount
  +setAddress()
  +createAmount()
}
class Deposit {
  -int createdAt
  #String phone
  -float duration
  -double price
  -float status
  +findAddress()
}
Card --|> Branch
Transfer ..> Transaction : "*"
Interest --* Transfer
Deposit --* Transaction
note right of Interest : Banking domain
@enduml