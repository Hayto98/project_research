@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Nurse {
  -boolean email
  -double note
  +long level
  +int type
  +float phone
  +saveCreatedat()
  +getEmail()
  +setPrice()
}
class Diagnosis {
  #Date updatedAt
  -float amount
  #int id
  +long description
  +findDuration()
  +processDescription()
  +sendId()
  +setAmount()
}
class Prescription {
  #float amount
  -int status
  #int duration
  #String address
  +findCode()
  +sendQuantity()
  +cancelUpdatedat()
  +findId()
}
interface LabTest {
  -String quantity
  #float level
  -String duration
  +long status
  +setCode()
  +getActive()
  +sendEmail()
  +getUpdatedat()
}
LabTest --* Diagnosis
Diagnosis --* Prescription
@enduml