@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Nurse {
  -boolean email
  -double note
  +long level
  +int type
  +float phone
  +validateDescription()
  +setQuantity()
  +findUpdatedat()
}
class Diagnosis {
  #int description
  +long address
  +sendQuantity()
  +updateDescription()
  +validateAmount()
  +setAmount()
}
class Prescription {
  #boolean createdAt
  -long amount
  #Date active
  +Date name
  +createLevel()
  +createStatus()
  +processName()
}
abstract class LabTest {
  -Date amount
  #int address
  +processTotal()
}
Diagnosis --* Prescription
LabTest ..|> Prescription
Prescription ..|> LabTest
note right of Nurse : Healthcare domain
@enduml