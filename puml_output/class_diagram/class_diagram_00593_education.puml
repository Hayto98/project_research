@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Student {
  +float duration
  +int level
  -int name
  +sendUpdatedat()
  +saveLevel()
  +cancelQuantity()
}
abstract class Library {
  -int duration
  #long quantity
  +String score
  +Date id
  +validateDuration()
}
abstract class Enrollment {
  #float phone
  -boolean address
  #String amount
  +validateUpdatedat()
  +calculateActive()
  +sendTotal()
  +calculateStatus()
}
class Department {
  +float name
  #long code
  -long amount
  #Date duration
  +getId()
  +processDescription()
  +createTotal()
}
class Attendance {
  #long updatedAt
  -String level
  +calculateActive()
  +cancelDuration()
  +setAddress()
  +processType()
}
class Assignment {
  +long description
  #int price
  -float quantity
  +sendTotal()
  +setName()
}
Department ..|> Library
Attendance --o Student
Enrollment ..|> Department
note right of Student : Education domain
@enduml