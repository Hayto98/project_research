@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
abstract class Album {
  #int amount
  #Date price
  #Date duration
  +findStatus()
}
interface Story {
  +double amount
  #long phone
  +Date level
  -Date status
  #Date active
  +cancelPrice()
  +sendDescription()
  +getScore()
}
class Report {
  -long email
  -float total
  #String code
  -float address
  +saveNote()
  +createTotal()
  +setQuantity()
  +updateUpdatedat()
}
interface Group {
  -double type
  -int price
  +validateDuration()
}
abstract class Message {
  #int duration
  +boolean phone
  -float price
  +deleteCode()
}
interface Follower {
  +long name
  +String total
  +String code
  -long level
  +processDuration()
  +validateQuantity()
  +setLevel()
}
Story --* Group
Album --* Message
Story ..|> Report
Group --|> Album
note right of Album : Social Media domain
@enduml