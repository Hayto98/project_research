@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
abstract class Album {
  #int amount
  #Date price
  #Date duration
  +createTotal()
}
class Story {
  +double amount
  #long phone
  +Date level
  -Date status
  #Date active
  +findUpdatedat()
  +sendScore()
  +getScore()
}
class Report {
  -long score
  -String createdAt
  +getAddress()
  +setTotal()
  +processStatus()
}
class Group {
  +long duration
  +float total
  +boolean note
  +float quantity
  -double level
  +deleteDuration()
  +processType()
  +validateCode()
  +createAddress()
}
class Message {
  +boolean updatedAt
  -float phone
  +int price
  #Date active
  +boolean amount
  +saveDescription()
  +validateType()
  +setDuration()
}
class Follower {
  +String code
  +long total
  -float id
  -double address
  #boolean amount
  +createQuantity()
  +validateEmail()
  +processEmail()
}
Story --* Group
Album --* Message
Story ..|> Report
Group --|> Album
@enduml