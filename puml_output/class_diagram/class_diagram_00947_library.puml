@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
interface Author {
  -boolean email
  +int total
  #float amount
  #Date price
  +float quantity
  +sendDescription()
}
class Member {
  +long quantity
  +float email
  #int amount
  +long duration
  #Date status
  +validateTotal()
  +cancelEmail()
  +createTotal()
  +calculateStatus()
}
abstract class Publisher {
  +float note
  +String type
  -String email
  -float quantity
  +String id
  +createNote()
}
class Book {
  #float active
  +double score
  -double id
  +createQuantity()
  +validateDescription()
  +cancelUpdatedat()
}
class Reservation {
  +double total
  #int amount
  -int address
  +processEmail()
  +getEmail()
}
Member --* Reservation
Book --> Author : "1..*"
Author --|> Reservation
@enduml