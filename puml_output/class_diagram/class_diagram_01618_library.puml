@startuml

interface Loan {
  -float type
  +String score
  #double description
  #long duration
  +findType()
}
class Branch {
  -boolean id
  +float active
  +cancelActive()
  +updateAmount()
  +getId()
  +createPhone()
}
interface Fine {
  -double note
  #Date type
  -String score
  -float address
  #int duration
  +calculateName()
}
class Librarian {
  #boolean createdAt
  +Date level
  +long email
  #Date updatedAt
  +calculateTotal()
  +processNote()
}
interface Catalog {
  +double price
  +boolean total
  +Date level
  #boolean email
  +validateAmount()
  +saveCode()
}
class Reservation {
  #boolean type
  +String phone
  +int note
  +long level
  +updateAddress()
}
class Renewal {
  #int amount
  -float duration
  +int id
  +getCreatedat()
}
Reservation --|> Renewal
Librarian --* Loan
Catalog --|> Reservation
note right of Loan : Library domain
@enduml