@startuml

interface Loan {
  -float type
  +String score
  #double description
  #long duration
  +createTotal()
}
abstract class Branch {
  #long id
  #String duration
  +savePrice()
  +updateNote()
  +processActive()
  +validateStatus()
}
class Fine {
  #long id
  #boolean quantity
  +calculateAmount()
  +findActive()
  +saveActive()
  +deleteEmail()
}
class Librarian {
  -float price
  #int total
  +double score
  +long type
  -int code
  +validateTotal()
  +sendNote()
  +cancelActive()
}
interface Catalog {
  #int amount
  -float email
  -float active
  +sendLevel()
  +calculateAmount()
  +setPhone()
  +updateCreatedat()
}
class Reservation {
  -String total
  #int duration
  #Date score
  #boolean email
  +float status
  +updateType()
  +updatePhone()
  +getLevel()
}
class Renewal {
  #boolean type
  +String phone
  +int note
  +long level
  +updateStatus()
}
Renewal ..|> Branch
Reservation ..> Branch : "0..1"
Catalog ..> Reservation : "1"
@enduml