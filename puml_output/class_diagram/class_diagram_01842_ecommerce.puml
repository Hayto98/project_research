@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
abstract class Supplier {
  #String phone
  -long type
  #Date price
  +double note
  +createCreatedat()
  +updateCode()
  +updateAddress()
  +sendDescription()
}
class Customer {
  #float active
  -int description
  #Date type
  #int status
  -double amount
  +cancelQuantity()
  +deleteQuantity()
}
class Warehouse {
  +int status
  +String name
  #Date quantity
  +int level
  +sendLevel()
  +getAmount()
}
interface Wishlist {
  +String price
  +boolean email
  +sendUpdatedat()
  +calculateQuantity()
  +findScore()
  +createTotal()
}
class Product {
  +Date duration
  -String updatedAt
  #double email
  +updateId()
  +validateName()
}
class Invoice {
  #int status
  #long duration
  -long description
  -Date total
  +processAmount()
}
class Shipment {
  -int code
  -long type
  +saveScore()
  +updateTotal()
}
Warehouse --|> Wishlist
Product ..|> Supplier
@enduml