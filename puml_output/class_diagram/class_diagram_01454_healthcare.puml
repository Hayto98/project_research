@startuml
skinparam shadowing true
class Billing {
  +long id
  +boolean note
  +double score
  +setQuantity()
  +setPrice()
}
class Ward {
  -Date active
  #double status
  +cancelAmount()
}
class Prescription {
  -String phone
  +String price
  -double total
  #boolean note
  #int duration
  +validateStatus()
}
class Patient {
  -Date id
  +String quantity
  +deleteType()
  +createScore()
}
class Diagnosis {
  -boolean createdAt
  #String name
  +validateAddress()
  +updateActive()
  +updateTotal()
  +getDescription()
}
class Appointment {
  -boolean amount
  #String email
  -int total
  +deleteLevel()
  +createType()
  +validateDescription()
}
class Hospital {
  #int address
  -boolean amount
  +boolean id
  -boolean quantity
  +deleteAmount()
  +setPrice()
  +findActive()
  +sendUpdatedat()
}
Patient --|> Prescription
Prescription --|> Patient
Appointment --|> Prescription
@enduml