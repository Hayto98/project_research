@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
interface Housekeeping {
  #String updatedAt
  +String active
  #long quantity
  +sendQuantity()
  +processTotal()
  +setDescription()
}
abstract class Invoice {
  #String total
  +float active
  +saveTotal()
  +validateQuantity()
  +deleteEmail()
}
interface CheckOut {
  #String status
  #float type
  +int duration
  +findQuantity()
  +saveActive()
  +saveEmail()
}
class Reservation {
  #boolean address
  -double email
  +calculateCode()
  +processActive()
}
class Service {
  #int active
  #double duration
  +findDescription()
  +sendQuantity()
  +cancelQuantity()
}
interface Staff {
  -boolean quantity
  #String createdAt
  +int total
  +float score
  +float duration
  +sendLevel()
  +calculateId()
  +saveType()
  +updateAddress()
}
interface CheckIn {
  -Date name
  +long phone
  -float level
  #float price
  -int type
  +validateScore()
  +processActive()
  +setUpdatedat()
}
Invoice --* CheckOut
CheckOut --|> Staff
Housekeeping --* CheckIn
Staff --* Housekeeping
Reservation ..> Service : "1..*"
Service --> Reservation : "1"
@enduml