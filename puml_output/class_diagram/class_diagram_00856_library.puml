@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
abstract class Branch {
  #float price
  +float updatedAt
  #double id
  +long phone
  +String note
  +deleteUpdatedat()
  +calculateUpdatedat()
}
class Fine {
  #Date amount
  +double total
  #double quantity
  +getDescription()
  +findAmount()
  +sendScore()
  +updateDescription()
}
class Reservation {
  -int score
  -String level
  #int name
  +sendCode()
  +deleteDescription()
}
abstract class Shelf {
  #float updatedAt
  -float createdAt
  -Date address
  -Date id
  +cancelId()
}
Shelf --|> Fine
Fine ..> Branch : "0..1"
@enduml