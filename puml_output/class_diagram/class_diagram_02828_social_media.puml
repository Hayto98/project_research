@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Comment {
  +double total
  +int description
  -float level
  +sendCode()
  +cancelEmail()
  +setAmount()
  +setPrice()
}
class Like {
  #double code
  #String level
  +findDescription()
  +getLevel()
  +validatePhone()
  +findAddress()
}
abstract class Profile {
  -String type
  -Date phone
  +float total
  +deleteUpdatedat()
  +processActive()
}
class Post {
  +double price
  +float active
  -int phone
  +updateStatus()
  +deleteCreatedat()
  +setAmount()
}
class Album {
  #String quantity
  #float address
  +validateLevel()
  +cancelStatus()
  +deleteNote()
}
class User {
  -int updatedAt
  -String phone
  -float id
  +deleteDuration()
  +saveType()
}
class Story {
  +int duration
  #long type
  +Date address
  +saveCode()
  +getEmail()
  +validateDuration()
}
User --> Comment : "1"
Post --|> Comment
Album --o Post
Like --o Post
Album ..> Profile : "0..1"
note right of Comment : Social Media domain
@enduml