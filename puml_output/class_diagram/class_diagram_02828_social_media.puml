@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Comment {
  +double total
  +int description
  -float level
  +createDescription()
  +findTotal()
  +createAddress()
  +saveDuration()
}
class Like {
  -int amount
  #float status
  +updateCreatedat()
}
class Profile {
  #float active
  -Date id
  -Date price
  -double description
  +double name
  +getPhone()
  +findTotal()
  +findLevel()
}
class Post {
  #int address
  +Date id
  +createNote()
  +calculateTotal()
}
abstract class Album {
  -String amount
  -int price
  -int active
  +createNote()
  +validateNote()
  +createPhone()
}
class User {
  +long code
  -boolean amount
  +Date address
  +getDuration()
  +createAmount()
  +savePrice()
}
interface Story {
  +int description
  +long note
  +updateQuantity()
}
Like --|> Post
Profile --> User : "0..1"
Story --> Like : "*"
Profile ..> Like : "*"
Profile ..|> Comment
@enduml