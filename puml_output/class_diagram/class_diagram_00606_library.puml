@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Renewal {
  #boolean createdAt
  -float address
  +getId()
  +validatePhone()
  +cancelDescription()
  +findNote()
}
class Author {
  +float address
  +double active
  -double note
  +createCode()
  +sendPhone()
  +saveCode()
}
abstract class Member {
  +Date active
  -int price
  +float email
  +Date phone
  +String amount
  +cancelDuration()
}
class Book {
  #boolean total
  -Date type
  #float status
  +Date email
  +createCode()
  +deleteType()
}
class Catalog {
  -double email
  +long name
  -float level
  +int quantity
  +deletePhone()
}
class Librarian {
  +float note
  #String type
  -double createdAt
  #float code
  +String address
  +getLevel()
  +calculatePrice()
  +cancelDuration()
  +saveDuration()
}
class Shelf {
  +Date quantity
  +int code
  -long amount
  -long duration
  +updateCode()
  +cancelScore()
  +validateDescription()
}
Shelf --|> Catalog
Author ..> Book : "1"
Author ..> Member : "0..1"
note right of Renewal : Library domain
@enduml