@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Renewal {
  #boolean createdAt
  -float address
  +sendTotal()
  +cancelType()
  +getName()
  +saveCreatedat()
}
class Author {
  -Date note
  #float name
  -int updatedAt
  +sendCreatedat()
}
abstract class Member {
  -boolean address
  #Date email
  -boolean code
  -Date phone
  #long score
  +getStatus()
  +findId()
  +validateId()
}
class Book {
  +String status
  #boolean description
  #int createdAt
  +updateEmail()
  +findActive()
  +updateUpdatedat()
}
class Catalog {
  +double status
  +boolean amount
  -long email
  +String code
  +cancelCode()
  +processTotal()
  +getPrice()
}
class Librarian {
  +long quantity
  -double status
  -double amount
  +String name
  +getEmail()
  +sendStatus()
  +cancelPrice()
}
class Shelf {
  #double type
  +boolean active
  -double updatedAt
  #Date id
  +cancelPhone()
  +processDescription()
  +createTotal()
}
Catalog --* Author
Author ..|> Librarian
@enduml