@startuml
skinparam ArrowColor #555555
class Customer {
  #Date code
  +String status
  +saveDuration()
  +validateDuration()
  +findPhone()
}
class Driver {
  +boolean note
  #int description
  -Date status
  +saveCreatedat()
  +setEmail()
  +validateCreatedat()
}
interface Inventory {
  -int quantity
  +double code
  -boolean updatedAt
  #Date duration
  -double total
  +sendCode()
  +cancelTotal()
}
interface Shipment {
  +float description
  +float total
  #Date amount
  +Date score
  +long name
  +setTotal()
  +deletePhone()
  +validateDuration()
}
class Manifest {
  -double name
  -Date level
  +validateActive()
  +updateCode()
}
interface Tracking {
  #double score
  -long email
  +createPrice()
  +saveStatus()
  +validatePhone()
}
class Depot {
  -boolean active
  #double id
  +cancelDuration()
  +setAddress()
  +sendDescription()
  +processDuration()
}
Customer --> Depot : "*"
Driver --* Inventory
Tracking --> Manifest : "0..1"
Manifest --> Depot : "1..*"
Inventory ..|> Shipment
note right of Customer : Logistics domain
@enduml