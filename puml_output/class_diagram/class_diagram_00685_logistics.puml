@startuml
skinparam ArrowColor #555555
class Customer {
  #Date code
  +String status
  +updatePhone()
  +validateActive()
  +createActive()
}
interface Driver {
  +int quantity
  #boolean amount
  +long note
  #Date description
  +getAmount()
  +processActive()
  +getType()
}
class Inventory {
  -String createdAt
  +long active
  -double level
  +int price
  +deletePrice()
  +cancelAmount()
  +updateAddress()
  +deleteType()
}
abstract class Shipment {
  +double createdAt
  +Date active
  +String code
  +float total
  +float note
  +cancelName()
}
class Manifest {
  -long address
  #String status
  +String total
  #Date description
  +saveName()
  +getNote()
  +sendUpdatedat()
  +createScore()
}
class Tracking {
  #boolean code
  -Date active
  -long duration
  +cancelName()
  +findName()
  +sendUpdatedat()
}
class Depot {
  -String price
  #String status
  -boolean address
  #double phone
  +getName()
  +processEmail()
  +validateActive()
  +sendLevel()
}
Tracking --> Inventory : "0..1"
Shipment --o Manifest
@enduml