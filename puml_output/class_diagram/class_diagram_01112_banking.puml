@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Branch {
  #String level
  #String address
  +float note
  +deleteDescription()
  +sendType()
}
class Interest {
  +Date note
  #String updatedAt
  +double type
  +savePrice()
  +processType()
  +validateScore()
  +cancelAddress()
}
class Statement {
  -String address
  -long id
  #String code
  +saveEmail()
}
class Loan {
  #boolean id
  -double createdAt
  -Date quantity
  +Date name
  +float price
  +updateName()
  +validateAmount()
  +sendPrice()
  +deleteAmount()
}
class Withdrawal {
  #int quantity
  +float description
  #Date level
  -String address
  +validateDescription()
  +findActive()
  +cancelTotal()
}
Loan ..> Withdrawal : "1"
Interest --> Loan : "1"
Statement --o Loan
Branch --|> Loan
@enduml