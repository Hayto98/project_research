@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Branch {
  #String level
  #String address
  +float note
  +cancelQuantity()
  +saveUpdatedat()
}
abstract class Interest {
  #float duration
  #String type
  +double amount
  +cancelPrice()
  +validateQuantity()
  +deleteAmount()
  +validateId()
}
class Statement {
  +String status
  #double address
  +int phone
  #boolean code
  -String active
  +sendDuration()
  +processPrice()
  +processDescription()
  +findDescription()
}
abstract class Loan {
  #int email
  -Date price
  +deleteDescription()
  +validateCreatedat()
  +updateDuration()
}
abstract class Withdrawal {
  -String score
  #double email
  +findStatus()
  +updatePrice()
  +sendStatus()
  +createActive()
}
Loan ..> Branch : "*"
Branch ..> Interest : "*"
note right of Branch : Banking domain
@enduml