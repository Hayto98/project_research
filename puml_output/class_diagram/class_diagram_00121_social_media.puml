@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
abstract class User {
  +double name
  -boolean status
  +long id
  +validatePhone()
  +updatePrice()
  +validateDuration()
  +deleteUpdatedat()
}
class Story {
  -long level
  +String address
  +int amount
  +double code
  +double type
  +setCreatedat()
  +findEmail()
  +saveName()
}
abstract class Album {
  #String active
  #float type
  +saveActive()
  +createAmount()
}
class Profile {
  +double amount
  -int active
  +float description
  +calculateName()
  +validateAmount()
  +sendUpdatedat()
}
class Report {
  +Date id
  +long createdAt
  -Date address
  +validateScore()
  +saveDescription()
}
interface Like {
  +float duration
  -boolean code
  +Date email
  #int quantity
  +findUpdatedat()
}
class Group {
  #boolean duration
  #Date id
  #float note
  -boolean amount
  +createTotal()
}
Story ..|> Report
Album --* Like
Story --* Album
@enduml