@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Loan {
  +double total
  +int name
  +int note
  +updateCode()
  +saveTotal()
}
class Reservation {
  #int description
  #Date amount
  +boolean quantity
  +saveDuration()
  +processName()
  +cancelScore()
  +saveAmount()
}
class Publisher {
  #long email
  -boolean score
  +createNote()
}
interface Fine {
  #boolean score
  #double amount
  +boolean id
  #String address
  -long email
  +updateType()
  +setNote()
  +updatePrice()
}
Publisher --|> Loan
Reservation --o Publisher
Publisher ..|> Reservation
@enduml