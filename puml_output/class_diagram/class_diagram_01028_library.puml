@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Loan {
  +double total
  +int name
  +int note
  +validateCreatedat()
  +deleteAmount()
}
class Reservation {
  #String active
  #double code
  -String total
  +sendQuantity()
  +calculateScore()
  +sendName()
}
interface Publisher {
  #boolean score
  #double amount
  +boolean id
  #String address
  -long email
  +deleteTotal()
  +getQuantity()
  +validateCode()
}
class Fine {
  +double type
  +Date email
  +String price
  +processType()
  +sendName()
  +calculateEmail()
}
Publisher --|> Reservation
Reservation --> Fine : "*"
note right of Loan : Library domain
@enduml