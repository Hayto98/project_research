@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
interface Teacher {
  -int amount
  +float active
  -long address
  +processNote()
  +calculateCode()
  +calculateAmount()
  +saveEmail()
}
abstract class Department {
  -long amount
  +String level
  +createAddress()
}
class Schedule {
  #double status
  +boolean updatedAt
  #double type
  #Date price
  +validatePhone()
}
class Student {
  -String score
  -float id
  #Date createdAt
  +long code
  #Date note
  +findAmount()
  +cancelCreatedat()
  +findDuration()
}
abstract class Classroom {
  -long email
  -int updatedAt
  -double note
  +String level
  +validateName()
  +savePhone()
}
abstract class Library {
  +long active
  -int code
  +String type
  -String id
  -Date email
  +findTotal()
  +validateActive()
}
Classroom --> Student : "1..*"
Classroom ..|> Library
Library ..|> Classroom
@enduml