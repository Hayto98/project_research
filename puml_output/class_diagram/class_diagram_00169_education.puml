@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
interface Teacher {
  -int amount
  +float active
  -long address
  +savePrice()
  +processName()
  +findPrice()
  +getAmount()
}
interface Department {
  +float address
  +Date id
  #float level
  -float status
  +updateType()
}
abstract class Schedule {
  +float name
  +Date score
  -float level
  #String price
  #int id
  +processTotal()
}
class Student {
  -boolean createdAt
  -float phone
  #long active
  -int quantity
  -Date total
  +calculatePhone()
  +processAmount()
}
class Classroom {
  -float code
  -boolean name
  +Date createdAt
  -String type
  -int level
  +processDescription()
  +deleteCode()
  +createCode()
}
class Library {
  -boolean duration
  #long description
  #boolean active
  +saveLevel()
  +updateId()
}
Teacher --* Classroom
Library --* Teacher
note right of Teacher : Education domain
@enduml