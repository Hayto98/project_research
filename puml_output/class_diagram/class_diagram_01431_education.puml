@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Department {
  -float total
  #boolean level
  #int price
  +Date phone
  +updateType()
}
class Classroom {
  +boolean amount
  +boolean duration
  +long id
  -long description
  +cancelDuration()
}
interface Exam {
  #boolean score
  +Date type
  +double id
  +processPhone()
  +calculateCreatedat()
  +updateCreatedat()
  +deleteStatus()
}
class Enrollment {
  -int phone
  -float status
  #Date price
  +Date code
  +sendCreatedat()
  +deleteCode()
}
Enrollment --|> Exam
Exam --o Classroom
note right of Department : Education domain
@enduml