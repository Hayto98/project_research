@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Department {
  -float total
  #boolean level
  #int price
  +Date phone
  +calculateNote()
}
abstract class Classroom {
  #String address
  #int amount
  +boolean level
  +getQuantity()
}
class Exam {
  #double note
  +float phone
  #boolean code
  +Date amount
  +createDuration()
  +getPhone()
}
abstract class Enrollment {
  +String price
  +long createdAt
  #Date level
  -String score
  +deleteTotal()
  +updatePhone()
  +sendDescription()
  +setCreatedat()
}
Enrollment --o Department
Classroom ..|> Exam
@enduml