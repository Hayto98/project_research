@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
interface Restaurant {
  +Date quantity
  +double address
  -long score
  +int price
  +savePrice()
  +findLevel()
}
class CheckIn {
  -String createdAt
  -String updatedAt
  +processName()
}
class CheckOut {
  -boolean createdAt
  #Date price
  +long code
  #long phone
  +validateName()
}
abstract class Amenity {
  -long status
  #boolean note
  +validateLevel()
  +calculateAddress()
  +processEmail()
  +createScore()
}
interface Guest {
  -double total
  -float status
  -boolean active
  +double name
  -int updatedAt
  +getPrice()
}
abstract class Payment {
  +long amount
  #boolean name
  -double updatedAt
  +setLevel()
  +calculateDescription()
  +getPrice()
}
Restaurant ..|> Guest
CheckOut --o Amenity
CheckIn ..> Amenity : "0..1"
@enduml