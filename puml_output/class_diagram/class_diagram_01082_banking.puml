@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Loan {
  +boolean name
  #int note
  -String active
  +Date status
  #int total
  +updateName()
}
interface Deposit {
  +float duration
  +String note
  #int address
  +saveDescription()
  +deleteScore()
  +cancelScore()
}
class Teller {
  -long level
  #Date price
  #String status
  #double total
  #long id
  +saveType()
  +createAmount()
}
class Branch {
  #float level
  #String description
  #int email
  -float note
  +setType()
  +findName()
  +createDuration()
  +setScore()
}
interface Beneficiary {
  +long createdAt
  -Date address
  +saveId()
  +sendDuration()
}
Deposit ..|> Beneficiary
Branch --o Teller
Loan --|> Deposit
Beneficiary --o Branch
@enduml