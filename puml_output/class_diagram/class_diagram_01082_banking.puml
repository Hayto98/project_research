@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Loan {
  +boolean name
  #int note
  -String active
  +Date status
  #int total
  +setScore()
}
class Deposit {
  -Date address
  +Date description
  +double updatedAt
  #boolean status
  -String level
  +sendId()
  +validateEmail()
  +sendActive()
  +setNote()
}
interface Teller {
  #long createdAt
  #int phone
  -double id
  #float active
  +saveCreatedat()
}
abstract class Branch {
  -String description
  -double level
  #int price
  +Date name
  #int createdAt
  +updateNote()
  +createTotal()
}
class Beneficiary {
  -int code
  -int level
  +Date total
  +findAmount()
  +cancelDescription()
  +findPrice()
  +validatePrice()
}
Deposit --* Branch
Loan --* Beneficiary
Beneficiary ..|> Teller
note right of Loan : Banking domain
@enduml