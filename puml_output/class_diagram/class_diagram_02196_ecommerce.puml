@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Supplier {
  #Date note
  -double level
  #Date total
  +boolean createdAt
  -double quantity
  +processCreatedat()
  +processUpdatedat()
  +processNote()
  +getCode()
}
class Wishlist {
  -boolean note
  -Date description
  +boolean createdAt
  #String type
  +processActive()
  +calculateLevel()
}
class Category {
  +double type
  #float amount
  +String duration
  -String id
  +cancelTotal()
  +processPrice()
  +setDuration()
}
abstract class Cart {
  #String note
  #float address
  +updateCreatedat()
}
interface Review {
  +float quantity
  -Date level
  -double active
  #Date status
  +cancelName()
  +setDuration()
}
abstract class Shipment {
  -Date address
  +double total
  #int phone
  +String name
  #long active
  +getAddress()
  +processPhone()
  +deleteDuration()
  +findScore()
}
class Warehouse {
  #int updatedAt
  -Date active
  +int email
  #boolean description
  #float duration
  +deleteQuantity()
}
Warehouse --o Supplier
Cart --|> Review
Cart --|> Shipment
Review --|> Shipment
Cart --o Wishlist
@enduml