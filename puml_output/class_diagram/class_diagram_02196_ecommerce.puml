@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Supplier {
  #Date note
  -double level
  #Date total
  +boolean createdAt
  -double quantity
  +deleteLevel()
  +setAddress()
  +processDescription()
  +updateType()
}
abstract class Wishlist {
  +float name
  #int score
  -double code
  +float amount
  +getId()
  +calculateDuration()
  +deleteId()
  +validateCode()
}
class Category {
  +double updatedAt
  -float total
  +findStatus()
}
interface Cart {
  +float quantity
  -Date level
  -double active
  #Date status
  +findPrice()
  +savePrice()
}
class Review {
  -Date phone
  +float name
  +String level
  #long price
  -double updatedAt
  +createCode()
  +calculateUpdatedat()
  +sendEmail()
  +saveDescription()
}
class Shipment {
  #boolean price
  #float code
  +String updatedAt
  +setTotal()
  +calculateActive()
  +getNote()
  +saveCode()
}
interface Warehouse {
  -float price
  +Date updatedAt
  +createTotal()
  +updatePrice()
  +processDescription()
  +deleteTotal()
}
Category --* Review
Supplier --* Wishlist
Cart --o Review
note right of Supplier : Ecommerce domain
@enduml