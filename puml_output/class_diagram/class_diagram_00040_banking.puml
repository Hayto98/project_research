@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
abstract class Beneficiary {
  #long duration
  #boolean active
  +Date phone
  #double level
  -Date updatedAt
  +findPhone()
  +findPrice()
  +cancelType()
}
class Loan {
  #double level
  #int active
  #float type
  +String price
  +int address
  +saveType()
}
class Branch {
  +double active
  +double phone
  #boolean score
  +long code
  -int price
  +findPrice()
}
class Customer {
  +String score
  +double updatedAt
  +createDescription()
  +createAmount()
  +calculateNote()
}
class Transaction {
  #boolean duration
  -float id
  +getDuration()
  +findDuration()
  +setDescription()
  +deleteCode()
}
Branch --o Beneficiary
Transaction --o Customer
Transaction ..|> Beneficiary
Customer --o Transaction
@enduml