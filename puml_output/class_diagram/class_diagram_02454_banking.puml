@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
interface Branch {
  -boolean type
  -boolean status
  #float phone
  -String email
  +Date score
  +calculateDuration()
  +calculateAmount()
}
interface Beneficiary {
  +float updatedAt
  #int code
  +long active
  +calculateName()
  +setStatus()
}
class Deposit {
  -double name
  #double phone
  -double quantity
  +Date description
  +processDescription()
  +updateScore()
  +findName()
}
interface Transfer {
  #int level
  +long address
  #int quantity
  -long id
  +deleteAmount()
  +setStatus()
  +calculateTotal()
  +setCode()
}
interface Statement {
  +float duration
  -long updatedAt
  -boolean level
  +Date note
  #double createdAt
  +validateScore()
}
Transfer --* Statement
Beneficiary ..|> Branch
@enduml