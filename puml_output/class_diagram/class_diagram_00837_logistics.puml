@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Customer {
  -Date id
  #long status
  +createAddress()
  +saveUpdatedat()
  +updateCode()
  +processDuration()
}
class Vehicle {
  #float createdAt
  +int active
  -float address
  +float type
  +long description
  +validateAddress()
  +sendAddress()
}
class Warehouse {
  -double id
  -int status
  +findActive()
  +sendActive()
  +updateTotal()
  +updateId()
}
interface Route {
  -String phone
  +double total
  #int status
  +cancelEmail()
  +updateQuantity()
  +sendName()
  +processCreatedat()
}
interface FuelLog {
  -int note
  #double quantity
  +sendAddress()
  +saveUpdatedat()
  +findNote()
}
class Manifest {
  -String description
  -int address
  +getPrice()
}
Manifest --* Route
Route --|> Customer
note right of Customer : Logistics domain
@enduml