@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Customer {
  -Date id
  #long status
  +deleteCreatedat()
  +calculateCreatedat()
  +setScore()
  +createLevel()
}
class Vehicle {
  -int code
  #boolean note
  -Date updatedAt
  +processPhone()
  +validateCode()
  +cancelDuration()
  +getDuration()
}
class Warehouse {
  -float address
  +long createdAt
  #long status
  +sendEmail()
  +updateName()
  +updateActive()
}
class Route {
  #boolean total
  #boolean duration
  +double createdAt
  +String level
  +validateLevel()
  +calculateType()
}
class FuelLog {
  #int status
  -boolean email
  -int code
  -boolean id
  +double type
  +getUpdatedat()
  +getQuantity()
}
class Manifest {
  #long quantity
  #int note
  #double description
  -String level
  +long duration
  +createAddress()
  +processDescription()
  +setType()
}
Customer --|> Route
Manifest --* Route
@enduml