@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
abstract class Package {
  +int email
  +Date total
  +createActive()
  +calculateId()
}
abstract class Customer {
  -double id
  -double address
  +float name
  +int active
  -double score
  +sendStatus()
  +setStatus()
  +getId()
}
interface Vehicle {
  -int phone
  -int total
  #int quantity
  -String level
  +boolean description
  +createUpdatedat()
}
class Warehouse {
  +Date note
  +String score
  #boolean code
  +calculateCreatedat()
  +processPhone()
  +cancelQuantity()
}
class Depot {
  +long phone
  -String duration
  -float code
  +processPrice()
  +findDuration()
  +calculateId()
}
Warehouse --|> Package
Customer ..|> Warehouse
Depot --* Customer
note right of Package : Logistics domain
@enduml