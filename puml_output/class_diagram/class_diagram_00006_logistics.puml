@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
abstract class Package {
  +int email
  +Date total
  +getUpdatedat()
  +calculateScore()
}
interface Customer {
  #boolean id
  +Date total
  #String note
  -double duration
  -double address
  +updateCreatedat()
  +processPrice()
}
class Vehicle {
  +Date note
  +String email
  +Date active
  #float status
  +sendPhone()
  +sendUpdatedat()
  +processNote()
  +validateDescription()
}
abstract class Warehouse {
  +double total
  +Date active
  +double description
  +String phone
  +deleteName()
}
class Depot {
  +String amount
  #String note
  +Date score
  +getDescription()
  +updateEmail()
  +calculateNote()
}
Vehicle ..|> Depot
Customer ..> Vehicle : "1..*"
Package --* Customer
@enduml