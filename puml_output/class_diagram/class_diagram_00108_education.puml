@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
interface Grade {
  #String amount
  +double status
  #float code
  #long address
  #boolean description
  +findUpdatedat()
}
abstract class Book {
  +float phone
  #long quantity
  #boolean level
  -float note
  +getAddress()
  +getCode()
  +createScore()
}
class Attendance {
  +boolean score
  +boolean id
  -double email
  -Date status
  -double duration
  +processDuration()
  +processActive()
  +saveScore()
}
class Library {
  +Date score
  -Date status
  -String name
  -boolean price
  +processScore()
  +processId()
  +calculateName()
}
Grade --o Library
Library ..> Book : "1"
@enduml