@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
interface Grade {
  #String amount
  +double status
  #float code
  #long address
  #boolean description
  +cancelTotal()
}
interface Book {
  +float phone
  #long quantity
  #boolean level
  -float note
  +calculateLevel()
  +updatePhone()
  +cancelTotal()
}
interface Attendance {
  -String email
  #float status
  +sendNote()
  +calculateEmail()
}
class Library {
  -Date quantity
  #String updatedAt
  +double createdAt
  +Date phone
  -Date id
  +setPrice()
  +sendPhone()
  +cancelAddress()
  +setId()
}
Library --o Book
Grade --o Library
note right of Grade : Education domain
@enduml