@startuml

class Depot {
  #float note
  +String code
  #boolean createdAt
  #double updatedAt
  +calculateNote()
  +getCode()
  +calculateTotal()
}
abstract class Shipment {
  -float total
  #boolean level
  +Date phone
  -Date updatedAt
  +validatePhone()
  +updateType()
}
class Customer {
  -String id
  #boolean score
  -double phone
  +saveAddress()
  +updateCreatedat()
  +setActive()
  +getPhone()
}
class Manifest {
  +int active
  -float address
  +int description
  #int email
  +getCreatedat()
}
interface Driver {
  #String name
  -String type
  +sendCreatedat()
  +saveId()
  +setActive()
}
Shipment --|> Manifest
Driver ..|> Customer
Depot --|> Driver
Driver --o Manifest
note right of Depot : Logistics domain
@enduml