@startuml

class Depot {
  #float note
  +String code
  #boolean createdAt
  #double updatedAt
  +validateType()
  +calculateCode()
  +createType()
}
abstract class Shipment {
  -double code
  -double price
  +cancelPrice()
  +processDuration()
  +validateAmount()
}
interface Customer {
  -int email
  -Date createdAt
  -Date address
  +updateActive()
  +findUpdatedat()
}
interface Manifest {
  -double phone
  #long status
  +int score
  +float address
  +cancelId()
}
class Driver {
  +int active
  -float address
  +int description
  #int email
  +setName()
}
Driver --|> Depot
Manifest --o Depot
@enduml