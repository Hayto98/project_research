@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Story {
  -Date name
  +double type
  +boolean note
  -float id
  -boolean description
  +sendPhone()
  +saveAmount()
  +createStatus()
  +findActive()
}
class Hashtag {
  -long amount
  +double address
  +long note
  +float description
  #Date quantity
  +sendPhone()
  +sendCreatedat()
  +createDuration()
  +deleteQuantity()
}
class Like {
  #int quantity
  -float description
  +String note
  -long phone
  -int duration
  +cancelQuantity()
  +cancelDuration()
  +saveLevel()
  +updateStatus()
}
class Notification {
  -Date phone
  +int active
  +saveTotal()
  +calculateAmount()
  +createPrice()
}
abstract class Report {
  +float level
  #Date code
  +long active
  +createPrice()
  +saveScore()
}
class Group {
  +int phone
  #boolean active
  +float quantity
  +sendName()
}
class Comment {
  +double createdAt
  #int description
  +Date phone
  +deleteNote()
}
Like ..> Notification : "1..*"
Story --> Report : "1"
Group --* Hashtag
@enduml