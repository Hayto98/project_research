@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Story {
  -Date name
  +double type
  +boolean note
  -float id
  -boolean description
  +validateNote()
  +sendType()
  +createActive()
  +processAmount()
}
class Hashtag {
  -String description
  -String quantity
  #Date note
  -long address
  -double id
  +setPrice()
}
class Like {
  #int note
  -float phone
  +String quantity
  +createPhone()
  +updateActive()
  +calculateNote()
  +saveUpdatedat()
}
class Notification {
  -Date phone
  +int active
  +processPrice()
  +saveNote()
  +saveUpdatedat()
}
interface Report {
  #Date active
  +long status
  +calculatePhone()
  +savePhone()
}
class Group {
  #boolean active
  +float quantity
  +double code
  -int createdAt
  +deletePhone()
  +updateNote()
}
interface Comment {
  -long updatedAt
  -Date id
  #float name
  +setDuration()
  +sendId()
  +getDuration()
}
Like --* Group
Report ..> Notification : "1..*"
Report --o Story
note right of Story : Social Media domain
@enduml