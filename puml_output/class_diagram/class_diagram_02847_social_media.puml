@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
interface Post {
  #float description
  +boolean level
  #double id
  -boolean active
  #Date email
  +createLevel()
  +sendUpdatedat()
  +createPhone()
  +sendDescription()
}
class Comment {
  +boolean active
  #float name
  #String description
  +deleteTotal()
  +deleteNote()
  +deleteActive()
}
abstract class Group {
  #long quantity
  -float phone
  -String type
  #double id
  +long active
  +saveCreatedat()
  +sendTotal()
  +deleteName()
  +processTotal()
}
class Hashtag {
  #Date updatedAt
  -String level
  -String amount
  +boolean status
  #int address
  +setCreatedat()
  +processStatus()
}
class Story {
  #long active
  #int amount
  +createNote()
  +cancelType()
  +calculateId()
}
class User {
  +Date quantity
  #int amount
  +updatePrice()
}
Group --|> User
Hashtag --> Story : "0..1"
User --* Post
@enduml