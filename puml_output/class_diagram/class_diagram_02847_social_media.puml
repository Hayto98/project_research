@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
interface Post {
  #float description
  +boolean level
  #double id
  -boolean active
  #Date email
  +findStatus()
  +deleteLevel()
  +updateActive()
  +getDescription()
}
class Comment {
  -double phone
  -long name
  +processId()
  +findScore()
  +getActive()
}
class Group {
  -Date total
  #float id
  -long note
  +long name
  +findEmail()
  +processUpdatedat()
  +cancelAmount()
  +setAddress()
}
interface Hashtag {
  #int status
  #long address
  +Date code
  #String description
  #boolean active
  +sendEmail()
  +findCreatedat()
}
class Story {
  -int email
  +Date name
  +getId()
  +deleteAddress()
}
class User {
  #int price
  #String active
  +saveEmail()
  +deleteActive()
  +setType()
}
Story ..> Group : "1..*"
Story --> Comment : "1..*"
Hashtag --* Comment
note right of Post : Social Media domain
@enduml