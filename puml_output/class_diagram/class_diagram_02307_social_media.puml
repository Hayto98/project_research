@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
interface Notification {
  +double description
  #int updatedAt
  #Date createdAt
  #String duration
  +createUpdatedat()
  +createCode()
}
abstract class Report {
  -long phone
  #float amount
  #long level
  +findDescription()
  +calculateDescription()
  +validateUpdatedat()
  +validateCode()
}
abstract class Story {
  +boolean duration
  +float level
  -boolean quantity
  #double active
  +cancelPrice()
  +cancelNote()
}
class Like {
  +String quantity
  -String price
  #float type
  #Date id
  +updateQuantity()
  +sendLevel()
}
interface Post {
  #String id
  -long duration
  #String updatedAt
  #boolean price
  +calculateAmount()
}
Like --|> Notification
Report --* Story
Post ..|> Like
@enduml