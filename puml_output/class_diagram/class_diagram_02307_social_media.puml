@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
interface Notification {
  +double description
  #int updatedAt
  #Date createdAt
  #String duration
  +sendAmount()
  +processCreatedat()
}
class Report {
  #float amount
  #long quantity
  #double address
  +deleteType()
  +createDuration()
  +cancelQuantity()
  +sendStatus()
}
interface Story {
  +Date address
  +Date active
  +float note
  +createPrice()
  +processDuration()
  +getStatus()
}
class Like {
  +String id
  +float updatedAt
  #boolean score
  -float address
  +createQuantity()
}
class Post {
  -String note
  +int type
  +validateDuration()
  +sendType()
  +updateStatus()
}
Report --|> Post
Like ..|> Story
Like --> Report : "*"
note right of Notification : Social Media domain
@enduml