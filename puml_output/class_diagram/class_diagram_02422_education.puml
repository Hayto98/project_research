@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Assignment {
  -float note
  #double address
  -int status
  +Date duration
  -double id
  +saveTotal()
  +saveStatus()
}
interface Library {
  #boolean address
  -double level
  +setNote()
  +findCreatedat()
  +findUpdatedat()
  +cancelQuantity()
}
abstract class Classroom {
  -String type
  -long name
  -long id
  -long code
  +cancelUpdatedat()
  +findUpdatedat()
  +getPhone()
  +sendId()
}
class Grade {
  #long code
  #long duration
  -int email
  #int description
  #Date price
  +calculateCode()
  +findLevel()
}
Grade ..|> Classroom
Assignment --|> Library
Assignment ..|> Grade
note right of Assignment : Education domain
@enduml