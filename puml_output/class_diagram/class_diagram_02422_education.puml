@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Assignment {
  -float note
  #double address
  -int status
  +Date duration
  -double id
  +getAmount()
  +cancelPrice()
}
abstract class Library {
  -boolean active
  #boolean id
  +sendCreatedat()
  +createId()
  +calculateUpdatedat()
  +getDescription()
}
abstract class Classroom {
  #float note
  +boolean createdAt
  +getDuration()
  +createPrice()
  +findDuration()
}
class Grade {
  +long duration
  -double name
  -long id
  -double code
  #int address
  +createNote()
  +updateActive()
}
Assignment --|> Classroom
Grade --|> Assignment
Classroom ..> Grade : "0..1"
@enduml