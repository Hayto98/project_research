@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Product {
  +String type
  #String active
  +getDuration()
  +createType()
  +processPhone()
}
abstract class Coupon {
  #boolean note
  #String name
  +String type
  #long quantity
  -double id
  +sendLevel()
  +sendType()
}
abstract class Cart {
  #float active
  #int email
  +long price
  +float name
  +cancelId()
  +setQuantity()
  +updateStatus()
  +cancelUpdatedat()
}
interface Return {
  +Date price
  #double status
  +calculateName()
  +cancelAmount()
}
Coupon --o Cart
Product ..|> Cart
note right of Product : Ecommerce domain
@enduml