@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Product {
  +String type
  #String active
  +cancelTotal()
  +calculateUpdatedat()
  +deleteDescription()
}
class Coupon {
  +double type
  #long phone
  +Date price
  #Date duration
  +float note
  +validateId()
  +cancelAmount()
}
class Cart {
  #float note
  -boolean createdAt
  -Date active
  -boolean type
  #float total
  +cancelPrice()
}
interface Return {
  -boolean description
  +String phone
  -int name
  +findName()
}
Product --|> Coupon
Coupon --> Cart : "*"
@enduml