@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Follower {
  #Date level
  #Date name
  +int id
  +processActive()
  +processAddress()
}
abstract class Hashtag {
  +double email
  +Date type
  +double name
  +calculateId()
  +deleteCreatedat()
  +getScore()
}
abstract class User {
  +long createdAt
  -double address
  +double id
  #boolean note
  +float code
  +createQuantity()
}
abstract class Comment {
  +int description
  #int status
  -String email
  +getEmail()
}
class Message {
  #long level
  -long quantity
  -double name
  +boolean createdAt
  -Date amount
  +deleteQuantity()
}
class Group {
  -double code
  #int total
  -double status
  +float id
  #String name
  +processLevel()
  +saveEmail()
  +createName()
  +sendName()
}
abstract class Notification {
  -long description
  #boolean phone
  -String code
  #float active
  +saveAddress()
}
Group --o Message
Message ..|> Group
Message --* Comment
User --> Group : "0..1"
Notification --|> Follower
@enduml