@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Warehouse {
  #Date phone
  -boolean total
  #boolean quantity
  +long amount
  +boolean description
  +updateActive()
  +findStatus()
}
interface Customer {
  -float id
  +float duration
  +String email
  -boolean type
  -String price
  +saveActive()
  +getTotal()
  +saveType()
  +processCreatedat()
}
abstract class Supplier {
  +Date total
  -int type
  +float score
  +calculateType()
  +deleteLevel()
}
abstract class Coupon {
  +String updatedAt
  -boolean duration
  -Date createdAt
  #Date type
  -float level
  +deleteStatus()
}
abstract class Return {
  -long status
  #String id
  #float description
  #double email
  -long createdAt
  +sendType()
}
class Review {
  +boolean active
  -String amount
  +float createdAt
  #double note
  -long code
  +cancelStatus()
  +createDuration()
}
Warehouse --> Return : "0..1"
Return ..|> Warehouse
Customer --o Return
@enduml