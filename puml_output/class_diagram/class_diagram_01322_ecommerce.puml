@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Warehouse {
  #Date phone
  -boolean total
  #boolean quantity
  +long amount
  +boolean description
  +getLevel()
  +saveLevel()
}
abstract class Customer {
  -float id
  #double email
  +getStatus()
  +getTotal()
  +cancelQuantity()
  +getTotal()
}
interface Supplier {
  -boolean total
  +Date updatedAt
  -int duration
  +deleteTotal()
}
abstract class Coupon {
  +float updatedAt
  +String createdAt
  -boolean type
  +findDuration()
  +saveQuantity()
  +findId()
  +saveTotal()
}
abstract class Return {
  -int id
  -long description
  +cancelType()
}
abstract class Review {
  #int id
  +double updatedAt
  #float score
  +String type
  +getCreatedat()
  +cancelNote()
  +validateQuantity()
}
Warehouse ..|> Coupon
Warehouse --> Return : "0..1"
Return ..|> Warehouse
note right of Warehouse : Ecommerce domain
@enduml