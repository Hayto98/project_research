@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Message {
  -long level
  #String name
  +setDuration()
  +cancelPhone()
  +setCreatedat()
  +findUpdatedat()
}
abstract class Hashtag {
  +float code
  #Date status
  +double amount
  +findLevel()
  +validateScore()
  +deleteQuantity()
  +validateLevel()
}
abstract class Notification {
  +float score
  -long address
  #double total
  +saveLevel()
  +deleteTotal()
  +findLevel()
  +sendLevel()
}
class Post {
  -double type
  -String email
  +String quantity
  +updateAmount()
  +calculateType()
  +processAddress()
}
Post --o Hashtag
Message ..> Notification : "0..1"
Hashtag ..|> Message
note right of Message : Social Media domain
@enduml