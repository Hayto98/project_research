@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Message {
  -long level
  #String name
  +setStatus()
  +findDescription()
  +validateActive()
  +cancelId()
}
class Hashtag {
  +String updatedAt
  +int price
  #Date createdAt
  +findActive()
}
abstract class Notification {
  #double score
  +boolean amount
  #long quantity
  -String phone
  +validateDuration()
  +processEmail()
  +sendScore()
}
abstract class Post {
  #boolean total
  +boolean level
  +double score
  +setAmount()
  +getNote()
  +cancelAddress()
}
Notification --|> Message
Message ..|> Hashtag
Hashtag --o Post
@enduml