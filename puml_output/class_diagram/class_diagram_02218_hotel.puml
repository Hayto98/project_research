@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
abstract class Service {
  -String address
  -float quantity
  -int id
  +findActive()
}
class Amenity {
  -int status
  -boolean email
  +float price
  +boolean score
  #boolean id
  +sendEmail()
  +calculateUpdatedat()
  +findNote()
  +deleteAmount()
}
class CheckOut {
  #int status
  -String email
  -String quantity
  -int code
  #int address
  +saveDuration()
  +createLevel()
  +findEmail()
}
interface Housekeeping {
  -int level
  #Date duration
  +validatePhone()
  +findPrice()
}
class Reservation {
  +int id
  -Date amount
  #boolean level
  +long duration
  +deleteCode()
}
interface Room {
  +boolean note
  #float level
  +cancelAmount()
  +calculateName()
  +processTotal()
}
Room --o Service
Room --* Housekeeping
Amenity --> Housekeeping : "1..*"
@enduml