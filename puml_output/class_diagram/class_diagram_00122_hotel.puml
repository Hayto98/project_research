@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Restaurant {
  -String address
  +double note
  #Date phone
  #float price
  -Date createdAt
  +updateType()
  +validateQuantity()
  +validateDescription()
}
class CheckIn {
  +int name
  +boolean duration
  -long amount
  -boolean phone
  +String active
  +calculateLevel()
  +setAddress()
  +cancelNote()
}
class CheckOut {
  +double email
  +float quantity
  #double active
  +setEmail()
}
class Guest {
  +String quantity
  #Date note
  #String total
  +findAddress()
  +saveQuantity()
  +setName()
  +processLevel()
}
CheckOut --> CheckIn : "1"
Restaurant ..|> Guest
CheckIn --o Restaurant
@enduml