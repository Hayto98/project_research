@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Restaurant {
  -String address
  +double note
  #Date phone
  #float price
  -Date createdAt
  +deleteAmount()
  +createNote()
  +getName()
}
class CheckIn {
  #float phone
  -long updatedAt
  -boolean amount
  +String createdAt
  +sendCreatedat()
  +createDescription()
  +createDuration()
}
class CheckOut {
  #String price
  -int amount
  #int note
  +processTotal()
  +getName()
  +findLevel()
}
class Guest {
  #long updatedAt
  -boolean description
  +boolean id
  +int total
  +int type
  +calculateDuration()
  +setActive()
}
Restaurant --* Guest
Restaurant --* CheckIn
CheckOut --|> Restaurant
note right of Restaurant : Hotel domain
@enduml