@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
interface Book {
  +String type
  #boolean code
  #float email
  +createUpdatedat()
  +updateActive()
  +validateAmount()
}
class Enrollment {
  +Date updatedAt
  -double address
  #Date id
  #String price
  #Date email
  +getEmail()
}
class Teacher {
  +String price
  -Date note
  -boolean updatedAt
  +float email
  +processCode()
  +processScore()
}
class Department {
  +boolean description
  #double quantity
  +Date total
  +updateLevel()
  +getEmail()
  +deleteNote()
  +setEmail()
}
class Attendance {
  -String note
  #long createdAt
  -int active
  +findDescription()
  +calculateType()
  +sendName()
}
class Course {
  +double address
  -boolean active
  +double code
  +saveType()
  +sendScore()
  +calculateDuration()
}
Attendance --* Department
Teacher --> Attendance : "*"
Attendance --> Book : "1..*"
Book ..> Department : "1"
Enrollment --o Book
@enduml