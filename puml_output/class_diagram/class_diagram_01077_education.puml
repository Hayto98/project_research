@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
interface Book {
  +String type
  #boolean code
  #float email
  +sendId()
  +createCreatedat()
  +cancelNote()
}
class Enrollment {
  +Date id
  -double score
  #Date price
  #String email
  +deleteStatus()
}
interface Teacher {
  +String price
  -Date note
  -boolean updatedAt
  +float email
  +getCode()
  +cancelCreatedat()
}
class Department {
  +Date total
  #double id
  -int score
  +long note
  +cancelCreatedat()
}
abstract class Attendance {
  #long active
  -int type
  #long id
  +deleteDescription()
  +validateActive()
  +cancelCode()
  +setType()
}
class Course {
  #Date note
  #double quantity
  #double price
  +createDuration()
  +cancelType()
  +sendStatus()
}
Book ..> Department : "1"
Enrollment --o Book
Teacher ..|> Department
note right of Book : Education domain
@enduml