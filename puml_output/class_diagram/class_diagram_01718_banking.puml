@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Account {
  -float total
  #double name
  +double score
  +deleteStatus()
}
interface Branch {
  -Date duration
  +float active
  +createUpdatedat()
  +processDescription()
}
interface Card {
  #long note
  -boolean duration
  +createAddress()
  +getPhone()
}
class Transaction {
  +String total
  +double email
  #String type
  +Date score
  -boolean price
  +calculateStatus()
  +updateAddress()
}
class Statement {
  +Date score
  -int amount
  +calculateQuantity()
  +deleteAmount()
  +processAmount()
  +getDuration()
}
Account --> Statement : "0..1"
Card ..> Account : "*"
note right of Account : Banking domain
@enduml