@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Account {
  -float total
  #double name
  +double score
  +processUpdatedat()
}
class Branch {
  -Date duration
  +float active
  +processDescription()
  +sendPrice()
}
class Card {
  #long description
  -boolean score
  +long status
  #long note
  +float active
  +validateId()
  +createPrice()
  +getPhone()
}
class Transaction {
  -boolean type
  +String price
  #long code
  #Date id
  #int name
  +deleteQuantity()
  +sendEmail()
  +sendUpdatedat()
  +updateId()
}
class Statement {
  +Date status
  -int score
  #double amount
  +setTotal()
  +getStatus()
  +saveAddress()
  +getName()
}
Transaction --|> Branch
Statement --|> Account
@enduml