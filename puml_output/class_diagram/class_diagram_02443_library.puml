@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Author {
  #Date level
  +Date code
  +float type
  -int phone
  #String note
  +findLevel()
}
class Librarian {
  #double phone
  #double id
  +validateActive()
  +calculateCode()
}
class Renewal {
  #long quantity
  #boolean type
  +double email
  -boolean phone
  +calculateCreatedat()
  +getEmail()
}
class Catalog {
  +int createdAt
  -int id
  -double price
  +int updatedAt
  +Date type
  +validateTotal()
  +setAddress()
}
class Member {
  +String status
  #float address
  +getAmount()
}
abstract class Shelf {
  #long level
  +double total
  +int quantity
  -float email
  +getActive()
  +deleteId()
  +setType()
  +updateStatus()
}
Author --o Catalog
Member ..|> Author
Author ..|> Member
note right of Author : Library domain
@enduml