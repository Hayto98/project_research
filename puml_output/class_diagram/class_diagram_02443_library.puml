@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Author {
  #Date level
  +Date code
  +float type
  -int phone
  #String note
  +cancelName()
}
interface Librarian {
  #double status
  +long phone
  #double id
  #String price
  +saveScore()
  +findType()
  +calculateLevel()
}
class Renewal {
  -long email
  #boolean phone
  +double address
  +float active
  +float createdAt
  +processName()
  +findAmount()
  +cancelNote()
}
class Catalog {
  +long updatedAt
  -int type
  +int description
  #int duration
  -double total
  +setQuantity()
}
class Member {
  -String name
  +boolean status
  +processQuantity()
}
class Shelf {
  #long quantity
  +double level
  +int total
  -float duration
  -String email
  +updateDuration()
  +setStatus()
}
Librarian --* Author
Author --o Catalog
Member ..|> Author
Author ..|> Member
@enduml