@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
interface Patient {
  #float active
  +boolean type
  +validateScore()
  +getType()
  +updateAmount()
  +setId()
}
class Ward {
  -Date note
  +int name
  +Date updatedAt
  -float duration
  +Date score
  +sendUpdatedat()
  +processDescription()
  +findTotal()
}
class Nurse {
  -float id
  #long active
  #int amount
  +setActive()
}
class Treatment {
  -int description
  +long name
  #Date updatedAt
  +float type
  #int duration
  +findType()
  +createId()
  +setAmount()
  +validateName()
}
class LabTest {
  #int status
  +Date updatedAt
  -boolean score
  +createNote()
  +saveAmount()
}
class Diagnosis {
  +boolean note
  #Date id
  +float status
  +validateNote()
  +saveActive()
}
class Insurance {
  +double createdAt
  -String duration
  +cancelLevel()
}
Nurse ..> Treatment : "0..1"
Ward --|> Nurse
@enduml