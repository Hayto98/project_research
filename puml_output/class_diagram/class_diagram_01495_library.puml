@startuml
skinparam defaultFontSize 11
abstract class Member {
  #int email
  #Date status
  +cancelCode()
  +findCreatedat()
  +saveEmail()
  +findNote()
}
class Branch {
  +float quantity
  -long duration
  +long level
  +boolean email
  +createQuantity()
  +calculateTotal()
}
abstract class Loan {
  +float total
  -String description
  #double status
  +setTotal()
}
abstract class Author {
  +long code
  -boolean phone
  #boolean total
  -Date level
  +String createdAt
  +getStatus()
  +createDuration()
}
class Shelf {
  -long level
  -String code
  -double address
  -long duration
  +double name
  +validateUpdatedat()
  +findCreatedat()
  +updateId()
  +saveActive()
}
Author --> Shelf : "0..1"
Shelf --* Member
note right of Member : Library domain
@enduml