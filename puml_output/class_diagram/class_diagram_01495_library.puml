@startuml
skinparam defaultFontSize 11
abstract class Member {
  #int email
  #Date status
  +validateActive()
  +findNote()
  +saveDescription()
  +getStatus()
}
class Branch {
  #float note
  -long phone
  -int quantity
  -long score
  +processDescription()
}
class Loan {
  -double email
  +double quantity
  +Date price
  +updateActive()
}
class Author {
  +String score
  #Date type
  +processLevel()
  +deletePhone()
  +processType()
  +createAddress()
}
class Shelf {
  #Date phone
  #float createdAt
  -Date code
  +String address
  #int total
  +updateCreatedat()
}
Loan --> Member : "*"
Shelf ..> Member : "1..*"
@enduml