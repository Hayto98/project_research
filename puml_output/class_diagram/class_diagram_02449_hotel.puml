@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Amenity {
  #boolean price
  +long active
  #int total
  #float code
  #String status
  +updateScore()
  +calculateAddress()
  +calculateStatus()
}
abstract class Reservation {
  +String createdAt
  +String duration
  +findAmount()
}
class Invoice {
  +String score
  #float type
  +deletePrice()
  +updateCreatedat()
  +processLevel()
  +cancelCreatedat()
}
class Staff {
  +long description
  #float quantity
  +validateScore()
  +createId()
}
class Housekeeping {
  #int description
  #Date level
  #int status
  +calculateName()
  +getEmail()
  +sendAmount()
  +createQuantity()
}
Invoice --o Staff
Reservation ..> Invoice : "1"
Staff --o Amenity
note right of Amenity : Hotel domain
@enduml