@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Amenity {
  #boolean price
  +long active
  #int total
  #float code
  #String status
  +findAddress()
  +saveActive()
  +cancelCreatedat()
}
class Reservation {
  +String status
  +String price
  +float name
  #int createdAt
  +float active
  +cancelAmount()
}
abstract class Invoice {
  -int status
  -int active
  +updateAmount()
  +processTotal()
}
interface Staff {
  +long name
  +long active
  #float status
  +createActive()
  +saveActive()
}
class Housekeeping {
  +boolean id
  #float description
  +createLevel()
}
Reservation --o Staff
Amenity --* Housekeeping
@enduml