@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
abstract class Customer {
  #String createdAt
  #float quantity
  +saveName()
  +getDuration()
  +deleteQuantity()
  +findDuration()
}
class Payment {
  +String updatedAt
  -int active
  +sendLevel()
  +getCode()
  +processCreatedat()
  +saveTotal()
}
interface Return {
  -boolean quantity
  #double phone
  #int type
  +cancelName()
  +createPrice()
}
class Supplier {
  +String level
  -float total
  +sendCreatedat()
}
Payment --* Supplier
Supplier --o Payment
Payment --> Customer : "*"
note right of Customer : Ecommerce domain
@enduml