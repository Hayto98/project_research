@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
interface Transfer {
  +double updatedAt
  +double code
  +String total
  -boolean duration
  +getNote()
  +setScore()
  +processPrice()
}
class Beneficiary {
  +Date id
  +Date description
  +processStatus()
  +saveName()
  +updateScore()
  +validateType()
}
interface Customer {
  +int createdAt
  +float address
  +saveDescription()
  +createDescription()
  +getPrice()
  +sendId()
}
class Transaction {
  #double amount
  -double email
  +int name
  -Date description
  #long note
  +createActive()
  +processStatus()
  +deleteEmail()
}
class Withdrawal {
  +boolean score
  #float active
  +updateId()
  +updateName()
  +validateType()
  +findUpdatedat()
}
class Statement {
  #String score
  +double createdAt
  +updateName()
}
Beneficiary --> Transaction : "1..*"
Customer --> Statement : "0..1"
Withdrawal ..|> Beneficiary
Transaction --* Statement
@enduml