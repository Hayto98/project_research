@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
interface Transfer {
  +double updatedAt
  +double code
  +String total
  -boolean duration
  +createUpdatedat()
  +setName()
  +findId()
}
class Beneficiary {
  -Date description
  #String type
  +long phone
  +deleteCode()
}
abstract class Customer {
  #float amount
  #long note
  +int duration
  +saveTotal()
  +createPrice()
  +deleteUpdatedat()
  +calculateAddress()
}
interface Transaction {
  #Date address
  #Date phone
  #float level
  +boolean code
  +findStatus()
  +cancelId()
  +setScore()
  +updateActive()
}
class Withdrawal {
  +long total
  +double name
  +createQuantity()
  +cancelUpdatedat()
  +cancelCreatedat()
}
class Statement {
  #int price
  +double quantity
  -int phone
  -int score
  +double note
  +saveStatus()
  +sendQuantity()
  +saveQuantity()
  +cancelDuration()
}
Transfer ..> Statement : "0..1"
Withdrawal ..|> Beneficiary
note right of Transfer : Banking domain
@enduml