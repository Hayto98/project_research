@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Statement {
  +boolean phone
  +String email
  -float description
  #boolean name
  +cancelCode()
}
interface Card {
  -float name
  #long email
  +setNote()
  +findEmail()
}
class Deposit {
  #long amount
  +boolean updatedAt
  +validateStatus()
  +processStatus()
  +processLevel()
  +processType()
}
abstract class Beneficiary {
  -float description
  -Date duration
  +findActive()
}
abstract class Account {
  #float id
  +int quantity
  +float code
  +deleteStatus()
  +cancelEmail()
  +createPhone()
}
abstract class Teller {
  #Date createdAt
  -long total
  +updateDuration()
  +findType()
  +deleteId()
  +findPrice()
}
class Transaction {
  +boolean score
  +Date note
  +boolean type
  -double amount
  +validateQuantity()
  +cancelStatus()
  +processPhone()
}
Beneficiary --* Card
Statement --|> Card
Statement ..> Teller : "1"
Account --o Transaction
Deposit --> Teller : "*"
@enduml