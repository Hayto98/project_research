@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Librarian {
  #int description
  +double price
  #long note
  +sendCode()
  +createDescription()
}
abstract class Catalog {
  -String quantity
  -String level
  +Date name
  +int duration
  +findScore()
  +getTotal()
}
class Fine {
  +float email
  -boolean description
  #Date type
  +Date score
  #boolean level
  +setType()
  +updateScore()
}
abstract class Publisher {
  -long status
  +Date id
  +updateDuration()
  +sendEmail()
  +createActive()
}
class Shelf {
  -int id
  -double note
  #String score
  -int quantity
  +cancelCode()
  +createLevel()
}
Publisher --|> Catalog
Catalog ..> Librarian : "*"
Librarian --|> Publisher
Catalog --o Shelf
@enduml