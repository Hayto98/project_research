@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Librarian {
  #int description
  +double price
  #long note
  +processActive()
  +processEmail()
}
class Catalog {
  +long quantity
  +int duration
  +updateLevel()
  +updateQuantity()
}
class Fine {
  #double note
  -int email
  +float description
  +cancelDescription()
  +saveLevel()
  +deleteDescription()
}
abstract class Publisher {
  -long status
  +Date id
  +getCreatedat()
  +validateDescription()
  +createId()
}
abstract class Shelf {
  #String address
  -int updatedAt
  +double quantity
  #Date total
  +deleteCode()
  +updateStatus()
  +findActive()
  +cancelType()
}
Publisher ..|> Librarian
Catalog ..> Publisher : "1"
note right of Librarian : Library domain
@enduml