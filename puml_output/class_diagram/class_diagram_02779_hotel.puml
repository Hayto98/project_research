@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Restaurant {
  #float score
  -long amount
  +processUpdatedat()
}
class Invoice {
  +Date score
  -int name
  +String total
  +createTotal()
  +deleteNote()
  +calculateNote()
  +processName()
}
abstract class Room {
  +boolean active
  -double note
  #Date description
  #int type
  #double name
  +deleteTotal()
}
interface Guest {
  #String price
  #Date amount
  -Date score
  +saveQuantity()
  +deleteType()
  +getCreatedat()
  +validateDescription()
}
abstract class Housekeeping {
  -String quantity
  #float type
  #double address
  +updateEmail()
  +saveDuration()
  +setNote()
}
class CheckOut {
  #long price
  -String level
  +float active
  #Date name
  +calculateDuration()
  +findPhone()
  +deleteCode()
  +findPrice()
}
class Service {
  #double active
  +double score
  -boolean name
  +updateEmail()
  +calculatePrice()
}
Housekeeping --* Guest
Guest --> Invoice : "*"
Guest ..|> Restaurant
@enduml