@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Restaurant {
  #float score
  -long amount
  +deleteCreatedat()
}
class Invoice {
  #double total
  +float code
  +setNote()
  +findName()
}
class Room {
  #double note
  #int duration
  +getCreatedat()
  +cancelPrice()
  +processDuration()
  +findUpdatedat()
}
abstract class Guest {
  -int level
  #boolean description
  +savePhone()
}
abstract class Housekeeping {
  -double score
  -long price
  +float amount
  +validateTotal()
  +cancelTotal()
  +validateQuantity()
  +calculateLevel()
}
interface CheckOut {
  -String score
  +float email
  +sendDescription()
  +validateActive()
  +updateUpdatedat()
