@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Wishlist {
  -Date code
  #Date address
  #double id
  +cancelLevel()
  +validateCode()
}
class Category {
  #long name
  +Date type
  #boolean total
  +validateDescription()
}
abstract class Payment {
  -long amount
  +long description
  -double name
  -float updatedAt
  +validateLevel()
  +setLevel()
  +deleteTotal()
  +cancelAddress()
}
class Shipment {
  #float description
  #int price
  #String total
  #double type
  +setActive()
}
Category --> Shipment : "0..1"
Shipment --> Category : "0..1"
@enduml