@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Book {
  +int price
  +String active
  #float level
  #Date score
  +findDuration()
  +deleteEmail()
}
abstract class Grade {
  +long updatedAt
  +String email
  #boolean level
  -boolean name
  +setActive()
}
class Schedule {
  #boolean status
  +int type
  +int quantity
  #boolean description
  +long address
  +saveDuration()
  +sendStatus()
  +processUpdatedat()
}
class Exam {
  #int email
  +boolean amount
  +findStatus()
}
class Enrollment {
  +double amount
  #int description
  +String code
  #String updatedAt
  +findTotal()
  +processEmail()
}
class Department {
  +boolean quantity
  -String address
  -Date name
  +sendDescription()
  +sendName()
  +updateQuantity()
}
interface Library {
  -String amount
  -double name
  -Date createdAt
  #String active
  +createCreatedat()
  +updateName()
  +saveNote()
}
Enrollment --> Library : "*"
Grade --|> Schedule
Schedule --|> Exam
Exam --* Book
Book --* Schedule
@enduml