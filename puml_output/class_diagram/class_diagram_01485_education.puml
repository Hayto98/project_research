@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Book {
  +int price
  +String active
  #float level
  #Date score
  +sendType()
  +createUpdatedat()
}
interface Grade {
  -String email
  +boolean score
  #long name
  #Date code
  +getTotal()
}
class Schedule {
  +int quantity
  +float description
  #boolean address
  +long active
  -boolean level
  +createName()
  +createAmount()
}
interface Exam {
  #int createdAt
  #long score
  #float id
  +deleteCode()
  +cancelUpdatedat()
}
class Enrollment {
  #int score
  #long updatedAt
  +float id
  -long name
  +String duration
  +getAddress()
  +findAddress()
  +processScore()
}
class Department {
  -String name
  -double createdAt
  -Date active
  +createDescription()
}
class Library {
  #boolean note
  -int level
  -String score
  +processName()
  +processId()
  +createId()
}
Schedule --o Grade
Exam ..|> Schedule
Department ..|> Library
Book --o Grade
note right of Book : Education domain
@enduml