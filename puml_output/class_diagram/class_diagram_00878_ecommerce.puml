@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Payment {
  -float total
  +double active
  -Date status
  #double level
  +Date note
  +processQuantity()
  +validateEmail()
}
class Shipment {
  #int level
  #Date status
  +processScore()
  +validateCode()
}
abstract class Category {
  #float id
  #double score
  -Date active
  +findCreatedat()
  +validateTotal()
  +getLevel()
  +calculateAddress()
}
interface Customer {
  -float duration
  +long id
  -double status
  -boolean createdAt
  #boolean type
  +deleteScore()
  +updateLevel()
  +calculateCreatedat()
  +updateType()
}
abstract class Product {
  +boolean createdAt
  +int description
  +long score
  +cancelAmount()
  +getEmail()
  +findDuration()
}
Customer ..> Payment : "1"
Payment --|> Product
Shipment --|> Customer
@enduml