@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Payment {
  -float total
  +double active
  -Date status
  #double level
  +Date note
  +getStatus()
  +getName()
}
interface Shipment {
  #Date active
  #int updatedAt
  +calculateLevel()
  +findAmount()
}
class Category {
  #boolean type
  -boolean total
  +String email
  +double code
  -float amount
  +validateTotal()
}
abstract class Customer {
  -int level
  -Date total
  +int amount
  +boolean quantity
  +cancelName()
}
class Product {
  +boolean email
  -double address
  +Date score
  +getStatus()
}
Shipment --|> Customer
Product --|> Customer
note right of Payment : Ecommerce domain
@enduml