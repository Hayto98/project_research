@startuml
skinparam defaultFontSize 13
class Teacher {
  -String note
  -int status
  #Date address
  -long amount
  +saveNote()
  +validateCreatedat()
}
abstract class Exam {
  #long updatedAt
  -String name
  +getQuantity()
  +findActive()
}
interface Student {
  +float type
  +double total
  +double amount
  +getQuantity()
  +sendLevel()
  +updateAddress()
  +findScore()
}
interface Library {
  +int code
  #Date email
  +double level
  -String updatedAt
  +updateStatus()
  +setName()
  +sendEmail()
  +cancelType()
}
abstract class Enrollment {
  #String duration
  +String id
  #int total
  +validateLevel()
  +cancelId()
  +saveTotal()
  +cancelAddress()
}
interface Attendance {
  #double email
  #float name
  +int active
  +int code
  +boolean total
  +deleteId()
}
abstract class Classroom {
  #int duration
  -int amount
  +double type
  #boolean active
  -boolean description
  +getCreatedat()
  +setCode()
  +validateActive()
  +updateCreatedat()
}
Attendance ..> Exam : "0..1"
Student ..|> Library
Attendance --o Student
@enduml