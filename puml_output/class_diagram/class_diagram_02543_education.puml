@startuml
skinparam defaultFontSize 13
class Teacher {
  -String note
  -int status
  #Date address
  -long amount
  +updateDescription()
  +calculateScore()
}
class Exam {
  -String name
  +boolean active
  -Date quantity
  +processTotal()
  +deleteName()
}
class Student {
  +long name
  -int price
  +int level
  #Date quantity
  +double address
  +getDuration()
  +processUpdatedat()
  +getCreatedat()
}
abstract class Library {
  #String duration
  +String id
  #int total
  +validateQuantity()
  +cancelTotal()
  +createName()
  +sendCode()
}
abstract class Enrollment {
  +boolean level
  #String amount
  -Date createdAt
  -boolean score
  +double updatedAt
  +saveUpdatedat()
  +calculateDescription()
}
class Attendance {
  #int level
  #int duration
  -double email
  +Date type
  -double amount
  +sendCreatedat()
  +validateDescription()
  +setPrice()
}
class Classroom {
  #float code
  -String createdAt
  +cancelActive()
}
Library --> Enrollment : "1"
Enrollment --|> Classroom
Attendance --* Library
Library ..> Student : "*"
Teacher --o Enrollment
note right of Teacher : Education domain
@enduml