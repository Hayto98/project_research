@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Nurse {
  +Date quantity
  #int description
  -Date duration
  +deleteCode()
}
class Insurance {
  #double updatedAt
  +boolean level
  +validateScore()
  +calculateCreatedat()
}
class Billing {
  #double quantity
  #Date active
  #int amount
  +createScore()
  +sendType()
  +updateName()
  +getId()
}
class Prescription {
  -long id
  +int name
  +createTotal()
  +getAddress()
  +cancelDuration()
  +processEmail()
}
class Appointment {
  +int type
  -String createdAt
  +boolean name
  -boolean code
  -String status
  +validateStatus()
  +setDuration()
  +saveName()
}
interface Diagnosis {
  #float description
  #boolean quantity
  #Date active
  +validateName()
}
class Treatment {
  +double level
  -Date updatedAt
  +deleteId()
  +saveCode()
}
Appointment ..|> Insurance
Billing --* Appointment
@enduml