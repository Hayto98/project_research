@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Billing {
  #int status
  #long total
  +Date duration
  +sendNote()
  +calculatePrice()
  +createCreatedat()
  +cancelPhone()
}
interface Treatment {
  +Date email
  +float amount
  -float name
  #String phone
  -String code
  +calculateScore()
  +processActive()
  +getDuration()
  +sendScore()
}
class Patient {
  #String price
  -boolean createdAt
  #int total
  #double note
  -int updatedAt
  +updatePhone()
}
class Hospital {
  +boolean description
  +double active
  -double name
  +updateAmount()
}
class Prescription {
  -boolean type
  -long email
  #long active
  -int updatedAt
  +long status
  +setNote()
  +deleteDescription()
}
Hospital --o Billing
Prescription --o Billing
Hospital --* Treatment
Prescription ..|> Treatment
@enduml