@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
abstract class Reservation {
  +int quantity
  -String updatedAt
  +String amount
  +String createdAt
  #double note
  +setUpdatedat()
  +calculateTotal()
  +createPrice()
}
interface Restaurant {
  -long status
  #Date duration
  -String address
  #String level
  +boolean email
  +setTotal()
  +calculateUpdatedat()
  +saveStatus()
}
interface CheckOut {
  #int duration
  #float email
  +setPrice()
  +sendDuration()
  +validateQuantity()
  +getId()
}
class Booking {
  -String amount
  +double id
  +processTotal()
  +setPrice()
  +cancelUpdatedat()
  +calculateActive()
}
class Staff {
  -String quantity
  +Date type
  +long amount
  +boolean address
  +createEmail()
}
Reservation --> Booking : "*"
CheckOut ..|> Booking
CheckOut --* Restaurant
@enduml