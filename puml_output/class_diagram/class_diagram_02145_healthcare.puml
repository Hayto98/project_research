@startuml
skinparam defaultFontSize 11
class Ward {
  +long updatedAt
  -Date status
  #int phone
  +long type
  #int amount
  +processId()
  +sendAmount()
  +createPrice()
}
class Billing {
  -String active
  #int price
  +int type
  -String duration
  -boolean name
  +calculateDescription()
  +deleteType()
}
class MedicalRecord {
  +double email
  #String type
  -Date level
  +deleteId()
  +deletePhone()
  +getDuration()
}
abstract class LabTest {
  +float total
  +Date level
  +float duration
  +boolean id
  #String price
  +updateLevel()
  +calculateLevel()
}
abstract class Nurse {
  #long active
  -Date updatedAt
  +int type
  +processDuration()
  +validatePrice()
  +createId()
  +cancelLevel()
}
class Doctor {
  +long description
  #int status
  -String id
  +getScore()
}
class Prescription {
  -String id
  +String code
  #float email
  #Date duration
  +validateTotal()
  +findUpdatedat()
  +setTotal()
  +sendStatus()
}
MedicalRecord --* Ward
Prescription --* MedicalRecord
Prescription --o Ward
Nurse ..> LabTest : "0..1"
MedicalRecord --o LabTest
Billing ..> Nurse : "*"
@enduml