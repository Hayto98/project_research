@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
abstract class Reservation {
  -double level
  +boolean score
  #float price
  -double quantity
  +saveDuration()
}
abstract class Room {
  +float updatedAt
  #int active
  +saveDescription()
  +validatePrice()
}
class CheckOut {
  -boolean level
  +boolean type
  -double price
  +Date updatedAt
  +findCreatedat()
}
class Payment {
  +String note
  +long name
  #String email
  +boolean description
  #int code
  +getDuration()
}
abstract class Service {
  #double price
  +long updatedAt
  -String createdAt
  +cancelStatus()
  +sendNote()
  +cancelPrice()
}
abstract class Restaurant {
  -String email
  #long code
  -double createdAt
  +float note
  -int type
  +getQuantity()
  +processNote()
  +validateTotal()
  +getAddress()
}
Service --> CheckOut : "0..1"
Room --> Restaurant : "1..*"
Payment --> Room : "0..1"
@enduml