@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class MedicalRecord {
  +int price
  #long address
  +boolean id
  +sendId()
  +deleteName()
  +findEmail()
  +processCreatedat()
}
interface Diagnosis {
  -boolean quantity
  #float note
  #Date phone
  +Date description
  +savePhone()
}
class Hospital {
  #double id
  -int type
  #String phone
  +updateDescription()
  +calculateNote()
  +createEmail()
}
class Ward {
  +float total
  -float quantity
  +processScore()
  +updateQuantity()
  +findId()
  +updateId()
}
Hospital --> MedicalRecord : "1..*"
Ward ..|> MedicalRecord
Diagnosis --> MedicalRecord : "*"
note right of MedicalRecord : Healthcare domain
@enduml