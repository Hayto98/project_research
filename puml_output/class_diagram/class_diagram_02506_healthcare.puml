@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class MedicalRecord {
  +int price
  #long address
  +boolean id
  +calculateActive()
  +processCode()
  +updateType()
  +processQuantity()
}
class Diagnosis {
  #double createdAt
  -int active
  -boolean score
  #float quantity
  #Date level
  +sendPrice()
}
interface Hospital {
  +String phone
  -long duration
  +createEmail()
  +sendCreatedat()
  +getTotal()
  +createType()
}
class Ward {
  -long updatedAt
  -String description
  -Date price
  -int note
  +updateQuantity()
  +sendScore()
  +cancelCode()
  +cancelAmount()
}
Hospital --|> Ward
Diagnosis --* MedicalRecord
@enduml