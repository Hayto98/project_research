@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Exam {
  +Date description
  +boolean total
  #long quantity
  -double active
  +updateStatus()
  +getQuantity()
  +processNote()
  +setType()
}
interface Student {
  #int quantity
  +boolean duration
  +sendStatus()
  +saveDuration()
  +findNote()
  +getPrice()
}
class Grade {
  -long email
  +int createdAt
  #long phone
  +validateAddress()
  +findPhone()
  +getType()
  +setType()
}
class Enrollment {
  #long name
  #int phone
  +cancelDuration()
  +updateAddress()
}
abstract class Schedule {
  #long quantity
  +String description
  +boolean address
  +validateActive()
}
Exam ..> Enrollment : "0..1"
Enrollment ..> Exam : "*"
Enrollment --> Schedule : "1..*"
note right of Exam : Education domain
@enduml