@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Exam {
  +Date description
  +boolean total
  #long quantity
  -double active
  +updateStatus()
  +validateId()
  +sendTotal()
  +findScore()
}
abstract class Student {
  #int status
  +boolean type
  -boolean id
  #String quantity
  #Date active
  +calculateEmail()
  +sendScore()
  +sendStatus()
  +sendDuration()
}
class Grade {
  -long email
  +int createdAt
  #long phone
  +findEmail()
  +findTotal()
  +deleteCode()
  +findQuantity()
}
class Enrollment {
  -float type
  +String code
  +setCreatedat()
}
class Schedule {
  -float level
  -int description
  -boolean createdAt
  +long score
  +sendLevel()
  +cancelTotal()
  +processName()
}
Schedule --* Exam
Schedule ..> Grade : "1"
@enduml