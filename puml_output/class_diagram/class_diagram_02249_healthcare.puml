@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
interface Patient {
  #double score
  #Date amount
  +int total
  #int name
  +calculatePhone()
  +findCreatedat()
}
class MedicalRecord {
  +String duration
  -Date quantity
  +float updatedAt
  -int type
  +savePrice()
  +processNote()
  +deleteAddress()
}
interface Nurse {
  +Date duration
  #int id
  -boolean status
  #double name
  -float score
  +sendPhone()
  +setType()
  +validateName()
}
class Diagnosis {
  -Date price
  -Date phone
  -boolean updatedAt
  +findScore()
}
class Doctor {
  -int phone
  +int active
  +String status
  #long total
  +long price
  +deleteAmount()
  +validateTotal()
  +saveCreatedat()
  +sendName()
}
abstract class Treatment {
  #float email
  #float status
  +Date updatedAt
  #String active
  -boolean phone
  +setCode()
  +processPrice()
}
class Appointment {
  #String note
  +int id
  -long price
  #String name
  #long description
  +createActive()
  +getCreatedat()
  +updateStatus()
}
Appointment --o MedicalRecord
Nurse --> Appointment : "*"
Patient --> MedicalRecord : "*"
@enduml