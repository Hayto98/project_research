@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
abstract class Group {
  #int updatedAt
  +Date address
  -Date createdAt
  +updateDescription()
}
class Report {
  #float id
  -boolean duration
  +Date level
  #String score
  +validateCode()
  +createId()
  +processTotal()
  +saveActive()
}
class Profile {
  +String phone
  -boolean createdAt
  +saveNote()
  +getPrice()
  +getStatus()
  +validateUpdatedat()
}
abstract class Follower {
  -boolean score
  -String quantity
  -Date price
  +boolean name
  #int total
  +sendActive()
}
abstract class Message {
  #Date name
  +long type
  #float duration
  #double note
  -String email
  +setPhone()
  +validateAmount()
  +calculateDuration()
  +saveAddress()
}
abstract class Like {
  -double updatedAt
  -String price
  -int address
  +float score
  #float code
  +cancelAddress()
  +updateLevel()
  +findDescription()
}
class Album {
  #Date updatedAt
  +boolean price
  #Date phone
  #long score
  +createScore()
  +cancelActive()
}
Message ..|> Album
Message --o Report
Group --* Message
Profile --|> Message
Like --* Report
note right of Group : Social Media domain
@enduml