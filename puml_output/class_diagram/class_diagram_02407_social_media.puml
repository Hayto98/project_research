@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
abstract class Group {
  #int updatedAt
  +Date address
  -Date createdAt
  +cancelLevel()
}
class Report {
  +String status
  +Date address
  -boolean id
  +deleteType()
}
interface Profile {
  +long type
  +double phone
  +updateAddress()
  +deleteStatus()
  +findDuration()
  +updateScore()
}
class Follower {
  +String phone
  -boolean createdAt
  +sendDuration()
  +calculateTotal()
  +processTotal()
  +setName()
}
abstract class Message {
  +double status
  #double address
  +saveName()
  +setId()
  +deleteNote()
}
abstract class Like {
  #Date duration
  +float total
  +boolean status
  #Date note
  -double id
  +validateUpdatedat()
}
class Album {
  -String email
  #double score
  +long id
  -int quantity
  -float note
  +validateType()
  +createPrice()
  +sendQuantity()
}
Follower ..> Report : "*"
Profile --|> Album
Follower --o Album
Group ..|> Follower
Report ..> Like : "1..*"
Message ..|> Profile
@enduml