@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
abstract class Student {
  #boolean email
  #double amount
  +boolean duration
  #String score
  +int note
  +cancelScore()
  +createName()
  +getType()
}
class Enrollment {
  +Date note
  -float total
  -long amount
  +updateNote()
}
class Schedule {
  -boolean status
  +int quantity
  +calculateTotal()
  +setName()
  +createAddress()
  +createEmail()
}
class Grade {
  +double updatedAt
  #boolean note
  +long duration
  +sendPhone()
  +cancelNote()
  +saveActive()
}
interface Attendance {
  #int price
  #float updatedAt
  +int level
  +String name
  +setId()
  +processType()
  +saveTotal()
}
abstract class Library {
  +long updatedAt
  -long amount
  +Date price
  +Date total
  +calculateEmail()
  +setType()
  +deleteAddress()
  +sendDescription()
}
Grade ..|> Library
Library --o Schedule
@enduml