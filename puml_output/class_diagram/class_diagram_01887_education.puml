@startuml
skinparam defaultFontSize 11
class Classroom {
  #boolean code
  #long id
  +setEmail()
  +saveAmount()
}
abstract class Schedule {
  +String phone
  -boolean amount
  +calculateName()
  +cancelDuration()
  +saveTotal()
  +processName()
}
class Course {
  #double price
  -float address
  +long id
  +findTotal()
  +findScore()
  +cancelName()
}
class Department {
  -String status
  #boolean level
  +long price
  #double total
  -Date duration
  +validateTotal()
  +cancelPhone()
  +findCreatedat()
}
class Enrollment {
  #long email
  -boolean total
  +createCode()
  +cancelCode()
}
class Exam {
  -double note
  -String level
  +getAmount()
}
interface Attendance {
  #String address
  #String type
  +deleteEmail()
  +getId()
  +findDescription()
}
Schedule ..> Attendance : "1"
Classroom --o Schedule
Attendance --> Enrollment : "0..1"
Exam --> Classroom : "0..1"
Department ..|> Schedule
@enduml