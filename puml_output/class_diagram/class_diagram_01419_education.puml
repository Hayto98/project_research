@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Teacher {
  -long address
  -int name
  -float total
  +boolean code
  #long amount
  +validateEmail()
  +cancelDescription()
}
class Grade {
  +double quantity
  +float description
  +boolean type
  -double phone
  +float amount
  +processPhone()
  +setAddress()
  +deleteDescription()
}
class Book {
  #int phone
  #int email
  +int price
  +int level
  +deleteNote()
}
class Enrollment {
  -Date phone
  -int type
  -int level
  +validateTotal()
  +calculateNote()
}
class Classroom {
  #double updatedAt
  #int price
  -boolean duration
  +cancelAmount()
  +calculateType()
  +deleteActive()
}
Grade --* Book
Teacher --|> Book
note right of Teacher : Education domain
@enduml