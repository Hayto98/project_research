@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Teacher {
  -long address
  -int name
  -float total
  +boolean code
  #long amount
  +deleteLevel()
  +createAmount()
}
class Grade {
  +float code
  -long total
  #Date quantity
  +deleteAddress()
  +getAddress()
}
class Book {
  -int score
  -float email
  +validatePrice()
  +cancelType()
  +findType()
  +deleteCode()
}
class Enrollment {
  -long amount
  -long description
  #int createdAt
  #int phone
  +findId()
}
class Classroom {
  -String duration
  +long name
  #double description
  +sendScore()
  +cancelDescription()
  +processScore()
  +saveAmount()
}
Book ..|> Grade
Book --o Enrollment
@enduml