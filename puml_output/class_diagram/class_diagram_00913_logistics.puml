@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Vehicle {
  #String id
  -Date address
  +saveEmail()
  +getAmount()
}
class Customer {
  #Date duration
  +double createdAt
  -int quantity
  #float address
  -int active
  +processName()
  +createCode()
  +calculateEmail()
  +saveLevel()
}
interface FuelLog {
  +float email
  -boolean phone
  +findCreatedat()
  +updateName()
}
class Warehouse {
  -int email
  #long type
  +Date address
  +long description
  +validateQuantity()
  +deleteCode()
}
Customer --> Warehouse : "1"
FuelLog --> Customer : "*"
note right of Vehicle : Logistics domain
@enduml