@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Vehicle {
  #String id
  -Date address
  +processAddress()
  +saveUpdatedat()
}
class Customer {
  -Date amount
  #int createdAt
  +savePrice()
  +updateCode()
  +calculateName()
}
class FuelLog {
  #float type
  -int email
  -double createdAt
  +updateCode()
}
class Warehouse {
  #boolean price
  #String email
  +sendPhone()
  +updateType()
  +getName()
}
Customer ..|> FuelLog
Vehicle --* Warehouse
@enduml