@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
interface Payment {
  +Date note
  #double score
  +setName()
  +findDuration()
  +getUpdatedat()
  +calculateDescription()
}
interface Invoice {
  +boolean id
  +double email
  -float amount
  +saveTotal()
  +createType()
  +cancelNote()
  +createPhone()
}
class Category {
  -long status
  #double email
  #float description
  #String createdAt
  +int quantity
  +sendUpdatedat()
  +getPhone()
}
class Review {
  +boolean updatedAt
  +Date email
  #float score
  +String note
  +boolean createdAt
  +updateUpdatedat()
  +validateCode()
  +findActive()
}
Review --|> Payment
Review --> Category : "1"
@enduml