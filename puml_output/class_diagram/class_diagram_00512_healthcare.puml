@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
interface Prescription {
  +double duration
  +int amount
  +sendAddress()
  +calculateCode()
  +saveNote()
}
class MedicalRecord {
  #boolean note
  #int name
  -boolean quantity
  +setAddress()
  +sendNote()
  +sendStatus()
}
class Diagnosis {
  #long email
  +long active
  #float description
  +processPrice()
  +createCode()
}
class Hospital {
  +double updatedAt
  #int score
  #float name
  #long duration
  #String createdAt
  +getCreatedat()
  +saveUpdatedat()
}
class Billing {
  +String id
  +boolean updatedAt
  #boolean name
  +findAddress()
}
class Doctor {
  +String amount
  -int level
  +long phone
  +getAmount()
}
MedicalRecord --* Prescription
Billing --> Hospital : "1..*"
Hospital ..> MedicalRecord : "*"
@enduml