@startuml
skinparam ArrowColor #555555
class Attendance {
  +String id
  +float description
  #float updatedAt
  +cancelAmount()
  +calculateAddress()
  +validateStatus()
}
class Classroom {
  #boolean address
  #float phone
  -float status
  -boolean name
  #float duration
  +validateUpdatedat()
  +calculateLevel()
}
class Course {
  #int price
  +double type
  +boolean level
  -Date description
  #int code
  +findScore()
  +getScore()
  +createQuantity()
}
interface Department {
  -String code
  +Date address
  +String quantity
  +float id
  +cancelType()
}
Attendance --o Course
Department --|> Course
Course --o Department
@enduml