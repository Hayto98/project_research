@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
abstract class Account {
  +String type
  +long address
  #long note
  +long level
  -float status
  +processCreatedat()
}
abstract class Customer {
  -long code
  +int duration
  -String updatedAt
  #boolean email
  +calculateStatus()
  +processAmount()
  +setPhone()
}
abstract class Teller {
  #boolean duration
  -int updatedAt
  -int address
  -float price
  +updateLevel()
  +deleteQuantity()
  +createNote()
}
class Deposit {
  +String address
  +long score
  +processScore()
}
class Transfer {
  -String total
  -double name
  -int price
  +cancelEmail()
  +validateCreatedat()
  +calculateType()
  +validateDescription()
}
class Statement {
  -float score
  #double id
  -double phone
  +findId()
  +createName()
}
class Beneficiary {
  -int type
  #float note
  -Date description
  +boolean name
  +double email
  +savePhone()
}
Statement --|> Beneficiary
Teller --> Statement : "0..1"
@enduml