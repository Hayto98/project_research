@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class CheckOut {
  -long id
  #double total
  +setNote()
}
abstract class Housekeeping {
  +boolean price
  -int updatedAt
  #int id
  #long score
  +saveDuration()
  +setTotal()
}
interface Payment {
  +Date level
  -float type
  +Date address
  #Date note
  +updatePhone()
  +saveEmail()
  +sendAddress()
  +cancelDuration()
}
abstract class Staff {
  -Date quantity
  +int price
  +validateUpdatedat()
  +getAddress()
  +sendPrice()
}
class Service {
  #long active
  #Date name
  #int email
  #float total
  -float type
  +findUpdatedat()
}
abstract class Room {
  +String active
  +long amount
  -double address
  +cancelId()
  +cancelQuantity()
  +setScore()
  +validateCreatedat()
}
class Amenity {
  +boolean amount
  +Date createdAt
  -long score
  #Date type
  +findAmount()
  +processScore()
  +deleteCreatedat()
  +createName()
}
Staff --* CheckOut
CheckOut ..> Staff : "0..1"
note right of CheckOut : Hotel domain
@enduml