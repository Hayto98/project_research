@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class CheckOut {
  -long id
  #double total
  +findNote()
}
abstract class Housekeeping {
  +boolean phone
  -int price
  #int updatedAt
  #long id
  +Date active
  +findAmount()
}
interface Payment {
  +Date level
  -float type
  +Date address
  #Date note
  +validateLevel()
  +updateStatus()
  +saveScore()
  +findStatus()
}
class Staff {
  -double duration
  #int total
  +boolean code
  #float quantity
  +sendStatus()
  +calculateName()
  +createScore()
}
class Service {
  #String score
  -boolean price
  #float quantity
  #double note
  +validateStatus()
  +createUpdatedat()
  +cancelId()
  +cancelAmount()
}
class Room {
  -int id
  +float updatedAt
  +long type
  -double amount
  -boolean active
  +cancelActive()
}
class Amenity {
  +String score
  #long address
  +processActive()
  +createStatus()
}
CheckOut --|> Service
Room --* Staff
Service --o Room
Room --o Housekeeping
Service ..|> Housekeeping
@enduml