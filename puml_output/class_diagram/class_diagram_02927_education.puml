@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Attendance {
  -Date phone
  +double code
  +calculateQuantity()
  +getDuration()
  +deletePhone()
  +updateStatus()
}
class Department {
  +float active
  #float duration
  #Date quantity
  +calculatePhone()
}
abstract class Course {
  +float duration
  -long active
  +double status
  +createCreatedat()
  +cancelDuration()
  +setName()
  +createPrice()
}
class Exam {
  #boolean duration
  -long total
  -float quantity
  -boolean price
  +String note
  +deleteEmail()
  +findStatus()
  +createPhone()
  +updateUpdatedat()
}
class Grade {
  +int type
  #boolean duration
  +Date phone
  #float active
  +deleteDescription()
  +saveCode()
  +cancelCode()
  +saveDuration()
}
class Teacher {
  -long address
  +Date name
  -double quantity
  -Date level
  +validateScore()
  +createDuration()
  +sendNote()
}
class Enrollment {
  +double createdAt
  +Date description
  #long type
  +sendNote()
  +findDescription()
}
Course ..|> Attendance
Grade ..|> Course
Teacher --o Grade
Course ..|> Teacher
Attendance --|> Grade
Enrollment --o Department
@enduml