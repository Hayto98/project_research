@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Driver {
  #long updatedAt
  #long type
  -float id
  +getCreatedat()
}
class Shipment {
  #Date description
  #Date active
  +int code
  -float name
  +Date level
  +updateNote()
  +updateCreatedat()
  +processType()
  +updateAddress()
}
class Warehouse {
  -long email
  #Date duration
  +updateCode()
}
class Tracking {
  -long email
  -long code
  -long level
  #float description
  +findType()
}
class DeliveryNote {
  #Date level
  +long code
  -Date active
  #String quantity
  +boolean score
  +getActive()
  +cancelEmail()
}
class Manifest {
  +float total
  +long quantity
  +Date email
  +cancelUpdatedat()
  +sendNote()
  +getTotal()
  +saveTotal()
}
class Depot {
  #String score
  #String amount
  #String createdAt
  +String updatedAt
  +saveScore()
  +setLevel()
}
Depot --o Shipment
Manifest --|> Driver
Tracking ..|> Driver
@enduml