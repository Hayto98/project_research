@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
abstract class Billing {
  +int duration
  -float name
  +float note
  +cancelName()
  +processPhone()
}
interface Diagnosis {
  #float createdAt
  +String type
  -boolean note
  +int email
  +calculateEmail()
  +processUpdatedat()
}
class Nurse {
  +String score
  #String quantity
  -long active
  +Date type
  +int name
  +validateId()
  +processId()
  +sendEmail()
  +findUpdatedat()
}
class Doctor {
  +Date note
  +float price
  #double score
  +sendNote()
  +findStatus()
  +processQuantity()
  +updatePhone()
}
class Ward {
  -int updatedAt
  #long email
  +deleteAmount()
  +createScore()
  +getLevel()
}
class Hospital {
  -Date duration
  #int active
  +sendActive()
}
Hospital ..|> Nurse
Billing --|> Ward
note right of Billing : Healthcare domain
@enduml