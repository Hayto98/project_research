@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
abstract class Billing {
  +int duration
  -float name
  +float note
  +processId()
  +setUpdatedat()
}
abstract class Diagnosis {
  #double duration
  -Date quantity
  +String createdAt
  -boolean type
  +updateStatus()
  +setCreatedat()
}
interface Nurse {
  #Date total
  +Date email
  -Date type
  +cancelAmount()
  +calculatePhone()
  +createUpdatedat()
  +saveStatus()
}
abstract class Doctor {
  #String description
  -long name
  +calculateStatus()
  +setDescription()
}
class Ward {
  #int address
  #long id
  +double type
  -Date level
  #Date email
  +getAmount()
}
class Hospital {
  -long score
  +long price
  -float active
  +float note
  +long status
  +saveTotal()
  +sendEmail()
  +sendAmount()
  +getNote()
}
Diagnosis --* Hospital
Ward --> Billing : "0..1"
Hospital ..> Billing : "1..*"
Hospital --|> Diagnosis
@enduml