@startuml
skinparam monochrome true
skinparam defaultFontSize 11
interface Album {
  -double updatedAt
  +int description
  #double status
  +String quantity
  +updateTotal()
  +calculateCreatedat()
}
abstract class Comment {
  -Date email
  +int phone
  +deleteStatus()
}
interface Like {
  -double score
  -String note
  +deleteScore()
  +deleteActive()
  +createLevel()
  +getCode()
}
abstract class Story {
  +boolean address
  +String phone
  +processAmount()
  +getDescription()
  +createType()
}
class Hashtag {
  +Date code
  +int level
  -int active
  -Date score
  +sendId()
  +processPhone()
  +cancelCode()
}
class Post {
  #int note
  #boolean price
  -float quantity
  #boolean createdAt
  +saveEmail()
  +sendType()
}
abstract class Follower {
  #int name
  #int quantity
  +findLevel()
  +processTotal()
  +processLevel()
  +validateName()
}
Like --> Follower : "*"
Album ..> Post : "*"
@enduml