@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Album {
  -int createdAt
  #long amount
  +Date address
  #boolean email
  +deletePrice()
  +cancelName()
}
class Comment {
  #Date price
  +int address
  -String type
  #boolean note
  +createLevel()
}
class Like {
  +int phone
  +Date amount
  +long type
  -int total
  +sendName()
  +createDuration()
  +processId()
}
class Group {
  +long id
  -long createdAt
  -String address
  +int note
  +createUpdatedat()
  +updateLevel()
  +processEmail()
  +saveAmount()
}
class Hashtag {
  -int phone
  -boolean name
  +deleteCreatedat()
}
interface Follower {
  #int id
  -boolean code
  -String createdAt
  -long phone
  -int address
  +sendStatus()
  +calculateStatus()
}
Follower --o Album
Album --o Hashtag
Album ..> Like : "*"
Comment --> Group : "0..1"
Like ..|> Group
@enduml