@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Album {
  -int createdAt
  #long amount
  +Date address
  #boolean email
  +processCreatedat()
  +validatePrice()
}
interface Comment {
  -String type
  #boolean note
  #String name
  #long amount
  +validateAmount()
  +processTotal()
  +getCreatedat()
}
class Like {
  -double quantity
  -boolean type
  -long createdAt
  +saveCreatedat()
}
class Group {
  +String name
  +float address
  -boolean level
  -boolean email
  -long phone
  +validateName()
}
class Hashtag {
  #float total
  #double name
  +Date email
  +updateDuration()
}
class Follower {
  +long duration
  -double description
  +boolean address
  #int type
  +findStatus()
  +calculateStatus()
  +sendTotal()
  +setAddress()
}
Comment --> Group : "0..1"
Like ..|> Group
Follower ..> Like : "1"
Comment --|> Follower
Hashtag ..> Like : "0..1"
note right of Album : Social Media domain
@enduml