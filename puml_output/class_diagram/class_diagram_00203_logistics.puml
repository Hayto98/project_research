@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
abstract class Inventory {
  #int total
  -boolean amount
  -boolean price
  -int updatedAt
  #int description
  +calculateDuration()
}
class Warehouse {
  #Date level
  +String email
  +int createdAt
  -String price
  +saveDescription()
  +createEmail()
  +cancelUpdatedat()
}
interface Depot {
  #float code
  -boolean id
  -String price
  -Date name
  +sendEmail()
}
abstract class Vehicle {
  +Date updatedAt
  -int description
  +validateScore()
}
class Shipment {
  #String quantity
  -String code
  +deletePrice()
}
Warehouse --o Inventory
Shipment --* Depot
Vehicle --* Warehouse
@enduml