@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
abstract class Classroom {
  +float status
  -long description
  #double score
  +processLevel()
}
class Book {
  -Date name
  +double type
  #double phone
  +calculatePhone()
}
interface Department {
  -float id
  #Date email
  #int status
  +savePhone()
}
interface Assignment {
  +float duration
  +float note
  #float price
  -int address
  #long type
  +cancelEmail()
}
Book --> Department : "0..1"
Assignment ..> Book : "0..1"
note right of Classroom : Education domain
@enduml