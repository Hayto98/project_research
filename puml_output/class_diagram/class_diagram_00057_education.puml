@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
abstract class Classroom {
  +float status
  -long description
  #double score
  +calculateAmount()
}
interface Book {
  -long updatedAt
  -Date name
  +calculateAmount()
  +deleteStatus()
}
abstract class Department {
  #int price
  #Date phone
  +sendAddress()
}
class Assignment {
  #double level
  -long createdAt
  -String status
  +float phone
  #float total
  +validateCreatedat()
  +sendActive()
  +processDescription()
  +setStatus()
}
Book ..|> Department
Book --o Assignment
Book --* Classroom
@enduml