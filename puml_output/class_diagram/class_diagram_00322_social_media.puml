@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
interface Album {
  #boolean level
  #double duration
  -double description
  +String createdAt
  +validateEmail()
  +setEmail()
  +updateAddress()
  +sendId()
}
class Notification {
  #double id
  +Date price
  +setAmount()
  +sendEmail()
  +validateCreatedat()
  +processName()
}
abstract class Profile {
  -int address
  #boolean price
  #Date type
  -float status
  +processDuration()
}
interface Like {
  -boolean quantity
  +float address
  #int price
  +float total
  +long status
  +getPrice()
  +saveScore()
  +calculateCreatedat()
}
abstract class Post {
  +double score
  #long name
  #long quantity
  +deleteNote()
  +setPhone()
}
class Story {
  -String description
  -int quantity
  #double email
  +double id
  -double status
  +processLevel()
}
Like --o Post
Post --|> Album
Like --|> Notification
Story --* Notification
Profile --|> Notification
@enduml