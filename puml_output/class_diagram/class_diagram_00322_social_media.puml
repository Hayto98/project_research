@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
interface Album {
  #boolean level
  #double duration
  -double description
  +String createdAt
  +setAddress()
  +saveCreatedat()
  +updateDuration()
  +setId()
}
abstract class Notification {
  -Date description
  #long note
  -double createdAt
  -String duration
  -int id
  +setUpdatedat()
  +sendPrice()
  +createAddress()
  +findLevel()
}
abstract class Profile {
  +float status
  +long price
  -float active
  -long description
  -float createdAt
  +sendName()
  +createUpdatedat()
}
abstract class Like {
  #int level
  -float email
  +long amount
  -String name
  +validateName()
}
class Post {
  -double level
  -String price
  -Date description
  +processDuration()
  +calculateActive()
  +findId()
  +setPrice()
}
class Story {
  -float createdAt
  +String phone
  +deleteDescription()
  +cancelScore()
}
Album ..> Story : "1"
Story ..> Post : "*"
note right of Album : Social Media domain
@enduml