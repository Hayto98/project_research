@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
abstract class Review {
  #int price
  #double phone
  #int level
  #int createdAt
  +setCode()
  +getType()
  +sendNote()
}
class Cart {
  #boolean email
  #Date note
  +deletePrice()
  +setPhone()
  +createNote()
  +savePrice()
}
class Category {
  -long amount
  #Date email
  +boolean id
  +validatePhone()
  +updatePhone()
}
class Invoice {
  #float quantity
  +double status
  -Date address
  #boolean price
  +long description
  +saveTotal()
}
abstract class Return {
  +long address
  #boolean active
  #String level
  +long note
  -double status
  +cancelDescription()
}
abstract class Order {
  -Date name
  -String amount
  -long email
  -String total
  +cancelCreatedat()
}
class Product {
  +String status
  +long type
  #float description
  +saveId()
  +findCreatedat()
}
Invoice --> Review : "*"
Product ..|> Return
Product ..> Review : "*"
@enduml