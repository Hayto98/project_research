@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
abstract class Review {
  #int price
  #double phone
  #int level
  #int createdAt
  +findCode()
  +updateCreatedat()
  +setEmail()
}
abstract class Cart {
  -String note
  -long level
  #Date createdAt
  +boolean score
  #Date amount
  +setId()
  +saveType()
}
class Category {
  #int address
  #float price
  +processTotal()
  +findLevel()
}
class Invoice {
  #Date code
  #double price
  +float note
  +long address
  +updateQuantity()
}
abstract class Return {
  -float status
  -long price
  #long address
  +long name
  -float amount
  +getScore()
  +getTotal()
  +deleteAmount()
}
class Order {
  #float description
  +String duration
  -float id
  +double status
  +boolean address
  +sendUpdatedat()
  +getType()
  +sendActive()
  +savePhone()
}
abstract class Product {
  +float total
  -boolean type
  -String amount
  +processCode()
  +sendEmail()
}
Order --> Return : "0..1"
Cart --> Invoice : "1..*"
note right of Review : Ecommerce domain
@enduml