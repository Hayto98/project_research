@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
interface Booking {
  #float id
  -float description
  #float email
  +long level
  #int price
  +cancelType()
  +validateEmail()
  +createLevel()
}
class Amenity {
  #float address
  #long name
  #long updatedAt
  -boolean total
  +deleteUpdatedat()
}
class Invoice {
  #boolean description
  -Date amount
  +setNote()
}
interface Guest {
  -String address
  #long total
  #String type
  +validateId()
  +calculateType()
  +cancelPhone()
}
abstract class Payment {
  #String updatedAt
  #Date total
  +Date duration
  +updateActive()
  +cancelPhone()
}
class Housekeeping {
  +String createdAt
  +double price
  #float quantity
  -double amount
  -boolean description
  +updateAddress()
  +calculateScore()
  +updateId()
  +getDescription()
}
Guest --* Payment
Amenity --* Guest
note right of Booking : Hotel domain
@enduml