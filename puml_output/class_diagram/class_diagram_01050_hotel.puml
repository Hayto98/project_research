@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
interface Booking {
  #float id
  -float description
  #float email
  +long level
  #int price
  +sendLevel()
  +getQuantity()
  +validateName()
}
class Amenity {
  -Date email
  +int level
  -boolean phone
  #long duration
  +setAmount()
  +cancelAddress()
  +saveActive()
}
class Invoice {
  +Date updatedAt
  +boolean amount
  +Date active
  +cancelDuration()
  +getUpdatedat()
  +cancelEmail()
}
class Guest {
  -String duration
  #long amount
  #String address
  -long total
  +double type
  +cancelActive()
  +updateTotal()
  +sendPrice()
  +calculateCode()
}
class Payment {
  #Date total
  +Date updatedAt
  +float status
  +updateNote()
  +getQuantity()
}
class Housekeeping {
  -float total
  -int createdAt
  +updateUpdatedat()
  +saveId()
}
Housekeeping --o Guest
Guest --> Payment : "*"
Amenity --o Invoice
Payment --|> Amenity
Booking --|> Amenity
@enduml