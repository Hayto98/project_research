@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Profile {
  +float address
  #float total
  +String description
  +updateLevel()
  +saveEmail()
  +createDescription()
}
class Notification {
  #long status
  -String address
  +Date price
  +float phone
  #int updatedAt
  +deleteAmount()
  +deleteActive()
}
class Group {
  -String status
  #float type
  -int note
  -String updatedAt
  #String createdAt
  +createCreatedat()
  +calculateActive()
}
abstract class Story {
  -double code
  -float quantity
  +Date total
  +updateStatus()
  +calculateScore()
}
interface Hashtag {
  #int updatedAt
  #float duration
  -Date note
  +cancelDuration()
  +createLevel()
  +validateDescription()
}
class Message {
  #double duration
  -double email
  -long updatedAt
  +getLevel()
  +deleteStatus()
  +saveScore()
  +sendStatus()
}
Message --> Story : "*"
Message --* Notification
Hashtag --o Story
Notification --> Story : "0..1"
@enduml