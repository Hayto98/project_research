@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Profile {
  +float address
  #float total
  +String description
  +createName()
  +sendCode()
  +calculateStatus()
}
class Notification {
  +Date phone
  +float updatedAt
  #int email
  #int total
  -double status
  +calculateStatus()
}
abstract class Group {
  +long updatedAt
  +boolean createdAt
  +int note
  +boolean id
  -boolean phone
  +setQuantity()
  +calculatePrice()
}
abstract class Story {
  +int status
  #float description
  -boolean updatedAt
  +boolean email
  -Date score
  +saveDescription()
  +updateDuration()
  +createUpdatedat()
}
abstract class Hashtag {
  #long note
  #long type
  #double address
  #double duration
  #int code
  +sendNote()
  +processDescription()
  +savePrice()
}
interface Message {
  #int score
  -long id
  +String email
  +setType()
  +deleteUpdatedat()
  +deleteAmount()
}
Message --o Notification
Story --o Hashtag
Story ..> Profile : "0..1"
note right of Profile : Social Media domain
@enduml