@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
abstract class Diagnosis {
  +long createdAt
  +double price
  +setPrice()
  +updateName()
  +saveName()
}
class MedicalRecord {
  #boolean type
  -boolean quantity
  -Date active
  +Date level
  +findPrice()
  +processType()
  +saveNote()
  +saveCreatedat()
}
class Prescription {
  -float name
  -long level
  +updateName()
  +setDuration()
  +createPrice()
}
class Ward {
  +long status
  -Date email
  +float createdAt
  +calculateLevel()
  +deleteQuantity()
  +updateQuantity()
}
class Patient {
  +float phone
  +int active
  #Date quantity
  +setQuantity()
}
class Insurance {
  +long address
  #Date level
  +findStatus()
}
MedicalRecord ..> Ward : "1"
Patient ..> Diagnosis : "*"
Diagnosis ..|> MedicalRecord
Patient --> Prescription : "1"
Diagnosis --|> Patient
@enduml