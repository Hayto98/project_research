@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
abstract class Diagnosis {
  +long createdAt
  +double price
  +setPrice()
  +validateQuantity()
  +saveType()
}
class MedicalRecord {
  #Date score
  #float total
  #double price
  #double status
  +calculateAddress()
  +getId()
}
class Prescription {
  -float note
  +float quantity
  +String level
  #long status
  +getPhone()
  +validateUpdatedat()
}
class Ward {
  -boolean email
  -int amount
  +updateScore()
  +saveId()
}
class Patient {
  +long address
  #Date level
  +savePrice()
}
class Insurance {
  +int name
  #long active
  #Date duration
  #String note
  +boolean id
  +createScore()
}
Ward --> Diagnosis : "*"
Ward --o MedicalRecord
Patient --> Ward : "0..1"
Insurance --|> MedicalRecord
note right of Diagnosis : Healthcare domain
@enduml