@startuml
skinparam monochrome true
skinparam defaultFontSize 13
abstract class Vehicle {
  #double amount
  #long phone
  -boolean email
  #boolean duration
  +createUpdatedat()
  +deleteId()
}
class Tracking {
  +String quantity
  #boolean level
  -String active
  -boolean status
  -int phone
  +calculateUpdatedat()
}
abstract class Shipment {
  +int name
  #float id
  #boolean phone
  -long email
  +updateTotal()
  +getAddress()
  +validateNote()
  +cancelScore()
}
interface Manifest {
  -Date createdAt
  +int id
  #Date address
  +validateAmount()
  +createCode()
  +sendAddress()
  +updateScore()
}
Tracking --o Shipment
Vehicle --* Shipment
Manifest --o Tracking
note right of Vehicle : Logistics domain
@enduml