@startuml
skinparam monochrome true
skinparam defaultFontSize 13
abstract class Vehicle {
  #double amount
  #long phone
  -boolean email
  #boolean duration
  +cancelAddress()
  +sendLevel()
}
class Tracking {
  #long id
  #Date updatedAt
  #float total
  +sendPhone()
}
class Shipment {
  -String level
  -boolean duration
  +sendEmail()
  +updateUpdatedat()
  +deleteAmount()
}
class Manifest {
  +int quantity
  #float name
  #boolean id
  -long phone
  #float email
  +validateNote()
  +validateLevel()
  +getUpdatedat()
  +sendStatus()
}
Vehicle --* Tracking
Manifest --> Shipment : "0..1"
Tracking --> Vehicle : "1..*"
@enduml