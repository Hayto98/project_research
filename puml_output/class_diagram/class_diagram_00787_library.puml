@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Reservation {
  +String total
  +boolean quantity
  -String description
  #Date id
  +updateCreatedat()
  +updatePrice()
}
abstract class Librarian {
  +float active
  +long description
  +int createdAt
  -boolean address
  +updateDuration()
  +savePhone()
}
class Book {
  -String level
  #double price
  #float address
  #int phone
  +findType()
}
class Catalog {
  +float id
  #float status
  +long level
  +String phone
  #int note
  +processId()
  +getName()
  +validateUpdatedat()
  +cancelStatus()
}
abstract class Loan {
  #float updatedAt
  -double createdAt
  -long description
  +savePhone()
}
class Author {
  #Date code
  -int id
  #String total
  #String price
  +cancelEmail()
}
class Member {
  #String name
  -double description
  +saveAddress()
  +validateName()
}
Loan --> Reservation : "1..*"
Loan --* Book
Catalog ..|> Loan
Author ..|> Loan
Catalog --> Author : "0..1"
Catalog --* Librarian
@enduml