@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Insurance {
  -Date code
  +Date price
  +updateId()
  +saveScore()
  +updateId()
}
class Nurse {
  #long name
  -double note
  +int amount
  +sendLevel()
}
class Treatment {
  #double name
  #long duration
  +sendCode()
  +updateActive()
  +getQuantity()
  +cancelName()
}
abstract class Hospital {
  #String code
  #long score
  +updatePhone()
  +cancelDescription()
}
class Billing {
  #long quantity
  -long phone
  +long updatedAt
  -boolean active
  +validateQuantity()
  +deleteEmail()
}
class Diagnosis {
  -boolean id
  +float duration
  -String total
  +saveLevel()
  +processNote()
  +validateStatus()
}
Treatment --o Nurse
Treatment --o Hospital
Nurse --o Diagnosis
note right of Insurance : Healthcare domain
@enduml