@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Insurance {
  -Date code
  +Date price
  +sendEmail()
  +updatePrice()
  +cancelScore()
}
interface Nurse {
  #int id
  +double description
  +Date active
  +updateLevel()
  +sendName()
  +sendLevel()
}
class Treatment {
  +String name
  +Date score
  -float amount
  +validateName()
  +createUpdatedat()
  +validatePhone()
}
class Hospital {
  +double quantity
  +String level
  +saveUpdatedat()
}
class Billing {
  +long updatedAt
  -long phone
  +boolean description
  +validateAddress()
  +findQuantity()
  +createAddress()
}
class Diagnosis {
  +long duration
  -int createdAt
  +String phone
  #float quantity
  +cancelCreatedat()
  +deleteId()
  +findDescription()
  +setName()
}
Insurance ..> Billing : "1..*"
Diagnosis --o Billing
Hospital --|> Treatment
Nurse ..|> Treatment
@enduml