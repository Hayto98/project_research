@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Group {
  #Date createdAt
  #double phone
  #float type
  #int quantity
  +Date level
  +validateCode()
  +saveType()
  +createActive()
}
interface Story {
  #long code
  +long status
  +int total
  +updateDescription()
}
abstract class Like {
  #float note
  +Date score
  -Date code
  #double total
  -boolean status
  +updateDuration()
  +cancelTotal()
  +calculateQuantity()
}
class Hashtag {
  +long email
  -long level
  +createId()
  +saveEmail()
}
class Notification {
  -boolean score
  +Date phone
  +saveName()
  +createLevel()
  +saveEmail()
  +sendActive()
}
Story ..> Notification : "0..1"
Notification ..|> Hashtag
@enduml