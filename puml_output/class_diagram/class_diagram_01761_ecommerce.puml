@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Payment {
  +float amount
  +boolean email
  #float level
  +long quantity
  -double id
  +findPrice()
  +deleteDescription()
}
class Order {
  +boolean name
  #int phone
  +validateNote()
  +validateId()
}
class Supplier {
  -long status
  -double note
  +validateTotal()
  +getAmount()
}
class Invoice {
  -int email
  #long status
  -Date description
  #String updatedAt
  -long phone
  +findDuration()
  +setId()
  +validateDuration()
  +savePrice()
}
class Coupon {
  #Date description
  #int id
  +boolean status
  +saveAmount()
  +deleteType()
  +createUpdatedat()
}
class Category {
  +String id
  -float email
  +int description
  -boolean status
  -float quantity
  +deleteDescription()
  +findEmail()
}
Order --|> Payment
Payment ..> Order : "0..1"
Category ..> Order : "0..1"
Coupon --o Invoice
Invoice ..> Coupon : "1..*"
@enduml