@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Author {
  #long description
  +String note
  #String name
  +Date total
  -double phone
  +saveNote()
  +cancelType()
  +sendDescription()
}
class Fine {
  -float type
  +Date address
  +setStatus()
  +updateType()
  +saveAddress()
}
interface Publisher {
  #float description
  +float address
  #float score
  -boolean total
  +Date quantity
  +findAmount()
  +cancelName()
  +calculatePhone()
  +updateActive()
}
class Loan {
  +long score
  -boolean price
  #Date quantity
  +updateAddress()
  +saveScore()
}
abstract class Book {
  +Date duration
  #boolean address
  +int code
  -Date email
  +String createdAt
  +getQuantity()
}
interface Renewal {
  -String active
  +boolean total
  +int quantity
  +String level
  +createCode()
  +cancelPrice()
  +sendUpdatedat()
}
interface Catalog {
  +long name
  -long address
  #int note
  +updateAmount()
  +deletePrice()
  +processNote()
}
Renewal --> Fine : "1..*"
Fine ..|> Loan
@enduml