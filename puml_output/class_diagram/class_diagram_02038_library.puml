@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Author {
  #long description
  +String note
  #String name
  +Date total
  -double phone
  +updateAmount()
  +getType()
  +validatePrice()
}
class Fine {
  #float status
  +long amount
  #float level
  #float price
  +createDuration()
  +updateActive()
  +createLevel()
  +getDuration()
}
abstract class Publisher {
  -String quantity
  -long id
  #boolean amount
  #int score
  #long price
  +processDuration()
  +validateCode()
  +createCreatedat()
  +getActive()
}
class Loan {
  #String total
  #boolean amount
  -boolean id
  +saveQuantity()
  +calculateAddress()
  +setStatus()
  +sendCreatedat()
}
class Book {
  #Date status
  #Date email
  #boolean amount
  +getAddress()
  +processAmount()
}
class Renewal {
  #int phone
  #long description
  +double address
  +int note
  -Date status
  +updatePrice()
  +saveCode()
}
class Catalog {
  +double score
  +double status
  #double id
  -double email
  +deleteType()
  +saveTotal()
  +deleteActive()
  +findNote()
}
Book --|> Publisher
Book --* Loan
Book --* Catalog
Publisher ..> Catalog : "1"
Fine ..|> Renewal
note right of Author : Library domain
@enduml