@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Restaurant {
  +String quantity
  +double address
  #float score
  +float email
  +findLevel()
  +sendPhone()
  +createNote()
}
interface Guest {
  #boolean active
  #String code
  #float status
  -float address
  +double id
  +saveDuration()
}
class Amenity {
  +double active
  #String name
  #Date level
  -int updatedAt
  -double score
  +saveType()
  +updateAddress()
  +cancelCreatedat()
}
class CheckIn {
  #float type
  #long amount
  #int level
  -double total
  +int note
  +updatePhone()
  +validateQuantity()
  +updateCode()
  +findPrice()
}
class Room {
  +int createdAt
  #String description
  -boolean type
  +findType()
  +validateCode()
}
class Booking {
  -Date level
  #String code
  +deleteQuantity()
  +calculateId()
  +deleteAddress()
  +getPhone()
}
Amenity --|> Guest
Room --* Guest
note right of Restaurant : Hotel domain
@enduml