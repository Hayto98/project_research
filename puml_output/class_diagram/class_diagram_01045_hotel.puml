@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Restaurant {
  +String quantity
  +double address
  #float score
  +float email
  +sendUpdatedat()
  +saveDuration()
  +calculatePrice()
}
class Guest {
  #boolean note
  #String duration
  -String active
  #boolean code
  +updateId()
}
abstract class Amenity {
  -float note
  #String id
  #Date quantity
  +validateNote()
}
class CheckIn {
  +boolean note
  #double active
  +validateDuration()
  +cancelCode()
}
interface Room {
  +double type
  -float updatedAt
  #int address
  +double createdAt
  +validatePrice()
  +createId()
  +updateScore()
  +getNote()
}
class Booking {
  -long note
  #long name
  +String description
  #double total
  -boolean updatedAt
  +sendEmail()
  +getEmail()
}
Restaurant ..> Guest : "1"
Amenity ..|> Room
Booking --* CheckIn
Booking ..|> Restaurant
Restaurant --|> Room
@enduml