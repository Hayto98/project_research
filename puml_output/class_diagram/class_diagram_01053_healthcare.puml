@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
abstract class Appointment {
  #boolean description
  +float code
  #long total
  #String name
  +getPrice()
  +createTotal()
}
class Hospital {
  #boolean id
  -float name
  +float score
  -boolean status
  -int note
  +findCode()
  +saveDescription()
  +saveAddress()
}
abstract class Billing {
  +String duration
  #float type
  +saveType()
  +sendStatus()
  +deleteTotal()
  +setDuration()
}
class Insurance {
  +long code
  +Date id
  #int note
  +float total
  +updateDescription()
}
class Treatment {
  +Date address
  -String duration
  -long score
  -Date amount
  -double price
  +deleteLevel()
  +validatePrice()
}
class Prescription {
  -boolean duration
  -float total
  +sendLevel()
  +cancelPrice()
}
class MedicalRecord {
  -int createdAt
  +boolean price
  +int duration
  -int quantity
  +saveQuantity()
  +saveEmail()
}
Billing --|> Treatment
Appointment --> MedicalRecord : "*"
Billing --o Appointment
Appointment --> Insurance : "1"
MedicalRecord --> Appointment : "0..1"
@enduml