@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Prescription {
  +float amount
  #long type
  -Date description
  #Date code
  +sendCreatedat()
  +deleteType()
  +updateStatus()
  +saveCode()
}
interface Billing {
  #int score
  +boolean phone
  -int price
  -boolean amount
  +validateCreatedat()
  +validateAmount()
  +updateId()
  +calculateActive()
}
class Diagnosis {
  #boolean phone
  +boolean amount
  +processDuration()
}
abstract class Nurse {
  #long createdAt
  +String code
  #long status
  +long name
  +processCode()
  +saveUpdatedat()
  +createAmount()
  +getDuration()
}
abstract class MedicalRecord {
  +String email
  +Date phone
  -float amount
  +getQuantity()
  +calculateCode()
  +updateScore()
}
Nurse ..> Prescription : "*"
Billing --> Diagnosis : "*"
Billing --> MedicalRecord : "0..1"
@enduml