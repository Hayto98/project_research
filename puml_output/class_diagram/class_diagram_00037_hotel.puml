@startuml
skinparam monochrome true
interface Service {
  +String createdAt
  -Date email
  +validateScore()
  +processPhone()
}
class CheckOut {
  +Date code
  -boolean amount
  +setType()
  +updateLevel()
}
interface Booking {
  -long price
  -double createdAt
  #double name
  +sendType()
}
interface Room {
  -int type
  +long price
  -long quantity
  -float score
  +cancelName()
}
class Staff {
  #long email
  #Date createdAt
  #int name
  +processAddress()
  +cancelCode()
  +getLevel()
}
interface Restaurant {
  #int phone
  -long price
  +deleteQuantity()
}
abstract class CheckIn {
  +long updatedAt
  +int score
  -long price
  #double level
  +savePhone()
  +processNote()
  +setId()
  +setId()
}
Room ..|> Restaurant
Service --|> CheckIn
note right of Service : Hotel domain
@enduml