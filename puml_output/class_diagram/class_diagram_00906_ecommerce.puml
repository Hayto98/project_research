@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
interface Product {
  -boolean id
  +long type
  +savePrice()
}
abstract class Wishlist {
  +int total
  +double address
  -String active
  #long name
  +double score
  +savePrice()
  +getPrice()
  +sendDuration()
}
interface Review {
  -int type
  -float amount
  -double quantity
  +deleteStatus()
  +sendAmount()
  +validateScore()
  +getCreatedat()
}
class Customer {
  -int price
  +float description
  -double updatedAt
  +saveName()
  +getEmail()
}
class Order {
  #double email
  -String active
  -Date score
  -double total
  +calculateAddress()
  +cancelAmount()
  +deleteCode()
}
abstract class Payment {
  -double email
  -double amount
  +getScore()
  +saveTotal()
  +calculateEmail()
  +updateAmount()
}
Customer --> Review : "1"
Order ..|> Review
Review --* Product
Customer ..> Payment : "1"
@enduml