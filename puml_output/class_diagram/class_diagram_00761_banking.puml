@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
abstract class Account {
  +double total
  -long createdAt
  +boolean duration
  +float price
  +cancelEmail()
}
class Branch {
  -long id
  +boolean address
  #String updatedAt
  +double phone
  +updateEmail()
  +deleteUpdatedat()
  +createPhone()
}
abstract class Interest {
  -double active
  +float type
  #boolean phone
  +String status
  +getName()
  +updateTotal()
  +cancelTotal()
}
class Withdrawal {
  +boolean active
  +long level
  -String note
  +processStatus()
  +updateQuantity()
  +savePrice()
  +setType()
}
class Customer {
  +Date active
  #String id
  #float amount
  #Date quantity
  +getQuantity()
}
class Deposit {
  -long amount
  -double level
  +calculateEmail()
  +deleteUpdatedat()
  +sendDuration()
}
Interest --o Customer
Branch --|> Deposit
Withdrawal ..> Account : "1..*"
Deposit --> Customer : "*"
@enduml