@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Inventory {
  #double quantity
  +String updatedAt
  +Date phone
  -boolean email
  +findQuantity()
  +setAmount()
}
class Tracking {
  -float score
  #Date name
  -Date type
  +long note
  #float updatedAt
  +setAddress()
}
interface Customer {
  -long code
  -double createdAt
  -Date note
  #float address
  +calculateType()
}
abstract class DeliveryNote {
  +String createdAt
  #int name
  -int active
  +validatePrice()
  +sendTotal()
}
class Depot {
  +double price
  +long name
  #double active
  +cancelType()
}
Depot --> DeliveryNote : "*"
Customer --* DeliveryNote
note right of Inventory : Logistics domain
@enduml