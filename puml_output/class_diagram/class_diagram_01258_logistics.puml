@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Inventory {
  #double quantity
  +String updatedAt
  +Date phone
  -boolean email
  +getActive()
  +getNote()
}
class Tracking {
  +double quantity
  -int total
  -float score
  +updateScore()
  +calculateNote()
  +findCode()
}
interface Customer {
  #long code
  #Date address
  +cancelNote()
}
abstract class DeliveryNote {
  -Date total
  #float email
  #Date price
  #boolean type
  +sendScore()
}
abstract class Depot {
  +Date amount
  +long createdAt
  +int name
  -double active
  #double level
  +cancelType()
}
DeliveryNote --> Inventory : "0..1"
DeliveryNote --* Tracking
@enduml