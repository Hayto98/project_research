@startuml
skinparam shadowing true
abstract class Publisher {
  -Date email
  #double total
  +double score
  #long id
  +float description
  +updateNote()
  +calculateLevel()
  +validateName()
  +calculateQuantity()
}
class Fine {
  -float code
  #Date email
  #float active
  #float quantity
  -boolean score
  +getCode()
  +cancelActive()
}
interface Member {
  +Date id
  +boolean code
  +float address
  +cancelId()
}
interface Reservation {
  #String price
  #int quantity
  +deleteScore()
}
class Branch {
  -double type
  -int duration
  #String quantity
  +calculateTotal()
  +saveId()
  +getDuration()
  +calculateQuantity()
}
Reservation --|> Fine
Reservation ..|> Branch
Reservation --> Member : "1..*"
@enduml