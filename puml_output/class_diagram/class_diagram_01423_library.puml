@startuml
skinparam shadowing true
abstract class Publisher {
  -Date email
  #double total
  +double score
  #long id
  +float description
  +sendType()
  +calculateCode()
  +processCode()
  +createActive()
}
class Fine {
  +boolean type
  #boolean active
  +Date total
  +String level
  +deleteUpdatedat()
  +cancelName()
  +getPhone()
}
interface Member {
  #String price
  #int quantity
  +deletePhone()
}
class Reservation {
  +Date type
  +double quantity
  +float email
  -boolean total
  -int score
  +calculateTotal()
}
class Branch {
  -String description
  +String total
  -boolean phone
  +Date active
  -Date score
  +setEmail()
}
Member --|> Branch
Branch ..|> Member
note right of Publisher : Library domain
@enduml