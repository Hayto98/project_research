@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
abstract class Renewal {
  #double amount
  +Date name
  -float address
  #int type
  +savePrice()
  +deleteDuration()
}
class Catalog {
  -double code
  #float createdAt
  +String id
  +createQuantity()
}
abstract class Author {
  #boolean note
  #float name
  #double description
  +sendAmount()
  +calculateCode()
  +getNote()
}
abstract class Librarian {
  #long total
  -float amount
  #long note
  +getLevel()
  +deleteQuantity()
  +findPrice()
}
interface Shelf {
  #boolean name
  #int updatedAt
  +String active
  -float score
  +double code
  +findAmount()
  +cancelActive()
  +updateLevel()
  +sendName()
}
abstract class Member {
  -long level
  -long active
  +findDuration()
  +findStatus()
  +processPrice()
}
class Book {
  #Date code
  +String amount
  #String level
  +saveAmount()
}
Renewal --o Author
Renewal --|> Librarian
Book --|> Catalog
Renewal --* Member
Catalog --|> Librarian
Catalog ..|> Author
@enduml