@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
abstract class Renewal {
  #double amount
  +Date name
  -float address
  #int type
  +cancelNote()
  +validateCreatedat()
}
class Catalog {
  #float id
  +String address
  +long total
  +cancelUpdatedat()
  +processName()
  +deleteScore()
  +cancelActive()
}
abstract class Author {
  +double score
  +double price
  #long quantity
  -float level
  +createCode()
  +setActive()
  +cancelNote()
}
class Librarian {
  +Date level
  #boolean active
  +String duration
  +validateStatus()
}
abstract class Shelf {
  +boolean total
  #boolean level
  -long quantity
  -long type
  -boolean note
  +validateDescription()
  +setAmount()
}
class Member {
  +String id
  -float score
  +createPrice()
}
class Book {
  +double id
  +int createdAt
  -float code
  +double score
  +float phone
  +setType()
  +validatePhone()
  +getAmount()
}
Shelf ..|> Member
Catalog ..> Member : "1..*"
Member --> Renewal : "1..*"
Member --> Catalog : "0..1"
note right of Renewal : Library domain
@enduml