@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Shelf {
  #String name
  -Date description
  +calculateStatus()
}
class Branch {
  -int type
  #double address
  +boolean name
  +saveQuantity()
}
class Author {
  #double createdAt
  #boolean note
  +deleteDuration()
  +sendName()
  +calculatePhone()
}
class Renewal {
  -Date type
  +int description
  +float price
  +long phone
  +deleteAddress()
  +saveStatus()
  +deleteActive()
}
class Loan {
  +double score
  -boolean createdAt
  +Date quantity
  +String total
  +saveNote()
}
Shelf --> Loan : "1"
Renewal --o Shelf
Loan ..> Renewal : "*"
note right of Shelf : Library domain
@enduml