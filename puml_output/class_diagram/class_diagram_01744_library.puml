@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Shelf {
  #String name
  -Date description
  +processType()
}
class Branch {
  -int description
  #double type
  +boolean address
  #boolean name
  +sendLevel()
}
class Author {
  #double name
  #boolean createdAt
  -int note
  +getPhone()
}
class Renewal {
  -float score
  -long phone
  #int type
  +int description
  +deleteCreatedat()
  +updateTotal()
}
class Loan {
  #boolean status
  #Date description
  #long active
  #float email
  +setPhone()
  +processDescription()
}
Shelf --* Renewal
Loan ..> Branch : "1"
Shelf ..> Loan : "*"
@enduml