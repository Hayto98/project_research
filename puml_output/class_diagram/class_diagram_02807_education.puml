@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
interface Grade {
  #long createdAt
  #float id
  -Date type
  +boolean score
  #String email
  +updateAmount()
}
interface Course {
  #Date type
  #String id
  +cancelUpdatedat()
  +deleteLevel()
  +updateAddress()
  +calculateAddress()
}
abstract class Department {
  +Date status
  +boolean score
  #long email
  +int code
  -int createdAt
  +updateNote()
  +setCreatedat()
  +calculateDescription()
}
class Library {
  #int amount
  +int quantity
  +String address
  #int createdAt
  +getPhone()
  +saveUpdatedat()
  +createQuantity()
  +cancelScore()
}
Department --|> Grade
Library ..> Course : "0..1"
@enduml