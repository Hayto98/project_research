@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
interface Grade {
  #long createdAt
  #float id
  -Date type
  +boolean score
  #String email
  +sendDuration()
}
interface Course {
  #Date type
  #String id
  +findAmount()
  +processTotal()
  +setScore()
  +saveEmail()
}
class Department {
  #long updatedAt
  +int code
  -int active
  +sendAmount()
  +validateAmount()
  +saveQuantity()
}
class Library {
  +String description
  #int createdAt
  -double level
  +saveTotal()
  +createId()
  +setPhone()
}
Library ..> Course : "0..1"
Library --> Department : "0..1"
note right of Grade : Education domain
@enduml