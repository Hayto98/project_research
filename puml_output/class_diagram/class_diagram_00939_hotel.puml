@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Housekeeping {
  +String email
  -boolean price
  #double quantity
  +processTotal()
  +updateUpdatedat()
  +processQuantity()
}
class Invoice {
  -String price
  -long total
  +float type
  +boolean quantity
  +createActive()
}
class Booking {
  -boolean type
  #Date price
  +sendPhone()
  +cancelEmail()
  +updateStatus()
}
class Amenity {
  #double note
  #Date phone
  -String status
  -String price
  +getDescription()
}
class CheckOut {
  -long amount
  +String type
  #Date id
  -boolean email
  +float code
  +calculateAddress()
}
class Reservation {
  +int phone
  -Date address
  #double updatedAt
  +double amount
  +savePhone()
}
Booking --o Amenity
Reservation --|> CheckOut
CheckOut ..|> Reservation
Reservation --* Booking
@enduml