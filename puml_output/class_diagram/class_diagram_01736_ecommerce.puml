@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
abstract class Order {
  #Date quantity
  #String phone
  -long active
  #double address
  +boolean level
  +updatePhone()
  +createCreatedat()
  +validateAmount()
  +processId()
}
abstract class Shipment {
  -boolean name
  -float address
  +deleteUpdatedat()
  +validateType()
  +validateId()
}
class Customer {
  +int address
  -double updatedAt
  #double code
  +sendActive()
  +calculateCode()
  +validateDescription()
  +calculateLevel()
}
class Return {
  #float name
  #double note
  +float active
  +sendDescription()
  +findCreatedat()
}
class Payment {
  #String address
  +double status
  +float code
  -Date quantity
  +float level
  +saveCreatedat()
  +createAddress()
}
abstract class Category {
  -double duration
  -Date updatedAt
  #Date phone
  +getName()
  +calculateAddress()
}
abstract class Review {
  #String quantity
  -int total
  +float score
  +findDuration()
  +deleteCode()
  +setId()
}
Shipment --* Order
Return --> Order : "0..1"
Category ..|> Return
note right of Order : Ecommerce domain
@enduml