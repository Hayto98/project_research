@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
abstract class Order {
  #Date quantity
  #String phone
  -long active
  #double address
  +boolean level
  +validateNote()
  +updateId()
  +deleteCode()
  +updateLevel()
}
class Shipment {
  +String amount
  -float type
  -boolean id
  -float level
  +validateQuantity()
  +processDuration()
  +updateTotal()
}
abstract class Customer {
  -Date id
  #int status
  #String active
  +int amount
  +processType()
  +createType()
  +saveName()
}
abstract class Return {
  #int code
  +double phone
  #boolean description
  #double price
  +float quantity
  +calculatePrice()
  +validateCode()
}
class Payment {
  +boolean total
  -String address
  #String status
  +sendName()
}
class Category {
  -double code
  +boolean updatedAt
  +long createdAt
  -double email
  +saveDescription()
  +cancelUpdatedat()
  +validatePrice()
  +saveType()
}
class Review {
  -double name
  +long price
  +updateAmount()
  +processEmail()
  +calculateDuration()
  +getQuantity()
}
Return ..|> Shipment
Review ..> Customer : "0..1"
@enduml