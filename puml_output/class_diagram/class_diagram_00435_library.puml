@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
interface Shelf {
  #float email
  -boolean quantity
  +double description
  +double active
  +updatePhone()
  +updateName()
  +getActive()
}
class Branch {
  +Date updatedAt
  +Date score
  +saveScore()
  +validateDescription()
  +saveStatus()
  +saveEmail()
}
abstract class Librarian {
  #float duration
  #long level
  +boolean address
  #double phone
  -float note
  +setActive()
}
class Reservation {
  #String amount
  -int price
  +boolean code
  +double total
  +String updatedAt
  +sendQuantity()
  +findPhone()
  +updateQuantity()
}
Reservation --|> Branch
Branch ..|> Reservation
note right of Shelf : Library domain
@enduml