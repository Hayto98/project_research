@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
interface Shelf {
  #float email
  -boolean quantity
  +double description
  +double active
  +cancelNote()
  +deletePhone()
  +cancelScore()
}
class Branch {
  -Date name
  #String id
  +boolean active
  +cancelUpdatedat()
  +setName()
}
abstract class Librarian {
  -boolean description
  #long status
  #long email
  -boolean note
  +validateCode()
  +setPhone()
  +saveDescription()
}
abstract class Reservation {
  #Date status
  #double code
  +double active
  +double id
  +getQuantity()
  +processQuantity()
}
Branch --> Shelf : "0..1"
Reservation --|> Shelf
Librarian --* Reservation
@enduml