@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
interface CheckIn {
  #boolean amount
  -int name
  +saveCreatedat()
  +createActive()
}
interface Service {
  -long id
  -String updatedAt
  -int quantity
  #double duration
  -Date note
  +sendDescription()
  +calculateTotal()
  +setStatus()
  +setAddress()
}
class Amenity {
  +String updatedAt
  +boolean email
  +int quantity
  #float id
  #double address
  +calculateLevel()
  +cancelPrice()
}
class Invoice {
  #Date email
  -Date description
  -String amount
  #double updatedAt
  #long duration
  +findPrice()
  +calculateAddress()
  +deletePhone()
  +findDuration()
}
class Guest {
  +Date phone
  -Date email
  #double level
  +getPhone()
  +sendType()
  +updateName()
  +saveTotal()
}
Invoice --> Service : "*"
Amenity --|> CheckIn
note right of CheckIn : Hotel domain
@enduml