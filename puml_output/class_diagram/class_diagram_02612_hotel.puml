@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
interface CheckIn {
  #boolean amount
  -int name
  +setScore()
  +getTotal()
}
class Service {
  -long id
  -String updatedAt
  -int quantity
  #double duration
  -Date note
  +saveActive()
  +createNote()
  +deleteId()
  +setCreatedat()
}
class Amenity {
  #String total
  -int status
  #long level
  #Date score
  -String address
  +sendId()
  +setStatus()
  +saveNote()
}
interface Invoice {
  -Date createdAt
  #boolean total
  #double updatedAt
  +createNote()
  +deleteDuration()
}
class Guest {
  #Date amount
  -Date updatedAt
  -String email
  +createStatus()
  +calculateCreatedat()
  +saveCode()
  +cancelName()
}
Invoice ..|> Amenity
Amenity ..> Service : "0..1"
Amenity ..> Guest : "1..*"
@enduml