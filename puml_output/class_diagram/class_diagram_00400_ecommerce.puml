@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Customer {
  -float description
  +Date amount
  #long total
  +int updatedAt
  #long createdAt
  +saveAddress()
  +saveActive()
  +sendNote()
  +createNote()
}
interface Product {
  +long duration
  -long type
  #float address
  #Date price
  +deleteLevel()
  +deleteStatus()
}
class Supplier {
  -Date createdAt
  #Date type
  +long code
  -String price
  +sendId()
  +sendDescription()
}
interface Invoice {
  +long quantity
  #long name
  +validateCreatedat()
  +setCode()
  +calculateQuantity()
  +getPrice()
}
abstract class Wishlist {
  -long active
  -String status
  +String phone
  -String price
  +processPrice()
  +setCreatedat()
}
class Category {
  #long score
  -double code
  +processAddress()
  +getCreatedat()
  +updateTotal()
}
Supplier --> Category : "1"
Customer --|> Product
@enduml