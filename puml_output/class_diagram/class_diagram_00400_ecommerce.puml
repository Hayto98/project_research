@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Customer {
  -float description
  +Date amount
  #long total
  +int updatedAt
  #long createdAt
  +deleteScore()
  +updateLevel()
  +createDuration()
  +cancelType()
}
class Product {
  #long name
  -int phone
  -String quantity
  -long level
  #Date updatedAt
  +validateEmail()
  +getDuration()
}
class Supplier {
  #boolean score
  +String status
  -float quantity
  +savePrice()
  +deleteTotal()
  +calculatePhone()
}
interface Invoice {
  -long phone
  -String price
  +setNote()
  +setCreatedat()
}
class Wishlist {
  +Date code
  -float score
  +calculateAddress()
  +sendPhone()
  +saveName()
  +createQuantity()
}
interface Category {
  +float id
  #float createdAt
  +saveCreatedat()
  +updateAddress()
}
Wishlist ..> Invoice : "1..*"
Product ..> Invoice : "*"
Category --o Invoice
Product --> Category : "*"
note right of Customer : Ecommerce domain
@enduml