@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class MedicalRecord {
  #boolean score
  -long quantity
  #String status
  -int amount
  +double createdAt
  +processDuration()
  +setCreatedat()
  +getLevel()
  +processPhone()
}
class Doctor {
  +Date email
  -int createdAt
  +long status
  +int active
  +updateName()
  +validateEmail()
  +saveEmail()
  +createLevel()
}
class Ward {
  +float score
  +int active
  #double status
  +calculateEmail()
  +cancelAddress()
}
abstract class Insurance {
  -boolean address
  +long active
  -Date note
  +double email
  +setQuantity()
  +getScore()
  +deletePrice()
  +setNote()
}
class Hospital {
  -float level
  +int description
  +findAddress()
  +deleteActive()
}
class Patient {
  #float duration
  +float description
  +processLevel()
  +findCreatedat()
}
Hospital ..|> MedicalRecord
Doctor --o Patient
MedicalRecord --|> Doctor
note right of MedicalRecord : Healthcare domain
@enduml