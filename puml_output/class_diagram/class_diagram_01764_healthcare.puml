@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class MedicalRecord {
  #boolean score
  -long quantity
  #String status
  -int amount
  +double createdAt
  +processAddress()
  +deletePhone()
  +deleteDuration()
  +deleteType()
}
interface Doctor {
  #double createdAt
  -int id
  +calculateUpdatedat()
  +findEmail()
  +deleteCreatedat()
}
class Ward {
  #float active
  -int amount
  +validateLevel()
  +calculatePhone()
}
class Insurance {
  -long note
  #long updatedAt
  -Date name
  +sendType()
}
class Hospital {
  +Date description
  -int code
  +deleteCreatedat()
  +getCode()
  +validateLevel()
  +saveCreatedat()
}
abstract class Patient {
  -boolean address
  +long active
  -Date note
  +double email
  +getLevel()
  +cancelAddress()
  +updatePrice()
  +saveActive()
}
Insurance --o MedicalRecord
Ward --> MedicalRecord : "0..1"
Ward ..|> Doctor
@enduml