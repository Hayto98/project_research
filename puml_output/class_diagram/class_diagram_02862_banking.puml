@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Branch {
  -boolean total
  #double address
  -int code
  +String level
  -float name
  +calculateActive()
  +findCode()
}
interface Loan {
  #boolean total
  -String phone
  -long price
  +Date quantity
  +double name
  +createDescription()
  +setEmail()
  +createActive()
  +sendAmount()
}
class Deposit {
  -long amount
  +double score
  +int status
  +calculateType()
}
class Account {
  #long id
  -long phone
  #double note
  -long name
  +setNote()
  +setName()
}
Branch --o Loan
Account --* Deposit
note right of Branch : Banking domain
@enduml