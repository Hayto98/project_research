@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
abstract class Cart {
  +String status
  +double email
  #int active
  +Date address
  +deleteTotal()
  +saveNote()
  +findStatus()
}
class Return {
  #long createdAt
  -int phone
  #int name
  -Date active
  +cancelId()
  +validateUpdatedat()
  +setAddress()
  +saveEmail()
}
interface Order {
  #int status
  +boolean score
  +createName()
}
interface Coupon {
  +long note
  +long updatedAt
  #boolean total
  -boolean createdAt
  +sendUpdatedat()
  +updateName()
}
class Warehouse {
  -Date address
  +float score
  +double note
  +deleteUpdatedat()
  +processLevel()
  +createPhone()
  +deleteCreatedat()
}
class Supplier {
  #float total
  -String quantity
  #float price
  -double level
  -int name
  +saveCreatedat()
  +cancelQuantity()
  +deletePhone()
  +deleteAmount()
}
class Customer {
  #int email
  #double level
  #Date note
  #long total
  +calculatePrice()
}
Coupon --> Order : "1..*"
Return --o Order
@enduml