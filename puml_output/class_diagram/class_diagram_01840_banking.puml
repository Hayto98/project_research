@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Statement {
  #float address
  -boolean phone
  -Date description
  +long active
  +Date amount
  +createAddress()
}
class Interest {
  -Date active
  -String address
  +double type
  +updateCreatedat()
  +validateDescription()
  +sendId()
}
class Card {
  -float level
  -int total
  -int name
  +validateAmount()
  +processLevel()
  +getUpdatedat()
  +sendActive()
}
class Teller {
  -int level
  #int duration
  +createNote()
  +findCreatedat()
}
class Branch {
  -long createdAt
  #Date type
  +sendNote()
  +getId()
  +updateDuration()
}
class Loan {
  #Date id
  #float code
  #float description
  +saveNote()
  +sendType()
  +calculatePhone()
}
class Deposit {
  -double amount
  -boolean active
  +findAmount()
  +cancelNote()
  +getCode()
  +getStatus()
}
Interest --|> Teller
Statement --|> Deposit
Teller --* Loan
Loan --* Branch
Teller --o Card
Statement --> Branch : "*"
@enduml