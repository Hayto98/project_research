@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Statement {
  #float address
  -boolean phone
  -Date description
  +long active
  +Date amount
  +setDescription()
}
class Interest {
  +String level
  -Date type
  -float email
  +String phone
  +saveLevel()
  +saveTotal()
}
class Card {
  -double address
  #String description
  +boolean type
  #long createdAt
  +boolean score
  +cancelUpdatedat()
  +createQuantity()
}
interface Teller {
  -long createdAt
  #Date type
  +updateType()
  +getUpdatedat()
  +findCreatedat()
}
class Branch {
  #Date description
  #float score
  +updateQuantity()
  +validateStatus()
  +deleteActive()
}
abstract class Loan {
  #Date phone
  #int score
  -String type
  +String total
  +double createdAt
  +saveLevel()
  +createTotal()
  +createType()
}
class Deposit {
  #boolean total
  #boolean name
  #String amount
  #boolean duration
  +String code
  +sendScore()
  +validateAddress()
  +saveCode()
  +calculateId()
}
Interest --|> Loan
Card --o Branch
note right of Statement : Banking domain
@enduml