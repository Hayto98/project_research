@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Attendance {
  -long status
  +double email
  +int type
  +sendEmail()
  +findNote()
}
interface Course {
  #double address
  +float amount
  +long updatedAt
  #double phone
  +createEmail()
  +saveActive()
}
interface Teacher {
  -long duration
  -long amount
  -long score
  +calculateUpdatedat()
  +deleteDuration()
  +setCreatedat()
  +sendCreatedat()
}
class Assignment {
  +String description
  #Date code
  +setDuration()
  +sendType()
  +updateCreatedat()
  +findAddress()
}
class Enrollment {
  #float status
  +long address
  +double phone
  +createAddress()
}
abstract class Department {
  #double note
  +String createdAt
  -boolean updatedAt
  #int active
  +int phone
  +getNote()
}
Department --* Teacher
Course --* Teacher
Department ..|> Enrollment
Enrollment ..> Attendance : "1"
Teacher --|> Course
@enduml