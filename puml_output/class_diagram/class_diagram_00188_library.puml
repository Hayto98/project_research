@startuml
skinparam monochrome true
class Renewal {
  +float duration
  +double note
  -int amount
  +String address
  +Date description
  +setName()
  +getScore()
  +validateScore()
}
class Catalog {
  +float price
  #long level
  +createType()
  +calculateTotal()
}
interface Publisher {
  +Date note
  -int address
  +String price
  +int total
  +setStatus()
}
class Author {
  #String createdAt
  -Date amount
  #double address
  -boolean phone
  +processName()
  +findTotal()
  +validateDuration()
  +findUpdatedat()
}
class Shelf {
  #double total
  -Date price
  #boolean active
  +calculateType()
  +processCreatedat()
  +setPrice()
}
class Librarian {
  #int note
  +boolean code
  +long score
  #boolean createdAt
  -double description
  +calculateCreatedat()
  +updateName()
  +cancelTotal()
}
interface Reservation {
  -Date duration
  +int type
  +savePhone()
  +saveScore()
  +getPrice()
  +validateScore()
}
Catalog --* Shelf
Renewal --* Author
@enduml