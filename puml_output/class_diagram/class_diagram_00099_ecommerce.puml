@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Category {
  +String amount
  -String active
  #long name
  +sendNote()
  +sendEmail()
}
abstract class Wishlist {
  +Date code
  -int level
  +float createdAt
  +cancelLevel()
}
class Supplier {
  #float name
  +boolean level
  #boolean createdAt
  #float description
  +setId()
  +getPhone()
  +processPhone()
}
class Review {
  +int description
  -float createdAt
  +long address
  #int active
  -float note
  +validateAmount()
  +getType()
}
abstract class Shipment {
  +long price
  +String createdAt
  +findCode()
  +createName()
  +setType()
  +findNote()
}
class Customer {
  #String active
  #double id
  #double quantity
  +validateAddress()
  +processCode()
}
Shipment --* Wishlist
Customer ..> Category : "1..*"
Shipment --* Category
Customer --|> Wishlist
@enduml