@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
abstract class Notification {
  +float level
  #boolean name
  -double active
  +processLevel()
}
class Report {
  #String address
  +boolean name
  -boolean active
  +double price
  +setNote()
  +findDuration()
  +getName()
  +findActive()
}
interface Follower {
  +float id
  #String createdAt
  -boolean type
  -String address
  #String description
  +validatePhone()
  +validateAmount()
  +sendPhone()
  +validateAmount()
}
class Hashtag {
  #String name
  #double amount
  +String createdAt
  -float score
  +findQuantity()
  +sendLevel()
}
class Group {
  #double active
  -int amount
  +calculateName()
  +calculateType()
  +setId()
}
interface User {
  +float address
  +float active
  -boolean code
  +double name
  +cancelEmail()
  +findCode()
  +sendNote()
}
interface Message {
  +double price
  #double updatedAt
  #String level
  +validateId()
  +getUpdatedat()
  +calculateCode()
}
Report --> Hashtag : "1"
Report --* Follower
Notification --* Message
Hashtag --|> Group
note right of Notification : Social Media domain
@enduml