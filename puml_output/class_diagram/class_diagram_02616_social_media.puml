@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
abstract class Notification {
  +float level
  #boolean name
  -double active
  +validateUpdatedat()
}
interface Report {
  +Date quantity
  #double address
  +calculateEmail()
}
interface Follower {
  +float active
  -Date code
  #boolean total
  +String note
  +updateActive()
  +createEmail()
  +getTotal()
  +findActive()
}
class Hashtag {
  #long status
  +Date name
  +double total
  +updateTotal()
  +processStatus()
  +validateQuantity()
}
interface Group {
  +int phone
  +int amount
  #String level
  #double address
  +processName()
}
class User {
  +float quantity
  #Date score
  #int address
  +findScore()
  +validateCreatedat()
  +calculateDescription()
  +setTotal()
}
abstract class Message {
  +String price
  #long type
  +findDuration()
  +setScore()
  +updateCode()
}
Notification --|> Group
Report --o Message
Group --o Report
Follower --* Group
User --> Notification : "*"
User ..|> Group
@enduml