@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class CheckOut {
  #String status
  #boolean phone
  #double duration
  #Date code
  -boolean type
  +cancelStatus()
  +validateType()
  +processId()
}
class Reservation {
  #boolean price
  #Date amount
  +double email
  #float type
  +processTotal()
  +createActive()
}
interface Amenity {
  +String description
  +int score
  -double active
  +calculateDescription()
}
class Payment {
  -long price
  -boolean id
  +sendAmount()
}
class Service {
  +String id
  -long type
  -String createdAt
  +sendEmail()
  +createAmount()
}
Reservation ..> CheckOut : "0..1"
Reservation --> Payment : "1..*"
CheckOut ..|> Service
Amenity ..|> Service
@enduml