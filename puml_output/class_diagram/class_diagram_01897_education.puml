@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Enrollment {
  -double duration
  #double name
  -String price
  +getAddress()
  +getCode()
}
interface Grade {
  -long description
  #Date level
  #double active
  -int code
  +processPrice()
  +createId()
  +deleteCode()
}
abstract class Library {
  -float email
  +double status
  +int price
  #float phone
  -double type
  +sendCreatedat()
  +sendStatus()
  +processAddress()
}
class Department {
  -int price
  +int name
  +float note
  -long amount
  +setTotal()
  +validatePhone()
}
Enrollment ..|> Library
Enrollment --> Grade : "1"
note right of Enrollment : Education domain
@enduml