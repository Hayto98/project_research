@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Course {
  +boolean level
  -float amount
  +setActive()
  +calculateQuantity()
  +setCode()
  +savePrice()
}
class Book {
  +Date price
  -boolean description
  #Date note
  +double duration
  +saveNote()
  +deleteScore()
  +updateDuration()
}
class Library {
  -long type
  -long quantity
  -int price
  +int description
  #float updatedAt
  +saveType()
  +processName()
  +getPhone()
}
class Exam {
  +boolean id
  #String createdAt
  -int amount
  #String active
  #int address
  +updateLevel()
  +updateActive()
  +processActive()
  +cancelTotal()
}
abstract class Schedule {
  -String email
  +Date amount
  -double duration
  #int level
  +setId()
  +createQuantity()
  +deleteLevel()
}
class Classroom {
  #float name
  #Date active
  -double price
  +sendLevel()
  +cancelLevel()
  +processActive()
  +createType()
}
Classroom --o Library
Course --> Library : "1..*"
@enduml