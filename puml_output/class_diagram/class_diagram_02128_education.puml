@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Course {
  +boolean level
  -float amount
  +calculateLevel()
  +getQuantity()
  +calculateDescription()
  +processPrice()
}
class Book {
  +int level
  +String duration
  #double code
  -long note
  -Date email
  +updatePhone()
  +validateEmail()
}
class Library {
  -long updatedAt
  -String duration
  +boolean level
  #Date email
  +boolean id
  +deleteDuration()
  +findId()
  +processDescription()
}
interface Exam {
  #float active
  #Date createdAt
  +createId()
  +updateId()
  +processQuantity()
  +findEmail()
}
class Schedule {
  #double amount
  -boolean phone
  +long status
  #long updatedAt
  +deleteName()
}
interface Classroom {
  #float duration
  +Date quantity
  -double type
  #long score
  +long createdAt
  +createEmail()
  +calculatePrice()
  +deleteId()
}
Book --|> Classroom
Library ..> Schedule : "0..1"
Exam --o Schedule
Classroom ..|> Course
note right of Course : Education domain
@enduml