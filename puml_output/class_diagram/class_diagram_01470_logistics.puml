@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Manifest {
  +long status
  +String phone
  +getName()
  +sendDuration()
  +findAmount()
  +validateStatus()
}
class Inventory {
  #double email
  #boolean createdAt
  +cancelName()
}
class Driver {
  -int createdAt
  -boolean phone
  -boolean id
  -String price
  +createStatus()
  +validateDuration()
}
class Depot {
  -double price
  -boolean duration
  -boolean name
  +getId()
  +updatePrice()
  +saveDuration()
}
class Tracking {
  -double total
  +int level
  -String note
  #long updatedAt
  -int address
  +processEmail()
  +cancelLevel()
}
class Route {
  -float name
  +long status
  +saveQuantity()
  +findAmount()
  +cancelDescription()
}
Manifest ..|> Tracking
Inventory ..|> Depot
note right of Manifest : Logistics domain
@enduml