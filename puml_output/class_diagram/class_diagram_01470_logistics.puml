@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Manifest {
  +long status
  +String phone
  +updateDuration()
  +saveEmail()
  +getUpdatedat()
  +setAddress()
}
interface Inventory {
  #String phone
  #long status
  +Date email
  +sendStatus()
  +saveUpdatedat()
  +calculateActive()
  +cancelScore()
}
class Driver {
  +long createdAt
  +double address
  +validateNote()
  +calculateCreatedat()
  +sendQuantity()
}
abstract class Depot {
  -boolean id
  #String description
  +Date email
  -boolean status
  +processNote()
  +deleteNote()
  +sendPhone()
  +createName()
}
class Tracking {
  +double duration
  #boolean score
  +double phone
  -boolean id
  -int active
  +deleteCreatedat()
  +createDuration()
  +saveId()
}
class Route {
  +double status
  -float phone
  #boolean address
  +Date amount
  +processQuantity()
}
Driver --* Inventory
Driver ..> Route : "0..1"
@enduml