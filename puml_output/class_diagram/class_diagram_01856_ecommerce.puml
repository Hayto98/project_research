@startuml
skinparam monochrome true
skinparam shadowing true
abstract class Return {
  +boolean description
  -double active
  +float type
  #float address
  -long level
  +validateName()
}
class Product {
  #boolean level
  #Date note
  +saveNote()
  +createActive()
}
class Shipment {
  #float address
  #boolean createdAt
  #float name
  +String score
