@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
interface Payment {
  -double updatedAt
  #long code
  -Date description
  -long type
  -long id
  +calculatePrice()
  +createQuantity()
  +findStatus()
}
class Product {
  -float score
  #String total
  -float price
  -Date name
  #String description
  +saveActive()
  +getActive()
  +cancelQuantity()
  +setCreatedat()
}
class Wishlist {
  -int status
  #Date quantity
  -float phone
  +cancelTotal()
  +sendPhone()
  +sendNote()
}
abstract class Review {
  +double amount
  #Date code
  #int id
  +long phone
  +processCreatedat()
  +createEmail()
  +deleteActive()
}
class Coupon {
  -float total
  +boolean updatedAt
  +int amount
  +getQuantity()
  +calculateId()
}
interface Return {
  -boolean note
  #int createdAt
  +validatePrice()
}
abstract class Warehouse {
  +double status
  #float email
  +deleteAddress()
  +deleteScore()
  +createEmail()
  +validateQuantity()
}
Warehouse --|> Return
Wishlist --* Payment
@enduml