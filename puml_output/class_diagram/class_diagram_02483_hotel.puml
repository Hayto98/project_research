@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class CheckOut {
  -float email
  -long name
  -Date total
  #long code
  +cancelPhone()
}
interface Booking {
  +double id
  #float level
  #boolean score
  -Date amount
  +String price
  +createAmount()
  +calculateAmount()
  +createQuantity()
}
interface Guest {
  +Date updatedAt
  #long price
  +float note
  +cancelAmount()
  +validateLevel()
}
class Service {
  -boolean status
  #boolean address
  +updateQuantity()
}
class Amenity {
  +Date quantity
  #int duration
  -boolean updatedAt
  +updateEmail()
  +getScore()
  +validateScore()
  +getType()
}
Guest --* Booking
@enduml