@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Doctor {
  +boolean duration
  -Date code
  #int id
  +createActive()
  +cancelDuration()
  +sendEmail()
}
class Diagnosis {
  +boolean active
  -Date level
  +Date code
  +double duration
  +float note
  +setDuration()
}
class Appointment {
  #boolean address
  -double status
  +cancelCode()
  +sendStatus()
  +getUpdatedat()
}
class Insurance {
  -Date createdAt
  +Date id
  +calculateLevel()
}
Appointment --> Doctor : "*"
Insurance --* Appointment
note right of Doctor : Healthcare domain
@enduml