@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
interface Treatment {
  +String code
  #Date description
  #String note
  +calculateName()
  +getType()
  +validateAmount()
  +createPhone()
}
abstract class Ward {
  -Date price
  +boolean name
  +int type
  #String status
  #String phone
  +setId()
  +updateAmount()
  +findCreatedat()
  +setPrice()
}
interface LabTest {
  #String name
  +String createdAt
  #long email
  +saveId()
  +getStatus()
  +saveDuration()
  +updateLevel()
}
class Insurance {
  +double level
  +String price
  -float total
  +boolean updatedAt
  +float email
  +createActive()
  +processLevel()
  +createAddress()
}
Insurance --o LabTest
Ward ..|> Insurance
@enduml