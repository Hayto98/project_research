@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
interface MedicalRecord {
  +double price
  -double quantity
  -int duration
  #long code
  +processUpdatedat()
  +sendAmount()
  +updateUpdatedat()
}
class Appointment {
  #int note
  +Date total
  -float duration
  +createStatus()
  +setNote()
  +sendTotal()
  +saveTotal()
}
class Billing {
  +double level
  -Date updatedAt
  -long name
  +int description
  +processDuration()
  +setTotal()
  +setQuantity()
}
interface Prescription {
  #Date type
  -Date duration
  #boolean price
  -String score
  -boolean quantity
  +calculatePrice()
}
MedicalRecord --* Appointment
Prescription --* MedicalRecord
@enduml