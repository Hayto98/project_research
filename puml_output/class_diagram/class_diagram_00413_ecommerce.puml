@startuml
skinparam monochrome true
class Shipment {
  #Date quantity
  -int phone
  -float status
  #Date code
  +cancelCreatedat()
}
class Warehouse {
  -long note
  +boolean address
  #double phone
  +sendDuration()
  +calculateScore()
}
class Cart {
  -int level
  -Date name
  +double note
  +updateAddress()
  +setNote()
  +setType()
  +setName()
}
class Payment {
  #Date id
  #Date address
  +String amount
  +float note
  +findStatus()
  +deleteScore()
  +getPrice()
  +validateId()
}
class Supplier {
  +Date score
  +String updatedAt
  #double code
  +deleteTotal()
  +updateId()
}
class Coupon {
  +String status
  #boolean price
  +cancelEmail()
  +calculateActive()
}
abstract class Review {
  -double description
  -double phone
  -Date name
  -long id
  +createActive()
}
Cart --* Review
Supplier --o Payment
Review ..|> Cart
@enduml