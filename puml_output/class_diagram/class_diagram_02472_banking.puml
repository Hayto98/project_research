@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Teller {
  #float type
  -Date status
  +Date note
  +deleteStatus()
  +deleteType()
}
interface Transaction {
  #String amount
  -boolean code
  #int updatedAt
  +String id
  #boolean total
  +validateNote()
}
class Deposit {
  #Date email
  #double score
  #int type
  -float duration
  #float price
  +setDuration()
}
class Account {
  +double active
  #boolean description
  +long type
  #String quantity
  +setPhone()
  +calculateQuantity()
  +getId()
}
Transaction ..> Teller : "*"
Transaction ..> Deposit : "*"
@enduml