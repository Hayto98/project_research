@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Teller {
  #float type
  -Date status
  +Date note
  +saveDuration()
  +processAmount()
}
class Transaction {
  -boolean id
  #int total
  +String code
  +updatePhone()
}
abstract class Deposit {
  #Date score
  #double type
  #int email
  -float price
  +findEmail()
}
class Account {
  -boolean type
  #String quantity
  -Date code
  +sendEmail()
}
Account --|> Deposit
Transaction ..> Teller : "*"
Transaction ..> Deposit : "*"
note right of Teller : Banking domain
@enduml