@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Renewal {
  +Date name
  +Date phone
  #float email
  +int quantity
  +validateQuantity()
}
abstract class Librarian {
  -Date quantity
  -boolean code
  +float phone
  +double total
  +validateName()
  +updateDuration()
  +getPrice()
}
class Loan {
  -long code
  -String total
  +float level
  #float price
  #String active
  +cancelAddress()
}
abstract class Publisher {
  #double createdAt
  #String status
  -double description
  +deleteUpdatedat()
  +processCode()
  +calculateEmail()
}
class Shelf {
  -Date total
  +boolean price
  +deleteTotal()
  +validatePhone()
  +saveAddress()
}
class Branch {
  +long status
  +String id
  +setTotal()
  +findCode()
}
Branch --> Publisher : "1"
Renewal --> Publisher : "*"
Loan ..|> Publisher
note right of Renewal : Library domain
@enduml