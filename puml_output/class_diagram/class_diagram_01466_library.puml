@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Renewal {
  +Date name
  +Date phone
  #float email
  +int quantity
  +validateDescription()
}
class Librarian {
  -double note
  -Date email
  -boolean quantity
  +float code
  +updateEmail()
}
class Loan {
  +double name
  +double updatedAt
  -float id
  -boolean price
  +saveLevel()
  +createActive()
  +findCode()
  +saveName()
}
class Publisher {
  +boolean active
  #Date level
  -double code
  +saveNote()
  +createLevel()
}
interface Shelf {
  -Date description
  +long active
  +deleteId()
  +getCreatedat()
  +validateScore()
  +deletePhone()
}
class Branch {
  -int note
  +double code
  -double total
  +findDescription()
}
Librarian --* Publisher
Loan --* Branch
Renewal ..> Branch : "1"
Renewal ..|> Loan
@enduml