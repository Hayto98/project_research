@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class DeliveryNote {
  #int code
  -int active
  +getAddress()
}
abstract class Inventory {
  #float price
  +String id
  +findActive()
  +processCode()
  +cancelPhone()
}
interface FuelLog {
  +double updatedAt
  #float createdAt
  +processName()
  +sendEmail()
  +saveId()
  +sendPhone()
}
class Route {
  -String email
  #double name
  -int type
  +Date price
  #double updatedAt
  +saveType()
}
class Driver {
  -long type
  #String total
  #Date status
  +boolean phone
  -double code
  +getName()
  +cancelCode()
}
class Warehouse {
  #double address
  #boolean updatedAt
  -long phone
  +float price
  +Date score
  +deleteCode()
  +createPhone()
  +setDuration()
  +processType()
}
abstract class Vehicle {
  -float updatedAt
  +float email
  #boolean price
  +String active
  +boolean status
  +deleteTotal()
}
Inventory --o DeliveryNote
Inventory --* Driver
Vehicle ..> DeliveryNote : "1..*"
Warehouse --o Vehicle
@enduml