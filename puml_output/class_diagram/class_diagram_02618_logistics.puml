@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class DeliveryNote {
  #int code
  -int active
  +calculatePrice()
}
class Inventory {
  -String id
  -boolean level
  +int duration
  +int code
  -boolean address
  +getCreatedat()
  +getPhone()
  +saveStatus()
  +processEmail()
}
class FuelLog {
  -int price
  +Date updatedAt
  #double email
  #boolean name
  +float type
  +findLevel()
  +cancelDuration()
  +sendType()
}
abstract class Route {
  #String status
  #Date phone
  +boolean code
  -double email
  #int quantity
  +deleteScore()
  +sendPrice()
  +validateDuration()
  +findUpdatedat()
}
class Driver {
  +float duration
  +Date phone
  -long total
  +double level
  -double quantity
  +createPrice()
  +sendActive()
}
interface Warehouse {
  #boolean type
  +String description
  +cancelCode()
}
class Vehicle {
  #long status
  +Date note
  -Date updatedAt
  +validateEmail()
  +validateScore()
  +sendPhone()
  +saveEmail()
}
Route ..> FuelLog : "*"
Vehicle ..> DeliveryNote : "*"
note right of DeliveryNote : Logistics domain
@enduml