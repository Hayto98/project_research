@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class CheckIn {
  +boolean quantity
  +Date amount
  +int price
  +setEmail()
  +deleteStatus()
}
class CheckOut {
  #long duration
  -float note
  -Date description
  #String amount
  +saveId()
}
class Room {
  +Date email
  #float id
  -long duration
  #int description
  +boolean code
  +updatePrice()
}
class Invoice {
  #float email
  +double amount
  -String total
  +float updatedAt
  +updateDuration()
  +updateName()
  +findAddress()
}
class Guest {
  +String amount
  #Date active
  +Date updatedAt
  +boolean note
  +cancelType()
  +sendId()
  +cancelQuantity()
}
Room ..|> CheckIn
Room ..|> CheckOut
CheckOut ..|> CheckIn
Invoice ..|> CheckIn
note right of CheckIn : Hotel domain
@enduml