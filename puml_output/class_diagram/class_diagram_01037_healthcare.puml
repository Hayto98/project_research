@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
interface Patient {
  +int note
  -float quantity
  -boolean description
  -Date duration
  #int address
  +saveId()
  +createAmount()
  +cancelName()
  +validateDuration()
}
class Treatment {
  +long email
  #Date address
  +float type
  +calculateName()
  +setId()
  +findEmail()
}
abstract class Prescription {
  #double note
  +float score
  #Date address
  #long status
  +float amount
  +deleteEmail()
  +findCode()
}
class Hospital {
  #long email
  -boolean address
  +setScore()
  +createCreatedat()
  +validateLevel()
  +setActive()
}
class Billing {
  +long duration
  -double type
  +validateActive()
  +sendLevel()
  +createAddress()
  +cancelQuantity()
}
class Appointment {
  #int address
  +String createdAt
  #int description
  +long phone
  +getNote()
  +findType()
  +deleteLevel()
  +createAmount()
}
class Ward {
  -Date name
  -double description
  #String id
  +getScore()
}
Patient --> Treatment : "0..1"
Appointment --o Treatment
Patient --|> Appointment
Ward --> Hospital : "*"
Patient --> Prescription : "1"
Appointment ..> Billing : "0..1"
@enduml