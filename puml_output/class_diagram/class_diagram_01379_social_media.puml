@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
interface Group {
  -Date level
  #double createdAt
  -double name
  -boolean code
  +updateStatus()
  +validateCode()
}
class Report {
  #long score
  +boolean name
  -int updatedAt
  -Date description
  -long quantity
  +sendType()
}
interface Notification {
  #String score
  -float amount
  -boolean phone
  -String status
  +Date active
  +findAddress()
}
class Post {
  #int createdAt
  #boolean amount
  -String quantity
  #double price
  +sendNote()
  +setActive()
  +updateType()
  +validateScore()
}
abstract class Album {
  +Date updatedAt
  +boolean type
  #long description
  #Date note
  +deleteQuantity()
  +findCreatedat()
  +getUpdatedat()
  +saveLevel()
}
Post --|> Album
Report --o Post
note right of Group : Social Media domain
@enduml