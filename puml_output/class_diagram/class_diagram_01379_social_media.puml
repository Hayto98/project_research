@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
interface Group {
  -Date level
  #double createdAt
  -double name
  -boolean code
  +sendNote()
  +createTotal()
}
class Report {
  #boolean code
  +int email
  -Date price
  -int name
  +validateCreatedat()
  +deleteLevel()
  +findScore()
}
abstract class Notification {
  #int name
  -boolean active
  #String type
  #float total
  +setAddress()
}
class Post {
  #String price
  #Date email
  -String status
  -int score
  +findType()
  +createQuantity()
}
abstract class Album {
  #double duration
  #boolean price
  -boolean code
  +updateUpdatedat()
  +calculateActive()
  +getTotal()
  +deleteActive()
}
Album --* Post
Report ..|> Post
Post ..> Report : "0..1"
@enduml