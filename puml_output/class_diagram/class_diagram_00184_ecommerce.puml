@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Supplier {
  #Date updatedAt
  +Date address
  #float price
  #int email
  +updateAddress()
  +setId()
  +saveCode()
}
class Order {
  +long level
  +boolean code
  +double status
  +processAddress()
  +findAddress()
  +findPhone()
}
abstract class Payment {
  #double createdAt
  #float type
  +updateActive()
  +findNote()
  +setQuantity()
  +createCreatedat()
}
class Review {
  -boolean updatedAt
  #String level
  +findEmail()
  +setUpdatedat()
  +sendAddress()
  +getCode()
}
interface Category {
  +double active
  #boolean price
  +Date description
  #float code
  #double type
  +getPrice()
  +createPhone()
  +updateAmount()
  +createAddress()
}
abstract class Customer {
  -String createdAt
  -Date phone
  -float updatedAt
  +sendActive()
  +validateStatus()
}
class Return {
  #long address
  -double total
  +deletePrice()
  +setTotal()
}
Supplier --o Category
Return --* Supplier
Order ..|> Payment
note right of Supplier : Ecommerce domain
@enduml