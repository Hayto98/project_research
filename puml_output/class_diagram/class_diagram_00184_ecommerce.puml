@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Supplier {
  #Date updatedAt
  +Date address
  #float price
  #int email
  +sendId()
  +updateCreatedat()
  +cancelUpdatedat()
}
class Order {
  +int id
  #String code
  +getType()
}
class Payment {
  -long score
  -long id
  +calculateStatus()
  +deleteCode()
  +cancelQuantity()
}
class Review {
  #float type
  -int score
  #boolean total
  +validatePhone()
  +updateLevel()
  +sendAddress()
  +cancelDescription()
}
class Category {
  #boolean status
  +double updatedAt
  #long price
  +validateNote()
}
interface Customer {
  #boolean id
  -int code
  +double score
  +double note
  +setScore()
}
interface Return {
  +int price
  -long id
  -float duration
  +int quantity
  -int phone
  +cancelEmail()
  +findQuantity()
  +cancelDescription()
}
Return ..|> Category
Payment ..|> Supplier
@enduml