@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Shipment {
  +String price
  +boolean phone
  #long type
  -int duration
  +deleteId()
  +calculateType()
  +deleteCreatedat()
}
interface Supplier {
  #int description
  +double phone
  +createStatus()
}
class Order {
  -int status
  +boolean note
  #long amount
  +deletePrice()
}
class Review {
  #boolean note
  #boolean duration
  +Date email
  #double updatedAt
  +cancelLevel()
  +calculateQuantity()
  +saveNote()
  +processType()
}
Review ..> Shipment : "1..*"
Order ..|> Supplier
@enduml