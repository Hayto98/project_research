@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Shipment {
  +String price
  +boolean phone
  #long type
  -int duration
  +createDuration()
  +getDescription()
  +validateAmount()
}
class Supplier {
  -int id
  -int score
  +boolean quantity
  #long description
  +double status
  +sendPhone()
  +processNote()
}
class Order {
  +Date score
  #double active
  #double duration
  +updatePrice()
  +cancelAmount()
  +calculateName()
  +findAddress()
}
class Review {
  #Date description
  +boolean level
  +int status
  +long total
  +processLevel()
  +updateName()
  +updateEmail()
  +sendAmount()
}
Shipment --> Order : "1"
Order --|> Shipment
note right of Shipment : Ecommerce domain
@enduml