@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
abstract class Vehicle {
  +String quantity
  #String level
  #double price
  -boolean type
  +findAddress()
}
class Depot {
  #int email
  +double status
  +Date createdAt
  -boolean type
  +double phone
  +sendType()
}
class Customer {
  -double amount
  +float quantity
  +String type
  +Date total
  #float duration
  +getPrice()
  +calculatePrice()
}
class Shipment {
  #float duration
  +String note
  +float id
  -int createdAt
  +sendActive()
  +findType()
  +cancelDescription()
  +validateTotal()
}
class FuelLog {
  +float total
  -long description
  +calculateEmail()
}
abstract class Tracking {
  #int createdAt
  +int total
  +int address
  +String score
  +deleteNote()
  +findPhone()
  +saveDuration()
  +setDuration()
}
abstract class Package {
  #boolean code
  #String note
  +setId()
  +updatePrice()
}
Package --|> Customer
Package --* Vehicle
Depot ..|> Customer
Depot --|> Package
@enduml