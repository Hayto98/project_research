@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
abstract class Vehicle {
  +String quantity
  #String level
  #double price
  -boolean type
  +updateDescription()
}
interface Depot {
  #int email
  +double status
  +Date createdAt
  -boolean type
  +double phone
  +findQuantity()
}
abstract class Customer {
  -int quantity
  -double level
  +float type
  +setCreatedat()
}
class Shipment {
  +boolean quantity
  +String note
  +float id
  +deleteTotal()
  +cancelQuantity()
  +setTotal()
  +deleteDescription()
}
abstract class FuelLog {
  +double name
  -boolean duration
  #boolean type
  -float phone
  +getCreatedat()
  +setUpdatedat()
}
class Tracking {
  +boolean total
  #Date name
  +setCode()
  +processLevel()
  +sendName()
  +deleteDuration()
}
class Package {
  +long quantity
  +int status
  +String code
  #Date duration
  +findTotal()
}
Depot ..|> Tracking
Package ..> Customer : "1..*"
Vehicle --|> FuelLog
note right of Vehicle : Logistics domain
@enduml