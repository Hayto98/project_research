@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Course {
  #boolean duration
  +Date phone
  +validateId()
}
class Exam {
  +String updatedAt
  #float type
  #Date quantity
  #double active
  +sendId()
  +deleteDuration()
  +setLevel()
}
class Grade {
  #long total
  #double name
  +cancelEmail()
  +setStatus()
}
class Classroom {
  #int phone
  +Date createdAt
  -Date type
  -String address
  +deleteActive()
  +calculateStatus()
  +setCode()
}
class Assignment {
  #Date status
  #String active
  -boolean createdAt
  #int type
  -long description
  +sendNote()
  +saveCreatedat()
  +getAmount()
}
class Library {
  +Date quantity
  +Date description
  -long status
  #double phone
  +processStatus()
  +deleteDuration()
  +getPhone()
}
Exam --|> Library
Library --* Grade
Assignment --o Library
Exam ..|> Assignment
note right of Course : Education domain
@enduml