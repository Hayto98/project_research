@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Course {
  #boolean duration
  +Date phone
  +saveType()
}
class Exam {
  +double updatedAt
  -boolean address
  +getLevel()
}
interface Grade {
  #String phone
  +double active
  +Date id
  -float description
  #double code
  +findUpdatedat()
  +sendAddress()
}
class Classroom {
  -int name
  -long phone
  +savePhone()
  +deleteType()
}
abstract class Assignment {
  -String code
  +Date quantity
  +Date description
  +Date active
  +updateUpdatedat()
  +deleteId()
  +validateType()
  +findPrice()
}
class Library {
  -long description
  #long level
  #float status
  -float phone
  #int createdAt
  +calculateDescription()
}
Grade --* Library
Exam --* Course
Course ..> Library : "*"
@enduml