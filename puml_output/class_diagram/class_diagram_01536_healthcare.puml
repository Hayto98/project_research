@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Treatment {
  +boolean description
  +Date code
  #Date id
  -float phone
  +updatePhone()
}
class Appointment {
  -double email
  -Date name
  +float amount
  #int duration
  +float code
  +validateUpdatedat()
  +calculateTotal()
  +getScore()
}
abstract class Diagnosis {
  #double quantity
  #long phone
  -double active
  +deleteActive()
  +cancelName()
}
class Hospital {
  -Date duration
  #Date code
  +validateStatus()
  +validateCreatedat()
  +validateEmail()
  +cancelScore()
}
class Billing {
  -float score
  #boolean id
  #boolean price
  +validateActive()
  +saveDuration()
}
Hospital --o Billing
Appointment --> Treatment : "0..1"
@enduml