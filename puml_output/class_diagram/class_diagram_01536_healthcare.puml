@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Treatment {
  +boolean description
  +Date code
  #Date id
  -float phone
  +saveQuantity()
}
abstract class Appointment {
  -double name
  -Date amount
  +float email
  #int code
  +validateType()
  +sendTotal()
}
interface Diagnosis {
  #double quantity
  #long phone
  -double active
  +processEmail()
  +cancelActive()
}
class Hospital {
  #double total
  +String level
  +deleteScore()
  +getPrice()
  +calculateScore()
}
interface Billing {
  -double duration
  -int level
  +float status
  +deleteQuantity()
  +savePhone()
}
Hospital ..> Diagnosis : "1..*"
Appointment --> Hospital : "1"
note right of Treatment : Healthcare domain
@enduml