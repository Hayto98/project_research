@startuml
skinparam defaultFontSize 11
interface Teacher {
  +String total
  +long email
  +float status
  #boolean level
  +long quantity
  +getScore()
  +createScore()
  +cancelUpdatedat()
  +validateEmail()
}
interface Enrollment {
  -long createdAt
  #Date note
  -double description
  +validateDescription()
  +createPhone()
  +calculatePhone()
  +saveId()
}
abstract class Attendance {
  +long note
  +float score
  #float address
  #String name
  +boolean type
  +getAmount()
  +processName()
  +updateScore()
}
class Course {
  -float updatedAt
  -float level
  -long email
  -boolean status
  +validateQuantity()
  +cancelNote()
  +deleteScore()
  +validateDescription()
}
Teacher --* Attendance
Enrollment --|> Teacher
Course --o Enrollment
@enduml