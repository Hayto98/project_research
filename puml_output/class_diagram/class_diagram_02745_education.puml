@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Grade {
  +int active
  -double address
  +findLevel()
  +setType()
  +deleteId()
}
interface Exam {
  +Date level
  +long type
  +setCreatedat()
  +setDuration()
}
class Schedule {
  #String score
  -long price
  -long description
  +cancelQuantity()
}
class Classroom {
  #double phone
  -String duration
  #double code
  #boolean note
  +calculateLevel()
  +calculateNote()
  +deleteScore()
}
class Student {
  +String active
  #long email
  -double phone
  -float address
  +Date score
  +updateDescription()
  +validateQuantity()
  +updateType()
  +processDescription()
}
class Library {
  +String duration
  #float name
  +float score
  +cancelUpdatedat()
  +calculateCreatedat()
}
Grade --|> Schedule
Classroom --|> Exam
Classroom --* Library
Library ..> Exam : "1"
Student --* Classroom
@enduml