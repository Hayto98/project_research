@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Grade {
  +int active
  -double address
  +deleteDuration()
  +saveCode()
  +cancelType()
}
class Exam {
  +Date phone
  #double updatedAt
  +Date code
  +calculatePhone()
}
abstract class Schedule {
  -Date active
  -long id
  +Date note
  -boolean amount
  +validateName()
  +sendPrice()
  +sendLevel()
  +createCreatedat()
}
class Classroom {
  #boolean duration
  -long price
  +validateName()
  +getLevel()
  +validateNote()
}
abstract class Student {
  +long code
  +boolean score
  #int type
  #String createdAt
  #String amount
  +saveCreatedat()
}
class Library {
  -Date total
  +String status
  -double phone
  -Date code
  +findLevel()
  +sendName()
}
Schedule ..> Exam : "1"
Exam --* Grade
Schedule --* Library
Library ..> Schedule : "*"
note right of Grade : Education domain
@enduml