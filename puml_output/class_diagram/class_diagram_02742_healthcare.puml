@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Patient {
  +Date id
  #String updatedAt
  +saveActive()
  +processPrice()
  +getName()
  +deleteCreatedat()
}
class Insurance {
  -String quantity
  -int id
  -int score
  +long description
  +createId()
  +findUpdatedat()
  +deleteNote()
}
abstract class Treatment {
  #float active
  #long amount
  +saveUpdatedat()
}
class Prescription {
  +String score
  -float amount
  +validateQuantity()
  +getId()
}
Prescription --> Patient : "*"
Insurance --* Patient
@enduml