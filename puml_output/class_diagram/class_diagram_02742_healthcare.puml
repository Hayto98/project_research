@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Patient {
  +Date id
  #String updatedAt
  +sendUpdatedat()
  +createCode()
  +validateQuantity()
  +getScore()
}
class Insurance {
  +long status
  -float type
  #String createdAt
  -String quantity
  #Date description
  +cancelLevel()
  +validateActive()
}
class Treatment {
  +String name
  +double score
  +deleteType()
  +getPrice()
}
class Prescription {
  #float score
  -String description
  -double code
  -int email
  #String level
  +getName()
  +sendQuantity()
  +getName()
}
Prescription --> Insurance : "1"
Prescription ..|> Treatment
note right of Patient : Healthcare domain
@enduml