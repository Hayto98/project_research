@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
interface Guest {
  -float amount
  #long phone
  +setEmail()
  +setDescription()
  +findScore()
}
class CheckOut {
  #double total
  -double code
  +String quantity
  +long phone
  -Date id
  +findNote()
  +updateNote()
  +setUpdatedat()
}
interface Amenity {
  #Date total
  +int level
  +float createdAt
  +updateId()
  +validateScore()
}
class Room {
  #double active
  +long description
  #String address
  +float code
  +setAmount()
  +deleteCode()
  +calculateQuantity()
  +findAddress()
}
class Reservation {
  +Date id
  #boolean address
  +setEmail()
  +setCode()
  +processPrice()
  +findCreatedat()
}
Reservation --> Room : "*"
Guest ..> Reservation : "1"
@enduml