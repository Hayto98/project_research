@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Shipment {
  -double note
  -boolean id
  #boolean type
  +cancelScore()
  +createLevel()
  +findPrice()
}
class Depot {
  #float description
  +String type
  #long createdAt
  -long active
  -float updatedAt
  +updatePrice()
  +updateId()
  +deleteQuantity()
  +findQuantity()
}
class Route {
  -float duration
  +int status
  #boolean createdAt
  #double quantity
  -long price
  +deleteName()
  +sendUpdatedat()
}
class FuelLog {
  #double active
  -float quantity
  -int level
  +boolean score
  +sendTotal()
  +findScore()
}
class Driver {
  #float id
  -long createdAt
  #double level
  +double quantity
  +cancelTotal()
  +getScore()
  +updateStatus()
}
class Manifest {
  #String total
  #String address
  -int amount
  +double id
  +sendPrice()
}
Shipment ..> Driver : "0..1"
Driver --|> Shipment
FuelLog --|> Manifest
Depot --> Manifest : "1"
note right of Shipment : Logistics domain
@enduml