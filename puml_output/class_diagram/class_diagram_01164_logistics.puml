@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Shipment {
  -double note
  -boolean id
  #boolean type
  +sendLevel()
  +processId()
  +sendAmount()
}
class Depot {
  #boolean createdAt
  +boolean note
  +String description
  #long type
  -long duration
  +validateDescription()
  +saveAmount()
  +createScore()
  +createPrice()
}
class Route {
  #float amount
  -int quantity
  +setPhone()
  +processScore()
  +createTotal()
  +createPhone()
}
class FuelLog {
  #boolean price
  #double quantity
  -long updatedAt
  +int createdAt
  +findDuration()
}
class Driver {
  #long duration
  #long active
  +cancelScore()
  +processId()
  +cancelPrice()
}
class Manifest {
  #float total
  #double quantity
  #float updatedAt
  #int status
  #long amount
  +calculateUpdatedat()
}
Depot --> Route : "*"
Route ..|> FuelLog
FuelLog --> Route : "*"
@enduml