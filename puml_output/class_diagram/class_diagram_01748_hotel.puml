@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Guest {
  #int createdAt
  -int active
  +long score
  -float phone
  -boolean name
  +createNote()
  +getLevel()
}
class Booking {
  +int total
  +int email
  #double quantity
  #Date name
  +findStatus()
  +updateLevel()
  +processPrice()
  +deleteTotal()
}
class CheckOut {
  +long address
  +String level
  +processCreatedat()
  +setNote()
}
abstract class Invoice {
  +Date score
  #String name
  +findPrice()
}
class Reservation {
  +long quantity
  -String description
  -String createdAt
  +deleteUpdatedat()
  +validateNote()
  +processStatus()
}
class Service {
  +double quantity
  +double phone
  #long price
  +long level
  #int name
  +findUpdatedat()
  +deleteScore()
  +updateCode()
  +saveName()
}
abstract class Room {
  #int active
  #boolean status
  +double code
  +getType()
  +deleteNote()
  +createName()
}
CheckOut --* Room
Service ..|> Booking
Reservation --> Service : "*"
Service --|> Reservation
note right of Guest : Hotel domain
@enduml