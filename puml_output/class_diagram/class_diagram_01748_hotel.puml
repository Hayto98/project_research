@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Guest {
  #int createdAt
  -int active
  +long score
  -float phone
  -boolean name
  +calculateScore()
  +calculateType()
}
abstract class Booking {
  -Date level
  -long status
  +setUpdatedat()
  +calculateNote()
  +calculateAddress()
}
class CheckOut {
  #Date active
  +float price
  +boolean level
  +findEmail()
  +calculateCode()
  +saveAddress()
  +processLevel()
}
class Invoice {
  +long address
  +String level
  +cancelCode()
  +getTotal()
}
class Reservation {
  #boolean note
  +Date id
  +Date score
  -long name
  #Date createdAt
  +saveUpdatedat()
  +getNote()
}
class Service {
  +long id
  +long address
  +float level
  +updateTotal()
  +createName()
}
abstract class Room {
  -boolean quantity
  -double price
  +deleteId()
  +deleteNote()
  +updateStatus()
}
Guest --> Invoice : "1..*"
Guest ..> CheckOut : "0..1"
Room ..> Invoice : "0..1"
Booking ..|> Reservation
Guest --|> Service
@enduml