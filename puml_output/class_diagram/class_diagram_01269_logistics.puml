@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
interface Route {
  +boolean price
  -long updatedAt
  -boolean id
  +setType()
}
class Inventory {
  +float level
  +int duration
  +saveUpdatedat()
  +createType()
}
interface Warehouse {
  -float duration
  -double description
  -Date type
  #String id
  -Date active
  +updateActive()
  +calculateName()
  +findPhone()
}
class Package {
  #boolean phone
  #int quantity
  #long total
  -double amount
  +validateUpdatedat()
  +processAmount()
}
Route ..|> Warehouse
Route --|> Package
note right of Route : Logistics domain
@enduml