@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
abstract class Staff {
  #int note
  -String status
  #Date updatedAt
  #String address
  #String total
  +sendName()
  +findAddress()
  +validateDuration()
}
class Invoice {
  -long name
  #int active
  +long code
  #boolean createdAt
  +createName()
  +setDescription()
  +processScore()
}
class Room {
  +float name
  #float price
  #String description
  #double address
  +calculateStatus()
  +calculateCode()
  +createActive()
  +setAddress()
}
class CheckIn {
  +Date level
  +String address
  -int price
  -int active
  +saveUpdatedat()
  +setTotal()
  +saveCreatedat()
}
interface Restaurant {
  #String quantity
  #float description
  #int note
  -int code
  #int phone
  +sendStatus()
}
class CheckOut {
  -Date active
  #boolean type
  -String duration
  +cancelId()
}
CheckOut --* Staff
Invoice --> Staff : "*"
@enduml