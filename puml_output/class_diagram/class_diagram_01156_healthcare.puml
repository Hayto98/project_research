@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class LabTest {
  -int createdAt
  -boolean type
  #int total
  +getTotal()
  +getAmount()
  +calculateUpdatedat()
  +findScore()
}
class Billing {
  +long name
  -String amount
  #String price
  +boolean duration
  #long id
  +setCreatedat()
}
class Insurance {
  -String quantity
  #long name
  +long active
  -int score
  +deleteStatus()
  +createStatus()
}
abstract class Doctor {
  #int id
  +double status
  +getType()
  +deleteName()
  +deletePrice()
  +cancelType()
}
Billing ..|> LabTest
Billing ..> Insurance : "*"
@enduml