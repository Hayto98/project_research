@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class MedicalRecord {
  -boolean type
  #String note
  -int status
  +boolean duration
  +setLevel()
  +validateTotal()
  +setDuration()
  +findActive()
}
class Treatment {
  -long id
  #boolean score
  #int status
  +saveQuantity()
  +validateQuantity()
  +processType()
  +calculateScore()
}
class Nurse {
  #String id
  +String amount
  #int createdAt
  -long phone
  +sendActive()
}
interface Diagnosis {
  +float amount
  #int score
  #Date price
  +sendTotal()
  +updateAmount()
  +deleteEmail()
}
interface Hospital {
  #float amount
  #boolean total
  +String type
  +updateUpdatedat()
  +setName()
  +validateActive()
}
class Prescription {
  -boolean status
  #int type
  #boolean total
  +long address
  +validatePrice()
  +updateTotal()
}
class LabTest {
  #String total
  #long updatedAt
  -double duration
  +sendScore()
  +updateDuration()
  +saveStatus()
}
Hospital ..> LabTest : "1..*"
MedicalRecord ..|> Treatment
LabTest --o Diagnosis
Diagnosis --o Treatment
note right of MedicalRecord : Healthcare domain
@enduml