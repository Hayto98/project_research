@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class MedicalRecord {
  -boolean type
  #String note
  -int status
  +boolean duration
  +saveStatus()
  +createPhone()
  +calculateStatus()
  +cancelActive()
}
class Treatment {
  #boolean code
  +double active
  -boolean description
  #Date amount
  +double id
  +validateDuration()
  +updateLevel()
  +cancelCode()
}
abstract class Nurse {
  +long score
  #String name
  +String email
  #int id
  -long amount
  +createId()
}
interface Diagnosis {
  +float amount
  #int score
  #Date price
  +getPrice()
  +createDescription()
  +findAmount()
}
class Hospital {
  +Date description
  +double email
  -boolean active
  +deleteNote()
}
interface Prescription {
  -boolean createdAt
  +long updatedAt
  +float code
  #double name
  +setScore()
  +cancelName()
  +validateDuration()
  +deleteCode()
}
interface LabTest {
  -int score
  -double active
  +double updatedAt
  +saveNote()
  +setNote()
  +findType()
}
Diagnosis --|> Prescription
Prescription --* Nurse
Diagnosis --> Nurse : "0..1"
@enduml