@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Shipment {
  #float quantity
  -int code
  #long updatedAt
  +saveDescription()
}
class Return {
  -double price
  #boolean id
  #int amount
  -long createdAt
  +getType()
  +createTotal()
  +processScore()
  +saveScore()
}
interface Customer {
  -String quantity
  +int code
  #String total
  #double email
  -String phone
  +deleteTotal()
  +validateStatus()
  +processId()
  +setActive()
}
class Coupon {
  +float email
  #float description
  +setPhone()
  +sendQuantity()
  +cancelEmail()
  +setTotal()
}
class Order {
  -String total
  -float amount
  #float email
  +cancelCreatedat()
}
class Cart {
  -boolean duration
  -long total
  -boolean name
  +boolean updatedAt
  +calculateEmail()
  +sendType()
  +getNote()
  +processAmount()
}
Coupon --* Customer
Shipment --* Cart
note right of Shipment : Ecommerce domain
@enduml