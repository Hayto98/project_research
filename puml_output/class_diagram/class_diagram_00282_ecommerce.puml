@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Shipment {
  #float quantity
  -int code
  #long updatedAt
  +createType()
}
class Return {
  +int phone
  #float price
  +createActive()
  +getPhone()
}
interface Customer {
  -float quantity
  +double duration
  -double active
  +saveType()
  +calculateDuration()
  +saveUpdatedat()
  +createStatus()
}
interface Coupon {
  -String quantity
  +int code
  #String total
  #double email
  -String phone
  +setType()
  +saveUpdatedat()
  +updateEmail()
  +findCode()
}
class Order {
  #long id
  +String status
  #float active
  -String email
  -boolean name
  +savePrice()
  +sendAddress()
  +getType()
}
abstract class Cart {
  #float createdAt
  -float total
  -String amount
  +getPrice()
  +saveUpdatedat()
  +getUpdatedat()
  +cancelStatus()
}
Shipment --> Customer : "*"
Shipment --* Return
Order --* Customer
@enduml