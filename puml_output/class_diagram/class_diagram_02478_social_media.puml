@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
abstract class Story {
  #double amount
  #long email
  +boolean phone
  +updateNote()
  +calculatePhone()
}
class User {
  #boolean name
  #int phone
  #String active
  #double note
  +updateId()
  +createPrice()
  +deleteDescription()
  +cancelName()
}
interface Album {
  #Date score
  #boolean price
  +calculateDuration()
  +cancelPhone()
  +updateTotal()
}
abstract class Post {
  #float address
  #int amount
  -Date createdAt
  +float description
  +findEmail()
}
class Comment {
  -int createdAt
  #String price
  +float note
  -float duration
  #String code
  +sendAmount()
  +sendType()
}
class Group {
  +int email
  -String code
  +sendId()
  +saveAmount()
  +cancelName()
  +sendUpdatedat()
}
Album ..> Story : "0..1"
Story ..> Comment : "0..1"
Story --* Album
User ..|> Post
@enduml