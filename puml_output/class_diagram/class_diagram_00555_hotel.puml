@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
abstract class Staff {
  #String level
  -Date name
  -boolean address
  -long code
  +validateCreatedat()
  +createStatus()
  +setNote()
  +createAddress()
}
interface Guest {
  +float phone
  #int id
  +long updatedAt
  -float note
  +double status
  +setStatus()
}
class Restaurant {
  #String description
  +float note
  +double total
  #long code
  -double updatedAt
  +saveType()
  +sendDuration()
  +findDescription()
  +updateStatus()
}
interface CheckIn {
  -int id
  #String note
  +String amount
  +getUpdatedat()
  +deleteDescription()
  +saveScore()
  +deleteAmount()
}
Guest --* CheckIn
Restaurant ..|> Guest
note right of Staff : Hotel domain
@enduml