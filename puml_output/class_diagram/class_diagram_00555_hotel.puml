@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
abstract class Staff {
  #String level
  -Date name
  -boolean address
  -long code
  +validateDuration()
  +saveStatus()
  +cancelNote()
  +cancelAddress()
}
class Guest {
  -float note
  #Date email
  +saveScore()
  +setName()
  +sendNote()
  +setDuration()
}
interface Restaurant {
  -long level
  +double status
  +String createdAt
  #String description
  +double duration
  +deletePrice()
  +cancelCreatedat()
}
class CheckIn {
  +double active
  #long name
  -double id
  +setScore()
  +sendCreatedat()
  +createDescription()
  +getPrice()
}
Guest --> Staff : "0..1"
Staff ..|> Guest
@enduml