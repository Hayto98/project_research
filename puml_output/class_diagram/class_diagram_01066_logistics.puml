@startuml
skinparam ArrowColor #555555
class FuelLog {
  -float phone
  #Date type
  #boolean status
  -String level
  +Date address
  +validateStatus()
  +calculateEmail()
}
abstract class Route {
  -double id
  #float phone
  #long note
  -float total
  #Date description
  +saveType()
  +updateId()
  +sendScore()
}
class Customer {
  +double createdAt
  -float updatedAt
  -String type
  #double description
  +validateUpdatedat()
  +processPhone()
  +calculateLevel()
  +validateStatus()
}
class Vehicle {
  -float type
  -float status
  +findUpdatedat()
  +createId()
  +findActive()
  +setEmail()
}
abstract class Tracking {
  +double name
  +double code
  -boolean type
  #long score
  #int id
  +calculateEmail()
  +deleteLevel()
  +processCode()
  +updateName()
}
abstract class Depot {
  +float total
  +boolean phone
  +validateDescription()
}
Tracking ..> Vehicle : "*"
FuelLog ..> Customer : "0..1"
note right of FuelLog : Logistics domain
@enduml