@startuml
skinparam ArrowColor #555555
class FuelLog {
  -float phone
  #Date type
  #boolean status
  -String level
  +Date address
  +setAmount()
  +createActive()
}
class Route {
  -double email
  +float price
  -double note
  #float id
  #long phone
  +createId()
  +cancelType()
  +sendActive()
  +cancelName()
}
class Customer {
  +int createdAt
  -int id
  +double score
  -float code
  -String quantity
  +saveAmount()
  +deleteCode()
  +deleteAddress()
  +calculateAmount()
}
class Vehicle {
  -String level
  -float phone
  -float status
  -float description
  #Date score
  +getNote()
  +updateActive()
}
interface Tracking {
  -String email
  +double total
  +updateScore()
  +findStatus()
  +findDescription()
  +cancelTotal()
}
class Depot {
  #float id
  #double type
  -long level
  +boolean quantity
  -float amount
  +cancelNote()
}
Vehicle --o FuelLog
Customer --|> Route
@enduml