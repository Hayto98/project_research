@startuml
skinparam defaultFontSize 11
class Shipment {
  -Date updatedAt
  +float amount
  +double active
  +double status
  +sendPrice()
}
interface FuelLog {
  #float active
  -double quantity
  +String id
  +int total
  +int createdAt
  +createName()
  +getActive()
}
interface Warehouse {
  -String duration
  +String note
  +findCode()
  +calculateQuantity()
  +setQuantity()
  +cancelName()
}
interface Route {
  +Date note
  +Date name
  +calculateDescription()
  +setDescription()
}
interface Driver {
  -Date price
  -double updatedAt
  #String level
  -double status
  #float id
  +saveActive()
  +deleteEmail()
  +findName()
}
class Manifest {
  #float quantity
  #String total
  #float score
  +long id
  #float amount
  +validateTotal()
}
class Package {
  +Date description
  #long duration
  +int note
  -int phone
  #String id
  +getLevel()
  +calculateScore()
  +deleteEmail()
  +updateDescription()
}
Route --|> Manifest
Manifest --|> Warehouse
Route ..> FuelLog : "1..*"
Shipment --* Driver
FuelLog ..|> Manifest
@enduml