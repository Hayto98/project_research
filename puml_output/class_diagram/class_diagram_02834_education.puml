@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Enrollment {
  +float phone
  -String note
  #double level
  #String createdAt
  +saveId()
  +getNote()
}
interface Teacher {
  -float level
  -double score
  -double duration
  -double amount
  +getNote()
  +calculateType()
  +sendNote()
  +sendDescription()
}
interface Book {
  #String total
  #int level
  +sendPrice()
  +calculateCode()
  +cancelType()
  +getName()
}
class Department {
  +String duration
  -String createdAt
  +getCode()
}
abstract class Student {
  -double score
  +double duration
  -double updatedAt
  +createType()
}
Teacher ..|> Student
Book --|> Department
Student ..|> Book
@enduml