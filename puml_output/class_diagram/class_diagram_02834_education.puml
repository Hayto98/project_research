@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Enrollment {
  +float phone
  -String note
  #double level
  #String createdAt
  +getQuantity()
  +saveLevel()
}
class Teacher {
  -double address
  -double email
  -long total
  +cancelCode()
  +calculateLevel()
}
class Book {
  +boolean note
  +String price
  +double name
  +setLevel()
}
abstract class Department {
  -double score
  +double duration
  -double updatedAt
  +saveTotal()
}
class Student {
  +boolean updatedAt
  -float phone
  +float note
  +setNote()
  +validateDescription()
}
Department --* Student
Student ..> Department : "0..1"
note right of Enrollment : Education domain
@enduml