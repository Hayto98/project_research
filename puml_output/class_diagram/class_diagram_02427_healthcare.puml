@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
abstract class Treatment {
  +long active
  -double createdAt
  +String id
  +double amount
  +findAmount()
  +sendPhone()
  +cancelQuantity()
  +cancelPrice()
}
interface LabTest {
  +Date duration
  -Date score
  -boolean name
  -boolean total
  +setType()
  +validateType()
  +updateType()
  +sendQuantity()
}
class MedicalRecord {
  +Date updatedAt
  -Date price
  +long createdAt
  +long email
  +calculateAmount()
}
abstract class Diagnosis {
  #double level
  +double price
  +saveAmount()
  +setAddress()
  +sendStatus()
  +validateQuantity()
}
abstract class Insurance {
  +long total
  #Date type
  -String email
  +updateCreatedat()
  +updateType()
  +setDuration()
}
LabTest ..|> Treatment
MedicalRecord --* LabTest
Diagnosis ..|> Treatment
Treatment ..|> Insurance
@enduml