@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
abstract class Treatment {
  +long active
  -double createdAt
  +String id
  +double amount
  +calculatePhone()
  +processScore()
  +saveQuantity()
  +cancelScore()
}
class LabTest {
  #double amount
  +float email
  +boolean total
  #long active
  -int phone
  +updateEmail()
  +setPrice()
  +findCode()
  +createUpdatedat()
}
class MedicalRecord {
  #Date note
  +boolean price
  +sendPrice()
  +getType()
  +cancelNote()
  +processScore()
}
class Diagnosis {
  -boolean updatedAt
  #long total
  +long type
  +boolean email
  +float code
  +deletePhone()
}
interface Insurance {
  +Date email
  +String price
  +double id
  +cancelPhone()
}
LabTest --* Diagnosis
MedicalRecord --o LabTest
note right of Treatment : Healthcare domain
@enduml