@startuml
skinparam monochrome true
skinparam shadowing true
class Library {
  #int code
  #long updatedAt
  #Date note
  +updateDescription()
  +getLevel()
}
class Exam {
  #boolean code
  +long active
  #boolean updatedAt
  +int duration
  -float status
  +processCreatedat()
  +calculateType()
}
class Department {
  #String name
  #Date email
  #double status
  #float active
  +float score
  +validateStatus()
  +getTotal()
}
interface Schedule {
  -String duration
  -Date email
  +deleteStatus()
  +processDuration()
  +calculateCreatedat()
}
class Enrollment {
  -int createdAt
  -Date level
  +float note
  +boolean code
  +boolean price
  +sendCode()
  +createActive()
  +updateTotal()
}
class Assignment {
  +long price
  +float code
  #float updatedAt
  -Date address
  +float phone
  +getCreatedat()
}
Exam --o Enrollment
Assignment --* Schedule
@enduml