@startuml
skinparam monochrome true
skinparam shadowing true
class Library {
  #int code
  #long updatedAt
  #Date note
  +updateCode()
  +getPrice()
}
class Exam {
  #int code
  -Date status
  #int active
  +createUpdatedat()
  +setType()
}
class Department {
  #String status
  #Date active
  #double level
  #float duration
  +updateCreatedat()
}
interface Schedule {
  -String duration
  -Date email
  +saveUpdatedat()
  +validateUpdatedat()
  +sendActive()
}
abstract class Enrollment {
  #double level
  -int note
  -Date code
  +setDuration()
  +deleteActive()
}
class Assignment {
  +float address
  #float phone
  #int createdAt
  -float note
  -int price
  +getDuration()
  +validateCreatedat()
  +setScore()
}
Exam --o Enrollment
Assignment --* Schedule
note right of Library : Education domain
@enduml