@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
interface Shipment {
  #String note
  #Date name
  -float description
  +sendPrice()
  +updateScore()
}
class Return {
  +long amount
  -double phone
  +boolean createdAt
  -float address
  +int updatedAt
  +sendAddress()
  +getAmount()
}
class Customer {
  +long status
  #int duration
  +validatePhone()
  +getName()
}
interface Coupon {
  -float note
  #long duration
  +calculateDescription()
}
class Review {
  +String active
  +int email
  +long duration
  +String description
  +getNote()
  +validateUpdatedat()
  +getId()
}
interface Cart {
  -boolean id
  -Date quantity
  #double total
  +deleteLevel()
  +getAddress()
  +cancelNote()
  +validateCode()
}
interface Category {
  +long description
  #int active
  +double note
  -int status
  +getAmount()
  +getScore()
  +validateEmail()
  +findEmail()
}
Return --> Cart : "1..*"
Category ..|> Cart
Category ..> Return : "0..1"
Coupon ..|> Cart
@enduml