@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
interface Shipment {
  #String note
  #Date name
  -float description
  +saveId()
  +processAmount()
}
class Return {
  -float address
  -double updatedAt
  +boolean id
  +deleteUpdatedat()
  +updateEmail()
  +savePhone()
}
class Customer {
  -boolean status
  +float id
  +setActive()
  +getNote()
}
abstract class Coupon {
  -Date score
  #long address
  #int id
  +String quantity
  +deleteCreatedat()
}
class Review {
  #boolean status
  -long level
  +processActive()
  +updateId()
  +createTotal()
  +calculateDuration()
}
class Cart {
  +Date note
  #double total
  +String createdAt
  -Date description
  +float address
  +processType()
  +updateActive()
}
abstract class Category {
  #boolean type
  -float updatedAt
  +updateDescription()
  +processAmount()
}
Coupon --> Cart : "1..*"
Shipment --* Cart
note right of Shipment : Ecommerce domain
@enduml