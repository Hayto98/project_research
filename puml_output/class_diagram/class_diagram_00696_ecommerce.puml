@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Supplier {
  -float updatedAt
  +long quantity
  +Date code
  +validateType()
}
class Shipment {
  +Date phone
  #float duration
  +findTotal()
  +createQuantity()
  +validateType()
}
abstract class Category {
  -int score
  +double status
  +findStatus()
  +cancelPrice()
  +setPhone()
}
class Payment {
  -int id
  #boolean name
  +String status
  +validateCode()
}
class Order {
  +Date id
  +long quantity
  -int note
  -long code
  -Date amount
  +validateLevel()
  +getAmount()
}
class Customer {
  -Date amount
  +Date id
  +boolean updatedAt
  -Date price
  #boolean code
  +cancelDuration()
  +saveDuration()
  +sendPhone()
  +getUpdatedat()
}
interface Product {
  #int score
  -String quantity
  #long name
  -double updatedAt
  +float code
  +setPhone()
  +deleteEmail()
  +saveType()
  +updateUpdatedat()
}
Customer --|> Shipment
Product --o Order
Supplier ..> Customer : "*"
Payment ..|> Order
Customer --o Product
Supplier --o Product
@enduml