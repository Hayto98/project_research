@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Supplier {
  -float updatedAt
  +long quantity
  +Date code
  +setName()
}
class Shipment {
  -boolean status
  +boolean level
  +long quantity
  +int score
  +createDuration()
  +validateUpdatedat()
  +getName()
  +setEmail()
}
class Category {
  +double status
  +float duration
  #long description
  +setAmount()
  +updateStatus()
  +validateTotal()
  +updatePrice()
}
class Payment {
  #int updatedAt
  #Date phone
  #boolean note
  #double amount
  #String id
  +findCreatedat()
  +saveStatus()
  +cancelTotal()
}
interface Order {
  +Date level
  #String phone
  #int type
  -String quantity
  #long name
  +processCode()
  +calculateDuration()
  +setActive()
  +findAmount()
}
class Customer {
  +String name
  -long note
  #Date price
  +double createdAt
  #float level
  +validateCreatedat()
}
class Product {
  +String active
  -Date total
  #String name
  +findTotal()
  +createPhone()
}
Product --o Customer
Customer --* Category
Order --* Product
Payment --* Category
Category ..> Supplier : "1"
note right of Supplier : Ecommerce domain
@enduml