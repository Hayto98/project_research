@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Album {
  #long level
  #boolean updatedAt
  +int score
  +setUpdatedat()
  +saveQuantity()
}
interface Report {
  -float note
  +long updatedAt
  #int name
  #float email
  +processScore()
  +updateId()
}
interface Post {
  -Date quantity
  +boolean code
  +setTotal()
  +updateCreatedat()
  +sendId()
}
abstract class Profile {
  #int price
  -double description
  -Date note
  +String updatedAt
  #String total
  +validateName()
  +setType()
  +cancelType()
  +processPrice()
}
Album --o Profile
Report --o Album
Report --> Profile : "0..1"
@enduml