@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Album {
  #long level
  #boolean updatedAt
  +int score
  +getDescription()
  +sendPhone()
}
abstract class Report {
  -float duration
  +long name
  #int email
  +findLevel()
  +saveCode()
}
class Post {
  #long email
  -float amount
  +findType()
  +processPrice()
}
class Profile {
  -Date updatedAt
  +String total
  #String duration
  -double quantity
  +float type
  +validateId()
  +deleteTotal()
}
Report ..|> Profile
Post ..|> Profile
note right of Album : Social Media domain
@enduml