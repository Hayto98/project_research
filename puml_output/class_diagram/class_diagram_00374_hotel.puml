@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Reservation {
  #double description
  -String status
  #float email
  +saveEmail()
  +cancelPhone()
}
interface Amenity {
  +boolean updatedAt
  -long phone
  #boolean total
  #Date duration
  +boolean address
  +setQuantity()
}
class CheckIn {
  #boolean code
  -float type
  -boolean createdAt
  -String active
  +String description
  +processNote()
  +setScore()
  +cancelNote()
}
abstract class Payment {
  +Date updatedAt
  -boolean email
  +float type
  +float createdAt
  +boolean score
  +getDescription()
  +validateScore()
  +calculatePhone()
  +calculateCreatedat()
}
class Restaurant {
  -boolean note
  #float duration
  +float id
  +sendActive()
  +validateQuantity()
  +saveCreatedat()
  +updateAddress()
}
Payment --|> Reservation
Payment ..|> Restaurant
Reservation --|> CheckIn
note right of Reservation : Hotel domain
@enduml