@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Reservation {
  #double description
  -String status
  #float email
  +updatePhone()
  +cancelPhone()
}
interface Amenity {
  -float duration
  +Date note
  -String updatedAt
  #double phone
  +setScore()
  +saveDuration()
  +cancelScore()
}
class CheckIn {
  +Date status
  #double quantity
  +cancelDuration()
}
abstract class Payment {
  -float active
  -boolean description
  -String score
  +processName()
  +saveScore()
}
abstract class Restaurant {
  +long code
  #double score
  +double note
  +Date type
  -boolean price
  +createId()
}
Reservation --|> Payment
Amenity ..> CheckIn : "*"
@enduml