@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
interface Author {
  #double price
  -String amount
  -Date name
  -int total
  +saveNote()
  +setUpdatedat()
  +setAddress()
}
class Renewal {
  +long status
  +float updatedAt
  +findDescription()
  +findType()
  +calculateUpdatedat()
}
class Shelf {
  +String createdAt
  +Date price
  -double address
  +saveLevel()
  +deletePrice()
  +saveDescription()
  +deleteStatus()
}
class Publisher {
  -boolean description
  #double type
  -String createdAt
  -float address
  +sendNote()
  +createDescription()
  +processId()
}
interface Book {
  +int price
  -double name
  +double id
  +saveCode()
  +calculateQuantity()
  +sendPrice()
}
class Branch {
  -double name
  #String updatedAt
  -boolean quantity
  +findDescription()
  +validateAmount()
  +sendNote()
}
class Fine {
  +float price
  -long status
  +int duration
  +findStatus()
}
Fine ..|> Branch
Book ..> Fine : "0..1"
@enduml