@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
interface Author {
  #double price
  -String amount
  -Date name
  -int total
  +updateName()
  +sendAddress()
  +findName()
}
class Renewal {
  -boolean name
  #long phone
  +int id
  +validateCreatedat()
  +setAmount()
  +savePrice()
  +processNote()
}
abstract class Shelf {
  -long phone
  #boolean description
  -double type
  +long createdAt
  +updateActive()
  +cancelActive()
  +deletePrice()
}
class Publisher {
  -double name
  +double updatedAt
  +calculateTotal()
  +saveCreatedat()
  +cancelCreatedat()
}
class Book {
  #String quantity
  -boolean price
  -boolean type
  +updatePhone()
  +findDescription()
  +calculateStatus()
}
abstract class Branch {
  +String note
  #String phone
  #int status
  +setScore()
  +updateName()
}
abstract class Fine {
  #long createdAt
  -boolean status
  #boolean amount
  +int code
  +setStatus()
  +processDuration()
  +cancelTotal()
  +processCreatedat()
}
Shelf --* Publisher
Book --* Shelf
Branch --> Book : "1"
Fine --o Branch
Shelf ..|> Fine
note right of Author : Library domain
@enduml