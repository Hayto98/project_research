@startuml
skinparam monochrome true
skinparam ArrowColor #555555
interface Tracking {
  -double note
  -float address
  +Date createdAt
  -Date name
  #float description
  +sendUpdatedat()
  +sendName()
  +getName()
  +saveDescription()
}
interface Vehicle {
  #long duration
  #Date price
  #String address
  +getId()
  +findEmail()
  +createUpdatedat()
}
interface DeliveryNote {
  -Date description
  +double address
  +deleteActive()
  +updatePhone()
  +getTotal()
  +saveCode()
}
class Package {
  #double phone
  +int total
  +boolean price
  -double address
  +updatePhone()
  +processStatus()
  +calculateStatus()
  +setPhone()
}
abstract class Driver {
  +long active
  -Date type
  #Date email
  -int score
  +calculateCreatedat()
  +sendScore()
  +sendQuantity()
  +updateTotal()
}
Package ..> DeliveryNote : "0..1"
Tracking --o Vehicle
Vehicle --* Package
@enduml