@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Warehouse {
  +long price
  #Date updatedAt
  #float quantity
  #float address
  +sendAmount()
  +validateCreatedat()
}
class Route {
  +int code
  -boolean phone
  +calculateQuantity()
  +sendStatus()
  +findCreatedat()
  +setScore()
}
class Tracking {
  +float createdAt
  -String duration
  +saveScore()
  +cancelTotal()
  +validateStatus()
  +findDuration()
}
class Customer {
  #float address
  +double code
  +String email
  #int type
  +String active
  +deleteEmail()
  +createCode()
  +validateDuration()
}
class Shipment {
  -boolean score
  #Date note
  +sendEmail()
  +createUpdatedat()
}
abstract class Depot {
  #int total
  -Date price
  +long note
  +findAddress()
  +findAmount()
  +deleteAmount()
}
class FuelLog {
  -String id
  +Date quantity
  #int active
  #long email
  +createDuration()
  +getDescription()
  +calculateId()
}
Shipment --* Tracking
Depot ..> FuelLog : "1..*"
FuelLog ..|> Customer
Warehouse ..|> Route
@enduml