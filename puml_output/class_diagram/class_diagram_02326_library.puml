@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Shelf {
  -long quantity
  #boolean score
  +createCreatedat()
  +saveLevel()
  +cancelName()
}
interface Catalog {
  -boolean amount
  #int phone
  +createQuantity()
}
class Loan {
  #Date address
  #boolean description
  #Date total
  #boolean level
  +long createdAt
  +saveCode()
  +validateLevel()
  +getPrice()
  +calculateCode()
}
class Member {
  +double updatedAt
  #float status
  +saveAmount()
}
interface Author {
  #int address
  +Date score
  -Date id
  +saveCode()
}
abstract class Renewal {
  -long score
  -long quantity
  #long description
  +double type
  +Date total
  +getUpdatedat()
  +validateEmail()
}
interface Fine {
  #String type
  -String quantity
  #long amount
  #String duration
  #double active
  +createType()
  +sendUpdatedat()
  +saveStatus()
}
Renewal ..> Fine : "*"
Author --o Fine
note right of Shelf : Library domain
@enduml