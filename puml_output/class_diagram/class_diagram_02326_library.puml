@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Shelf {
  -long quantity
  #boolean score
  +updateLevel()
  +saveNote()
  +updateAddress()
}
interface Catalog {
  +int level
  -float score
  +getCreatedat()
  +setAddress()
  +sendId()
  +deleteTotal()
}
class Loan {
  #int quantity
  #float name
  -int note
  +Date address
  +deleteCreatedat()
}
abstract class Member {
  +double address
  -String level
  +updateActive()
  +findAddress()
  +updateQuantity()
}
class Author {
  #int price
  #boolean level
  +Date id
  +setAddress()
  +setName()
  +setPhone()
}
class Renewal {
  #String type
  -double name
  +setType()
  +deleteActive()
  +updateNote()
}
abstract class Fine {
  -int address
  #int email
  +int phone
  -float quantity
  -Date code
  +deleteLevel()
  +deleteActive()
  +calculateTotal()
  +findScore()
}
Member ..> Fine : "1"
Loan ..> Shelf : "1..*"
Renewal --> Shelf : "*"
@enduml