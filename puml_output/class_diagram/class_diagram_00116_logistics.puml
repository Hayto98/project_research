@startuml
skinparam monochrome true
skinparam shadowing true
class Vehicle {
  #float status
  #int phone
  #boolean total
  +boolean level
  +sendCreatedat()
  +validateQuantity()
  +sendId()
  +validateQuantity()
}
interface Tracking {
  #float code
  -String phone
  +saveName()
  +validateDuration()
  +createAddress()
  +findId()
}
class Depot {
  -int type
  -Date code
  +cancelStatus()
  +calculateCode()
}
abstract class Manifest {
  -String status
  #float level
  +updatePhone()
}
class Route {
  +Date id
  -Date email
  #boolean type
  -int note
  +long amount
  +calculateActive()
  +deleteNote()
}
class Inventory {
  #int note
  #Date price
  -String level
  +validateEmail()
  +calculatePrice()
  +setPhone()
}
Tracking --* Manifest
Tracking ..> Depot : "1..*"
Manifest --o Depot
Tracking ..> Route : "1"
note right of Vehicle : Logistics domain
@enduml