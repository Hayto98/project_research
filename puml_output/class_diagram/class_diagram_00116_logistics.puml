@startuml
skinparam monochrome true
skinparam shadowing true
class Vehicle {
  #float status
  #int phone
  #boolean total
  +boolean level
  +createDescription()
  +sendId()
  +cancelId()
  +getNote()
}
interface Tracking {
  #boolean address
  +String quantity
  +deleteEmail()
  +updateNote()
  +saveStatus()
}
class Depot {
  -boolean price
  -long name
  +updateAmount()
}
class Manifest {
  -int type
  -Date code
  +cancelActive()
  +cancelUpdatedat()
}
class Route {
  +boolean code
  +int total
  #long name
  #int status
  #double price
  +calculateScore()
}
abstract class Inventory {
  +int level
  -Date amount
  +double description
  #int email
  -int note
  +findLevel()
  +deletePrice()
}
Inventory ..> Manifest : "0..1"
Route --|> Depot
Depot --* Inventory
Manifest --|> Inventory
@enduml