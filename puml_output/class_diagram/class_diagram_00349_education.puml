@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Enrollment {
  +float price
  #long email
  #boolean active
  -float createdAt
  +String description
  +processPhone()
  +createCode()
  +updateDescription()
}
class Exam {
  +float id
  #String quantity
  +updateTotal()
  +getTotal()
  +processCode()
}
class Attendance {
  +boolean active
  #long createdAt
  -boolean description
  +updateAmount()
  +sendLevel()
}
class Classroom {
  -int id
  -Date amount
  +boolean email
  -float active
  #float phone
  +updateId()
  +sendId()
}
class Student {
  +Date type
  #Date email
  -float status
  -String address
  +findStatus()
  +setName()
  +setCreatedat()
  +processUpdatedat()
}
class Department {
  -Date level
  +String id
  #long quantity
  #boolean duration
  #int name
  +findStatus()
}
Classroom ..> Exam : "*"
Exam ..|> Classroom
@enduml