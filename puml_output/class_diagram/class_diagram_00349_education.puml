@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Enrollment {
  +float price
  #long email
  #boolean active
  -float createdAt
  +String description
  +deleteCreatedat()
  +updateActive()
  +findActive()
}
class Exam {
  +float duration
  #String quantity
  +validateCreatedat()
  +getUpdatedat()
  +sendLevel()
}
class Attendance {
  #long description
  -boolean code
  +int active
  +getAmount()
  +createActive()
  +validateNote()
  +deleteNote()
}
class Classroom {
  -float createdAt
  -String duration
  -int level
  #Date phone
  +calculateStatus()
  +calculateId()
  +findAmount()
  +validateActive()
}
abstract class Student {
  +float quantity
  +double level
  +setDuration()
}
class Department {
  +Date code
  -int status
  #double note
  +processScore()
  +saveActive()
}
Student --* Attendance
Exam ..> Student : "*"
Department ..> Exam : "0..1"
note right of Enrollment : Education domain
@enduml