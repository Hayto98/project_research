@startuml
skinparam ArrowColor #555555
class Supplier {
  -float description
  +boolean score
  +boolean phone
  -double price
  +getStatus()
  +setPhone()
}
abstract class Category {
  #String phone
  +int name
  #String type
  #boolean active
  +float status
  +validateScore()
}
abstract class Customer {
  -long type
  -Date phone
  -String score
  -int createdAt
  +double status
  +updatePhone()
  +calculateQuantity()
  +setEmail()
  +cancelTotal()
}
class Invoice {
  +float score
  #double note
  -Date code
  +calculateActive()
  +saveDescription()
  +getCode()
  +processAmount()
}
interface Review {
  #long amount
  +long status
  +setDuration()
}
Invoice --|> Customer
Invoice --> Category : "1"
@enduml