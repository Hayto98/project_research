@startuml
skinparam ArrowColor #555555
class Supplier {
  -float description
  +boolean score
  +boolean phone
  -double price
  +cancelType()
  +calculatePhone()
}
class Category {
  +Date active
  +Date status
  #String duration
  #Date code
  #String description
  +processTotal()
  +processPhone()
  +sendCreatedat()
}
class Customer {
  +float address
  +double phone
  -Date duration
  -long id
  +float note
  +saveAmount()
}
interface Invoice {
  #Date code
  #String description
  #float note
  +int address
  +boolean price
  +updateAddress()
  +cancelName()
  +getPrice()
}
class Review {
  #String note
  +Date amount
  +deleteNote()
  +processStatus()
  +findLevel()
}
Customer --o Invoice
Supplier --* Review
note right of Supplier : Ecommerce domain
@enduml