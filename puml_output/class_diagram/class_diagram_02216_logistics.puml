@startuml
skinparam monochrome true
skinparam defaultFontSize 13
interface Route {
  #double updatedAt
  +Date address
  -String id
  #String note
  +updateActive()
  +updateStatus()
  +createLevel()
}
class Customer {
  -Date active
  #long name
  #float description
  -long updatedAt
  -boolean total
  +updateUpdatedat()
  +processPhone()
  +getLevel()
}
class Package {
  +double quantity
  -boolean level
  -boolean code
  +double score
  #boolean phone
  +findNote()
  +cancelCode()
}
class Vehicle {
  -boolean description
  +int name
  +processLevel()
}
class Tracking {
  +boolean type
  -boolean status
  +double phone
  #int total
  +Date name
  +createPhone()
  +validateCreatedat()
}
Tracking --|> Route
Package --* Vehicle
note right of Route : Logistics domain
@enduml