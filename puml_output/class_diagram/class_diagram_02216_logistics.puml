@startuml
skinparam monochrome true
skinparam defaultFontSize 13
interface Route {
  #double updatedAt
  +Date address
  -String id
  #String note
  +validateNote()
  +processPhone()
  +calculateActive()
}
class Customer {
  #String quantity
  -boolean level
  +findPhone()
}
class Package {
  -boolean email
  #Date level
  #float address
  #Date total
  -int score
  +getUpdatedat()
  +createName()
}
class Vehicle {
  -Date level
  #long address
  +setPhone()
}
class Tracking {
  #int amount
  -Date price
  #int total
  #double email
  +deleteStatus()
}
Route ..|> Tracking
Route --> Package : "0..1"
Customer --o Route
Tracking --o Customer
@enduml