@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Depot {
  +Date phone
  -String total
  #int quantity
  +calculateCreatedat()
  +createEmail()
  +createDuration()
}
class Customer {
  -boolean phone
  +String address
  #float updatedAt
  #Date level
  +getStatus()
  +validateTotal()
}
class Package {
  -int active
  +Date code
  +float note
  +findAmount()
}
class Driver {
  +String id
  #String total
  +findType()
  +deletePhone()
  +cancelAddress()
  +deleteAddress()
}
class Tracking {
  +long active
  #double updatedAt
  -double note
  -Date price
  +calculateCode()
}
abstract class Route {
  -boolean type
  -long score
  +updatePrice()
}
Tracking --> Package : "1..*"
Customer ..> Tracking : "1..*"
Driver --> Depot : "1..*"
@enduml