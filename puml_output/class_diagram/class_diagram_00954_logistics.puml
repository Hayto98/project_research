@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Package {
  -double quantity
  -float total
  +saveScore()
  +validateScore()
  +deleteType()
  +calculatePhone()
}
class Shipment {
  -boolean address
  -boolean email
  #long amount
  +cancelId()
  +updateNote()
  +createAmount()
}
interface Customer {
  #long type
  #Date quantity
  #String phone
  +cancelActive()
  +findAddress()
  +sendActive()
}
class Driver {
  +String email
  #Date amount
  +boolean updatedAt
  +Date score
  +cancelPrice()
  +validateDuration()
  +findQuantity()
  +findEmail()
}
interface Warehouse {
  #Date address
  #long score
  -String note
  +setName()
  +cancelCode()
  +validateStatus()
  +validateCode()
}
Warehouse --* Package
Warehouse --> Driver : "0..1"
note right of Package : Logistics domain
@enduml