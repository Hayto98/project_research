@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Package {
  -double quantity
  -float total
  +setQuantity()
  +setScore()
  +calculateDuration()
  +findType()
}
class Shipment {
  #long type
  #Date price
  #int phone
  +sendPrice()
  +cancelType()
  +sendAddress()
}
class Customer {
  -boolean level
  #String note
  +Date active
  #double phone
  +calculateAddress()
  +createEmail()
  +createUpdatedat()
}
class Driver {
  #float quantity
  #float phone
  #long address
  #float name
  #boolean email
  +createDescription()
  +updateNote()
}
class Warehouse {
  +Date amount
  #int updatedAt
  #String level
  #double score
  +findQuantity()
  +findLevel()
  +sendActive()
  +setActive()
}
Customer ..> Warehouse : "0..1"
Customer --> Driver : "1..*"
Customer --o Package
Package --> Warehouse : "1"
@enduml