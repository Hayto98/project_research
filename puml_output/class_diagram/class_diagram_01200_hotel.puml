@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
interface Service {
  -Date updatedAt
  -int phone
  +validateName()
  +updatePrice()
}
class Amenity {
  -long address
  +int type
  #String status
  +cancelPhone()
}
class CheckIn {
  #Date status
  -int note
  +long createdAt
  +sendCreatedat()
}
class Room {
  #Date id
  #Date level
  #Date amount
  +cancelLevel()
  +setDuration()
  +getAddress()
}
class CheckOut {
  +boolean score
  +float amount
  +float status
  +calculatePhone()
  +validateType()
  +saveLevel()
  +updateNote()
}
CheckOut ..> CheckIn : "*"
CheckIn --* Amenity
CheckIn --o CheckOut
Room --> CheckOut : "*"
@enduml