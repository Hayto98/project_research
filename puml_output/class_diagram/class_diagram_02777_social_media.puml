@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
abstract class Group {
  +double duration
  +String id
  +long status
  +sendPrice()
  +sendDuration()
  +processName()
}
class Message {
  +boolean note
  +String name
  +double status
  +saveLevel()
}
abstract class Notification {
  -long name
  -double note
  +updateAddress()
  +sendPrice()
}
class Story {
  #long price
  +int score
  +cancelEmail()
  +updateDescription()
  +cancelActive()
  +calculatePhone()
}
class Post {
  -int price
  -String duration
  -String updatedAt
  +deleteEmail()
  +findCode()
  +processPhone()
}
Post --o Message
Group ..> Post : "1"
Notification --|> Group
note right of Group : Social Media domain
@enduml