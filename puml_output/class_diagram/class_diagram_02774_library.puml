@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
interface Member {
  -double active
  #int description
  #int phone
  +int email
  +createDescription()
  +updateLevel()
}
class Reservation {
  +String score
  #double amount
  +double name
  #int description
  -long email
  +findActive()
}
class Librarian {
  #Date phone
  #long total
  +double duration
  -double type
  +float level
  +saveNote()
  +setCreatedat()
  +sendPrice()
}
class Shelf {
  -Date level
  #float total
  +setLevel()
  +validateType()
}
Librarian --|> Reservation
Librarian --* Shelf
Member --* Librarian
note right of Member : Library domain
@enduml