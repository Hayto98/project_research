@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
interface Member {
  -double active
  #int description
  #int phone
  +int email
  +findCreatedat()
  +setType()
}
class Reservation {
  +int total
  -int score
  +Date amount
  +validateId()
  +setNote()
  +sendDuration()
  +createNote()
}
class Librarian {
  -Date email
  #long status
  -Date active
  -double amount
  +saveDescription()
  +getActive()
  +cancelActive()
  +createAmount()
}
class Shelf {
  +int price
  #double duration
  -String amount
  #double phone
  -Date note
  +cancelEmail()
  +getCode()
}
Shelf --* Reservation
Librarian --* Member
Librarian --> Shelf : "1"
@enduml