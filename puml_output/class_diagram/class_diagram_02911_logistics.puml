@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Depot {
  +float total
  +Date type
  -double level
  +double email
  -boolean active
  +saveCode()
  +sendId()
}
interface Driver {
  #String updatedAt
  +int duration
  -float email
  +processDescription()
  +sendAmount()
}
class Manifest {
  +long email
  #boolean createdAt
  +deleteType()
  +getStatus()
}
class Shipment {
  -double updatedAt
  #String active
  +calculateType()
  +createUpdatedat()
  +getPrice()
}
Manifest --> Shipment : "1..*"
Depot ..> Driver : "*"
note right of Depot : Logistics domain
@enduml