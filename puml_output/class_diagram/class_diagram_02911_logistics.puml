@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Depot {
  +float total
  +Date type
  -double level
  +double email
  -boolean active
  +processNote()
  +setDuration()
}
class Driver {
  +int score
  -boolean createdAt
  +findAddress()
}
class Manifest {
  +long amount
  +float note
  +long description
  #boolean duration
  +int address
  +sendStatus()
  +updateActive()
  +validateEmail()
  +deleteQuantity()
}
class Shipment {
  -long total
  +String code
  -boolean address
  #String duration
  +cancelAmount()
  +setAddress()
  +findQuantity()
}
Manifest --o Shipment
Shipment --|> Driver
@enduml