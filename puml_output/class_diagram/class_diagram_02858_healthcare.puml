@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Hospital {
  -String price
  #Date active
  #String code
  -int note
  +calculateDuration()
  +deletePrice()
  +processName()
  +processPrice()
}
class LabTest {
  #int note
  #int email
  +saveId()
  +processType()
  +sendLevel()
}
interface Nurse {
  #boolean amount
  +int email
  #long level
  -String updatedAt
  +getTotal()
  +findQuantity()
}
class Billing {
  -long note
  -float id
  +float amount
  +boolean name
  -Date total
  +findStatus()
  +processNote()
  +setPrice()
  +setLevel()
}
class Prescription {
  -long name
  +double level
  +updateDescription()
  +findId()
}
abstract class Ward {
  #String status
  #double level
  +int total
  -int score
  +findNote()
  +findCode()
  +calculateId()
}
Prescription --o Billing
Hospital --> Nurse : "*"
@enduml