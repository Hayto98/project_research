@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Hospital {
  -String price
  #Date active
  #String code
  -int note
  +sendNote()
  +getUpdatedat()
  +validateName()
  +findNote()
}
class LabTest {
  +double level
  #long updatedAt
  +long email
  +updateLevel()
  +cancelAmount()
  +deleteAddress()
}
abstract class Nurse {
  -long updatedAt
  -double createdAt
  +deleteName()
}
abstract class Billing {
  #double phone
  #Date type
  +int amount
  +String updatedAt
  #float address
  +createUpdatedat()
  +calculateUpdatedat()
  +updateAmount()
}
abstract class Prescription {
  #String status
  #double level
  +int total
  -int score
  +setPhone()
  +getName()
  +cancelPrice()
}
abstract class Ward {
  +boolean address
  -int note
  +updateTotal()
}
Hospital ..|> Nurse
Prescription --o LabTest
note right of Hospital : Healthcare domain
@enduml