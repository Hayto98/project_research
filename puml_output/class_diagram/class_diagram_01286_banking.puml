@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
abstract class Teller {
  #Date description
  #long updatedAt
  #long phone
  #boolean email
  #int total
  +getStatus()
  +calculateDuration()
  +updateDescription()
}
class Interest {
  +float email
  -String name
  -double createdAt
  +boolean code
  #long quantity
  +deleteDescription()
  +getAddress()
}
interface Deposit {
  #long note
  +boolean description
  #double address
  +getScore()
  +sendAmount()
  +processNote()
  +saveAmount()
}
class Account {
  -long level
  -boolean duration
  #boolean id
  +boolean address
  +saveCode()
  +saveCreatedat()
  +updateCode()
  +validateType()
}
Interest --|> Deposit
Deposit --|> Teller
Deposit --|> Interest
note right of Teller : Banking domain
@enduml