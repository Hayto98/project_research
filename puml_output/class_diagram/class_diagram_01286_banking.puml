@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
abstract class Teller {
  #Date description
  #long updatedAt
  #long phone
  #boolean email
  #int total
  +saveEmail()
  +setStatus()
  +saveName()
}
interface Interest {
  -String description
  +String status
  -String total
  +validateId()
  +processLevel()
  +sendName()
}
class Deposit {
  -Date updatedAt
  #int amount
  -int description
  -Date id
  +setQuantity()
  +setStatus()
  +getQuantity()
}
interface Account {
  -double note
  #Date name
  +float score
  +long active
  #boolean amount
  +setCode()
}
Account --o Interest
Interest --o Deposit
Teller ..> Deposit : "0..1"
@enduml