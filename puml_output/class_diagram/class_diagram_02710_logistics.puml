@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
abstract class Depot {
  -String active
  #boolean code
  #float address
  -Date id
  +updateCode()
}
class Vehicle {
  -boolean duration
  -int id
  #long quantity
  #long status
  #long name
  +setScore()
  +sendDuration()
  +updateCreatedat()
  +findScore()
}
interface Shipment {
  -double createdAt
  -long note
  +getCode()
  +saveName()
  +saveCode()
}
class Warehouse {
  #long amount
  +Date price
  -Date code
  +validateCode()
  +calculatePhone()
  +getName()
}
class Manifest {
  +int email
  +int code
  +saveLevel()
  +cancelEmail()
}
abstract class Route {
  #boolean total
  -String address
  +createCode()
}
Depot ..|> Shipment
Vehicle --* Warehouse
Manifest --* Route
Shipment --* Warehouse
@enduml