@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
abstract class Branch {
  #String name
  +double level
  +double address
  +setName()
  +saveTotal()
  +cancelAmount()
}
class Author {
  #long active
  -boolean email
  +getActive()
  +processNote()
  +getQuantity()
  +saveUpdatedat()
}
class Shelf {
  #String score
  #boolean type
  +double level
  #int address
  +deleteLevel()
  +createEmail()
  +setAddress()
  +savePrice()
}
abstract class Renewal {
  +String phone
  -long score
  -Date level
  #double note
  #double address
  +setDuration()
}
Branch --> Shelf : "*"
Author --|> Renewal
note right of Branch : Library domain
@enduml