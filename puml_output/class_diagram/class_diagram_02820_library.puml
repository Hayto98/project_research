@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
abstract class Branch {
  #String name
  +double level
  +double address
  +cancelEmail()
  +cancelPrice()
  +saveId()
}
abstract class Author {
  #float email
  -Date code
  -long active
  +calculateEmail()
  +findDuration()
  +getId()
  +saveAmount()
}
class Shelf {
  #boolean updatedAt
  #double status
  -Date quantity
  +boolean type
  +calculateQuantity()
  +validateTotal()
}
class Renewal {
  -Date amount
  -Date level
  -double email
  -Date score
  #boolean code
  +calculateName()
  +setPrice()
  +calculateType()
  +createScore()
}
Shelf --o Author
Renewal --o Shelf
@enduml