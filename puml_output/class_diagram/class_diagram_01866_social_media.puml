@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
abstract class Post {
  +Date note
  #String price
  +int score
  +boolean duration
  +deleteCode()
  +calculateDescription()
  +validateDescription()
}
abstract class User {
  #double total
  #int amount
  +boolean price
  +savePrice()
  +deleteAddress()
  +calculateScore()
}
class Group {
  -float duration
  #Date quantity
  #Date updatedAt
  -Date id
  +saveCreatedat()
  +getUpdatedat()
}
class Notification {
  -Date level
  +boolean createdAt
  +Date type
  -float amount
  +validateAmount()
  +processActive()
  +getId()
  +sendScore()
}
User --> Post : "0..1"
Group --|> User
Group --* Post
@enduml