@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
abstract class Customer {
  -long type
  -double name
  #String total
  +validateName()
  +updateTotal()
  +findUpdatedat()
}
class Shipment {
  +int score
  +double amount
  +cancelAddress()
  +cancelNote()
  +getEmail()
  +processQuantity()
}
class Driver {
  #double total
  -float description
  +Date id
  +deleteQuantity()
  +processName()
  +updateAmount()
  +cancelStatus()
}
abstract class Manifest {
  +Date code
  +double createdAt
  +boolean updatedAt
  +sendEmail()
  +calculateActive()
}
class DeliveryNote {
  -String code
  -long active
  -double total
  -Date price
  +setAmount()
  +calculateNote()
}
interface FuelLog {
  -Date active
  #float level
  #Date quantity
  -int id
  #Date updatedAt
  +validateActive()
  +processCode()
}
Manifest --* Customer
Driver --> FuelLog : "1"
Manifest --o DeliveryNote
Manifest --> Driver : "0..1"
Shipment ..> Customer : "0..1"
@enduml