@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
interface Follower {
  +double level
  -String code
  #float email
  +deleteId()
  +createStatus()
}
class Notification {
  +Date level
  +int total
  +cancelType()
  +processEmail()
}
class Comment {
  #long amount
  +int score
  #String level
  +findPhone()
  +deleteAddress()
  +deleteType()
  +setPhone()
}
abstract class Album {
  -long level
  -boolean amount
  -String quantity
  +Date type
  +updateEmail()
  +getId()
  +findQuantity()
  +createId()
}
class Like {
  -boolean status
  +float quantity
  #boolean email
  +getId()
  +updateAddress()
  +savePrice()
  +findQuantity()
}
Like ..> Comment : "*"
Follower ..|> Album
Comment --o Notification
@enduml