@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
interface Follower {
  +double level
  -String code
  #float email
  +sendCreatedat()
  +findScore()
}
class Notification {
  #float status
  #float name
  #int createdAt
  #int description
  #boolean updatedAt
  +updateUpdatedat()
  +saveCode()
  +processDescription()
}
class Comment {
  -long email
  -boolean level
  -String amount
  +Date quantity
  #float type
  +calculateType()
  +validateId()
  +sendDuration()
  +cancelCreatedat()
}
class Album {
  -Date email
  #long total
  #boolean id
  -Date type
  +getType()
  +updateDuration()
  +findQuantity()
  +validateCreatedat()
}
abstract class Like {
  -boolean level
  #String email
  +double id
  +calculatePhone()
  +deleteCode()
  +getPrice()
  +setQuantity()
}
Like ..> Notification : "0..1"
Comment ..|> Like
note right of Follower : Social Media domain
@enduml