@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class User {
  -long active
  +float id
  -int total
  -long status
  +findName()
}
class Follower {
  #Date email
  +boolean note
  +Date active
  +double createdAt
  +Date price
  +cancelCreatedat()
  +calculatePrice()
  +findUpdatedat()
}
class Group {
  #boolean active
  -float level
  #Date updatedAt
  -int code
  +saveLevel()
  +validateUpdatedat()
  +deleteActive()
  +getActive()
}
abstract class Message {
  +boolean amount
  +int createdAt
  +boolean status
  +sendEmail()
  +updateCreatedat()
}
class Album {
  -long active
  +double quantity
  #int amount
  +Date updatedAt
  +float duration
  +calculateId()
  +validateCode()
  +processName()
}
Group ..> Follower : "0..1"
User --> Album : "1..*"
note right of User : Social Media domain
@enduml