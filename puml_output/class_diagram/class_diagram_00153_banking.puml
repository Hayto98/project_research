@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Account {
  -Date phone
  -boolean active
  +Date code
  +updateCreatedat()
  +deleteActive()
}
class Beneficiary {
  -boolean level
  -long name
  +int score
  -int phone
  #float code
  +updateStatus()
  +sendActive()
  +getCreatedat()
}
class Customer {
  +float phone
  +double description
  +int type
  +validateCode()
  +createTotal()
  +saveCode()
  +cancelAddress()
}
class Teller {
  #double duration
  +float description
  -long amount
  +processActive()
  +validateDuration()
}
interface Deposit {
  +long status
  -String email
  +deleteScore()
  +sendNote()
}
class Branch {
  +Date amount
  #Date price
  -long createdAt
  #boolean status
  -String phone
  +deleteAmount()
  +findLevel()
  +deleteActive()
  +createTotal()
}
abstract class Interest {
  -long phone
  -double code
  #String duration
  +validateActive()
}
Beneficiary ..> Interest : "*"
Interest --|> Customer
note right of Account : Banking domain
@enduml