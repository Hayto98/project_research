@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Account {
  -Date phone
  -boolean active
  +Date code
  +calculateNote()
  +processActive()
}
class Beneficiary {
  #String type
  #Date level
  +findNote()
  +deletePrice()
  +calculateDuration()
}
class Customer {
  #float amount
  #long duration
  +Date phone
  +boolean createdAt
  +sendEmail()
}
class Teller {
  +float phone
  +double description
  +int type
  +setEmail()
  +findNote()
  +deleteName()
  +processLevel()
}
class Deposit {
  #double address
  +float updatedAt
  -long description
  #int amount
  +findDuration()
  +findQuantity()
  +sendActive()
  +cancelAmount()
}
interface Branch {
  +long status
  -String email
  +findPhone()
  +saveActive()
}
interface Interest {
  +long amount
  +Date price
  #Date duration
  -long level
  #boolean createdAt
  +calculateId()
  +getPhone()
  +findLevel()
}
Beneficiary --> Branch : "0..1"
Deposit --o Customer
Teller --* Beneficiary
@enduml