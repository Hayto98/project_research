@startuml
skinparam monochrome true
skinparam defaultFontSize 13
abstract class Reservation {
  -long updatedAt
  -float active
  -double status
  -String code
  +processScore()
  +saveStatus()
}
class Room {
  #String price
  #boolean name
  #String active
  -float duration
  +processLevel()
  +findPrice()
}
class Housekeeping {
  -double active
  -String phone
  +int duration
  -Date description
  +processCreatedat()
  +findScore()
  +getDuration()
  +createPrice()
}
class Amenity {
  +Date duration
  -double id
  +double code
  +createScore()
}
class CheckIn {
  -double note
  #Date description
  #double quantity
  -double createdAt
  +deletePrice()
  +deleteStatus()
}
Room --|> CheckIn
CheckIn --* Amenity
@enduml