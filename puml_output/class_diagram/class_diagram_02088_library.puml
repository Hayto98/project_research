@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Member {
  #double address
  +Date description
  +calculateType()
  +updateDuration()
}
class Branch {
  #int createdAt
  #long total
  +setStatus()
  +getAddress()
  +processType()
  +saveNote()
}
class Author {
  -int quantity
  +boolean price
  -double active
  +float note
  +processName()
  +getActive()
}
class Reservation {
  -double status
  #long total
  -String type
  -double phone
  -long createdAt
  +updateAmount()
}
abstract class Renewal {
  #Date status
  +Date amount
  +boolean name
  #int email
  +processLevel()
}
Branch --|> Author
Author --> Member : "0..1"
Author --> Renewal : "1..*"
@enduml