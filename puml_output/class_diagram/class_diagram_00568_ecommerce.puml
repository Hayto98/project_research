@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
abstract class Payment {
  #float type
  #String note
  #float quantity
  +deleteAmount()
}
class Return {
  +double price
  +int phone
  +float quantity
  -String active
  #boolean type
  +setUpdatedat()
  +getScore()
  +calculateTotal()
  +validateName()
}
class Invoice {
  +boolean score
  -boolean email
  -double type
  -long code
  +cancelDuration()
  +sendScore()
  +findActive()
  +findActive()
}
class Cart {
  +int duration
  #double address
  #double level
  -float email
  +deleteLevel()
  +findCode()
}
class Warehouse {
  #long type
  +boolean score
  #long address
  +sendDescription()
  +findActive()
  +createTotal()
}
abstract class Product {
  -boolean score
  #int id
  +createCreatedat()
  +updateId()
  +validatePrice()
  +updateQuantity()
}
Warehouse ..|> Return
Invoice ..> Product : "1..*"
Cart --o Warehouse
Warehouse ..> Cart : "0..1"
note right of Payment : Ecommerce domain
@enduml