@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
abstract class Payment {
  #float type
  #String note
  #float quantity
  +calculateAddress()
}
class Return {
  -boolean price
  -String duration
  -float phone
  +findId()
  +saveLevel()
}
abstract class Invoice {
  #Date level
  -String score
  +updatePrice()
  +setActive()
}
interface Cart {
  #long total
  -Date address
  #String name
  +boolean code
  -boolean email
  +cancelQuantity()
  +processDescription()
  +updateTotal()
}
abstract class Warehouse {
  +int phone
  #double address
  #double level
  -float email
  +validateCreatedat()
  +savePrice()
}
class Product {
  -Date amount
  -int type
  #Date score
  +validateAmount()
  +createStatus()
  +saveQuantity()
}
Cart --|> Product
Warehouse --* Payment
Warehouse ..|> Product
Cart ..|> Invoice
@enduml