@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
interface Classroom {
  #float active
  +String updatedAt
  +setDuration()
}
abstract class Enrollment {
  -double score
  +float phone
  +double createdAt
  +validateName()
}
class Grade {
  -int level
  #long price
  +getCode()
  +getEmail()
  +processType()
  +validateUpdatedat()
}
abstract class Assignment {
  #double name
  -int phone
  +double description
  -int level
  +int active
  +sendUpdatedat()
}
interface Book {
  -long status
  #boolean total
  -float address
  +boolean type
  +sendDuration()
}
Enrollment --o Classroom
Assignment --o Book
Assignment --* Classroom
note right of Classroom : Education domain
@enduml