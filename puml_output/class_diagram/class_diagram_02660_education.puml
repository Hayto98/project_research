@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
interface Classroom {
  #float active
  +String updatedAt
  +validatePhone()
}
interface Enrollment {
  -double active
  +float amount
  +double score
  #boolean phone
  +long createdAt
  +setName()
}
class Grade {
  +float address
  +long amount
  -double phone
  -int price
  -boolean name
  +calculateEmail()
  +saveUpdatedat()
  +sendPhone()
  +validateCode()
}
class Assignment {
  -long type
  +String total
  +boolean createdAt
  +boolean name
  +validatePrice()
  +createId()
}
interface Book {
  -long status
  #boolean total
  -float address
  +boolean type
  +createStatus()
}
Book --|> Enrollment
Assignment --o Book
@enduml