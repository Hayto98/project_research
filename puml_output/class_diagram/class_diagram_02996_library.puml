@startuml
skinparam defaultFontSize 11
abstract class Member {
  -boolean quantity
  +String description
  +getAmount()
}
class Shelf {
  -float amount
  #double total
  -double price
  +int quantity
  +long duration
  +setTotal()
  +cancelAmount()
  +updateLevel()
}
class Author {
  -float code
  -int level
  -double description
  -float duration
  +sendDuration()
  +getLevel()
  +updateDescription()
}
class Librarian {
  -Date email
  -float total
  #long phone
  +sendTotal()
  +saveName()
  +setAddress()
  +calculateCreatedat()
}
Librarian --|> Shelf
Member --o Shelf
@enduml