@startuml
skinparam defaultFontSize 11
abstract class Member {
  -boolean quantity
  +String description
  +saveId()
}
abstract class Shelf {
  +long total
  #double price
  -double quantity
  +deleteCode()
  +validateQuantity()
}
class Author {
  +double phone
  -int duration
  -double code
  -float description
  +saveCode()
  +updateQuantity()
  +updateEmail()
}
interface Librarian {
  +double phone
  #long quantity
  #Date duration
  +boolean score
  -long type
  +findCode()
}
Librarian ..|> Member
Member ..> Shelf : "1..*"
Member ..> Author : "*"
note right of Member : Library domain
@enduml