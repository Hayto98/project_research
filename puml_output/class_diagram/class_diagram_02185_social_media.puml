@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Post {
  +boolean status
  -long level
  +setType()
  +findUpdatedat()
}
class Profile {
  -String price
  -String active
  #double phone
  +sendCreatedat()
  +deleteEmail()
  +validateId()
}
interface Notification {
  #long code
  -boolean id
  #String price
  #double active
  -Date duration
  +getUpdatedat()
  +createId()
  +cancelId()
  +deleteLevel()
}
class Comment {
  -Date createdAt
  #float updatedAt
  -Date active
  -double address
  +saveTotal()
  +setScore()
}
class Story {
  -double score
  -float id
  +sendQuantity()
  +updateName()
}
class Message {
  +boolean price
  -boolean level
  +long type
  +sendLevel()
  +cancelLevel()
  +saveLevel()
  +cancelPhone()
}
class Album {
  +double amount
  +Date total
  +calculateActive()
  +createId()
  +deleteAmount()
}
Album --* Comment
Profile --|> Story
Message ..|> Notification
Story --o Message
note right of Post : Social Media domain
@enduml