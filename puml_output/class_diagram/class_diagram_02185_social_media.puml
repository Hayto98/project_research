@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Post {
  +boolean status
  -long level
  +updateName()
  +cancelScore()
}
abstract class Profile {
  -boolean phone
  -double active
  +float description
  +createAddress()
  +validateLevel()
  +validateActive()
  +deletePrice()
}
interface Notification {
  -float score
  +boolean createdAt
  -float amount
  +float email
  +createDuration()
}
interface Comment {
  #Date address
  +float note
  +saveScore()
  +calculateStatus()
  +processCreatedat()
  +calculateAmount()
}
class Story {
  +Date quantity
  #long id
  -Date level
  +processDuration()
  +findPrice()
}
class Message {
  #double phone
  +boolean total
  -Date level
  #String active
  #String updatedAt
  +getAddress()
  +sendCreatedat()
  +getPrice()
  +getEmail()
}
interface Album {
  -boolean updatedAt
  -int name
  #double description
  #int score
  +deletePrice()
  +getUpdatedat()
  +findDuration()
}
Story ..> Album : "1..*"
Post ..|> Album
Comment --o Post
Post ..> Message : "1..*"
Comment --* Story
Post ..|> Profile
@enduml