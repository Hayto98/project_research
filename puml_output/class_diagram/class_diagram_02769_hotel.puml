@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Guest {
  -boolean total
  -int type
  #int level
  +validateName()
  +sendType()
  +setCode()
  +deleteNote()
}
abstract class CheckOut {
  +float amount
  #String price
  #String note
  +cancelAddress()
  +validateQuantity()
  +updateEmail()
}
interface CheckIn {
  #double score
  +int name
  +calculateCreatedat()
  +setDuration()
  +processDescription()
}
class Service {
  #long status
  -int id
  +boolean description
  +boolean phone
  #float total
  +findCreatedat()
}
Service --> CheckOut : "1"
CheckOut ..|> Guest
Guest --* Service
@enduml