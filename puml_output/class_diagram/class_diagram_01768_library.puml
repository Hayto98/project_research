@startuml
skinparam monochrome true
skinparam defaultFontSize 11
interface Reservation {
  -Date amount
  #boolean duration
  +deleteLevel()
}
class Branch {
  +boolean level
  #Date description
  +processAddress()
  +deleteAmount()
  +validateEmail()
  +findId()
}
abstract class Loan {
  -long price
  +Date address
  +setEmail()
  +sendTotal()
}
abstract class Publisher {
  +boolean note
  #int total
  +long type
  +deleteCode()
  +setScore()
}
abstract class Librarian {
  -float total
  -String note
  #long id
  +float description
  +updateAmount()
  +createId()
  +getQuantity()
}
class Catalog {
  -long code
  -float total
  +Date level
  #int amount
  +boolean updatedAt
  +setAmount()
  +getScore()
  +findQuantity()
  +findId()
}
Loan --> Publisher : "*"
Reservation ..> Publisher : "1..*"
Branch --|> Publisher
@enduml