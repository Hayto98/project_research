@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class FuelLog {
  #double type
  +long score
  +Date email
  +updatePhone()
  +createAmount()
}
class Package {
  -Date createdAt
  +boolean code
  +double description
  +findNote()
}
class Manifest {
  #int price
  +long createdAt
  -Date description
  +updateName()
}
class Driver {
  +float code
  +double email
  +getLevel()
  +validateTotal()
  +cancelLevel()
  +cancelStatus()
}
abstract class Customer {
  -double price
  +Date score
  +String status
  +calculateCreatedat()
}
Customer ..|> Manifest
FuelLog --|> Customer
@enduml