@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class FuelLog {
  #double type
  +long score
  +Date email
  +savePhone()
  +createLevel()
}
interface Package {
  -Date createdAt
  +boolean code
  +double description
  +setName()
}
class Manifest {
  -Date createdAt
  #String description
  +String level
  +String id
  -int address
  +calculateTotal()
  +setCode()
}
abstract class Driver {
  -double price
  +Date score
  +String status
  +validatePhone()
}
interface Customer {
  +boolean description
  #long id
  -double score
  +float name
  +deleteNote()
  +createTotal()
}
Driver --|> Package
Customer --|> Driver
note right of FuelLog : Logistics domain
@enduml