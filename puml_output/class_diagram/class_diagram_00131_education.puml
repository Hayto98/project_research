@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Assignment {
  +String updatedAt
  +float amount
  +long createdAt
  -double email
  -int score
  +updatePhone()
}
class Teacher {
  +String active
  +Date createdAt
  #boolean duration
  +int status
  +findCode()
  +deleteStatus()
  +validateAmount()
}
interface Exam {
  +float updatedAt
  -long level
  +updateNote()
  +setUpdatedat()
  +getDescription()
  +sendStatus()
}
interface Attendance {
  -boolean active
  #float level
  +sendDescription()
  +createActive()
  +sendCreatedat()
}
class Library {
  -long score
  #boolean address
  #double type
  #double active
  +updateDescription()
  +processTotal()
  +saveDuration()
}
interface Course {
  +boolean total
  #float level
  +deleteUpdatedat()
  +cancelPhone()
}
Teacher --o Assignment
Exam --* Attendance
Course ..|> Exam
Exam ..|> Assignment
Exam --> Teacher : "1..*"
note right of Assignment : Education domain
@enduml