@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Assignment {
  +String updatedAt
  +float amount
  +long createdAt
  -double email
  -int score
  +processPhone()
}
class Teacher {
  #Date amount
  +String quantity
  +String active
  #Date createdAt
  +deleteAddress()
  +sendActive()
}
class Exam {
  -int amount
  #boolean status
  +processPrice()
}
interface Attendance {
  -int type
  -String phone
  +setName()
  +validateDescription()
}
class Library {
  +boolean active
  #long score
  +saveActive()
  +validateCode()
  +createQuantity()
}
interface Course {
  -Date phone
  -boolean email
  -long score
  +createUpdatedat()
  +sendCode()
  +findCode()
  +saveNote()
}
Attendance ..> Course : "1"
Attendance ..> Library : "0..1"
Library ..|> Teacher
@enduml