@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Product {
  #boolean address
  +Date duration
  +String phone
  +float total
  +sendPrice()
  +cancelActive()
  +findPhone()
}
abstract class Category {
  +double score
  -Date note
  +int type
  +saveEmail()
}
abstract class Cart {
  #int level
  -double price
  +int name
  +double note
  -long active
  +getType()
}
abstract class Return {
  -float score
  +Date phone
  +getDescription()
  +findId()
  +getAddress()
}
Cart --|> Product
Category --> Product : "1..*"
Product --|> Cart
@enduml