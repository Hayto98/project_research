@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class CheckIn {
  +boolean amount
  +double note
  -long id
  +int level
  +findEmail()
  +calculatePrice()
  +sendScore()
}
class Guest {
  #boolean note
  #String price
  +deleteDuration()
}
class Staff {
  +double updatedAt
  +float code
  -long type
  +String amount
  -long id
  +setActive()
}
class CheckOut {
  +float code
  -String active
  #Date note
  +createPhone()
}
interface Service {
  #double id
  -double name
  +float phone
  +createEmail()
}
Service --* CheckOut
Guest --o Service
Service --> CheckIn : "*"
CheckIn --o Service
@enduml