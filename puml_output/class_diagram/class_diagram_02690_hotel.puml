@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Amenity {
  +double code
  -String address
  #Date email
  #long total
  +deleteDuration()
  +setType()
  +updateActive()
}
class Staff {
  #String email
  +int score
  #Date name
  +updatePhone()
  +createId()
}
class Room {
  +Date address
  -boolean type
  +long email
  -int quantity
  +double score
  +sendEmail()
  +findAddress()
  +updateCode()
  +updateType()
}
class Guest {
  +boolean note
  -double createdAt
  +sendAddress()
  +calculateUpdatedat()
}
Staff --* Amenity
Guest ..> Room : "1..*"
note right of Amenity : Hotel domain
@enduml