@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Amenity {
  +double code
  -String address
  #Date email
  #long total
  +getName()
  +setPrice()
  +createCode()
}
interface Staff {
  #float type
  +Date createdAt
  +deleteName()
  +sendAmount()
}
class Room {
  #Date status
  #boolean createdAt
  +saveNote()
  +getStatus()
}
class Guest {
  -Date id
  #long duration
  #long type
  #float address
  +createNote()
  +deleteScore()
  +deleteEmail()
}
Amenity --* Staff
Staff --o Amenity
Guest --* Room
@enduml