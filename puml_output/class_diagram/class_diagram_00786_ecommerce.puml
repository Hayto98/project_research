@startuml
skinparam defaultFontSize 11
class Review {
  #int type
  -long createdAt
  #Date code
  #double id
  +long total
  +validateTotal()
  +findLevel()
  +getPrice()
  +findDescription()
}
class Shipment {
  -Date score
  -String active
  -float createdAt
  #float id
  +setPrice()
  +createScore()
}
interface Warehouse {
  -String status
  +int phone
  +cancelQuantity()
  +cancelDuration()
  +sendId()
  +saveName()
}
class Product {
  -float note
  #boolean duration
  +sendAmount()
  +processTotal()
  +findCode()
}
class Coupon {
  +boolean total
  -int updatedAt
  +boolean amount
  +getPrice()
  +saveDescription()
  +cancelDescription()
}
class Invoice {
  -double description
  +boolean quantity
  +int phone
  -Date code
  #int price
  +validateUpdatedat()
  +updatePhone()
  +sendDescription()
  +findId()
}
Invoice --* Coupon
Shipment ..|> Review
Warehouse --> Shipment : "0..1"
Invoice --* Review
note right of Review : Ecommerce domain
@enduml