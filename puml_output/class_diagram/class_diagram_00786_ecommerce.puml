@startuml
skinparam defaultFontSize 11
class Review {
  #int type
  -long createdAt
  #Date code
  #double id
  +long total
  +findQuantity()
  +sendDuration()
  +setNote()
  +cancelDescription()
}
interface Shipment {
  #String price
  -boolean description
  +updateDuration()
  +createName()
}
abstract class Warehouse {
  +double note
  -boolean description
  +validateEmail()
}
class Product {
  #double name
  #long id
  #boolean createdAt
  #String active
  +updateQuantity()
}
class Coupon {
  -float note
  #boolean duration
  +createStatus()
  +validateQuantity()
  +saveAmount()
}
abstract class Invoice {
  -int address
  #int createdAt
  +saveActive()
}
Shipment --> Invoice : "1..*"
Review ..> Product : "0..1"
Coupon --|> Shipment
Product --* Shipment
Warehouse --> Review : "*"
@enduml