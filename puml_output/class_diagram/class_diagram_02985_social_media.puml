@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Message {
  #int total
  +long address
  #double price
  +processPhone()
  +createTotal()
  +processTotal()
}
class User {
  #int name
  -String price
  +int address
  +getAmount()
  +getDescription()
  +cancelName()
  +deletePhone()
}
class Album {
  #boolean updatedAt
  #int description
  +double note
  +deleteNote()
  +deleteAmount()
  +savePrice()
}
class Report {
  -String price
  -String active
  +int amount
  +processNote()
}
Album --* Message
Album --> User : "0..1"
Album --> Report : "*"
note right of Message : Social Media domain
@enduml