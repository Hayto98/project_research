@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Message {
  #int total
  +long address
  #double price
  +sendDescription()
  +processTotal()
  +saveDescription()
}
class User {
  +String total
  #float type
  -Date duration
  -boolean updatedAt
  +processLevel()
  +cancelEmail()
}
class Album {
  +int note
  #float id
  #String amount
  +sendType()
  +saveScore()
}
class Report {
  #boolean updatedAt
  #int description
  +double note
  +sendStatus()
  +findId()
  +sendCode()
}
User --o Album
User --o Message
@enduml