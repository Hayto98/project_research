@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
interface Housekeeping {
  +int total
  #double active
  -double note
  +createEmail()
}
abstract class Guest {
  -int createdAt
  +double type
  -boolean phone
  +getDescription()
  +setActive()
}
abstract class Booking {
  -Date updatedAt
  #String price
  +int address
  +int amount
  -float active
  +createDuration()
  +sendEmail()
}
class Amenity {
  -String level
  +long phone
  #float amount
  -double description
  +setActive()
}
abstract class Restaurant {
  #boolean active
  +long type
  #long amount
  +setStatus()
}
class Invoice {
  -String phone
  #int total
  +long quantity
  -boolean level
  +processNote()
  +calculateAddress()
  +updatePhone()
}
class Staff {
  #boolean address
  -String active
  +saveDescription()
  +getId()
}
Housekeeping --o Guest
Staff --|> Invoice
Amenity --* Invoice
Amenity --|> Guest
Staff --o Amenity
@enduml