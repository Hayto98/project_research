@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
interface Housekeeping {
  +int total
  #double active
  -double note
  +calculateDescription()
}
class Guest {
  -boolean phone
  #Date duration
  +float description
  -boolean score
  -int type
  +validateLevel()
  +deleteAmount()
  +validateScore()
  +setDescription()
}
class Booking {
  +double description
  +String address
  +cancelPhone()
  +deleteDescription()
  +createStatus()
}
class Amenity {
  -int duration
  #Date price
  #double total
  +boolean code
  +createAddress()
  +setStatus()
}
class Restaurant {
  -String phone
  #int total
  +long quantity
  -boolean level
  +saveAmount()
  +saveCode()
  +getAddress()
}
interface Invoice {
  +float name
  -float description
  #String type
  -Date note
  -double code
  +getType()
  +calculateNote()
}
class Staff {
  +long description
  #boolean address
  -String email
  +sendTotal()
}
Guest ..> Staff : "1"
Restaurant --> Housekeeping : "1..*"
Staff ..> Booking : "1"
note right of Housekeeping : Hotel domain
@enduml