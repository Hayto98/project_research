@startuml
skinparam shadowing true
class Amenity {
  -long total
  #float address
  +processPhone()
  +setDuration()
}
abstract class Booking {
  #boolean email
  -boolean amount
  +Date description
  +String status
  -float type
  +calculateDuration()
  +updateCreatedat()
  +setPhone()
}
abstract class Staff {
  +long updatedAt
  -String code
  -double name
  +findTotal()
  +setQuantity()
  +findPrice()
  +setNote()
}
class Room {
  +Date quantity
  +float email
  -String createdAt
  #float note
  +cancelStatus()
  +findNote()
  +updateName()
  +calculateEmail()
}
Booking ..> Room : "1..*"
Amenity ..> Staff : "1"
Room --o Staff
@enduml