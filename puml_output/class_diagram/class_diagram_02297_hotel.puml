@startuml
skinparam shadowing true
class Amenity {
  -long total
  #float address
  +findNote()
  +findPrice()
}
class Booking {
  #boolean description
  -boolean status
  +Date type
  +setTotal()
}
class Staff {
  -double createdAt
  +double updatedAt
  -float code
  -float name
  #double description
  +findQuantity()
  +createEmail()
}
class Room {
  +String id
  +String name
  -Date note
  +long status
  #long score
  +findCode()
}
Room --o Booking
Amenity ..|> Booking
Booking --> Room : "*"
note right of Amenity : Hotel domain
@enduml