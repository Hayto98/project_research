@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
abstract class Account {
  #Date price
  +double phone
  +validateStatus()
  +saveTotal()
  +sendCreatedat()
  +calculateDuration()
}
interface Withdrawal {
  #boolean type
  #float email
  #double status
  +getActive()
  +getQuantity()
  +validateActive()
  +createAddress()
}
abstract class Transfer {
  #float active
  +int code
  #Date address
  #long note
