@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Order {
  -float type
  +boolean note
  #String id
  +boolean updatedAt
  -boolean email
  +sendDuration()
}
abstract class Product {
  +Date createdAt
  +boolean level
  -Date duration
  +cancelCreatedat()
  +validateDescription()
  +updateEmail()
}
class Payment {
  +double id
  -int note
  #double level
  #Date active
  #int phone
  +processStatus()
  +cancelLevel()
}
abstract class Shipment {
  -double active
  -int updatedAt
  #long createdAt
  -boolean name
  -float email
  +calculateTotal()
  +getActive()
}
abstract class Warehouse {
  -String createdAt
  -long status
  #String phone
  -long duration
  +String id
  +findPhone()
  +findType()
  +cancelType()
}
class Return {
  #boolean status
  #float score
  -String phone
  +createAmount()
  +calculatePhone()
  +updateEmail()
  +validateLevel()
}
abstract class Review {
  -String phone
  +int note
  #double id
  #int level
  +cancelType()
  +cancelLevel()
}
Order ..> Product : "1..*"
Shipment ..|> Warehouse
@enduml