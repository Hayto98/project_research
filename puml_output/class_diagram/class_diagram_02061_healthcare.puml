@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
interface MedicalRecord {
  #float address
  +int level
  +boolean quantity
  +cancelEmail()
  +processCreatedat()
}
class Doctor {
  +boolean level
  #boolean total
  #long description
  -Date quantity
  +processDuration()
  +processCode()
}
abstract class Prescription {
  +String status
  +boolean updatedAt
  -float total
  +processName()
  +validateScore()
  +validatePrice()
}
class LabTest {
  -String total
  +int status
  -double email
  +long phone
  -double level
  +calculatePhone()
  +calculateScore()
  +createAmount()
  +saveQuantity()
}
interface Appointment {
  +boolean createdAt
  +String price
  -String type
  +cancelAddress()
  +validateTotal()
}
MedicalRecord --> Doctor : "1"
LabTest ..> Prescription : "1"
Appointment --|> Doctor
LabTest --|> Appointment
@enduml