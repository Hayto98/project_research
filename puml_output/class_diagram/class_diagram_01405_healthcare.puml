@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Doctor {
  #int score
  +double description
  +validateCode()
  +cancelNote()
  +sendName()
  +validateAddress()
}
class Insurance {
  -Date description
  +Date name
  +saveStatus()
}
class Diagnosis {
  +double status
  -float amount
  -Date duration
  #boolean type
  +String active
  +createTotal()
}
abstract class Billing {
  #double phone
  +long status
  #double level
  -String total
  +findDuration()
}
class Ward {
  -int quantity
  -Date amount
  -String id
  +float email
  +String price
  +processLevel()
  +cancelCreatedat()
}
abstract class Nurse {
  -boolean score
  +Date note
  +boolean createdAt
  +validateDescription()
  +validateCode()
  +createId()
  +calculateDescription()
}
interface Hospital {
  -long description
  +int email
  +saveType()
  +cancelCreatedat()
  +sendScore()
}
Billing --|> Nurse
Doctor ..|> Billing
Billing ..> Diagnosis : "1"
Hospital ..> Diagnosis : "*"
note right of Doctor : Healthcare domain
@enduml