@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Doctor {
  #int score
  +double description
  +saveType()
  +setEmail()
  +findNote()
  +findUpdatedat()
}
abstract class Insurance {
  +String phone
  +Date address
  +getPhone()
}
class Diagnosis {
  -String status
  +String id
  +deleteDescription()
  +getCode()
  +validateType()
  +validateUpdatedat()
}
class Billing {
  #String type
  -double price
  -Date active
  -long amount
  +String code
  +sendAmount()
  +updateEmail()
  +updateDuration()
  +deleteCode()
}
abstract class Ward {
  +String code
  -boolean duration
  -double name
  +long note
  #long quantity
  +updatePrice()
}
class Nurse {
  #boolean amount
  #int type
  +validateCreatedat()
  +cancelAmount()
  +saveAmount()
  +saveNote()
}
class Hospital {
  #int id
  -String total
  -Date phone
  +sendStatus()
}
Insurance --|> Ward
Nurse --* Insurance
Diagnosis ..|> Hospital
Insurance --> Nurse : "1..*"
Hospital --o Nurse
@enduml