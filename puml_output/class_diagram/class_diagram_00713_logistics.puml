@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
interface Tracking {
  -boolean address
  +Date id
  -Date code
  +cancelName()
}
abstract class Manifest {
  -float id
  +boolean code
  -String active
  +double updatedAt
  -double price
  +deletePrice()
}
class Driver {
  -String amount
  +Date type
  #int phone
  +calculateQuantity()
}
class Route {
  #String total
  -Date phone
  #long email
  #String active
  +saveTotal()
  +getTotal()
  +validateStatus()
  +setActive()
}
class DeliveryNote {
  #Date level
  -int note
  #boolean createdAt
  #int description
  +createCreatedat()
  +sendDuration()
}
class Package {
  +float price
  -Date description
  +String quantity
  +long type
  #Date name
  +deleteQuantity()
}
abstract class FuelLog {
  #Date level
  #String score
  +getQuantity()
}
Tracking --> Driver : "*"
Tracking --|> Manifest
@enduml