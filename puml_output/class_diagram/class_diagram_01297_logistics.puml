@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
abstract class Shipment {
  -int createdAt
  +Date type
  +long phone
  +long amount
  +validateLevel()
  +deletePhone()
  +saveAddress()
}
abstract class Depot {
  #boolean price
  #String level
  +createName()
  +validateScore()
  +validateNote()
}
class Manifest {
  #long amount
  +long total
  +Date active
  -double note
  +validateScore()
  +sendScore()
}
class Tracking {
  -String email
  +boolean price
  +int createdAt
  +cancelLevel()
  +findCreatedat()
  +processTotal()
  +findLevel()
}
interface Customer {
  #String phone
  #long amount
  +String email
  -Date updatedAt
  +cancelLevel()
  +deleteCreatedat()
  +getType()
  +updateAddress()
}
class Package {
  #double status
  #double updatedAt
  #float code
  -int type
  #String description
  +getQuantity()
}
abstract class Route {
  -float email
  +float address
  #float quantity
  +boolean code
  +double type
  +calculateType()
}
Tracking --* Manifest
Manifest ..> Tracking : "1..*"
Tracking --> Customer : "1"
Shipment --|> Customer
Depot --o Route
Shipment --|> Tracking
@enduml