@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Group {
  +String active
  +String description
  #double type
  +int email
  +setActive()
}
class Post {
  #double email
  +double price
  +String id
  #long note
  +getType()
  +updateUpdatedat()
  +sendTotal()
  +createTotal()
}
interface Story {
  +int description
  +Date updatedAt
  +Date address
  +double amount
  -long quantity
  +validateActive()
}
class Album {
  #Date address
  #float total
  #int amount
  +findCode()
  +updateCode()
  +findCode()
}
Group --> Album : "1..*"
Group --o Post
Album --* Group
note right of Group : Social Media domain
@enduml