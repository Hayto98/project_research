@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Group {
  +String active
  +String description
  #double type
  +int email
  +processAmount()
}
interface Post {
  -boolean email
  -String duration
  -String price
  +Date id
  +findDescription()
  +deleteTotal()
  +findAmount()
}
class Story {
  -boolean updatedAt
  -float duration
  +int active
  -int total
  -int quantity
  +findAddress()
  +updatePhone()
}
class Album {
  -String note
  -boolean phone
  +deleteScore()
  +calculateCreatedat()
  +setNote()
}
Post ..> Album : "1"
Post ..> Group : "1"
@enduml