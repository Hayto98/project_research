@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
interface Statement {
  #long updatedAt
  #boolean note
  #float amount
  -Date status
  +deleteCode()
  +processScore()
}
abstract class Account {
  -long type
  +float updatedAt
  -Date code
  #boolean level
  +calculateDuration()
  +saveDuration()
}
class Transaction {
  -int active
  -long phone
  -String description
  -double level
  #Date duration
  +calculateId()
  +createQuantity()
  +processDescription()
}
class Withdrawal {
  +boolean duration
  -String amount
  #long description
  +int note
  -double score
  +findStatus()
}
abstract class Customer {
  +double price
  -double code
  +updateDuration()
}
abstract class Card {
  +String amount
  -float createdAt
  #long active
  +cancelId()
  +getTotal()
}
Customer --|> Withdrawal
Transaction --|> Customer
@enduml