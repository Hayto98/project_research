@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
interface Album {
  +double active
  #boolean status
  -String createdAt
  +sendId()
  +setNote()
  +findPrice()
}
abstract class Story {
  +boolean total
  -String active
  +setStatus()
  +cancelPhone()
  +calculateCode()
  +updateNote()
}
class Hashtag {
  +int level
  -Date updatedAt
  +cancelId()
}
class Group {
  -long description
  +boolean phone
  -float active
  +boolean status
  #Date level
  +validatePrice()
  +sendLevel()
  +validateLevel()
}
class Comment {
  -boolean quantity
  +boolean active
  -double code
  +boolean email
  #String createdAt
  +cancelDescription()
  +deletePrice()
  +validateDescription()
}
interface Post {
  #double name
  #long code
  #double quantity
  -String phone
  +boolean createdAt
  +processStatus()
}
class Like {
  +int level
  +long updatedAt
  -String note
  #int phone
  #float id
  +sendQuantity()
  +saveId()
  +findScore()
}
Post --|> Like
Like --|> Group
Hashtag ..|> Like
Comment --> Album : "0..1"
note right of Album : Social Media domain
@enduml