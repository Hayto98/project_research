@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
interface Album {
  +double active
  #boolean status
  -String createdAt
  +sendQuantity()
  +deleteStatus()
  +findType()
}
class Story {
  -String note
  -float price
  +findDescription()
}
abstract class Hashtag {
  +boolean total
  -double status
  +sendId()
}
abstract class Group {
  +float id
  +int level
  +createLevel()
  +processAmount()
  +findDescription()
}
class Comment {
  -boolean active
  #String total
  -long description
  +setDuration()
  +calculateLevel()
  +createId()
}
class Post {
  -double updatedAt
  #boolean active
  -float score
  #long email
  +setTotal()
  +setPrice()
  +createLevel()
  +sendActive()
}
interface Like {
  -boolean email
  +boolean createdAt
  +validateName()
  +createAddress()
  +cancelAmount()
}
Album --> Hashtag : "0..1"
Story --* Group
Story --> Comment : "*"
Post --|> Album
Like --* Hashtag
Comment ..> Story : "*"
@enduml