@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
abstract class Message {
  #boolean note
  +boolean phone
  #long active
  #String type
  +calculateScore()
  +createCode()
  +validateScore()
  +findNote()
}
class Hashtag {
  +long id
  -double description
  +String email
  +saveCreatedat()
  +processActive()
  +setCode()
}
class Like {
  -boolean quantity
  #int updatedAt
  +int total
  #String note
  +calculateStatus()
  +calculateTotal()
  +findNote()
  +setDuration()
}
class Post {
  #int note
  -String code
  +float duration
  #Date score
  +deletePrice()
  +processLevel()
  +updatePrice()
  +processAmount()
}
abstract class Story {
  -boolean email
  -float code
  +String note
  #Date type
  +String total
  +validateScore()
}
class Profile {
  #Date name
  #int active
  +createPhone()
  +updateTotal()
}
class Group {
  -long type
  #boolean name
  +validateAmount()
  +calculatePhone()
  +findEmail()
}
Group --* Profile
Like ..|> Post
Post --> Story : "1..*"
note right of Message : Social Media domain
@enduml