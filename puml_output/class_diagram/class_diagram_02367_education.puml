@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Attendance {
  -double total
  +int email
  -Date price
  #float status
  +updateAmount()
  +setEmail()
  +cancelType()
  +cancelAddress()
}
interface Enrollment {
  +double description
  -int amount
  -int phone
  -Date score
  -String createdAt
  +calculateId()
  +getStatus()
  +calculateEmail()
}
class Course {
  +Date score
  #boolean amount
  +sendPhone()
}
abstract class Schedule {
  #double id
  -String total
  +processActive()
  +validateType()
  +saveStatus()
  +deletePrice()
}
abstract class Teacher {
  +float quantity
  #long amount
  +setCreatedat()
  +cancelName()
  +calculatePrice()
  +findPhone()
}
interface Classroom {
  -String name
  #int id
  +float phone
  -double duration
  +String email
  +cancelName()
  +createAmount()
  +setTotal()
}
Classroom --|> Course
Attendance --> Enrollment : "1..*"
Course ..> Enrollment : "1..*"
Teacher --|> Enrollment
@enduml