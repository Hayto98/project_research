@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Attendance {
  -double total
  +int email
  -Date price
  #float status
  +validateQuantity()
  +cancelNote()
  +deleteAmount()
  +validatePhone()
}
class Enrollment {
  -int total
  -Date address
  -String updatedAt
  +getName()
  +createScore()
  +getScore()
}
class Course {
  -double duration
  +String status
  +cancelType()
  +validateCode()
  +calculateCreatedat()
  +processType()
}
class Schedule {
  #boolean amount
  #double id
  #Date score
  #int quantity
  +getId()
  +validateLevel()
  +getEmail()
  +calculateCode()
}
interface Teacher {
  +String id
  #long address
  #long total
  +sendPhone()
  +findQuantity()
  +setStatus()
}
class Classroom {
  +float quantity
  -boolean createdAt
  +float email
  #boolean amount
  +saveDuration()
  +setAddress()
}
Attendance --* Enrollment
Classroom ..> Schedule : "1..*"
note right of Attendance : Education domain
@enduml