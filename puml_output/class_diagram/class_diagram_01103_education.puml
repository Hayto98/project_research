@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
abstract class Grade {
  -Date total
  +boolean price
  +createEmail()
}
class Department {
  #long score
  #String phone
  +getName()
  +sendCreatedat()
  +findEmail()
}
interface Teacher {
  +boolean quantity
  +boolean updatedAt
  +updateAmount()
}
class Exam {
  +int duration
  -float score
  +getAmount()
  +sendStatus()
  +findUpdatedat()
}
Grade --o Teacher
Exam --* Teacher
Teacher --> Grade : "0..1"
note right of Grade : Education domain
@enduml