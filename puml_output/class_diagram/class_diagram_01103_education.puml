@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
abstract class Grade {
  -Date total
  +boolean price
  +deleteName()
}
class Department {
  #long code
  #String score
  #long phone
  +saveId()
}
interface Teacher {
  -int email
  +boolean active
  +boolean status
  +cancelNote()
}
class Exam {
  -float status
  #long score
  +float id
  +boolean createdAt
  +createLevel()
}
Teacher --> Grade : "*"
Exam --* Teacher
@enduml