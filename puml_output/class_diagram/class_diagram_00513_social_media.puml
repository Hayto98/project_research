@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Hashtag {
  #long description
  -boolean id
  #Date active
  +String type
  +int duration
  +findDescription()
}
interface Comment {
  -Date status
  #float email
  #Date address
  #Date duration
  +calculateAddress()
  +getUpdatedat()
  +setAmount()
}
abstract class Group {
  #long address
  -int active
  -boolean total
  +calculateActive()
}
abstract class Post {
  +Date note
  +double email
  +long duration
  +float total
  +boolean description
  +validateTotal()
  +calculateCode()
  +cancelDescription()
  +findCreatedat()
}
class Report {
  #double id
  +long duration
  +int price
  +int note
  +processCreatedat()
  +findPrice()
}
class Message {
  +long name
  -Date level
  +double quantity
  +validateDuration()
}
Message --* Report
Report --* Group
Hashtag ..> Report : "0..1"
@enduml