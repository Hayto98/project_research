@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Hashtag {
  #long description
  -boolean id
  #Date active
  +String type
  +int duration
  +cancelLevel()
}
interface Comment {
  -Date status
  #float email
  #Date address
  #Date duration
  +deleteTotal()
  +deleteAddress()
  +sendLevel()
}
abstract class Group {
  #float type
  -float createdAt
  #boolean total
  -double name
  +cancelNote()
  +calculateDescription()
  +setAmount()
}
abstract class Post {
  #double phone
  #double id
  #long code
  +cancelPhone()
  +getId()
}
abstract class Report {
  +int note
  #int status
  #long phone
  +String code
  #Date createdAt
  +getAddress()
  +createAmount()
  +processName()
}
class Message {
  -long active
  +boolean email
  #int score
  +setScore()
  +validatePrice()
}
Group --|> Post
Hashtag --> Message : "1..*"
Hashtag --* Comment
Comment --|> Report
note right of Hashtag : Social Media domain
@enduml