@startuml
skinparam defaultFontSize 11
class Attendance {
  -double level
  #float note
  -long status
  #float duration
  +sendCode()
  +validatePhone()
  +deleteNote()
}
class Grade {
  +float address
  +String name
  +processCode()
}
class Department {
  +Date type
  +int total
  -int quantity
  +cancelTotal()
  +cancelEmail()
  +createUpdatedat()
  +sendCode()
}
class Library {
  +Date phone
  #double active
  #String description
  +sendActive()
  +sendTotal()
  +createDescription()
  +setDuration()
}
abstract class Enrollment {
  -boolean amount
  -Date level
  +setUpdatedat()
  +findScore()
}
Library --o Department
Enrollment ..> Grade : "1..*"
@enduml