@startuml
skinparam defaultFontSize 13
interface Insurance {
  +boolean status
  +float address
  +double updatedAt
  -Date note
  #String createdAt
  +createPrice()
  +createActive()
  +calculateActive()
}
interface Appointment {
  -boolean type
  #int address
  #float createdAt
  #boolean duration
  +findCode()
}
abstract class Nurse {
  #float updatedAt
  +long email
  -String address
  +double id
  +sendTotal()
  +createNote()
}
class Prescription {
  +boolean address
  +String quantity
  +double updatedAt
  -String name
  +saveDescription()
  +cancelEmail()
}
class Hospital {
  #Date description
  -int email
  +int duration
  #boolean price
  +validateId()
  +updateActive()
  +createTotal()
  +deleteLevel()
}
Insurance --> Prescription : "1"
Hospital --o Nurse
@enduml