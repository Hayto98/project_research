@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Student {
  #double note
  -long updatedAt
  -double score
  +updateDescription()
}
abstract class Schedule {
  -Date duration
  #Date updatedAt
  +int createdAt
  +int total
  +calculateAddress()
  +getDuration()
}
abstract class Teacher {
  -String phone
  #Date description
  +Date name
  -long note
  +findCreatedat()
  +createEmail()
}
abstract class Classroom {
  #long score
  -String type
  -long status
  +cancelStatus()
  +findLevel()
}
class Enrollment {
  -boolean type
  #boolean name
  +double status
  #long description
  +findLevel()
}
Classroom --|> Enrollment
Enrollment --|> Classroom
Enrollment --|> Schedule
Student ..|> Teacher
@enduml