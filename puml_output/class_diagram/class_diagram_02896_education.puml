@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Student {
  #double note
  -long updatedAt
  -double score
  +updateType()
}
class Schedule {
  #Date createdAt
  #String total
  +int email
  +saveUpdatedat()
  +deleteTotal()
}
class Teacher {
  +Date description
  #float name
  +Date note
  -long type
  +createType()
  +saveCreatedat()
}
interface Classroom {
  -float status
  #int phone
  +float address
  #long name
  #long score
  +getStatus()
  +deletePrice()
  +cancelLevel()
  +sendDescription()
}
abstract class Enrollment {
  +Date active
  #boolean name
  #boolean price
  -String note
  +setId()
  +createDescription()
}
Teacher ..|> Classroom
Schedule --> Classroom : "1"
Classroom ..> Schedule : "*"
Student ..|> Teacher
note right of Student : Education domain
@enduml