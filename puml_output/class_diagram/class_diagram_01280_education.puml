@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
abstract class Course {
  +boolean amount
  +float code
  +saveName()
}
class Department {
  +long address
  +float duration
  -boolean id
  +int price
  +sendEmail()
  +saveLevel()
  +processPrice()
}
class Attendance {
  -Date level
  +long phone
  #String updatedAt
  +float amount
  +createCode()
  +validateCreatedat()
  +validateAmount()
  +updateType()
}
abstract class Enrollment {
  #Date code
  +Date email
  -double address
  #double duration
  +double name
  +setId()
  +deleteActive()
  +cancelName()
  +getName()
}
class Classroom {
  -double createdAt
  -int id
  #boolean level
  -long quantity
  #double note
  +processPrice()
  +createPhone()
}
Department --> Enrollment : "1"
Course --|> Attendance
@enduml