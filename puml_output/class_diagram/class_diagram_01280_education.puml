@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
abstract class Course {
  +boolean amount
  +float code
  +calculateCreatedat()
}
class Department {
  -int address
  -boolean id
  +int price
  -int code
  +createEmail()
  +cancelPhone()
}
class Attendance {
  #String email
  +float description
  -int phone
  +createAmount()
  +processTotal()
}
class Enrollment {
  #long address
  -boolean code
  -int name
  -double score
  +findCreatedat()
  +sendPrice()
  +updateId()
  +getQuantity()
}
abstract class Classroom {
  -Date total
  -int duration
  +String amount
  +int level
  +sendActive()
  +cancelName()
  +setPhone()
  +setEmail()
}
Enrollment ..|> Department
Department ..|> Classroom
Department ..> Attendance : "*"
note right of Course : Education domain
@enduml