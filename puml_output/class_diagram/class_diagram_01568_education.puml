@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Schedule {
  -long email
  +String total
  -boolean address
  -int type
  #Date createdAt
  +savePrice()
  +deleteUpdatedat()
}
class Exam {
  #int score
  -String price
  +float duration
  +long updatedAt
  +validatePrice()
  +findCode()
  +setAmount()
  +deleteCode()
}
interface Department {
  +Date duration
  -Date id
  #long price
  +Date description
  #String updatedAt
  +sendNote()
}
abstract class Attendance {
  +int description
  -Date status
  +sendLevel()
}
interface Enrollment {
  -int createdAt
  #float level
  +String note
  +String email
  +float amount
  +cancelEmail()
  +calculateId()
  +calculateStatus()
  +updateLevel()
}
Attendance --o Enrollment
Attendance --> Schedule : "0..1"
@enduml