@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
abstract class Album {
  -int description
  #Date duration
  #double note
  +sendType()
}
class User {
  -float note
  +int score
  +float updatedAt
  #float name
  +cancelType()
}
interface Notification {
  #boolean status
  -long createdAt
  #String level
  +double active
  #double updatedAt
  +processTotal()
  +calculateEmail()
  +saveCreatedat()
  +deleteLevel()
}
class Hashtag {
  -float code
  +double total
  +cancelPhone()
  +cancelAddress()
}
interface Post {
  -long updatedAt
  #int quantity
  -int duration
  +cancelLevel()
  +saveLevel()
  +createQuantity()
}
class Follower {
  -boolean type
  -long score
  -int amount
  -String description
  +float active
  +deleteType()
  +updateLevel()
  +cancelCreatedat()
  +getAddress()
}
class Report {
  #int level
  +Date total
  +saveDuration()
  +updateDuration()
  +getDuration()
}
Report --* User
Follower ..|> Notification
note right of Album : Social Media domain
@enduml