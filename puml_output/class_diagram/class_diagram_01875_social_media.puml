@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
abstract class Album {
  -int description
  #Date duration
  #double note
  +findPrice()
}
abstract class User {
  #float quantity
  #int note
  +updateEmail()
}
class Notification {
  #float code
  -boolean active
  #double status
  +calculateNote()
}
class Hashtag {
  #String level
  +double phone
  #double email
  +cancelQuantity()
  +getAddress()
  +deleteAmount()
  +deleteName()
}
class Post {
  +double level
  -float description
  +double status
  +findUpdatedat()
  +sendLevel()
}
class Follower {
  +long duration
  +long score
  -boolean active
  +double description
  +calculateScore()
  +deleteDescription()
}
interface Report {
  #int quantity
  +Date id
  +double type
  #long score
  +deletePrice()
  +setType()
  +updateTotal()
}
User --o Post
User ..|> Hashtag
@enduml