@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
interface Report {
  -Date price
  -Date quantity
  #float name
  #long duration
  +setAmount()
  +processEmail()
  +setNote()
  +findUpdatedat()
}
class Story {
  #double phone
  #String code
  -double amount
  -long name
  +processStatus()
  +findUpdatedat()
  +createPrice()
}
class Profile {
  -String name
  +long updatedAt
  -double note
  +calculateCreatedat()
  +getEmail()
}
class Post {
  +Date active
  +double duration
  -float id
  #float email
  -boolean status
  +processType()
  +deleteEmail()
}
abstract class Album {
  +float code
  +double score
  #String amount
  #String phone
  +boolean status
  +processPrice()
  +findUpdatedat()
  +findStatus()
}
abstract class Message {
  -boolean description
  -int createdAt
  +processScore()
  +calculateNote()
}
Album --|> Story
Post --> Report : "1..*"
Message --|> Album
Album ..|> Profile
@enduml