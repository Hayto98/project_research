@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
interface Report {
  -Date price
  -Date quantity
  #float name
  #long duration
  +cancelTotal()
  +cancelAddress()
  +createPhone()
  +setAmount()
}
class Story {
  -long level
  -boolean id
  -long address
  +String note
  +float active
  +calculateId()
  +updatePhone()
  +calculatePrice()
  +deleteAddress()
}
class Profile {
  #float type
  #boolean active
  +createStatus()
}
class Post {
  #int price
  -float phone
  -float level
  +setScore()
  +deletePhone()
  +sendStatus()
  +deleteUpdatedat()
}
abstract class Album {
  +boolean duration
  -int code
  +getDescription()
  +cancelCreatedat()
  +createDuration()
  +validateAmount()
}
class Message {
  +double address
  +boolean level
  -Date amount
  +sendQuantity()
}
Album --* Profile
Story --> Profile : "1"
Story ..> Message : "1..*"
note right of Report : Social Media domain
@enduml