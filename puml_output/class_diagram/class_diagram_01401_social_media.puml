@startuml
skinparam monochrome true
abstract class Comment {
  -float id
  #double email
  +float note
  -String price
  +processScore()
  +updateNote()
  +processTotal()
  +validateTotal()
}
interface Notification {
  +double quantity
  #int address
  #String code
  -int price
  #Date note
  +createActive()
  +updateName()
}
class Profile {
  -double active
  -double status
  -boolean level
  -boolean address
  +sendUpdatedat()
  +cancelTotal()
  +setUpdatedat()
}
interface Post {
  +long address
  #float active
  -double name
  +getType()
  +findActive()
  +setActive()
}
abstract class Album {
  #String code
  #float name
  +setNote()
}
class Follower {
  +Date description
  #long name
  +Date amount
  -int status
  +updatePhone()
  +processScore()
  +saveActive()
}
Post ..|> Profile
Post --o Follower
Comment --|> Profile
note right of Comment : Social Media domain
@enduml