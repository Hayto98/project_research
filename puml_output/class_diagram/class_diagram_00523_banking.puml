@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Card {
  -float code
  +int score
  -float createdAt
  +double duration
  +String total
  +sendEmail()
}
abstract class Transaction {
  +boolean createdAt
  +Date score
  +Date description
  #boolean phone
  +findCode()
}
class Customer {
  -String phone
  +Date address
  +findQuantity()
  +createActive()
  +cancelEmail()
  +getStatus()
}
class Loan {
  +String total
  #float address
  +updateDuration()
  +processTotal()
}
abstract class Beneficiary {
  +Date score
  #String note
  +float quantity
  +updateNote()
  +createAmount()
}
class Branch {
  #long note
  -int duration
  +getId()
  +setType()
}
Transaction ..> Beneficiary : "1..*"
Branch ..> Card : "*"
Card ..|> Beneficiary
Branch ..|> Beneficiary
@enduml