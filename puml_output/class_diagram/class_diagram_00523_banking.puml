@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Card {
  -float code
  +int score
  -float createdAt
  +double duration
  +String total
  +updateNote()
}
class Transaction {
  +boolean score
  +Date description
  +Date phone
  +validateEmail()
}
interface Customer {
  -String phone
  +Date address
  +validateAddress()
  +setAmount()
  +setTotal()
  +validateCreatedat()
}
class Loan {
  +boolean id
  -long note
  +Date price
  +setUpdatedat()
}
interface Beneficiary {
  #long description
  -int status
  +double note
  +long score
  +cancelAddress()
  +saveId()
}
interface Branch {
  -float name
  +float level
  -float amount
  -boolean updatedAt
  -long createdAt
  +calculateScore()
  +deleteScore()
  +saveNote()
  +getTotal()
}
Transaction --* Loan
Loan ..> Customer : "*"
Loan --o Card
Card --o Branch
Transaction ..|> Customer
note right of Card : Banking domain
@enduml