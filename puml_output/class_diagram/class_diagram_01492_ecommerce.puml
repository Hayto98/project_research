@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Warehouse {
  -int name
  #String phone
  -boolean price
  +long updatedAt
  +createPhone()
}
class Category {
  +String phone
  +Date amount
  +double active
  +String note
  +updateNote()
  +setType()
}
abstract class Shipment {
  -int duration
  -long note
  +float type
  -long score
  +findName()
  +setId()
  +deleteType()
  +saveId()
}
class Coupon {
  #float score
  #float id
  +long duration
  -boolean level
  +calculateCode()
  +calculateUpdatedat()
  +cancelNote()
  +validateStatus()
}
class Customer {
  #String updatedAt
  +long level
  +boolean status
  -String note
  +double address
  +setDuration()
  +cancelTotal()
}
class Return {
  #double score
  #double email
  -String name
  -Date note
  -long id
  +deleteName()
  +updateType()
}
class Wishlist {
  -Date code
  -String amount
  +int email
  +boolean total
  -float address
  +setStatus()
  +processQuantity()
}
Return --|> Customer
Shipment ..> Wishlist : "1..*"
Return ..|> Shipment
@enduml