@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Warehouse {
  -int name
  #String phone
  -boolean price
  +long updatedAt
  +setEmail()
}
class Category {
  +String amount
  #int active
  -int note
  +boolean code
  +sendDescription()
  +processEmail()
}
interface Shipment {
  -String type
  -long duration
  -boolean address
  #Date amount
  +int total
  +sendId()
  +sendId()
  +findLevel()
}
class Coupon {
  -float total
  -int note
  #String price
  -boolean createdAt
  +saveStatus()
  +getAddress()
  +updateActive()
}
class Customer {
  +String status
  -float total
  +sendEmail()
  +getNote()
  +getNote()
  +saveNote()
}
class Return {
  -Date phone
  +long type
  +updateNote()
  +saveCode()
}
class Wishlist {
  -Date level
  -String duration
  +int total
  +boolean address
  +saveUpdatedat()
  +setName()
  +saveQuantity()
  +saveScore()
}
Shipment ..> Wishlist : "1..*"
Return ..> Customer : "1..*"
note right of Warehouse : Ecommerce domain
@enduml