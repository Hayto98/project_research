@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
interface Cart {
  -float updatedAt
  +double active
  #float createdAt
  +calculateScore()
}
interface Supplier {
  #String code
  #int duration
  +getNote()
  +sendPrice()
  +setTotal()
  +cancelPrice()
}
interface Payment {
  -double updatedAt
  -double active
  -double address
  -int quantity
  #boolean duration
  +calculateCreatedat()
}
class Coupon {
  -boolean total
  #float type
  -float name
  -long score
  -String createdAt
  +createNote()
  +validateCode()
}
class Warehouse {
  #String active
  -long price
  #String quantity
  #long description
  +processDescription()
  +deleteTotal()
  +updateUpdatedat()
  +createCode()
}
class Review {
  #int code
  -long amount
  -Date phone
  -String name
  #boolean level
  +createType()
  +processId()
  +updateStatus()
  +calculateType()
}
interface Category {
  #long duration
  -double id
  -double status
  +deleteStatus()
  +deleteName()
  +createAddress()
}
Cart --* Supplier
Category --* Review
Category ..|> Coupon
Payment ..> Coupon : "1..*"
Review --|> Cart
Cart --o Category
@enduml