@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
interface Cart {
  -float updatedAt
  +double active
  #float createdAt
  +createLevel()
}
class Supplier {
  #String duration
  #int code
  +createQuantity()
  +saveDuration()
  +calculateUpdatedat()
  +findActive()
}
class Payment {
  -double updatedAt
  -float quantity
  -int type
  #boolean address
  +validateEmail()
}
abstract class Coupon {
  #Date type
  -float name
  -long level
  -String createdAt
  +int email
  +validateActive()
  +calculateQuantity()
  +deleteStatus()
}
abstract class Warehouse {
  -float score
  +int id
  #int address
  -String total
  +validateName()
  +cancelAmount()
}
class Review {
  #boolean phone
  +float type
  #int email
  #Date code
  +String price
  +processPrice()
  +validateNote()
  +createEmail()
}
class Category {
  #long amount
  -int email
  +calculatePhone()
  +findId()
  +setName()
}
Coupon --* Cart
Review --* Coupon
note right of Cart : Ecommerce domain
@enduml