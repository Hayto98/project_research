@startuml
skinparam defaultFontSize 13
class Appointment {
  +double code
  -long amount
  +boolean note
  #String total
  +getPrice()
  +cancelCode()
}
class Treatment {
  +long phone
  #double description
  -float score
  +double address
  #float type
  +cancelPhone()
}
abstract class Nurse {
  -String type
  +boolean email
  #Date level
  +Date status
  +findAmount()
  +setStatus()
  +findDuration()
}
class Insurance {
  -String phone
  +Date level
  -double type
  +String status
  +calculatePrice()
  +processStatus()
  +createScore()
  +sendScore()
}
abstract class Diagnosis {
  #String id
  +Date score
  -int price
  -boolean phone
  +setPrice()
  +processActive()
  +updateTotal()
}
interface Ward {
  #boolean duration
  #long total
  +long amount
  +Date code
  +getId()
  +setType()
  +cancelId()
  +getType()
}
abstract class Doctor {
  -double amount
  +double level
  -int type
  +setActive()
  +getCreatedat()
  +validateLevel()
}
Appointment ..> Nurse : "1..*"
Ward --* Treatment
@enduml