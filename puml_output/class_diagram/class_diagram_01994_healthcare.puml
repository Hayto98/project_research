@startuml
skinparam defaultFontSize 13
class Appointment {
  +double code
  -long amount
  +boolean note
  #String total
  +processAddress()
  +calculatePhone()
}
class Treatment {
  -float type
  +double amount
  #float quantity
  +long total
  +createType()
  +saveEmail()
  +createStatus()
  +processStatus()
}
class Nurse {
  +boolean address
  -long total
  +cancelLevel()
  +processStatus()
  +createName()
}
class Insurance {
  +double price
  -float createdAt
  -float name
  #String total
  #boolean phone
  +validateDuration()
  +setName()
  +savePhone()
  +updateEmail()
}
interface Diagnosis {
  #double createdAt
  +Date phone
  +boolean score
  #boolean address
  +getPhone()
  +setLevel()
  +processType()
}
class Ward {
  #float code
  -long total
  -int description
  -long amount
  +validateScore()
  +setName()
}
class Doctor {
  +float createdAt
  -Date quantity
  +boolean type
  -double phone
  +createCode()
}
Doctor --* Ward
Doctor ..> Appointment : "1"
note right of Appointment : Healthcare domain
@enduml