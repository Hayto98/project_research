@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
abstract class Loan {
  -long address
  +String amount
  +double note
  -Date email
  +setAmount()
  +getScore()
  +processStatus()
}
class Reservation {
  -double total
  -double updatedAt
  -double name
  -float price
  -boolean quantity
  +saveScore()
  +calculateCreatedat()
  +calculateActive()
}
interface Catalog {
  #double score
  #boolean email
  #Date phone
  -Date updatedAt
  +setNote()
}
class Fine {
  -Date email
  +float price
  +float active
  #String score
  +findCreatedat()
  +saveLevel()
}
class Librarian {
  +String price
  -float duration
  +createPrice()
  +updateUpdatedat()
}
Fine --* Librarian
Fine --o Catalog
Catalog --o Reservation
Librarian --o Fine
note right of Loan : Library domain
@enduml