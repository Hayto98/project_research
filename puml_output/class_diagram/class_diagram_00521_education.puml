@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
abstract class Schedule {
  -String total
  -long code
  +double note
  +String address
  +boolean score
  +calculateEmail()
  +saveTotal()
  +findUpdatedat()
}
abstract class Book {
  +long type
  +String code
  -float id
  #long price
  +createStatus()
  +updateType()
}
abstract class Enrollment {
  +long price
  -boolean id
  +float amount
  #long total
  #String description
  +sendId()
}
interface Exam {
  +int duration
  -long level
  +int name
  +float email
  +calculateScore()
  +sendTotal()
  +deleteActive()
  +saveType()
}
class Department {
  -double type
  -double updatedAt
  #double score
  #boolean duration
  #String total
  +saveScore()
  +cancelDuration()
  +processNote()
}
class Teacher {
  -long quantity
  -float description
  +boolean name
  +boolean score
  +int duration
  +calculateStatus()
  +saveUpdatedat()
  +sendPrice()
}
Schedule --* Exam
Enrollment --o Book
Schedule --> Enrollment : "1"
Book --|> Teacher
Teacher ..|> Book
@enduml