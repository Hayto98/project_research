@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Route {
  +String code
  #int email
  +boolean name
  +String phone
  +sendAddress()
}
class Manifest {
  -boolean level
  -int phone
  +validatePhone()
  +sendPhone()
  +setType()
}
interface Customer {
  -Date description
  #long level
  +double price
  +sendCode()
  +setCreatedat()
}
class Inventory {
  -Date name
  #boolean quantity
  -Date active
  #long status
  +sendType()
  +saveName()
}
abstract class DeliveryNote {
  -long name
  #double type
  +String score
  +validateScore()
}
abstract class Shipment {
  -String note
  -double phone
  -Date price
  #double email
  -boolean code
  +findPrice()
  +setStatus()
}
Shipment --|> Route
DeliveryNote ..|> Route
DeliveryNote --o Inventory
@enduml