@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Route {
  +String code
  #int email
  +boolean name
  +String phone
  +createDescription()
}
class Manifest {
  +long phone
  +float note
  #boolean description
  +int email
  +createQuantity()
  +getPrice()
  +deleteNote()
  +findEmail()
}
interface Customer {
  -Date name
  #boolean quantity
  -Date active
  #long status
  +calculatePrice()
  +updateName()
}
abstract class Inventory {
  +long email
  -Date price
  -double updatedAt
  -double status
  +cancelCode()
  +createStatus()
  +validateType()
}
abstract class DeliveryNote {
  +Date address
  +String active
  #String updatedAt
  +boolean level
  #float status
  +processActive()
  +calculateQuantity()
  +createQuantity()
  +updatePhone()
}
abstract class Shipment {
  #float amount
  #long duration
  +long quantity
  -boolean active
  +sendPrice()
  +findActive()
  +calculateAmount()
  +calculateId()
}
Inventory --|> Manifest
Route --o Inventory
note right of Route : Logistics domain
@enduml