@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Shelf {
  -Date updatedAt
  +long id
  -String level
  #boolean duration
  +boolean createdAt
  +cancelCreatedat()
  +processPrice()
  +createCode()
}
abstract class Loan {
  #long price
  +long quantity
  +boolean description
  +calculateTotal()
  +createPrice()
}
class Member {
  +long description
  +double type
  +deleteAmount()
  +cancelCode()
  +findPhone()
}
class Catalog {
  -String type
  #long total
  #boolean note
  #int amount
  +processPhone()
  +validateUpdatedat()
  +updateDescription()
}
class Reservation {
  -double email
  #float phone
  +double status
  +saveScore()
}
interface Librarian {
  #double address
  #long description
  +deleteEmail()
}
Reservation --|> Loan
Loan --|> Member
Librarian --o Loan
Catalog ..> Reservation : "0..1"
Loan --* Librarian
@enduml