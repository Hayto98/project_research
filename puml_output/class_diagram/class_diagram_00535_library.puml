@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Shelf {
  -Date updatedAt
  +long id
  -String level
  #boolean duration
  +boolean createdAt
  +calculateUpdatedat()
  +deleteType()
  +sendCreatedat()
}
abstract class Loan {
  -int level
  #int description
  -float address
  +float updatedAt
  +deleteType()
}
class Member {
  -double status
  +int type
  -double score
  -double phone
  +processId()
  +sendPhone()
}
interface Catalog {
  +Date quantity
  +long type
  #Date createdAt
  +setQuantity()
  +processStatus()
  +processCode()
}
class Reservation {
  #double address
  #long description
  +processDuration()
}
class Librarian {
  +Date amount
  #int quantity
  +processLevel()
  +saveDescription()
  +updateDescription()
  +createScore()
}
Catalog ..> Member : "0..1"
Shelf ..> Loan : "0..1"
Loan --|> Reservation
Librarian --* Catalog
note right of Shelf : Library domain
@enduml