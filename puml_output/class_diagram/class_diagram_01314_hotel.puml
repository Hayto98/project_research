@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
abstract class CheckIn {
  -float quantity
  #long updatedAt
  +Date level
  +int type
  +createName()
}
class Restaurant {
  +double phone
  -boolean duration
  +int code
  +boolean active
  -float name
  +createQuantity()
  +findAmount()
  +cancelCode()
}
abstract class Payment {
  -Date code
  -double level
  #double price
  +String name
  +String quantity
  +sendDuration()
}
class Booking {
  -long id
  #double createdAt
  -long email
  +Date description
  +saveActive()
  +deleteCreatedat()
  +sendType()
  +findScore()
}
CheckIn ..> Booking : "*"
Restaurant --> Booking : "1"
@enduml