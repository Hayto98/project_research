@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Staff {
  +int amount
  #int code
  #Date price
  +float address
  +getLevel()
}
class Booking {
  +long duration
  #long createdAt
  +Date score
  +validateStatus()
  +processPrice()
  +cancelAmount()
}
class Service {
  +float status
  +boolean level
  +createType()
  +findActive()
}
interface Invoice {
  -double code
  +double amount
  #long active
  #String address
  +findType()
  +validateAddress()
}
class Amenity {
  +long description
  #Date code
  +long id
  +Date address
  -Date name
  +processAddress()
  +sendQuantity()
  +processCreatedat()
  +processAddress()
}
class Housekeeping {
  #int updatedAt
  #long phone
  +boolean note
  +sendPhone()
  +validateCreatedat()
}
Staff ..> Amenity : "*"
Service --o Amenity
Amenity --> Service : "1..*"
note right of Staff : Hotel domain
@enduml