@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Staff {
  +int amount
  #int code
  #Date price
  +float address
  +processAddress()
}
class Booking {
  -Date description
  -int createdAt
  #boolean score
  -long amount
  +getUpdatedat()
}
abstract class Service {
  #int level
  +boolean amount
  #int status
  -double name
  #float score
  +cancelStatus()
  +calculateAddress()
  +findPrice()
}
class Invoice {
  +Date type
  -long createdAt
  -float duration
  -Date address
  #Date code
  +getEmail()
  +calculateTotal()
  +cancelStatus()
  +processCode()
}
class Amenity {
  #Date status
  +long quantity
  +deletePhone()
}
abstract class Housekeeping {
  +double note
  #long address
  -boolean active
  +int quantity
  -double type
  +saveDescription()
  +validateDuration()
}
Amenity --> Booking : "1..*"
Service ..|> Booking
@enduml