@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Service {
  #double type
  #boolean status
  +processId()
  +updateName()
}
interface CheckOut {
  +long level
  #Date amount
  +float createdAt
  +updateActive()
  +createPrice()
  +processAddress()
  +calculateType()
}
class Payment {
  +float name
  -String createdAt
  -String email
  +cancelId()
  +setActive()
}
abstract class Room {
  -long score
  #boolean total
  +findType()
}
class Restaurant {
  -String address
  #Date email
  -String updatedAt
  +processAddress()
}
class Booking {
  #int createdAt
  #boolean amount
  -float duration
  +cancelNote()
}
class Housekeeping {
  #boolean name
  +boolean duration
  +Date status
  #long email
  +saveDescription()
  +validateQuantity()
  +sendQuantity()
}
Room ..> Payment : "*"
CheckOut ..> Restaurant : "1"
@enduml