@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
interface LabTest {
  +String note
  +String amount
  +boolean quantity
  #float createdAt
  +cancelNote()
  +sendQuantity()
  +processTotal()
}
interface Ward {
  -boolean duration
  -Date status
  +createScore()
  +cancelCreatedat()
  +createCreatedat()
}
interface Patient {
  #double name
  -Date note
  +long email
  +createPhone()
  +sendPrice()
}
interface Appointment {
  #Date price
  #double type
  +long status
  #double note
  +int name
  +cancelUpdatedat()
  +deleteName()
  +cancelType()
}
class Doctor {
  #double code
  +long amount
  -float name
  +updatePhone()
  +validateAddress()
}
Doctor --o Appointment
LabTest --* Patient
@enduml