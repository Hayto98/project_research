@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
interface LabTest {
  +String note
  +String amount
  +boolean quantity
  #float createdAt
  +updateActive()
  +processDuration()
  +findLevel()
}
class Ward {
  -Date quantity
  -int score
  +deleteScore()
  +updateName()
  +findNote()
  +createTotal()
}
abstract class Patient {
  #int address
  +Date active
  +calculateType()
  +findStatus()
  +processName()
  +sendTotal()
}
class Appointment {
  #long price
  +int description
  +int level
  +boolean quantity
  +deleteAddress()
  +processUpdatedat()
  +saveEmail()
  +createLevel()
}
abstract class Doctor {
  +long id
  #boolean phone
  +int address
  -Date total
  +long duration
  +setAmount()
  +createUpdatedat()
  +findStatus()
}
Ward --|> LabTest
Doctor --* Appointment
note right of LabTest : Healthcare domain
@enduml