@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Depot {
  #long note
  -boolean updatedAt
  +createName()
  +setType()
}
class Tracking {
  #int status
  #int total
  +deleteTotal()
  +deleteCreatedat()
  +findAddress()
}
interface Inventory {
  #int status
  -int quantity
  +calculateScore()
  +processNote()
  +calculateStatus()
  +findCode()
}
class FuelLog {
  #float name
  +long updatedAt
  -boolean total
  +Date address
  +Date id
  +createPhone()
  +processTotal()
}
FuelLog ..|> Depot
Depot --* Tracking
note right of Depot : Logistics domain
@enduml