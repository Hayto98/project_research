@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Depot {
  #long note
  -boolean updatedAt
  +getNote()
  +deleteNote()
}
class Tracking {
  #int address
  #int score
  -int status
  -int level
  +Date total
  +getAmount()
  +validateActive()
  +getType()
}
class Inventory {
  -boolean createdAt
  -double total
  -String duration
  #String type
  +processEmail()
}
abstract class FuelLog {
  #float updatedAt
  -float total
  +getScore()
}
Inventory --> Tracking : "0..1"
Depot ..|> Inventory
@enduml