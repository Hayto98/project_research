@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Statement {
  -String price
  +float name
  +getAmount()
  +deleteEmail()
  +getAddress()
  +calculateAddress()
}
class Interest {
  #long address
  -String price
  #String updatedAt
  +long amount
  -long total
  +processPrice()
  +calculateAmount()
}
class Customer {
  -long address
  -Date description
  #double type
  -boolean id
  +boolean note
  +setLevel()
  +validateName()
}
class Branch {
  -String status
  #long id
  +String createdAt
  +double note
  +createType()
  +calculateLevel()
}
class Transaction {
  -float amount
  +double email
  -String type
  +getDescription()
}
class Loan {
  -double level
  #Date score
  +String duration
  -Date active
  +float phone
  +sendEmail()
  +calculateUpdatedat()
  +calculateEmail()
  +processEmail()
}
class Withdrawal {
  -String duration
  #boolean type
  -boolean status
  +int name
  -int total
  +saveActive()
  +saveStatus()
  +cancelStatus()
  +updatePhone()
}
Transaction --> Withdrawal : "1..*"
Branch --o Loan
Customer --> Interest : "*"
Withdrawal ..|> Interest
@enduml