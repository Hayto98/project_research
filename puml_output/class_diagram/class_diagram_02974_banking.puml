@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Statement {
  -String price
  +float name
  +saveTotal()
  +deleteAmount()
  +cancelNote()
  +validatePrice()
}
interface Interest {
  -double amount
  +boolean total
  +int active
  +createQuantity()
  +updateUpdatedat()
  +processEmail()
}
abstract class Customer {
  -long description
  -Date type
  #double id
  -boolean note
  +cancelCreatedat()
}
class Branch {
  -double phone
  +Date duration
  -String status
  +String id
  -int createdAt
  +findDuration()
  +deleteAmount()
  +createLevel()
}
abstract class Transaction {
  #float updatedAt
  -boolean total
  -boolean phone
  #boolean name
  #boolean id
  +validatePrice()
  +saveCode()
  +getEmail()
}
class Loan {
  #String createdAt
  +float name
  -double amount
  +boolean price
  #long type
  +deletePrice()
  +updateNote()
}
interface Withdrawal {
  #long total
  -Date active
  +createDescription()
  +cancelPrice()
  +updateCreatedat()
  +validateDescription()
}
Statement ..|> Interest
Branch --* Loan
note right of Statement : Banking domain
@enduml