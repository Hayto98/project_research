@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
abstract class LabTest {
  +String note
  +float score
  +createLevel()
}
interface Prescription {
  #Date id
  +double updatedAt
  -float type
  +updateAmount()
  +createPhone()
  +calculateNote()
}
abstract class Billing {
  +String createdAt
  -long address
  -long level
  -float amount
  +findUpdatedat()
  +updateQuantity()
  +calculateLevel()
  +validateCreatedat()
}
class Appointment {
  -long email
  #int score
  +Date price
  #float status
  +float note
  +processQuantity()
  +cancelId()
  +setPrice()
}
abstract class Ward {
  -String type
  #double note
  #boolean phone
  +processCreatedat()
  +processName()
  +createAmount()
  +saveTotal()
}
interface Diagnosis {
  +Date duration
  -long createdAt
  +Date total
  #int status
  +setAddress()
  +processId()
  +getActive()
  +saveType()
}
class Hospital {
  -String address
  #String type
  +boolean updatedAt
  #String name
  -boolean total
  +validateDescription()
}
Billing --o Appointment
LabTest --> Diagnosis : "1..*"
Prescription --|> Hospital
LabTest --* Hospital
Diagnosis --* Appointment
Diagnosis ..> Billing : "1"
@enduml