@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Fine {
  -double active
  #String level
  +Date quantity
  -long type
  +updateNote()
  +deleteTotal()
}
class Librarian {
  #String status
  #long note
  +saveLevel()
}
class Member {
  -int total
  +int name
  +float address
  -float active
  +processActive()
  +calculateCode()
  +setId()
  +validateLevel()
}
class Renewal {
  +long price
  #double status
  +deleteAddress()
  +findName()
  +savePhone()
}
class Loan {
  #double email
  -long amount
  -int phone
  +long level
  +getStatus()
}
abstract class Branch {
  -boolean score
  #boolean amount
  +long duration
  +processActive()
  +cancelNote()
}
Branch --> Member : "1..*"
Renewal --o Member
Renewal ..|> Branch
@enduml