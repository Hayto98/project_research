@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Fine {
  -double active
  #String level
  +Date quantity
  -long type
  +sendAddress()
  +getStatus()
}
abstract class Librarian {
  #Date quantity
  +long code
  +getAddress()
  +findScore()
  +findActive()
  +calculateCreatedat()
}
class Member {
  +double id
  #long price
  +double type
  +getPhone()
}
abstract class Renewal {
  -Date updatedAt
  -int level
  -Date name
  +float code
  +validateQuantity()
  +createDescription()
  +setEmail()
  +setType()
}
class Loan {
  #boolean score
  +long quantity
  +int active
  +deleteAddress()
  +cancelScore()
}
class Branch {
  #float phone
  -double total
  +String price
  +int score
  +Date description
  +saveTotal()
  +createLevel()
  +validateScore()
}
Librarian ..|> Fine
Renewal --* Loan
Member --* Loan
Branch --|> Fine
note right of Fine : Library domain
@enduml