@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Shipment {
  +float createdAt
  -double note
  +saveLevel()
}
interface Vehicle {
  -Date description
  +float score
  #float name
  +processAmount()
  +findActive()
  +setId()
  +calculateNote()
}
class Route {
  +Date type
  +Date name
  #Date email
  #long amount
  +saveStatus()
  +updateEmail()
  +processDuration()
}
class Inventory {
  -long level
  +double phone
  +sendPrice()
  +validateType()
}
interface Customer {
  +double total
  +long duration
  #long email
  -int note
  +sendPhone()
  +validatePhone()
}
class DeliveryNote {
  -String note
  -Date price
  -long id
  +saveStatus()
  +findLevel()
  +calculateAddress()
}
Inventory ..> Customer : "*"
DeliveryNote ..|> Vehicle
Shipment ..> Route : "*"
note right of Shipment : Logistics domain
@enduml