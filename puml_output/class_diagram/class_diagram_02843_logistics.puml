@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Shipment {
  +float createdAt
  -double note
  +calculateUpdatedat()
}
interface Vehicle {
  -Date description
  +float score
  #float name
  +findActive()
  +cancelDuration()
  +processScore()
  +setAmount()
}
class Route {
  #double id
  +long price
  +calculateEmail()
  +findCreatedat()
  +findId()
  +findEmail()
}
class Inventory {
  #boolean score
  -Date quantity
  +processPrice()
}
class Customer {
  -String duration
  -int id
  #double name
  -double phone
  #long type
  +cancelCreatedat()
  +calculateScore()
  +deletePrice()
  +sendDescription()
}
class DeliveryNote {
  +int createdAt
  #long quantity
  -long active
  +boolean address
  #float score
  +saveLevel()
  +deletePrice()
}
Shipment --|> Inventory
Inventory --* DeliveryNote
Route ..> Shipment : "*"
Route --o DeliveryNote
Customer ..> Inventory : "0..1"
@enduml