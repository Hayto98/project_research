@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
interface Schedule {
  -int description
  -float type
  +createTotal()
}
class Attendance {
  -double description
  +Date note
  -double quantity
  +boolean active
  +sendActive()
  +calculateName()
  +cancelDescription()
}
interface Exam {
  #Date phone
  #float level
  +createAddress()
  +cancelNote()
  +cancelCreatedat()
}
class Course {
  #String price
  +double email
  #String level
  #float status
  +getId()
  +saveType()
  +findPrice()
  +getLevel()
}
class Student {
  #float note
  #long name
  #Date active
  +int price
  -int email
  +setId()
}
Exam --> Attendance : "1..*"
Schedule --|> Attendance
Schedule ..> Exam : "*"
note right of Schedule : Education domain
@enduml