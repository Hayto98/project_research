@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
interface Schedule {
  -int description
  -float type
  +deleteName()
}
abstract class Attendance {
  -long quantity
  #double description
  +processDuration()
  +cancelUpdatedat()
  +sendDescription()
  +saveTotal()
}
class Exam {
  +boolean description
  #int level
  #String email
  -float active
  #boolean total
  +getNote()
  +validateDuration()
  +setPhone()
}
abstract class Course {
  -float id
  -String address
  #String price
  +updateEmail()
}
interface Student {
  +String score
  #double type
  +calculateEmail()
  +getStatus()
  +savePrice()
  +getType()
}
Course --> Schedule : "*"
Exam --> Student : "0..1"
Attendance ..|> Course
@enduml