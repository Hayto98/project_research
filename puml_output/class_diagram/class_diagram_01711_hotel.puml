@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Service {
  -double duration
  +Date address
  +deleteEmail()
}
class Amenity {
  #float price
  -boolean note
  -Date code
  -boolean score
  +deleteLevel()
}
interface Reservation {
  #float updatedAt
  +float description
  #Date score
  -float createdAt
  +sendEmail()
}
class Staff {
  +int id
  #float createdAt
  -long updatedAt
  -boolean email
  #boolean note
  +getPhone()
  +savePhone()
}
interface Housekeeping {
  #double score
  #boolean email
  #boolean duration
  +cancelStatus()
}
Amenity --o Reservation
Housekeeping ..|> Reservation
Reservation --o Service
@enduml