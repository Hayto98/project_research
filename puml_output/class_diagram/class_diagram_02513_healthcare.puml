@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
abstract class Billing {
  -double type
  #float total
  +Date duration
  +float score
  +updateStatus()
  +saveStatus()
  +saveAmount()
  +createDescription()
}
class MedicalRecord {
  -Date total
  +int amount
  +String score
  +boolean level
  +String updatedAt
  +sendAddress()
  +processUpdatedat()
}
class Insurance {
  +Date active
  #float total
  +String address
  +setCreatedat()
}
abstract class Diagnosis {
  +double name
  -String code
  +processScore()
  +setAmount()
  +validateCreatedat()
}
class Hospital {
  #double code
  +int amount
  +Date total
  +cancelScore()
  +getDescription()
  +validateLevel()
}
abstract class Prescription {
  -float id
  #float duration
  #boolean phone
  +long amount
  -Date type
  +calculateTotal()
  +cancelType()
}
Diagnosis ..|> Prescription
Insurance --|> MedicalRecord
Prescription --> Billing : "1"
Prescription --o Diagnosis
Prescription --o MedicalRecord
@enduml