@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
interface Room {
  -String code
  -double amount
  +saveAmount()
  +sendDescription()
}
class Invoice {
  -int email
  +double id
  +int amount
  -String updatedAt
  #float address
  +processNote()
}
class Service {
  -float email
  -int description
  +int score
  #double code
  #double level
  +validatePhone()
  +processCode()
  +saveLevel()
}
class Amenity {
  #Date status
  +double code
  -long active
  +String type
  +int id
  +processPrice()
}
Service ..|> Invoice
Invoice --|> Room
Invoice ..> Amenity : "0..1"
@enduml