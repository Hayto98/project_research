@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Like {
  -Date level
  -boolean total
  -float price
  +long active
  +setNote()
}
abstract class Album {
  -int duration
  +long total
  #long updatedAt
  +sendPrice()
}
class User {
  -double amount
  #float createdAt
  -int duration
  +String score
  +processDescription()
  +updateCreatedat()
}
class Hashtag {
  +int name
  +Date duration
  +validateEmail()
  +findScore()
}
class Message {
  +long createdAt
  +float email
  +findCode()
}
class Report {
  #boolean active
  +float id
  #int type
  +int quantity
  +findName()
  +getNote()
}
class Notification {
  -long score
  +String total
  -float active
  -long level
  +cancelPrice()
  +saveId()
  +validateCode()
}
Hashtag --|> Notification
User --o Like
Report --> Hashtag : "1..*"
@enduml