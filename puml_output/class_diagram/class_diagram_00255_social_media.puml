@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Like {
  -Date level
  -boolean total
  -float price
  +long active
  +calculateTotal()
}
class Album {
  #long updatedAt
  +Date quantity
  -long amount
  +int status
  #int phone
  +createTotal()
  +cancelEmail()
}
class User {
  -float name
  +String description
  +getId()
}
class Hashtag {
  #Date createdAt
  -float status
  +Date quantity
  +createDescription()
  +createAmount()
}
class Message {
  #Date status
  #double quantity
  -Date active
  #String id
  +updateCreatedat()
  +findActive()
}
class Report {
  #double id
  -long level
  +String address
  -float total
  +validateQuantity()
  +saveName()
  +deleteDescription()
}
abstract class Notification {
  #long name
  #boolean email
  +long id
  #float type
  #long total
  +findDescription()
}
Hashtag --o Report
Like --|> Report
Like ..> Album : "1"
note right of Like : Social Media domain
@enduml