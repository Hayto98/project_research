@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Grade {
  -float price
  -float amount
  -float duration
  +deletePhone()
  +createType()
  +validateCode()
  +createEmail()
}
interface Book {
  -Date note
  +double type
  +Date description
  +setPhone()
  +findEmail()
  +createType()
}
abstract class Schedule {
  -float code
  -int score
  #float id
  #Date active
  +boolean quantity
  +findAmount()
}
class Enrollment {
  -double updatedAt
  #boolean active
  +Date price
  +sendEmail()
  +setCreatedat()
}
Schedule --|> Grade
Grade --|> Enrollment
Enrollment --> Book : "1..*"
note right of Grade : Education domain
@enduml