@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Grade {
  -float price
  -float amount
  -float duration
  +getPrice()
  +getEmail()
  +createAmount()
  +validateAmount()
}
abstract class Book {
  -float code
  -int email
  -Date level
  +double description
  +cancelDuration()
}
class Schedule {
  -double phone
  -double email
  +saveActive()
}
class Enrollment {
  #Date quantity
  +boolean price
  #String amount
  #int active
  +sendNote()
  +findAddress()
  +setDuration()
}
Enrollment ..> Book : "1"
Book ..> Schedule : "1..*"
Grade --> Enrollment : "1..*"
@enduml