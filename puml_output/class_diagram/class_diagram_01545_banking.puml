@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Branch {
  +int description
  -Date level
  +String duration
  +Date active
  +findScore()
  +validateDescription()
  +cancelCode()
}
abstract class Loan {
  -boolean phone
  +boolean quantity
  -long level
  +long amount
  #Date note
  +setDuration()
  +setId()
}
abstract class Transfer {
  #double level
  +int id
  -String total
  #int type
  +processStatus()
  +calculateTotal()
  +deleteTotal()
  +validateDescription()
}
class Teller {
  #long email
  #float type
  #int level
  #int code
  +int total
  +updateEmail()
  +saveDescription()
  +processNote()
  +getPrice()
}
abstract class Interest {
  #long level
  +Date phone
  #int createdAt
  -Date status
  -String description
  +processDescription()
  +createCode()
  +processDuration()
  +processAmount()
}
Loan ..> Branch : "1"
Transfer --o Loan
Branch ..|> Loan
Transfer --|> Interest
note right of Branch : Banking domain
@enduml