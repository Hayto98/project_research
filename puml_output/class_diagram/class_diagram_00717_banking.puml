@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
interface Statement {
  #boolean description
  +Date price
  +long quantity
  -int email
  #int active
  +setActive()
}
class Beneficiary {
  #float code
  +int email
  +calculatePrice()
  +setTotal()
  +validateUpdatedat()
  +getScore()
}
class Teller {
  #long note
  +long code
  #float phone
  +float duration
  -float updatedAt
  +sendCode()
}
interface Transaction {
  -int type
  -double email
  +boolean quantity
  #long amount
  +createType()
  +getUpdatedat()
  +sendTotal()
  +findName()
}
Teller --> Statement : "*"
Statement ..> Beneficiary : "*"
@enduml