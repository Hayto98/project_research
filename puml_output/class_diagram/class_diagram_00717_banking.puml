@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
interface Statement {
  #boolean description
  +Date price
  +long quantity
  -int email
  #int active
  +deleteStatus()
}
class Beneficiary {
  #long active
  -boolean id
  #int amount
  -float type
  +setDuration()
  +validateNote()
  +updatePhone()
  +setPhone()
}
interface Teller {
  -Date email
  #long id
  +createQuantity()
  +deleteAddress()
  +deleteAddress()
  +processCode()
}
interface Transaction {
  +float price
  #double id
  +double quantity
  #Date email
  +cancelCode()
  +validateTotal()
  +processCreatedat()
  +calculateAddress()
}
Beneficiary --|> Statement
Teller ..> Transaction : "1"
note right of Statement : Banking domain
@enduml