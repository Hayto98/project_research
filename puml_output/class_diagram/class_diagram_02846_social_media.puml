@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Profile {
  -String name
  -String phone
  +setAddress()
  +setTotal()
}
class Group {
  +double type
  +String phone
  +setEmail()
  +validateAmount()
}
interface Hashtag {
  +long id
  +Date createdAt
  +boolean code
  +int score
  +processNote()
}
interface Post {
  +String address
  #double amount
  +createTotal()
  +validateActive()
  +deleteAddress()
  +cancelId()
}
Post --> Group : "1"
Hashtag ..> Group : "0..1"
Post --|> Hashtag
@enduml