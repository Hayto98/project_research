@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Profile {
  -String name
  -String phone
  +sendQuantity()
  +getName()
}
abstract class Group {
  #int updatedAt
  -long note
  #Date code
  -float status
  +findCreatedat()
}
class Hashtag {
  +Date description
  +boolean quantity
  +deleteActive()
}
class Post {
  +String address
  #double amount
  +findDuration()
  +updatePhone()
  +cancelPrice()
  +processTotal()
}
Hashtag ..> Group : "0..1"
Post --|> Hashtag
note right of Profile : Social Media domain
@enduml