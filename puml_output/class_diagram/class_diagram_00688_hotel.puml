@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Invoice {
  +long level
  -boolean price
  +double total
  -long duration
  +validatePrice()
  +cancelCode()
  +deletePrice()
  +findType()
}
class CheckOut {
  #float description
  +double duration
  -double price
  +long status
  -int email
  +setEmail()
  +createType()
}
class Payment {
  +int amount
  #long status
  +updateAddress()
  +processNote()
  +processPhone()
}
abstract class Housekeeping {
  -long quantity
  +long total
  -int type
  +createDescription()
  +processDuration()
  +processPrice()
}
class Guest {
  #long active
  #int status
  +Date createdAt
  -boolean amount
  -long email
  +createCreatedat()
}
class Booking {
  +float note
  +Date id
  #float description
  +createAddress()
  +setCode()
  +calculateId()
  +sendPhone()
}
Payment --> CheckOut : "0..1"
CheckOut ..|> Payment
Housekeeping ..> Guest : "0..1"
@enduml