@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Manifest {
  +int updatedAt
  -double code
  -Date level
  +updateId()
}
class Vehicle {
  -Date amount
  #String type
  +boolean quantity
  +getDescription()
}
class Depot {
  -float updatedAt
  #Date type
  +createTotal()
}
interface Driver {
  +boolean name
  #float createdAt
  +float quantity
  #float status
  +validateType()
}
class Inventory {
  +float amount
  -float price
  +getId()
}
interface Tracking {
  -String note
  -double type
  #Date id
  -float price
  +Date total
  +cancelCode()
  +updateType()
  +saveQuantity()
}
class Warehouse {
  -int duration
  -boolean description
  +deleteAddress()
  +updateLevel()
}
Inventory ..|> Manifest
Manifest --|> Depot
Warehouse --|> Vehicle
Tracking --* Inventory
Tracking --* Vehicle
note right of Manifest : Logistics domain
@enduml