@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Manifest {
  +int updatedAt
  -double code
  -Date level
  +processPrice()
}
class Vehicle {
  -long amount
  -Date duration
  +findId()
}
interface Depot {
  +String id
  +double description
  +setActive()
  +cancelDescription()
  +sendDuration()
  +createType()
}
class Driver {
  #int total
  -String level
  +boolean phone
  #float name
  +getStatus()
  +getDuration()
}
interface Inventory {
  +String phone
  +double type
  +calculateTotal()
}
abstract class Tracking {
  #double name
  -boolean id
  +sendTotal()
  +createPrice()
  +setDuration()
  +getAddress()
}
class Warehouse {
  #Date note
  -float price
  +cancelScore()
  +sendStatus()
}
Warehouse --|> Inventory
Vehicle ..> Driver : "1..*"
Tracking --|> Depot
Inventory --o Vehicle
@enduml