@startuml

interface User {
  #double level
  -String phone
  +cancelUpdatedat()
  +findDuration()
  +calculateEmail()
  +setQuantity()
}
class Message {
  #long name
  #boolean note
  #Date description
  +updateCode()
  +cancelQuantity()
  +createStatus()
  +cancelCode()
}
class Follower {
  #double createdAt
  +int total
  -String quantity
  -int duration
  -String note
  +findScore()
  +validateId()
  +sendType()
  +deleteActive()
}
abstract class Notification {
  -Date amount
  #long phone
  +Date status
  -String total
  #boolean description
  +savePrice()
  +processAddress()
}
class Like {
  #boolean status
  -long type
  -float email
  +cancelTotal()
  +calculateUpdatedat()
  +updateQuantity()
  +deleteStatus()
}
interface Story {
  +boolean code
  #long createdAt
  +boolean email
  -long phone
  #String status
  +findType()
  +validateQuantity()
  +saveCreatedat()
  +processDuration()
}
User ..|> Like
Story --|> Message
Notification --> Story : "0..1"
Message --o Like
@enduml