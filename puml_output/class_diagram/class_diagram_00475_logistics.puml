@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Shipment {
  #int name
  -boolean description
  #long quantity
  +findScore()
  +getEmail()
}
abstract class Route {
  -boolean total
  #Date code
  -String active
  +validateDuration()
  +cancelPrice()
}
class Depot {
  -boolean createdAt
  #float amount
  -boolean id
  #int level
  -long code
  +setPhone()
  +processAmount()
}
class DeliveryNote {
  +float amount
  +boolean code
  -String active
  #double total
  +String updatedAt
  +sendType()
  +calculateLevel()
  +cancelDuration()
}
class Tracking {
  +int price
  -boolean total
  +int email
  -int type
  +double duration
  +findQuantity()
  +createPhone()
}
class Inventory {
  #double price
  -long updatedAt
  +calculateScore()
  +processUpdatedat()
}
Route --* Shipment
Depot ..> DeliveryNote : "0..1"
Depot ..> Shipment : "1..*"
note right of Shipment : Logistics domain
@enduml