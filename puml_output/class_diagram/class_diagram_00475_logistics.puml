@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Shipment {
  #int name
  -boolean description
  #long quantity
  +cancelUpdatedat()
  +createStatus()
}
class Route {
  #boolean note
  -boolean amount
  #Date total
  -String code
  +updateTotal()
  +sendActive()
}
interface Depot {
  +String amount
  -boolean price
  #float createdAt
  -boolean duration
  #int id
  +cancelPhone()
  +validateCode()
  +updateUpdatedat()
  +deleteCode()
}
abstract class DeliveryNote {
  #String name
  #double price
  #Date amount
  +validateId()
  +calculateTotal()
}
class Tracking {
  -boolean id
  -double price
  #boolean name
  #long score
  +getActive()
  +createDuration()
  +updateEmail()
  +setQuantity()
}
class Inventory {
  +long price
  +String name
  -float createdAt
  +Date duration
  #long score
  +validateType()
  +calculateStatus()
  +sendPhone()
}
Tracking --o Shipment
Route --o DeliveryNote
@enduml