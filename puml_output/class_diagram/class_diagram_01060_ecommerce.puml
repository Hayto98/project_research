@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Cart {
  +float quantity
  #long updatedAt
  -boolean duration
  -int active
  +deleteUpdatedat()
}
class Review {
  #int duration
  #int name
  #float amount
  -int type
  +double status
  +saveStatus()
  +createAmount()
  +sendEmail()
}
class Coupon {
  +float phone
  #String price
  #float level
  #double status
  #float type
  +cancelDescription()
  +cancelDuration()
}
class Customer {
  +float address
  #String updatedAt
  +deleteQuantity()
}
interface Return {
  +double createdAt
  #int name
  -long address
  +calculateEmail()
  +validateLevel()
  +getId()
}
class Product {
  +double createdAt
  +long name
  +deleteScore()
  +deleteId()
}
Customer --> Return : "0..1"
Review --|> Customer
Customer ..|> Cart
note right of Cart : Ecommerce domain
@enduml