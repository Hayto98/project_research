@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Cart {
  +float quantity
  #long updatedAt
  -boolean duration
  -int active
  +deleteScore()
}
class Review {
  +float price
  #int name
  #int amount
  #float type
  +processUpdatedat()
  +saveNote()
  +deletePhone()
}
abstract class Coupon {
  -String status
  -long quantity
  #double amount
  -String active
  +updateUpdatedat()
  +calculateLevel()
  +deleteEmail()
  +calculateStatus()
}
class Customer {
  -Date duration
  +String createdAt
  #String description
  +int id
  #long name
  +updateDescription()
  +deleteNote()
}
class Return {
  +long type
  -long score
  +deleteCreatedat()
  +createActive()
  +processScore()
  +cancelActive()
}
class Product {
  +String code
  +double name
  +deleteName()
  +sendId()
}
Return --|> Review
Review --> Customer : "0..1"
@enduml