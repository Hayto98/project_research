@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
abstract class Interest {
  #float createdAt
  #Date duration
  -boolean name
  +saveDescription()
  +deletePrice()
}
class Statement {
  #float name
  -double phone
  +saveUpdatedat()
}
class Withdrawal {
  +Date address
  +String quantity
  +Date updatedAt
  +sendCreatedat()
}
class Deposit {
  -Date address
  -float email
  +cancelActive()
  +calculatePhone()
}
interface Branch {
  +int type
  #float duration
  +calculateStatus()
}
abstract class Transfer {
  +String total
  +double createdAt
  +findType()
}
abstract class Teller {
  +boolean name
  #Date quantity
  +validateLevel()
  +setDescription()
  +updateEmail()
}
Teller --> Transfer : "*"
Branch ..> Deposit : "*"
note right of Interest : Banking domain
@enduml