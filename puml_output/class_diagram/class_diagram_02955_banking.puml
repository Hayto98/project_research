@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
abstract class Interest {
  #float createdAt
  #Date duration
  -boolean name
  +calculateUpdatedat()
  +setLevel()
}
class Statement {
  -boolean address
  #boolean id
  #Date name
  +Date phone
  +int email
  +calculateCreatedat()
  +setTotal()
}
class Withdrawal {
  +Date status
  +boolean code
  +validateNote()
  +updateUpdatedat()
}
class Deposit {
  -long quantity
  #float type
  #boolean updatedAt
  #String active
  +setId()
  +getDuration()
  +processScore()
  +getAmount()
}
abstract class Branch {
  -Date updatedAt
  +double id
  +calculateQuantity()
}
class Transfer {
  -String name
  #double code
  +setUpdatedat()
  +getPrice()
  +saveId()
  +updateAmount()
}
class Teller {
  -Date active
  #float duration
  +int phone
  +getAmount()
  +validateAddress()
}
Teller --> Transfer : "*"
Branch ..> Deposit : "*"
@enduml