@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Account {
  -int note
  #int createdAt
  -float phone
  +long email
  -String total
  +saveName()
}
class Beneficiary {
  #String id
  #float active
  +createActive()
  +validateEmail()
  +deleteTotal()
}
abstract class Transfer {
  #Date name
  #boolean type
  +float status
  +double duration
  -int score
  +cancelCreatedat()
  +updateType()
}
class Teller {
  +long duration
  -boolean updatedAt
  -boolean name
  +double note
  +setType()
}
Account --o Transfer
Transfer --> Teller : "1"
@enduml