@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Account {
  -int note
  #int createdAt
  -float phone
  +long email
  -String total
  +calculateCreatedat()
}
interface Beneficiary {
  #String id
  #float active
  +validateStatus()
  +processScore()
  +processName()
}
abstract class Transfer {
  +boolean level
  #float name
  +getType()
}
class Teller {
  +long updatedAt
  #Date total
  #int amount
  +processCreatedat()
}
Teller --* Transfer
Account --|> Beneficiary
Beneficiary --|> Account
note right of Account : Banking domain
@enduml