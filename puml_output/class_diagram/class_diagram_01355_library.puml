@startuml
skinparam shadowing true
interface Fine {
  -Date description
  +int total
  #String duration
  +long createdAt
  +findAddress()
  +setCreatedat()
  +getLevel()
}
class Catalog {
  -String quantity
  +Date amount
  -float code
  +setCode()
  +sendStatus()
}
class Reservation {
  +int updatedAt
  #String level
  #float price
  -String note
  #int quantity
  +setAddress()
  +cancelPrice()
}
class Renewal {
  #long address
  +long score
  -float phone
  +deleteTotal()
  +cancelDuration()
  +cancelActive()
}
abstract class Branch {
  #double email
  +boolean price
  +setAddress()
  +validateDescription()
  +processScore()
  +createLevel()
}
class Publisher {
  +Date phone
  #String createdAt
  -long id
  -long email
  -float description
  +createStatus()
  +setDuration()
  +processEmail()
  +getStatus()
}
Catalog --o Renewal
Fine --* Branch
Catalog --* Reservation
note right of Fine : Library domain
@enduml