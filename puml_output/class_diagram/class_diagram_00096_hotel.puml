@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Guest {
  +Date total
  -boolean description
  +saveActive()
}
abstract class Reservation {
  -int phone
  #float price
  #int note
  #float quantity
  +int score
  +sendStatus()
  +validateAmount()
  +processAmount()
}
class Payment {
  -int level
  #int total
  #String note
  +deleteCreatedat()
  +getStatus()
  +sendAddress()
}
class Housekeeping {
  -int email
  +Date address
  #float type
  +createScore()
}
interface Restaurant {
  +float note
  -Date price
  -float total
  #double name
  -long quantity
  +findNote()
  +calculateDuration()
  +saveType()
}
Reservation ..> Guest : "1"
Guest --o Restaurant
@enduml