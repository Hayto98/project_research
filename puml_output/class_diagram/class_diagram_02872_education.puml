@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Grade {
  +Date status
  +String total
  #long score
  +findLevel()
  +setScore()
  +saveCode()
  +getQuantity()
}
interface Attendance {
  -String level
  +int address
  +createStatus()
}
class Student {
  #int duration
  #int active
  +String quantity
  +createDuration()
  +findDescription()
}
class Course {
  -String active
  +boolean id
  +getEmail()
}
class Teacher {
  -Date quantity
  +float address
  #int type
  +Date active
  -boolean note
  +findCreatedat()
  +cancelUpdatedat()
  +setDescription()
}
abstract class Exam {
  +String updatedAt
  +String score
  #Date duration
  +processAddress()
  +deleteNote()
}
Student --> Exam : "1..*"
Course ..|> Grade
note right of Grade : Education domain
@enduml