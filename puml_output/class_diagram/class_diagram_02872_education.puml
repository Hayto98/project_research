@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Grade {
  +Date status
  +String total
  #long score
  +validateTotal()
  +processId()
  +getType()
  +sendAmount()
}
class Attendance {
  #boolean quantity
  #long name
  +cancelEmail()
  +validateCode()
  +processActive()
  +updateCreatedat()
}
class Student {
  #long status
  #int quantity
  #int description
  +String active
  +setTotal()
  +cancelPrice()
}
interface Course {
  #String quantity
  -String score
  +boolean code
  +deletePhone()
}
class Teacher {
  -boolean name
  -double total
  #int quantity
  #int address
  +processNote()
}
class Exam {
  +Date createdAt
  #float level
  -Date updatedAt
  +int status
  +cancelEmail()
  +calculateTotal()
}
Attendance --> Grade : "0..1"
Course ..|> Student
@enduml