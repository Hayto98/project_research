@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Statement {
  #float duration
  -double amount
  -float total
  +sendStatus()
}
class Beneficiary {
  #long updatedAt
  #String quantity
  +String address
  +setAddress()
}
interface Transaction {
  -Date price
  #long phone
  +float description
  +long email
  +String updatedAt
  +createActive()
}
class Interest {
  #float updatedAt
  #boolean amount
  +findDescription()
  +updateDescription()
  +cancelStatus()
}
abstract class Account {
  +int createdAt
  -boolean quantity
  +setTotal()
  +updateCode()
  +calculateName()
  +findLevel()
}
class Card {
  -Date email
  -float id
  +long quantity
  +long total
  #Date name
  +cancelType()
  +saveLevel()
}
class Loan {
  +float note
  +String duration
  +sendTotal()
  +calculateId()
  +processNote()
  +findUpdatedat()
}
Interest --* Loan
Interest --|> Account
Loan --o Card
note right of Statement : Banking domain
@enduml