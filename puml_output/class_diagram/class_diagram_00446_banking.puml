@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Statement {
  #float duration
  -double amount
  -float total
  +sendQuantity()
}
class Beneficiary {
  #long amount
  #long updatedAt
  #String quantity
  +processQuantity()
}
class Transaction {
  -long address
  +long type
  +createId()
  +saveName()
}
interface Interest {
  +String createdAt
  -boolean id
  -Date address
  +float status
  +saveAddress()
  +createUpdatedat()
}
interface Account {
  -boolean description
  +float createdAt
  +Date duration
  -float status
  +validateNote()
}
abstract class Card {
  +float code
  #float total
  #Date createdAt
  -boolean duration
  -long price
  +updateScore()
}
class Loan {
  +long name
  #Date type
  +boolean total
  -Date createdAt
  #String phone
  +calculateAmount()
}
Beneficiary --|> Loan
Interest --o Account
Interest ..> Card : "1"
Interest ..> Loan : "0..1"
Beneficiary --o Interest
@enduml