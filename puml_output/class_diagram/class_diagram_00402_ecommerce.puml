@startuml
skinparam monochrome true
skinparam shadowing true
class Wishlist {
  -Date code
  #double id
  +cancelCreatedat()
  +getStatus()
  +findNote()
  +updateDuration()
}
abstract class Payment {
  #boolean phone
  +boolean total
  +processAmount()
  +updateCreatedat()
  +updateStatus()
}
interface Order {
  +Date code
  +boolean id
  +double price
  +String duration
  #String updatedAt
  +validateDescription()
  +saveEmail()
  +findId()
  +findAmount()
}
class Review {
  +int description
  #boolean phone
  -int code
  +double name
  #boolean type
  +createActive()
  +sendEmail()
}
class Category {
  #long total
  -float email
  +float price
  +validateAddress()
  +validateEmail()
}
Order --* Review
Payment ..|> Category
Payment --> Wishlist : "1..*"
@enduml