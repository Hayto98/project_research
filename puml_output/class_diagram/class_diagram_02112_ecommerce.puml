@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
interface Warehouse {
  +double type
  #long phone
  -Date status
  -float quantity
  -double id
  +findLevel()
}
class Wishlist {
  +boolean address
  -double code
  +String createdAt
  -int note
  #boolean duration
  +createType()
}
class Invoice {
  #long updatedAt
  +String description
  +String note
  +deleteActive()
  +createDescription()
  +validateId()
  +deleteStatus()
}
class Cart {
  #float id
  -boolean score
  -double phone
  +String quantity
  -int createdAt
  +sendStatus()
  +sendQuantity()
  +saveLevel()
  +cancelName()
}
abstract class Order {
  -int name
  #boolean phone
  +long email
  +double amount
  +createStatus()
}
class Payment {
  #double duration
  -Date email
  #float phone
  -Date updatedAt
  -long note
  +sendStatus()
}
interface Supplier {
  +String active
  #boolean description
  -long name
  -int createdAt
  +String status
  +cancelUpdatedat()
  +cancelDuration()
  +saveCode()
}
Invoice ..|> Wishlist
Wishlist --* Warehouse
note right of Warehouse : Ecommerce domain
@enduml