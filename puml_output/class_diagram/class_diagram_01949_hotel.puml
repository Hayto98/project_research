@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Service {
  +Date address
  -String phone
  #int status
  +validateAmount()
}
class Amenity {
  +double id
  -Date updatedAt
  #float amount
  #Date email
  +calculateId()
}
class Room {
  -long email
  -int duration
  -Date id
  -long quantity
  -double description
  +findTotal()
}
interface Restaurant {
  #String name
  +long score
  #double code
  +float description
  +calculateDuration()
  +setUpdatedat()
}
interface Guest {
  +Date type
  +boolean note
  +Date quantity
  -Date email
  +Date active
  +updateQuantity()
  +setQuantity()
  +createUpdatedat()
  +processUpdatedat()
}
class Payment {
  +int name
  #String code
  +sendCode()
  +setStatus()
  +processName()
}
Guest ..|> Restaurant
Room --* Service
Room --|> Restaurant
Restaurant --o Room
note right of Service : Hotel domain
@enduml