@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Service {
  +Date address
  -String phone
  #int status
  +validateDuration()
}
class Amenity {
  +long active
  +double address
  -Date id
  #float updatedAt
  +getDuration()
}
abstract class Room {
  #long code
  #long type
  +calculatePhone()
}
class Restaurant {
  -double quantity
  -Date price
  #Date amount
  #String address
  #double phone
  +saveId()
  +saveActive()
  +getLevel()
}
class Guest {
  #double status
  +float address
  +calculateTotal()
  +findLevel()
}
abstract class Payment {
  #Date updatedAt
  #double active
  +getAmount()
  +createName()
  +processDescription()
  +updateCode()
}
Room ..> Service : "0..1"
Guest ..> Amenity : "*"
Payment ..> Amenity : "*"
Amenity --|> Room
@enduml