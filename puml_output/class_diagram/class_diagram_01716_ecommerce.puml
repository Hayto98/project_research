@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
interface Invoice {
  -String price
  -boolean duration
  -double score
  +findTotal()
  +processId()
}
abstract class Wishlist {
  #long description
  #int total
  +String updatedAt
  -int id
  +updateDescription()
  +createQuantity()
  +createAmount()
}
abstract class Warehouse {
  +double duration
  +long type
  +int score
  +int status
  +saveAmount()
  +cancelLevel()
  +setType()
  +deleteActive()
}
class Order {
  #double updatedAt
  +float duration
  +Date active
  +processDescription()
  +getDescription()
  +updateId()
}
class Category {
  #double status
  #float type
  +findTotal()
  +calculateId()
  +setQuantity()
}
interface Product {
  +int status
  #long code
  #double phone
  #float type
  +int email
  +setEmail()
  +deleteQuantity()
  +getCreatedat()
}
class Cart {
  #float name
  #long level
  +getScore()
}
Cart --* Product
Category ..> Warehouse : "0..1"
Product --|> Warehouse
Order --|> Category
@enduml