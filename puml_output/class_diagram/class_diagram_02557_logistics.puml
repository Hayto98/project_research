@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Tracking {
  -Date level
  #long name
  #float price
  +calculateTotal()
  +setDuration()
}
abstract class Inventory {
  #Date updatedAt
  -String email
  +createCode()
  +sendUpdatedat()
  +deleteCreatedat()
}
abstract class Manifest {
  -long type
  +double level
  -double phone
  +float score
  #String total
  +sendAmount()
  +calculateCreatedat()
  +getActive()
}
interface Depot {
  -double type
  #float score
  -double price
  +savePhone()
  +createPhone()
  +updateNote()
}
Inventory ..|> Tracking
Depot --> Manifest : "0..1"
Tracking ..> Manifest : "*"
note right of Tracking : Logistics domain
@enduml