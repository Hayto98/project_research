@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Tracking {
  -Date level
  #long name
  #float price
  +processType()
  +getPhone()
}
class Inventory {
  -long code
  +float updatedAt
  #float email
  +int note
  +double status
  +saveUpdatedat()
  +getId()
  +processEmail()
  +updateTotal()
}
class Manifest {
  -int note
  #String phone
  #long code
  #float price
  +double level
  +updatePrice()
  +saveLevel()
}
interface Depot {
  -double type
  #float score
  -double price
  +deleteStatus()
  +validateDescription()
  +saveScore()
}
Manifest ..> Tracking : "*"
Depot ..|> Tracking
Inventory --> Manifest : "*"
@enduml