@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Profile {
  +Date id
  -double level
  +long duration
  +boolean status
  #String email
  +calculateDescription()
  +updateAddress()
  +deleteQuantity()
}
class Comment {
  -double level
  #int active
  +int email
  +cancelUpdatedat()
}
interface Post {
  +int description
  -boolean total
  #float type
  +deleteAmount()
  +setCode()
  +findCode()
}
class Album {
  #long id
  +int name
  +validateTotal()
}
class Notification {
  +Date level
  #float active
  #boolean quantity
  -long note
  +createName()
  +validateCode()
  +processQuantity()
}
class Like {
  #Date name
  #double quantity
  #String amount
  +getPrice()
}
class Report {
  #String createdAt
  +String score
  -boolean updatedAt
  +validateName()
  +processStatus()
}
Album --* Profile
Report --|> Notification
Profile --> Report : "1..*"
Profile ..|> Post
Notification ..|> Album
note right of Profile : Social Media domain
@enduml