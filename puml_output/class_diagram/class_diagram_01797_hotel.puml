@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Payment {
  #long note
  -String email
  +deleteAmount()
}
interface CheckIn {
  #float quantity
  -float phone
  +long name
  -boolean total
  #long duration
  +sendCode()
  +calculateLevel()
  +processName()
  +createName()
}
class CheckOut {
  #float email
  -boolean createdAt
  +double updatedAt
  #String name
  +updateDescription()
}
abstract class Restaurant {
  -int code
  -Date id
  -float name
  -float price
  +int note
  +updateLevel()
  +getQuantity()
  +processName()
}
CheckOut --|> Restaurant
CheckIn ..> CheckOut : "*"
note right of Payment : Hotel domain
@enduml