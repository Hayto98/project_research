@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Payment {
  #long note
  -String email
  +calculateAddress()
}
class CheckIn {
  #float quantity
  -float phone
  +long name
  -boolean total
  #long duration
  +sendQuantity()
  +sendType()
  +getType()
  +processType()
}
interface CheckOut {
  -boolean name
  +int email
  +Date duration
  -boolean quantity
  +double active
  +setActive()
}
interface Restaurant {
  -double createdAt
  #String description
  +calculateEmail()
}
Restaurant ..|> CheckIn
Restaurant --* CheckOut
CheckOut ..|> Payment
@enduml