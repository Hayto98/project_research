@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
interface Payment {
  +long active
  -long level
  +int duration
  -Date name
  #Date email
  +processPhone()
  +sendPhone()
}
class Review {
  -double active
  -boolean level
  #double type
  +double quantity
  +findPrice()
  +saveTotal()
  +setType()
  +createAddress()
}
interface Order {
  +int address
  #int name
  +Date price
  +sendStatus()
}
class Category {
  #String id
  +long quantity
  -Date price
  -float description
  -Date note
  +sendId()
}
interface Product {
  +Date updatedAt
  +boolean createdAt
  -int level
  -boolean active
  +boolean address
  +createId()
}
interface Shipment {
  +float active
  -long note
  +Date type
  #float status
  +deleteName()
  +calculateType()
  +getNote()
}
Category --o Payment
Product ..> Review : "1"
Review ..|> Order
Product --> Payment : "1..*"
Product ..> Category : "1"
@enduml