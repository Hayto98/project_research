@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Shelf {
  +Date active
  -float updatedAt
  #boolean id
  #float email
  +boolean level
  +findLevel()
  +processName()
  +validateAmount()
  +createScore()
}
class Reservation {
  #float type
  #int level
  +double name
  #boolean price
  +validateCreatedat()
  +saveName()
  +updateName()
  +updateAmount()
}
class Book {
  +boolean email
  -long phone
  +String score
  +calculatePrice()
  +updateDescription()
}
abstract class Branch {
  -float active
  +double duration
  +double code
  +saveLevel()
}
class Author {
  -int total
  +double description
  +int status
  -Date active
  +sendStatus()
}
interface Loan {
  #double type
  -int code
  +float price
  #float active
  -long amount
  +setAddress()
  +saveScore()
  +updateQuantity()
  +updateName()
}
abstract class Fine {
  #String name
  #String status
  #Date duration
  +int quantity
  +validateNote()
  +processPhone()
}
Author --o Book
Reservation ..|> Shelf
Book --* Loan
@enduml