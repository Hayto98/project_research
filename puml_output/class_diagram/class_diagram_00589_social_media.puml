@startuml
skinparam defaultFontSize 13
class Notification {
  +long price
  #Date score
  #double type
  #Date level
  +createNote()
}
interface Report {
  -int duration
  +String id
  #double updatedAt
  +int phone
  -double level
  +setScore()
  +processPrice()
}
class Comment {
  +Date id
  +int duration
  +sendCreatedat()
  +saveCode()
}
abstract class Message {
  #String note
  -boolean amount
  -int type
  -float email
  #Date code
  +validateDescription()
}
abstract class Hashtag {
  -String type
  -String updatedAt
  -double email
  #Date createdAt
  +cancelNote()
  +findNote()
  +createPrice()
}
class Post {
  -float price
  #boolean code
  +float duration
  #boolean amount
  +createUpdatedat()
  +cancelLevel()
  +calculatePhone()
  +findId()
}
Message ..|> Comment
Hashtag ..> Report : "*"
Notification --|> Comment
Message ..> Report : "*"
Hashtag ..|> Post
note right of Notification : Social Media domain
@enduml