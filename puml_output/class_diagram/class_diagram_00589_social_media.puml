@startuml
skinparam defaultFontSize 13
class Notification {
  +long price
  #Date score
  #double type
  #Date level
  +cancelPhone()
}
abstract class Report {
  -int duration
  +String id
  #double updatedAt
  +int phone
  -double level
  +createAddress()
  +cancelAmount()
}
abstract class Comment {
  #float amount
  +int id
  +boolean level
  +Date score
  +double status
  +sendUpdatedat()
  +createName()
  +cancelPrice()
  +saveAddress()
}
abstract class Message {
  #double code
  +double active
  #Date duration
  +long email
  +calculateUpdatedat()
  +sendCreatedat()
}
class Hashtag {
  +long duration
  +long updatedAt
  -Date email
  #long createdAt
  #double note
  +findLevel()
  +calculatePhone()
  +saveCode()
  +findStatus()
}
class Post {
  -float price
  #boolean code
  +float duration
  #boolean amount
  +createQuantity()
  +validateNote()
  +findName()
  +processEmail()
}
Comment ..> Notification : "*"
Message ..|> Comment
Hashtag ..> Report : "*"
Notification --|> Comment
Message ..> Report : "*"
@enduml