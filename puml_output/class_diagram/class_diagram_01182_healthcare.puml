@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class MedicalRecord {
  -boolean phone
  #long note
  +float level
  -boolean status
  +deleteScore()
}
class Nurse {
  #float email
  #double type
  +float level
  +processStatus()
}
interface Hospital {
  -long amount
  #boolean id
  -int level
  #int price
  +setPhone()
  +validateName()
  +validateScore()
}
class LabTest {
  #long duration
  -Date quantity
  +findCreatedat()
  +processEmail()
  +updateActive()
}
interface Billing {
  +long address
  #Date email
  #long phone
  +createAddress()
  +validateScore()
}
class Appointment {
  -boolean level
  +double amount
  +double code
  +setUpdatedat()
}
class Insurance {
  #boolean createdAt
  #Date note
  +double level
  +double id
  #Date description
  +cancelName()
  +calculateAddress()
  +cancelScore()
}
Insurance --* Hospital
Appointment --|> Nurse
LabTest ..|> Nurse
note right of MedicalRecord : Healthcare domain
@enduml