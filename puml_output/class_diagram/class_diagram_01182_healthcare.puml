@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class MedicalRecord {
  -boolean phone
  #long note
  +float level
  -boolean status
  +createCode()
}
interface Nurse {
  -Date description
  #double email
  +updateDescription()
  +updateCreatedat()
  +sendTotal()
  +deleteLevel()
}
abstract class Hospital {
  +String active
  #String email
  +sendPhone()
  +findQuantity()
  +createUpdatedat()
  +deleteId()
}
interface LabTest {
  -String amount
  -boolean updatedAt
  -Date address
  #String code
  #long phone
  +getPrice()
  +getName()
  +updateQuantity()
}
class Billing {
  #Date createdAt
  #float note
  +long email
  -long duration
  +saveScore()
  +updateScore()
}
interface Appointment {
  #String updatedAt
  #int email
  #Date address
  #boolean score
  +findNote()
  +cancelAddress()
}
interface Insurance {
  +String total
  +long code
  #double duration
  +updateCreatedat()
  +updateScore()
}
Insurance --|> LabTest
Insurance --> Nurse : "1"
LabTest --o Nurse
Billing --* Appointment
Billing --o MedicalRecord
@enduml