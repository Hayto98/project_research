@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
interface Staff {
  #int level
  +int address
  #Date active
  +Date phone
  +saveAddress()
  +calculateQuantity()
}
class Room {
  +Date type
  #long quantity
  -Date score
  +int updatedAt
  +updateDescription()
  +setAmount()
  +validatePhone()
}
interface Amenity {
  #int createdAt
  #long id
  -double duration
  -double code
  +updateDescription()
  +cancelPhone()
  +createId()
  +findName()
}
abstract class CheckIn {
  +Date level
  -Date type
  #Date phone
  +validateName()
  +setAmount()
}
class Invoice {
  +int total
  -Date duration
  +String updatedAt
  +cancelCreatedat()
}
Staff --|> Invoice
Amenity --> Room : "1"
@enduml