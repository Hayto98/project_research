@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
interface Staff {
  #int level
  +int address
  #Date active
  +Date phone
  +deleteTotal()
  +updateEmail()
}
abstract class Room {
  #boolean score
  -long duration
  #int updatedAt
  +long code
  +setScore()
  +validateCreatedat()
}
class Amenity {
  -double code
  -double amount
  -int email
  +cancelPrice()
  +deleteLevel()
  +processPhone()
}
class CheckIn {
  -double updatedAt
  +String type
  +long description
  #String amount
  +setTotal()
}
class Invoice {
  -int id
  #String status
  +sendName()
  +calculateActive()
  +cancelUpdatedat()
  +cancelLevel()
}
Amenity ..|> Room
note right of Staff : Hotel domain
@enduml