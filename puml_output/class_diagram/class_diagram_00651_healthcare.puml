@startuml
skinparam defaultFontSize 13
class Nurse {
  #int id
  +int description
  +findDuration()
}
abstract class Diagnosis {
  #long quantity
  +boolean note
  +float name
  +double id
  -float level
  +validateDescription()
}
class MedicalRecord {
  -boolean updatedAt
  -long description
  -boolean amount
  +createNote()
  +validateScore()
}
class Insurance {
  -String phone
  -int active
  +String score
  -Date updatedAt
  -float address
  +deleteNote()
  +createNote()
  +cancelNote()
}
Diagnosis --o MedicalRecord
Nurse --> Diagnosis : "*"
Nurse --> Insurance : "1..*"
@enduml