@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
interface LabTest {
  -float quantity
  #String name
  #Date price
  +float type
  +processScore()
}
class MedicalRecord {
  #float active
  -float phone
  +String quantity
  #long price
  +float status
  +saveId()
  +createTotal()
  +sendName()
}
class Insurance {
  #float updatedAt
  +boolean email
  #float description
  #Date createdAt
  +getStatus()
  +createNote()
}
class Doctor {
  -boolean id
  -double name
  #boolean description
  -float status
  +createPrice()
}
class Hospital {
  +String active
  +Date type
  -String price
  #String score
  +String status
  +processStatus()
}
MedicalRecord ..|> LabTest
Insurance ..> MedicalRecord : "0..1"
Insurance --o Doctor
@enduml