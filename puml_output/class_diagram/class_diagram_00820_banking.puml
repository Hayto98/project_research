@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
abstract class Deposit {
  +long email
  #boolean price
  #boolean duration
  #long score
  -String active
  +sendId()
  +sendEmail()
  +cancelType()
  +getQuantity()
}
class Card {
  #boolean code
  +Date price
  #double updatedAt
  #Date name
  +findDescription()
  +sendTotal()
  +createEmail()
}
class Transaction {
  #long note
  #int phone
  +double total
  +setEmail()
  +cancelName()
  +findId()
  +deleteType()
}
class Beneficiary {
  #float quantity
  #Date phone
  #int price
  +deleteCreatedat()
  +cancelDuration()
}
Beneficiary --o Deposit
Deposit --> Card : "*"
@enduml