@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
abstract class Deposit {
  +long email
  #boolean price
  #boolean duration
  #long score
  -String active
  +updateCreatedat()
  +cancelCode()
  +findAddress()
  +setPrice()
}
class Card {
  +Date level
  #double duration
  +cancelId()
  +validateCreatedat()
  +processPhone()
}
abstract class Transaction {
  #double level
  -Date description
  +Date amount
  +int total
  +cancelPhone()
  +calculateLevel()
  +findLevel()
}
class Beneficiary {
  +double email
  +float amount
  -boolean total
  +cancelTotal()
  +createDescription()
  +sendLevel()
  +calculateAmount()
}
Beneficiary --o Transaction
note right of Deposit : Banking domain
@enduml