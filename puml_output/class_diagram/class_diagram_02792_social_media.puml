@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Report {
  #boolean score
  #float name
  -Date amount
  -float type
  +int createdAt
  +createEmail()
  +updateType()
  +createAddress()
}
interface Follower {
  +long type
  #int active
  +calculateStatus()
  +findType()
}
class Notification {
  #String address
  +Date type
  #int description
  +cancelCreatedat()
  +sendActive()
  +createPrice()
  +processLevel()
}
abstract class User {
  -long quantity
  #String phone
  -double total
  +String type
  +sendCode()
  +setId()
  +calculateName()
  +validatePhone()
}
class Message {
  -int code
  #boolean status
  #long price
  -Date active
  +processPhone()
  +calculateCreatedat()
}
Follower --* Report
Follower --* Message
Message --> Notification : "0..1"
@enduml