@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Report {
  #boolean score
  #float name
  -Date amount
  -float type
  +int createdAt
  +deleteCode()
  +saveDuration()
  +setType()
}
interface Follower {
  +Date quantity
  #float level
  #int amount
  +validateType()
  +deleteId()
}
class Notification {
  -double type
  #long total
  -Date price
  +saveTotal()
  +processPhone()
  +createName()
}
class User {
  +Date status
  +long code
  +String type
  #double note
  #double address
  +findDuration()
  +sendEmail()
}
class Message {
  #String address
  -int note
  +float updatedAt
  +cancelPhone()
  +cancelUpdatedat()
  +sendCreatedat()
}
Message --* Follower
User --* Notification
Report ..|> Follower
note right of Report : Social Media domain
@enduml