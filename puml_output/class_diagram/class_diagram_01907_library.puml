@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
abstract class Catalog {
  -Date duration
  -int name
  +validateScore()
  +deleteScore()
}
abstract class Author {
  -double email
  -float name
  +double price
  +deleteType()
  +cancelTotal()
}
abstract class Publisher {
  +long status
  #int note
  #float amount
  -double updatedAt
  +getPhone()
  +getNote()
  +validatePrice()
  +getUpdatedat()
}
class Reservation {
  +long duration
  #boolean note
  -float active
  -int phone
  +createDuration()
  +createScore()
  +getQuantity()
}
abstract class Shelf {
  +Date total
  #float updatedAt
  -double type
  -float note
  -int level
  +calculateCode()
  +setActive()
  +updateDuration()
}
class Book {
  +int updatedAt
  #Date name
  #float note
  -double amount
  +float total
  +processId()
  +saveName()
  +saveAmount()
  +sendAddress()
}
Shelf --|> Book
Book --> Shelf : "0..1"
Shelf --* Catalog
Book ..> Reservation : "1..*"
@enduml