@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Publisher {
  +boolean price
  +double note
  +int id
  +deleteAmount()
  +findPrice()
}
interface Book {
  +String status
  #Date amount
  +float note
  +double quantity
  +int price
  +processPrice()
  +updateStatus()
  +deleteScore()
  +validatePhone()
}
class Shelf {
  +Date note
  +double price
  #int address
  -long total
  +updateDescription()
  +calculateCreatedat()
  +saveLevel()
  +createEmail()
}
interface Author {
  +boolean name
  -Date code
  -String score
  -long phone
  +processLevel()
  +processId()
  +updateUpdatedat()
  +setNote()
}
Book --* Publisher
Publisher --* Shelf
Author ..> Book : "1"
@enduml