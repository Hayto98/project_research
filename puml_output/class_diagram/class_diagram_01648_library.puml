@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Publisher {
  +boolean price
  +double note
  +int id
  +calculateActive()
  +cancelType()
}
class Book {
  +String note
  #Date quantity
  +float price
  +calculateCode()
  +updatePrice()
}
class Shelf {
  -double amount
  -long code
  -float updatedAt
  +findDescription()
}
abstract class Author {
  -int phone
  -float address
  #long score
  +setScore()
}
Book --* Shelf
Shelf --* Publisher
Shelf --o Book
note right of Publisher : Library domain
@enduml