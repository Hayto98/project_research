@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
interface Tracking {
  +float description
  -double createdAt
  +sendDuration()
}
class Customer {
  +float quantity
  +double status
  -double updatedAt
  +calculateStatus()
  +calculateLevel()
  +sendAmount()
  +setLevel()
}
class Driver {
  +float address
  #float active
  -int price
  +String total
  +sendStatus()
}
class Inventory {
  -double quantity
  +float code
  +cancelDescription()
  +findCreatedat()
}
class Manifest {
  #long createdAt
  -long total
  +getDescription()
  +setCreatedat()
  +validateActive()
}
class Warehouse {
  #int updatedAt
  #int email
  -double id
  -boolean quantity
  #float description
  +validatePrice()
  +createPrice()
  +createPrice()
}
Driver ..> Customer : "0..1"
Warehouse ..|> Tracking
Customer --o Tracking
note right of Tracking : Logistics domain
@enduml