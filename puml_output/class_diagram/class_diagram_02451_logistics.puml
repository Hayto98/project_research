@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
interface Tracking {
  +float description
  -double createdAt
  +findDuration()
}
interface Customer {
  +float createdAt
  +String quantity
  +sendScore()
}
abstract class Driver {
  +Date type
  #int price
  -long status
  #boolean level
  -Date amount
  +updateDuration()
  +cancelType()
  +saveLevel()
  +sendActive()
}
class Inventory {
  #String updatedAt
  +String code
  -String id
  +saveAmount()
  +setType()
  +saveLevel()
}
class Manifest {
  +double createdAt
  #long phone
  -long status
  +setAmount()
  +updatePrice()
  +getEmail()
}
class Warehouse {
  #double address
  +long active
  +long code
  +processEmail()
  +findPhone()
}
Driver --o Inventory
Manifest --* Driver
Inventory ..> Driver : "*"
@enduml