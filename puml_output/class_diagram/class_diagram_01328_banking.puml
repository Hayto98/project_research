@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Statement {
  #int email
  #boolean createdAt
  -String code
  +deleteStatus()
  +validateQuantity()
}
class Beneficiary {
  +boolean amount
  +float level
  +String duration
  -Date note
  +createAmount()
  +validateDuration()
  +sendName()
  +findNote()
}
abstract class Interest {
  #String amount
  +String price
  #double phone
  +int type
  +findAddress()
  +validateUpdatedat()
}
abstract class Card {
  #long description
  -boolean updatedAt
  -long email
  -int score
  -double address
  +calculateActive()
  +calculateTotal()
  +createDuration()
  +getAddress()
}
Statement --> Beneficiary : "*"
Beneficiary --o Card
note right of Statement : Banking domain
@enduml