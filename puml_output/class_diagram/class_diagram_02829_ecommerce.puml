@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Review {
  -Date code
  #long phone
  +String createdAt
  -Date quantity
  +saveAmount()
  +calculateStatus()
}
class Coupon {
  +long total
  -boolean status
  #String code
  +sendScore()
  +createUpdatedat()
}
class Warehouse {
  #long duration
  -String id
  +createStatus()
  +processNote()
  +validatePrice()
  +cancelActive()
}
class Payment {
  #boolean price
  -double level
  +Date quantity
  +deleteAmount()
  +validatePhone()
}
class Supplier {
  #long note
  +String code
  -Date description
  +long address
  #boolean level
  +setCreatedat()
  +createLevel()
}
class Order {
  +Date amount
  #Date phone
  -Date duration
  #boolean level
  +deleteName()
}
Payment --o Order
Supplier ..|> Coupon
@enduml