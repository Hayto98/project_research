@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Transfer {
  +boolean note
  #int duration
  #String description
  +getId()
  +setUpdatedat()
  +validateType()
}
abstract class Transaction {
  -float level
  +double price
  -float email
  +cancelNote()
  +processEmail()
}
class Customer {
  +float phone
  #String quantity
  -boolean name
  +boolean amount
  +cancelDuration()
  +sendPhone()
  +validateCode()
  +validateQuantity()
}
class Withdrawal {
  +int email
  -double score
  -int type
  -float phone
  -int id
  +validatePhone()
  +createLevel()
  +updateLevel()
}
Transfer --> Customer : "0..1"
Transfer --* Withdrawal
Transaction ..> Customer : "1..*"
note right of Transfer : Banking domain
@enduml