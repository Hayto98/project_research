@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Transfer {
  +boolean note
  #int duration
  #String description
  +setName()
  +findNote()
  +processPrice()
}
class Transaction {
  +double price
  -float amount
  +boolean duration
  -double email
  -float phone
  +savePrice()
}
class Customer {
  +float quantity
  #String level
  -boolean name
  +boolean amount
  +processEmail()
  +sendActive()
  +cancelAmount()
  +calculateLevel()
}
class Withdrawal {
  -long code
  #double phone
  #long quantity
  +float address
  +sendNote()
  +findActive()
}
Withdrawal --o Transfer
Customer --> Transfer : "1..*"
Customer --* Transaction
@enduml