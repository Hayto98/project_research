@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Book {
  +String description
  -boolean code
  +calculateUpdatedat()
  +processPrice()
  +cancelCode()
  +findAmount()
}
class Member {
  -String status
  -Date level
  +deleteName()
  +validateType()
}
abstract class Catalog {
  -Date duration
  +String type
  +Date score
  -Date price
  +sendPrice()
}
interface Librarian {
  +boolean status
  +double email
  #Date phone
  +double name
  +processDuration()
  +calculateCode()
  +deleteCode()
  +processActive()
}
class Shelf {
  -long createdAt
  +int amount
  +findPhone()
}
class Fine {
  #boolean note
  +Date updatedAt
  +updateAmount()
  +processUpdatedat()
}
interface Renewal {
  -String updatedAt
  +int active
  #boolean level
  +sendType()
}
Member --* Catalog
Librarian --o Member
Book --> Catalog : "*"
Member ..|> Fine
Book --> Renewal : "1..*"
Shelf --o Librarian
@enduml