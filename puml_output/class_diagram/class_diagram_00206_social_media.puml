@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Comment {
  #long duration
  +long quantity
  +double description
  #String name
  +saveName()
  +validateDescription()
  +deleteAmount()
  +saveScore()
}
abstract class Group {
  -long amount
  #long createdAt
  #int price
  #int type
  #Date address
  +validateId()
  +calculatePrice()
  +calculateEmail()
  +createEmail()
}
abstract class User {
  -boolean email
  +boolean code
  -float createdAt
  +String name
  +createActive()
  +getTotal()
  +findStatus()
}
class Hashtag {
  #double id
  +int address
  #long createdAt
  -double status
  #String description
  +savePrice()
  +findCreatedat()
}
Group --|> Hashtag
Hashtag --* Group
User --o Group
@enduml