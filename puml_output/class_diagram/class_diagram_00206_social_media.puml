@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Comment {
  #long duration
  +long quantity
  +double description
  #String name
  +calculatePrice()
  +validateNote()
  +processAmount()
  +updatePrice()
}
abstract class Group {
  #int price
  #Date email
  -String level
  #String description
  +createEmail()
  +setCreatedat()
  +getPhone()
  +sendCreatedat()
}
interface User {
  #Date createdAt
  +double status
  +float address
  -int score
  +int duration
  +deleteDescription()
  +sendPhone()
  +processTotal()
  +sendStatus()
}
class Hashtag {
  #double type
  -long createdAt
  -double email
  -Date status
  +deletePhone()
}
User ..> Hashtag : "1..*"
Comment --|> Hashtag
note right of Comment : Social Media domain
@enduml