@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
interface Librarian {
  +float duration
  -long note
  -double description
  +long active
  +long status
  +findUpdatedat()
  +createTotal()
  +sendPhone()
}
class Fine {
  #boolean updatedAt
  +float total
  -String level
  -double id
  #long code
  +saveEmail()
  +calculateScore()
}
interface Member {
  +String phone
  #String price
  -long amount
  +long createdAt
  +createDuration()
}
class Renewal {
  -long amount
  #String type
  -int description
  +setCode()
  +processPrice()
  +deleteNote()
  +cancelTotal()
}
class Shelf {
  -int code
  +float address
  +String duration
  +long price
  +boolean description
  +updateName()
  +setAddress()
  +deletePrice()
}
class Reservation {
  +Date total
  +boolean price
  +int email
  #long updatedAt
  +boolean description
  +calculateStatus()
  +calculateCreatedat()
}
Reservation --o Fine
Member ..|> Renewal
Renewal --|> Member
Librarian --o Fine
note right of Librarian : Library domain
@enduml