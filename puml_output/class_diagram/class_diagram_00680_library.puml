@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
interface Librarian {
  +float duration
  -long note
  -double description
  +long active
  +long status
  +cancelName()
  +validateNote()
  +processDescription()
}
abstract class Fine {
  -String id
  +Date note
  #float updatedAt
  +float total
  +processCode()
  +sendName()
  +createPrice()
}
interface Member {
  -long description
  -boolean email
  +int price
  +String active
  +validateLevel()
}
class Renewal {
  #long status
  +int quantity
  -int code
  -long level
  +setTotal()
}
class Shelf {
  -boolean status
  -long code
  #double note
  +long price
  #String amount
  +setLevel()
  +validateUpdatedat()
  +validateCreatedat()
  +validateNote()
}
class Reservation {
  +boolean name
  -int email
  +validatePhone()
}
Fine --|> Renewal
Renewal --o Reservation
Member ..|> Fine
Librarian --> Reservation : "1"
@enduml