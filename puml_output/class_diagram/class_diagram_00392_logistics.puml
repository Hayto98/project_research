@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
abstract class Driver {
  -boolean score
  +Date status
  +float duration
  -long phone
  +findTotal()
  +validateLevel()
}
abstract class Depot {
  +boolean id
  +long phone
  +saveNote()
  +processActive()
  +getActive()
  +createAddress()
}
interface Tracking {
  -int total
  -String score
  -float type
  -String id
  +long name
  +calculateCode()
}
abstract class Vehicle {
  +float type
  +boolean price
  +long createdAt
  +sendUpdatedat()
  +createStatus()
}
Vehicle ..|> Driver
Tracking --o Depot
@enduml