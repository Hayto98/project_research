@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
abstract class Driver {
  -boolean score
  +Date status
  +float duration
  -long phone
  +calculateCode()
  +getPhone()
}
class Depot {
  +int quantity
  #String type
  +calculateScore()
  +processLevel()
  +getName()
  +createDescription()
}
class Tracking {
  +int phone
  -float total
  +calculateTotal()
}
class Vehicle {
  -int price
  #boolean createdAt
  -float code
  -int id
  +long status
  +processPhone()
  +calculateUpdatedat()
  +getLevel()
  +deleteDuration()
}
Tracking --> Driver : "*"
Depot ..|> Driver
Vehicle ..> Depot : "0..1"
note right of Driver : Logistics domain
@enduml