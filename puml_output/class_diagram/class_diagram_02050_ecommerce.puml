@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Warehouse {
  -float quantity
  #boolean score
  -String email
  -float address
  +updateTotal()
  +saveDuration()
  +sendDescription()
  +saveId()
}
interface Shipment {
  -int description
  +double duration
  -float phone
  #int id
  #double price
  +validateScore()
  +processDescription()
}
class Invoice {
  +int score
  +float amount
  +calculateDuration()
}
abstract class Supplier {
  #long code
  +long quantity
  +createTotal()
}
class Customer {
  -String total
  +Date address
  -double name
  #boolean note
  +processLevel()
  +processScore()
  +createCreatedat()
}
class Category {
  #double duration
  #double updatedAt
  +float address
  +float phone
  -int level
  +setPrice()
  +cancelNote()
  +validateAmount()
  +updateUpdatedat()
}
class Coupon {
  +int updatedAt
  -String id
  +float email
  +getEmail()
  +cancelPhone()
  +saveEmail()
  +calculateUpdatedat()
}
Warehouse ..> Shipment : "0..1"
Category --> Shipment : "1..*"
Shipment ..> Category : "1"
Shipment ..> Customer : "0..1"
@enduml