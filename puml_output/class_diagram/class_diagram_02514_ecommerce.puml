@startuml

class Product {
  #boolean active
  +float amount
  +processCode()
}
interface Review {
  #String score
  #Date type
  -boolean status
  #double duration
  +calculateAddress()
  +validateEmail()
}
class Order {
  #Date createdAt
  #float id
  +double amount
  +updateQuantity()
  +setAmount()
}
class Warehouse {
  -double createdAt
  +float email
  -float active
  -String total
  #boolean quantity
  +deleteDescription()
  +setCode()
}
class Shipment {
  +Date note
  #int email
  +calculateLevel()
  +processAmount()
}
interface Wishlist {
  -Date amount
  #float quantity
  +saveCode()
}
Product --o Shipment
Review --|> Shipment
Warehouse --|> Product
Shipment ..|> Review
@enduml