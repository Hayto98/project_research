@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Invoice {
  +boolean level
  #float email
  -Date description
  -String createdAt
  #long total
  +calculateCode()
  +createLevel()
  +validateActive()
  +processId()
}
class Housekeeping {
  +Date code
  -long duration
  +cancelCreatedat()
  +getId()
}
abstract class Booking {
  -long code
  +int updatedAt
  -int quantity
  +calculateType()
  +saveDescription()
  +processType()
}
class Amenity {
  -float type
  #long email
  #long code
  #int note
  +findActive()
}
class Restaurant {
  -double description
  -long status
  -String updatedAt
  -int note
  #float total
  +saveType()
  +processName()
  +sendUpdatedat()
  +sendPrice()
}
class CheckOut {
  #double address
  -long description
  +saveDuration()
  +updatePhone()
}
CheckOut --|> Invoice
Restaurant --|> Amenity
Invoice --* Amenity
@enduml