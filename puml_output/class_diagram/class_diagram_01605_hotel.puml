@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Invoice {
  +boolean level
  #float email
  -Date description
  -String createdAt
  #long total
  +calculateDuration()
  +cancelAddress()
  +getCode()
  +saveCode()
}
class Housekeeping {
  -double phone
  +Date level
  #String description
  +Date total
  +validateAddress()
  +deleteDescription()
  +calculateUpdatedat()
}
class Booking {
  #double code
  -float address
  #long type
  #long email
  #int duration
  +processUpdatedat()
}
interface Amenity {
  -double description
  -long status
  -String updatedAt
  -int note
  #float total
  +getUpdatedat()
  +setAddress()
  +deleteType()
  +processEmail()
}
class Restaurant {
  -String code
  +double status
  -double score
  +findType()
  +cancelDuration()
  +createCreatedat()
}
class CheckOut {
  +String quantity
  +float score
  +long status
  +getEmail()
  +saveName()
}
Invoice --|> Housekeeping
Invoice ..|> CheckOut
note right of Invoice : Hotel domain
@enduml