@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Hospital {
  +Date level
  +boolean total
  -long email
  +deletePrice()
  +setNote()
}
class Nurse {
  +String price
  -float phone
  +validateEmail()
}
class Doctor {
  #float price
  #float type
  +findScore()
  +getAddress()
}
class Patient {
  #float score
  #double note
  +createId()
}
class Prescription {
  -Date level
  -double active
  -String amount
  +String note
  +createCode()
  +validateName()
}
class Diagnosis {
  -long createdAt
  +int email
  +float duration
  +calculateCreatedat()
  +setStatus()
  +validatePhone()
  +findDuration()
}
class Insurance {
  #String name
  -float amount
  #String address
  +boolean note
  -long description
  +saveEmail()
}
Patient --* Doctor
Prescription --> Diagnosis : "0..1"
Nurse --* Diagnosis
note right of Hospital : Healthcare domain
@enduml