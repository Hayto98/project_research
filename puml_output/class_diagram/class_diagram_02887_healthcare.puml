@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Hospital {
  +Date level
  +boolean total
  -long email
  +findId()
  +processType()
}
class Nurse {
  +String status
  -float active
  +long duration
  -int price
  +double phone
  +findTotal()
  +updateCode()
  +createDescription()
  +validateType()
}
interface Doctor {
  -String score
  #float id
  -Date address
  +saveId()
  +setTotal()
  +setName()
  +sendDuration()
}
class Patient {
  -Date level
  -double active
  -String amount
  +String note
  +getNote()
  +createEmail()
}
class Prescription {
  -int name
  -long description
  +int updatedAt
  +float createdAt
  +processLevel()
  +calculateNote()
  +updateUpdatedat()
  +deleteQuantity()
}
class Diagnosis {
  +Date duration
  #float status
  #Date note
  #Date name
  +processEmail()
  +cancelQuantity()
  +validateCode()
}
interface Insurance {
  +boolean type
  -long name
  +createType()
}
Doctor --* Patient
Doctor ..> Prescription : "0..1"
Prescription ..|> Diagnosis
Diagnosis --|> Doctor
@enduml