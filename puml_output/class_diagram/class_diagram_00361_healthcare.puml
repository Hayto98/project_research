@startuml
skinparam shadowing true
abstract class Insurance {
  #Date createdAt
  +float level
  -Date total
  +float code
  +createTotal()
  +cancelAmount()
  +validateId()
  +saveDescription()
}
class Diagnosis {
  +float active
  #Date updatedAt
  -String price
  #boolean type
  #int note
  +updateDescription()
  +calculateDuration()
  +createId()
  +createAmount()
}
class Treatment {
  #Date email
  +double status
  #double price
  +setId()
  +validateCreatedat()
  +sendScore()
  +updateActive()
}
class Patient {
  -boolean level
  -float quantity
  +calculateLevel()
  +processId()
  +cancelCreatedat()
  +findCreatedat()
}
Diagnosis ..> Insurance : "1..*"
Insurance ..|> Treatment
@enduml