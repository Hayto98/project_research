@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
abstract class CheckOut {
  +int email
  +float name
  +double score
  -double status
  +updateQuantity()
  +findAddress()
  +createPhone()
}
class Amenity {
  +double active
  +int name
  -Date amount
  #boolean status
  +sendDuration()
  +processId()
  +saveCreatedat()
}
interface Payment {
  #int email
  +float duration
  +setAddress()
  +findAmount()
  +sendStatus()
  +createActive()
}
class Service {
  +int price
  -float amount
  #String total
  +double phone
  +boolean name
  +getLevel()
}
Service --> Amenity : "0..1"
CheckOut ..> Payment : "1"
note right of CheckOut : Hotel domain
@enduml