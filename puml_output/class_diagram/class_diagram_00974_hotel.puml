@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
abstract class CheckOut {
  +int email
  +float name
  +double score
  -double status
  +findLevel()
  +sendEmail()
  +createQuantity()
}
class Amenity {
  +int phone
  +int createdAt
  -int email
  +long active
  +findPrice()
  +setId()
  +cancelCode()
}
class Payment {
  #long level
  #int status
  +float email
  +processAmount()
  +validateScore()
  +updateScore()
  +processUpdatedat()
}
interface Service {
  +double email
  -int active
  +processStatus()
  +saveEmail()
  +getEmail()
  +calculateNote()
}
CheckOut --o Service
CheckOut --|> Payment
@enduml