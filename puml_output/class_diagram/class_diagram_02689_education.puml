@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
interface Enrollment {
  +Date status
  #boolean name
  +String level
  #Date score
  #Date code
  +findTotal()
}
class Library {
  +double phone
  #Date updatedAt
  #boolean active
  -double id
  +createLevel()
  +processScore()
}
class Assignment {
  -Date price
  #double duration
  +float status
  #boolean type
  +long createdAt
  +deleteDuration()
}
class Schedule {
  #float active
  +String score
  +boolean price
  +saveTotal()
}
Enrollment --o Schedule
Enrollment --> Assignment : "1"
Assignment ..|> Enrollment
@enduml