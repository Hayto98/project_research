@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
interface Enrollment {
  +Date status
  #boolean name
  +String level
  #Date score
  #Date code
  +validateQuantity()
}
class Library {
  -boolean active
  #Date id
  #long level
  +deletePhone()
  +sendPrice()
  +calculatePrice()
  +findStatus()
}
abstract class Assignment {
  #boolean note
  +long total
  #String amount
  +validateDescription()
  +sendDuration()
  +sendPrice()
  +cancelCreatedat()
}
class Schedule {
  +int level
  -Date code
  +float quantity
  +sendEmail()
}
Library --o Schedule
Assignment ..> Enrollment : "1..*"
note right of Enrollment : Education domain
@enduml