@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
abstract class Beneficiary {
  -boolean quantity
  -boolean address
  +boolean note
  +long active
  +float createdAt
  +cancelStatus()
  +sendEmail()
}
interface Branch {
  -int id
  -boolean total
  +cancelCode()
  +calculateEmail()
}
class Interest {
  #boolean code
  +boolean score
  #long total
  #long quantity
  +validateDuration()
  +updateEmail()
  +sendEmail()
  +setAmount()
}
class Card {
  +long note
  -String email
  +double score
  +saveStatus()
  +createId()
  +calculateCode()
  +validateQuantity()
}
abstract class Transfer {
  +double email
  -Date id
  -Date amount
  -Date quantity
  -boolean status
  +calculateDuration()
  +validatePhone()
}
Card --o Interest
Interest --* Transfer
Beneficiary --> Branch : "1..*"
Interest ..|> Branch
@enduml