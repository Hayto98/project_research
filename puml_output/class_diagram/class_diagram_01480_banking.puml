@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
abstract class Beneficiary {
  -boolean quantity
  -boolean address
  +boolean note
  +long active
  +float createdAt
  +setCreatedat()
  +cancelCode()
}
class Branch {
  -String note
  +boolean createdAt
  -String total
  #Date active
  #double level
  +findDuration()
  +setLevel()
  +findAddress()
}
class Interest {
  -long address
  #boolean total
  +long createdAt
  -String score
  +double description
  +calculateAmount()
  +processType()
  +saveEmail()
  +getAmount()
}
interface Card {
  #double status
  #double createdAt
  #long total
  #float type
  +sendCode()
  +findNote()
}
class Transfer {
  #boolean quantity
  -float phone
  -int email
  +long id
  -int description
  +cancelLevel()
  +deletePrice()
}
Transfer --o Branch
Branch --* Card
note right of Beneficiary : Banking domain
@enduml