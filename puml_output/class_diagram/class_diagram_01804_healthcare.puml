@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Prescription {
  #Date status
  -Date updatedAt
  #long active
  -long type
  +deleteStatus()
}
abstract class Billing {
  -boolean type
  #long active
  +long phone
  +findId()
  +getPrice()
}
class Diagnosis {
  +float phone
  -int amount
  +String email
  #boolean duration
  +getActive()
  +findNote()
}
class Patient {
  +int name
  -Date amount
  +saveLevel()
  +saveName()
  +processTotal()
  +createScore()
}
class MedicalRecord {
  +int updatedAt
  -Date active
  #boolean id
  +cancelActive()
  +createQuantity()
  +saveAddress()
  +getActive()
}
abstract class Treatment {
  -String address
  -boolean code
  +processTotal()
  +deleteStatus()
}
Treatment ..|> Patient
Diagnosis --o Patient
Prescription --> Treatment : "0..1"
MedicalRecord --|> Billing
@enduml