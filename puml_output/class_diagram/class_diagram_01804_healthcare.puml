@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Prescription {
  #Date status
  -Date updatedAt
  #long active
  -long type
  +savePrice()
}
class Billing {
  -int active
  +float phone
  #long note
  -long address
  +long id
  +deleteType()
  +deleteUpdatedat()
  +getScore()
}
class Diagnosis {
  +int code
  +int duration
  +savePrice()
  +calculateNote()
  +updateCreatedat()
}
class Patient {
  +long active
  #Date id
  #double level
  +deleteNote()
  +getAddress()
  +setNote()
}
class MedicalRecord {
  #float active
  -int updatedAt
  -double note
  -String phone
  +cancelLevel()
}
class Treatment {
  #double name
  +double email
  #String updatedAt
  +createActive()
  +findCode()
  +processName()
}
Diagnosis ..|> Treatment
MedicalRecord --* Prescription
note right of Prescription : Healthcare domain
@enduml