@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Invoice {
  #int createdAt
  #long email
  -float note
  +calculatePrice()
  +cancelDuration()
}
class Return {
  +Date updatedAt
  +float description
  +float duration
  #float address
  -long code
  +calculateCreatedat()
  +findDuration()
  +deleteName()
}
interface Cart {
  #int description
  #double duration
  #boolean createdAt
  +Date price
  -boolean note
  +processUpdatedat()
  +createQuantity()
  +processTotal()
}
class Wishlist {
  -long createdAt
  #float name
  #float active
  #boolean updatedAt
  +cancelNote()
  +deleteLevel()
  +saveQuantity()
  +findDuration()
}
class Payment {
  #Date name
  +double type
  +deleteCreatedat()
}
abstract class Supplier {
  -Date updatedAt
  #long score
  +int note
  #long type
  +createDuration()
  +sendDescription()
  +setAddress()
}
Cart --|> Return
Payment ..> Supplier : "1..*"
@enduml