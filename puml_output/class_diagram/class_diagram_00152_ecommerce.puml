@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
interface Review {
  -double id
  #long price
  +calculateName()
}
class Supplier {
  #Date createdAt
  +int duration
  #String level
  +float phone
  +cancelAddress()
}
class Coupon {
  #String type
  -float quantity
  #Date phone
  -String name
  +processStatus()
  +calculateName()
}
abstract class Product {
  #boolean description
  -long updatedAt
  +cancelLevel()
  +cancelCode()
}
Review ..> Product : "1"
Review --> Coupon : "*"
Product --* Coupon
@enduml