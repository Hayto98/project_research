@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
interface Review {
  -double id
  #long price
  +validatePhone()
}
class Supplier {
  #Date createdAt
  +int duration
  #String phone
  +sendName()
}
class Coupon {
  -long quantity
  #float type
  +sendCode()
}
abstract class Product {
  -boolean code
  #String description
  #int phone
  #int address
  +createDescription()
  +processNote()
  +sendName()
  +updateId()
}
Product --> Supplier : "1..*"
Review --o Supplier
note right of Review : Ecommerce domain
@enduml