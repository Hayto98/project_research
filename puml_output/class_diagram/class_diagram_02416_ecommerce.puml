@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Review {
  #boolean price
  #long status
  -boolean note
  +int active
  +int updatedAt
  +processCreatedat()
  +findStatus()
  +calculateStatus()
}
interface Category {
  +Date createdAt
  -long quantity
  +double price
  +setQuantity()
  +setPhone()
}
class Order {
  +boolean createdAt
  -int type
  -long name
  +Date score
  +findStatus()
  +calculateEmail()
  +updateDescription()
  +validateScore()
}
abstract class Product {
  #boolean id
  +double address
  +saveStatus()
  +calculateCreatedat()
}
Review --|> Category
Category --* Review
note right of Review : Ecommerce domain
@enduml