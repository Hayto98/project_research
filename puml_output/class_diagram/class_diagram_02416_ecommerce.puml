@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Review {
  #boolean price
  #long status
  -boolean note
  +int active
  +int updatedAt
  +sendName()
  +cancelUpdatedat()
  +sendId()
}
class Category {
  +Date status
  -long amount
  +double createdAt
  +String quantity
  #float price
  +findNote()
  +createAmount()
  +saveUpdatedat()
}
class Order {
  +boolean createdAt
  -int type
  -long name
  +Date score
  +updateCreatedat()
  +updateScore()
  +createPhone()
  +setNote()
}
class Product {
  -float description
  #String phone
  +long score
  +cancelCode()
}
Review ..|> Category
Category --* Review
@enduml