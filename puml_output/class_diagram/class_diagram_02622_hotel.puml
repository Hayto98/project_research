@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Reservation {
  #boolean amount
  +int score
  #long description
  -String phone
  +processActive()
  +findNote()
}
abstract class CheckOut {
  #int quantity
  +String email
  -String level
  #int address
  +processStatus()
  +saveType()
}
interface Booking {
  +int phone
  -Date price
  -String quantity
  -double level
  +updateQuantity()
  +saveNote()
  +cancelName()
}
interface Amenity {
  -int id
  +double phone
  +findCreatedat()
  +calculateEmail()
  +validateType()
  +createAmount()
}
abstract class Housekeeping {
  #String active
  #boolean type
  -int email
  +float id
  +updateId()
  +sendPrice()
  +getNote()
  +validateDuration()
}
class CheckIn {
  +float status
  #boolean level
  #String email
  -int total
  +boolean description
  +getAddress()
  +cancelScore()
  +getId()
  +processDuration()
}
Amenity --o Housekeeping
Housekeeping --o Booking
@enduml