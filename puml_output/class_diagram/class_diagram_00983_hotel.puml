@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Guest {
  #Date id
  #int name
  #Date phone
  +double price
  +cancelTotal()
  +deleteScore()
}
abstract class Booking {
  +Date createdAt
  +long updatedAt
  +long name
  #boolean level
  -int description
  +sendDuration()
  +validateAddress()
  +deleteDescription()
}
class Amenity {
  +int note
  -String level
  -boolean phone
  +sendUpdatedat()
  +cancelUpdatedat()
}
abstract class Room {
  +String status
  +float quantity
  #String email
  -boolean description
  #boolean type
  +createLevel()
  +cancelCreatedat()
  +calculateEmail()
  +sendUpdatedat()
}
abstract class Housekeeping {
  #double phone
  +String description
  #int note
  #Date address
  #boolean createdAt
  +saveQuantity()
}
Housekeeping --o Room
Room ..|> Housekeeping
note right of Guest : Hotel domain
@enduml