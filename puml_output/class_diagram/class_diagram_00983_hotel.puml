@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Guest {
  #Date id
  #int name
  #Date phone
  +double price
  +processEmail()
  +updateEmail()
}
class Booking {
  +String total
  #String createdAt
  -int updatedAt
  -boolean name
  #double score
  +findCreatedat()
  +saveStatus()
}
interface Amenity {
  +double address
  #float description
  -String level
  +long id
  +deleteAmount()
}
interface Room {
  -double score
  +long updatedAt
  #long level
  +setActive()
  +processPhone()
}
abstract class Housekeeping {
  +float code
  -boolean description
  #boolean score
  +createQuantity()
  +deleteUpdatedat()
  +findName()
  +updateDescription()
}
Amenity ..> Booking : "*"
Housekeeping --* Room
Booking --* Room
@enduml