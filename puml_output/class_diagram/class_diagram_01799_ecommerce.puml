@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
interface Return {
  +float duration
  -int price
  -boolean code
  +saveCode()
  +processScore()
  +updateCreatedat()
}
class Product {
  -double total
  -long updatedAt
  +boolean quantity
  -double note
  +double status
  +createId()
  +saveActive()
}
abstract class Category {
  +float id
  -int description
  +cancelAddress()
  +validateName()
  +calculateType()
  +processDescription()
}
abstract class Order {
  -double active
  -float status
  +int updatedAt
  +String phone
  #long amount
  +saveAmount()
  +setDescription()
  +updateScore()
}
class Payment {
  #long quantity
  -int active
  -long email
  +createStatus()
  +setEmail()
  +deleteLevel()
  +deleteCreatedat()
}
interface Shipment {
  #Date code
  +double createdAt
  +findName()
  +setAmount()
}
Payment --* Shipment
Category --|> Payment
@enduml