@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Ward {
  +Date type
  +int active
  -String amount
  -double score
  +saveDuration()
  +deleteCode()
}
abstract class Diagnosis {
  -long email
  +float description
  #double active
  +sendLevel()
  +validateName()
  +setUpdatedat()
  +saveScore()
}
class Doctor {
  #int price
  +float name
  +int address
  #boolean active
  #float note
  +findDuration()
  +saveEmail()
}
class Nurse {
  #int quantity
  #Date type
  +createType()
  +findName()
  +calculateDuration()
  +processUpdatedat()
}
interface Patient {
  #int description
  +Date name
  -float phone
  +long amount
  +calculateStatus()
  +deleteScore()
  +findName()
}
interface LabTest {
  #double createdAt
  +String email
  -String active
  +updateAmount()
}
class Billing {
  -boolean createdAt
  #int name
  #float id
  +cancelDescription()
  +sendAddress()
  +sendName()
}
Doctor --|> LabTest
Doctor --o Diagnosis
LabTest ..|> Diagnosis
@enduml