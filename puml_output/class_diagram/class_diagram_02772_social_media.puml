@startuml
skinparam monochrome true
skinparam ArrowColor #555555
interface Follower {
  -Date active
  +boolean status
  #int updatedAt
  #float type
  +deleteNote()
}
interface Like {
  #String updatedAt
  -Date quantity
  +setScore()
  +deleteActive()
  +findQuantity()
}
class Comment {
  -boolean description
  +float level
  #float active
  +getActive()
  +getTotal()
  +getDescription()
  +sendDuration()
}
class Message {
  -Date updatedAt
  -Date description
  +boolean name
  +saveCode()
}
class Notification {
  +boolean address
  +long code
  #boolean description
  +deleteStatus()
  +getName()
  +deleteUpdatedat()
  +deleteType()
}
class Post {
  #float name
  +boolean total
  #long note
  #String quantity
  #long active
  +sendPhone()
  +setActive()
  +findEmail()
}
Notification ..> Message : "1"
Message ..> Follower : "0..1"
Message ..|> Like
Post --* Follower
Message --|> Post
@enduml