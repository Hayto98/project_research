@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Tracking {
  -Date amount
  +boolean updatedAt
  +Date quantity
  #long email
  +saveLevel()
  +cancelAmount()
}
class Customer {
  +int price
  -String type
  -String name
  +processDescription()
  +getQuantity()
  +processPrice()
}
class Shipment {
  -boolean score
  +double id
  +processActive()
  +updateEmail()
}
class Inventory {
  #double email
  #String updatedAt
  -Date name
  #boolean id
  +int duration
  +deleteQuantity()
  +sendEmail()
  +validateStatus()
}
class Driver {
  +int quantity
  #float phone
  -float type
  +savePhone()
  +processLevel()
}
Driver --o Customer
note right of Tracking : Logistics domain
@enduml