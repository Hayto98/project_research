@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Tracking {
  -Date amount
  +boolean updatedAt
  +Date quantity
  #long email
  +cancelDuration()
  +cancelActive()
}
interface Customer {
  #double updatedAt
  +String duration
  +double price
  +createQuantity()
}
class Shipment {
  -Date note
  -long description
  +Date name
  #boolean quantity
  +processPhone()
}
class Inventory {
  +double price
  #int score
  +getLevel()
  +deleteActive()
  +deleteCreatedat()
}
class Driver {
  #double id
  #String email
  +saveUpdatedat()
  +calculateStatus()
  +getCode()
  +setType()
}
Shipment --* Customer
Driver --* Shipment
@enduml