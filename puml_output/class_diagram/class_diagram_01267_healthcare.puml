@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Ward {
  -boolean id
  #long price
  +boolean phone
  -double code
  +setName()
}
class Doctor {
  +float id
  -long level
  +String updatedAt
  +int duration
  +long amount
  +findDuration()
  +cancelPhone()
  +calculateTotal()
}
class Prescription {
  #double description
  #Date note
  +int price
  #boolean createdAt
  -double type
  +setNote()
}
abstract class Hospital {
  +Date score
  -int email
  +long status
  -float id
  +cancelId()
  +validatePhone()
  +setActive()
  +findPhone()
}
class Appointment {
  -String level
  -long duration
  +processDescription()
}
class Diagnosis {
  -boolean updatedAt
  #int total
  #String level
  #int active
  +calculatePrice()
  +findLevel()
}
abstract class MedicalRecord {
  -float type
  -double name
  #Date score
  -boolean phone
  #Date updatedAt
  +createCreatedat()
}
Prescription --* Doctor
Diagnosis ..> MedicalRecord : "0..1"
@enduml