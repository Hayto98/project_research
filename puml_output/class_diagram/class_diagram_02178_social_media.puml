@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
abstract class Report {
  -long note
  #double phone
  -float amount
  -long score
  #String price
  +getStatus()
  +setNote()
  +createPrice()
  +findType()
}
class Story {
  #String type
  -String address
  +calculateId()
  +calculateUpdatedat()
  +createLevel()
}
interface Message {
  +long amount
  +String updatedAt
  +createScore()
  +saveNote()
}
abstract class Album {
  +Date email
  #Date quantity
  +calculateNote()
}
class Group {
  +float quantity
  #Date note
  +setUpdatedat()
  +updateLevel()
}
abstract class Notification {
  #boolean id
  #String total
  +updateActive()
  +getDuration()
  +deleteCreatedat()
}
abstract class Post {
  #Date updatedAt
  -Date score
  -String total
  +int amount
  -double address
  +sendPrice()
  +validateAmount()
  +calculateStatus()
}
Post --|> Story
Report --* Group
Notification --* Group
Story ..> Message : "1..*"
Notification ..|> Album
note right of Report : Social Media domain
@enduml