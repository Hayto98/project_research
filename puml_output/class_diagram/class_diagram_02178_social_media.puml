@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
abstract class Report {
  -long note
  #double phone
  -float amount
  -long score
  #String price
  +deletePhone()
  +saveEmail()
  +saveLevel()
  +calculateType()
}
class Story {
  -float note
  #double email
  +savePrice()
}
class Message {
  -String address
  -int status
  -boolean duration
  #float id
  #float email
  +calculateAddress()
}
class Album {
  #int quantity
  -boolean id
  #double code
  +saveEmail()
  +sendAddress()
  +processDescription()
  +updateDescription()
}
interface Group {
  +boolean total
  #Date note
  +updateLevel()
}
abstract class Notification {
  +float level
  #int updatedAt
  +findName()
  +calculateAmount()
}
class Post {
  #String total
  -float level
  +createDescription()
  +calculateId()
}
Story --o Post
Post ..|> Album
Group --o Notification
Story --> Notification : "1..*"
Message --* Notification
@enduml