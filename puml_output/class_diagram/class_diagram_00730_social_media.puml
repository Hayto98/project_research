@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Notification {
  -int description
  #int duration
  +float quantity
  +cancelName()
  +validateCode()
  +setAddress()
}
interface Message {
  -int email
  #long quantity
  +int amount
  +deleteTotal()
  +deleteName()
  +calculateCreatedat()
  +deleteTotal()
}
abstract class Report {
  +String code
  +Date note
  +long description
  -double score
  #String level
  +setId()
  +createDuration()
}
abstract class Profile {
  -long level
  #float total
  -float email
  -String amount
  +createId()
  +createLevel()
  +deleteAmount()
  +validateCreatedat()
}
interface Story {
  #float note
  -int amount
  #Date code
  -Date quantity
  +sendScore()
}
class User {
  #double code
  #double price
  -String quantity
  -double amount
  +String total
  +createCode()
  +findUpdatedat()
}
Notification --> Story : "1..*"
User --> Report : "0..1"
note right of Notification : Social Media domain
@enduml