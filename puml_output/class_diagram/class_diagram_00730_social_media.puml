@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Notification {
  -int description
  #int duration
  +float quantity
  +saveDuration()
  +validateStatus()
  +sendDescription()
}
class Message {
  -long code
  +double duration
  +boolean address
  -int amount
  +getName()
  +getAddress()
}
class Report {
  -double amount
  #double name
  +double price
  +Date createdAt
  +Date duration
  +createCode()
  +validateId()
  +validateStatus()
  +saveLevel()
}
class Profile {
  #String quantity
  #boolean phone
  +String price
  +cancelAddress()
}
interface Story {
  -long address
  #float level
  -float total
  -String email
  -long amount
  +deleteCreatedat()
}
interface User {
  #boolean amount
  #boolean phone
  -double createdAt
  +calculateType()
  +validatePhone()
}
User ..|> Report
User ..> Profile : "1"
Story ..|> User
User --> Story : "*"
@enduml