@startuml
skinparam defaultFontSize 13
class Teacher {
  -int score
  -int address
  #int type
  +processCreatedat()
  +saveEmail()
}
class Exam {
  #long status
  -int score
  -long duration
  +deleteCode()
  +deleteNote()
  +setAddress()
}
abstract class Grade {
  +String duration
  -Date total
  -boolean name
  -boolean level
  +calculateAddress()
}
class Enrollment {
  -long score
  #boolean status
  +calculateTotal()
  +cancelActive()
  +deleteAmount()
}
class Assignment {
  #boolean updatedAt
  #double total
  +cancelDescription()
  +findDuration()
  +saveScore()
  +setId()
}
class Classroom {
  -boolean amount
  #float phone
  +float address
  +float total
  +String code
  +findScore()
}
abstract class Attendance {
  +float level
  #boolean type
  +validateId()
  +setQuantity()
  +createPrice()
  +processStatus()
}
Enrollment ..|> Classroom
Enrollment --> Teacher : "*"
Grade ..|> Enrollment
Attendance ..|> Classroom
note right of Teacher : Education domain
@enduml