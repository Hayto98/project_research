@startuml
skinparam defaultFontSize 13
class Teacher {
  -int score
  -int address
  #int type
  +saveAmount()
  +sendEmail()
}
class Exam {
  #Date updatedAt
  #Date status
  +processNote()
}
class Grade {
  +int amount
  -String type
  -Date phone
  #Date email
  -long description
  +savePhone()
  +setId()
  +findAmount()
  +sendEmail()
}
class Enrollment {
  #float type
  +double score
  -String note
  +boolean active
  +updateTotal()
}
class Assignment {
  #int price
  +float total
  +int active
  -boolean amount
  +deleteType()
  +deleteActive()
  +getCode()
  +createCreatedat()
}
interface Classroom {
  -int id
  -long description
  +createAddress()
  +sendPhone()
  +calculateActive()
  +createUpdatedat()
}
class Attendance {
  +Date status
  #boolean duration
  +calculateType()
  +getPrice()
  +processAmount()
  +saveDuration()
}
Teacher --> Classroom : "*"
Grade --|> Teacher
Classroom --* Grade
Attendance --o Enrollment
@enduml