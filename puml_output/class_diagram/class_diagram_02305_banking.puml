@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Transaction {
  -Date description
  -double createdAt
  +processAddress()
  +processName()
  +calculatePhone()
  +saveType()
}
interface Teller {
  -int note
  #boolean level
  -long quantity
  -long email
  +findPrice()
  +findCreatedat()
}
class Customer {
  #float price
  #long address
  -int total
  +float name
  +findType()
  +deleteName()
}
class Withdrawal {
  -String type
  -String duration
  +boolean createdAt
  +int id
  +calculateQuantity()
  +setCreatedat()
  +setQuantity()
  +validateActive()
}
Customer --o Transaction
Teller --|> Customer
note right of Transaction : Banking domain
@enduml