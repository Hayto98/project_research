@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Transaction {
  -Date description
  -double createdAt
  +calculateAmount()
  +saveCreatedat()
  +sendName()
  +deleteEmail()
}
class Teller {
  #long phone
  -double type
  +Date active
  #double quantity
  -long note
  +setType()
  +calculateDescription()
  +calculateType()
}
abstract class Customer {
  #long phone
  -float email
  #String price
  +updateTotal()
  +updateType()
  +sendStatus()
}
class Withdrawal {
  -long type
  #float description
  -double name
  +updatePrice()
  +deleteDuration()
}
Customer --|> Transaction
Transaction --> Withdrawal : "*"
@enduml