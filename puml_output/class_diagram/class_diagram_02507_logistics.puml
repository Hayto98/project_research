@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
abstract class Package {
  #String active
  +float email
  +setNote()
  +cancelUpdatedat()
  +savePhone()
}
class Customer {
  -long email
  +String score
  +updateCode()
  +updatePhone()
  +findId()
}
abstract class Manifest {
  #float score
  +boolean name
  -int updatedAt
  +getId()
  +validateDescription()
  +getDuration()
}
class DeliveryNote {
  +Date score
  +String name
  +findCreatedat()
  +createTotal()
}
class Depot {
  #Date note
  +double id
  -String description
  #double duration
  -double quantity
  +validateDuration()
}
class Warehouse {
  +String email
  +boolean updatedAt
  +boolean code
  +saveStatus()
  +saveActive()
  +getName()
}
Package --* Depot
Customer --|> Depot
Manifest ..> DeliveryNote : "*"
Package --> DeliveryNote : "0..1"
note right of Package : Logistics domain
@enduml