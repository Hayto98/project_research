@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
abstract class Package {
  #String active
  +float email
  +getLevel()
  +findLevel()
  +deletePhone()
}
abstract class Customer {
  -float phone
  #boolean id
  -long code
  +sendLevel()
}
class Manifest {
  #float updatedAt
  +double code
  +boolean createdAt
  +int phone
  +createDescription()
  +createId()
}
abstract class DeliveryNote {
  -float phone
  +String name
  #int id
  +calculatePrice()
}
class Depot {
  +float code
  #int status
  +saveStatus()
  +setQuantity()
  +updateEmail()
}
class Warehouse {
  #Date note
  +double id
  -String description
  #double duration
  -double quantity
  +saveStatus()
}
Depot ..|> Package
Manifest ..> Customer : "1"
Package ..|> Warehouse
Depot --> Customer : "1..*"
@enduml