@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Room {
  -int total
  -int createdAt
  +String address
  +findTotal()
  +findPhone()
  +updateDescription()
  +createStatus()
}
interface Reservation {
  #String email
  +String description
  +updateId()
}
abstract class Payment {
  -Date quantity
  +double updatedAt
  +float phone
  #boolean total
  +calculateId()
}
class CheckOut {
  -int updatedAt
  -long score
  -long description
  -boolean phone
  #long amount
  +getTotal()
}
abstract class Amenity {
  -long duration
  -boolean createdAt
  +boolean updatedAt
  #float description
  +updateLevel()
  +setType()
  +updateCreatedat()
}
class Restaurant {
  +String duration
  #boolean phone
  -long status
  +createScore()
  +cancelPrice()
}
class Housekeeping {
  -boolean amount
  -String level
  -long quantity
  -long address
  +updateDescription()
  +sendEmail()
  +calculateName()
}
Payment --o Reservation
Restaurant --* Reservation
note right of Room : Hotel domain
@enduml