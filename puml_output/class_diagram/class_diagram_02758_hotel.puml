@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Room {
  -int total
  -int createdAt
  +String address
  +getActive()
  +processLevel()
  +saveStatus()
  +cancelDescription()
}
class Reservation {
  #float description
  #String email
  #long status
  +findDuration()
  +setUpdatedat()
}
class Payment {
  +float id
  -Date createdAt
  +setTotal()
  +getPrice()
  +createScore()
}
class CheckOut {
  -String phone
  -double id
  +boolean note
  #int amount
  -int level
  +createScore()
  +deleteName()
  +calculateTotal()
  +calculatePhone()
}
class Amenity {
  +double address
  #double score
  -boolean phone
  +Date id
  +cancelLevel()
  +getAmount()
}
interface Restaurant {
  #int quantity
  #boolean phone
  -int address
  +sendCreatedat()
}
class Housekeeping {
  +String address
  +boolean description
  #double phone
  +findPhone()
  +cancelPhone()
  +getCreatedat()
}
CheckOut ..> Payment : "1..*"
Reservation --* Amenity
Payment --> Housekeeping : "1..*"
Room --* CheckOut
Payment ..|> Reservation
@enduml