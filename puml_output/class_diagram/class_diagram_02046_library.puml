@startuml
skinparam monochrome true
skinparam defaultFontSize 11
abstract class Author {
  #long createdAt
  -float active
  +sendScore()
  +cancelActive()
  +updateDescription()
  +deleteUpdatedat()
}
class Book {
  #int amount
  -Date id
  +sendPrice()
  +savePhone()
  +saveEmail()
}
class Catalog {
  -float name
  +boolean type
  +createEmail()
}
class Renewal {
  -float description
  #boolean email
  -String price
  +boolean note
  -int active
  +cancelCode()
  +sendQuantity()
}
Author --|> Book
note right of Author : Library domain
@enduml