@startuml
skinparam monochrome true
skinparam defaultFontSize 11
abstract class Author {
  #long createdAt
  -float active
  +findPrice()
  +findEmail()
  +findTotal()
  +getUpdatedat()
}
interface Book {
  +Date description
  +int amount
  +boolean updatedAt
  +processTotal()
  +cancelDescription()
}
class Catalog {
  #double phone
  -float email
  +boolean duration
  +long status
  #long name
  +validateUpdatedat()
}
class Renewal {
  -float price
  #boolean score
  -String note
  +boolean level
  +deleteScore()
  +sendType()
  +saveQuantity()
  +sendStatus()
}
Catalog --|> Renewal
Author --|> Book
@enduml