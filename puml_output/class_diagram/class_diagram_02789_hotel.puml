@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
abstract class Staff {
  -double total
  #Date level
  +saveType()
  +getScore()
  +setPrice()
}
interface Guest {
  +long quantity
  +float total
  +setName()
  +updatePhone()
}
class Room {
  #boolean amount
  -long price
  +String createdAt
  +int type
  #int note
  +getId()
  +setNote()
}
abstract class Invoice {
  +String name
  +boolean id
  +processEmail()
  +deleteCode()
}
class Payment {
  -int name
  #boolean level
  +saveType()
}
Payment ..> Guest : "1..*"
Invoice --o Guest
Invoice --o Staff
@enduml