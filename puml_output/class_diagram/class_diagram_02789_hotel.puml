@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
abstract class Staff {
  -double total
  #Date level
  +sendActive()
  +getQuantity()
  +calculateStatus()
}
class Guest {
  #float updatedAt
  +double id
  +calculateCreatedat()
  +processNote()
}
interface Room {
  +boolean phone
  +boolean createdAt
  +double name
  -double level
  +getId()
}
class Invoice {
  +boolean name
  -float level
  +getName()
  +cancelEmail()
  +deleteLevel()
}
class Payment {
  +double duration
  #double description
  +double quantity
  #float total
  +updateLevel()
}
Room --> Staff : "1..*"
Staff --|> Guest
note right of Staff : Hotel domain
@enduml