@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Service {
  +long createdAt
  #float quantity
  #double email
  #long address
  +long phone
  +createDuration()
}
class Payment {
  #long level
  #boolean score
  #Date address
  +deleteStatus()
}
class Housekeeping {
  -float type
  #int total
  #float id
  -double phone
  +findId()
  +updateNote()
  +deleteId()
}
interface Staff {
  +float email
  +String total
  #int address
  #Date description
  +boolean type
  +validateCreatedat()
}
class Amenity {
  #boolean address
  -int description
  +float code
  -float price
  +sendType()
  +setEmail()
  +findUpdatedat()
  +setLevel()
}
class CheckIn {
  #boolean code
  -int price
  -double status
  -double email
  #int type
  +sendEmail()
  +createDescription()
  +validateActive()
}
Payment --* CheckIn
Service --o Housekeeping
Staff --|> Payment
CheckIn ..|> Service
note right of Service : Hotel domain
@enduml