@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Service {
  +long createdAt
  #float quantity
  #double email
  #long address
  +long phone
  +setAmount()
}
class Payment {
  -float active
  #long updatedAt
  #boolean score
  +saveAddress()
}
class Housekeeping {
  #String active
  -long address
  #int type
  #float total
  +saveAmount()
  +saveCreatedat()
  +saveDescription()
}
class Staff {
  #boolean note
  -long description
  -long id
  +sendCreatedat()
  +processQuantity()
}
class Amenity {
  #Date active
  +boolean amount
  +saveScore()
}
class CheckIn {
  +Date phone
  -boolean address
  #long description
  +calculateId()
  +saveLevel()
}
Staff ..> Amenity : "*"
Service ..> Housekeeping : "0..1"
Service --|> Amenity
Staff --o Service
@enduml