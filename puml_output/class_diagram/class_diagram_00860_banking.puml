@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
abstract class Account {
  -int description
  +boolean status
  -String active
  +updateDescription()
}
class Loan {
  #String createdAt
  -Date price
  +validateAmount()
  +sendUpdatedat()
}
class Teller {
  +float duration
  -int score
  -int note
  +Date status
  -long active
  +deleteQuantity()
}
interface Customer {
  -String email
  #String total
  -long price
  +findUpdatedat()
  +findCreatedat()
}
abstract class Branch {
  -long score
  -int level
  -float createdAt
  #int active
  +int type
  +getName()
  +deleteQuantity()
  +validateQuantity()
}
class Beneficiary {
  #int name
  #double active
  #Date description
  #float id
  +updateName()
  +updateDuration()
}
class Transfer {
  #long total
  -Date address
  -Date updatedAt
  +validateActive()
}
Loan ..|> Beneficiary
Account ..> Customer : "1..*"
Loan --> Teller : "1..*"
@enduml