@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Supplier {
  #float email
  #double address
  +long createdAt
  +calculateCode()
  +cancelDuration()
  +calculateAmount()
  +createStatus()
}
class Payment {
  +Date id
  -float level
  +boolean address
  +updateCode()
  +validatePhone()
  +updatePrice()
}
class Coupon {
  +Date type
  #String duration
  +getPhone()
  +validateScore()
  +deletePrice()
}
abstract class Invoice {
  -int active
  +long level
  +Date code
  +long email
  +processUpdatedat()
  +setStatus()
  +calculateUpdatedat()
}
Supplier --> Invoice : "1"
Payment --> Invoice : "1..*"
@enduml