@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Supplier {
  #float email
  #double address
  +long createdAt
  +calculateNote()
  +sendStatus()
  +deleteId()
  +cancelAddress()
}
class Payment {
  -String name
  -double phone
  +Date code
  #String id
  +calculateAddress()
  +processNote()
  +validateActive()
}
interface Coupon {
  -int level
  +long email
  +findUpdatedat()
}
class Invoice {
  +boolean amount
  +int status
  -boolean level
  -Date name
  +processName()
  +validateScore()
}
Coupon --* Supplier
Supplier --> Invoice : "1"
note right of Supplier : Ecommerce domain
@enduml