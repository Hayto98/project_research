@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
interface Nurse {
  -boolean code
  #Date id
  -long address
  +double amount
  #Date price
  +sendCode()
}
class Diagnosis {
  +int active
  -double total
  +saveScore()
}
class LabTest {
  #int note
  #String description
  -int duration
  -Date code
  #boolean id
  +validateTotal()
  +getId()
}
class MedicalRecord {
  +boolean total
  -int email
  +String updatedAt
  +sendCreatedat()
  +sendName()
  +saveLevel()
  +validateDescription()
}
class Hospital {
  #double email
  #double status
  +processType()
  +findId()
  +findUpdatedat()
}
class Appointment {
  #long updatedAt
  #float phone
  -long description
  -long code
  -boolean quantity
  +validateEmail()
  +findUpdatedat()
}
MedicalRecord --* Hospital
Diagnosis ..> Hospital : "1..*"
LabTest --o Nurse
Appointment --> LabTest : "1"
@enduml