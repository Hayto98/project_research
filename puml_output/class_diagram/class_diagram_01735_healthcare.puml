@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
interface Nurse {
  -boolean code
  #Date id
  -long address
  +double amount
  #Date price
  +processAmount()
}
class Diagnosis {
  -String amount
  #double createdAt
  -int address
  #Date note
  -String id
  +findCreatedat()
}
interface LabTest {
  -Date address
  #boolean amount
  +findType()
  +updateCreatedat()
}
abstract class MedicalRecord {
  +int updatedAt
  +double description
  -double score
  +String total
  +setType()
  +saveNote()
  +validatePrice()
}
class Hospital {
  -int total
  #String updatedAt
  +cancelEmail()
  +sendPhone()
  +createType()
}
class Appointment {
  -boolean level
  -float updatedAt
  +float status
  #boolean total
  +validateId()
  +processDescription()
  +cancelQuantity()
}
MedicalRecord --o Diagnosis
LabTest --o Appointment
note right of Nurse : Healthcare domain
@enduml