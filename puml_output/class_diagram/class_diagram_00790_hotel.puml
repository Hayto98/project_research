@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Amenity {
  #int note
  -double amount
  +Date phone
  -double id
  -Date address
  +updateDuration()
}
class Booking {
  +boolean description
  #Date active
  +cancelId()
  +processEmail()
  +createCode()
  +setScore()
}
class Guest {
  -Date createdAt
  +Date type
  #String level
  #float note
  +processEmail()
  +getNote()
  +deleteCreatedat()
  +findUpdatedat()
}
class Reservation {
  +float email
  -float createdAt
  +sendScore()
  +calculateNote()
}
Booking ..> Amenity : "*"
Guest ..|> Amenity
note right of Amenity : Hotel domain
@enduml