@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Amenity {
  #int note
  -double amount
  +Date phone
  -double id
  -Date address
  +deletePhone()
}
class Booking {
  #int name
  #Date description
  +validateActive()
  +updateActive()
  +deleteDuration()
  +calculateScore()
}
class Guest {
  +long code
  +Date score
  +setDuration()
  +deleteActive()
  +processTotal()
  +cancelId()
}
class Reservation {
  -float price
  +double note
  +sendId()
  +cancelUpdatedat()
}
Guest --* Amenity
Booking --o Amenity
@enduml