@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Route {
  #Date score
  +double status
  +findLevel()
  +deleteDescription()
  +setId()
  +savePrice()
}
class Package {
  -int type
  #Date quantity
  +getDescription()
}
class Warehouse {
  +Date address
  #long createdAt
  +Date email
  +processNote()
  +deleteType()
}
interface Shipment {
  #float quantity
  #String status
  +float type
  +updateDuration()
  +getLevel()
  +cancelPrice()
  +createDuration()
}
interface FuelLog {
  #Date total
  #float address
  -int price
  +updateAddress()
}
interface Tracking {
  #String quantity
  -int status
  +long type
  +sendCreatedat()
  +validateQuantity()
}
abstract class Vehicle {
  -boolean name
  +boolean id
  +calculateQuantity()
  +saveCode()
  +processAddress()
  +validatePhone()
}
Route --o Warehouse
Route --> Package : "1"
Package --> Warehouse : "1..*"
Tracking ..> Shipment : "1"
Shipment ..|> Warehouse
Vehicle --|> Tracking
@enduml