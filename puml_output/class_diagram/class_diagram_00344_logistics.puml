@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Shipment {
  +double updatedAt
  +long description
  #long type
  #int id
  +createQuantity()
  +updateNote()
  +saveCreatedat()
  +cancelDuration()
}
interface Driver {
  #String duration
  -double createdAt
  +cancelCode()
  +processStatus()
  +setLevel()
}
class DeliveryNote {
  #long name
  #Date code
  #int type
  +cancelQuantity()
  +cancelPrice()
  +setCreatedat()
}
interface Package {
  #boolean total
  #boolean id
  #boolean quantity
  +processAddress()
  +getId()
}
interface Inventory {
  #float price
  #String phone
  +deleteTotal()
  +getStatus()
}
Inventory ..> Package : "1..*"
Driver --o DeliveryNote
@enduml