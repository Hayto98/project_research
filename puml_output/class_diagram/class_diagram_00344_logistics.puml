@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Shipment {
  +double updatedAt
  +long description
  #long type
  #int id
  +createActive()
  +validateActive()
  +getDuration()
  +updateCode()
}
class Driver {
  +String phone
  +double type
  #long duration
  #Date description
  #int amount
  +processScore()
  +deleteTotal()
  +getQuantity()
}
interface DeliveryNote {
  -float type
  #long active
  #float status
  +findCreatedat()
}
class Package {
  #double phone
  -String updatedAt
  +float active
  +float address
  #float type
  +setNote()
}
class Inventory {
  +Date level
  +Date code
  +boolean total
  +saveEmail()
}
Package --* Shipment
DeliveryNote ..|> Driver
note right of Shipment : Logistics domain
@enduml