@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Profile {
  -boolean type
  #long quantity
  #float level
  +calculateScore()
  +setQuantity()
  +validateAmount()
  +cancelNote()
}
class Story {
  -boolean id
  +boolean phone
  +boolean address
  #String score
  +deleteCreatedat()
  +deleteId()
}
class Notification {
  -Date duration
  #float address
  +calculateCreatedat()
}
class Hashtag {
  #double address
  +int status
  +double description
  -double level
  +boolean total
  +setPrice()
}
class Like {
  #long code
  +float quantity
  #float active
  +cancelId()
  +getDuration()
}
Notification --* Hashtag
Profile ..> Hashtag : "*"
@enduml