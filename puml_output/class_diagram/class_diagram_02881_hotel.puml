@startuml
skinparam shadowing true
class Staff {
  #long quantity
  +double code
  +sendCreatedat()
  +sendId()
}
interface Housekeeping {
  +boolean email
  +int createdAt
  +validateEmail()
  +sendStatus()
  +validateTotal()
  +getCode()
}
abstract class Payment {
  #String description
  +float active
  +createName()
  +cancelAddress()
  +getStatus()
  +findUpdatedat()
}
class CheckOut {
  #Date total
  #boolean createdAt
  +long code
  -float address
  #long score
  +processCode()
}
abstract class Service {
  -float address
  -boolean code
  #float phone
  #boolean duration
  +sendId()
  +validatePhone()
  +validateDuration()
  +calculateName()
}
class Invoice {
  +int quantity
  #String email
  +long createdAt
  -long code
  +Date total
  +processType()
}
Service ..|> Invoice
note right of Staff : Hotel domain
@enduml