@startuml
skinparam shadowing true
class Staff {
  #long quantity
  +double code
  +findPrice()
  +saveNote()
}
interface Housekeeping {
  #float duration
  -int name
  +cancelAmount()
}
class Payment {
  -boolean active
  #String price
  -double phone
  +setQuantity()
}
class CheckOut {
  -long code
  +boolean description
  -float active
  +String id
  #Date updatedAt
  +saveAddress()
  +sendDuration()
}
abstract class Service {
  -long createdAt
  #long code
  +double address
  +float level
  -long amount
  +processAmount()
  +sendPhone()
  +createNote()
}
interface Invoice {
  -float note
  #String quantity
  -long active
  -boolean score
  +savePhone()
  +processActive()
  +sendCreatedat()
  +updateLevel()
}
Housekeeping --o Staff
Housekeeping ..> Invoice : "1"
Staff --o Payment
Payment ..> Housekeeping : "1"
@enduml