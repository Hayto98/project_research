@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Story {
  +long price
  -String status
  -long phone
  +boolean note
  +findCode()
  +setCreatedat()
  +cancelDuration()
}
abstract class Comment {
  +boolean amount
  #boolean createdAt
  -int description
  #double email
  -Date address
  +setCreatedat()
  +processActive()
  +updateActive()
  +getAmount()
}
interface Album {
  +float name
  -double email
  +int createdAt
  +updateStatus()
  +sendDuration()
  +deleteUpdatedat()
}
class Message {
  +Date active
  #int amount
  #double id
  +int description
  #Date quantity
  +updateLevel()
}
abstract class Notification {
  -boolean active
  +int updatedAt
  +float quantity
  +double address
  -boolean score
  +findScore()
  +processCreatedat()
}
class Hashtag {
  -boolean note
  +float id
  -boolean description
  +deleteUpdatedat()
  +saveDuration()
  +deleteActive()
}
class Profile {
  #int duration
  #Date createdAt
  +calculateDuration()
}
Profile --> Comment : "0..1"
Notification ..> Message : "1..*"
Message ..|> Album
Message ..> Story : "0..1"
note right of Story : Social Media domain
@enduml