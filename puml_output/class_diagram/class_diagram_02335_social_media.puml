@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Story {
  +long price
  -String status
  -long phone
  +boolean note
  +setCode()
  +saveUpdatedat()
  +getLevel()
}
class Comment {
  +int level
  +long note
  #boolean duration
  +createCreatedat()
  +createStatus()
  +deleteUpdatedat()
}
interface Album {
  +double description
  #int price
  #float address
  #String note
  +boolean code
  +saveId()
  +calculateScore()
}
class Message {
  +float quantity
  -int type
  +boolean code
  +createScore()
  +setActive()
}
class Notification {
  +Date active
  #int amount
  #double id
  +int description
  #Date quantity
  +setAmount()
}
class Hashtag {
  -long price
  #String active
  +String updatedAt
  +double quantity
  -boolean address
  +createTotal()
  +setActive()
}
interface Profile {
  +double createdAt
  #String description
  -boolean updatedAt
  -int note
  +Date id
  +getScore()
  +updateTotal()
}
Profile ..|> Notification
Notification --> Comment : "1"
@enduml