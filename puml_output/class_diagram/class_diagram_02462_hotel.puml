@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Reservation {
  -String type
  +String total
  -float code
  #Date score
  +createName()
  +deleteQuantity()
  +processType()
  +setScore()
}
interface Invoice {
  +int score
  +long code
  +deleteDescription()
}
interface CheckIn {
  -float updatedAt
  +boolean phone
  -long id
  #Date email
  +setEmail()
  +calculateQuantity()
  +sendType()
}
interface Amenity {
  #Date code
  +Date note
  +int amount
  #String description
  +updatePrice()
}
Reservation --> Invoice : "1"
CheckIn --o Amenity
Amenity ..> Invoice : "*"
@enduml