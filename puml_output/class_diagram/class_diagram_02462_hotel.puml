@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Reservation {
  -String type
  +String total
  -float code
  #Date score
  +processStatus()
  +calculateDuration()
  +getScore()
  +saveCode()
}
class Invoice {
  #boolean amount
  #long quantity
  +long id
  +createQuantity()
}
class CheckIn {
  #long phone
  +double quantity
  +int address
  #Date total
  +saveName()
}
class Amenity {
  #double name
  +double id
  +validatePrice()
}
Amenity --o CheckIn
Invoice --> CheckIn : "*"
CheckIn --> Reservation : "0..1"
note right of Reservation : Hotel domain
@enduml