@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
interface Loan {
  -boolean createdAt
  #String score
  -long name
  +long status
  +Date price
  +calculateTotal()
  +updateId()
}
abstract class Beneficiary {
  +long address
  -float status
  -double phone
  #double active
  +calculateQuantity()
  +updatePhone()
}
interface Interest {
  -int active
  +double note
  +createNote()
  +validatePhone()
}
class Statement {
  #Date id
  -String duration
  +boolean updatedAt
  +long total
  #float email
  +processCode()
  +processScore()
  +cancelCreatedat()
}
Beneficiary --> Interest : "1"
Loan --> Statement : "0..1"
@enduml