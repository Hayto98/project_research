@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
interface Loan {
  -boolean createdAt
  #String score
  -long name
  +long status
  +Date price
  +findTotal()
  +sendDuration()
}
class Beneficiary {
  -long status
  -double phone
  #double active
  +double amount
  +sendNote()
}
class Interest {
  +String updatedAt
  -String type
  +int createdAt
  +createType()
  +getStatus()
  +cancelCode()
  +createLevel()
}
interface Statement {
  #boolean id
  +float total
  +int duration
  #int description
  +saveDescription()
  +createUpdatedat()
  +saveDescription()
  +setQuantity()
}
Statement ..|> Beneficiary
Loan --o Beneficiary
note right of Loan : Banking domain
@enduml