@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Author {
  +double note
  #boolean description
  +long duration
  +Date score
  #Date amount
  +cancelCode()
}
class Reservation {
  -float email
  +long status
  +boolean total
  +String updatedAt
  +sendAmount()
  +saveAmount()
  +setCreatedat()
}
interface Branch {
  +Date duration
  #long total
  #long active
  -float email
  +int score
  +saveDuration()
  +deleteActive()
}
class Shelf {
  #float name
  +float updatedAt
  +saveType()
  +updateScore()
  +createStatus()
}
class Loan {
  +double email
  -float status
  #String active
  #int type
  +Date quantity
  +sendCreatedat()
  +getCode()
  +calculateActive()
}
class Fine {
  +int description
  +boolean address
  +float duration
  +createType()
}
Shelf --o Branch
note right of Author : Library domain
@enduml