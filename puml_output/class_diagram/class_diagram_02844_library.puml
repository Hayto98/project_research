@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Author {
  +double note
  #boolean description
  +long duration
  +Date score
  #Date amount
  +saveLevel()
}
interface Reservation {
  -float description
  +double phone
  +updateCreatedat()
  +deleteCode()
}
class Branch {
  #long id
  #int level
  #int duration
  +int status
  +findDescription()
  +processLevel()
  +createDescription()
  +findCreatedat()
}
class Shelf {
  #long active
  -float quantity
  +createCreatedat()
  +createScore()
}
interface Loan {
  +float active
  +Date description
  +float code
  +findEmail()
  +getAmount()
  +validateUpdatedat()
}
class Fine {
  +boolean status
  -long name
  +double total
  -float email
  +updateId()
}
Author --* Loan
Loan --|> Reservation
Author --> Shelf : "1"
@enduml