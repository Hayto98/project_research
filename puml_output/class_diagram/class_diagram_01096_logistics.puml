@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Route {
  +int code
  #int quantity
  +validateNote()
  +sendCode()
  +updateNote()
  +cancelActive()
}
interface Driver {
  #double price
  #long code
  -int active
  +findCode()
  +getUpdatedat()
  +createTotal()
}
class Warehouse {
  +int address
  #String amount
  -float email
  +findActive()
  +cancelType()
  +createName()
  +sendTotal()
}
abstract class Customer {
  #float amount
  -Date score
  #Date phone
  +getType()
}
class Inventory {
  -boolean description
  #int amount
  +float duration
  #boolean total
  +saveAddress()
  +validateActive()
}
interface DeliveryNote {
  #double total
  +String duration
  +int name
  #double level
  +saveDescription()
  +calculateId()
}
Inventory ..> Driver : "0..1"
Driver ..> DeliveryNote : "1..*"
Warehouse ..> Route : "1"
DeliveryNote --|> Customer
@enduml