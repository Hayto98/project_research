@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Grade {
  -boolean status
  #int level
  +Date createdAt
  #long code
  +setCode()
  +createTotal()
}
interface Course {
  #long status
  +double duration
  #float price
  +Date total
  +sendDescription()
  +updateLevel()
  +findLevel()
}
class Department {
  +long id
  -String level
  +boolean quantity
  +createLevel()
  +processCreatedat()
}
class Book {
  -int type
  +float note
  +processUpdatedat()
  +saveType()
}
Department --o Course
Course --> Grade : "1"
@enduml