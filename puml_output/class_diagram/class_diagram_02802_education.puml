@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Grade {
  -boolean status
  #int level
  +Date createdAt
  #long code
  +findDuration()
  +saveDuration()
}
interface Course {
  #long status
  +double duration
  #float price
  +Date total
  +createDescription()
  +cancelDescription()
  +getLevel()
}
interface Department {
  +boolean description
  +Date quantity
  -float type
  #String name
  +processPhone()
  +deleteStatus()
  +updateAmount()
  +getActive()
}
class Book {
  +int price
  +float description
  +Date amount
  -long status
  +sendPhone()
  +cancelAddress()
  +sendName()
  +getTotal()
}
Department ..|> Grade
Course --|> Book
Book --* Department
note right of Grade : Education domain
@enduml