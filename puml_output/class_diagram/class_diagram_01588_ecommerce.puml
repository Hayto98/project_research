@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Warehouse {
  +boolean name
  +String duration
  -double score
  -String createdAt
  +boolean status
  +validateQuantity()
  +getDescription()
  +processCode()
}
interface Review {
  -String id
  #boolean status
  +float score
  -float total
  +calculateNote()
}
interface Cart {
  -int id
  #Date updatedAt
  +saveAmount()
  +sendDuration()
}
class Coupon {
  -long level
  +boolean email
  +processActive()
  +setDescription()
  +validateAmount()
  +sendActive()
}
abstract class Shipment {
  #float level
  #String code
  +double price
  +long updatedAt
  #float quantity
  +processAddress()
  +processTotal()
  +createTotal()
  +getTotal()
}
class Return {
  -double createdAt
  +int id
  -boolean total
  +int level
  #float price
  +findAddress()
  +sendCreatedat()
  +calculateActive()
}
Cart --* Coupon
Review ..> Shipment : "1"
Cart --o Shipment
Return --* Review
@enduml