@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Warehouse {
  +boolean name
  +String duration
  -double score
  -String createdAt
  +boolean status
  +deleteId()
  +cancelPhone()
  +getStatus()
}
interface Review {
  #boolean note
  +int code
  #String active
  +int level
  -int duration
  +processEmail()
  +setLevel()
}
class Cart {
  +String phone
  -boolean status
  -double active
  #boolean price
  +calculateUpdatedat()
}
class Coupon {
  +long updatedAt
  #float note
  +processCreatedat()
  +findAddress()
  +processCreatedat()
  +saveId()
}
interface Shipment {
  +double id
  #int price
  +boolean type
  -int score
  -boolean name
  +createType()
  +createUpdatedat()
  +findLevel()
}
interface Return {
  #int phone
  -Date note
  +getName()
  +validateAddress()
}
Coupon --> Warehouse : "1"
Coupon --* Review
Warehouse --* Cart
note right of Warehouse : Ecommerce domain
@enduml