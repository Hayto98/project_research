@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Amenity {
  #boolean name
  -int duration
  #Date phone
  +String total
  #String address
  +calculatePhone()
  +sendEmail()
  +createAddress()
}
abstract class Staff {
  +float score
  #boolean address
  +sendPrice()
  +validateQuantity()
}
interface CheckIn {
  +Date type
  +Date phone
  -Date duration
  -String name
  -double note
  +setScore()
  +createDescription()
  +setEmail()
  +updateId()
}
abstract class Booking {
  +int active
  #String quantity
  #double name
  +getEmail()
}
class Payment {
  #long score
  -Date amount
  +calculateTotal()
  +deleteActive()
  +processActive()
  +validateUpdatedat()
}
class Service {
  +boolean price
  #Date duration
  -String id
  #double amount
  -double note
  +updateCreatedat()
  +deleteEmail()
}
class Restaurant {
  #long score
  #Date quantity
  #boolean createdAt
  +long total
  #boolean email
  +sendDescription()
  +getQuantity()
  +getEmail()
  +processName()
}
Amenity --> Restaurant : "1..*"
Amenity ..> Service : "1"
Booking --* Staff
note right of Amenity : Hotel domain
@enduml