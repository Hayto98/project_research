@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Amenity {
  #boolean name
  -int duration
  #Date phone
  +String total
  #String address
  +calculateQuantity()
  +saveScore()
  +getScore()
}
class Staff {
  +float address
  #boolean price
  +boolean id
  -long duration
  +processId()
  +saveName()
  +findActive()
}
class CheckIn {
  #long name
  +double note
  -boolean amount
  #Date duration
  #boolean price
  +cancelEmail()
  +sendAmount()
  +validateAmount()
  +validateCode()
}
class Booking {
  #long updatedAt
  +String id
  +boolean total
  +float duration
  +deleteEmail()
  +validateEmail()
  +saveLevel()
  +savePhone()
}
class Payment {
  -Date status
  #float score
  -float amount
  -double email
  +findDuration()
  +calculateAmount()
}
interface Service {
  #double updatedAt
  +float id
  +Date total
  #float price
  +getLevel()
  +findUpdatedat()
  +saveUpdatedat()
  +createTotal()
}
abstract class Restaurant {
  -double active
  +int type
  +validateCreatedat()
  +sendAddress()
}
Service --o Restaurant
@enduml