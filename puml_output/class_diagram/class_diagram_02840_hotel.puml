@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Amenity {
  -int duration
  +float amount
  #boolean updatedAt
  +createStatus()
}
abstract class Room {
  -double total
  #long updatedAt
  #boolean level
  -float createdAt
  +processPrice()
  +sendCreatedat()
  +getStatus()
}
interface Service {
  +int createdAt
  -Date price
  -float type
  +sendEmail()
}
abstract class Booking {
  #String quantity
  -int description
  +getQuantity()
  +saveTotal()
  +calculateDescription()
  +processUpdatedat()
}
Booking ..|> Service
Booking --* Room
@enduml