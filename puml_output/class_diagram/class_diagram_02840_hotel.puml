@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Amenity {
  -int duration
  +float amount
  #boolean updatedAt
  +sendPrice()
}
class Room {
  #long updatedAt
  #boolean duration
  -float createdAt
  -int note
  -boolean type
  +updatePrice()
  +saveType()
}
class Service {
  +double phone
  #float total
  +long name
  +sendStatus()
  +validateDescription()
}
abstract class Booking {
  -long type
  -boolean duration
  -double description
  +deleteEmail()
  +getPhone()
  +calculateAmount()
  +cancelPrice()
}
Room --* Service
Booking --* Amenity
note right of Amenity : Hotel domain
@enduml