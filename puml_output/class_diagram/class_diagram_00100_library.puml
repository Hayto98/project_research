@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
abstract class Member {
  +Date code
  +float phone
  +boolean email
  #int note
  +getDescription()
  +calculateActive()
}
abstract class Reservation {
  +boolean score
  -boolean active
  +Date type
  +setPhone()
  +deleteCreatedat()
  +getDuration()
  +saveStatus()
}
class Book {
  +int description
  +Date amount
  #Date total
  +cancelTotal()
  +calculateCode()
}
class Author {
  -float updatedAt
  +Date price
  +boolean amount
  +sendAmount()
  +setAmount()
  +sendAmount()
  +findCode()
}
class Renewal {
  #String active
  -double note
  #float type
  +long name
  #double duration
  +sendScore()
  +deleteAddress()
}
class Catalog {
  #String note
  +String id
  +boolean price
  +int level
  #int createdAt
  +cancelPrice()
  +getLevel()
  +validateAmount()
  +validateDescription()
}
Author --> Member : "*"
Reservation --* Renewal
Member --> Reservation : "1"
note right of Member : Library domain
@enduml