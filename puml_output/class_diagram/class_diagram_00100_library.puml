@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
abstract class Member {
  +Date code
  +float phone
  +boolean email
  #int note
  +saveId()
  +createCreatedat()
}
abstract class Reservation {
  #float createdAt
  -boolean score
  +Date active
  -float type
  +long status
  +deleteStatus()
  +saveNote()
}
class Book {
  #int phone
  #boolean updatedAt
  +deleteUpdatedat()
  +setNote()
}
class Author {
  #double createdAt
  -Date level
  +String duration
  +processPrice()
  +calculateCode()
}
class Renewal {
  +boolean id
  +Date code
  +int note
  -boolean amount
  -double level
  +findTotal()
}
class Catalog {
  #float email
  +long total
  +validateQuantity()
  +getScore()
  +cancelType()
  +createType()
}
Book --> Catalog : "*"
Catalog ..> Author : "1"
Author ..|> Member
@enduml