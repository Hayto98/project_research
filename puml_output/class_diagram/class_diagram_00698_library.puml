@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
abstract class Branch {
  #Date createdAt
  +String description
  +updateCreatedat()
}
class Book {
  +Date total
  #float note
  +int type
  +getEmail()
}
class Fine {
  #float quantity
  -boolean code
  -double updatedAt
  +calculateName()
  +createUpdatedat()
}
abstract class Author {
  +String description
  #int total
  +Date amount
  +sendType()
  +updatePhone()
  +saveEmail()
  +getLevel()
}
interface Catalog {
  +long phone
  #int quantity
  -int note
  +sendDuration()
  +cancelActive()
}
class Renewal {
  #double price
  #float total
  #String level
  #boolean quantity
  +String email
  +createEmail()
  +getActive()
  +sendScore()
}
class Loan {
  #String createdAt
  +String score
  +validateDescription()
}
Catalog --o Renewal
Fine --|> Catalog
@enduml