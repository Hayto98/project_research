@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
abstract class Branch {
  #Date createdAt
  +String description
  +createCreatedat()
}
abstract class Book {
  +long type
  +long createdAt
  +boolean updatedAt
  #int amount
  #float id
  +cancelAddress()
  +processDescription()
  +validateActive()
}
abstract class Fine {
  +String description
  #int total
  +Date amount
  +saveName()
  +saveCode()
  +cancelAmount()
  +savePhone()
}
class Author {
  +Date name
  +Date email
  #long active
  #double updatedAt
  #double quantity
  +calculateQuantity()
  +createTotal()
  +findCode()
  +saveDuration()
}
class Catalog {
  +Date email
  +float price
  +saveScore()
  +findCode()
}
class Renewal {
  #String duration
  #Date status
  +validateDuration()
  +getQuantity()
  +updateId()
  +validateAddress()
}
abstract class Loan {
  #float score
  +boolean type
  +deleteTotal()
  +setUpdatedat()
  +saveUpdatedat()
}
Book --o Author
Loan ..> Catalog : "1"
Book --* Loan
Branch ..> Author : "1"
note right of Branch : Library domain
@enduml