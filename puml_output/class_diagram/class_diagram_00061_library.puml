@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Publisher {
  #String active
  -boolean status
  +long createdAt
  -int score
  +sendActive()
}
class Loan {
  +double note
  -long amount
  +float email
  #boolean createdAt
  +findAddress()
  +cancelId()
  +saveDescription()
  +saveType()
}
abstract class Member {
  +long email
  +long createdAt
  #long name
  -double duration
  +validateActive()
  +calculateAmount()
}
class Reservation {
  #Date type
  -double createdAt
  -long active
  +createAddress()
  +createEmail()
  +saveId()
  +processAmount()
}
Publisher --o Loan
Member --> Reservation : "1"
Member --* Publisher
note right of Publisher : Library domain
@enduml