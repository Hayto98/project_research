@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Publisher {
  #String active
  -boolean status
  +long createdAt
  -int score
  +sendAmount()
}
interface Loan {
  #int phone
  +double note
  -long amount
  +float email
  +cancelUpdatedat()
  +validateScore()
  +savePrice()
  +updateActive()
}
class Member {
  -String total
  -String quantity
  -Date email
  -double createdAt
  -int name
  +cancelScore()
  +createDescription()
  +processType()
}
class Reservation {
  #Date updatedAt
  #long type
  -float createdAt
  +findQuantity()
  +deleteAmount()
  +sendAddress()
}
Member ..> Loan : "1"
Reservation --* Publisher
Publisher --o Loan
@enduml