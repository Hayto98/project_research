@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
abstract class Comment {
  #Date note
  #long type
  -String active
  +updateId()
}
interface Notification {
  -int code
  -boolean id
  +double description
  +String status
  +cancelCreatedat()
  +processName()
  +saveCreatedat()
  +processScore()
}
class Follower {
  #double description
  +boolean note
  +String address
  +findScore()
  +updateType()
}
class User {
  #long description
  #String email
  #float phone
  +float total
  +createAmount()
}
interface Report {
  +String description
  #double type
  +boolean price
  +double phone
  +getDescription()
  +calculatePhone()
}
class Hashtag {
  +float score
  +Date level
  +getType()
  +updateCreatedat()
}
Report --|> User
Comment --> Notification : "*"
Report --> Notification : "*"
Follower --> Notification : "1"
User --> Notification : "*"
note right of Comment : Social Media domain
@enduml