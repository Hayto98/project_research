@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Shipment {
  #double createdAt
  -float score
  +findScore()
  +getQuantity()
}
class Depot {
  #long total
  -double createdAt
  #float amount
  +validateCode()
  +saveNote()
}
interface DeliveryNote {
  -float duration
  #String description
  #String note
  -Date code
  +processTotal()
}
class Manifest {
  -Date price
  #float phone
  -float name
  +createQuantity()
}
class Warehouse {
  +double active
  #Date quantity
  +long note
  +setEmail()
  +createStatus()
  +updatePrice()
  +validateAmount()
}
class FuelLog {
  #double total
  #Date level
  +boolean description
  +setAddress()
  +saveLevel()
  +findQuantity()
}
class Inventory {
  #Date address
  #long email
  -int level
  +Date updatedAt
  +validateScore()
  +sendCode()
  +processDuration()
  +findPhone()
}
Warehouse ..|> Manifest
Manifest --* Inventory
Shipment --> Inventory : "1..*"
FuelLog --o Depot
Inventory --o Shipment
@enduml