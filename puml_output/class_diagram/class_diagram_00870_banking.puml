@startuml

class Account {
  #double active
  #Date name
  #float createdAt
  +double score
  +processDuration()
  +validateDuration()
}
class Teller {
  -Date createdAt
  -float active
  #double duration
  +cancelName()
  +findCreatedat()
  +sendAddress()
  +cancelCode()
}
class Transfer {
  -double duration
  #boolean price
  -String level
  +cancelEmail()
  +deletePhone()
}
interface Card {
  -double note
  -float email
  +Date active
  -String address
  #float duration
  +getLevel()
  +setStatus()
  +saveName()
}
interface Statement {
  +String code
  #boolean price
  +Date duration
  +calculateScore()
}
Account ..|> Teller
Transfer ..> Statement : "1"
note right of Account : Banking domain
@enduml