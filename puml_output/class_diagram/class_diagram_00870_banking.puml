@startuml

class Account {
  #double active
  #Date name
  #float createdAt
  +double score
  +sendName()
  +createNote()
}
interface Teller {
  #int duration
  -Date id
  -float createdAt
  #double score
  +setId()
  +setUpdatedat()
  +getPrice()
  +setCode()
}
class Transfer {
  #float duration
  -double code
  -double id
  #boolean updatedAt
  +updateActive()
  +sendId()
  +validateDescription()
  +deleteDescription()
}
class Card {
  -boolean phone
  #float type
  -double note
  +cancelCreatedat()
  +createName()
  +deleteTotal()
  +createCode()
}
class Statement {
  #String phone
  +Date name
  +processNote()
}
Teller --o Account
Account --|> Teller
Statement ..> Teller : "1"
Card --|> Account
@enduml