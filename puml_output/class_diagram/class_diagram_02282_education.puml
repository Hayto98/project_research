@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Assignment {
  #double status
  #double phone
  +long total
  +cancelCode()
  +findTotal()
}
class Book {
  +String code
  #String price
  -long total
  #float duration
  +setTotal()
}
interface Library {
  +String address
  -String duration
  +String price
  #int active
  #Date quantity
  +validateQuantity()
}
class Course {
  -Date phone
  +double email
  #long code
  -String type
  +saveUpdatedat()
  +validateCreatedat()
}
Library --|> Course
Course ..> Assignment : "1"
@enduml