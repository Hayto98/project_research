@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
abstract class Teller {
  +double level
  +long status
  +updateUpdatedat()
}
interface Withdrawal {
  #Date status
  +float amount
  +createName()
}
abstract class Branch {
  +double note
  #boolean active
  +updateCreatedat()
  +sendType()
  +calculateName()
  +getTotal()
}
abstract class Interest {
  #float id
  -Date code
  -String price
  +validateCreatedat()
  +updateType()
  +updateAmount()
}
Interest ..> Branch : "*"
Withdrawal --o Interest
note right of Teller : Banking domain
@enduml