@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
abstract class Teller {
  +double level
  +long status
  +saveNote()
}
class Withdrawal {
  #Date status
  +float amount
  +updateLevel()
}
class Branch {
  #boolean status
  -int note
  +boolean active
  -float name
  -String total
  +findAmount()
}
abstract class Interest {
  #float id
  -Date code
  -String price
  +validateScore()
  +updateDescription()
  +validateNote()
}
Withdrawal ..|> Teller
Interest ..> Branch : "*"
Withdrawal --o Interest
@enduml