@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Shelf {
  -String code
  #double duration
  +processStatus()
  +updateCreatedat()
}
class Reservation {
  #int active
  -float price
  -double code
  +long score
  +validateTotal()
  +createEmail()
  +setPhone()
  +findScore()
}
class Publisher {
  #int level
  #double code
  -float phone
  +saveId()
}
class Librarian {
  #float updatedAt
  #long note
  #double score
  #String level
  +long price
  +createUpdatedat()
}
class Renewal {
  #String updatedAt
  -Date createdAt
  -boolean email
  +Date total
  +setDuration()
  +calculateCreatedat()
  +calculateQuantity()
}
class Loan {
  +Date score
  -String quantity
  +float type
  +Date description
  -boolean status
  +processLevel()
}
abstract class Branch {
  -int duration
  -boolean name
  +deleteName()
  +updateCode()
}
Renewal ..|> Shelf
Librarian --|> Reservation
@enduml