@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Restaurant {
  +int active
  +int price
  +double updatedAt
  +boolean duration
  +int description
  +deleteCode()
  +sendTotal()
  +cancelScore()
  +setAddress()
}
class Guest {
  +Date email
  #int address
  -boolean duration
  +long description
  +createType()
  +processQuantity()
}
abstract class Booking {
  +double updatedAt
  #String note
  +Date level
  +deleteDescription()
  +processName()
}
class Housekeeping {
  +boolean duration
  #String price
  #boolean total
  -int email
  -long name
  +updateNote()
}
class Invoice {
  -double email
  #float description
  #String updatedAt
  +validateCode()
  +cancelUpdatedat()
  +sendQuantity()
}
interface CheckOut {
  +int price
  #Date total
  +int updatedAt
  +String duration
  +double id
  +deleteName()
}
class Amenity {
  -long score
  #String amount
  +float price
  +boolean description
  #boolean duration
  +setName()
  +updateTotal()
  +validatePhone()
  +processDuration()
}
Restaurant --o Amenity
Amenity --o Booking
Amenity --> Guest : "*"
Restaurant --o Invoice
Invoice ..> Housekeeping : "1..*"
@enduml