@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Shipment {
  #int type
  -Date note
  -String duration
  +calculateDescription()
  +sendCreatedat()
  +updateActive()
  +processCreatedat()
}
class Product {
  -boolean level
  +float duration
  +calculateCreatedat()
  +deletePhone()
  +validatePhone()
  +cancelNote()
}
abstract class Invoice {
  #boolean status
  #boolean phone
  +double total
  +deleteEmail()
}
interface Cart {
  #Date quantity
  #double note
  +processActive()
  +findCreatedat()
  +createStatus()
}
abstract class Wishlist {
  -Date name
  #float createdAt
  #double email
  #float status
  #double duration
  +calculateQuantity()
  +setEmail()
}
interface Category {
  +long level
  +String email
  +boolean amount
  -int note
  +processQuantity()
}
Product --o Cart
Shipment --o Invoice
Category --> Product : "1"
Product ..> Shipment : "0..1"
@enduml