@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
interface Insurance {
  +double total
  #double updatedAt
  #double code
  +long name
  +cancelAmount()
  +validateQuantity()
  +findAddress()
}
class Doctor {
  #float name
  #float price
  +findQuantity()
  +cancelDuration()
  +sendDuration()
  +setStatus()
}
abstract class Treatment {
  -Date code
  -String duration
  #long active
  -int quantity
  +updateCode()
  +findNote()
}
class MedicalRecord {
  #float address
  #boolean total
  #float name
  +deleteType()
  +processDescription()
}
class Prescription {
  #float id
  #String type
  +int phone
  +createPhone()
}
abstract class Patient {
  -int price
  -String duration
  +calculateLevel()
  +validateAddress()
  +validatePrice()
}
class Nurse {
  +double email
  +double status
  -Date duration
  -Date level
  -boolean quantity
  +cancelCode()
  +deleteName()
}
Doctor --* Treatment
Patient ..> Prescription : "1"
Nurse ..|> Treatment
Patient ..|> Nurse
Patient --|> Treatment
Treatment ..> MedicalRecord : "*"
@enduml