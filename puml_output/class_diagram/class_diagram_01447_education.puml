@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Department {
  -Date id
  -float createdAt
  #double quantity
  -long email
  +validateCreatedat()
  +updateUpdatedat()
}
interface Teacher {
  #String code
  #long score
  +cancelCreatedat()
  +calculateCreatedat()
  +deleteId()
  +updateStatus()
}
abstract class Book {
  #Date amount
  #int id
  #String type
  -long note
  +setStatus()
  +setEmail()
  +setLevel()
  +getTotal()
}
abstract class Enrollment {
  -long quantity
  -float price
  -String email
  +boolean total
  -String score
  +deleteCode()
  +updateLevel()
  +updateUpdatedat()
}
class Student {
  +float description
  #boolean duration
  +float note
  -Date createdAt
  +processQuantity()
  +validatePrice()
}
Book --> Enrollment : "1..*"
Enrollment --o Teacher
note right of Department : Education domain
@enduml