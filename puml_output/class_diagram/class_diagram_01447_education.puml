@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Department {
  -Date id
  -float createdAt
  #double quantity
  -long email
  +cancelType()
  +getDuration()
}
class Teacher {
  +String createdAt
  #boolean updatedAt
  #String score
  +sendType()
  +sendQuantity()
  +calculateDuration()
}
abstract class Book {
  +int total
  +Date createdAt
  -long amount
  +cancelTotal()
  +validateName()
}
interface Enrollment {
  -String score
  +String updatedAt
  -String name
  #String total
  -double address
  +createNote()
  +findScore()
  +saveCode()
  +sendAddress()
}
abstract class Student {
  +String total
  #long address
  +long quantity
  +String note
  +getName()
  +findType()
}
Teacher --|> Student
Book ..|> Teacher
Student ..|> Enrollment
Department --o Student
@enduml