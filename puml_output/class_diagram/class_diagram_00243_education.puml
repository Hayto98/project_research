@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Course {
  -int type
  +boolean active
  -Date duration
  +validateTotal()
  +processQuantity()
}
class Classroom {
  -boolean score
  -long quantity
  #int note
  +int amount
  +Date code
  +calculateQuantity()
  +cancelDuration()
  +updateType()
}
class Exam {
  -int updatedAt
  +boolean active
  #double code
  +findLevel()
}
interface Book {
  #String type
  #float duration
  +updateTotal()
  +deleteName()
  +validateCode()
  +createStatus()
}
class Enrollment {
  #Date quantity
  +Date level
  +String type
  #boolean amount
  +sendStatus()
}
Exam ..> Book : "1..*"
Enrollment ..|> Book
note right of Course : Education domain
@enduml