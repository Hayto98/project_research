@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Course {
  -int type
  +boolean active
  -Date duration
  +validateType()
  +validateDuration()
}
abstract class Classroom {
  +float quantity
  +double name
  #long type
  -boolean duration
  +String note
  +findId()
  +createType()
}
class Exam {
  #boolean quantity
  +float level
  +boolean updatedAt
  #String type
  -int amount
  +getCreatedat()
  +findStatus()
}
abstract class Book {
  +double level
  -Date score
  +calculateDuration()
}
abstract class Enrollment {
  -String total
  -String amount
  +boolean name
  +updateLevel()
  +findName()
  +sendName()
}
Classroom --|> Enrollment
Enrollment --> Course : "1"
@enduml