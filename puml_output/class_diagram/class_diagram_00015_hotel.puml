@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Room {
  +long updatedAt
  #int amount
  +int email
  -long score
  +sendEmail()
  +setCreatedat()
}
class Invoice {
  -long updatedAt
  -long price
  #float level
  #long description
  +calculateEmail()
  +calculateTotal()
  +findAddress()
  +validateEmail()
}
class Guest {
  +double type
  +double id
  +createPrice()
  +saveDescription()
}
class Staff {
  #double address
  +double active
  +Date phone
  +setLevel()
  +findUpdatedat()
  +calculateNote()
}
Staff --|> Guest
Guest ..> Staff : "0..1"
@enduml