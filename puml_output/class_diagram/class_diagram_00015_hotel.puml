@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Room {
  +long updatedAt
  #int amount
  +int email
  -long score
  +updateId()
  +findPhone()
}
class Invoice {
  -Date price
  #long description
  #double duration
  +int phone
  +String note
  +processId()
}
class Guest {
  #float status
  +long total
  #long description
  #double price
  +double name
  +saveQuantity()
  +deleteDuration()
}
class Staff {
  #Date price
  -boolean code
  +setScore()
  +findUpdatedat()
}
Room ..> Staff : "*"
Invoice --> Room : "0..1"
note right of Room : Hotel domain
@enduml