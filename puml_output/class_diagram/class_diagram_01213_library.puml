@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Shelf {
  #String type
  -float duration
  -long phone
  #boolean status
  #long price
  +getActive()
}
class Loan {
  #long status
  #String updatedAt
  -boolean id
  -float quantity
  -boolean active
  +validateType()
}
abstract class Publisher {
  #double duration
  #Date name
  +calculateCreatedat()
  +sendName()
  +saveActive()
  +setLevel()
}
class Reservation {
  -boolean code
  #int description
  +float name
  #double level
  -boolean note
  +getDuration()
  +findAmount()
  +sendNote()
}
interface Book {
  -Date quantity
  -String note
  #boolean amount
  #double score
  +calculateCreatedat()
  +validateDescription()
  +getStatus()
  +createTotal()
}
interface Renewal {
  #Date description
  #boolean price
  +float duration
  -float code
  +getDescription()
}
class Member {
  +boolean duration
  -int phone
  -long description
  +float amount
  +cancelTotal()
  +getCreatedat()
}
Publisher ..|> Book
Renewal --o Loan
Book --|> Renewal
Book --|> Shelf
Publisher ..> Shelf : "0..1"
Publisher ..|> Reservation
@enduml