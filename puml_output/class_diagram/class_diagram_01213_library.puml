@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Shelf {
  #String type
  -float duration
  -long phone
  #boolean status
  #long price
  +findAmount()
}
abstract class Loan {
  #float updatedAt
  -long id
  +sendCode()
  +createDuration()
  +calculatePrice()
}
interface Publisher {
  #String note
  #double status
  +validateType()
  +sendDescription()
  +savePhone()
  +calculateCode()
}
class Reservation {
  #double description
  -boolean active
  +updateLevel()
  +calculateEmail()
}
interface Book {
  -int total
  +long updatedAt
  #long address
  +boolean quantity
  +calculateAddress()
  +findDuration()
  +validateDescription()
  +calculateDescription()
}
interface Renewal {
  -float score
  #boolean description
  +setAddress()
}
interface Member {
  +float description
  -long amount
  +float duration
  +String price
  +cancelUpdatedat()
  +saveUpdatedat()
  +processActive()
}
Book --|> Shelf
Publisher ..> Shelf : "0..1"
note right of Shelf : Library domain
@enduml