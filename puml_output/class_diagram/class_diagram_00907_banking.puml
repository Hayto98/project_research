@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Card {
  #int name
  +int active
  +boolean level
  -int note
  +float phone
  +validateDuration()
}
class Deposit {
  +long phone
  -int code
  +getActive()
  +createStatus()
  +findName()
}
class Branch {
  #boolean score
  #Date amount
  +saveStatus()
  +sendDuration()
  +calculatePrice()
  +updateAmount()
}
interface Transfer {
  #boolean quantity
  -int total
  #long id
  #int active
  +calculateCode()
  +deletePhone()
  +findScore()
}
Branch ..|> Card
Card ..> Transfer : "1..*"
@enduml