@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Card {
  #int name
  +int active
  +boolean level
  -int note
  +float phone
  +validateName()
}
class Deposit {
  +boolean code
  #boolean createdAt
  -Date address
  #boolean quantity
  +getScore()
  +saveAmount()
  +sendScore()
}
interface Branch {
  +boolean score
  #float level
  #boolean quantity
  -int duration
  #long total
  +validatePrice()
  +createScore()
}
class Transfer {
  #boolean createdAt
  #float description
  -int status
  #boolean amount
  +updatePrice()
  +saveDescription()
  +getPhone()
  +findCreatedat()
}
Card --* Deposit
Deposit ..> Transfer : "*"
note right of Card : Banking domain
@enduml