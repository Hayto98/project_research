@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
abstract class DeliveryNote {
  -float level
  +long updatedAt
  #float code
  -double quantity
  +processAddress()
  +cancelName()
  +updateTotal()
}
interface Manifest {
  #String amount
  +long active
  +processName()
  +sendCreatedat()
  +calculateUpdatedat()
  +validateDuration()
}
class Warehouse {
  +Date level
  -String updatedAt
  +Date name
  -long total
  +processActive()
  +sendQuantity()
}
class Package {
  -boolean note
  #double level
  +Date email
  +saveEmail()
  +processStatus()
}
class FuelLog {
  +String code
  +long quantity
  -double note
  +findPhone()
  +findScore()
  +saveName()
  +updateCreatedat()
}
class Customer {
  +long description
  #Date code
  #long name
  +getStatus()
  +findTotal()
  +calculateScore()
  +cancelAmount()
}
FuelLog --* Manifest
Manifest --o Customer
Warehouse --o Customer
FuelLog ..|> Package
Warehouse ..|> FuelLog
@enduml