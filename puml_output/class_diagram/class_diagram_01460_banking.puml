@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Card {
  #boolean type
  -Date description
  -Date address
  +boolean total
  -int level
  +setDuration()
  +processStatus()
  +createScore()
}
abstract class Interest {
  #int name
  #double email
  #long total
  +validateEmail()
  +setNote()
  +createStatus()
  +cancelTotal()
}
interface Customer {
  +double phone
  #boolean address
  +String total
  +float note
  #boolean code
  +calculateQuantity()
  +findQuantity()
  +cancelAmount()
}
class Teller {
  -double phone
  +String updatedAt
  +long amount
  +deleteName()
  +setPrice()
  +createCode()
  +createUpdatedat()
}
class Withdrawal {
  +double status
  +long createdAt
  +long id
  +deleteDuration()
}
Withdrawal --|> Interest
Withdrawal ..> Card : "1"
note right of Card : Banking domain
@enduml