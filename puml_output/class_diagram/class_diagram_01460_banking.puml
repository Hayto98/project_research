@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Card {
  #boolean type
  -Date description
  -Date address
  +boolean total
  -int level
  +processAmount()
  +createType()
  +saveStatus()
}
interface Interest {
  +long status
  #boolean email
  -Date score
  +Date note
  -boolean description
  +processTotal()
  +deleteCode()
  +validateAmount()
}
class Customer {
  -long email
  #double status
  -String total
  +double active
  #boolean note
  +processName()
  +saveId()
}
interface Teller {
  #int price
  +float quantity
  -int level
  #boolean amount
  +getId()
  +cancelLevel()
}
abstract class Withdrawal {
  -double code
  +String status
  +processCreatedat()
}
Teller --|> Customer
Customer --|> Interest
Interest ..|> Card
Card --o Interest
@enduml