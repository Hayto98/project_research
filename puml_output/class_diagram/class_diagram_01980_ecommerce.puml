@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
abstract class Cart {
  #boolean id
  -double score
  +processAmount()
  +createEmail()
  +getPhone()
}
class Supplier {
  #boolean code
  #boolean status
  -boolean price
  -long phone
  +saveNote()
  +setPhone()
  +saveAmount()
}
class Order {
  -boolean status
  +String type
  #float description
  -long duration
  +saveDescription()
  +sendId()
  +deleteAddress()
}
abstract class Category {
  #Date active
  -double status
  +float amount
  +deleteCreatedat()
}
class Payment {
  #Date id
  #int quantity
  #double status
  -double type
  -long note
  +setPhone()
  +setDescription()
  +saveDuration()
}
Supplier --o Category
Category --> Supplier : "1..*"
note right of Cart : Ecommerce domain
@enduml