@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
abstract class Cart {
  #boolean id
  -double score
  +cancelQuantity()
  +calculateDescription()
  +saveStatus()
}
class Supplier {
  -String email
  +double id
  -boolean phone
  #float name
  +findDescription()
  +saveAmount()
  +cancelPhone()
  +updateLevel()
}
abstract class Order {
  +float phone
  #long amount
  +deleteActive()
}
class Category {
  +String total
  #float level
  +cancelId()
  +calculatePhone()
  +cancelDuration()
}
class Payment {
  -int description
  #String address
  +processId()
  +processNote()
}
Category --|> Cart
Supplier ..|> Payment
Payment --|> Category
@enduml