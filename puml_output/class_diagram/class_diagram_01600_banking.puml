@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Transaction {
  #boolean score
  +float updatedAt
  +float code
  +setNote()
  +calculateQuantity()
  +createUpdatedat()
}
interface Transfer {
  -String phone
  #String total
  +long price
  -double id
  +processQuantity()
  +processCreatedat()
}
class Branch {
  #int name
  #String amount
  +deleteLevel()
}
class Teller {
  #String duration
  -Date note
  +updateType()
  +setCreatedat()
  +deleteTotal()
}
interface Interest {
  +long total
  -String code
  #double updatedAt
  +saveType()
  +setTotal()
  +updateCode()
  +updateTotal()
}
class Loan {
  +double note
  -int level
  +saveEmail()
  +validateStatus()
  +sendUpdatedat()
  +validateName()
}
Transfer --> Teller : "*"
Interest --|> Teller
Branch ..> Loan : "*"
note right of Transaction : Banking domain
@enduml