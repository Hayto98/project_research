@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Transaction {
  #boolean score
  +float updatedAt
  +float code
  +cancelEmail()
  +sendCode()
  +processType()
}
class Transfer {
  #double updatedAt
  #double score
  +long address
  +Date phone
  +setUpdatedat()
}
class Branch {
  -int price
  -String active
  +int description
  #int note
  #String quantity
  +calculateLevel()
}
class Teller {
  -Date name
  #boolean note
  #Date active
  #Date code
  +calculateNote()
  +sendCreatedat()
  +createAddress()
}
class Interest {
  +float total
  -String level
  +String score
  +setAmount()
  +createPrice()
  +setStatus()
}
interface Loan {
  +int note
  -int type
  +double status
  #int total
  -long createdAt
  +createEmail()
  +saveType()
}
Loan --* Branch
Transaction ..|> Interest
Branch --* Transaction
Transfer --> Teller : "*"
Interest --|> Teller
@enduml