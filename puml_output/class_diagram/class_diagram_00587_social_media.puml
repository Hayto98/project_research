@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Album {
  -String address
  +String updatedAt
  +long quantity
  -String description
  +Date status
  +saveName()
  +savePrice()
  +calculateActive()
}
abstract class Follower {
  -long status
  -double score
  +cancelCode()
  +processName()
  +processType()
  +updateCreatedat()
}
class Comment {
  -String updatedAt
  +Date name
  +validateEmail()
  +createPrice()
  +getTotal()
}
class Hashtag {
  #double email
  +float score
  +boolean name
  +processScore()
  +getUpdatedat()
  +processTotal()
}
class Profile {
  -float code
  -long amount
  +cancelNote()
  +saveDescription()
}
class Group {
  -int score
  #int price
  -boolean note
  #boolean duration
  #boolean code
  +deletePhone()
  +findId()
  +saveEmail()
}
Album --|> Hashtag
Profile ..> Group : "*"
Profile --o Album
@enduml