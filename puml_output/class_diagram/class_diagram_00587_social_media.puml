@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Album {
  -String address
  +String updatedAt
  +long quantity
  -String description
  +Date status
  +calculateLevel()
  +sendPrice()
  +findActive()
}
class Follower {
  -long score
  -double type
  +getPrice()
  +deleteLevel()
  +setUpdatedat()
  +getTotal()
}
class Comment {
  +long email
  +float status
  #long price
  +saveType()
}
class Hashtag {
  -long level
  #String address
  +deleteAddress()
}
abstract class Profile {
  #double createdAt
  -Date duration
  #Date id
  #Date note
  +setEmail()
  +deleteDuration()
  +updateQuantity()
  +cancelLevel()
}
interface Group {
  -String amount
  #boolean name
  #double duration
  #String code
  +processDuration()
  +createNote()
  +getLevel()
  +updateLevel()
}
Follower --o Group
Group ..|> Hashtag
Comment --* Follower
Comment --|> Album
note right of Album : Social Media domain
@enduml