@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Shelf {
  #double phone
  -float address
  +deleteScore()
  +findType()
}
abstract class Publisher {
  -int type
  +boolean updatedAt
  -long email
  +calculateScore()
}
class Fine {
  #int name
  +boolean amount
  -boolean createdAt
  +saveType()
  +processScore()
  +validatePrice()
}
abstract class Librarian {
  #int active
  +String total
  -boolean description
  +sendUpdatedat()
  +calculateScore()
  +deleteDuration()
  +validateCreatedat()
}
class Loan {
  -int createdAt
  -Date status
  +double phone
  #boolean duration
  +deleteTotal()
  +setStatus()
  +sendName()
}
Librarian --|> Shelf
Librarian --o Loan
Shelf --* Fine
Publisher --|> Shelf
@enduml