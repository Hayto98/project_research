@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Guest {
  -double updatedAt
  +Date code
  #int score
  +sendScore()
}
abstract class Amenity {
  -Date duration
  +double email
  +deleteDescription()
}
abstract class Invoice {
  #boolean amount
  +int active
  #long note
  +Date level
  +calculateDescription()
  +validateAmount()
  +setNote()
  +calculateCreatedat()
}
class Reservation {
  +int code
  #float type
  #String status
  +String address
  +saveEmail()
  +saveLevel()
  +getPhone()
}
Guest --* Invoice
Guest --> Amenity : "1"
Invoice ..|> Guest
@enduml