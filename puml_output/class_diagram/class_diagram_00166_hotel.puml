@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Guest {
  -double updatedAt
  +Date code
  #int score
  +calculateNote()
}
class Amenity {
  #float type
  -long createdAt
  +boolean note
  #double status
  +updateQuantity()
  +deleteNote()
}
class Invoice {
  +long address
  +int status
  #float email
  #String code
  +String type
  +getTotal()
  +processId()
  +sendQuantity()
}
class Reservation {
  +long duration
  #boolean id
  #double email
  #long description
  +updateName()
  +findUpdatedat()
}
Guest --o Invoice
Reservation --> Guest : "0..1"
Guest --* Amenity
note right of Guest : Hotel domain
@enduml