@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
abstract class Customer {
  -long quantity
  -int createdAt
  -String email
  #long status
  -float total
  +findStatus()
}
class Statement {
  +Date active
  #boolean total
  +Date price
  +cancelDuration()
}
class Transfer {
  +float total
  -int status
  +String type
  +deleteDescription()
}
class Account {
  +String phone
  -int address
  #int quantity
  #boolean duration
  +setAmount()
}
class Withdrawal {
  #double id
  +long type
  +Date name
  +boolean amount
  +calculateEmail()
  +deleteUpdatedat()
  +createType()
}
interface Card {
  #long name
  #int type
  +String updatedAt
  +long level
  +String email
  +sendDescription()
  +sendAmount()
}
Statement --o Withdrawal
Account --> Transfer : "1"
@enduml