@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Grade {
  #int total
  #int quantity
  +float status
  +Date code
  +createId()
  +validateName()
}
class Attendance {
  #boolean updatedAt
  +float createdAt
  +long note
  #boolean id
  +findPrice()
  +updateAddress()
  +updateAmount()
}
interface Schedule {
  +long score
  +int amount
  #double phone
  +double duration
  -String total
  +sendTotal()
  +setDuration()
  +getCreatedat()
  +updateStatus()
}
class Classroom {
  +int updatedAt
  +long name
  #int amount
  +createQuantity()
}
Attendance ..|> Classroom
Grade --> Attendance : "1"
Schedule --* Attendance
@enduml