@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Billing {
  #float id
  #String email
  #float address
  -boolean total
  #long type
  +createScore()
  +calculateTotal()
  +processEmail()
  +processLevel()
}
interface Ward {
  -boolean quantity
  #int name
  +saveDescription()
  +calculateAddress()
  +updateDuration()
}
class Treatment {
  -int active
  #Date total
  +long code
  -String updatedAt
  -boolean score
  +saveUpdatedat()
  +sendAddress()
  +setAmount()
}
interface Diagnosis {
  #String price
  -long score
  +findCode()
}
class Doctor {
  -float quantity
  -int active
  +validateId()
  +deletePhone()
  +validateEmail()
  +findCode()
}
class Patient {
  #int type
  #long updatedAt
  -float createdAt
  +setDuration()
  +processPhone()
  +processNote()
  +updateCreatedat()
}
abstract class MedicalRecord {
  +long price
  +float level
  -double amount
  +sendAmount()
}
Doctor --o Billing
Doctor --o Ward
@enduml