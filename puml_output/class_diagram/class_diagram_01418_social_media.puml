@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Report {
  -int name
  #long code
  -float quantity
  -long price
  +deleteAmount()
}
class Notification {
  -Date duration
  +boolean price
  -int active
  +calculateName()
  +createLevel()
}
class Hashtag {
  +int description
  -Date email
  #Date level
  +boolean phone
  +float id
  +getLevel()
  +calculateCreatedat()
  +saveAmount()
}
class Post {
  -String id
  #float type
  +long level
  +sendLevel()
  +getPhone()
  +processId()
  +setActive()
}
class Album {
  #double code
  #double type
  #long phone
  #String total
  +updateEmail()
  +cancelEmail()
  +validateTotal()
}
class Message {
  +double quantity
  +float type
  +processAddress()
}
Message --* Album
Notification --> Post : "0..1"
note right of Report : Social Media domain
@enduml