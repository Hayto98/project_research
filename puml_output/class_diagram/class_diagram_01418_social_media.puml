@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Report {
  -int name
  #long code
  -float quantity
  -long price
  +getEmail()
}
class Notification {
  #int updatedAt
  #long price
  +int active
  -String email
  +calculateUpdatedat()
  +findName()
  +cancelAddress()
}
interface Hashtag {
  +int description
  -Date email
  #Date level
  +boolean phone
  +float id
  +sendTotal()
  +deleteUpdatedat()
  +sendScore()
}
class Post {
  -double createdAt
  -String description
  #float id
  +updateLevel()
}
abstract class Album {
  +String phone
  #int note
  +processAmount()
  +findActive()
  +sendPhone()
}
abstract class Message {
  +Date note
  #long email
  #Date active
  -long status
  #double level
  +processQuantity()
  +updateLevel()
}
Notification --|> Post
Report --* Post
Message ..> Report : "1..*"
Album ..|> Message
@enduml