@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
interface Treatment {
  #Date total
  -long note
  -int status
  #Date id
  -int address
  +findCreatedat()
  +updateTotal()
  +processDuration()
  +validateAddress()
}
class Prescription {
  #float level
  #int email
  -String score
  -boolean id
  +saveQuantity()
  +getActive()
}
class Patient {
  -boolean quantity
  -String level
  +processPhone()
  +sendNote()
  +saveStatus()
}
class Billing {
  -long duration
  #int createdAt
  -Date status
  #long updatedAt
  +updatePhone()
  +deleteTotal()
}
class Hospital {
  -String price
  #float level
  +createUpdatedat()
  +cancelId()
  +deleteTotal()
}
Hospital --o Treatment
Prescription ..> Billing : "0..1"
@enduml