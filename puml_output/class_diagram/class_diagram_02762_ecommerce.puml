@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Supplier {
  -long type
  +String createdAt
  +boolean active
  -boolean description
  +boolean quantity
  +getActive()
  +cancelId()
  +sendAmount()
  +setUpdatedat()
}
class Review {
  -boolean status
  +String quantity
  #float id
  +String note
  +long level
  +cancelCreatedat()
  +findScore()
}
interface Cart {
  #long price
  #long score
  +Date id
  -int level
  +long createdAt
  +processUpdatedat()
  +findDescription()
}
abstract class Return {
  -long name
  #String id
  #float active
  +long score
  +cancelId()
}
interface Shipment {
  -long level
  -int type
  -float phone
  +float total
  +deleteType()
  +validateNote()
  +findEmail()
}
interface Payment {
  +int amount
  -Date updatedAt
  +long score
  #double duration
  #float level
  +deleteNote()
}
Cart ..|> Payment
Cart --|> Return
Payment --> Return : "1..*"
Return --o Supplier
Supplier --> Return : "1..*"
@enduml