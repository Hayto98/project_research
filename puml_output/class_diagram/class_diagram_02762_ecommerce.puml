@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Supplier {
  -long type
  +String createdAt
  +boolean active
  -boolean description
  +boolean quantity
  +findPhone()
  +sendName()
  +createNote()
  +setQuantity()
}
interface Review {
  -boolean note
  +String quantity
  +getCode()
}
class Cart {
  -double total
  #boolean quantity
  +String active
  +findAddress()
  +sendQuantity()
}
class Return {
  #double createdAt
  #float updatedAt
  -String email
  +boolean amount
  #float active
  +validateActive()
  +setDuration()
  +setAddress()
  +setPhone()
}
interface Shipment {
  -long level
  -int type
  -float phone
  +float total
  +findUpdatedat()
  +sendActive()
  +calculateAmount()
}
class Payment {
  +double score
  #int updatedAt
  -float createdAt
  +findName()
  +getType()
  +createQuantity()
  +updateEmail()
}
Supplier --> Return : "1..*"
Return --o Supplier
Shipment --* Cart
Supplier --> Payment : "*"
note right of Supplier : Ecommerce domain
@enduml