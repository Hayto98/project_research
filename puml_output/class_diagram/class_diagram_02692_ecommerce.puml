@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Payment {
  +int amount
  +long phone
  +int total
  +double updatedAt
  #String description
  +calculatePrice()
}
interface Return {
  #double type
  -float status
  +int createdAt
  -float name
  #float code
  +deleteDuration()
  +createName()
}
interface Product {
  #int score
  +String quantity
  +calculateDuration()
  +getPrice()
  +updateLevel()
  +sendTotal()
}
class Order {
  -float type
  +float total
  #long amount
  -long duration
  +calculateScore()
  +updatePrice()
}
Return ..|> Order
Order --o Return
@enduml