@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
interface Booking {
  -Date duration
  #int score
  #double phone
  #int active
  #String createdAt
  +setType()
  +deleteDescription()
}
abstract class Restaurant {
  -long price
  #int email
  +updatePhone()
  +getPhone()
}
abstract class Invoice {
  #long duration
  #boolean level
  #Date active
  +validateType()
}
class Service {
  +Date note
  -float duration
  +int createdAt
  +String updatedAt
  +long email
  +findCreatedat()
  +saveEmail()
  +createUpdatedat()
  +updateAmount()
}
class Reservation {
  -long id
  #float level
  -String active
  +cancelActive()
}
abstract class Room {
  #boolean level
  -boolean name
  -Date code
  +float duration
  +calculateName()
  +updateCreatedat()
  +createPhone()
  +deletePrice()
}
class CheckOut {
  +String code
  -boolean description
  +createCreatedat()
  +validateActive()
  +cancelEmail()
}
Room --* Reservation
Reservation ..|> Invoice
Service --* Invoice
CheckOut ..|> Room
Invoice --o Room
note right of Booking : Hotel domain
@enduml