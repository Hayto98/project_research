@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
interface Shelf {
  +boolean status
  +String createdAt
  +getLevel()
  +findEmail()
}
class Catalog {
  +double status
  #Date active
  -boolean email
  +float name
  +calculateName()
  +updateLevel()
  +calculateStatus()
}
class Member {
  -long updatedAt
  -double id
  +updateDescription()
  +sendPhone()
  +getPhone()
  +setPhone()
}
abstract class Fine {
  #float score
  #double phone
  #Date updatedAt
  #long total
  +deleteStatus()
}
Member --> Catalog : "1"
Catalog --|> Fine
Shelf ..> Fine : "1..*"
note right of Shelf : Library domain
@enduml