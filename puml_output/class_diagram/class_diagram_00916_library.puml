@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
interface Shelf {
  +boolean status
  +String createdAt
  +savePhone()
  +processEmail()
}
class Catalog {
  #long quantity
  +String status
  +deleteUpdatedat()
  +saveDescription()
  +calculateLevel()
  +createAmount()
}
interface Member {
  +int phone
  #boolean price
  +validateEmail()
  +cancelPhone()
  +sendAmount()
  +saveEmail()
}
class Fine {
  -double type
  -float address
  +getEmail()
  +calculatePrice()
}
Shelf --|> Catalog
Member --* Catalog
Member ..|> Fine
@enduml