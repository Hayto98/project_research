@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
abstract class Reservation {
  #boolean address
  #float score
  -float total
  +processScore()
  +updateActive()
  +saveNote()
}
class Book {
  +boolean name
  +double price
  -double quantity
  +double duration
  -boolean type
  +deleteAmount()
  +getAmount()
  +cancelAddress()
}
interface Branch {
  +boolean id
  +int duration
  +deleteAddress()
  +processAmount()
}
interface Publisher {
  -int total
  -long amount
  -float price
  +Date code
  +findStatus()
  +updateCreatedat()
  +getActive()
  +deleteNote()
}
class Loan {
  +float active
  -long createdAt
  #double description
  +int quantity
  -int name
  +validateUpdatedat()
  +sendScore()
}
class Librarian {
  #Date amount
  -boolean updatedAt
  -long type
  +String price
  -float score
  +setEmail()
  +getCreatedat()
}
Loan --o Publisher
Publisher ..|> Loan
Librarian --o Loan
@enduml