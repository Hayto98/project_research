@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
interface Account {
  #String name
  #float amount
  -Date quantity
  +cancelQuantity()
  +saveQuantity()
}
class Beneficiary {
  -Date createdAt
  +long email
  +setCode()
  +findTotal()
  +processTotal()
  +cancelDuration()
}
abstract class Transfer {
  +double active
  +int description
  #String phone
  +float address
  +processPrice()
  +processAddress()
  +setPrice()
}
class Deposit {
  #String note
  +String id
  #int createdAt
  -float level
  #String score
  +deleteScore()
  +calculateCode()
  +processDuration()
}
abstract class Customer {
  +boolean type
  +double quantity
  +updatePhone()
}
Customer --o Transfer
Account --* Deposit
Transfer ..> Account : "0..1"
Deposit ..> Beneficiary : "1..*"
@enduml