@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
interface Order {
  #boolean address
  +Date createdAt
  +long description
  #Date name
  +deleteName()
  +processNote()
  +cancelActive()
  +deleteDescription()
}
class Category {
  -boolean description
  #long score
  +setStatus()
  +calculateTotal()
  +processAddress()
  +saveScore()
}
abstract class Payment {
  #int total
  -int id
  +Date name
  -String duration
  +sendCreatedat()
  +findTotal()
  +findDescription()
}
abstract class Warehouse {
  +float price
  -boolean phone
  +Date quantity
  +createUpdatedat()
  +updateStatus()
}
class Product {
  #long type
  +boolean id
  -Date createdAt
  -float amount
  +processAmount()
}
Category --o Payment
Product ..|> Warehouse
@enduml