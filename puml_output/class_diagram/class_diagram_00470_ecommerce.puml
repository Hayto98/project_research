@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
interface Order {
  #boolean address
  +Date createdAt
  +long description
  #Date name
  +createLevel()
  +cancelDescription()
  +getDescription()
  +sendNote()
}
interface Category {
  -float price
  -String status
  +double phone
  #int total
  +updateUpdatedat()
  +findPrice()
  +setActive()
}
interface Payment {
  -long type
  +float total
  -boolean updatedAt
  +Date price
  +sendUpdatedat()
  +getDuration()
}
class Warehouse {
  #long id
  #long createdAt
  #String amount
  +int quantity
  +long description
  +sendPrice()
  +deleteCode()
  +processType()
  +deleteQuantity()
}
class Product {
  +String duration
  -String total
  -Date note
  #Date createdAt
  +sendStatus()
  +createEmail()
  +processId()
  +saveCreatedat()
}
Payment ..> Order : "*"
Warehouse --|> Payment
note right of Order : Ecommerce domain
@enduml