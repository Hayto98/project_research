@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Renewal {
  #double status
  +Date amount
  -int duration
  +boolean score
  +savePhone()
  +validateStatus()
  +cancelPrice()
}
class Loan {
  +long note
  -String description
  -String id
  -Date updatedAt
  +deleteActive()
  +updateType()
}
class Shelf {
  #boolean duration
  #int quantity
  #float note
  #float status
  +boolean total
  +validateCode()
  +cancelId()
}
interface Catalog {
  -int level
  #long active
  -float type
  +processDuration()
  +findName()
}
Catalog --|> Renewal
Loan --* Shelf
note right of Renewal : Library domain
@enduml