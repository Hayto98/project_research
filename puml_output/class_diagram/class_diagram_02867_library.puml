@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Renewal {
  #double status
  +Date amount
  -int duration
  +boolean score
  +getStatus()
  +createType()
  +deleteCode()
}
class Loan {
  +long level
  -Date price
  +setId()
  +createId()
}
interface Shelf {
  -long updatedAt
  +double name
  +getNote()
}
class Catalog {
  +boolean active
  -boolean updatedAt
  -double type
  +updateEmail()
}
Loan ..|> Shelf
Shelf --> Renewal : "1"
@enduml