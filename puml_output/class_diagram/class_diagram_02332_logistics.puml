@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
abstract class FuelLog {
  #long email
  #long quantity
  +Date name
  +findDescription()
  +sendName()
  +cancelEmail()
}
class Depot {
  -float address
  -double updatedAt
  #long name
  +findUpdatedat()
}
abstract class Customer {
  #long price
  +long status
  +processDescription()
  +sendActive()
  +deleteType()
}
class Tracking {
  #boolean createdAt
  #long description
  +processPrice()
  +saveTotal()
  +getScore()
}
class Route {
  #String score
  +double note
  #String code
  +double name
  -float price
  +findScore()
  +setTotal()
  +sendActive()
}
class Shipment {
  -Date duration
  -long score
  -float createdAt
  #Date id
  +calculateEmail()
  +findAddress()
}
class Manifest {
  #float phone
  #Date quantity
  #Date address
  +float total
  +long description
  +cancelTotal()
  +createActive()
  +updateTotal()
}
Shipment --> Manifest : "0..1"
Shipment --> Customer : "1..*"
FuelLog --o Depot
Shipment --|> Depot
@enduml