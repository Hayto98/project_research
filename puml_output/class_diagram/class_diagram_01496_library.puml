@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
abstract class Branch {
  -int price
  +boolean description
  -String updatedAt
  -String createdAt
  +findDuration()
  +validateScore()
  +saveId()
  +processScore()
}
abstract class Renewal {
  #float total
  -int type
  +sendUpdatedat()
  +createDuration()
  +deleteType()
}
abstract class Author {
  #Date amount
  +long total
  -int type
  -float score
  +deleteAddress()
}
class Publisher {
  #Date address
  #String code
  +Date type
  +validateEmail()
  +processDescription()
}
Author --> Renewal : "0..1"
Publisher --* Author
Author ..> Publisher : "1..*"
@enduml