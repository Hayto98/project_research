@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
abstract class Branch {
  -int price
  +boolean description
  -String updatedAt
  -String createdAt
  +sendAddress()
  +getPrice()
  +getTotal()
  +processLevel()
}
abstract class Renewal {
  -int phone
  #double price
  -double type
  +createAddress()
  +deleteNote()
}
class Author {
  +double code
  #Date createdAt
  #String address
  +findUpdatedat()
  +setQuantity()
}
abstract class Publisher {
  #long total
  #long score
  #float description
  #boolean price
  +validateUpdatedat()
  +deleteCode()
  +createActive()
}
Publisher --> Renewal : "0..1"
Branch --|> Author
Renewal --* Branch
note right of Branch : Library domain
@enduml