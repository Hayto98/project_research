@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Library {
  +long status
  #long quantity
  -int note
  +getAddress()
  +sendPrice()
  +updateDuration()
  +validateScore()
}
abstract class Grade {
  +Date id
  #float quantity
  #long phone
  +createPrice()
  +updateName()
  +deleteScore()
}
class Schedule {
  +float updatedAt
  -boolean phone
  +int address
  #Date amount
  +float id
  +calculateName()
  +validatePhone()
  +updateNote()
  +createType()
}
class Course {
  -long updatedAt
  #Date status
  +findCreatedat()
  +createDuration()
}
Course ..> Grade : "0..1"
Schedule ..> Grade : "0..1"
Library ..> Grade : "1"
@enduml