@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Fine {
  +boolean amount
  #float email
  +updateName()
  +processTotal()
  +sendAddress()
  +processActive()
}
class Catalog {
  +int code
  +long total
  -long status
  +processAmount()
}
abstract class Renewal {
  +double price
  -long status
  +getId()
  +saveScore()
  +cancelNote()
  +savePrice()
}
class Publisher {
  #int phone
  #Date status
  +calculateName()
  +findLevel()
  +validateDuration()
}
class Branch {
  +boolean id
  -long duration
  #float createdAt
  #float total
  +calculateScore()
  +updateId()
  +sendEmail()
}
class Shelf {
  #String id
  -int code
  +boolean name
  -double email
  +findPrice()
  +setId()
  +sendStatus()
}
interface Author {
  +Date quantity
  -double active
  #String createdAt
  +saveCreatedat()
  +calculateTotal()
  +updatePhone()
  +setName()
}
Author ..> Catalog : "0..1"
Catalog --> Renewal : "1..*"
Catalog --> Shelf : "0..1"
Branch --o Publisher
Shelf --o Publisher
@enduml