@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Fine {
  +boolean amount
  #float email
  +setNote()
  +createCreatedat()
  +findStatus()
  +findCreatedat()
}
class Catalog {
  -long status
  #Date description
  +String level
  -String id
  -String quantity
  +calculateTotal()
}
class Renewal {
  -String type
  #int phone
  #Date createdAt
  #Date updatedAt
  #boolean name
  +validateAddress()
  +updateQuantity()
  +getId()
}
class Publisher {
  -Date code
  +String active
  #long price
  +String phone
  +long quantity
  +processAmount()
}
class Branch {
  #float type
  #int level
  -Date address
  #float active
  +setAddress()
  +calculateActive()
}
class Shelf {
  -boolean address
  #float id
  #long amount
  +Date createdAt
  #int active
  +processActive()
  +processNote()
  +calculateDescription()
  +setActive()
}
class Author {
  -String quantity
  +String updatedAt
  #double code
  +boolean duration
  +findType()
}
Author ..> Publisher : "*"
Publisher --o Renewal
Branch ..|> Renewal
Renewal --|> Branch
Catalog ..> Publisher : "1..*"
note right of Fine : Library domain
@enduml