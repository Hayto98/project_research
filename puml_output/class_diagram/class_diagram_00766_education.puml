@startuml
skinparam monochrome true
skinparam ArrowColor #555555
abstract class Attendance {
  +float email
  #float description
  #long quantity
  +boolean amount
  +getStatus()
  +sendUpdatedat()
  +createScore()
  +cancelUpdatedat()
}
interface Student {
  #Date quantity
  #long active
  #int price
  #int id
  #String email
  +setId()
}
class Grade {
  +String level
  #int amount
  -boolean price
  +processActive()
  +sendTotal()
}
class Library {
  -int quantity
  +boolean duration
  +sendAmount()
  +getEmail()
  +sendScore()
}
abstract class Schedule {
  -long createdAt
  -String active
  -boolean updatedAt
  #double status
  +createType()
  +getQuantity()
}
class Course {
  #int phone
  +float quantity
  -float duration
  #Date price
  +findCode()
  +processTotal()
  +getScore()
}
Library --* Grade
Grade --o Attendance
Course ..|> Library
Attendance --> Schedule : "1..*"
Library --* Student
note right of Attendance : Education domain
@enduml