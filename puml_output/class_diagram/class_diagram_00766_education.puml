@startuml
skinparam monochrome true
skinparam ArrowColor #555555
abstract class Attendance {
  +float email
  #float description
  #long quantity
  +boolean amount
  +saveEmail()
  +deleteQuantity()
  +sendAmount()
  +sendNote()
}
class Student {
  #Date duration
  -String note
  #long quantity
  +createTotal()
  +updateType()
  +setAddress()
}
class Grade {
  +int status
  +float duration
  +saveName()
  +getLevel()
}
class Library {
  -float total
  #boolean level
  -long description
  +calculatePhone()
}
class Schedule {
  -float amount
  #int duration
  +long score
  #boolean active
  +setActive()
  +deleteType()
  +validateTotal()
  +setCreatedat()
}
interface Course {
  -long createdAt
  -String active
  -boolean updatedAt
  #double status
  +calculateScore()
  +validateName()
}
Course --|> Grade
Schedule ..> Grade : "1..*"
@enduml