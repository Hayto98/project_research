@startuml
skinparam ArrowColor #555555
class Vehicle {
  -int address
  +double total
  -float phone
  +saveActive()
}
class DeliveryNote {
  -float active
  #Date amount
  +String code
  #float quantity
  +boolean createdAt
  +createScore()
  +validateStatus()
  +setDuration()
  +cancelCode()
}
abstract class Inventory {
  #Date type
  -Date total
  #long quantity
  -Date email
  +long createdAt
  +processPrice()
}
class Shipment {
  #int id
  #long email
  -boolean name
  -String active
  +boolean type
  +deleteName()
  +sendUpdatedat()
}
Inventory --o Shipment
DeliveryNote --|> Shipment
Shipment --> Vehicle : "1"
@enduml