@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Transaction {
  #boolean duration
  -boolean active
  #long score
  #float total
  +validateType()
  +cancelName()
  +getDescription()
  +getEmail()
}
class Transfer {
  #boolean score
  -double description
  +long level
  #Date type
  +createCode()
  +processAddress()
  +saveCreatedat()
}
class Deposit {
  -double active
  #String id
  +double createdAt
  +long type
  +calculateDuration()
}
class Withdrawal {
  #int address
  +String status
  -boolean price
  +deleteActive()
  +calculateUpdatedat()
  +createPrice()
  +deleteTotal()
}
class Customer {
  -int level
  +long createdAt
  +long active
  #boolean score
  +getPrice()
  +createUpdatedat()
}
class Beneficiary {
  +String id
  -String level
  -float name
  +createPrice()
  +findTotal()
  +createCreatedat()
  +deleteAddress()
}
Withdrawal ..|> Beneficiary
Beneficiary ..> Withdrawal : "1..*"
note right of Transaction : Banking domain
@enduml