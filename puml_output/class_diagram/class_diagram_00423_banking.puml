@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Transaction {
  #boolean duration
  -boolean active
  #long score
  #float total
  +sendPhone()
  +validateName()
  +processId()
  +saveId()
}
class Transfer {
  -boolean name
  +float email
  +boolean address
  +sendAmount()
  +setPhone()
  +validateLevel()
  +saveScore()
}
abstract class Deposit {
  -float phone
  -String active
  +sendStatus()
  +validateScore()
  +findStatus()
  +updateDescription()
}
class Withdrawal {
  -double active
  #String id
  +double createdAt
  +long type
  +saveCode()
}
interface Customer {
  #double createdAt
  #int address
  +String status
  +sendQuantity()
  +deleteUpdatedat()
  +getId()
  +saveAddress()
}
interface Beneficiary {
  +float updatedAt
  #long quantity
  #boolean price
  +float description
  #float total
  +createCode()
  +updateQuantity()
  +processPrice()
}
Transaction ..> Deposit : "0..1"
Transaction --* Withdrawal
Transfer ..|> Beneficiary
Transaction --|> Customer
@enduml