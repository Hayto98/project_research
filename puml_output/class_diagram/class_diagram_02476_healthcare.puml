@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Ward {
  #String id
  #int score
  +Date name
  -boolean status
  +Date phone
  +validateUpdatedat()
  +updateCreatedat()
  +calculateTotal()
}
class Appointment {
  #int code
  #Date status
  +deleteType()
  +getQuantity()
}
interface Nurse {
  #long quantity
  +long price
  +String code
  +getQuantity()
  +cancelCreatedat()
  +sendLevel()
}
class Insurance {
  #float status
  #float price
  #double quantity
  +long description
  -double name
  +updateActive()
}
abstract class Patient {
  #String duration
  +double active
  #String amount
  #int level
  +updateActive()
  +deleteAddress()
  +findPrice()
}
class MedicalRecord {
  #boolean score
  -Date name
  +deleteName()
  +setDuration()
  +updateEmail()
}
class Billing {
  +boolean address
  #float name
  -Date createdAt
  #double id
  #String updatedAt
  +cancelDuration()
  +validateCode()
  +deleteScore()
  +findScore()
}
Patient ..> Appointment : "0..1"
Patient --|> MedicalRecord
@enduml