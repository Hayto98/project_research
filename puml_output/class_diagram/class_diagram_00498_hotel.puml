@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Room {
  #Date amount
  +int code
  +float duration
  +updateCreatedat()
  +deleteAddress()
}
class Invoice {
  -String id
  +double status
  +float code
  +String name
  +boolean updatedAt
  +findLevel()
  +cancelDuration()
  +updatePhone()
  +findAddress()
}
class Guest {
  +boolean address
  +Date quantity
  -float status
  +saveActive()
  +processTotal()
  +validateEmail()
}
interface Booking {
  +float email
  +int score
  #String active
  -int price
  #double updatedAt
  +processScore()
}
class CheckOut {
  #String phone
  -double status
  -double address
  -Date description
  -long type
  +setName()
  +validateType()
  +processId()
  +createType()
}
abstract class Housekeeping {
  -Date id
  -long status
  #boolean total
  #Date updatedAt
  +saveActive()
  +findTotal()
  +getDescription()
}
interface Reservation {
  -double status
  #long note
  +double total
  -boolean name
  +calculateUpdatedat()
  +updateEmail()
}
Room --|> CheckOut
Room --> Invoice : "1..*"
@enduml