@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Room {
  #Date amount
  +int code
  +float duration
  +updateEmail()
  +cancelPrice()
}
class Invoice {
  +long code
  +int name
  +deleteStatus()
  +getCreatedat()
  +cancelType()
  +saveUpdatedat()
}
class Guest {
  +boolean address
  +Date quantity
  -float status
  +sendNote()
  +setDuration()
  +processEmail()
}
interface Booking {
  -int updatedAt
  #double description
  #String level
  -boolean duration
  #boolean status
  +validateStatus()
  +validateDescription()
  +processCode()
  +processType()
}
abstract class CheckOut {
  #Date email
  -long address
  #String quantity
  +double type
  +float id
  +saveAddress()
  +createDuration()
  +sendQuantity()
  +sendActive()
}
class Housekeeping {
  +double note
  -Date total
  +deleteNote()
  +validateLevel()
  +updateTotal()
}
class Reservation {
  +int level
  #long status
  +sendAmount()
  +validateId()
  +validateActive()
  +calculateUpdatedat()
}
Guest --|> CheckOut
Room ..|> Invoice
note right of Room : Hotel domain
@enduml