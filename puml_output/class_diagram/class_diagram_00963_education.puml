@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Library {
  -int active
  -String note
  +calculateDescription()
  +saveCreatedat()
  +cancelNote()
  +cancelType()
}
abstract class Attendance {
  #int status
  +boolean quantity
  +long address
  +boolean level
  +getUpdatedat()
  +getPrice()
  +processLevel()
}
abstract class Enrollment {
  +boolean code
  #long description
  +Date score
  +validateTotal()
  +getDescription()
}
class Department {
  -String price
  #double createdAt
  +calculateTotal()
}
interface Course {
  #boolean phone
  -double price
  -float createdAt
  +int level
  +validateCreatedat()
  +createId()
}
interface Exam {
  #float duration
  +String active
  #long email
  #long id
  +double type
  +sendNote()
  +sendUpdatedat()
  +cancelCreatedat()
  +getId()
}
interface Schedule {
  -float score
  #String updatedAt
  #Date active
  +boolean type
  +boolean code
  +createStatus()
  +createAmount()
  +validateScore()
  +setTotal()
}
Course --|> Enrollment
Schedule ..|> Attendance
note right of Library : Education domain
@enduml