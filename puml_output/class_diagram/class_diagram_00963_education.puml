@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Library {
  -int active
  -String note
  +updateEmail()
  +setLevel()
  +deleteLevel()
  +sendPrice()
}
class Attendance {
  -long level
  #long type
  #int price
  +boolean phone
  +long status
  +calculatePrice()
}
class Enrollment {
  #double updatedAt
  -Date id
  +findId()
  +validatePhone()
  +validateCode()
  +saveActive()
}
class Department {
  +float createdAt
  #int description
  +Date phone
  +float total
  +getTotal()
  +findActive()
  +deleteQuantity()
  +savePrice()
}
abstract class Course {
  #long total
  -double duration
  +calculateCode()
  +updatePhone()
}
interface Exam {
  +float price
  -int email
  -String updatedAt
  #Date amount
  +findDescription()
  +calculateDescription()
  +sendQuantity()
  +findCreatedat()
}
class Schedule {
  #long duration
  +double status
  #double level
  #float active
  -boolean phone
  +findDescription()
  +calculateNote()
}
Library --> Course : "*"
Schedule ..|> Course
@enduml