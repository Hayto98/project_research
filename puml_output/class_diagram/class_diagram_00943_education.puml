@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
interface Enrollment {
  -long email
  +float score
  #long level
  +int id
  #double phone
  +processCreatedat()
  +calculateTotal()
  +deleteNote()
}
class Schedule {
  +String createdAt
  -int email
  +String phone
  +float address
  +String name
  +calculateDescription()
}
class Library {
  -long address
  +String score
  #long phone
  +double code
  +createActive()
  +sendQuantity()
  +sendStatus()
  +calculateName()
}
class Teacher {
  +String active
  #int type
  +int amount
  +deleteTotal()
  +cancelAddress()
  +updateEmail()
  +createNote()
}
class Department {
  -long code
  #float total
  #double quantity
  +boolean score
  +cancelLevel()
  +getPhone()
}
interface Grade {
  #double id
  -int address
  -Date duration
  #long createdAt
  +saveUpdatedat()
}
Schedule ..|> Grade
Schedule ..> Library : "*"
Library --|> Department
Enrollment --* Library
Schedule --o Teacher
@enduml