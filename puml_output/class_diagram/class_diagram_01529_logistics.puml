@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
interface Warehouse {
  #long email
  #long status
  -float phone
  +deletePrice()
}
abstract class Package {
  #double quantity
  #Date address
  +deleteActive()
  +createTotal()
  +saveDescription()
}
class Vehicle {
  -long type
  +String id
  #long price
  +float amount
  #long address
  +deleteNote()
}
interface Shipment {
  +float address
  -Date type
  -Date note
  +deleteActive()
  +deleteEmail()
}
class Manifest {
  +float duration
  #float phone
  #boolean address
  -boolean amount
  +saveAmount()
  +calculateDuration()
  +sendPhone()
}
Shipment ..> Manifest : "0..1"
Vehicle --o Manifest
Shipment --o Package
Warehouse --o Shipment
@enduml