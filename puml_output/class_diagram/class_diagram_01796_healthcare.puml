@startuml
skinparam monochrome true
skinparam ArrowColor #555555
interface Ward {
  +Date level
  -Date type
  +String status
  -Date duration
  +processAmount()
  +processPrice()
  +createCreatedat()
}
interface Nurse {
  -Date quantity
  +double createdAt
  -float score
  +cancelAddress()
  +processUpdatedat()
  +validateScore()
}
abstract class Appointment {
  -double active
  -String type
  #String note
  -float quantity
  +saveAddress()
}
class Prescription {
  #double price
  #double quantity
  #boolean name
  +calculateAmount()
}
abstract class Hospital {
  +int status
  +float email
  +sendDuration()
  +validateCode()
}
interface Treatment {
  -int amount
  #Date address
  -boolean email
  #Date name
  -Date price
  +setAmount()
}
interface MedicalRecord {
  +long address
  #float amount
  +long description
  -String duration
  -long quantity
  +createCode()
  +calculateLevel()
  +deleteActive()
  +saveStatus()
}
Treatment --> Appointment : "*"
Hospital ..> Nurse : "1..*"
@enduml