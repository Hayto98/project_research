@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
interface Exam {
  -boolean price
  #long createdAt
  -String active
  #String level
  #long type
  +deleteQuantity()
  +validateLevel()
  +updatePrice()
  +processAmount()
}
class Schedule {
  #float active
  +Date total
  +processCode()
  +saveDescription()
}
class Book {
  -Date updatedAt
  #double price
  #String description
  #long phone
  -double level
  +sendQuantity()
  +validateNote()
}
class Library {
  +String name
  #int score
  +long id
  +calculateTotal()
  +deleteEmail()
  +setAmount()
  +createName()
}
abstract class Student {
  #boolean createdAt
  #int duration
  +int phone
  +processTotal()
  +processCreatedat()
  +calculateEmail()
}
class Department {
  #float id
  #float price
  +processName()
  +savePrice()
  +createPrice()
  +getType()
}
class Classroom {
  +double note
  +int description
  +getCode()
  +calculateAmount()
  +updateUpdatedat()
}
Library --* Book
Schedule --o Library
Student --* Classroom
@enduml