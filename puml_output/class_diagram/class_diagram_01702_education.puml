@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
interface Exam {
  -boolean price
  #long createdAt
  -String active
  #String level
  #long type
  +setId()
  +setEmail()
  +sendStatus()
  +findActive()
}
abstract class Schedule {
  +Date level
  -double createdAt
  +calculateDescription()
  +cancelPhone()
}
interface Book {
  -double total
  #int note
  #int active
  +int name
  +float phone
  +updateCode()
}
interface Library {
  -float status
  -Date address
  +int note
  +validateDuration()
  +cancelAmount()
}
class Student {
  +Date level
  +Date address
  +String note
  +sendActive()
  +sendPrice()
  +getLevel()
  +calculateCode()
}
class Department {
  +double note
  +int description
  +cancelNote()
  +setUpdatedat()
  +calculateEmail()
}
class Classroom {
  #double total
  +Date duration
  +int phone
  +createActive()
  +deleteTotal()
  +processDuration()
  +updateAddress()
}
Book --o Library
Schedule --* Classroom
Book --|> Student
note right of Exam : Education domain
@enduml