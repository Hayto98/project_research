@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Branch {
  +boolean quantity
  #float type
  #double updatedAt
  +findUpdatedat()
  +createNote()
  +validateDescription()
}
interface Publisher {
  +long status
  #Date description
  +cancelDescription()
  +calculateLevel()
  +validateEmail()
  +createId()
}
class Loan {
  +long phone
  #Date email
  -double duration
  +Date score
  -double price
  +saveNote()
  +sendAddress()
  +processEmail()
}
abstract class Catalog {
  -float note
  #float phone
  -Date email
  +deleteLevel()
  +validatePrice()
}
class Librarian {
  +float createdAt
  +int type
  #float email
  #long total
  +processStatus()
  +findCreatedat()
  +updateAddress()
  +saveQuantity()
}
class Renewal {
  +boolean note
  +double quantity
  +getUpdatedat()
}
Renewal ..|> Catalog
Renewal ..|> Branch
Branch --o Librarian
Loan --|> Branch
Librarian ..> Renewal : "1..*"
note right of Branch : Library domain
@enduml