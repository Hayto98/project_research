@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Branch {
  +boolean quantity
  #float type
  #double updatedAt
  +setCreatedat()
  +createScore()
  +findCreatedat()
}
abstract class Publisher {
  +String description
  -boolean score
  #float name
  -boolean status
  +cancelCreatedat()
  +processEmail()
}
class Loan {
  #Date email
  #Date id
  -long code
  -long active
  +sendType()
  +saveStatus()
  +saveName()
}
class Catalog {
  #double score
  -Date price
  -Date total
  -boolean status
  +saveAmount()
  +cancelDescription()
  +validateAddress()
}
abstract class Librarian {
  -float note
  #float phone
  -Date email
  +saveQuantity()
  +savePrice()
}
class Renewal {
  -String quantity
  +int email
  #float createdAt
  #long type
  -double level
  +deleteType()
}
Publisher ..> Loan : "1..*"
Publisher --o Branch
Loan --> Publisher : "0..1"
@enduml