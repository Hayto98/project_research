@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
abstract class Branch {
  +boolean total
  +long duration
  -double name
  +long level
  +deleteTotal()
  +deleteNote()
  +updateStatus()
  +calculatePhone()
}
interface Loan {
  #long code
  +double note
  +long id
  +cancelScore()
  +calculateId()
}
class Publisher {
  -float createdAt
  #boolean description
  -double active
  #int updatedAt
  #boolean type
  +validateScore()
  +updatePhone()
}
class Shelf {
  +boolean duration
  -int note
  #double quantity
  +createPhone()
}
interface Librarian {
  -long description
  +double score
  +updateActive()
  +createType()
  +calculateNote()
  +processCreatedat()
}
interface Catalog {
  -String updatedAt
  -boolean address
  #double level
  -int status
  -float id
  +deleteUpdatedat()
  +findType()
  +calculateStatus()
  +getCode()
}
abstract class Reservation {
  #double score
  -double amount
  #int email
  +calculateTotal()
  +cancelStatus()
}
Publisher --* Loan
Shelf --o Reservation
@enduml