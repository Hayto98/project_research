@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
abstract class Branch {
  +boolean total
  +long duration
  -double name
  +long level
  +getUpdatedat()
  +createActive()
  +deleteCode()
  +processId()
}
class Loan {
  -int price
  #String status
  +sendTotal()
}
class Publisher {
  #boolean duration
  #double active
  -float updatedAt
  +processActive()
  +updateScore()
  +cancelScore()
}
interface Shelf {
  #Date address
  -long code
  +boolean updatedAt
  +deleteDuration()
  +processId()
  +setScore()
  +setDescription()
}
interface Librarian {
  #int address
  #boolean updatedAt
  #double note
  +long total
  #boolean id
  +setScore()
  +getPhone()
  +setQuantity()
}
interface Catalog {
  +boolean price
  +Date amount
  #long email
  #double duration
  -double total
  +updateCode()
  +getQuantity()
}
class Reservation {
  +double total
  +int note
  -double type
  -long description
  +validateDescription()
}
Branch --|> Publisher
Loan --* Publisher
Catalog --* Branch
note right of Branch : Library domain
@enduml