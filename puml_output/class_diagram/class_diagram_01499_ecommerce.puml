@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Warehouse {
  -double description
  #double updatedAt
  #long code
  #float id
  +String email
  +getDuration()
  +validateUpdatedat()
  +cancelPhone()
}
interface Invoice {
  -int amount
  #float name
  +long quantity
  -float active
  #double code
  +validateDuration()
  +createStatus()
  +updateId()
  +validateQuantity()
}
interface Wishlist {
  #int updatedAt
  -Date email
  -int id
  -float createdAt
  +findAmount()
}
class Payment {
  -float address
  -long amount
  -long quantity
  -long price
  +processTotal()
  +saveActive()
  +sendLevel()
}
class Product {
  #double amount
  -int code
  -Date id
  -double type
  -float note
  +cancelUpdatedat()
  +setAmount()
  +calculateQuantity()
  +calculateScore()
}
interface Coupon {
  +int status
  #boolean note
  #double phone
  +String name
  #boolean duration
  +calculateDuration()
  +findAmount()
  +findActive()
  +calculateActive()
}
class Customer {
  #Date amount
  #Date score
  #Date name
  #Date status
  +updateLevel()
  +validateAmount()
  +deletePrice()
  +sendLevel()
}
Warehouse ..|> Coupon
Product --* Warehouse
Invoice --o Payment
Invoice --o Wishlist
note right of Warehouse : Ecommerce domain
@enduml