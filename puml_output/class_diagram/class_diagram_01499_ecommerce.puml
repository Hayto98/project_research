@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Warehouse {
  -double description
  #double updatedAt
  #long code
  #float id
  +String email
  +cancelTotal()
  +findDescription()
  +cancelId()
}
class Invoice {
  -boolean score
  #String total
  -int amount
  #float name
  +cancelId()
  +validateUpdatedat()
}
abstract class Wishlist {
  -float address
  -boolean email
  #long status
  +Date updatedAt
  -String id
  +updatePhone()
  +createCreatedat()
}
class Payment {
  -long description
  +long note
  #double id
  -float amount
  -long score
  +processDescription()
  +updateTotal()
  +validateDuration()
  +calculateScore()
}
abstract class Product {
  #String active
  +double score
  #boolean phone
  #Date type
  -float amount
  +sendCode()
  +validateCreatedat()
  +cancelPhone()
  +getActive()
}
class Coupon {
  -float price
  -float type
  -boolean updatedAt
  #double code
  +double amount
  +calculateId()
  +cancelEmail()
  +setLevel()
}
class Customer {
  #Date code
  +Date id
  #float score
  #float price
  -boolean active
  +saveLevel()
  +updateLevel()
  +createCode()
}
Product --|> Coupon
Warehouse ..> Coupon : "*"
Invoice ..> Coupon : "1..*"
Invoice --o Customer
Product --* Customer
@enduml