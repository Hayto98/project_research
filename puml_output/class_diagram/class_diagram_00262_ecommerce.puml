@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Product {
  -boolean level
  #boolean id
  -int phone
  -float price
  +calculateStatus()
}
class Coupon {
  +double description
  #long id
  -String active
  +getType()
}
interface Customer {
  -Date code
  #double id
  +int status
  +saveEmail()
  +calculateDescription()
  +findLevel()
}
class Review {
  -long type
  -boolean address
  +long total
  +setUpdatedat()
}
Customer ..|> Coupon
Coupon ..> Review : "1"
@enduml