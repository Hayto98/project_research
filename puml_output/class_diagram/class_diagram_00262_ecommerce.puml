@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Product {
  -boolean level
  #boolean id
  -int phone
  -float price
  +findAddress()
}
class Coupon {
  -Date id
  -long active
  +String updatedAt
  +saveDuration()
}
class Customer {
  -Date id
  #double status
  +updatePhone()
  +getId()
}
interface Review {
  -long type
  -boolean address
  +long total
  +getPrice()
}
Customer --* Product
Review --> Customer : "1"
note right of Product : Ecommerce domain
@enduml