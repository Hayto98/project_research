@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Insurance {
  -Date active
  #long duration
  +getNote()
  +deleteEmail()
}
class Hospital {
  -int updatedAt
  -float score
  #Date type
  +findActive()
  +updateStatus()
  +updateAddress()
  +validateQuantity()
}
class Nurse {
  #double active
  #int quantity
  +processDuration()
  +findNote()
}
class MedicalRecord {
  +float total
  +boolean amount
  +cancelEmail()
}
class LabTest {
  #long note
  #String type
  +processPrice()
  +calculateId()
  +validateUpdatedat()
  +deleteName()
}
class Ward {
  #Date total
  #long level
  #boolean quantity
  +sendTotal()
  +updateType()
}
Ward ..> MedicalRecord : "*"
LabTest --|> Ward
Insurance --* Ward
MedicalRecord --|> Nurse
Ward ..> LabTest : "*"
note right of Insurance : Healthcare domain
@enduml