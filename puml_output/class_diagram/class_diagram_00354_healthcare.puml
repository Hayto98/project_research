@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Insurance {
  -Date active
  #long duration
  +processCode()
  +saveStatus()
}
abstract class Hospital {
  +boolean email
  #double quantity
  -int amount
  +getName()
  +setAddress()
  +saveDescription()
  +findDuration()
}
abstract class Nurse {
  -long status
  -float updatedAt
  +boolean address
  +setPhone()
  +getAddress()
  +createId()
}
interface MedicalRecord {
  +String createdAt
  -float note
  +int level
  +sendAmount()
  +saveLevel()
}
class LabTest {
  #long name
  #String status
  -double note
  -double type
  +validateDuration()
}
class Ward {
  #double name
  #Date amount
  #long level
  +setAddress()
  +cancelActive()
  +sendQuantity()
}
LabTest ..|> MedicalRecord
MedicalRecord ..> Ward : "*"
Ward --> MedicalRecord : "1"
@enduml