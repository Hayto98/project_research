@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
abstract class Post {
  #float address
  #int code
  -int duration
  #Date score
  +updateActive()
  +saveDuration()
  +findCreatedat()
}
interface Notification {
  +boolean status
  +String name
  +double score
  #Date amount
  -double type
  +deleteScore()
  +validateCode()
  +updateNote()
}
abstract class Group {
  -Date updatedAt
  -String type
  #String phone
  +String quantity
  +processCreatedat()
  +cancelQuantity()
  +sendId()
  +saveCreatedat()
}
class Album {
  +int score
  #long createdAt
  +findAmount()
  +findCode()
}
interface Report {
  #double note
  +long code
  -double updatedAt
  #Date amount
  #long quantity
  +findCode()
  +findLevel()
  +updateCreatedat()
  +validateScore()
}
abstract class User {
  #int total
  +boolean code
  -String email
  +deleteDescription()
  +calculateScore()
  +sendDuration()
  +saveCreatedat()
}
Album --o Notification
Report --* Album
User --* Notification
@enduml