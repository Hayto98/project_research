@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Insurance {
  +long score
  +String active
  #float name
  #float createdAt
  #double amount
  +calculateQuantity()
  +updateDescription()
  +updateEmail()
}
class Appointment {
  #long quantity
  #String description
  +processEmail()
  +deleteUpdatedat()
}
class Treatment {
  -double code
  -Date address
  -boolean price
  #boolean email
  +setDuration()
  +findCreatedat()
}
abstract class Hospital {
  -Date score
  +boolean email
  -boolean price
  +boolean id
  +cancelDescription()
}
abstract class MedicalRecord {
  +long quantity
  -int address
  +int code
  #long phone
  -boolean status
  +processAddress()
}
class Diagnosis {
  #Date description
  -float email
  +float type
  +updateId()
  +cancelActive()
  +getDuration()
  +sendNote()
}
Appointment --o Treatment
MedicalRecord --|> Insurance
Hospital --* Insurance
note right of Insurance : Healthcare domain
@enduml