@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Insurance {
  +long score
  +String active
  #float name
  #float createdAt
  #double amount
  +saveCode()
  +findScore()
  +processPhone()
}
class Appointment {
  +long updatedAt
  +Date email
  -Date id
  +validateCreatedat()
}
abstract class Treatment {
  +long description
  -Date updatedAt
  -long email
  -long phone
  +findName()
  +getUpdatedat()
  +cancelDuration()
  +createDescription()
}
class Hospital {
  -long duration
  #boolean createdAt
  +updateCode()
  +sendActive()
  +saveName()
}
class MedicalRecord {
  #Date code
  +double total
  -long score
  -String duration
  -String name
  +validateAddress()
}
class Diagnosis {
  -boolean updatedAt
  +double duration
  -float address
  +updateStatus()
  +findPhone()
}
Hospital ..> MedicalRecord : "1..*"
Insurance ..|> Hospital
Diagnosis --> Insurance : "1"
MedicalRecord --o Diagnosis
@enduml