@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Return {
  #String score
  -long total
  #Date description
  +sendActive()
  +createAmount()
  +saveNote()
  +processPhone()
}
abstract class Supplier {
  -long id
  +double email
  #float address
  #boolean total
  #String type
  +saveCreatedat()
}
class Order {
  -long active
  +int id
  +Date status
  +createEmail()
  +deleteStatus()
  +processPrice()
  +createId()
}
class Category {
  -boolean updatedAt
  #boolean email
  +int phone
  +cancelDuration()
  +validateAmount()
  +createPrice()
}
class Customer {
  -Date code
  #double address
  #long level
  +processUpdatedat()
  +sendCode()
  +findStatus()
}
interface Warehouse {
  -int createdAt
  +double description
  +float amount
  #long address
  -double duration
  +sendPrice()
  +updateName()
}
Supplier ..|> Order
Warehouse --|> Order
@enduml