@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Branch {
  #String name
  #boolean duration
  +Date updatedAt
  #long type
  +deleteAmount()
  +saveAmount()
  +sendDuration()
  +validateActive()
}
interface Book {
  -Date quantity
  #int updatedAt
  +cancelDescription()
  +updateStatus()
}
class Reservation {
  -String address
  #int description
  +boolean updatedAt
  -String phone
  +updateEmail()
  +processLevel()
  +updateScore()
}
abstract class Author {
  +Date quantity
  -double phone
  -float description
  #float address
  #Date price
  +findQuantity()
  +createAddress()
  +setPrice()
  +sendTotal()
}
interface Shelf {
  +Date duration
  #float total
  +createLevel()
}
interface Catalog {
  -Date total
  #Date price
  +int type
  #double level
  +boolean duration
  +sendCode()
  +createStatus()
  +saveStatus()
  +updateDescription()
}
Shelf ..|> Catalog
Author --|> Reservation
note right of Branch : Library domain
@enduml