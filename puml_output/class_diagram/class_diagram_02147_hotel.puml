@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Housekeeping {
  +boolean level
  -boolean code
  +setDuration()
  +saveAmount()
  +sendActive()
}
interface Booking {
  -Date amount
  +String address
  +sendName()
}
class Invoice {
  +int status
  -boolean updatedAt
  +Date name
  +sendPrice()
  +findEmail()
  +validateScore()
  +getNote()
}
abstract class Amenity {
  #float id
  +boolean total
  #float email
  -int score
  #float amount
  +sendPrice()
  +updateId()
  +updateTotal()
  +deletePhone()
}
abstract class CheckOut {
  #long address
  +long active
  +boolean description
  #long phone
  +getStatus()
  +findLevel()
}
Amenity --> Invoice : "1..*"
Housekeeping --|> Amenity
Housekeeping ..> Booking : "*"
@enduml