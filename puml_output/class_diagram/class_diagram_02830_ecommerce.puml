@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
interface Coupon {
  #int level
  #String amount
  #float duration
  #int name
  +setAddress()
  +createAddress()
  +createStatus()
}
class Category {
  +boolean phone
  #Date status
  #float name
  +int level
  +calculateCreatedat()
  +findTotal()
  +updateCode()
}
class Shipment {
  +double total
  -Date type
  +double duration
  #long amount
  +int price
  +updateType()
  +findPrice()
}
class Supplier {
  -float note
  #float address
  +Date score
  #long phone
  +findTotal()
}
class Order {
  #long address
  #double id
  -int type
  #float price
  #long phone
  +setId()
  +saveScore()
  +cancelName()
  +processPrice()
}
class Invoice {
  #int phone
  #long note
  +boolean level
  +getCreatedat()
  +processAmount()
  +getPhone()
}
Coupon ..|> Category
Category --* Invoice
Category --o Coupon
@enduml