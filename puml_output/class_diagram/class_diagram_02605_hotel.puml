@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Booking {
  #boolean updatedAt
  +double type
  +double note
  +int score
  +sendPrice()
  +findPhone()
  +updateLevel()
}
class Reservation {
  +float quantity
  -String address
  +String name
  +cancelNote()
  +processUpdatedat()
  +calculateCode()
}
class CheckOut {
  -boolean email
  #String price
  +String note
  #Date total
  -float duration
  +cancelDescription()
}
abstract class Amenity {
  #double name
  +float description
  +findName()
  +processPrice()
  +createId()
  +cancelLevel()
}
abstract class Payment {
  +double quantity
  #Date note
  +boolean status
  #float address
  -boolean duration
  +sendId()
  +getPrice()
}
Reservation --|> CheckOut
Amenity --> CheckOut : "1"
@enduml