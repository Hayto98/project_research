@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Booking {
  #boolean updatedAt
  +double type
  +double note
  +int score
  +saveDescription()
  +createName()
  +updateQuantity()
}
class Reservation {
  +String description
  +boolean phone
  +updateAmount()
  +calculateCreatedat()
  +saveDuration()
}
abstract class CheckOut {
  -boolean price
  #String note
  +String total
  #Date email
  +setNote()
  +getName()
  +deleteDuration()
}
abstract class Amenity {
  -double note
  -double level
  +boolean updatedAt
  +cancelQuantity()
  +deletePrice()
  +cancelStatus()
}
interface Payment {
  +long active
  +Date updatedAt
  #Date createdAt
  #float code
  +validateLevel()
  +cancelId()
  +updateAddress()
  +sendUpdatedat()
}
CheckOut ..> Booking : "1"
Payment --o Booking
note right of Booking : Hotel domain
@enduml