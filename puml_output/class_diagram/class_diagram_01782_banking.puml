@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Loan {
  -long score
  -int active
  +createPhone()
  +saveName()
  +validateQuantity()
  +cancelLevel()
}
interface Statement {
  +int id
  -double note
  -Date amount
  +double name
  +findStatus()
  +getUpdatedat()
  +setEmail()
  +setNote()
}
class Branch {
  +int createdAt
  #String duration
  -float amount
  #long score
  #int email
  +findScore()
  +validateEmail()
  +validateUpdatedat()
  +setType()
}
class Customer {
  +double createdAt
  -float active
  +setPrice()
  +validateStatus()
  +saveQuantity()
}
abstract class Transaction {
  -long code
  +int active
  +double level
  +int createdAt
  +long quantity
  +cancelActive()
  +findDuration()
  +processAmount()
  +processType()
}
Branch --* Statement
Branch --|> Customer
Statement --o Loan
note right of Loan : Banking domain
@enduml