@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Loan {
  -long score
  -int active
  +validateAddress()
  +processCreatedat()
  +saveLevel()
  +saveScore()
}
class Statement {
  #String quantity
  -int level
  +String active
  +double phone
  +sendStatus()
  +cancelAddress()
  +updateAddress()
  +setUpdatedat()
}
abstract class Branch {
  +float status
  -int name
  #Date updatedAt
  -float duration
  +float email
  +validateQuantity()
  +processNote()
}
class Customer {
  #long status
  #int description
  -Date duration
  #long price
  +processStatus()
  +processPrice()
  +validatePhone()
}
abstract class Transaction {
  +double duration
  -float status
  -String createdAt
  -long active
  +saveUpdatedat()
}
Customer --|> Transaction
Transaction --* Statement
Customer ..|> Branch
@enduml