@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
abstract class Group {
  -Date type
  #double duration
  +setAmount()
  +setId()
  +cancelActive()
}
class Message {
  +long code
  -String quantity
  +int active
  #long level
  +double description
  +processId()
}
abstract class Notification {
  #double status
  #long quantity
  +float updatedAt
  +createAddress()
  +validateCode()
  +cancelStatus()
  +validateDuration()
}
interface Album {
  +long type
  +float amount
  +setNote()
  +saveAddress()
  +calculateId()
  +cancelStatus()
}
class Post {
  +Date active
  -long address
  +deleteAddress()
  +deleteQuantity()
  +saveNote()
}
class Follower {
  #Date description
  -double note
  +calculateEmail()
  +findTotal()
  +setQuantity()
}
class Report {
  #double status
  -float id
  #String score
  -float price
  +setPrice()
  +sendNote()
  +updateDescription()
  +createLevel()
}
Follower --> Post : "1..*"
Album --* Notification
Notification --o Message
Follower --* Album
note right of Group : Social Media domain
@enduml