@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
abstract class Group {
  -Date type
  #double duration
  +createAddress()
  +createTotal()
  +calculateAddress()
}
class Message {
  #Date level
  +double active
  +findScore()
}
interface Notification {
  +String description
  +boolean createdAt
  -int phone
  -Date total
  +processTotal()
}
class Album {
  #long description
  +float status
  -long quantity
  -long updatedAt
  +boolean type
  +calculateCreatedat()
}
interface Post {
  +long type
  +float amount
  +cancelLevel()
  +getDuration()
  +findNote()
  +saveAmount()
}
class Follower {
  +Date id
  -long status
  #long quantity
  +float name
  -int address
  +deletePhone()
  +deleteTotal()
  +setScore()
}
abstract class Report {
  #Date name
  -double description
  -float note
  +deleteName()
  +sendUpdatedat()
  +validateStatus()
  +processNote()
}
Group ..|> Notification
Post --> Report : "1..*"
Group --> Report : "*"
Follower --* Album
Report --|> Post
@enduml