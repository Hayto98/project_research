@startuml
skinparam shadowing true
interface Route {
  -Date level
  +boolean quantity
  +long name
  #int updatedAt
  +getTotal()
  +sendType()
  +saveName()
  +cancelPrice()
}
abstract class Warehouse {
  -long score
  #int name
  #Date email
  +float phone
  +double status
  +saveEmail()
}
class Shipment {
  +float level
  -Date code
  #float createdAt
  -float description
  +processEmail()
}
interface Manifest {
  -float total
  -long code
  #long status
  +double price
  +sendUpdatedat()
  +setActive()
}
class Customer {
  +boolean updatedAt
  +int name
  +updateCreatedat()
  +savePhone()
}
class Vehicle {
  -int address
  +String level
  -int score
  #String phone
  +createEmail()
  +cancelScore()
  +findStatus()
}
abstract class FuelLog {
  #boolean level
  -long code
  #int email
  +processCreatedat()
  +deleteNote()
  +saveTotal()
  +findEmail()
}
Customer --o Warehouse
Warehouse ..> Vehicle : "1"
@enduml