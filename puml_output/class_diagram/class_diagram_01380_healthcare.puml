@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
interface Diagnosis {
  -String total
  +long quantity
  -double code
  +long description
  #Date createdAt
  +cancelNote()
  +deleteDuration()
  +cancelPhone()
}
interface Nurse {
  -int description
  -boolean status
  +calculateCreatedat()
}
class Insurance {
  #String email
  #double id
  #String quantity
  +updateDuration()
  +setCode()
  +updateLevel()
  +deleteDuration()
}
class Doctor {
  #Date address
  -Date description
  -float name
  +float score
  +saveCode()
  +sendType()
  +processAmount()
}
class Prescription {
  #int name
  +float status
  +Date amount
  +setPhone()
  +createPhone()
  +calculateAddress()
  +setCode()
}
class LabTest {
  +float score
  +long name
  -String active
  #String createdAt
  -boolean phone
  +updateAddress()
  +cancelId()
  +saveCode()
  +deleteActive()
}
class Treatment {
  +boolean quantity
  +float level
  -int email
  +String address
  +updateStatus()
  +saveEmail()
  +updateCode()
}
Nurse --o Prescription
Doctor --* Diagnosis
Doctor ..|> Prescription
note right of Diagnosis : Healthcare domain
@enduml