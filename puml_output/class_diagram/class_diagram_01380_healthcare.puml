@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
interface Diagnosis {
  -String total
  +long quantity
  -double code
  +long description
  #Date createdAt
  +validateActive()
  +deletePrice()
  +getEmail()
}
interface Nurse {
  -int score
  -boolean name
  +float description
  -Date status
  +saveScore()
  +processDuration()
}
class Insurance {
  #double quantity
  #String id
  +updateDescription()
  +validateActive()
  +processCreatedat()
  +getType()
}
class Doctor {
  -long level
  +String description
  +boolean status
  +cancelUpdatedat()
  +calculateLevel()
  +saveName()
}
class Prescription {
  +Date code
  #int score
  #int type
  +Date level
  +updateQuantity()
}
class LabTest {
  +long id
  -long amount
  -Date note
  +setDuration()
  +cancelStatus()
  +getType()
}
class Treatment {
  +float score
  +long name
  -String active
  #String createdAt
  -boolean phone
  +processPrice()
  +setEmail()
  +findName()
  +updateActive()
}
Nurse ..|> Prescription
Insurance --> Treatment : "1..*"
@enduml