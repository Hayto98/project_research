@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Booking {
  +boolean address
  +double active
  +String description
  +sendStatus()
  +setUpdatedat()
  +processQuantity()
}
class Amenity {
  #Date updatedAt
  #float status
  +findLevel()
  +processTotal()
}
interface Guest {
  -boolean description
  -double status
  +boolean createdAt
  -long note
  +calculateUpdatedat()
  +calculateName()
}
class Restaurant {
  -int status
  +float level
  +sendTotal()
  +calculateTotal()
}
Booking --o Amenity
Guest --> Amenity : "*"
note right of Booking : Hotel domain
@enduml