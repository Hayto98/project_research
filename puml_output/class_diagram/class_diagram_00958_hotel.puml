@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Booking {
  +boolean address
  +double active
  +String description
  +calculatePrice()
  +createPhone()
  +getType()
}
class Amenity {
  #Date quantity
  #float createdAt
  +Date status
  #boolean updatedAt
  -float score
  +cancelUpdatedat()
  +saveDuration()
  +saveCreatedat()
  +validateCode()
}
class Guest {
  -double note
  +boolean quantity
  -long active
  +sendScore()
  +processPrice()
}
abstract class Restaurant {
  +boolean code
  -int status
  +validateType()
  +createCode()
}
Restaurant --o Guest
Booking --o Restaurant
Restaurant --o Amenity
@enduml