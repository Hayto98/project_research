@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Enrollment {
  +double duration
  #long id
  +double updatedAt
  +cancelCreatedat()
  +validateId()
  +getType()
}
abstract class Teacher {
  #long address
  #Date active
  +String updatedAt
  +double note
  -int status
  +createTotal()
  +processAddress()
}
interface Assignment {
  #boolean duration
  -double score
  +setEmail()
  +findUpdatedat()
  +createQuantity()
}
abstract class Attendance {
  #int level
  #double note
  +sendType()
  +getEmail()
}
class Grade {
  +float name
  +double createdAt
  +float price
  #float active
  +setAmount()
  +sendCode()
}
interface Schedule {
  -float address
  -int createdAt
  -long active
  -float description
  +calculatePhone()
}
Assignment --> Attendance : "1"
Grade --o Attendance
Schedule ..|> Enrollment
note right of Enrollment : Education domain
@enduml