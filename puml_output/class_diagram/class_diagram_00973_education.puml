@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Enrollment {
  +double duration
  #long id
  +double updatedAt
  +findLevel()
  +getQuantity()
  +processActive()
}
class Teacher {
  -double name
  #long type
  +saveAmount()
  +validateEmail()
}
class Assignment {
  -double status
  +int duration
  +processPhone()
  +cancelCreatedat()
  +createName()
}
class Attendance {
  #boolean duration
  -double score
  +processAmount()
  +deleteLevel()
  +sendType()
}
class Grade {
  +boolean email
  #Date quantity
  #Date type
  +getStatus()
  +setAddress()
  +setType()
  +saveDescription()
}
abstract class Schedule {
  -String score
  -String type
  +Date id
  +getScore()
  +getStatus()
  +setLevel()
  +updateCode()
}
Attendance ..> Enrollment : "0..1"
Enrollment --> Teacher : "1"
@enduml