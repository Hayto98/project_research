@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Amenity {
  -Date level
  #double code
  -double active
  +boolean type
  +updateAddress()
}
class CheckIn {
  #double quantity
  -String level
  +calculateUpdatedat()
  +getPrice()
  +getCode()
}
class CheckOut {
  -Date description
  -float type
  #long createdAt
  +Date id
  -String email
  +deleteLevel()
  +validateId()
  +deletePhone()
  +setName()
}
class Reservation {
  #int email
  #boolean amount
  #String address
  +int updatedAt
  +findId()
  +cancelNote()
}
CheckIn --* Amenity
CheckOut ..> Amenity : "*"
@enduml