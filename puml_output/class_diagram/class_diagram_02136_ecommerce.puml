@startuml

class Warehouse {
  -Date score
  +String quantity
  -double amount
  +getQuantity()
}
interface Wishlist {
  #String address
  #float name
  +float price
  #boolean description
  +boolean note
  +cancelAddress()
  +processType()
  +processEmail()
}
abstract class Shipment {
  #String amount
  #double code
  +processLevel()
  +createId()
}
interface Coupon {
  +double duration
  -long total
  +boolean score
  #boolean active
  +getPhone()
  +sendQuantity()
}
interface Customer {
  #long phone
  #Date createdAt
  -boolean total
  +String address
  -boolean score
  +saveAmount()
  +updateCode()
  +getCode()
  +cancelAddress()
}
Coupon --> Warehouse : "0..1"
Shipment --> Warehouse : "1..*"
note right of Warehouse : Ecommerce domain
@enduml