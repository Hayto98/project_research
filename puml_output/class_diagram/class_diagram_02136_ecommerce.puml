@startuml

class Warehouse {
  -Date score
  +String quantity
  -double amount
  +getDuration()
}
class Wishlist {
  -Date active
  #Date note
  #int address
  -boolean name
  +sendQuantity()
}
class Shipment {
  -double duration
  -long quantity
  #Date address
  +saveEmail()
  +createCode()
  +findNote()
  +getQuantity()
}
class Coupon {
  #float updatedAt
  -boolean type
  #Date quantity
  #String id
  -long phone
  +calculateLevel()
  +findNote()
  +getCode()
}
interface Customer {
  #long name
  #double phone
  -int active
  +saveCreatedat()
  +deletePhone()
  +getPhone()
  +cancelUpdatedat()
}
Customer --> Coupon : "1"
Warehouse --> Shipment : "*"
Wishlist --|> Customer
@enduml