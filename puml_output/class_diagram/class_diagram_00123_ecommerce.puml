@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
interface Coupon {
  -int description
  #float quantity
  +updateScore()
}
class Category {
  -long description
  #long name
  -boolean note
  +boolean price
  +String active
  +setDescription()
  +createDescription()
}
class Wishlist {
  +float note
  -double id
  +createType()
  +findType()
  +createId()
}
class Order {
  +double quantity
  +Date level
  #float address
  #Date description
  -boolean duration
  +findUpdatedat()
  +getQuantity()
  +saveNote()
}
class Shipment {
  -double score
  #Date type
  +sendLevel()
  +sendStatus()
  +cancelDescription()
  +setUpdatedat()
}
Shipment --* Wishlist
Coupon --o Order
@enduml