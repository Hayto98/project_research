@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
interface Nurse {
  #Date price
  +String status
  -int total
  #int quantity
  #long updatedAt
  +deleteDuration()
}
class Ward {
  +float price
  +boolean updatedAt
  #float phone
  -int description
  +calculateActive()
}
interface Treatment {
  #boolean code
  +float phone
  #boolean total
  #float address
  #Date active
  +updateCreatedat()
  +saveEmail()
  +saveDuration()
  +createName()
}
class Billing {
  -String name
  +String score
  +int active
  +int level
  +float note
  +cancelActive()
  +cancelUpdatedat()
}
interface Patient {
  +double total
  #boolean address
  +Date duration
  #float type
  +boolean quantity
  +saveTotal()
  +createScore()
  +deleteName()
  +setName()
}
class Doctor {
  #Date type
  +long name
  #boolean id
  -boolean level
  -long phone
  +validateCode()
}
Ward --|> Patient
Doctor --|> Ward
Billing ..|> Nurse
note right of Nurse : Healthcare domain
@enduml