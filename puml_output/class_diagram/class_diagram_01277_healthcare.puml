@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
interface Nurse {
  #Date price
  +String status
  -int total
  #int quantity
  #long updatedAt
  +calculateAddress()
}
interface Ward {
  -boolean duration
  +float email
  +findEmail()
  +validateCode()
  +processCreatedat()
}
class Treatment {
  +boolean level
  #float score
  +float email
  +getScore()
  +updateCreatedat()
  +createType()
  +findTotal()
}
interface Billing {
  #boolean code
  +float phone
  #boolean total
  #float address
  #Date active
  +deleteAddress()
  +calculateNote()
  +sendDuration()
  +calculateScore()
}
interface Patient {
  #boolean name
  #double description
  -String price
  +String duration
  +processDuration()
}
class Doctor {
  #int id
  #double createdAt
  -long active
  +cancelDuration()
  +validateLevel()
  +getActive()
  +getStatus()
}
Treatment --o Nurse
Patient --|> Doctor
Doctor ..|> Patient
Billing --* Doctor
@enduml