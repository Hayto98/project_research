@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Prescription {
  +float createdAt
  +float total
  +saveScore()
}
class Appointment {
  -long amount
  +String score
  -int phone
  +String type
  +int status
  +validateDescription()
}
class Treatment {
  #boolean duration
  #long quantity
  +String email
  -Date status
  +float type
  +saveUpdatedat()
  +deleteLevel()
}
class Ward {
  -String name
  #float note
  +sendNote()
  +processEmail()
  +deleteUpdatedat()
}
class Diagnosis {
  #float phone
  +boolean quantity
  +getActive()
}
class Insurance {
  +long score
  -double email
  +boolean note
  -int id
  +setActive()
  +saveEmail()
  +setStatus()
}
interface LabTest {
  +int duration
  -long quantity
  -double phone
  -int description
  +updateQuantity()
}
Insurance --* Diagnosis
Diagnosis ..> Ward : "1"
Prescription --> Insurance : "1..*"
Diagnosis --> LabTest : "1"
@enduml