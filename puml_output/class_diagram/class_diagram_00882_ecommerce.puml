@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Return {
  -long duration
  #boolean score
  +getDuration()
  +validateTotal()
  +getTotal()
  +deletePrice()
}
class Shipment {
  -boolean active
  +int amount
  -Date description
  -Date duration
  #String level
  +validateId()
}
abstract class Wishlist {
  #float phone
  #boolean status
  +createStatus()
}
abstract class Coupon {
  -float score
  +double quantity
  #int updatedAt
  +float name
  +Date price
  +createDuration()
  +cancelCode()
  +getAmount()
}
Wishlist ..> Shipment : "1"
Shipment ..|> Coupon
Coupon --* Wishlist
note right of Return : Ecommerce domain
@enduml