@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Return {
  -long duration
  #boolean score
  +updateQuantity()
  +setActive()
  +savePhone()
  +setPhone()
}
class Shipment {
  #float name
  -float total
  #float description
  +boolean price
  +Date createdAt
  +sendScore()
  +processId()
}
class Wishlist {
  +long address
  +double type
  +float id
  +validateEmail()
  +getCreatedat()
  +findEmail()
}
interface Coupon {
  #double quantity
  #Date status
  +saveLevel()
  +cancelPrice()
  +calculatePrice()
  +createQuantity()
}
Return --* Shipment
@enduml