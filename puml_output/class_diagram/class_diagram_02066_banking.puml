@startuml
skinparam shadowing true
class Beneficiary {
  +boolean code
  #long updatedAt
  -Date id
  -int level
  #String description
  +saveUpdatedat()
}
class Teller {
  #String score
  -float phone
  +Date price
  +saveName()
  +deleteNote()
  +createActive()
  +cancelScore()
}
class Withdrawal {
  -int quantity
  +int id
  +setTotal()
}
interface Card {
  +Date name
  -Date code
  #long type
  -long note
  +setTotal()
  +processStatus()
  +findName()
  +cancelLevel()
}
class Customer {
  +boolean address
  #boolean updatedAt
  +createTotal()
  +updateDescription()
}
Teller --* Customer
Customer --* Withdrawal
Customer --o Teller
@enduml