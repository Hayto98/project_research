@startuml
skinparam shadowing true
class Beneficiary {
  +boolean code
  #long updatedAt
  -Date id
  -int level
  #String description
  +saveName()
}
interface Teller {
  #String score
  -float phone
  +Date price
  +calculateName()
  +validateName()
  +setQuantity()
  +getPrice()
}
class Withdrawal {
  -boolean createdAt
  #long id
  +setDuration()
}
abstract class Card {
  -long createdAt
  -boolean address
  +String phone
  #Date score
  #long active
  +getActive()
  +saveScore()
}
class Customer {
  -float score
  +int description
  #boolean level
  +createLevel()
  +updateType()
  +createCreatedat()
}
Teller ..|> Customer
Customer --* Beneficiary
Teller --o Card
note right of Beneficiary : Banking domain
@enduml