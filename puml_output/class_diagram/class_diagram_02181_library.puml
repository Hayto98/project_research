@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Book {
  #long name
  -int type
  +Date price
  +float code
  -float updatedAt
  +processPhone()
  +savePrice()
}
class Publisher {
  -float amount
  +Date status
  -long code
  -boolean updatedAt
  +updateNote()
}
interface Librarian {
  #float price
  -String total
  -String quantity
  +deleteNote()
}
interface Member {
  #long level
  #double createdAt
  #int total
  +long name
  -float duration
  +updateType()
  +setCode()
  +validateDuration()
}
class Loan {
  #boolean active
  +long total
  #double quantity
  +saveDuration()
  +setPrice()
  +calculateScore()
  +getQuantity()
}
abstract class Branch {
  #long email
  +int score
  -Date total
  +Date code
  #int phone
  +findNote()
  +findTotal()
  +saveId()
  +validatePrice()
}
Loan ..|> Publisher
Publisher --> Member : "1"
@enduml