@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Book {
  #long name
  -int type
  +Date price
  +float code
  -float updatedAt
  +cancelId()
  +sendEmail()
}
class Publisher {
  +long code
  +Date level
  +validateTotal()
  +sendCode()
  +sendDuration()
}
class Librarian {
  +String total
  +float quantity
  #double phone
  #float code
  #int duration
  +getCreatedat()
  +findEmail()
  +cancelType()
  +saveCreatedat()
}
class Member {
  +int type
  #Date address
  -Date amount
  -Date level
  +validatePrice()
}
abstract class Loan {
  #boolean duration
  #boolean price
  -float level
  +Date email
  +sendQuantity()
  +deleteCreatedat()
  +calculateAmount()
}
interface Branch {
  #String type
  #int code
  +int name
  +sendName()
  +saveEmail()
  +deleteTotal()
  +calculateActive()
}
Librarian ..> Book : "*"
Publisher --|> Book
Member ..> Book : "0..1"
Member --o Publisher
note right of Book : Library domain
@enduml