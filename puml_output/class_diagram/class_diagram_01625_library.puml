@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Book {
  -float address
  +long id
  #long description
  +processActive()
  +cancelId()
  +saveActive()
}
class Loan {
  #float createdAt
  -int score
  #Date code
  +setAddress()
}
class Publisher {
  +float amount
  #String createdAt
  +double total
  +float status
  +validateTotal()
}
class Branch {
  +double phone
  +float status
  +Date note
  +findPrice()
  +calculateAmount()
  +updateName()
}
interface Member {
  +long level
  #double amount
  #boolean updatedAt
  +cancelActive()
  +findDescription()
}
Member --o Branch
Loan --|> Member
Book --> Member : "1"
@enduml