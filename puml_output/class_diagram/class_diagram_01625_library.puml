@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Book {
  -float address
  +long id
  #long description
  +updatePhone()
  +sendQuantity()
  +cancelAmount()
}
class Loan {
  #Date total
  #String description
  +validateAmount()
  +saveCreatedat()
}
abstract class Publisher {
  +double createdAt
  +float id
  +findEmail()
}
class Branch {
  +float status
  +Date note
  -boolean duration
  -String total
  +cancelAmount()
  +updateId()
}
class Member {
  -Date active
  +int description
  +String type
  +float duration
  #String note
  +processPhone()
  +updateDuration()
  +deleteEmail()
}
Book ..> Loan : "1..*"
Loan ..|> Member
Member --* Book
note right of Book : Library domain
@enduml