@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Shipment {
  +long score
  #boolean email
  +double note
  #int total
  -double updatedAt
  +sendUpdatedat()
  +calculateType()
  +createAmount()
  +saveScore()
}
class Tracking {
  -String name
  +int phone
  -long id
  +validateEmail()
  +calculateId()
}
class DeliveryNote {
  +String score
  +boolean createdAt
  +sendStatus()
  +deleteQuantity()
}
class Package {
  -String duration
  +Date description
  +double createdAt
  +processName()
  +findCode()
  +deleteActive()
  +processQuantity()
}
interface Route {
  -float updatedAt
  -int type
  +cancelAmount()
  +deleteCode()
}
DeliveryNote --|> Tracking
Route --o Tracking
@enduml