@startuml
skinparam ArrowColor #555555
class Appointment {
  +float type
  +String name
  -boolean status
  -boolean score
  +cancelPhone()
}
class Billing {
  -float type
  +int code
  +deleteName()
}
class Nurse {
  +float active
  -String type
  +boolean address
  +updateTotal()
  +findDuration()
  +deleteType()
}
class Hospital {
  +String name
  +float email
  +long total
  #boolean createdAt
  #boolean quantity
  +deleteUpdatedat()
  +calculateName()
  +cancelActive()
}
class Doctor {
  -boolean status
  #double id
  +long updatedAt
  +String type
  +findDescription()
  +cancelCode()
}
class Patient {
  -boolean active
  -long description
  +int status
  #long price
  -long address
  +saveStatus()
  +validateNote()
  +saveId()
  +deleteEmail()
}
class Insurance {
  -double score
  +double total
  -String duration
  +validateId()
  +calculateCode()
  +createPhone()
  +updateScore()
}
Appointment --> Patient : "0..1"
Doctor --o Nurse
Nurse ..> Hospital : "*"
Appointment ..> Hospital : "0..1"
Doctor ..|> Appointment
note right of Appointment : Healthcare domain
@enduml