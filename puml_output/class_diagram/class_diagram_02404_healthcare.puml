@startuml
skinparam ArrowColor #555555
class Appointment {
  +float type
  +String name
  -boolean status
  -boolean score
  +getQuantity()
}
class Billing {
  -float code
  +int type
  +int duration
  +cancelTotal()
}
interface Nurse {
  +float active
  -String type
  +boolean address
  +processActive()
  +setNote()
  +setCreatedat()
}
interface Hospital {
  #double type
  +boolean code
  -double active
  +findEmail()
  +getUpdatedat()
}
class Doctor {
  +long name
  #boolean status
  +updateAmount()
  +validateCode()
  +saveTotal()
}
class Patient {
  +int name
  -double active
  #Date id
  -String email
  -int status
  +processPrice()
}
class Insurance {
  -boolean name
  +String active
  +createStatus()
  +saveUpdatedat()
  +calculateUpdatedat()
  +sendAmount()
}
Insurance --> Nurse : "*"
Nurse ..|> Billing
Patient --o Nurse
Nurse --o Doctor
@enduml