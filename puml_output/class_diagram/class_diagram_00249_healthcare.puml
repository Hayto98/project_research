@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
abstract class Hospital {
  #String duration
  #int total
  -boolean note
  -float status
  +calculateType()
}
abstract class MedicalRecord {
  +boolean id
  +long note
  +createQuantity()
  +findPrice()
  +sendUpdatedat()
}
class Ward {
  #long type
  -boolean phone
  +setUpdatedat()
  +deleteId()
  +cancelType()
}
class Doctor {
  -double name
  #int level
  #double quantity
  +createAmount()
}
class Appointment {
  -String type
  -long createdAt
  +updateAddress()
}
Hospital --* Doctor
Hospital --* Ward
Doctor --o Ward
Appointment --o Hospital
@enduml