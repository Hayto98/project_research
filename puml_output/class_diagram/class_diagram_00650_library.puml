@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Fine {
  #long level
  +boolean note
  -Date id
  +double address
  #boolean email
  +sendPrice()
  +validateId()
  +calculateDescription()
  +processEmail()
}
abstract class Author {
  +int updatedAt
  #long name
  +int total
  +calculateCode()
}
class Branch {
  -float type
  #boolean duration
  +int createdAt
  +deleteStatus()
  +createPrice()
  +processScore()
}
class Reservation {
  -boolean updatedAt
  #Date status
  #Date address
  +cancelPhone()
  +cancelNote()
  +sendPhone()
}
class Renewal {
  #double score
  #int type
  -boolean note
  #boolean id
  +sendPrice()
}
Reservation --o Author
Branch --* Fine
note right of Fine : Library domain
@enduml