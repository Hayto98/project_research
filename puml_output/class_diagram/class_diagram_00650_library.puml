@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Fine {
  #long level
  +boolean note
  -Date id
  +double address
  #boolean email
  +calculateTotal()
  +getCreatedat()
  +calculateCode()
  +sendPhone()
}
class Author {
  +String description
  -float type
  +int email
  #long price
  +int updatedAt
  +updateCode()
}
abstract class Branch {
  -Date description
  -int updatedAt
  +calculateType()
  +savePrice()
  +calculatePrice()
  +saveNote()
}
class Reservation {
  -boolean amount
  #Date status
  #long quantity
  +int price
  +validateDuration()
}
abstract class Renewal {
  +long duration
  #Date phone
  -double note
  +boolean level
  +getQuantity()
  +processActive()
  +saveName()
  +getCreatedat()
}
Renewal --> Fine : "*"
Fine ..|> Reservation
Reservation --> Branch : "1"
Branch ..|> Author
@enduml