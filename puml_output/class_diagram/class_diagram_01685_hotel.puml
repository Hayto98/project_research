@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
abstract class Payment {
  +int level
  +boolean score
  +setNote()
  +sendActive()
  +sendAmount()
}
class Amenity {
  -int quantity
  +long note
  +saveCode()
  +deletePhone()
  +calculateId()
}
class Housekeeping {
  #double duration
  -double note
  +boolean updatedAt
  -Date level
  #boolean createdAt
  +sendName()
  +processQuantity()
  +setPhone()
  +updateActive()
}
class Staff {
  +float status
  -String type
  #String score
  -float phone
  +validateTotal()
  +setCreatedat()
}
interface Booking {
  #boolean createdAt
  #float name
  +saveAmount()
  +createName()
  +processUpdatedat()
  +processCode()
}
class Guest {
  -int amount
  -long type
  +String updatedAt
  +float note
  +savePrice()
  +calculateStatus()
  +updateNote()
}
Staff --|> Booking
Staff --* Payment
Guest --|> Booking
note right of Payment : Hotel domain
@enduml