@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
abstract class Payment {
  +int level
  +boolean score
  +deleteQuantity()
  +deleteDuration()
  +cancelAmount()
}
interface Amenity {
  -double createdAt
  +int name
  -boolean quantity
  +calculateTotal()
  +sendPrice()
  +setDescription()
}
class Housekeeping {
  #boolean total
  #double id
  +float code
  -int note
  +updateLevel()
  +cancelCode()
  +setType()
  +sendAmount()
}
abstract class Staff {
  -int score
  #int name
  -String type
  -Date quantity
  #boolean status
  +calculateAddress()
  +saveType()
  +sendStatus()
}
abstract class Booking {
  -float active
  +long name
  +validateEmail()
  +getTotal()
  +getScore()
  +calculateActive()
}
class Guest {
  #float name
  #int active
  -Date note
  +deleteTotal()
}
Amenity --|> Staff
Payment --* Booking
Amenity --o Booking
Staff --o Amenity
@enduml