@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Staff {
  -long quantity
  -long level
  +double note
  +getTotal()
  +processAmount()
  +getCode()
}
abstract class CheckIn {
  +long type
  +float status
  -float score
  +int email
  #double updatedAt
  +getLevel()
  +deleteTotal()
}
abstract class Restaurant {
  #Date address
  +boolean email
  -double phone
  +updateAddress()
  +findDuration()
  +setDuration()
}
class Amenity {
  -Date duration
  #float level
  -int quantity
  +saveScore()
  +updateStatus()
  +processActive()
}
Restaurant --o CheckIn
Staff ..|> Restaurant
Staff --|> Amenity
note right of Staff : Hotel domain
@enduml