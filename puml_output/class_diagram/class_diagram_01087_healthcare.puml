@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class MedicalRecord {
  #long status
  #Date price
  +findQuantity()
  +createPrice()
  +saveDuration()
  +cancelPhone()
}
class Nurse {
  +float active
  -Date description
  +float id
  +findPhone()
  +savePhone()
  +validateTotal()
  +getAmount()
}
interface Diagnosis {
  -boolean address
  -long type
  #Date email
  +double note
  +calculateEmail()
  +getStatus()
}
interface Patient {
  +boolean duration
  +double note
  +saveAddress()
  +findType()
  +processDuration()
}
class Hospital {
  +long active
  +String status
  +processUpdatedat()
  +sendUpdatedat()
  +sendEmail()
}
Nurse ..> Diagnosis : "0..1"
Nurse --> Hospital : "0..1"
@enduml