@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Category {
  +double type
  +long amount
  #boolean description
  +processNote()
}
class Invoice {
  #float createdAt
  +int level
  +processCreatedat()
  +cancelTotal()
}
class Return {
  +long address
  #long score
  +sendType()
  +getDuration()
  +createTotal()
  +updateAddress()
}
class Shipment {
  #long description
  +long amount
  #Date type
  -float createdAt
  +processPrice()
}
Category --> Shipment : "1..*"
Shipment ..|> Return
note right of Category : Ecommerce domain
@enduml