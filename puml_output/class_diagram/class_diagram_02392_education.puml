@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Exam {
  #boolean price
  -boolean quantity
  -String active
  -Date amount
  #double duration
  +calculateEmail()
}
interface Schedule {
  #String amount
  +String status
  +cancelTotal()
  +getAmount()
  +calculateNote()
  +deletePhone()
}
class Department {
  -long phone
  -int createdAt
  -long quantity
  #boolean amount
  +getDuration()
}
abstract class Book {
  +float score
  #float quantity
  +createQuantity()
}
Department --o Book
Department ..> Schedule : "*"
note right of Exam : Education domain
@enduml