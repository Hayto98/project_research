@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
abstract class Group {
  -String type
  #boolean createdAt
  +saveEmail()
  +calculateEmail()
  +processDescription()
  +findNote()
}
class Story {
  #float total
  #Date createdAt
  +validatePhone()
}
interface Report {
  -int active
  -int id
  +Date email
  +setQuantity()
  +deleteUpdatedat()
  +getActive()
}
abstract class Profile {
  +String status
  +float description
  +findNote()
  +cancelPhone()
  +saveId()
}
class Hashtag {
  +Date note
  +double description
  -boolean updatedAt
  #long address
  +saveStatus()
  +sendPrice()
  +findLevel()
}
class Post {
  #boolean id
  +long total
  -double amount
  +validateName()
  +sendId()
  +saveActive()
  +setDuration()
}
Group --o Post
Report --> Post : "1"
Report --* Profile
Profile --|> Report
@enduml