@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
abstract class Group {
  -String type
  #boolean createdAt
  +getName()
  +createCode()
  +updateStatus()
  +calculateCreatedat()
}
interface Story {
  +boolean code
  +long score
  +updateTotal()
  +updateCode()
  +findEmail()
  +cancelNote()
}
class Report {
  +String description
  -String amount
  +createName()
}
class Profile {
  +Date note
  +double description
  -boolean updatedAt
  #long address
  +saveStatus()
  +deleteId()
  +calculateAmount()
}
interface Hashtag {
  -double email
  -int address
  +getName()
  +processPhone()
  +validateDuration()
  +setQuantity()
}
abstract class Post {
  +float phone
  #int type
  -String price
  -double address
  +createScore()
  +processCode()
  +sendEmail()
  +sendQuantity()
}
Report --> Post : "1"
Post --* Hashtag
note right of Group : Social Media domain
@enduml