@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Department {
  -boolean address
  -double amount
  -Date duration
  +long phone
  -float note
  +validateAddress()
  +setNote()
}
class Teacher {
  -String amount
  -float price
  #boolean quantity
  -long level
  -int type
  +cancelScore()
  +sendNote()
}
interface Assignment {
  +boolean duration
  +float note
  +saveCreatedat()
  +sendCreatedat()
  +processCode()
  +sendId()
}
class Classroom {
  -String createdAt
  #long type
  -float status
  +Date active
  +saveNote()
  +validateActive()
  +createDescription()
  +getDescription()
}
class Exam {
  #int quantity
  #int note
  +validatePrice()
}
Teacher --> Assignment : "1"
Assignment ..|> Department
Classroom ..> Department : "0..1"
note right of Department : Education domain
@enduml