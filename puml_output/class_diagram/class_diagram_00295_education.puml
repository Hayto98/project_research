@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Department {
  -boolean address
  -double amount
  -Date duration
  +long phone
  -float note
  +validateLevel()
  +findCode()
}
class Teacher {
  #double note
  +double code
  +createDuration()
  +sendName()
  +getAddress()
}
class Assignment {
  +int duration
  #boolean quantity
  #double email
  #String type
  +setLevel()
  +getScore()
  +deleteQuantity()
  +saveLevel()
}
abstract class Classroom {
  +boolean active
  +long createdAt
  #Date note
  +sendId()
  +deleteActive()
  +getAmount()
}
class Exam {
  +Date name
  #Date active
  -Date email
  -long note
  +validateCode()
  +updateActive()
  +setLevel()
}
Department ..> Assignment : "*"
Teacher --|> Exam
@enduml