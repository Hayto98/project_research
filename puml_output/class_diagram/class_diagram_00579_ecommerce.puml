@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
interface Wishlist {
  -int description
  #String name
  #boolean updatedAt
  -double id
  #Date phone
  +sendCode()
  +createPrice()
}
class Order {
  #String total
  #long price
  +boolean id
  +processPrice()
  +updateUpdatedat()
  +processPrice()
  +saveScore()
}
abstract class Coupon {
  #String updatedAt
  +int createdAt
  +validatePrice()
  +saveEmail()
  +setCode()
  +updateAddress()
}
abstract class Supplier {
  #boolean note
  +Date total
  -float level
  +long active
  +calculateDescription()
}
Coupon ..> Supplier : "0..1"
Wishlist ..> Coupon : "*"
note right of Wishlist : Ecommerce domain
@enduml