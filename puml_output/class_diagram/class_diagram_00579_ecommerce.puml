@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
interface Wishlist {
  -int description
  #String name
  #boolean updatedAt
  -double id
  #Date phone
  +createUpdatedat()
  +sendStatus()
}
class Order {
  -boolean price
  +Date amount
  +Date level
  -String total
  +saveType()
  +sendCode()
  +setScore()
  +processType()
}
class Coupon {
  -float type
  +int price
  +Date score
  +saveType()
}
class Supplier {
  #long total
  +String address
  +long price
  +createAmount()
  +processPhone()
  +processTotal()
  +cancelCreatedat()
}
Order --* Coupon
Order ..> Supplier : "1"
Supplier --|> Wishlist
@enduml