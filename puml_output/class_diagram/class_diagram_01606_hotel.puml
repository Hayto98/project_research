@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Service {
  -boolean duration
  +long price
  -Date phone
  +int code
  +getNote()
  +deleteCreatedat()
  +validateScore()
  +deleteAddress()
}
abstract class CheckIn {
  -float duration
  #int name
  -double score
  #Date total
  #double description
  +processPhone()
  +deletePrice()
  +saveId()
}
class Guest {
  +boolean duration
  +double createdAt
  +boolean address
  -Date price
  +validateUpdatedat()
  +getQuantity()
  +createActive()
}
class Room {
  +long status
  -String address
  +double phone
  +String createdAt
  +deleteScore()
  +saveAddress()
}
class Reservation {
  #boolean createdAt
  +String address
  -long phone
  -int price
  +setStatus()
  +updateNote()
  +savePrice()
}
class Restaurant {
  +String phone
  +long description
  #boolean level
  +deletePhone()
  +updateEmail()
  +cancelPrice()
  +updateAddress()
}
Room --> Reservation : "1..*"
Guest ..> Restaurant : "1"
CheckIn --o Guest
Service --|> Restaurant
@enduml