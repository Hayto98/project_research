@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Treatment {
  +float createdAt
  -float address
  #double price
  -Date quantity
  +cancelPrice()
  +createStatus()
  +processNote()
}
class LabTest {
  +boolean phone
  -long price
  +calculateQuantity()
  +sendCode()
  +saveTotal()
  +createName()
}
class Diagnosis {
  +Date updatedAt
  +Date address
  #long status
  +float phone
  -long duration
  +validateCreatedat()
  +cancelActive()
  +validateId()
}
class Prescription {
  -String level
  -String email
  -long type
  #Date price
  +validateAddress()
  +cancelType()
  +savePrice()
}
class Appointment {
  #int score
  +double description
  +boolean active
  -String amount
  +getTotal()
  +deleteEmail()
}
Appointment --* Treatment
Prescription --> Diagnosis : "0..1"
@enduml