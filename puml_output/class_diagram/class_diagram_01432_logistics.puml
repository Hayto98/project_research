@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Manifest {
  #int id
  #float level
  +sendQuantity()
  +findQuantity()
}
class Shipment {
  +String updatedAt
  +double score
  #int price
  +int createdAt
  +cancelType()
  +processPrice()
  +findLevel()
}
class DeliveryNote {
  -boolean total
  -double level
  -long name
  #Date note
  +getPhone()
}
class Warehouse {
  #boolean createdAt
  +long email
  +boolean total
  -float quantity
  #double phone
  +saveLevel()
  +calculateActive()
}
abstract class FuelLog {
  -float address
  #float duration
  +sendDuration()
  +processDescription()
}
class Route {
  #long duration
  -long code
  #String phone
  -boolean type
  +long id
  +processScore()
  +sendDescription()
  +getTotal()
}
class Customer {
  +String score
  +long email
  #float note
  +float quantity
  -float level
  +processEmail()
  +sendPrice()
  +updateName()
}
Manifest --* FuelLog
Shipment --> Route : "1"
Route --* Manifest
Route --o Customer
FuelLog ..|> Route
@enduml