@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Manifest {
  #int id
  #float level
  +sendAddress()
  +setLevel()
}
interface Shipment {
  +String updatedAt
  +double score
  #int price
  +int createdAt
  +updateUpdatedat()
  +findQuantity()
  +calculateLevel()
}
class DeliveryNote {
  -boolean note
  #float active
  +double phone
  +float price
  #Date total
  +updateEmail()
  +cancelTotal()
  +sendQuantity()
  +savePhone()
}
interface Warehouse {
  #double address
  +float status
  #double total
  +saveAddress()
}
interface FuelLog {
  #float phone
  -boolean description
  +boolean quantity
  -double id
  +sendEmail()
}
abstract class Route {
  -boolean score
  -float code
  +String total
  -boolean level
  +processDuration()
  +createEmail()
  +deleteCode()
}
class Customer {
  #Date duration
  +double updatedAt
  +boolean total
  -int address
  +findStatus()
}
Route --o Customer
FuelLog ..|> Route
Customer ..|> Shipment
note right of Manifest : Logistics domain
@enduml