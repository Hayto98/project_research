@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
abstract class Guest {
  +Date address
  -float total
  +getName()
  +validateQuantity()
  +getId()
  +processCreatedat()
}
class Amenity {
  +float status
  -int total
  #Date quantity
  +cancelPhone()
}
class Booking {
  #double address
  -Date code
  +setDescription()
  +findNote()
  +sendName()
}
class Payment {
  #String name
  +String status
  #String description
  #int id
  +findDuration()
  +sendQuantity()
}
abstract class Restaurant {
  +String updatedAt
  +int score
  +setScore()
}
Restaurant --> Amenity : "0..1"
Restaurant ..> Guest : "1"
Guest --o Restaurant
note right of Guest : Hotel domain
@enduml