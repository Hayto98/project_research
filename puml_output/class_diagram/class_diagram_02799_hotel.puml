@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
abstract class Guest {
  +Date address
  -float total
  +saveId()
  +calculateId()
  +getDescription()
  +createActive()
}
class Amenity {
  +int id
  +float note
  +findAmount()
}
class Booking {
  #long note
  #long updatedAt
  +Date id
  +validatePhone()
  +updateScore()
  +processTotal()
}
class Payment {
  #Date status
  -long description
  +float note
  +int name
  +updateAddress()
}
class Restaurant {
  +Date name
  +Date code
  #boolean active
  +cancelQuantity()
  +updatePrice()
  +validateLevel()
}
Restaurant --|> Amenity
Amenity ..> Restaurant : "1"
@enduml