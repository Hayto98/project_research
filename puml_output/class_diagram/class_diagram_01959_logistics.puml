@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Vehicle {
  #String quantity
  +boolean id
  +processDuration()
  +deleteTotal()
  +processActive()
  +calculatePhone()
}
class Driver {
  -long price
  -long status
  +Date active
  +boolean quantity
  +boolean name
  +setPhone()
  +saveName()
}
interface Warehouse {
  +String address
  -String name
  +cancelQuantity()
  +calculateId()
  +saveQuantity()
}
abstract class FuelLog {
  -String updatedAt
  +String email
  -boolean score
  +Date active
  #boolean status
  +deleteScore()
  +cancelAmount()
  +getAddress()
}
class Route {
  #Date price
  #String type
  +deleteType()
  +calculateDuration()
  +cancelDescription()
  +getType()
}
class DeliveryNote {
  -Date createdAt
  +float address
  +boolean status
  -String email
  +createPrice()
  +createAddress()
  +deleteAmount()
}
Route --o Vehicle
FuelLog --> Route : "1..*"
@enduml