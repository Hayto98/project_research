@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Vehicle {
  #String quantity
  +boolean id
  +updateCreatedat()
  +createCreatedat()
  +cancelLevel()
  +calculatePrice()
}
class Driver {
  -long score
  +Date name
  +boolean email
  +boolean phone
  +cancelPrice()
  +sendCode()
}
class Warehouse {
  -String name
  #long code
  +getDescription()
  +calculateLevel()
  +calculateUpdatedat()
  +createScore()
}
interface FuelLog {
  +String type
  -boolean status
  +findScore()
}
class Route {
  +double score
  -boolean total
  #float phone
  +sendNote()
}
interface DeliveryNote {
  +long code
  #float email
  +createNote()
}
Driver --* Route
Vehicle --o Warehouse
Vehicle --> FuelLog : "1"
note right of Vehicle : Logistics domain
@enduml