@startuml
skinparam monochrome true
skinparam defaultFontSize 13
abstract class Manifest {
  #double name
  +String price
  +Date note
  +boolean email
  #long duration
  +getQuantity()
  +updateNote()
  +sendEmail()
  +processNote()
}
class Package {
  +Date email
  +long total
  -boolean note
  +String updatedAt
  +float price
  +cancelTotal()
  +findUpdatedat()
}
class Warehouse {
  +Date score
  +int amount
  +setTotal()
  +findId()
}
class FuelLog {
  -int level
  #double score
  +createDescription()
  +validateActive()
  +getDescription()
}
class Tracking {
  +String note
  #Date email
  +long score
  +int description
  -int status
  +deletePrice()
  +validateCreatedat()
  +calculateActive()
}
interface Route {
  #int active
  +int name
  -Date level
  -double code
  -boolean type
  +calculatePhone()
  +setQuantity()
  +deleteActive()
}
Manifest --o Route
Tracking ..|> Manifest
note right of Manifest : Logistics domain
@enduml