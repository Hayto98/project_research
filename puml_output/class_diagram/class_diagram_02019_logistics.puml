@startuml
skinparam monochrome true
skinparam defaultFontSize 13
abstract class Manifest {
  #double name
  +String price
  +Date note
  +boolean email
  #long duration
  +saveEmail()
  +deleteEmail()
  +createQuantity()
  +saveTotal()
}
class Package {
  -long score
  -double email
  #int note
  -String duration
  #String code
  +cancelCode()
  +sendAmount()
  +calculateNote()
}
class Warehouse {
  #Date description
  +Date total
  +sendPrice()
  +createTotal()
}
interface FuelLog {
  +Date score
  +int amount
  +getLevel()
  +getPhone()
}
class Tracking {
  -int status
  #double level
  -long score
  +deleteCode()
  +findDuration()
}
class Route {
  -boolean email
  +boolean type
  #boolean note
  +updateUpdatedat()
}
Tracking --* Manifest
Manifest --o Package
@enduml