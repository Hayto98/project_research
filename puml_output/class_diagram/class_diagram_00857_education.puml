@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
interface Schedule {
  +double note
  #float updatedAt
  -boolean quantity
  -float total
  +sendQuantity()
  +deleteStatus()
  +createScore()
  +setEmail()
}
class Attendance {
  +double duration
  -double level
  +validateDuration()
  +saveAmount()
}
class Library {
  +String active
  +int price
  +createCreatedat()
  +cancelAddress()
  +createLevel()
  +createActive()
}
class Book {
  +float score
  +String type
  #Date note
  +sendActive()
}
Attendance --|> Schedule
Book --> Attendance : "1"
Attendance --> Library : "*"
@enduml