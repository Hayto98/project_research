@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
interface Schedule {
  +double note
  #float updatedAt
  -boolean quantity
  -float total
  +sendUpdatedat()
  +validateQuantity()
  +setDuration()
  +cancelCreatedat()
}
abstract class Attendance {
  #Date price
  #String createdAt
  #boolean address
  -String note
  +int quantity
  +calculateDescription()
  +createAddress()
}
class Library {
  +float score
  +String type
  #Date note
  +cancelType()
}
class Book {
  -float id
  #String type
  +findLevel()
  +processEmail()
}
Schedule ..> Attendance : "1..*"
Schedule --o Library
Book ..> Schedule : "*"
note right of Schedule : Education domain
@enduml