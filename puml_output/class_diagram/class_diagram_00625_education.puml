@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
abstract class Library {
  #boolean active
  -long duration
  +calculateTotal()
  +cancelName()
  +calculateActive()
}
abstract class Teacher {
  +long email
  -String active
  #boolean updatedAt
  #float level
  +sendUpdatedat()
  +findCreatedat()
  +validateAmount()
}
class Department {
  #String updatedAt
  -String level
  +double score
  +getUpdatedat()
  +deleteName()
  +getNote()
}
class Course {
  -float description
  #double phone
  #int quantity
  #long name
  +sendType()
}
interface Grade {
  -boolean price
  #long level
  #boolean score
  +updateTotal()
  +saveAmount()
}
Teacher --o Course
Teacher --|> Department
Library --|> Course
note right of Library : Education domain
@enduml