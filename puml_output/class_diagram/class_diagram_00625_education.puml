@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
abstract class Library {
  #boolean active
  -long duration
  +deleteAmount()
  +findTotal()
  +getAddress()
}
interface Teacher {
  -long price
  -boolean active
  +calculateActive()
  +updateQuantity()
}
class Department {
  #Date price
  +Date id
  +long score
  +String phone
  +processPrice()
  +saveDuration()
}
interface Course {
  +double total
  #long status
  +createScore()
}
class Grade {
  +long name
  +long note
  +deleteNote()
  +calculateQuantity()
  +calculateType()
}
Course ..> Teacher : "1..*"
Library --> Course : "0..1"
Course --> Department : "1..*"
Grade ..|> Teacher
@enduml