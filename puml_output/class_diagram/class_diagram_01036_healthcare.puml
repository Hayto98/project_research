@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Patient {
  #int total
  #Date duration
  -Date email
  +createTotal()
  +processCode()
  +createQuantity()
}
class Doctor {
  -double level
  +float address
  +int id
  -double description
  +processUpdatedat()
  +processPhone()
  +updateActive()
  +createCode()
}
interface Ward {
  -Date price
  -float description
  +Date type
  +String updatedAt
  +double id
  +sendTotal()
}
class Appointment {
  #float amount
  -boolean duration
  -boolean email
  -Date status
  +setUpdatedat()
  +getUpdatedat()
}
abstract class Prescription {
  +long score
  #boolean price
  +updateScore()
  +cancelPrice()
  +calculateScore()
  +saveCreatedat()
}
class Billing {
  -Date address
  -long code
  +calculatePhone()
  +findId()
  +setName()
  +sendUpdatedat()
}
Doctor --|> Patient
Ward --> Patient : "1"
Prescription --* Patient
Prescription --> Ward : "1..*"
Prescription --o Billing
note right of Patient : Healthcare domain
@enduml