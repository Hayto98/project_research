@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Patient {
  #int total
  #Date duration
  -Date email
  +findCreatedat()
  +findAmount()
  +validateUpdatedat()
}
class Doctor {
  #String quantity
  #Date code
  +long phone
  -int address
  +updateType()
  +setNote()
}
abstract class Ward {
  #boolean type
  -String updatedAt
  #double duration
  -int phone
  -Date createdAt
  +processCode()
  +sendAddress()
}
class Appointment {
  -float amount
  +boolean code
  -long duration
  +processUpdatedat()
  +deleteName()
  +validateId()
}
interface Prescription {
  +int level
  +int total
  -Date score
  +float price
  #double description
  +createAmount()
}
interface Billing {
  -String updatedAt
  -String score
  -Date price
  -long level
  -float createdAt
  +cancelId()
  +deleteEmail()
  +sendUpdatedat()
  +cancelTotal()
}
Patient ..|> Prescription
Appointment --|> Doctor
@enduml