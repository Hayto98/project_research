@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Warehouse {
  -Date updatedAt
  #double total
  +long note
  +createTotal()
}
class Manifest {
  -long score
  #double price
  +calculateId()
  +saveStatus()
}
abstract class Vehicle {
  -float total
  +double phone
  -String level
  +deleteType()
  +saveDescription()
  +setDuration()
}
class Tracking {
  -boolean phone
  +int createdAt
  +int type
  -boolean updatedAt
  +findPrice()
}
abstract class Customer {
  +int total
  -Date name
  +findQuantity()
}
abstract class DeliveryNote {
  -boolean level
  +float total
  +sendAmount()
}
Customer --> Manifest : "*"
Tracking --* DeliveryNote
@enduml