@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Warehouse {
  -Date updatedAt
  #double total
  +long note
  +findAddress()
}
interface Manifest {
  -long score
  #double price
  +getType()
  +sendDescription()
}
abstract class Vehicle {
  -String phone
  -Date address
  #int code
  #long total
  +updateType()
  +saveUpdatedat()
  +processActive()
}
class Tracking {
  #String status
  #double updatedAt
  +double quantity
  +setCreatedat()
}
abstract class Customer {
  #String address
  #boolean total
  +validateScore()
  +updateActive()
  +setScore()
  +setLevel()
}
class DeliveryNote {
  #boolean type
  +String duration
  -float phone
  -Date description
  -String active
  +savePhone()
  +sendName()
}
Tracking ..|> DeliveryNote
Vehicle --* Tracking
Vehicle --* Warehouse
note right of Warehouse : Logistics domain
@enduml