@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Book {
  #float id
  #String status
  -double price
  #boolean description
  +boolean code
  +cancelCreatedat()
  +createEmail()
  +cancelScore()
  +getPhone()
}
class Loan {
  #Date type
  +float total
  +long id
  -long duration
  +String amount
  +calculateAmount()
  +createName()
  +cancelCode()
}
class Branch {
  -int phone
  #String updatedAt
  #String email
  -String status
  #double active
  +createCode()
  +findDescription()
}
class Reservation {
  +Date duration
  #int quantity
  -String id
  -int updatedAt
  -boolean email
  +createCode()
  +getCreatedat()
  +createUpdatedat()
  +saveId()
}
Book ..> Loan : "*"
Branch --> Book : "0..1"
@enduml