@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Book {
  #float id
  #String status
  -double price
  #boolean description
  +boolean code
  +calculateTotal()
  +deleteType()
  +processTotal()
  +cancelId()
}
abstract class Loan {
  -double duration
  -String updatedAt
  +float code
  +processNote()
  +processDescription()
  +calculatePhone()
}
class Branch {
  +boolean level
  +boolean status
  +double duration
  +boolean note
  +updateAmount()
  +cancelStatus()
  +sendPrice()
  +cancelQuantity()
}
class Reservation {
  -String email
  -int name
  -boolean createdAt
  +deleteScore()
  +sendName()
  +findDescription()
  +sendCode()
}
Reservation --* Branch
Book ..|> Branch
Branch ..|> Reservation
note right of Book : Library domain
@enduml