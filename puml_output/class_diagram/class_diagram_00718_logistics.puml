@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Inventory {
  #String total
  +boolean type
  +cancelScore()
  +updateStatus()
  +updatePrice()
}
class Package {
  -String quantity
  #Date price
  +Date description
  +processTotal()
}
class Manifest {
  +float phone
  +Date address
  -float email
  +long score
  +updateScore()
}
interface Route {
  +String address
  +long name
  +sendQuantity()
}
abstract class Shipment {
  #int id
  -long createdAt
  +saveName()
  +processScore()
}
Shipment ..|> Inventory
Manifest --|> Inventory
Inventory --|> Package
@enduml