@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Inventory {
  #String total
  +boolean type
  +saveUpdatedat()
  +getEmail()
  +updateQuantity()
}
abstract class Package {
  #String email
  #String status
  -int score
  +validateAddress()
  +createEmail()
  +updateName()
}
class Manifest {
  -String quantity
  +String id
  +long level
  +sendNote()
}
class Route {
  +double createdAt
  -Date score
  +calculatePrice()
  +findLevel()
}
class Shipment {
  +float quantity
  +int score
  +long status
  +saveQuantity()
  +findQuantity()
  +updateCreatedat()
}
Shipment --* Inventory
Package --o Shipment
note right of Inventory : Logistics domain
@enduml