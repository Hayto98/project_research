@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
abstract class Book {
  -long description
  +int total
  +cancelName()
  +deleteName()
  +saveCode()
}
abstract class Exam {
  -long updatedAt
  -boolean type
  +deleteQuantity()
  +createDescription()
  +calculatePhone()
  +updateEmail()
}
abstract class Department {
  -Date quantity
  #boolean status
  -long duration
  +Date phone
  #boolean level
  +findAmount()
  +validateQuantity()
  +deleteScore()
  +deleteAddress()
}
class Student {
  #double phone
  #boolean email
  -Date level
  +boolean name
  +getUpdatedat()
}
class Attendance {
  -double address
  -float status
  +String updatedAt
  -Date active
  #int price
  +createLevel()
}
class Course {
  #boolean address
  -float phone
  +boolean updatedAt
  +String score
  +createCode()
  +validateId()
  +cancelDescription()
  +createAddress()
}
Book ..> Exam : "0..1"
Exam --|> Department
@enduml