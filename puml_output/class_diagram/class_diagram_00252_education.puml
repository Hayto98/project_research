@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
abstract class Book {
  -long description
  +int total
  +findEmail()
  +calculatePrice()
  +cancelId()
}
class Exam {
  +boolean phone
  -double quantity
  #double address
  #double active
  -String price
  +validateStatus()
  +createActive()
  +processAddress()
}
class Department {
  -long total
  -long amount
  #Date level
  +boolean updatedAt
  -Date email
  +findAmount()
  +cancelScore()
  +getDescription()
  +processAddress()
}
class Student {
  -long active
  +String price
  -Date email
  +getEmail()
  +createAddress()
}
class Attendance {
  +boolean updatedAt
  +String active
  -int note
  +findCode()
}
class Course {
  +long description
  +boolean createdAt
  +createPhone()
}
Department --o Book
Attendance --* Book
note right of Book : Education domain
@enduml