@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
abstract class LabTest {
  -Date amount
  +double score
  +int updatedAt
  +sendDuration()
  +validateAmount()
  +createDuration()
  +validateDuration()
}
class Billing {
  +int note
  +float id
  +double duration
  -float amount
  -double price
  +createDuration()
  +setQuantity()
}
class Insurance {
  +int score
  -float type
  #long name
  +createActive()
}
class Patient {
  +boolean createdAt
  #Date name
  -Date price
  -String type
  -boolean score
  +findNote()
}
Billing --* Patient
LabTest --* Billing
@enduml