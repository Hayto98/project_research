@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
abstract class LabTest {
  -Date amount
  +double score
  +int updatedAt
  +saveEmail()
  +calculateAddress()
  +validateTotal()
  +processId()
}
abstract class Billing {
  +float price
  +double id
  -float description
  +processDescription()
  +calculateStatus()
  +deleteScore()
}
interface Insurance {
  +long name
  +double createdAt
  +String updatedAt
  -double price
  -String phone
  +savePhone()
  +setPhone()
  +sendCode()
}
class Patient {
  +float score
  -long active
  +calculateEmail()
}
Billing --> LabTest : "*"
note right of LabTest : Healthcare domain
@enduml