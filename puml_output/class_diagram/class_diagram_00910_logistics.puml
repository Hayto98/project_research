@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Tracking {
  #String description
  -float name
  +Date createdAt
  #Date price
  #int quantity
  +updatePrice()
}
abstract class Manifest {
  +long note
  #boolean duration
  -float updatedAt
  +saveName()
  +cancelCreatedat()
  +processEmail()
  +cancelDescription()
}
class DeliveryNote {
  #double amount
  -double duration
  #boolean total
  #String score
  +validateDescription()
  +setAmount()
  +updateTotal()
}
interface Depot {
  #int code
  #float total
  -int email
  #long createdAt
  -Date score
  +cancelTotal()
  +createPrice()
}
Depot ..> Tracking : "*"
DeliveryNote --> Depot : "0..1"
@enduml