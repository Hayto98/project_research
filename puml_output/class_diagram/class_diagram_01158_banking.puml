@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Account {
  #int name
  -boolean updatedAt
  +sendCreatedat()
  +setDescription()
  +updateDuration()
  +validateActive()
}
class Transfer {
  -boolean phone
  -Date total
  #Date code
  -boolean type
  +updateActive()
  +createDescription()
  +deleteQuantity()
  +deleteCode()
}
abstract class Card {
  +int code
  +Date createdAt
  +updateQuantity()
}
class Statement {
  #Date duration
  -float code
  +saveNote()
  +updateScore()
  +processType()
  +cancelPhone()
}
class Transaction {
  #String price
  -float active
  +Date updatedAt
  +createId()
  +processPhone()
}
Transfer --o Account
Card --> Transaction : "1..*"
@enduml