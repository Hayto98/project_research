@startuml
skinparam defaultFontSize 11
class Restaurant {
  -long createdAt
  -String total
  +int level
  +cancelAddress()
}
abstract class Service {
  +int email
  +long level
  -int note
  -double code
  #float id
  +calculateActive()
}
class Amenity {
  #double updatedAt
  +long duration
  +boolean email
  +cancelAddress()
}
class Payment {
  #boolean phone
  #String name
  +int amount
  +boolean email
  -double quantity
  +sendName()
}
class CheckIn {
  #float amount
  -Date note
  +deleteType()
}
class Reservation {
  #long quantity
  +double level
  #float address
  -long createdAt
  #int description
  +processActive()
}
Reservation ..|> CheckIn
Restaurant --* Payment
Service --> CheckIn : "1..*"
CheckIn --o Payment
@enduml