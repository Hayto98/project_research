@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Reservation {
  #Date amount
  +float createdAt
  +int quantity
  +long duration
  +double address
  +validateCreatedat()
  +updateNote()
  +deletePrice()
}
class CheckIn {
  -Date duration
  #String total
  #Date phone
  -long quantity
  +findType()
}
class Room {
  +double amount
  #String email
  #Date note
  #int type
  +updatePrice()
  +setDuration()
}
class Booking {
  -int createdAt
  #Date score
  -boolean name
  +double total
  +createCode()
  +deleteAmount()
  +findLevel()
  +cancelTotal()
}
class Amenity {
  #double description
  -int status
  -int note
  +processStatus()
  +updateActive()
  +setCreatedat()
}
class Payment {
  -double active
  +boolean description
  #double updatedAt
  #boolean createdAt
  +processQuantity()
  +updateDuration()
  +saveAddress()
  +sendLevel()
}
CheckIn ..> Amenity : "1..*"
CheckIn ..|> Room
@enduml