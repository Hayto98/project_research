@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
interface Order {
  -int active
  #boolean amount
  #int code
  +cancelId()
}
abstract class Cart {
  -String phone
  -long createdAt
  +sendPrice()
  +processAddress()
  +saveDescription()
}
interface Review {
  #String address
  +int code
  -Date quantity
  #String type
  +cancelStatus()
  +cancelUpdatedat()
  +deleteDuration()
}
class Wishlist {
  +boolean quantity
  +Date status
  +boolean name
  #int phone
  +processUpdatedat()
}
class Invoice {
  #boolean note
  #float email
  +calculateAmount()
  +updateAmount()
  +getActive()
  +setPrice()
}
class Shipment {
  -String price
  -boolean address
  #int updatedAt
  #Date type
  +boolean description
  +setType()
  +findStatus()
  +cancelCode()
}
Wishlist --o Cart
Wishlist --> Order : "*"
@enduml