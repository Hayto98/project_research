@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
interface Patient {
  +Date phone
  #long amount
  +cancelAddress()
  +cancelNote()
  +validatePhone()
  +processAmount()
}
abstract class Treatment {
  #int address
  +int id
  +double updatedAt
  +createAmount()
  +deleteUpdatedat()
  +calculatePrice()
}
class Insurance {
  -Date description
  +long createdAt
  +updateDescription()
  +validateNote()
  +createScore()
}
class Hospital {
  -float quantity
  +float type
  +String level
  #double code
  +findUpdatedat()
  +calculateQuantity()
  +findNote()
}
interface Nurse {
  -int quantity
  -int email
  #String description
  +long code
  +saveStatus()
  +processPrice()
  +updateCode()
  +getAmount()
}
class MedicalRecord {
  #int active
  -boolean quantity
  #double email
  #float code
  -String createdAt
  +sendCreatedat()
}
abstract class LabTest {
  #String name
  +float createdAt
  +Date active
  +int status
  +createTotal()
  +setType()
}
LabTest --* MedicalRecord
LabTest --> Insurance : "1..*"
note right of Patient : Healthcare domain
@enduml