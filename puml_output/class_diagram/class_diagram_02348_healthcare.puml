@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
interface Patient {
  +Date phone
  #long amount
  +findUpdatedat()
  +saveCreatedat()
  +findName()
  +deletePrice()
}
class Treatment {
  -String type
  +boolean amount
  +int duration
  +String description
  +calculateTotal()
  +getDescription()
  +updateLevel()
  +calculateScore()
}
class Insurance {
  #long updatedAt
  +int price
  +long level
  +validateScore()
  +setPrice()
}
interface Hospital {
  -boolean createdAt
  -Date description
  #Date address
  -Date note
  +deleteType()
  +sendName()
  +getId()
}
class Nurse {
  -Date description
  +double status
  -Date level
  -boolean type
  +processDescription()
  +validateAddress()
  +calculateStatus()
}
class MedicalRecord {
  -int type
  #String description
  +findCreatedat()
  +cancelCreatedat()
}
class LabTest {
  +Date price
  -boolean updatedAt
  -float code
  -String name
  #int amount
  +getAddress()
  +calculateDuration()
}
Nurse --|> Hospital
Patient ..|> Nurse
Hospital --> MedicalRecord : "1..*"
Patient --> Treatment : "1"
Nurse ..|> Patient
@enduml