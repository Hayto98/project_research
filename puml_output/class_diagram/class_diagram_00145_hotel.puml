@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class CheckIn {
  #String code
  +int type
  -String createdAt
  -Date id
  +cancelPhone()
  +getTotal()
}
class Amenity {
  -int phone
  +Date total
  -float note
  +long duration
  +findStatus()
}
class Reservation {
  +int active
  -Date code
  -double email
  +long type
  +saveType()
}
interface Room {
  #String code
  #float createdAt
  +saveAmount()
}
class Booking {
  +float description
  #boolean updatedAt
  -boolean name
  -Date price
  +int email
  +processUpdatedat()
  +sendId()
}
interface Staff {
  -int note
  +double email
  +String total
  +updateAddress()
  +validateName()
  +updateDuration()
}
class Service {
  #double code
  -boolean email
  -Date note
  +deletePrice()
  +calculatePhone()
  +setPrice()
  +validateStatus()
}
Reservation --|> CheckIn
CheckIn ..> Room : "*"
@enduml