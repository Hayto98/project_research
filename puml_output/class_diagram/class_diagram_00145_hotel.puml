@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class CheckIn {
  #String code
  +int type
  -String createdAt
  -Date id
  +createCreatedat()
  +validateEmail()
}
class Amenity {
  #long note
  +long phone
  +Date email
  +float description
  -boolean code
  +findEmail()
}
abstract class Reservation {
  #double updatedAt
  -float phone
  +createLevel()
}
class Room {
  #String code
  #float createdAt
  +processCode()
}
abstract class Booking {
  -long duration
  +float updatedAt
  #boolean name
  +cancelQuantity()
  +findStatus()
  +deleteCreatedat()
}
class Staff {
  -float active
  #long level
  -double createdAt
  +getTotal()
  +updateId()
}
interface Service {
  +float type
  -double id
  #double phone
  -boolean createdAt
  +saveScore()
  +calculateNote()
  +createCode()
  +createId()
}
CheckIn ..> Room : "*"
note right of CheckIn : Hotel domain
@enduml