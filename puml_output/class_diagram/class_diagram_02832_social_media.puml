@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Story {
  +boolean type
  -float createdAt
  +boolean price
  #boolean description
  #Date duration
  +updateStatus()
  +findAmount()
  +saveScore()
  +cancelName()
}
class Report {
  +Date note
  -Date address
  +float name
  #int active
  +sendNote()
  +sendAddress()
  +setNote()
  +deleteCode()
}
class Notification {
  #long score
  +String amount
  +cancelCreatedat()
}
class Message {
  #int phone
  -int level
  +long name
  #double total
  +createLevel()
  +processEmail()
}
class Hashtag {
  -Date code
  +Date name
  -String duration
  -double amount
  -long level
  +updatePrice()
  +validateLevel()
}
Story --* Report
Notification --|> Hashtag
Notification ..> Message : "*"
Message --o Story
@enduml