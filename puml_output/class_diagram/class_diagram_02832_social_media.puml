@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Story {
  +boolean type
  -float createdAt
  +boolean price
  #boolean description
  #Date duration
  +updateTotal()
  +validatePhone()
  +validateNote()
  +validateName()
}
interface Report {
  -int quantity
  -double updatedAt
  -float description
  +setScore()
  +deleteDuration()
  +validateId()
}
class Notification {
  #long total
  -Date quantity
  +calculateActive()
}
class Message {
  +Date updatedAt
  #int status
  -String email
  +String type
  +getTotal()
  +saveCreatedat()
}
class Hashtag {
  -long price
  +String type
  +deleteAddress()
}
Notification --* Story
Message --o Hashtag
Hashtag --o Story
note right of Story : Social Media domain
@enduml