@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
interface Catalog {
  #boolean email
  +double score
  -boolean quantity
  #double total
  +createTotal()
}
class Author {
  #String level
  #String address
  #double amount
  +validateCreatedat()
  +findId()
}
abstract class Librarian {
  +int code
  #float score
  -double amount
  +float quantity
  +getActive()
  +setId()
  +cancelCreatedat()
  +updateNote()
}
class Member {
  +String address
  -int status
  -double description
  +sendScore()
  +sendCreatedat()
  +setName()
  +saveDuration()
}
interface Book {
  +int code
  +String total
  #int note
  #float phone
  #long type
  +setPrice()
}
class Loan {
  -Date description
  #String createdAt
  +boolean type
  -String duration
  +findName()
  +updateDescription()
  +getNote()
}
Loan --* Catalog
Book ..|> Loan
@enduml