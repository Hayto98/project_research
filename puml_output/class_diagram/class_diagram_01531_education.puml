@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
interface Department {
  +boolean type
  -int code
  #String description
  #float score
  #boolean createdAt
  +calculateDuration()
  +cancelNote()
  +calculateNote()
  +validateLevel()
}
class Enrollment {
  -String active
  #int phone
  -String quantity
  +long level
  +calculateId()
}
class Library {
  #float description
  +boolean address
  +boolean id
  -String amount
  -boolean price
  +deleteDuration()
  +validatePhone()
}
class Schedule {
  +boolean total
  -int address
  +findCode()
}
abstract class Exam {
  +int total
  #boolean name
  +double level
  +long note
  +deleteLevel()
  +sendEmail()
  +getCreatedat()
}
class Book {
  -boolean note
  +int price
  -String total
  +findId()
}
class Grade {
  #boolean phone
  #boolean total
  -double type
  +setScore()
  +calculateNote()
  +calculateAddress()
}
Library --o Book
Schedule --* Enrollment
Library --* Grade
Grade --* Book
Department --o Exam
@enduml