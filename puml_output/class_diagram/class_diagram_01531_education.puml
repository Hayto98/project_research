@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
interface Department {
  +boolean type
  -int code
  #String description
  #float score
  #boolean createdAt
  +sendCreatedat()
  +updateCreatedat()
  +sendActive()
  +validateActive()
}
class Enrollment {
  -String phone
  +long total
  +String name
  -Date updatedAt
  +deleteAddress()
  +getAmount()
  +savePrice()
  +cancelStatus()
}
interface Library {
  +long score
  #Date email
  +processCode()
  +findUpdatedat()
}
class Schedule {
  +long address
  -long createdAt
  -String score
  +float type
  #Date updatedAt
  +deleteDescription()
  +findActive()
  +getPrice()
  +setPhone()
}
class Exam {
  #Date score
  -double updatedAt
  -float description
  +cancelName()
  +updateNote()
  +setId()
}
class Book {
  #double active
  #boolean createdAt
  #boolean phone
  -double total
  +saveCreatedat()
  +deleteType()
  +validateTotal()
}
abstract class Grade {
  -float address
  #long duration
  +boolean quantity
  +updateAmount()
  +saveQuantity()
  +processTotal()
  +updateDescription()
}
Grade ..> Enrollment : "1..*"
Grade --|> Department
Enrollment --|> Grade
Library --* Book
Exam --* Schedule
note right of Department : Education domain
@enduml