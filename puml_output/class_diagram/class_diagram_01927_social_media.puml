@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
abstract class Group {
  +long createdAt
  +int price
  +sendQuantity()
  +saveCode()
}
class Profile {
  +Date type
  -long level
  #boolean active
  -float description
  #Date quantity
  +updateUpdatedat()
  +findPhone()
  +findAddress()
  +sendAmount()
}
class Notification {
  +String phone
  #double id
  +double total
  +updateStatus()
  +cancelScore()
  +calculateAmount()
}
interface Message {
  #double total
  +int type
  -double updatedAt
  #long id
  +deleteId()
}
abstract class Album {
  +float score
  +int email
  #double status
  -Date amount
  +cancelActive()
}
class User {
  +float amount
  +int status
  -Date total
  -boolean createdAt
  +createAmount()
  +processScore()
  +validateUpdatedat()
  +validateTotal()
}
Group ..|> User
Notification ..|> User
note right of Group : Social Media domain
@enduml