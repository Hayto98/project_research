@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Doctor {
  #boolean score
  #Date address
  +String phone
  +float amount
  +double name
  +getDescription()
}
abstract class MedicalRecord {
  -Date address
  -long email
  -int code
  -double status
  #boolean phone
  +validateScore()
  +getTotal()
  +saveId()
  +deleteQuantity()
}
class Prescription {
  +boolean status
  -String updatedAt
  +double duration
  +calculateDuration()
  +validateStatus()
  +getDuration()
}
class Nurse {
  #int type
  -String code
  +sendCreatedat()
}
Prescription --o Nurse
Nurse --o MedicalRecord
Doctor --|> MedicalRecord
note right of Doctor : Healthcare domain
@enduml