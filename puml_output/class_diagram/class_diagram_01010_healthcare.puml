@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Doctor {
  #boolean score
  #Date address
  +String phone
  +float amount
  +double name
  +saveId()
}
class MedicalRecord {
  #Date note
  -long address
  #double email
  -double code
  +long status
  +calculateDuration()
  +validateLevel()
  +calculatePrice()
  +saveActive()
}
abstract class Prescription {
  +long score
  +Date id
  #int total
  +Date level
  +setStatus()
  +saveStatus()
}
class Nurse {
  #long code
  +String amount
  #boolean note
  +float phone
  +float price
  +validatePhone()
  +getStatus()
  +processPhone()
  +deleteId()
}
Nurse --|> Doctor
MedicalRecord --> Nurse : "1..*"
@enduml