@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Nurse {
  -Date type
  #int active
  +float email
  +setTotal()
  +deletePhone()
  +cancelQuantity()
  +getName()
}
abstract class Patient {
  +boolean code
  -double description
  -Date quantity
  #long total
  +sendNote()
}
interface Insurance {
  #float phone
  -long address
  +float updatedAt
  +calculateTotal()
  +findTotal()
}
abstract class Hospital {
  -float updatedAt
  #float status
  -int createdAt
  +validateDescription()
  +cancelCode()
  +validateId()
}
class Doctor {
  -String address
  #boolean quantity
  +getId()
  +updateEmail()
}
Nurse --* Patient
Hospital --|> Insurance
Nurse --|> Doctor
@enduml