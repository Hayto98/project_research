@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Nurse {
  -Date type
  #int active
  +float email
  +createNote()
  +calculateQuantity()
  +setDescription()
  +createLevel()
}
abstract class Patient {
  -double duration
  #boolean total
  +setUpdatedat()
  +sendCreatedat()
  +validateAddress()
}
class Insurance {
  +String quantity
  +long name
  #float amount
  -int note
  -float createdAt
  +setCreatedat()
  +getAddress()
  +createTotal()
  +setDuration()
}
interface Hospital {
  +int type
  -double total
  -String email
  +setCode()
}
class Doctor {
  +String createdAt
  -Date active
  -String updatedAt
  +long amount
  #double quantity
  +createCreatedat()
  +updatePrice()
  +cancelStatus()
}
Insurance ..> Nurse : "1..*"
Patient ..> Hospital : "1..*"
note right of Nurse : Healthcare domain
@enduml