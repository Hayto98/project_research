@startuml
skinparam monochrome true
skinparam shadowing true
interface Loan {
  -long code
  -double price
  #int quantity
  #double total
  #Date active
  +cancelQuantity()
}
class Fine {
  #float active
  +float level
  +setEmail()
  +findName()
  +processEmail()
}
class Shelf {
  -int amount
  -String duration
  +createAddress()
  +calculateLevel()
  +updateQuantity()
}
interface Book {
  -String id
  -boolean updatedAt
  -long quantity
  -double code
  -int status
  +saveTotal()
  +calculateStatus()
}
interface Author {
  -Date code
  #int active
  +validateStatus()
  +cancelDuration()
  +updateNote()
}
Shelf --* Fine
Fine --o Shelf
note right of Loan : Library domain
@enduml