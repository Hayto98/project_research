@startuml
skinparam monochrome true
skinparam shadowing true
interface Loan {
  -long code
  -double price
  #int quantity
  #double total
  #Date active
  +sendLevel()
}
interface Fine {
  #float email
  #float active
  +float status
  -String level
  +setCreatedat()
  +saveId()
  +processCreatedat()
}
abstract class Shelf {
  -int name
  -String status
  -long amount
  -double score
  +cancelAddress()
  +findDuration()
}
abstract class Book {
  +String updatedAt
  -String quantity
  +sendQuantity()
  +deleteLevel()
  +calculateTotal()
  +findAmount()
}
class Author {
  -String total
  #String email
  #String updatedAt
  #float description
  -Date duration
  +getCreatedat()
  +createId()
}
Shelf --> Loan : "0..1"
Book ..> Fine : "1..*"
Fine ..> Shelf : "0..1"
@enduml