@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
abstract class Staff {
  +long email
  +int code
  +long createdAt
  -long total
  +saveLevel()
}
interface Restaurant {
  -String email
  #Date duration
  +long description
  -float address
  #Date code
  +deleteEmail()
  +calculateQuantity()
}
abstract class Guest {
  +float quantity
  -boolean score
  +saveLevel()
}
class CheckIn {
  -long quantity
  +float updatedAt
  +createEmail()
}
class Booking {
  +Date email
  +Date type
  +cancelCode()
}
interface Amenity {
  -String description
  +float status
  #long quantity
  +updateAddress()
  +cancelStatus()
  +calculateAmount()
}
CheckIn ..|> Booking
CheckIn --|> Staff
Amenity --|> CheckIn
Staff ..> Guest : "1..*"
Staff ..> Amenity : "0..1"
@enduml