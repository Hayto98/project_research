@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Invoice {
  +int type
  -double total
  +findTotal()
}
class Order {
  #int id
  -int address
  -Date duration
  +double createdAt
  +setName()
  +getLevel()
}
class Product {
  #String active
  -String updatedAt
  +int price
  +updateEmail()
  +createEmail()
  +updateCreatedat()
}
class Payment {
  +String quantity
  +String price
  +deleteStatus()
}
interface Customer {
  #double id
  +Date total
  +cancelType()
  +deleteNote()
  +sendEmail()
  +processDescription()
}
interface Review {
  -int quantity
  -Date active
  +double description
  +setStatus()
}
Review ..|> Invoice
Payment --|> Order
note right of Invoice : Ecommerce domain
@enduml