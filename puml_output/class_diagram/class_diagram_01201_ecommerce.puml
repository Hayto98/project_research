@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Invoice {
  +int type
  -double total
  +deleteType()
}
abstract class Order {
  #long quantity
  +int id
  +createQuantity()
  +saveTotal()
}
class Product {
  +boolean updatedAt
  -float type
  #int amount
  #Date code
  +double name
  +deletePhone()
}
abstract class Payment {
  #long id
  +Date createdAt
  +sendAddress()
  +calculateScore()
  +processDuration()
}
class Customer {
  +int status
  +String quantity
  +String price
  #String amount
  +getAddress()
}
abstract class Review {
  -boolean type
  -double duration
  +boolean description
  +processAddress()
  +updateLevel()
}
Payment --* Order
Review --o Invoice
Invoice --|> Review
@enduml