@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Book {
  +int amount
  #String status
  -Date createdAt
  +calculateNote()
}
class Classroom {
  -String address
  -double email
  +double active
  -int code
  -Date note
  +createDescription()
  +deleteStatus()
}
abstract class Attendance {
  +Date name
  #double duration
  #double note
  +validateId()
  +processCreatedat()
  +updateEmail()
}
class Teacher {
  +int phone
  #Date createdAt
  -long amount
  +calculateCreatedat()
}
Teacher --> Classroom : "1..*"
Teacher --* Attendance
note right of Book : Education domain
@enduml