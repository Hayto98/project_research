@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Book {
  +int amount
  #String status
  -Date createdAt
  +setNote()
}
abstract class Classroom {
  +float type
  -double address
  +long email
  -int active
  +validateName()
  +updateStatus()
  +deleteCreatedat()
  +setCode()
}
class Attendance {
  +float description
  +Date duration
  +Date status
  -float price
  +processNote()
}
abstract class Teacher {
  +float phone
  -String address
  +long id
  +int type
  +int createdAt
  +calculateCreatedat()
  +processQuantity()
  +findAmount()
}
Classroom --o Attendance
Teacher --* Attendance
@enduml