@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
abstract class Coupon {
  +float amount
  #double price
  +saveCreatedat()
  +sendNote()
  +sendCreatedat()
  +calculatePhone()
}
class Category {
  -String status
  +long amount
  #long score
  #int type
  +processId()
  +sendAddress()
}
class Order {
  #int address
  -float level
  +String type
  +String status
  +updateLevel()
}
class Return {
  -String note
  -float phone
  +int createdAt
  #Date active
  #int code
  +findLevel()
}
Category ..|> Order
Return --> Category : "0..1"
Coupon --|> Order
note right of Coupon : Ecommerce domain
@enduml