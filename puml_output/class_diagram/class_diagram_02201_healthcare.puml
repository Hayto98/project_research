@startuml
skinparam defaultFontSize 13
class Hospital {
  #int updatedAt
  #double note
  -long type
  -double email
  -int price
  +setNote()
  +updateQuantity()
}
class Billing {
  #int phone
  #double updatedAt
  -int total
  -float createdAt
  +double duration
  +processUpdatedat()
}
class Appointment {
  +float createdAt
  #float code
  +setQuantity()
  +createPhone()
}
interface MedicalRecord {
  +boolean code
  +long address
  -int quantity
  +createDescription()
  +saveCreatedat()
  +updateQuantity()
  +sendType()
}
class Diagnosis {
  #double duration
  +int address
  #String phone
  -boolean updatedAt
  #float quantity
  +findId()
}
Billing ..|> Diagnosis
Diagnosis --> Hospital : "1"
MedicalRecord --|> Diagnosis
note right of Hospital : Healthcare domain
@enduml