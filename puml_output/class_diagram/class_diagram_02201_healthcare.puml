@startuml
skinparam defaultFontSize 13
class Hospital {
  #int updatedAt
  #double note
  -long type
  -double email
  -int price
  +setStatus()
  +calculateUpdatedat()
}
abstract class Billing {
  -int quantity
  -boolean name
  +boolean total
  +validateActive()
  +sendNote()
  +calculateDuration()
}
abstract class Appointment {
  -int createdAt
  +Date price
  #String status
  +float total
  +int name
  +getType()
  +calculatePhone()
}
class MedicalRecord {
  -String level
  #String amount
  -double code
  +double address
  +deleteEmail()
  +getName()
  +getEmail()
}
class Diagnosis {
  +float quantity
  -boolean active
  #long type
  +updateStatus()
  +findDuration()
  +validateStatus()
}
Appointment ..|> MedicalRecord
Billing --* Hospital
Diagnosis ..> Hospital : "1"
MedicalRecord ..|> Billing
@enduml