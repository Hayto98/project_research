@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
abstract class Grade {
  -int quantity
  -boolean createdAt
  +updateQuantity()
  +cancelActive()
}
abstract class Student {
  #float id
  #boolean duration
  #long price
  +saveDuration()
  +cancelId()
  +processEmail()
  +findStatus()
}
class Book {
  -double updatedAt
  #double code
  #boolean active
  +findUpdatedat()
  +deleteDuration()
  +sendNote()
}
class Exam {
  +String description
  -int email
  -int score
  #String id
  -long updatedAt
  +sendDuration()
  +validateNote()
  +sendUpdatedat()
}
class Assignment {
  #boolean id
  -long duration
  -int description
  +sendDescription()
  +findStatus()
  +processNote()
  +calculateName()
}
abstract class Classroom {
  -long price
  -String duration
  -long name
  -double id
  +calculateQuantity()
  +saveAddress()
}
class Teacher {
  -boolean name
  +long quantity
  +Date code
  +Date duration
  +String active
  +getTotal()
}
Teacher --> Grade : "*"
Grade --|> Exam
Classroom --* Exam
Teacher --> Exam : "0..1"
Classroom --|> Teacher
note right of Grade : Education domain
@enduml