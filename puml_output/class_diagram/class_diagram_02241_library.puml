@startuml
skinparam ArrowColor #555555
class Branch {
  +Date status
  -Date email
  #String duration
  +float id
  #float code
  +sendPhone()
  +deleteQuantity()
  +findActive()
}
class Reservation {
  #Date id
  +float phone
  +processPhone()
  +sendScore()
  +findStatus()
  +deleteNote()
}
abstract class Book {
  -String active
  -long id
  -Date total
  -String quantity
  +saveNote()
  +cancelLevel()
  +validatePrice()
  +findDescription()
}
class Member {
  +boolean address
  -Date quantity
  -String note
  #long updatedAt
  +float name
  +getEmail()
  +setCode()
  +saveEmail()
  +updateDescription()
}
abstract class Publisher {
  #boolean quantity
  #int level
  -long total
  #boolean address
  #boolean email
  +sendName()
  +updateDescription()
  +findPhone()
}
class Fine {
  +String amount
  +String level
  +double code
  +calculateAddress()
  +findCode()
}
Book ..> Branch : "*"
Fine --> Branch : "0..1"
Branch --* Reservation
Publisher --o Fine
Branch --> Fine : "1..*"
@enduml