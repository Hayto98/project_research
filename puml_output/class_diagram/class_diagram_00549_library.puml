@startuml

class Shelf {
  -String email
  -float price
  +float quantity
  +boolean description
  +updateScore()
  +deleteCode()
}
interface Renewal {
  +float quantity
  #long active
  -double price
  -String createdAt
  +cancelPhone()
  +createCreatedat()
  +cancelDescription()
}
abstract class Branch {
  +boolean updatedAt
  +Date score
  -long status
  -boolean type
  +double email
  +findActive()
  +createLevel()
}
class Reservation {
  #double active
  -float address
  -long level
  #int name
  +deleteAddress()
  +getPrice()
  +setName()
}
class Loan {
  #long code
  +String duration
  -String address
  +validateName()
  +validateType()
  +findPhone()
  +findPrice()
}
class Member {
  +float email
  +boolean active
  -int note
  #long total
  +setEmail()
  +createStatus()
  +createAddress()
}
Loan --o Renewal
Reservation --o Shelf
note right of Shelf : Library domain
@enduml