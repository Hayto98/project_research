@startuml

class Shelf {
  -String email
  -float price
  +float quantity
  +boolean description
  +sendNote()
  +setAddress()
}
class Renewal {
  -boolean active
  #Date quantity
  +createType()
  +sendId()
  +savePhone()
  +createId()
}
class Branch {
  -int total
  #float email
  +double id
  -int level
  #float phone
  +validateName()
}
class Reservation {
  #double score
  -long status
  +findActive()
  +processUpdatedat()
}
interface Loan {
  -long level
  +boolean address
  -float email
  -float active
  +calculateScore()
  +calculateStatus()
  +calculateAddress()
  +cancelPhone()
}
class Member {
  #long id
  #boolean price
  +String code
  +float name
  +cancelDuration()
  +createActive()
  +setLevel()
}
Reservation --> Shelf : "*"
Branch --* Shelf
@enduml