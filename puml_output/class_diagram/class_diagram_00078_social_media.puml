@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Message {
  +long id
  -double status
  #boolean description
  #double score
  #float quantity
  +createDuration()
  +sendCode()
  +processTotal()
  +processActive()
}
class Group {
  -long status
  -boolean description
  #double price
  +double updatedAt
  +setNote()
  +validateId()
  +findCode()
}
class Album {
  #int updatedAt
  -long total
  -int amount
  +cancelDescription()
  +saveActive()
  +setNote()
  +findDescription()
}
class Report {
  +int note
  -double score
  #long level
  -float createdAt
  +setAddress()
  +getScore()
}
class Notification {
  -String address
  -float note
  +setCode()
  +sendNote()
  +sendScore()
}
Notification --* Message
Album --|> Group
@enduml