@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Message {
  +long id
  -double status
  #boolean description
  #double score
  #float quantity
  +calculateNote()
  +processCreatedat()
  +getDuration()
  +createStatus()
}
class Group {
  +double updatedAt
  -double type
  +long quantity
  +int email
  +double price
  +sendAmount()
  +calculateQuantity()
}
abstract class Album {
  #int price
  -double score
  #boolean total
  +updateDescription()
  +validatePrice()
}
interface Report {
  +boolean type
  +long createdAt
  -double score
  +float active
  +createUpdatedat()
  +calculateCode()
  +findScore()
  +findName()
}
class Notification {
  +float description
  -Date code
  -double id
  -long status
  +calculateScore()
  +processAmount()
  +getCode()
  +processDescription()
}
Group ..> Album : "*"
Report --* Album
Report --> Message : "*"
Group --o Message
note right of Message : Social Media domain
@enduml