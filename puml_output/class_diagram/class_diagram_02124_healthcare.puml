@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
abstract class Appointment {
  +String phone
  -float email
  #long price
  #double quantity
  +Date type
  +setEmail()
  +processCreatedat()
}
interface Diagnosis {
  +boolean name
  -int id
  +validateEmail()
}
abstract class Patient {
  -String description
  +int status
  +validateLevel()
}
interface Insurance {
  #String status
  #long email
  -boolean level
  +calculateQuantity()
  +findPrice()
  +processLevel()
}
class Ward {
  +int address
  +Date total
  #boolean name
  #float quantity
  +deleteLevel()
  +deletePrice()
  +processLevel()
  +findCreatedat()
}
abstract class MedicalRecord {
  +Date code
  #int id
  +int address
  +saveCode()
  +saveName()
  +deleteCreatedat()
  +validateCreatedat()
}
Ward --> Diagnosis : "1..*"
Ward ..> Insurance : "0..1"
note right of Appointment : Healthcare domain
@enduml