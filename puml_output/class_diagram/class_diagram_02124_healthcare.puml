@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
abstract class Appointment {
  +String phone
  -float email
  #long price
  #double quantity
  +Date type
  +getType()
  +validateAddress()
}
abstract class Diagnosis {
  +int score
  #double name
  +String level
  +deleteCreatedat()
  +validateName()
  +saveEmail()
}
class Patient {
  +int address
  #String name
  +sendUpdatedat()
  +findName()
  +sendActive()
}
class Insurance {
  #String email
  #long duration
  +saveTotal()
  +createStatus()
  +createUpdatedat()
}
class Ward {
  -double quantity
  #String price
  -String type
  +String name
  #Date duration
  +setLevel()
  +processEmail()
  +saveAddress()
  +getActive()
}
abstract class MedicalRecord {
  #String level
  -String createdAt
  #boolean price
  +String amount
  +float code
  +validatePrice()
  +sendLevel()
  +cancelStatus()
  +calculateEmail()
}
Diagnosis ..|> Patient
Appointment ..|> Ward
Ward --> Patient : "*"
@enduml