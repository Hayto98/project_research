@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Message {
  -Date active
  #String total
  -int code
  +getEmail()
  +updateQuantity()
  +calculateScore()
  +validateId()
}
class Hashtag {
  #float note
  #String status
  -int active
  +boolean id
  +sendTotal()
  +sendPhone()
  +saveStatus()
}
class User {
  -String email
  +float price
  -boolean amount
  +saveCreatedat()
  +cancelDescription()
  +processDuration()
  +cancelScore()
}
abstract class Comment {
  -float address
  +double duration
  #Date quantity
  +float id
  #float createdAt
  +deleteLevel()
  +createEmail()
}
interface Follower {
  #int duration
  -double code
  +double email
  -Date level
  +findScore()
  +createCreatedat()
}
class Like {
  #boolean total
  #long phone
  +boolean id
  +cancelAddress()
  +findAmount()
}
Like ..|> Comment
User --* Follower
Like --o Message
@enduml