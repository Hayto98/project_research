@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Message {
  -Date active
  #String total
  -int code
  +deleteEmail()
  +setId()
  +createNote()
  +setActive()
}
class Hashtag {
  +boolean type
  #long amount
  +validateDescription()
}
class User {
  +float price
  -boolean amount
  -long quantity
  #int id
  +processAddress()
  +findAddress()
  +findQuantity()
  +findId()
}
interface Comment {
  #Date note
  +float updatedAt
  #float type
  +sendEmail()
  +cancelCode()
}
class Follower {
  -double duration
  +double createdAt
  +saveLevel()
  +updateQuantity()
  +deleteId()
  +updateTotal()
}
class Like {
  #long active
  +boolean duration
  +createTotal()
  +deleteType()
}
User --* Follower
Like --o Message
Like ..> Follower : "0..1"
note right of Message : Social Media domain
@enduml