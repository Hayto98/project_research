@startuml

class Card {
  -double total
  #String price
  +createId()
  +updatePhone()
  +calculateCreatedat()
  +findPrice()
}
class Interest {
  +int amount
  -Date quantity
  +long active
  -long code
  +processPrice()
}
class Customer {
  #double level
  +double code
  #Date active
  +sendCreatedat()
  +createLevel()
  +calculateTotal()
}
interface Transaction {
  #double price
  #boolean name
  +setCode()
}
interface Deposit {
  +double description
  +double email
  +Date createdAt
  +Date status
  +int phone
  +processQuantity()
  +createCreatedat()
  +findNote()
  +sendCode()
}
Customer --|> Interest
Customer --|> Transaction
@enduml