@startuml
skinparam defaultFontSize 11
abstract class Restaurant {
  +String type
  -boolean phone
  +createActive()
  +deletePhone()
}
class Invoice {
  -float updatedAt
  -float type
  -String code
  -String note
  -long description
  +findUpdatedat()
  +getTotal()
}
abstract class Reservation {
  -boolean code
  -long score
  -Date email
  #Date duration
  +processDescription()
  +cancelUpdatedat()
  +validateQuantity()
  +setType()
}
class CheckOut {
  #long description
  -long email
  #String quantity
  +updateNote()
}
class Room {
  -double active
  +double quantity
  #int name
  +validateLevel()
  +createName()
  +cancelName()
  +deleteScore()
}
abstract class Amenity {
  -boolean description
  #Date quantity
  -int level
  +updateNote()
  +createQuantity()
}
Room ..|> CheckOut
Amenity --* Reservation
Amenity ..> Restaurant : "*"
@enduml