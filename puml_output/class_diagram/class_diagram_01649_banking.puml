@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Statement {
  -String level
  +boolean address
  +boolean note
  -Date quantity
  -String amount
  +findDescription()
}
class Transaction {
  +boolean total
  -float createdAt
  +Date name
  -double score
  +createLevel()
  +findStatus()
  +processPrice()
}
abstract class Teller {
  -int code
  #boolean duration
  +double description
  +boolean quantity
  +long type
  +findDuration()
  +validateStatus()
  +processUpdatedat()
}
class Deposit {
  +int updatedAt
  +float createdAt
  +Date description
  +calculatePhone()
  +deleteTotal()
  +cancelPhone()
}
abstract class Withdrawal {
  #boolean type
  -float code
  +sendCode()
  +getActive()
  +validateLevel()
  +updateTotal()
}
Statement --> Teller : "*"
Withdrawal --o Teller
Transaction --o Withdrawal
Transaction ..> Teller : "0..1"
note right of Statement : Banking domain
@enduml