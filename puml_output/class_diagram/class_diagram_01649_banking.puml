@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Statement {
  -String level
  +boolean address
  +boolean note
  -Date quantity
  -String amount
  +getActive()
}
class Transaction {
  +String quantity
  #String total
  +cancelActive()
  +getUpdatedat()
}
abstract class Teller {
  -boolean address
  #String type
  -double email
  +calculateCode()
  +processAmount()
  +getEmail()
  +createQuantity()
}
abstract class Deposit {
  +boolean amount
  +long active
  -Date id
  #long price
  +sendCreatedat()
}
class Withdrawal {
  +int updatedAt
  +int duration
  +validateStatus()
  +saveNote()
}
Withdrawal --o Teller
Teller --o Transaction
Deposit ..> Statement : "*"
@enduml