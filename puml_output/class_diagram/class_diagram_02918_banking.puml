@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Branch {
  #Date code
  #Date updatedAt
  #String quantity
  +cancelCode()
}
class Statement {
  #float total
  #String updatedAt
  +int name
  +float id
  +getPhone()
  +cancelPhone()
  +saveId()
  +calculateAddress()
}
abstract class Withdrawal {
  +Date level
  +boolean note
  +deleteStatus()
  +createDuration()
  +createAmount()
}
abstract class Beneficiary {
  +int type
  -int email
  -long duration
  +long active
  -float phone
  +validateCode()
}
class Transfer {
  +int score
  +int level
  +long email
  +long total
  +sendEmail()
}
Beneficiary ..> Branch : "*"
Statement --* Transfer
Beneficiary ..> Withdrawal : "1..*"
Statement --o Withdrawal
@enduml