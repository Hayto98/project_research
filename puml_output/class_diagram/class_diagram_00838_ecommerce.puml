@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
interface Shipment {
  #String quantity
  #int active
  -String address
  +long duration
  -double type
  +deleteUpdatedat()
  +calculateStatus()
}
abstract class Payment {
  #float status
  +int level
  +boolean score
  +getTotal()
}
class Warehouse {
  +boolean note
  +int score
  -String price
  +boolean total
  +sendCode()
  +setUpdatedat()
  +processDescription()
}
class Invoice {
  -float status
  #boolean score
  +updateDescription()
  +sendLevel()
  +cancelEmail()
  +deleteDuration()
}
class Coupon {
  -Date total
  +int updatedAt
  -String level
  #float status
  +saveCreatedat()
  +saveDuration()
  +processDescription()
}
class Category {
  -float id
  -boolean level
  +saveNote()
  +sendDescription()
  +calculateEmail()
  +deleteStatus()
}
Coupon --* Shipment
Invoice ..> Payment : "1..*"
@enduml