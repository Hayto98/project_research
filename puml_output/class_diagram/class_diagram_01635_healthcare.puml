@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
interface Nurse {
  #float total
  +boolean amount
  -float duration
  +calculatePhone()
}
abstract class Treatment {
  +String level
  +float email
  +Date id
  +int address
  +String note
  +createAmount()
}
abstract class Appointment {
  -boolean price
  +String description
  +float note
  -float email
  -float name
  +processDescription()
  +calculateCreatedat()
  +processId()
}
class Hospital {
  +String phone
  -String quantity
  -float createdAt
  +boolean amount
  +String status
  +createQuantity()
  +saveStatus()
  +calculateCode()
  +deleteLevel()
}
class Billing {
  +boolean status
  -boolean price
  #float description
  +float active
  -long duration
  +getCode()
}
Billing --> Treatment : "1"
Treatment --|> Appointment
@enduml