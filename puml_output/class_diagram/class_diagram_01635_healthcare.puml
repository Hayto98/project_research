@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
interface Nurse {
  #float total
  +boolean amount
  -float duration
  +createType()
}
abstract class Treatment {
  +int id
  +Date address
  +int note
  +String description
  +validateNote()
}
abstract class Appointment {
  #int description
  +int note
  -float email
  -float name
  -long total
  +cancelQuantity()
  +calculatePhone()
  +createCreatedat()
}
class Hospital {
  -String status
  -float code
  +cancelDescription()
  +setType()
}
class Billing {
  #Date amount
  +String type
  #float status
  -boolean price
  #float description
  +processAddress()
  +getLevel()
}
Billing --> Treatment : "1"
Treatment --|> Appointment
note right of Nurse : Healthcare domain
@enduml