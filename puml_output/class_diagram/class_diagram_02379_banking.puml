@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
interface Account {
  #String total
  -boolean id
  #long name
  #boolean phone
  -boolean status
  +getQuantity()
}
class Deposit {
  #boolean phone
  #float status
  -boolean address
  #int email
  #String quantity
  +saveEmail()
  +cancelLevel()
}
interface Branch {
  +long amount
  #int total
  -Date phone
  -boolean createdAt
  #long code
  +processId()
}
interface Beneficiary {
  #long name
  +double level
  +saveId()
}
interface Withdrawal {
  +long quantity
  #double description
  #Date active
  +deleteCode()
  +cancelPrice()
}
abstract class Statement {
  -float amount
  -float status
  #long level
  +sendNote()
  +deleteNote()
  +deleteName()
  +sendId()
}
class Card {
  -Date email
  +boolean price
  #long createdAt
  -int name
  +getPrice()
  +validateDuration()
  +processDuration()
  +validateAddress()
}
Withdrawal --> Card : "1"
Deposit --o Statement
Beneficiary --* Statement
Deposit --o Beneficiary
Account --> Statement : "1..*"
Card --> Account : "1"
@enduml