@startuml
skinparam defaultFontSize 13
class Supplier {
  +long createdAt
  -String total
  +cancelName()
  +sendTotal()
}
class Return {
  +double amount
  +int createdAt
  +double price
  +saveDescription()
}
class Invoice {
  -float createdAt
  -String duration
  +Date note
  +processUpdatedat()
}
class Customer {
  +boolean name
  -float address
  #float amount
  +long score
  #Date description
  +updateNote()
  +getNote()
  +createPrice()
  +calculateDescription()
}
abstract class Coupon {
  +String id
  +long total
  #String note
  +int address
  #String code
  +getStatus()
}
Return --|> Supplier
Invoice --> Return : "1..*"
Return --|> Invoice
@enduml