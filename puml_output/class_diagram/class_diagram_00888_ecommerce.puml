@startuml
skinparam defaultFontSize 13
class Supplier {
  +long createdAt
  -String total
  +findId()
  +findPhone()
}
class Return {
  +double duration
  +int createdAt
  +double price
  +findEmail()
}
interface Invoice {
  -float createdAt
  -String duration
  +Date note
  +deleteEmail()
}
abstract class Customer {
  +boolean address
  +int amount
  +cancelCode()
  +validateActive()
  +savePrice()
  +sendQuantity()
}
abstract class Coupon {
  +float total
  +String id
  +long duration
  #String note
  +int address
  +setLevel()
}
Return --|> Supplier
Invoice --> Return : "1..*"
Return --|> Invoice
note right of Supplier : Ecommerce domain
@enduml