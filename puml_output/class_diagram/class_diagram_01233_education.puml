@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Teacher {
  -float note
  -boolean phone
  +boolean level
  +calculatePhone()
  +findEmail()
  +sendLevel()
  +createEmail()
}
class Assignment {
  +float note
  #double duration
  #long description
  +sendPhone()
  +saveLevel()
}
interface Student {
  -double status
  #float code
  #long quantity
  -String total
  +long updatedAt
  +saveScore()
  +sendLevel()
  +updateUpdatedat()
  +cancelScore()
}
interface Classroom {
  -boolean address
  #double createdAt
  #String type
  +calculateActive()
}
class Enrollment {
  #long amount
  +double total
  -float updatedAt
  +validateCode()
}
Classroom --|> Student
Student --o Assignment
note right of Teacher : Education domain
@enduml