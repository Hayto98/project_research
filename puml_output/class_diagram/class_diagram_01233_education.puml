@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Teacher {
  -float note
  -boolean phone
  +boolean level
  +saveName()
  +createAmount()
  +validateTotal()
  +validateAddress()
}
interface Assignment {
  -float email
  +int duration
  #double description
  #long note
  +calculateDuration()
  +saveScore()
}
interface Student {
  -double status
  #float code
  #long quantity
  -String total
  +long updatedAt
  +updateAddress()
  +deleteLevel()
  +sendAmount()
  +findDuration()
}
interface Classroom {
  +long updatedAt
  +double score
  -boolean active
  +savePrice()
  +setName()
  +sendType()
  +updateScore()
}
interface Enrollment {
  +int price
  +Date active
  +processDuration()
  +processNote()
  +saveCreatedat()
  +processName()
}
Student --* Teacher
Teacher --o Enrollment
@enduml