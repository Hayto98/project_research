@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Ward {
  +String email
  +int description
  +Date updatedAt
  -long duration
  +cancelTotal()
  +updateDuration()
}
class Billing {
  +long status
  +String createdAt
  +createUpdatedat()
  +validatePhone()
}
abstract class Doctor {
  #double active
  #Date level
  #String address
  +String status
  +calculatePhone()
  +findEmail()
}
class MedicalRecord {
  +int active
  #double name
  -Date note
  -Date amount
  +deleteAmount()
  +sendCode()
  +calculateActive()
}
class Insurance {
  #double duration
  #Date total
  +String active
  +createUpdatedat()
}
Doctor ..> MedicalRecord : "*"
Billing --> Insurance : "1..*"
note right of Ward : Healthcare domain
@enduml