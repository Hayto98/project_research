@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Ward {
  +String email
  +int description
  +Date updatedAt
  -long duration
  +getQuantity()
  +calculateQuantity()
}
class Billing {
  +long id
  +String status
  #int createdAt
  +createScore()
  +processStatus()
  +validateTotal()
}
class Doctor {
  #Date phone
  #String active
  +String address
  +float status
  -long total
  +createQuantity()
  +createActive()
  +getPrice()
}
interface MedicalRecord {
  +int note
  #double amount
  +deleteStatus()
  +deleteCode()
  +processNote()
  +createActive()
}
class Insurance {
  #long score
  #float code
  +boolean price
  +sendLevel()
  +findPrice()
  +sendActive()
  +sendCode()
}
Ward --|> Insurance
Doctor --|> Billing
Doctor ..> MedicalRecord : "*"
Billing --> Insurance : "1..*"
@enduml