@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Customer {
  -long amount
  #long price
  -String address
  +cancelDuration()
}
class Category {
  -double type
  #double score
  +double code
  -boolean price
  +findAddress()
  +saveAddress()
  +setAddress()
  +saveScore()
}
abstract class Return {
  +double description
  -float total
  #int active
  +Date createdAt
  +createId()
  +createStatus()
  +processCode()
  +calculateEmail()
}
class Shipment {
  -long active
  #Date quantity
  -Date id
  +validateTotal()
  +getPrice()
  +sendNote()
}
Customer ..|> Shipment
Return ..|> Customer
note right of Customer : Ecommerce domain
@enduml