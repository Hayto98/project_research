@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Assignment {
  -int level
  #double address
  #String id
  +findLevel()
  +updateDescription()
}
abstract class Student {
  #long amount
  +String level
  +double duration
  #boolean quantity
  #boolean status
  +deleteLevel()
}
class Grade {
  +String score
  #String address
  +Date note
  +double amount
  +Date status
  +deleteCreatedat()
  +sendAddress()
  +processTotal()
  +createName()
}
class Schedule {
  #String createdAt
  #boolean updatedAt
  #int price
  +Date address
  +calculateActive()
  +saveTotal()
  +cancelDuration()
  +validateType()
}
class Teacher {
  -String score
  -float type
  -boolean createdAt
  +cancelDuration()
  +savePrice()
}
class Classroom {
  -int updatedAt
  +boolean createdAt
  #String email
  +Date level
  +long name
  +findQuantity()
  +calculateUpdatedat()
  +processQuantity()
  +cancelCreatedat()
}
Teacher --> Classroom : "1"
Classroom --o Student
Assignment --* Classroom
@enduml