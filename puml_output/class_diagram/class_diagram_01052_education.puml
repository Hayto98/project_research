@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Assignment {
  -int level
  #double address
  #String id
  +updateTotal()
  +cancelTotal()
}
class Student {
  +String quantity
  +double status
  #boolean address
  +updateType()
}
interface Grade {
  +String duration
  #String note
  +Date amount
  +double status
  +findType()
  +createEmail()
}
abstract class Schedule {
  -boolean status
  +Date quantity
  #float createdAt
  #int updatedAt
  +Date price
  +sendQuantity()
  +updateScore()
  +processCreatedat()
  +createStatus()
}
abstract class Teacher {
  +long score
  +String createdAt
  -int email
  +boolean price
  #String updatedAt
  +findName()
}
class Classroom {
  #int address
  -String name
  #String total
  -Date updatedAt
  +long id
  +findName()
  +cancelTotal()
  +cancelId()
  +createActive()
}
Grade ..> Teacher : "1"
Assignment --* Student
Schedule --|> Teacher
Grade ..> Classroom : "1"
Schedule --> Classroom : "0..1"
note right of Assignment : Education domain
@enduml