@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Classroom {
  -String price
  -float createdAt
  -long code
  +validateTotal()
  +updateQuantity()
}
class Teacher {
  #double type
  #boolean id
  #int active
  #String score
  #Date duration
  +deleteNote()
  +createCode()
  +sendStatus()
}
class Book {
  -float duration
  -int createdAt
  +getDescription()
}
class Department {
  +float status
  +double createdAt
  -float quantity
  +updateName()
  +deleteDescription()
}
class Exam {
  #float duration
  -String address
  +String id
  +calculateEmail()
  +findLevel()
  +saveEmail()
}
Classroom --> Department : "*"
Book --* Teacher
@enduml