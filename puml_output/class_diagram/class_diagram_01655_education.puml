@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Classroom {
  -String price
  -float createdAt
  -long code
  +findUpdatedat()
  +calculateType()
}
class Teacher {
  +int active
  #long total
  #boolean createdAt
  #String name
  #float address
  +validateAddress()
  +deleteStatus()
}
class Book {
  +float status
  +double createdAt
  -float quantity
  +setDuration()
  +deleteAmount()
}
interface Department {
  +long id
  +float quantity
  +String status
  +double createdAt
  +findPhone()
  +deletePhone()
  +updateCreatedat()
  +sendCode()
}
interface Exam {
  +double description
  #double amount
  -boolean phone
  +String price
  +deleteTotal()
  +createDescription()
}
Teacher ..|> Department
Classroom --|> Teacher
note right of Classroom : Education domain
@enduml