@startuml

class Book {
  +String id
  #boolean createdAt
  #int name
  +deleteName()
  +updateEmail()
  +findCode()
}
class Department {
  #String type
  #Date email
  #double status
  -float updatedAt
  +setTotal()
  +processTotal()
}
class Classroom {
  -Date code
  #boolean amount
  -Date note
  #long total
  +int score
  +calculateNote()
}
interface Teacher {
  #Date createdAt
  +float updatedAt
  -long id
  +cancelName()
  +sendName()
}
class Grade {
  #double price
  +long status
  #Date email
  -int duration
  #String amount
  +cancelDescription()
  +processType()
  +updateUpdatedat()
  +calculatePrice()
}
Classroom --|> Teacher
Book --> Department : "*"
Teacher --|> Classroom
Grade --o Department
@enduml