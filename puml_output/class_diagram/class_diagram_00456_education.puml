@startuml

class Book {
  +String id
  #boolean createdAt
  #int name
  +createTotal()
  +validatePhone()
  +validateType()
}
class Department {
  #Date updatedAt
  #double name
  +deleteQuantity()
  +processCode()
  +cancelTotal()
}
class Classroom {
  -Date note
  #boolean total
  -Date duration
  +setCreatedat()
  +sendCode()
  +updateDuration()
}
interface Teacher {
  #Date createdAt
  +float updatedAt
  -long id
  +findType()
  +setNote()
}
abstract class Grade {
  #int email
  #double price
  +createLevel()
}
Classroom --> Department : "1"
Grade ..> Teacher : "*"
Book --o Classroom
Book ..|> Grade
note right of Book : Education domain
@enduml