@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Report {
  #int total
  #String duration
  +getUpdatedat()
}
abstract class Group {
  #double level
  +long duration
  #int total
  +sendScore()
  +getCode()
  +processCode()
  +createName()
}
class Like {
  +long amount
  #Date email
  +saveEmail()
  +saveEmail()
}
class Message {
  #boolean createdAt
  -long status
  -boolean address
  -double level
  -int active
  +calculatePrice()
}
class Notification {
  -int price
  +String description
  +findLevel()
  +findStatus()
  +validateEmail()
}
class Comment {
  +double name
  +float quantity
  #Date status
  +boolean email
  #long id
  +getCode()
}
Report ..|> Notification
Message --o Notification
Group --|> Message
Notification ..|> Message
note right of Report : Social Media domain
@enduml