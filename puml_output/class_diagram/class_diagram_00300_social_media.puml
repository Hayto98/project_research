@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Report {
  #int total
  #String duration
  +getDuration()
}
class Group {
  #double price
  +long createdAt
  #int total
  +findDuration()
  +deletePhone()
  +saveActive()
  +saveEmail()
}
class Like {
  +long code
  +long quantity
  #Date name
  +Date status
  -float id
  +createTotal()
  +setUpdatedat()
  +createDuration()
}
class Message {
  #Date address
  #boolean status
  +findPrice()
}
interface Notification {
  +String phone
  -double total
  -String address
  #double price
  +double note
  +validateNote()
  +updateActive()
}
class Comment {
  #int phone
  -String email
  +createId()
  +validateEmail()
  +createType()
}
Report --o Group
Report --> Comment : "1..*"
Report --|> Message
@enduml