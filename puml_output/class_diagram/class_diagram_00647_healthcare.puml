@startuml
skinparam ArrowColor #555555
class Doctor {
  +float active
  -String id
  -int createdAt
  +findQuantity()
  +validatePhone()
  +setEmail()
}
class Insurance {
  +double duration
  +double score
  #double status
  +cancelUpdatedat()
  +deleteLevel()
}
interface Patient {
  #boolean score
  -float note
  #float amount
  -float code
  +validateQuantity()
  +sendType()
}
abstract class Prescription {
  -Date address
  -String total
  +float note
  +updateName()
  +getUpdatedat()
}
class Appointment {
  #Date quantity
  +float note
  #Date code
  -Date id
  +calculateUpdatedat()
}
class Ward {
  #Date phone
  +Date level
  -boolean code
  +long createdAt
  +cancelDuration()
  +saveQuantity()
  +deleteDuration()
}
interface Nurse {
  -Date score
  -long quantity
  #boolean createdAt
  +processAddress()
  +createDuration()
}
Prescription --> Insurance : "1..*"
Insurance --|> Doctor
@enduml