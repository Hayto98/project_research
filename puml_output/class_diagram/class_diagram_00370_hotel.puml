@startuml

interface Invoice {
  #double phone
  +Date duration
  #double total
  -int active
  +updatePrice()
  +saveAmount()
  +createId()
}
interface Service {
  +boolean note
  -double phone
  -long address
  -Date email
  +processId()
  +calculatePhone()
  +createId()
}
class Staff {
  -double status
  -Date createdAt
  +Date price
  +validatePhone()
  +cancelDescription()
  +getLevel()
  +cancelQuantity()
}
interface Housekeeping {
  -float total
  #boolean email
  -Date quantity
  #long description
  +Date score
  +findUpdatedat()
  +cancelStatus()
}
Housekeeping --o Staff
Staff --|> Invoice
note right of Invoice : Hotel domain
@enduml