@startuml

interface Invoice {
  #double phone
  +Date duration
  #double total
  -int active
  +getTotal()
  +saveName()
  +updateQuantity()
}
class Service {
  -long id
  -String active
  #double quantity
  -long note
  +cancelQuantity()
  +createType()
  +setDuration()
}
class Staff {
  +int id
  +int total
  -long phone
  -long quantity
  #int duration
  +calculateCreatedat()
  +sendType()
  +sendStatus()
  +cancelId()
}
interface Housekeeping {
  #float name
  #double level
  -long quantity
  +createCreatedat()
  +updateLevel()
  +setTotal()
}
Staff ..> Invoice : "0..1"
Service --|> Staff
Invoice --> Service : "*"
@enduml