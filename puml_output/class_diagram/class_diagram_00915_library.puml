@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
abstract class Branch {
  +float type
  #String active
  #long duration
  +boolean note
  +processEmail()
}
interface Reservation {
  -long duration
  +Date updatedAt
  -long note
  +createLevel()
  +sendPrice()
}
class Publisher {
  #Date createdAt
  -boolean code
  +calculateNote()
  +processPhone()
}
class Renewal {
  #float status
  +String name
  #double price
  +validateId()
  +cancelNote()
  +getDuration()
}
Branch --* Reservation
note right of Branch : Library domain
@enduml