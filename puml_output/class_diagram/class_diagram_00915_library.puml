@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
abstract class Branch {
  +float type
  #String active
  #long duration
  +boolean note
  +validateName()
}
class Reservation {
  -long duration
  +Date updatedAt
  -long note
  +validateAmount()
  +savePrice()
}
interface Publisher {
  #int email
  -float code
  -double createdAt
  -String level
  +Date quantity
  +createNote()
}
class Renewal {
  -String score
  #double amount
  +float code
  #float note
  +String phone
  +calculatePhone()
  +getType()
  +processTotal()
  +cancelId()
}
Publisher --o Renewal
Branch --> Renewal : "1..*"
@enduml