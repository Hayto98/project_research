@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Account {
  #Date id
  -double level
  +sendDescription()
  +validateId()
}
abstract class Statement {
  #long description
  #String createdAt
  +long address
  +String code
  +long status
  +getUpdatedat()
  +saveDuration()
}
class Branch {
  -double createdAt
  #boolean type
  #boolean total
  +saveAddress()
  +findQuantity()
  +sendName()
}
class Customer {
  +int name
  #double note
  #Date amount
  +saveQuantity()
}
class Withdrawal {
  #double id
  -float duration
  #String type
  +getTotal()
  +deleteLevel()
}
Withdrawal ..> Account : "1..*"
Account ..> Withdrawal : "1"
@enduml