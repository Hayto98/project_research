@startuml
skinparam monochrome true
skinparam defaultFontSize 11
interface Message {
  -String id
  -float name
  #int status
  +setType()
  +validateLevel()
  +savePhone()
}
class Report {
  -Date name
  #double id
  +calculateCreatedat()
  +deleteCode()
}
abstract class Notification {
  +String type
  -String status
  -Date email
  +getType()
  +updateDescription()
  +cancelQuantity()
}
class Group {
  +Date createdAt
  -long price
  +processDuration()
  +updateUpdatedat()
}
class Album {
  +long active
  +boolean address
  #Date amount
  +double code
  +getDescription()
}
class Like {
  +float status
  -boolean amount
  +createId()
  +cancelTotal()
  +processDuration()
}
abstract class Profile {
  #double quantity
  -String name
  +cancelAddress()
}
Report --* Profile
Notification --o Message
Report ..> Album : "*"
Report --> Notification : "0..1"
@enduml