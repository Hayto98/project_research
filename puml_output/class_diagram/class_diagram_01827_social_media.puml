@startuml
skinparam monochrome true
skinparam defaultFontSize 11
interface Message {
  -String id
  -float name
  #int status
  +deleteName()
  +deleteName()
  +findName()
}
class Report {
  -double total
  #float score
  #int createdAt
  -String address
  +setId()
  +calculateCode()
  +createPhone()
}
class Notification {
  #int note
  -int address
  #float code
  +validateDescription()
  +updateStatus()
  +saveAddress()
}
class Group {
  -int duration
  #Date amount
  #int code
  -boolean createdAt
  +getStatus()
}
class Album {
  #boolean description
  #long price
  +int score
  +saveCode()
  +createDuration()
  +getScore()
  +processTotal()
}
class Like {
  +float quantity
  +float email
  +validateStatus()
  +calculateDescription()
  +cancelType()
}
class Profile {
  +double active
  -String description
  +Date name
  +Date createdAt
  +validatePhone()
  +setType()
}
Notification ..> Album : "0..1"
Profile --> Group : "*"
Group ..> Profile : "0..1"
Report ..> Album : "1"
note right of Message : Social Media domain
@enduml