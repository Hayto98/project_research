@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
interface Customer {
  +boolean quantity
  #String phone
  -int note
  #boolean address
  +updateDuration()
  +validateStatus()
}
class Review {
  -boolean description
  -long score
  +deleteCreatedat()
}
class Cart {
  +long name
  -int phone
  +long active
  +String address
  +findUpdatedat()
  +saveAddress()
}
class Return {
  -boolean active
  -String email
  +deleteTotal()
  +getAddress()
  +deleteAmount()
}
Cart --|> Customer
Customer ..|> Review
note right of Customer : Ecommerce domain
@enduml