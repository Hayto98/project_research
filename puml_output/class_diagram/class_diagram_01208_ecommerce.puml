@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
interface Customer {
  +boolean quantity
  #String phone
  -int note
  #boolean address
  +processPrice()
  +getQuantity()
}
class Review {
  +boolean phone
  -boolean id
  +updateTotal()
  +updatePrice()
  +sendLevel()
}
class Cart {
  -Date quantity
  #Date duration
  -int name
  +calculateCreatedat()
  +createScore()
  +cancelTotal()
}
class Return {
  #int code
  #long createdAt
  +processQuantity()
  +createUpdatedat()
}
Return --* Cart
Customer ..|> Review
Return ..> Customer : "1..*"
@enduml