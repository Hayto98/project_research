@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Warehouse {
  +boolean status
  +double code
  -boolean active
  +String total
  #int updatedAt
  +validateCreatedat()
}
abstract class Invoice {
  -float quantity
  #long createdAt
  -float id
  +findLevel()
  +sendCreatedat()
  +processEmail()
}
class Payment {
  -float amount
  +float updatedAt
  -String total
  -int email
  #boolean createdAt
  +createUpdatedat()
  +deleteCode()
  +setEmail()
  +saveName()
}
class Shipment {
  -double total
  +Date phone
  #Date email
  -long status
  +boolean type
  +updateStatus()
  +calculateDuration()
  +sendCode()
}
Invoice --o Shipment
Invoice --|> Payment
@enduml