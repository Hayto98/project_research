@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Author {
  #boolean total
  -int updatedAt
  +createUpdatedat()
  +deleteId()
  +updateAddress()
}
class Branch {
  +double note
  -int code
  #Date amount
  +double email
  +processAmount()
  +updateActive()
  +setDescription()
}
interface Renewal {
  +int code
  +Date score
  #boolean amount
  +deleteCode()
  +createStatus()
}
abstract class Member {
  -Date amount
  +long total
  +calculateActive()
  +setUpdatedat()
  +deleteName()
}
abstract class Loan {
  +float name
  -float phone
  +saveCode()
  +cancelType()
  +deleteQuantity()
}
class Fine {
  +long email
  -String amount
  +float type
  -String active
  +createDescription()
  +calculateDescription()
  +saveScore()
}
interface Librarian {
  -float id
  -long price
  #long level
  +double address
  +getQuantity()
  +getDescription()
  +deleteAmount()
  +updateQuantity()
}
Branch --* Member
Member --> Branch : "1"
Author --o Branch
Fine --> Renewal : "1..*"
Author --o Renewal
@enduml