@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Author {
  #boolean total
  -int updatedAt
  +sendName()
  +validateNote()
  +setAmount()
}
class Branch {
  #Date type
  +double quantity
  -String updatedAt
  +setDuration()
}
class Renewal {
  +int score
  +Date amount
  +validateScore()
  +calculateId()
}
class Member {
  -double type
  +String amount
  -int address
  -float email
  #Date name
  +calculateStatus()
  +updateEmail()
  +createDuration()
}
class Loan {
  +float active
  -String id
  -boolean quantity
  #long address
  #long name
  +calculatePrice()
}
class Fine {
  -float total
  -boolean quantity
  -float address
  -int description
  +validateType()
  +updateDuration()
  +setId()
  +updateType()
}
class Librarian {
  -long name
  -String quantity
  -int price
  +int code
  +validateCreatedat()
}
Author --|> Member
Member ..> Renewal : "0..1"
note right of Author : Library domain
@enduml