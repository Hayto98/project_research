@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Appointment {
  +String note
  -String description
  #double total
  +cancelTotal()
  +setDuration()
}
interface Patient {
  -boolean phone
  #double description
  +double address
  -long duration
  +setUpdatedat()
  +cancelCode()
  +processCode()
  +processEmail()
}
class Insurance {
  +boolean status
  #double name
  +boolean score
  -int phone
  +updatePhone()
  +calculateLevel()
  +calculateNote()
  +validateType()
}
interface Diagnosis {
  -int name
  +double code
  +Date status
  -long id
  +getScore()
  +getDuration()
  +updatePhone()
  +updateAddress()
}
class Prescription {
  #float email
  -int description
  +processUpdatedat()
}
Appointment --|> Patient
Prescription --* Appointment
Patient --|> Insurance
note right of Appointment : Healthcare domain
@enduml