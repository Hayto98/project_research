@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Appointment {
  +String note
  -String description
  #double total
  +getCode()
  +deleteLevel()
}
abstract class Patient {
  -long duration
  +long level
  +validateAmount()
  +getScore()
  +saveType()
}
abstract class Insurance {
  -boolean total
  #Date address
  +findNote()
  +findLevel()
  +deleteAddress()
  +findDescription()
}
class Diagnosis {
  +String code
  #float type
  -String email
  #Date name
  -int phone
  +validateCreatedat()
  +processLevel()
  +validateNote()
}
class Prescription {
  #long level
  +String price
  +String note
  -int phone
  +double type
  +deletePhone()
}
Diagnosis --> Insurance : "*"
Appointment --> Prescription : "0..1"
Insurance --* Patient
Patient ..> Appointment : "1..*"
@enduml