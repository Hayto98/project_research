@startuml
skinparam monochrome true
skinparam shadowing true
class Reservation {
  +float address
  -float description
  +boolean quantity
  +String active
  +createPhone()
}
class CheckIn {
  #boolean code
  -long createdAt
  -boolean updatedAt
  #int quantity
  +setStatus()
  +createCreatedat()
  +createScore()
  +processName()
}
interface Restaurant {
  -String description
  +boolean active
  +createCode()
  +calculateNote()
}
class Invoice {
  #String id
  +boolean duration
  -boolean address
  +deleteType()
}
abstract class Staff {
  #boolean type
  +int score
  +double description
  #float price
  +saveTotal()
}
Staff --o Restaurant
Reservation --> Restaurant : "*"
@enduml