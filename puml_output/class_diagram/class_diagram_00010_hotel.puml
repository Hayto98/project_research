@startuml
skinparam monochrome true
skinparam shadowing true
class Reservation {
  +float address
  -float description
  +boolean quantity
  +String active
  +setPhone()
}
class CheckIn {
  -Date createdAt
  #double updatedAt
  +createActive()
  +cancelCreatedat()
  +findLevel()
}
interface Restaurant {
  #int status
  #double description
  +float updatedAt
  +boolean id
  #int code
  +updateCode()
  +sendCreatedat()
}
class Invoice {
  +boolean address
  -boolean code
  +findType()
}
class Staff {
  +float score
  +double description
  #float price
  +int active
  #long status
  +setLevel()
  +validateScore()
  +findPrice()
  +calculateTotal()
}
Restaurant ..> Reservation : "*"
Invoice --* Restaurant
note right of Reservation : Hotel domain
@enduml