@startuml
skinparam monochrome true
skinparam shadowing true
interface Branch {
  -int code
  +long phone
  -Date active
  -String score
  +createCode()
  +calculateTotal()
  +createAddress()
  +calculatePrice()
}
class Teller {
  #Date createdAt
  +long price
  +boolean type
  +int address
  +cancelDescription()
  +createPrice()
  +cancelLevel()
}
interface Transfer {
  -String amount
  -Date type
  #long email
  +boolean phone
  +deleteUpdatedat()
}
interface Interest {
  #boolean note
  +long status
  -long type
  +boolean email
  +deleteId()
  +cancelDescription()
  +processStatus()
}
abstract class Card {
  +long price
  +boolean description
  +float phone
  #long active
  -String code
  +processTotal()
  +sendAddress()
  +updateId()
  +setEmail()
}
Card --> Teller : "1"
Branch --* Transfer
Teller --> Transfer : "1"
@enduml