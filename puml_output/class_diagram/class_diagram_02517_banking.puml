@startuml
skinparam monochrome true
skinparam shadowing true
interface Branch {
  -int code
  +long phone
  -Date active
  -String score
  +deleteCode()
  +sendDescription()
  +cancelEmail()
  +updatePrice()
}
abstract class Teller {
  +long name
  #double quantity
  #long createdAt
  #float updatedAt
  +processEmail()
  +validatePhone()
}
class Transfer {
  #boolean score
  -double email
  #float amount
  +double active
  -boolean status
  +createQuantity()
  +createDescription()
}
interface Interest {
  +long phone
  #String total
  +long level
  +boolean price
  +sendPhone()
  +createId()
}
abstract class Card {
  +long email
  -int address
  #long quantity
  #String description
  #Date id
  +updateName()
}
Teller --> Branch : "1"
Branch ..> Teller : "1..*"
Interest ..> Branch : "0..1"
note right of Branch : Banking domain
@enduml