@startuml
skinparam defaultFontSize 13
class Warehouse {
  -int id
  #Date phone
  +updateId()
  +deleteDescription()
}
class Customer {
  -float updatedAt
  +String description
  +validateName()
  +validateScore()
}
interface Shipment {
  -double status
  +boolean email
  #Date createdAt
  +int name
  +validateAmount()
  +processCode()
}
class DeliveryNote {
  #boolean phone
  +String note
  +String email
  +long name
  #boolean amount
  +deleteUpdatedat()
  +validateDuration()
}
Warehouse ..|> Shipment
Customer --> Shipment : "*"
DeliveryNote --|> Warehouse
note right of Warehouse : Logistics domain
@enduml