@startuml
skinparam defaultFontSize 13
class Warehouse {
  -int id
  #Date phone
  +deleteAddress()
  +processCode()
}
class Customer {
  +double quantity
  +String name
  #boolean updatedAt
  +updateTotal()
  +setUpdatedat()
}
class Shipment {
  -double status
  +boolean email
  #Date createdAt
  +int name
  +createActive()
  +validateTotal()
}
class DeliveryNote {
  -long code
  +int id
  #boolean active
  +String price
  +String phone
  +createActive()
}
Customer --* Warehouse
DeliveryNote --> Warehouse : "0..1"
@enduml