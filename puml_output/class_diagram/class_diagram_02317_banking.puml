@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Account {
  #int address
  +double status
  +Date name
  +createCreatedat()
  +getCode()
  +validateType()
  +findNote()
}
class Transaction {
  #boolean duration
  #boolean level
  #Date createdAt
  +double score
  +deleteType()
}
class Deposit {
  -double level
  +long active
  -int price
  +sendEmail()
  +deleteQuantity()
  +createCreatedat()
  +deleteCreatedat()
}
class Loan {
  +double note
  -Date address
  #int status
  -Date name
  +float updatedAt
  +updateAmount()
  +createAddress()
  +calculateScore()
}
abstract class Branch {
  +double amount
  -int code
  #double duration
  -long active
  +getUpdatedat()
  +validatePrice()
}
Deposit --* Account
Account ..> Branch : "*"
Loan --o Transaction
@enduml