@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Doctor {
  +String createdAt
  -double id
  +sendName()
  +createName()
  +sendQuantity()
  +cancelDescription()
}
class Diagnosis {
  -double email
  -String id
  #String updatedAt
  #boolean status
  +float description
  +validateDescription()
  +deleteDescription()
}
class Insurance {
  #double level
  +long createdAt
  +int duration
  -boolean code
  -float address
  +createQuantity()
}
interface Patient {
  +boolean description
  -double price
  -double level
  #boolean quantity
  +updateStatus()
  +validateDescription()
}
interface Nurse {
  -Date price
  #Date note
  +String type
  +Date quantity
  -String score
  +sendCode()
  +deleteQuantity()
}
Patient --* Insurance
Diagnosis ..> Doctor : "1..*"
Diagnosis --o Insurance
@enduml