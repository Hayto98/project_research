@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Doctor {
  +String createdAt
  -double id
  +processNote()
  +sendEmail()
  +calculateEmail()
  +getDuration()
}
class Diagnosis {
  -long description
  +boolean note
  +cancelDuration()
}
class Insurance {
  #float duration
  #float description
  #int type
  +setAddress()
  +findNote()
}
class Patient {
  +long amount
  #boolean duration
  -int price
  -float total
  +createId()
  +sendNote()
  +calculatePrice()
  +processActive()
}
interface Nurse {
  -double updatedAt
  -double level
  -double active
  +saveId()
  +getName()
  +saveTotal()
}
Diagnosis --|> Patient
Insurance --* Patient
note right of Doctor : Healthcare domain
@enduml