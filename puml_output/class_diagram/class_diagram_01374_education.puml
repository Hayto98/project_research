@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
interface Student {
  +String score
  -int createdAt
  +updateDescription()
  +saveTotal()
}
class Teacher {
  -long email
  +String status
  +Date amount
  #boolean score
  +saveDescription()
}
abstract class Attendance {
  #Date status
  -Date name
  #double email
  +getPrice()
  +calculateActive()
  +processId()
  +setPhone()
}
abstract class Grade {
  #double email
  -float quantity
  -Date status
  -long updatedAt
  +saveAmount()
}
interface Library {
  +float score
  -double price
  #Date email
  +float phone
  +deleteEmail()
}
class Assignment {
  -Date phone
  +int note
  #Date id
  -String price
  +createDescription()
}
Library --> Teacher : "*"
Attendance --o Assignment
Student ..|> Assignment
Library ..> Assignment : "1..*"
note right of Student : Education domain
@enduml