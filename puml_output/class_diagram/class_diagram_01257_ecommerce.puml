@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Review {
  +boolean description
  #boolean price
  -float total
  -String active
  +boolean code
  +setPrice()
}
abstract class Category {
  -Date code
  #int name
  +calculateLevel()
  +createPhone()
  +createCreatedat()
}
abstract class Product {
  -Date total
  -long type
  -long duration
  +validateQuantity()
}
class Customer {
  +int total
  #int type
  -Date description
  -Date score
  +processType()
  +cancelName()
  +saveEmail()
}
interface Warehouse {
  #String description
  -double updatedAt
  +updatePrice()
  +updateEmail()
  +updateStatus()
}
Customer --> Warehouse : "1"
Product --> Customer : "1..*"
Review --* Customer
@enduml