@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
abstract class Classroom {
  -float total
  -long status
  -String description
  -String amount
  +getAddress()
  +getStatus()
  +setDuration()
  +sendEmail()
}
class Book {
  -double level
  #int total
  #boolean updatedAt
  +String type
  #boolean address
  +processQuantity()
  +findAddress()
  +calculateUpdatedat()
  +saveTotal()
}
class Library {
  -Date quantity
  +long address
  -float active
  -long score
  +setDuration()
}
class Exam {
  #long note
  -boolean name
  #int total
  +findCode()
  +calculateStatus()
  +updateCreatedat()
}
class Course {
  #boolean code
  -Date email
  +int type
  +int id
  +boolean description
  +setQuantity()
  +processQuantity()
  +saveStatus()
  +calculateDescription()
}
class Student {
  -double createdAt
  +double price
  #Date status
  +deleteScore()
  +validateId()
  +calculateEmail()
  +setName()
}
Book --> Exam : "*"
Classroom ..|> Library
note right of Classroom : Education domain
@enduml