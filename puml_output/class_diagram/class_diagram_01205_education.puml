@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
abstract class Classroom {
  -float total
  -long status
  -String description
  -String amount
  +cancelTotal()
  +createActive()
  +updateActive()
  +cancelEmail()
}
class Book {
  -float id
  -float type
  -double total
  #int updatedAt
  +updateActive()
}
interface Library {
  #float type
  -int quantity
  #long address
  -long price
  #boolean updatedAt
  +cancelScore()
  +processActive()
  +calculatePhone()
}
class Exam {
  #float phone
  -String id
  -float status
  #long duration
  -boolean amount
  +findCreatedat()
  +setCode()
}
class Course {
  +long status
  -float updatedAt
  +boolean createdAt
  +Date level
  #double note
  +getEmail()
}
class Student {
  -String description
  #long active
  -float level
  +cancelPrice()
  +deleteQuantity()
  +getPhone()
}
Classroom ..> Course : "0..1"
Book --|> Exam
Library --|> Exam
@enduml