@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class LabTest {
  +long createdAt
  #Date price
  #float active
  +cancelId()
}
class Doctor {
  #double phone
  +float score
  -float price
  +String amount
  +long type
  +calculateDescription()
  +findStatus()
  +sendDuration()
}
class MedicalRecord {
  -boolean amount
  +long email
  #Date description
  -String duration
  +setCreatedat()
}
class Diagnosis {
  +Date quantity
  -String name
  +getPhone()
}
class Nurse {
  +boolean quantity
  #int id
  +findLevel()
  +sendId()
}
abstract class Billing {
  #boolean score
  #float duration
  #int type
  #double updatedAt
  +cancelLevel()
  +saveDescription()
}
class Treatment {
  -String status
  +boolean note
  +createDescription()
  +createStatus()
}
Nurse --|> MedicalRecord
Billing --> Diagnosis : "0..1"
note right of LabTest : Healthcare domain
@enduml