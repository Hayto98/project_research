@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
interface Assignment {
  +float createdAt
  #int price
  +createCode()
}
class Library {
  -Date level
  #float active
  +String duration
  -Date email
  #long phone
  +deleteEmail()
  +saveDuration()
}
abstract class Course {
  -int quantity
  #int level
  +updateCreatedat()
}
class Enrollment {
  #Date id
  #int level
  #boolean code
  +validateCreatedat()
  +cancelActive()
  +getPhone()
  +saveId()
}
interface Teacher {
  #double status
  -Date code
  -int score
  +saveStatus()
}
Assignment --* Enrollment
Teacher ..|> Enrollment
Enrollment --> Teacher : "1"
note right of Assignment : Education domain
@enduml