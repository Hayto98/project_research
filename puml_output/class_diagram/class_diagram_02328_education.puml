@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
interface Assignment {
  +float createdAt
  #int price
  +cancelPhone()
}
class Library {
  #boolean total
  -boolean level
  -long active
  #boolean score
  +cancelEmail()
}
class Course {
  #String updatedAt
  #long description
  #Date email
  #long note
  +deleteDescription()
  +validateNote()
}
class Enrollment {
  #Date createdAt
  +boolean email
  #String description
  +findDescription()
  +findDuration()
}
interface Teacher {
  #String address
  #boolean createdAt
  +float active
  #String name
  #String phone
  +calculateAmount()
  +calculateDescription()
  +deleteName()
  +updateType()
}
Assignment --> Teacher : "1"
Teacher --* Enrollment
Library --> Assignment : "*"
@enduml