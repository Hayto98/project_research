@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
interface Patient {
  #long score
  +boolean status
  +getDescription()
  +setType()
  +cancelUpdatedat()
  +setName()
}
interface Insurance {
  -float total
  #float phone
  +getPrice()
  +sendDescription()
  +setPhone()
}
class Ward {
  #float address
  #boolean score
  +Date type
  #int phone
  +findAddress()
  +deleteId()
  +getScore()
}
abstract class Hospital {
  +float price
  #double total
  +double email
  #float active
  +deleteEmail()
  +cancelTotal()
  +getType()
}
class Diagnosis {
  #boolean description
  -String amount
  -long score
  #String price
  +Date id
  +cancelTotal()
  +updateUpdatedat()
  +calculateStatus()
}
class Billing {
  -Date email
  #float name
  -long price
  +setId()
}
Hospital ..|> Billing
Insurance --* Diagnosis
Billing --> Patient : "0..1"
Diagnosis ..> Insurance : "0..1"
note right of Patient : Healthcare domain
@enduml