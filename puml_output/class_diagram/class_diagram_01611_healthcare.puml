@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
interface Patient {
  #long score
  +boolean status
  +saveEmail()
  +setLevel()
  +deleteEmail()
  +getUpdatedat()
}
class Insurance {
  -float duration
  -long updatedAt
  #float code
  -String name
  -boolean status
  +validateId()
  +updateTotal()
}
class Ward {
  #float address
  #boolean score
  +Date type
  #int phone
  +setCode()
  +findQuantity()
  +createCreatedat()
}
class Hospital {
  -double score
  -long note
  +getStatus()
}
interface Diagnosis {
  -boolean code
  -String total
  #double active
  +double address
  +int amount
  +createLevel()
  +findEmail()
  +processCode()
  +deleteStatus()
}
interface Billing {
  +int name
  #long quantity
  #double address
  +int active
  +findType()
  +validateEmail()
  +saveQuantity()
  +createNote()
}
Ward --o Patient
Hospital --* Ward
Billing ..> Diagnosis : "1"
@enduml