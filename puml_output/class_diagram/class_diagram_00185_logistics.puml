@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
interface DeliveryNote {
  +int email
  +double name
  +Date phone
  #String score
  +saveId()
}
class Tracking {
  +int duration
  +long phone
  -long email
  #String active
  +calculateStatus()
  +updateDuration()
  +createTotal()
}
class Warehouse {
  #String duration
  +float total
  +getNote()
  +findActive()
  +getAmount()
  +savePrice()
}
class Vehicle {
  #String quantity
  +float name
  +Date note
  -Date id
  +getQuantity()
  +sendUpdatedat()
}
DeliveryNote ..|> Warehouse
Vehicle ..> Warehouse : "*"
Vehicle ..> DeliveryNote : "0..1"
@enduml