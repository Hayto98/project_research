@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
interface DeliveryNote {
  +int email
  +double name
  +Date phone
  #String score
  +getAddress()
}
class Tracking {
  +long email
  -long active
  #String amount
  #Date updatedAt
  +findId()
  +findEmail()
  +cancelCode()
}
interface Warehouse {
  -Date duration
  #long id
  #boolean name
  #long note
  -String quantity
  +getStatus()
  +getStatus()
  +saveAddress()
  +saveUpdatedat()
}
interface Vehicle {
  #float status
  -float description
  +Date total
  +boolean score
  +createEmail()
  +saveId()
  +updateType()
}
Warehouse ..> Tracking : "*"
Warehouse ..> Vehicle : "1..*"
DeliveryNote --> Tracking : "1"
note right of DeliveryNote : Logistics domain
@enduml