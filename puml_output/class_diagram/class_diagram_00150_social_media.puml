@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
interface Follower {
  #float duration
  +long price
  #float name
  +deleteName()
  +processAddress()
  +validateCreatedat()
  +deleteActive()
}
interface Album {
  -float email
  +float code
  -double total
  #long phone
  #String duration
  +sendLevel()
  +sendNote()
  +calculateQuantity()
  +findDuration()
}
interface User {
  -double price
  #Date code
  +boolean name
  #Date type
  +sendAmount()
  +cancelAddress()
  +processScore()
  +createUpdatedat()
}
abstract class Comment {
  -int note
  -boolean description
  +getDescription()
  +saveActive()
  +findCode()
  +deletePhone()
}
interface Profile {
  +long createdAt
  #String active
  +String price
  +saveAddress()
  +setDescription()
  +getUpdatedat()
}
Album --|> Comment
Comment --o Follower
Comment --|> Profile
Profile --o User
note right of Follower : Social Media domain
@enduml