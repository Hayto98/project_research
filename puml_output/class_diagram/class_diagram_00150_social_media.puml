@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
interface Follower {
  #float duration
  +long price
  #float name
  +setType()
  +saveId()
  +processTotal()
  +findQuantity()
}
class Album {
  -float description
  #float active
  -String level
  +sendPhone()
  +sendAddress()
  +saveName()
  +validateStatus()
}
class User {
  -long note
  #boolean address
  #float id
  -double total
  +String duration
  +processTotal()
  +calculateQuantity()
  +validateTotal()
  +updatePhone()
}
class Comment {
  +Date active
  -String amount
  -int address
  -int type
  -boolean quantity
  +processQuantity()
  +setType()
  +getAmount()
  +findDuration()
}
class Profile {
  +boolean phone
  -String level
  -Date createdAt
  +createEmail()
}
Follower ..> User : "1..*"
Follower --|> Album
@enduml