@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Payment {
  +double email
  +double address
  +boolean active
  +float quantity
  -String createdAt
  +cancelAmount()
  +cancelActive()
  +getName()
  +cancelUpdatedat()
}
class Customer {
  +float price
  +String duration
  -double level
  #boolean description
  #Date phone
  +updatePrice()
  +getUpdatedat()
  +findQuantity()
}
class Coupon {
  #String level
  +double description
  +validateTotal()
  +findTotal()
  +processLevel()
  +updatePrice()
}
interface Supplier {
  -double total
  -Date email
  -String duration
  +calculateAmount()
}
class Review {
  #String code
  +long name
  #boolean phone
  +setCreatedat()
  +saveTotal()
  +createStatus()
  +createTotal()
}
abstract class Return {
  +int status
  #int createdAt
  +setQuantity()
  +deleteLevel()
  +saveCreatedat()
}
Coupon --o Supplier
Review ..|> Customer
@enduml