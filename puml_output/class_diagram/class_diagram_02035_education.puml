@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Attendance {
  #Date level
  +boolean note
  -long price
  +Date code
  +processEmail()
  +getScore()
  +validateId()
  +findScore()
}
interface Department {
  +long total
  #long description
  +Date amount
  +findQuantity()
  +calculateLevel()
  +createAddress()
  +setCreatedat()
}
class Library {
  -String duration
  #int active
  +float type
  +boolean updatedAt
  +double email
  +sendPrice()
  +createTotal()
}
class Teacher {
  -double total
  -Date active
  #String description
  #Date createdAt
  +calculateUpdatedat()
}
abstract class Assignment {
  -boolean total
  #float type
  -long email
  +String amount
  +setPrice()
  +getActive()
  +saveDescription()
}
abstract class Grade {
  #Date createdAt
  +Date total
  +findStatus()
  +findActive()
}
class Student {
  -String price
  -boolean note
  -boolean description
  +deleteType()
  +saveStatus()
  +findStatus()
  +setNote()
}
Department ..|> Attendance
Library ..|> Attendance
Assignment ..|> Teacher
note right of Attendance : Education domain
@enduml