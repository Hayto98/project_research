@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Attendance {
  #Date level
  +boolean note
  -long price
  +Date code
  +deleteDuration()
  +updateAddress()
  +validateAmount()
  +deleteEmail()
}
class Department {
  +int id
  +long score
  #long updatedAt
  +Date total
  +cancelUpdatedat()
  +deleteType()
  +calculatePhone()
  +deleteAmount()
}
interface Library {
  -boolean address
  #Date status
  #double createdAt
  +long score
  +updateDuration()
  +findPrice()
  +setLevel()
}
class Teacher {
  +boolean score
  -long updatedAt
  #double price
  +cancelName()
  +deleteCreatedat()
}
abstract class Assignment {
  -Date createdAt
  #String total
  #Date level
  +cancelCreatedat()
}
class Grade {
  -boolean active
  +long level
  #boolean email
  -long total
  +String type
  +createPhone()
  +createDuration()
  +processCode()
}
interface Student {
  -Date total
  #float name
  +Date createdAt
  +setCreatedat()
  +updateUpdatedat()
}
Library ..|> Assignment
Grade --o Teacher
Student --> Grade : "0..1"
Student --|> Teacher
Teacher --* Assignment
Assignment ..|> Teacher
@enduml