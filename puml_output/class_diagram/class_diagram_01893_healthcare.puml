@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Ward {
  +int amount
  +String phone
  #double type
  +sendName()
  +createEmail()
  +processNote()
}
interface MedicalRecord {
  +boolean type
  #String level
  +processActive()
  +getLevel()
  +updateScore()
}
abstract class Doctor {
  #float total
  +float email
  +Date id
  #boolean name
  #double createdAt
  +processNote()
  +deleteCode()
  +deleteUpdatedat()
  +validateDuration()
}
abstract class Nurse {
  -double status
  +String amount
  +createDuration()
  +saveName()
  +createQuantity()
  +createCode()
}
class Treatment {
  -float id
  -String phone
  +saveUpdatedat()
  +updateQuantity()
  +findDescription()
}
class Billing {
  -int type
  -float total
  -String id
  #int score
  +getEmail()
  +findQuantity()
  +saveAddress()
}
class Diagnosis {
  +String score
  -float type
  +String price
  +long id
  +setLevel()
}
Ward ..|> Doctor
Diagnosis ..|> Billing
Billing ..> Ward : "1"
Nurse ..|> Ward
@enduml