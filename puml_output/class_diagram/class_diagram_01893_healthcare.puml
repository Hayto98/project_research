@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Ward {
  +int amount
  +String phone
  #double type
  +processLevel()
  +findScore()
  +getType()
}
interface MedicalRecord {
  -int duration
  +Date name
  -float active
  +calculateEmail()
  +getName()
  +updateCreatedat()
  +deleteScore()
}
interface Doctor {
  +Date price
  +float phone
  -double address
  +String note
  #boolean name
  +calculatePrice()
  +createAmount()
  +updateId()
  +findId()
}
class Nurse {
  #long type
  #double name
  -float phone
  +String address
  +updateEmail()
  +calculateName()
  +saveUpdatedat()
}
class Treatment {
  -boolean address
  -double amount
  +float id
  +getNote()
  +updateCode()
}
class Billing {
  -int id
  #float description
  +Date phone
  +Date name
  +calculateId()
}
class Diagnosis {
  -float active
  +Date createdAt
  +sendQuantity()
  +findPrice()
}
Nurse --> Ward : "0..1"
Billing --|> Doctor
MedicalRecord ..|> Billing
MedicalRecord --o Diagnosis
MedicalRecord --|> Ward
MedicalRecord ..|> Doctor
note right of Ward : Healthcare domain
@enduml