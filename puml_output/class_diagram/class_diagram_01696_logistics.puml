@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
abstract class FuelLog {
  #double note
  #long email
  #boolean total
  +sendAddress()
  +findType()
  +getAmount()
}
class Route {
  #float name
  -long description
  -int address
  +long price
  +validateAmount()
  +processType()
  +cancelPhone()
}
class Customer {
  +Date code
  #long name
  +getEmail()
  +saveDescription()
  +updateLevel()
  +getActive()
}
abstract class Vehicle {
  #String description
  +double score
  +String duration
  #int note
  +processStatus()
  +setAddress()
  +updatePrice()
}
abstract class DeliveryNote {
  +int id
  #long email
  -long score
  -String active
  #int code
  +deletePhone()
  +sendPhone()
  +updateTotal()
}
class Depot {
  +float email
  #String code
  -String total
  +boolean id
  +getNote()
  +processType()
  +updateDescription()
}
Vehicle --|> Depot
Vehicle --* FuelLog
Route --* Depot
Vehicle --o DeliveryNote
@enduml