@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Customer {
  +boolean email
  #int amount
  -boolean quantity
  -int updatedAt
  +validateLevel()
  +createAmount()
}
class Withdrawal {
  #boolean amount
  +boolean id
  #float name
  +double address
  #String updatedAt
  +findCode()
  +deleteActive()
  +processLevel()
}
class Card {
  -int price
  #float active
  +updateActive()
  +processQuantity()
}
class Account {
  #String code
  +int createdAt
  +sendPhone()
  +calculateActive()
}
Card --> Account : "1..*"
Withdrawal ..|> Card
Customer ..|> Account
@enduml