@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Customer {
  +boolean email
  #int amount
  -boolean quantity
  -int updatedAt
  +validateAmount()
  +calculateAmount()
}
class Withdrawal {
  #boolean address
  +boolean updatedAt
  +calculateDuration()
  +setDuration()
}
class Card {
  -boolean type
  #double total
  +boolean amount
  +String code
  +updateDuration()
}
class Account {
  +int createdAt
  +long code
  +validateActive()
  +cancelPhone()
  +updateScore()
}
Customer ..|> Account
Customer ..|> Card
note right of Customer : Banking domain
@enduml