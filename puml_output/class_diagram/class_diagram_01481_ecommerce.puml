@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
interface Review {
  -boolean name
  -Date status
  +createEmail()
  +updateActive()
  +validateEmail()
  +createDescription()
}
class Product {
  #String description
  +Date amount
  +processAddress()
  +deleteDuration()
}
interface Warehouse {
  +Date phone
  -float updatedAt
  +boolean active
  +saveTotal()
}
interface Wishlist {
  +boolean description
  #int type
  +setLevel()
  +createType()
}
Review --|> Warehouse
Warehouse --o Product
Review --|> Product
note right of Review : Ecommerce domain
@enduml