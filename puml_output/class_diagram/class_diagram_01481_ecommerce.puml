@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
interface Review {
  -boolean name
  -Date status
  +cancelAddress()
  +sendAddress()
  +sendEmail()
  +findDuration()
}
class Product {
  +int quantity
  #String description
  +Date address
  +double name
  +updateQuantity()
  +updateType()
  +cancelPrice()
}
interface Warehouse {
  +Date phone
  -float updatedAt
  +boolean active
  +sendPrice()
}
abstract class Wishlist {
  +boolean description
  #int type
  +getType()
  +cancelActive()
}
Wishlist --o Warehouse
Review --|> Warehouse
Warehouse --o Product
@enduml