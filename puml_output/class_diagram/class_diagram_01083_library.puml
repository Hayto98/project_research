@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
abstract class Loan {
  #float active
  -double email
  -String code
  -long quantity
  #float score
  +validateType()
  +sendPhone()
}
interface Member {
  #long total
  #boolean description
  +boolean updatedAt
  +setLevel()
  +createEmail()
  +getType()
}
interface Shelf {
  +boolean note
  -long score
  +int total
  +getAddress()
  +saveDescription()
}
class Catalog {
  #long code
  -String type
  -String updatedAt
  +float total
  +cancelAddress()
}
Loan --o Member
Member ..> Loan : "1"
note right of Loan : Library domain
@enduml