@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
abstract class Loan {
  #float active
  -double email
  -String code
  -long quantity
  #float score
  +setEmail()
  +validateName()
}
interface Member {
  +int duration
  #long active
  #boolean createdAt
  +boolean total
  +setDescription()
  +deleteUpdatedat()
  +validateAddress()
}
class Shelf {
  +double type
  #double active
  +processEmail()
}
class Catalog {
  -Date updatedAt
  +long description
  #float duration
  -String id
  +updateStatus()
  +deleteUpdatedat()
  +cancelCreatedat()
  +cancelDuration()
}
Catalog --* Loan
Loan --|> Catalog
Shelf --|> Loan
@enduml