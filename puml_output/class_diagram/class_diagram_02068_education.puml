@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Classroom {
  #double address
  -Date code
  +saveName()
}
class Department {
  +String active
  -String status
  -long level
  +processAddress()
  +setPhone()
  +savePhone()
}
class Enrollment {
  #Date address
  #long status
  +long code
  #double createdAt
  +processStatus()
  +createPhone()
  +sendActive()
  +calculateTotal()
}
abstract class Student {
  +Date total
  +long description
  +double level
  +cancelActive()
}
Classroom --o Department
Classroom ..|> Enrollment
@enduml