@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Classroom {
  #double address
  -Date code
  +calculatePhone()
}
class Department {
  +double status
  +float code
  +createEmail()
  +cancelName()
  +getAddress()
}
class Enrollment {
  #Date code
  #long createdAt
  +createType()
  +calculatePhone()
}
class Student {
  +Date duration
  +long description
  +double total
  #boolean level
  +boolean active
  +sendName()
  +calculateType()
  +getAmount()
  +getEmail()
}
Department --> Student : "1"
Department --> Classroom : "*"
note right of Classroom : Education domain
@enduml