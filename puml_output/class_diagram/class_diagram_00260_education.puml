@startuml
skinparam ArrowColor #555555
class Assignment {
  -float email
  +String quantity
  -double name
  -boolean type
  +processUpdatedat()
  +validateStatus()
  +saveScore()
}
class Student {
  -float email
  +Date amount
  +saveCreatedat()
  +setPrice()
  +sendNote()
}
class Exam {
  +long quantity
  #int code
  +String phone
  #Date price
  +cancelNote()
  +setPhone()
}
interface Attendance {
  #boolean status
  #boolean duration
  +long email
  #Date id
  +float active
  +getScore()
  +processQuantity()
  +getAddress()
}
Student --* Assignment
Student --> Attendance : "*"
Assignment --* Student
@enduml