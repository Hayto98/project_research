@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Route {
  -boolean quantity
  #String name
  +saveStatus()
  +setDuration()
  +updateDescription()
  +getDescription()
}
class Inventory {
  -long score
  -String quantity
  +deleteCode()
}
class Shipment {
  -int level
  +Date id
  -int amount
  #String address
  #int quantity
  +deleteQuantity()
  +cancelTotal()
  +validateNote()
  +calculateDuration()
}
class Manifest {
  #String note
  #float id
  #float level
  +createLevel()
  +updateScore()
}
Shipment --* Inventory
Inventory --> Shipment : "1..*"
Route ..> Inventory : "*"
@enduml