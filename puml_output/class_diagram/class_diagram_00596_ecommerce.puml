@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
interface Invoice {
  -double score
  +boolean id
  -double phone
  +deleteId()
  +cancelCode()
}
interface Supplier {
  +float total
  #String type
  +double quantity
  +long active
  -int level
  +processCode()
}
abstract class Shipment {
  +boolean name
  #Date active
  +boolean level
  +String createdAt
  +boolean phone
  +getAddress()
  +savePhone()
}
abstract class Coupon {
  -long status
  +int amount
  +String quantity
  -long duration
  +processQuantity()
}
class Order {
  -boolean email
  +String code
  +double createdAt
  +long note
  +validateLevel()
  +sendAmount()
}
class Customer {
  -Date address
  #double updatedAt
  +calculateStatus()
}
abstract class Wishlist {
  +Date phone
  -int description
  -Date id
  +updateDescription()
}
Supplier ..> Shipment : "*"
Wishlist --o Order
Shipment --* Supplier
Order --o Coupon
Invoice --* Coupon
@enduml