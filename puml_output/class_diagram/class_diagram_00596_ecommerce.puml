@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
interface Invoice {
  -double score
  +boolean id
  -double phone
  +processActive()
  +cancelTotal()
}
abstract class Supplier {
  +double quantity
  +long active
  -int type
  +String description
  #double status
  +findName()
  +sendActive()
  +updatePhone()
  +setLevel()
}
interface Shipment {
  +String active
  #float id
  +calculateName()
  +calculateQuantity()
}
class Coupon {
  -long duration
  +int quantity
  +String status
  +createLevel()
  +setName()
  +updatePhone()
}
class Order {
  -long duration
  #float createdAt
  +getUpdatedat()
  +processName()
}
class Customer {
  -float score
  +double code
  #Date id
  +getPrice()
  +deletePhone()
  +deleteId()
  +updateEmail()
}
class Wishlist {
  #boolean status
  -float createdAt
  #double note
  -int level
  -boolean quantity
  +calculateCode()
  +calculateQuantity()
  +updateCreatedat()
  +findCreatedat()
}
Shipment ..|> Customer
Supplier --o Order
note right of Invoice : Ecommerce domain
@enduml