@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Coupon {
  -Date createdAt
  +Date active
  #float updatedAt
  +long code
  +updateCreatedat()
}
class Order {
  +int note
  +int id
  #boolean updatedAt
  +savePrice()
  +sendCode()
}
class Supplier {
  +float phone
  +float score
  -long note
  +calculateStatus()
  +createId()
  +cancelCode()
}
class Payment {
  +Date active
  #double score
  -double updatedAt
  +setLevel()
  +validateType()
  +updateNote()
  +saveCreatedat()
}
interface Return {
  #Date name
  +float phone
  +validatePrice()
  +getStatus()
}
interface Shipment {
  -int amount
  +float quantity
  +boolean active
  -Date description
  +double address
  +processAmount()
  +cancelId()
  +calculateScore()
  +getScore()
}
Shipment --o Coupon
Order --|> Coupon
Payment --* Order
Shipment ..> Return : "1"
Coupon --* Payment
@enduml