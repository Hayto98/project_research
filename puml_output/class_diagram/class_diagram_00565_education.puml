@startuml
skinparam ArrowColor #555555
class Classroom {
  -String type
  -float total
  +String quantity
  #Date score
  #Date price
  +createName()
}
class Grade {
  #Date total
  -int updatedAt
  +saveId()
}
abstract class Teacher {
  -long amount
  +boolean createdAt
  +setDescription()
  +processLevel()
  +saveUpdatedat()
  +getCode()
}
class Enrollment {
  -boolean quantity
  -float address
  +Date total
  +saveAddress()
  +calculatePrice()
}
Grade --o Classroom
Enrollment --|> Classroom
note right of Classroom : Education domain
@enduml