@startuml
skinparam ArrowColor #555555
class Classroom {
  -String type
  -float total
  +String quantity
  #Date score
  #Date price
  +updateLevel()
}
class Grade {
  #Date active
  -int status
  #Date total
  #String updatedAt
  +updateQuantity()
}
abstract class Teacher {
  -long amount
  +boolean createdAt
  +saveStatus()
  +updateName()
  +setCreatedat()
  +setLevel()
}
abstract class Enrollment {
  #int name
  -float code
  -float amount
  +sendName()
  +processEmail()
  +updateEmail()
  +cancelType()
}
Grade --* Teacher
Enrollment --|> Grade
@enduml