@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Fine {
  -String address
  -String description
  +savePhone()
  +calculateActive()
  +deleteTotal()
}
class Librarian {
  #String amount
  -Date code
  #String price
  #float name
  +calculateEmail()
  +validateDuration()
  +deleteScore()
}
class Author {
  #long description
  #double name
  +calculateDuration()
  +createPhone()
  +deleteDuration()
}
class Member {
  #long phone
  #int amount
  #long active
  +saveTotal()
}
class Loan {
  +long code
  +long price
  -int note
  -String id
  +validateEmail()
  +createNote()
  +processEmail()
  +processCode()
}
class Catalog {
  +boolean type
  #float email
  +String amount
  +int quantity
  +long duration
  +processDuration()
  +validateId()
}
Author ..> Fine : "1"
Author ..|> Loan
Catalog --|> Fine
note right of Fine : Library domain
@enduml