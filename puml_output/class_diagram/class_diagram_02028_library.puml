@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Fine {
  -String address
  -String description
  +getAmount()
  +cancelType()
  +updateTotal()
}
abstract class Librarian {
  +String total
  -boolean code
  +Date address
  +deleteName()
}
class Author {
  #Date price
  -boolean email
  +int phone
  #String amount
  +sendUpdatedat()
  +saveCode()
  +deleteCreatedat()
}
abstract class Member {
  #long phone
  +boolean description
  #boolean id
  -Date amount
  +sendActive()
  +createQuantity()
}
class Loan {
  -String phone
  +long level
  +long email
  -int code
  -String price
  +createAmount()
  +setPrice()
  +cancelPhone()
  +processDescription()
}
abstract class Catalog {
  -long email
  #int note
  -double code
  +boolean status
  #float price
  +calculateId()
  +saveLevel()
}
Librarian --* Catalog
Catalog --o Librarian
Loan --|> Author
@enduml