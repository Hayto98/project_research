@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
interface Restaurant {
  +String id
  #int updatedAt
  -long type
  +int createdAt
  +float code
  +validateCreatedat()
  +calculateActive()
  +setScore()
  +processActive()
}
class Room {
  #double note
  -long id
  -int address
  +processScore()
  +findPrice()
}
class Guest {
  +String updatedAt
  -String note
  -int score
  +validateAddress()
}
class Service {
  #boolean code
  +Date level
  +String description
  +findName()
}
interface Reservation {
  #float phone
  +long id
  #boolean createdAt
  #int amount
  +cancelNote()
  +deleteId()
  +calculateName()
  +getName()
}
Guest ..|> Room
Guest --o Restaurant
@enduml