@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
interface Restaurant {
  +String id
  #int updatedAt
  -long type
  +int createdAt
  +float code
  +deleteActive()
  +saveCreatedat()
  +setLevel()
  +deleteNote()
}
class Room {
  -int score
  #boolean price
  +float note
  #String address
  +updateNote()
  +sendDescription()
}
class Guest {
  -int code
  +boolean address
  +Date amount
  #String status
  #int email
  +findId()
}
interface Service {
  #float phone
  +long id
  #boolean createdAt
  #int amount
  +updateAddress()
  +updateAddress()
  +updateCreatedat()
  +saveQuantity()
}
class Reservation {
  -float status
  +int level
  -double address
  +boolean price
  +double amount
  +validateActive()
}
Room --|> Guest
Service --* Restaurant
Room --> Service : "1"
note right of Restaurant : Hotel domain
@enduml