@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Customer {
  +String note
  #double address
  -long phone
  +int quantity
  +saveScore()
  +createDuration()
  +validateLevel()
}
class Transfer {
  +long code
  +float address
  -double price
  +String note
  +int name
  +getAddress()
  +findPhone()
}
class Transaction {
  #Date status
  #double score
  +calculateDuration()
}
abstract class Branch {
  -double price
  +double updatedAt
  #int score
  +setQuantity()
}
class Interest {
  #int address
  #int amount
  #Date duration
  -float active
  +createEmail()
}
abstract class Account {
  -double price
  -long name
  +Date amount
  +processId()
  +cancelUpdatedat()
  +validateId()
}
Transfer --> Branch : "1"
Customer --|> Account
Customer --|> Branch
@enduml