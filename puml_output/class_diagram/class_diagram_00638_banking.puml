@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Customer {
  +String note
  #double address
  -long phone
  +int quantity
  +validatePrice()
  +createDuration()
  +findTotal()
}
class Transfer {
  -String price
  -double note
  +String name
  +int updatedAt
  +calculateDescription()
  +updateName()
}
class Transaction {
  #float level
  -int status
  #boolean score
  -double type
  +double createdAt
  +setAmount()
  +saveQuantity()
}
class Branch {
  #int address
  #Date active
  -float updatedAt
  +processLevel()
}
class Interest {
  -int name
  #long amount
  #Date total
  +int price
  +double email
  +setName()
}
class Account {
  +boolean note
  -Date code
  +sendEmail()
  +updateDescription()
  +validateAddress()
  +validateType()
}
Account ..|> Transaction
Interest --|> Branch
Customer ..> Transfer : "0..1"
note right of Customer : Banking domain
@enduml