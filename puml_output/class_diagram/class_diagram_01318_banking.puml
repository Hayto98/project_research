@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
interface Branch {
  -Date phone
  +int id
  +cancelType()
  +sendDuration()
  +cancelStatus()
}
interface Card {
  +long type
  +long duration
  #String level
  +sendAmount()
}
interface Withdrawal {
  -double level
  +double score
  +float note
  #Date description
  +String updatedAt
  +createLevel()
}
interface Transfer {
  -float price
  +double score
  -float total
  +String type
  +sendPhone()
  +sendDescription()
  +findDuration()
  +cancelEmail()
}
Branch --* Transfer
Withdrawal --o Card
Withdrawal --|> Transfer
note right of Branch : Banking domain
@enduml