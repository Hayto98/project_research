@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
interface Branch {
  -Date phone
  +int id
  +saveDuration()
  +getId()
  +cancelAmount()
}
interface Card {
  #double score
  -boolean amount
  +setDuration()
  +getEmail()
  +getNote()
  +sendId()
}
class Withdrawal {
  +float status
  #Date score
  +deleteUpdatedat()
  +setAddress()
  +cancelLevel()
  +sendLevel()
}
abstract class Transfer {
  +double updatedAt
  +float quantity
  #Date note
  +setUpdatedat()
}
Withdrawal --> Transfer : "1..*"
Transfer --o Withdrawal
@enduml