@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
abstract class Customer {
  -double type
  +long score
  -long code
  +updateNote()
  +getName()
}
class Warehouse {
  +double updatedAt
  #Date quantity
  +cancelEmail()
  +processNote()
}
class Invoice {
  -int score
  -long price
  +processNote()
}
interface Cart {
  #boolean score
  +double description
  -float note
  -String price
  +updateCode()
  +getId()
}
class Category {
  +double description
  +boolean phone
  +processActive()
  +findStatus()
}
Cart ..> Invoice : "*"
Category ..> Cart : "*"
Cart --> Customer : "1"
Customer ..> Cart : "0..1"
@enduml