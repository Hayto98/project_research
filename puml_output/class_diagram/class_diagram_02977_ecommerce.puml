@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
abstract class Customer {
  -double type
  +long score
  -long code
  +sendCreatedat()
  +setUpdatedat()
}
class Warehouse {
  #int note
  +Date active
  +setScore()
  +calculatePhone()
  +updateType()
}
class Invoice {
  #Date score
  +double address
  +sendScore()
  +setNote()
  +createTotal()
  +getAmount()
}
abstract class Cart {
  +float score
  #int duration
  +updateType()
  +updateScore()
  +updateCreatedat()
}
interface Category {
  -String email
  #String note
  #String score
  #boolean price
  -float active
  +findCode()
  +deleteActive()
}
Warehouse ..> Customer : "1"
Invoice --> Warehouse : "0..1"
Invoice ..> Customer : "1"
Customer --|> Invoice
note right of Customer : Ecommerce domain
@enduml