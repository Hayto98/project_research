@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Tracking {
  #boolean address
  -double type
  #long amount
  #Date note
  -double status
  +findId()
  +deleteEmail()
  +validatePrice()
  +findType()
}
interface Warehouse {
  +float code
  +String createdAt
  +deleteCode()
  +createActive()
  +updateActive()
}
class Vehicle {
  -boolean id
  +boolean active
  +long level
  #String quantity
  #float price
  +validateTotal()
  +processStatus()
  +createScore()
  +createType()
}
interface Customer {
  -long price
  #Date id
  #double code
  +validateTotal()
}
abstract class FuelLog {
  -Date note
  +double amount
  +long total
  +deleteAmount()
  +saveDuration()
  +findCode()
}
class Driver {
  -long level
  -String createdAt
  #double score
  -boolean description
  +float code
  +saveType()
  +setEmail()
}
class Route {
  +boolean score
  +long amount
  +validateStatus()
  +setUpdatedat()
}
Vehicle --|> Driver
FuelLog ..> Tracking : "*"
Warehouse --o Vehicle
Route --|> Customer
Warehouse ..> Route : "0..1"
FuelLog --|> Route
@enduml