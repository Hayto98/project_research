@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Tracking {
  #boolean address
  -double type
  #long amount
  #Date note
  -double status
  +deleteLevel()
  +setCode()
  +updateId()
  +setCode()
}
class Warehouse {
  #String address
  #boolean id
  -boolean amount
  #double price
  +sendCode()
  +cancelCreatedat()
  +createStatus()
}
abstract class Vehicle {
  #float updatedAt
  +Date active
  +double amount
  -Date price
  +sendId()
  +findNote()
  +deleteNote()
  +deleteTotal()
}
class Customer {
  -Date price
  -double description
  +createPrice()
  +cancelCreatedat()
  +sendDescription()
}
class FuelLog {
  #float phone
  +float quantity
  +float name
  -String total
  +float price
  +deleteScore()
  +setAddress()
}
class Driver {
  #String level
  #String email
  +deleteQuantity()
  +calculateType()
  +getUpdatedat()
  +updateDuration()
}
class Route {
  -long score
  +String address
  +getEmail()
  +sendName()
  +validateUpdatedat()
}
Tracking ..|> Route
Vehicle --* Route
note right of Tracking : Logistics domain
@enduml