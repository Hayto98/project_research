@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Exam {
  +int description
  -Date active
  #Date status
  -String total
  #float address
  +findQuantity()
}
abstract class Book {
  -double level
  +boolean createdAt
  #Date code
  +calculateDuration()
  +validateCreatedat()
}
class Assignment {
  +long name
  #Date score
  +long id
  #long phone
  +Date note
  +createPrice()
  +sendPhone()
  +setName()
}
abstract class Course {
  #String createdAt
  #boolean duration
  +long quantity
  +String id
  +Date description
  +updateNote()
  +calculateName()
  +getPrice()
  +createTotal()
}
class Student {
  -long email
  +String status
  -String price
  +findPhone()
}
Exam ..|> Book
Exam --> Assignment : "1..*"
@enduml