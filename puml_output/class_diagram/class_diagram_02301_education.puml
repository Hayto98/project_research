@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Exam {
  +int description
  -Date active
  #Date status
  -String total
  #float address
  +validateType()
}
interface Book {
  -double level
  +boolean createdAt
  #Date code
  +sendDescription()
  +saveStatus()
}
abstract class Assignment {
  -Date score
  #double id
  +createScore()
}
class Course {
  -long level
  +double address
  -int description
  +long phone
  +deleteStatus()
}
interface Student {
  +String address
  #float status
  +sendAddress()
  +findName()
  +updateEmail()
  +setPrice()
}
Assignment --|> Exam
Student ..|> Exam
note right of Exam : Education domain
@enduml