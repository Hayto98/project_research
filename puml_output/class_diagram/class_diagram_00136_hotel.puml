@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
interface Guest {
  +String duration
  +int phone
  #Date createdAt
  #int amount
  -Date note
  +getType()
}
class Payment {
  -long duration
  -int type
  #boolean level
  +cancelDescription()
  +validateCode()
  +getName()
  +saveNote()
}
class Housekeeping {
  +double status
  #int name
  #String address
  +boolean note
  +saveType()
}
class CheckIn {
  #String price
  -boolean type
  +boolean address
  +double score
  +deleteCreatedat()
  +updatePrice()
}
class Restaurant {
  -boolean duration
  #float status
  +saveId()
}
Payment --* Guest
Housekeeping --|> Payment
CheckIn --o Restaurant
@enduml