@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
interface Guest {
  +String duration
  +int phone
  #Date createdAt
  #int amount
  -Date note
  +setCreatedat()
}
class Payment {
  +Date duration
  #float type
  #boolean email
  -Date quantity
  +float score
  +deleteAddress()
  +saveStatus()
}
class Housekeeping {
  +Date note
  +String updatedAt
  #String duration
  +boolean active
  +calculateType()
  +validateAddress()
  +findStatus()
}
abstract class CheckIn {
  -float duration
  +long description
  +setId()
}
interface Restaurant {
  #float note
  +String score
  +updateCode()
  +createPhone()
  +updateStatus()
  +saveNote()
}
CheckIn --> Restaurant : "0..1"
Payment --> CheckIn : "*"
note right of Guest : Hotel domain
@enduml