@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Assignment {
  -String name
  #boolean active
  -int duration
  +sendDescription()
  +saveDuration()
  +updateNote()
  +setDescription()
}
class Grade {
  -Date amount
  #Date updatedAt
  -boolean note
  +Date description
  +createCode()
  +saveAddress()
  +createNote()
}
class Exam {
  #Date quantity
  #float duration
  +int description
  #String email
  +updateAmount()
  +setScore()
  +findQuantity()
}
abstract class Attendance {
  +String id
  -float createdAt
  +Date note
  +updatePrice()
  +validateId()
}
interface Schedule {
  +double phone
  #Date type
  +int description
  #String email
  +cancelType()
  +cancelPhone()
  +createDuration()
}
abstract class Student {
  -int amount
  #long updatedAt
  +validateAmount()
  +validatePrice()
}
interface Course {
  -float code
  -Date email
  +long price
  +String active
  #Date level
  +updateEmail()
}
Exam --> Schedule : "1"
Attendance --> Schedule : "1"
Assignment --|> Grade
Exam ..> Assignment : "*"
Course --o Exam
@enduml