@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Assignment {
  -String name
  #boolean active
  -int duration
  +cancelActive()
  +setQuantity()
  +createAmount()
  +updateNote()
}
class Grade {
  +long type
  -long level
  -int status
  -boolean email
  #Date amount
  +deleteCode()
  +createAddress()
}
abstract class Exam {
  +String id
  -float createdAt
  +Date note
  +getStatus()
  +cancelEmail()
}
class Attendance {
  +Date description
  +long email
  -double status
  -String total
  #int createdAt
  +validateUpdatedat()
  +sendQuantity()
}
class Schedule {
  -boolean score
  -double total
  -Date code
  +long email
  +setActive()
  +saveName()
}
abstract class Student {
  +int quantity
  +long active
  +Date code
  -float note
  -float id
  +updateEmail()
  +findEmail()
  +updatePrice()
  +findTotal()
}
interface Course {
  #float status
  +double score
  +deleteUpdatedat()
  +deleteDescription()
}
Schedule --* Student
Schedule --|> Attendance
Course --|> Exam
Assignment --o Course
note right of Assignment : Education domain
@enduml