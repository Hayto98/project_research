@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
interface Tracking {
  +double name
  -long score
  +createAmount()
}
class Manifest {
  +String createdAt
  #Date code
  -boolean level
  +float updatedAt
  #int email
  +calculateDuration()
  +saveType()
  +updateAmount()
}
class FuelLog {
  -double phone
  #double updatedAt
  -int type
  +long total
  -double name
  +deletePrice()
  +getTotal()
  +updateStatus()
  +saveAddress()
}
abstract class Vehicle {
  -long phone
  #Date score
  +updateStatus()
  +getScore()
}
Tracking --|> FuelLog
FuelLog --* Tracking
@enduml