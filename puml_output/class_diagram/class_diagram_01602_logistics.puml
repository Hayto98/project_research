@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
interface Tracking {
  +double name
  -long score
  +validateCreatedat()
}
abstract class Manifest {
  -String code
  +float duration
  #Date updatedAt
  +sendUpdatedat()
  +cancelUpdatedat()
  +createScore()
  +deleteType()
}
class FuelLog {
  -double type
  #double total
  -int name
  +createTotal()
  +calculateNote()
}
abstract class Vehicle {
  +long updatedAt
  #float amount
  -long price
  +updateActive()
  +processCode()
}
Tracking --* FuelLog
Tracking --|> Manifest
note right of Tracking : Logistics domain
@enduml