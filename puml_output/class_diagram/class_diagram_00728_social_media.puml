@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
abstract class Hashtag {
  -float id
  #int status
  +int price
  +calculateCode()
  +setName()
  +processActive()
  +setTotal()
}
class Follower {
  -String email
  -String status
  +validateEmail()
  +calculatePhone()
  +calculateAmount()
}
interface Group {
  #long createdAt
  -double quantity
  #Date price
  +Date amount
  +processCode()
  +findNote()
  +updateId()
}
class Post {
  #double id
  #float email
  +boolean level
  +validateEmail()
  +processDuration()
}
class Story {
  +String description
  #Date id
  #int name
  +createDuration()
}
class Notification {
  -double note
  -Date status
  +boolean level
  -String phone
  +updatePrice()
  +calculateCode()
  +createUpdatedat()
  +deleteActive()
}
class Report {
  +String duration
  +Date name
  +boolean updatedAt
  -float total
  +processEmail()
  +validateType()
}
Story --o Hashtag
Group --> Report : "1"
Story --o Group
Hashtag ..|> Follower
Hashtag ..> Group : "*"
Group --|> Post
@enduml