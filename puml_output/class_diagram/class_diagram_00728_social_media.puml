@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
abstract class Hashtag {
  -float id
  #int status
  +int price
  +calculateId()
  +updateQuantity()
  +setCode()
  +createStatus()
}
abstract class Follower {
  -String phone
  -double name
  +updateQuantity()
  +cancelPrice()
  +deleteActive()
}
class Group {
  +Date total
  +int id
  +long email
  -Date level
  +cancelStatus()
  +cancelLevel()
  +updateStatus()
  +updateQuantity()
}
class Post {
  +boolean id
  #boolean name
  +String updatedAt
  +getQuantity()
  +processStatus()
  +setScore()
  +validateType()
}
abstract class Story {
  +double name
  #double level
  +long email
  #String code
  +double price
  +getDescription()
  +saveDescription()
}
interface Notification {
  -long amount
  #String level
  #long score
  -String status
  +int note
  +createNote()
}
class Report {
  #double name
  #long createdAt
  #long note
  +String total
  -Date price
  +saveCreatedat()
  +calculatePhone()
  +findUpdatedat()
}
Story --|> Group
Group --* Notification
Notification ..|> Follower
note right of Hashtag : Social Media domain
@enduml