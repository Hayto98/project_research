@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Billing {
  +Date active
  #long code
  +updateType()
  +validateTotal()
  +deleteDuration()
  +createPrice()
}
class LabTest {
  -boolean id
  #int active
  #String createdAt
  -float updatedAt
  +int amount
  +sendDescription()
  +deleteDescription()
  +getNote()
  +calculateEmail()
}
class Prescription {
  -double address
  +int note
  +deleteCode()
  +findPrice()
  +setScore()
  +updateAmount()
}
interface MedicalRecord {
  +double duration
  #int code
  +getPhone()
  +calculateType()
}
interface Nurse {
  -int quantity
  #String type
  +float email
  #String price
  -int description
  +createStatus()
  +sendEmail()
}
class Treatment {
  -String code
  +String createdAt
  -boolean note
  #Date price
  +int address
  +updateAmount()
  +calculateDuration()
}
abstract class Appointment {
  +Date code
  +String updatedAt
  +int active
  +saveEmail()
}
Prescription ..|> Nurse
MedicalRecord ..> Treatment : "*"
Treatment --> Prescription : "*"
@enduml