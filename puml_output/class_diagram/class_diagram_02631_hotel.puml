@startuml
skinparam monochrome true
skinparam shadowing true
class Service {
  +Date price
  #boolean score
  +int id
  -double createdAt
  +updateId()
}
interface Room {
  +Date createdAt
  #String status
  +int total
  +float updatedAt
  +saveId()
  +sendActive()
  +getPrice()
}
class Reservation {
  #Date address
  #int updatedAt
  -boolean amount
  +float type
  -boolean description
  +findAddress()
}
class Payment {
  +boolean status
  +float note
  +long updatedAt
  #int level
  +processScore()
  +createTotal()
  +saveCreatedat()
  +updateEmail()
}
class Staff {
  +int status
  -String code
  #int description
  +sendPrice()
}
class Guest {
  +boolean duration
  -int updatedAt
  #Date description
  -boolean amount
  +long name
  +updatePhone()
  +validateAmount()
}
Service --|> Room
Guest --> Staff : "0..1"
@enduml