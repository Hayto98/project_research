@startuml

class Fine {
  #int score
  #Date code
  +double level
  -int amount
  +getEmail()
  +processId()
}
class Author {
  #String id
  +Date score
  -int createdAt
  #boolean level
  -String address
  +processDescription()
}
class Reservation {
  #float updatedAt
  +String amount
  -float email
  #float total
  +cancelType()
  +validateEmail()
  +saveScore()
  +calculateScore()
}
class Member {
  #boolean description
  -double note
  +boolean phone
  +createPrice()
  +getDuration()
  +validatePhone()
}
Reservation ..|> Author
Member --|> Author
Reservation --> Fine : "1..*"
@enduml