@startuml

class Fine {
  #int score
  #Date code
  +double level
  -int amount
  +deleteLevel()
  +deleteTotal()
}
class Author {
  +Date createdAt
  -int address
  #boolean status
  +setActive()
  +cancelId()
  +createCreatedat()
}
interface Reservation {
  #float updatedAt
  +String amount
  -float email
  #float total
  +setPhone()
  +createEmail()
  +updateDescription()
  +processPhone()
}
interface Member {
  -float total
  +long description
  -double active
  +Date address
  +calculateName()
  +findDuration()
  +validateCode()
  +cancelPhone()
}
Member --o Fine
Reservation --* Fine
Member ..> Author : "*"
note right of Fine : Library domain
@enduml