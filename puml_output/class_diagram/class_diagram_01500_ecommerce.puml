@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Category {
  +float status
  #float active
  -Date id
  +Date quantity
  +int phone
  +saveUpdatedat()
  +saveScore()
}
class Cart {
  +long email
  +String phone
  -boolean amount
  +deleteDuration()
  +calculateEmail()
  +sendDuration()
  +cancelTotal()
}
class Review {
  #long address
  +String type
  -Date email
  +deleteCode()
  +calculateId()
}
abstract class Supplier {
  -Date code
  -long description
  -Date quantity
  +getEmail()
}
Cart ..> Supplier : "1"
Supplier --|> Cart
note right of Category : Ecommerce domain
@enduml