@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Category {
  +float status
  #float active
  -Date id
  +Date quantity
  +int phone
  +cancelDuration()
  +calculateLevel()
}
class Cart {
  -Date score
  +String level
  -String createdAt
  +double email
  +updateType()
  +findUpdatedat()
  +updateAmount()
  +updateEmail()
}
class Review {
  #long quantity
  +String amount
  -Date address
  #int type
  +String email
  +saveUpdatedat()
  +processName()
  +cancelCode()
  +validateDescription()
}
class Supplier {
  -Date description
  -long quantity
  +calculateUpdatedat()
  +findType()
  +setDescription()
}
Review --|> Supplier
Cart ..> Supplier : "1"
@enduml