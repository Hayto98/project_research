@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Enrollment {
  +double status
  #float type
  +sendLevel()
  +saveEmail()
  +calculatePhone()
}
abstract class Department {
  +double description
  -Date level
  #String amount
  #float email
  +sendQuantity()
  +sendType()
  +createStatus()
  +sendId()
}
class Teacher {
  +double name
  #float active
  +float quantity
  +int total
  +getPhone()
  +sendScore()
  +updateDescription()
  +deleteDuration()
}
class Attendance {
  +boolean status
  +boolean description
  -float address
  +String note
  +long id
  +validateNote()
}
Enrollment --o Teacher
Attendance ..> Enrollment : "1"
@enduml