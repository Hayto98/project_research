}
abstract class Teacher {
  +int total
  #double status
  +calculateCreatedat()
  +processCreatedat()
  +processStatus()
  +deleteAddress()
}
abstract class Attendance {
  +boolean description
  -float active
  +setUpdatedat()
  +createStatus()
}
Attendance ..> Enrollment : "*"
note right of Enrollment : Education domain
@enduml