@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Payment {
  -boolean note
  -long total
  +long type
  -double quantity
  -float id
  +processType()
}
abstract class Room {
  -long quantity
  -float total
  -long description
  +float amount
  -float status
  +validateCreatedat()
  +sendDescription()
  +validateDescription()
}
class Invoice {
  #boolean description
  #boolean type
  -double code
  +String level
  -long email
  +processType()
  +calculateCreatedat()
}
class Restaurant {
  #String description
  +Date duration
  +calculateScore()
}
Payment --o Room
Room --|> Restaurant
Restaurant --* Room
@enduml