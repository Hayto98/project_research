@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Staff {
  +boolean createdAt
  -float email
  +createNote()
  +cancelStatus()
  +deleteName()
}
class Reservation {
  #Date address
  +float id
  -int price
  +calculateCode()
  +sendActive()
  +validateScore()
}
class Amenity {
  +float phone
  #float active
  +int type
  +updateCreatedat()
  +processPhone()
  +validateNote()
}
class Booking {
  -double quantity
  #int name
  +savePrice()
  +setUpdatedat()
}
Staff --|> Amenity
Amenity --* Booking
@enduml