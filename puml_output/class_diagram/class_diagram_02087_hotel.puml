@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Staff {
  +boolean createdAt
  -float email
  +setEmail()
  +updateCreatedat()
  +validateId()
}
abstract class Reservation {
  -double note
  #long amount
  +updatePhone()
  +sendType()
}
class Amenity {
  +Date amount
  +String email
  +findName()
  +calculateNote()
  +findCreatedat()
}
interface Booking {
  +boolean level
  +long name
  #long updatedAt
  +createNote()
  +deleteEmail()
  +calculatePrice()
  +findDescription()
}
Amenity ..> Reservation : "*"
Staff ..> Amenity : "*"
note right of Staff : Hotel domain
@enduml