@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Student {
  +Date score
  -long price
  #float level
  +float createdAt
  +getAddress()
  +cancelUpdatedat()
  +findQuantity()
}
class Assignment {
  +int createdAt
  +Date description
  +deleteAddress()
  +createAddress()
  +updatePhone()
  +processAddress()
}
interface Teacher {
  #long note
  +long amount
  -double id
  +findCreatedat()
  +validateNote()
  +validateUpdatedat()
  +validateNote()
}
interface Grade {
  #String level
  -long price
  #long active
  #float email
  +long id
  +calculatePrice()
  +deleteId()
  +getQuantity()
  +createStatus()
}
class Enrollment {
  +String id
  -int note
  #int score
  -float name
  +setQuantity()
  +createActive()
  +sendDescription()
}
Enrollment --o Grade
note right of Student : Education domain
@enduml