@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Student {
  +Date score
  -long price
  #float level
  +float createdAt
  +updateActive()
  +saveCreatedat()
  +cancelActive()
}
class Assignment {
  +int quantity
  +Date code
  -float createdAt
  +long description
  +createActive()
  +createScore()
  +updateTotal()
}
abstract class Teacher {
  #boolean level
  +Date updatedAt
  -int note
  -double amount
  +findDuration()
  +calculateQuantity()
  +cancelName()
  +cancelNote()
}
class Grade {
  #Date phone
  -float updatedAt
  #long address
  +boolean note
  +double price
  +deleteId()
  +calculateDuration()
  +getStatus()
}
class Enrollment {
  #double quantity
  +float total
  +float price
  +updateAddress()
}
Teacher --|> Student
Grade --|> Student
@enduml