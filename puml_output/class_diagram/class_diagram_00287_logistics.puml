@startuml
skinparam defaultFontSize 13
class Warehouse {
  +long amount
  +Date note
  #int total
  +getName()
  +findActive()
  +sendName()
}
class Shipment {
  +Date code
  #Date level
  +float createdAt
  +deleteActive()
}
interface Depot {
  -int level
  -float phone
  #long name
  #float score
  #float active
  +saveDuration()
  +findCreatedat()
}
class Manifest {
  -long status
  #String level
  -boolean active
  +float id
  +validateDescription()
  +setCreatedat()
  +deleteDescription()
}
interface Vehicle {
  +int amount
  #String description
  -String score
  +processLevel()
  +createScore()
}
class Driver {
  -boolean price
  #int type
  +deleteName()
}
Manifest --o Shipment
Depot --|> Vehicle
Shipment --> Manifest : "1"
Depot ..|> Driver
note right of Warehouse : Logistics domain
@enduml