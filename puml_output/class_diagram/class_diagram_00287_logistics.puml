@startuml
skinparam defaultFontSize 13
class Warehouse {
  +long amount
  +Date note
  #int total
  +updatePrice()
  +saveId()
  +cancelUpdatedat()
}
interface Shipment {
  +boolean description
  +int updatedAt
  +getName()
}
class Depot {
  +String active
  +double note
  +long phone
  +processAddress()
  +saveDuration()
  +sendStatus()
}
interface Manifest {
  -String duration
  #boolean createdAt
  +double address
  +cancelActive()
  +createPhone()
  +cancelId()
}
interface Vehicle {
  +float phone
  +Date duration
  +findId()
  +setLevel()
}
interface Driver {
  +int amount
  #String description
  -String score
  +saveAmount()
  +savePrice()
}
Vehicle --> Warehouse : "1"
Manifest --o Driver
Vehicle ..> Shipment : "1"
Shipment --o Warehouse
@enduml