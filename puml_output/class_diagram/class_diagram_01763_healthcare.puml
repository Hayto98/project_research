@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
abstract class Billing {
  -int id
  -double address
  -double createdAt
  +int duration
  +calculateTotal()
  +sendPhone()
  +getDescription()
}
class Prescription {
  #String score
  -long createdAt
  #int quantity
  +Date type
  +float updatedAt
  +cancelAddress()
  +updateLevel()
  +deletePrice()
  +findDescription()
}
class Doctor {
  +String quantity
  #long score
  +long updatedAt
  +updateCode()
}
interface LabTest {
  +boolean name
  -Date note
  #double amount
  +saveTotal()
  +deleteCreatedat()
  +findId()
  +deleteAddress()
}
class Patient {
  +double duration
  -String level
  -long phone
  +processQuantity()
  +validateCreatedat()
  +getType()
}
class Appointment {
  +float email
  -int active
  +int total
  +cancelTotal()
  +deleteQuantity()
  +getCode()
  +processPrice()
}
interface Insurance {
  #double name
  -String type
  -Date amount
  +saveCreatedat()
}
LabTest --* Appointment
Doctor ..|> LabTest
Patient ..> Doctor : "1"
Patient --o Insurance
Patient ..|> LabTest
@enduml