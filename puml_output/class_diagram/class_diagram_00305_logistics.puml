@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Warehouse {
  +double id
  +String quantity
  +float status
  -Date total
  +updateStatus()
  +validateId()
}
class Customer {
  +boolean level
  #double description
  +float id
  +double createdAt
  +sendEmail()
  +calculateTotal()
}
class Vehicle {
  +double createdAt
  +float quantity
  +long email
  -Date note
  +long updatedAt
  +createNote()
}
abstract class Shipment {
  #long total
  -int id
  #int price
  +boolean type
  +saveDuration()
  +createTotal()
  +deleteId()
  +getDuration()
}
Customer --> Warehouse : "1"
Vehicle --o Warehouse
note right of Warehouse : Logistics domain
@enduml