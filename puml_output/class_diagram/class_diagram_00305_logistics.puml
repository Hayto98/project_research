@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Warehouse {
  +double id
  +String quantity
  +float status
  -Date total
  +deleteTotal()
  +findLevel()
}
class Customer {
  +long phone
  #int id
  +processScore()
}
class Vehicle {
  -float active
  +float score
  +sendCode()
}
class Shipment {
  +Date total
  -long duration
  -int address
  +double level
  +validateStatus()
}
Vehicle ..> Customer : "0..1"
Vehicle --* Warehouse
@enduml