@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
interface Exam {
  -long quantity
  +boolean active
  #Date type
  -float status
  +Date total
  +saveQuantity()
}
class Enrollment {
  #int active
  -String duration
  #String amount
  -boolean phone
  +getType()
  +validatePhone()
  +findId()
}
class Teacher {
  #long score
  -double updatedAt
  +Date active
  -Date phone
  +updateAmount()
}
class Book {
  +boolean code
  #boolean active
  -float phone
  #long duration
  #int type
  +createTotal()
  +getPhone()
}
interface Schedule {
  #long duration
  +String price
  +boolean name
  +processQuantity()
  +cancelDuration()
}
Exam ..|> Teacher
Teacher ..> Schedule : "*"
Teacher --|> Enrollment
@enduml