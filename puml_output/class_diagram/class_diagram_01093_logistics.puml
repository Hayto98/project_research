@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class FuelLog {
  #float phone
  +int level
  #long total
  +String createdAt
  +int address
  +findActive()
  +validateAmount()
}
class Shipment {
  #int status
  #int note
  #float updatedAt
  +String price
  -String amount
  +createStatus()
  +processType()
  +validatePhone()
  +createScore()
}
interface Customer {
  -double duration
  -int status
  -String total
  +getEmail()
  +createPhone()
}
abstract class Manifest {
  +int type
  +boolean note
  +calculateDescription()
  +updateDuration()
  +validateDescription()
}
class Route {
  -long address
  -String note
  -long name
  +deleteTotal()
  +getQuantity()
}
class Vehicle {
  #float level
  +long id
  #String name
  +getType()
  +sendPhone()
  +processPhone()
}
Manifest --* Vehicle
Customer --> Vehicle : "0..1"
Manifest ..> Route : "1..*"
@enduml