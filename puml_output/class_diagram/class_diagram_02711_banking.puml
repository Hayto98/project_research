@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
abstract class Account {
  -boolean total
  #double id
  -String score
  +String description
  +cancelTotal()
  +findPhone()
}
class Statement {
  +boolean level
  -double status
  +long quantity
  -boolean price
  -int updatedAt
  +getCode()
}
abstract class Loan {
  #int duration
  #String code
  -Date amount
  +setDuration()
  +cancelLevel()
  +getId()
}
class Card {
  #double code
  -long phone
  #int description
  -long status
  +int total
  +setEmail()
  +deleteQuantity()
  +createPrice()
}
class Interest {
  -String email
  +int address
  +Date note
  +getType()
  +deleteCode()
  +validateCode()
}
Loan ..> Interest : "*"
Account ..|> Card
Account --|> Interest
Interest --> Loan : "1..*"
@enduml