@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Hospital {
  -float active
  +double price
  #boolean description
  +calculateCode()
  +deleteId()
  +findName()
}
abstract class Insurance {
  #double code
  -long description
  +float name
  +updateQuantity()
  +processDuration()
  +createLevel()
  +saveLevel()
}
class Prescription {
  -boolean updatedAt
  -double score
  +double status
  -String description
  #double code
  +processScore()
}
class Doctor {
  +double active
  +int price
  +updateTotal()
  +saveLevel()
}
class LabTest {
  -Date description
  +long status
  -int level
  +createCode()
}
class MedicalRecord {
  -double amount
  +float updatedAt
  +String total
  +calculateId()
  +cancelEmail()
  +processAddress()
}
Prescription ..> Hospital : "*"
Insurance --|> Hospital
Doctor --> Insurance : "1..*"
note right of Hospital : Healthcare domain
@enduml