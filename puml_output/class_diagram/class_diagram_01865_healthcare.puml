@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Hospital {
  -float active
  +double price
  #boolean description
  +findAmount()
  +validatePhone()
  +findId()
}
class Insurance {
  +int note
  +boolean description
  +validateStatus()
  +deleteName()
  +updateLevel()
  +findAddress()
}
abstract class Prescription {
  #Date quantity
  #float type
  #String email
  +updateAmount()
  +deletePhone()
  +updateStatus()
  +createStatus()
}
class Doctor {
  -double code
  +double type
  -String score
  +setCode()
  +calculateDuration()
  +saveId()
  +deletePrice()
}
interface LabTest {
  -int id
  +boolean active
  +int price
  -float duration
  +getActive()
  +findDuration()
}
interface MedicalRecord {
  -Date description
  +long status
  -int level
  +deleteId()
}
Hospital ..|> Insurance
Insurance ..> MedicalRecord : "*"
Doctor ..|> MedicalRecord
Hospital --> MedicalRecord : "1..*"
@enduml