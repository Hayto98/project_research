@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Notification {
  +long total
  -Date price
  +findDuration()
  +cancelNote()
  +updateQuantity()
  +processEmail()
}
interface Message {
  #double phone
  #double quantity
  +double email
  +createDescription()
  +sendDescription()
}
class Post {
  -Date updatedAt
  #int duration
  -int createdAt
  +double name
  +createId()
  +sendDuration()
}
class Hashtag {
  +boolean status
  -float amount
  -int duration
  #double phone
  +float code
  +createCode()
}
abstract class Album {
  -long email
  +boolean note
  +double total
  +setName()
  +createCreatedat()
  +saveAddress()
  +processLevel()
}
abstract class Follower {
  -boolean type
  +long address
  +processNote()
}
Message --|> Hashtag
Notification ..> Post : "1..*"
@enduml