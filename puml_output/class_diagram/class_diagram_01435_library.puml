@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Branch {
  -String duration
  +boolean address
  -long total
  +setCode()
  +saveAddress()
  +sendUpdatedat()
  +findType()
}
class Renewal {
  -int email
  +double type
  +deleteDescription()
}
interface Book {
  #Date price
  +String total
  +sendDuration()
  +setAddress()
  +deleteEmail()
}
class Reservation {
  -double address
  +double updatedAt
  #int email
  +cancelNote()
  +saveId()
  +sendId()
  +saveCreatedat()
}
abstract class Author {
  #long quantity
  -float address
  #String level
  -Date type
  -double score
  +validateAddress()
  +calculateName()
  +sendPrice()
}
class Shelf {
  #long total
  +int phone
  #String address
  +processAmount()
  +saveActive()
  +deleteScore()
}
Book --> Branch : "0..1"
Renewal --|> Shelf
Book --|> Renewal
note right of Branch : Library domain
@enduml