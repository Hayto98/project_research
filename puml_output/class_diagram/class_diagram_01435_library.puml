@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Branch {
  -String duration
  +boolean address
  -long total
  +setDescription()
  +cancelStatus()
  +cancelPrice()
  +validateDuration()
}
interface Renewal {
  -Date type
  -double phone
  +String status
  +savePhone()
  +updateAmount()
  +getEmail()
  +getScore()
}
class Book {
  #Date total
  #String level
  -float updatedAt
  +float code
  -int quantity
  +validateScore()
  +findDescription()
}
class Reservation {
  #int phone
  #boolean type
  #float updatedAt
  -boolean total
  +calculateType()
  +deleteId()
  +deleteStatus()
  +createType()
}
class Author {
  #Date createdAt
  #Date price
  +processDescription()
  +saveCreatedat()
  +setQuantity()
  +processEmail()
}
class Shelf {
  -Date address
  -double email
  -long duration
  -double active
  +boolean code
  +getNote()
  +validateTotal()
  +sendEmail()
  +getPhone()
}
Book --* Author
Renewal --> Shelf : "1"
Author --o Book
Renewal ..|> Author
@enduml