@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Warehouse {
  +boolean active
  #String name
  +createActive()
  +saveTotal()
}
abstract class Shipment {
  #Date code
  -float name
  -int total
  +updateDuration()
}
class Cart {
  -long updatedAt
  -boolean createdAt
  +String amount
  #String description
  #Date type
  +calculateTotal()
}
interface Category {
  +Date quantity
  #long note
  +boolean price
  -float status
  +calculateAddress()
  +saveTotal()
}
interface Return {
  -String email
  #Date quantity
  -double updatedAt
  -boolean status
  -long name
  +calculateActive()
  +validateCode()
  +validateEmail()
  +deleteName()
}
Shipment --> Return : "0..1"
Cart ..> Return : "0..1"
Category --> Warehouse : "0..1"
Shipment --|> Warehouse
@enduml