@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Warehouse {
  +boolean active
  #String name
  +validateTotal()
  +updateCode()
}
class Shipment {
  +long level
  -float quantity
  +int address
  #int updatedAt
  +double id
  +createPhone()
  +sendName()
  +setName()
  +sendStatus()
}
interface Cart {
  +Date quantity
  #long note
  +boolean price
  -float status
  +deleteDuration()
  +cancelTotal()
}
class Category {
  +Date updatedAt
  #double status
  -double name
  #double address
  +calculateActive()
  +deleteStatus()
  +createDuration()
}
class Return {
  +long duration
  -Date active
  +double level
  +cancelUpdatedat()
}
Return --|> Warehouse
Shipment --|> Cart
note right of Warehouse : Ecommerce domain
@enduml