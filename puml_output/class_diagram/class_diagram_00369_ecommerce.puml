@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Return {
  -int active
  +int total
  +sendAmount()
  +getNote()
  +processNote()
}
interface Customer {
  +long phone
  +int quantity
  -boolean note
  +saveName()
  +deleteScore()
  +updateUpdatedat()
  +setCode()
}
class Warehouse {
  -int active
  #float phone
  +processNote()
  +calculateId()
  +processActive()
}
interface Wishlist {
  #int active
  #boolean total
  +createDuration()
  +setNote()
  +updateEmail()
  +processPrice()
}
class Payment {
  -Date status
  #float code
  -float quantity
  +validatePhone()
  +getLevel()
  +updateStatus()
  +setTotal()
}
Payment --o Wishlist
Return --|> Customer
Customer --* Return
Return ..> Payment : "1..*"
@enduml