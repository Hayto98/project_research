@startuml
skinparam monochrome true
skinparam ArrowColor #555555
interface Library {
  -String status
  +int name
  -double email
  #Date note
  #boolean code
  +setType()
  +calculateId()
  +validateType()
}
class Attendance {
  #double description
  -double amount
  +String total
  +processQuantity()
  +processName()
  +cancelCode()
  +setStatus()
}
class Book {
  #boolean status
  #boolean type
  +String active
  -Date name
  +findAddress()
  +createName()
}
class Teacher {
  #double name
  +String code
  -boolean level
  #Date type
  +calculateCreatedat()
  +saveCode()
  +updateType()
  +updateCreatedat()
}
class Assignment {
  -String code
  +float score
  -boolean type
  -String price
  +updatePhone()
  +setDescription()
}
abstract class Exam {
  +Date address
  #Date active
  +boolean duration
  -double amount
  +setStatus()
  +sendDescription()
  +deleteActive()
  +calculatePrice()
}
class Department {
  +String price
  +float email
  #int createdAt
  #Date phone
  +deleteScore()
  +setNote()
  +createPhone()
}
Book --* Exam
Attendance --|> Book
Teacher --|> Assignment
Assignment --|> Department
Assignment --* Library
Library --* Exam
note right of Library : Education domain
@enduml