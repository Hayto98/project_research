@startuml
skinparam monochrome true
skinparam ArrowColor #555555
interface Library {
  -String status
  +int name
  -double email
  #Date note
  #boolean code
  +getType()
  +getId()
  +saveCode()
}
class Attendance {
  +double type
  #double status
  -double updatedAt
  +String description
  +sendCode()
  +updateLevel()
  +sendStatus()
  +saveTotal()
}
abstract class Book {
  +String level
  -long code
  +processScore()
}
abstract class Teacher {
  #String level
  +long score
  +sendType()
  +getActive()
}
class Assignment {
  +float name
  +float address
  -boolean level
  -String duration
  +processTotal()
}
interface Exam {
  +int total
  +boolean createdAt
  -String code
  #double level
  #double type
  +deleteQuantity()
  +calculateLevel()
  +validateNote()
}
abstract class Department {
  -String status
  +float score
  #double amount
  -long updatedAt
  +deleteScore()
  +savePhone()
  +sendUpdatedat()
}
Exam --> Library : "*"
Teacher --|> Department
Assignment ..|> Attendance
Assignment --o Teacher
Library --o Book
@enduml