@startuml

class Loan {
  #Date amount
  -Date duration
  +getAddress()
  +updateScore()
}
abstract class Deposit {
  +double status
  #double note
  +setEmail()
  +saveStatus()
}
class Transfer {
  #int phone
  -String id
  #boolean duration
  +savePrice()
  +getLevel()
  +deleteQuantity()
}
abstract class Withdrawal {
  -String type
  -long email
  -Date address
  +setAmount()
}
class Account {
  #long score
  +float type
  +createDuration()
  +cancelCode()
}
Account --* Deposit
Loan --|> Transfer
note right of Loan : Banking domain
@enduml