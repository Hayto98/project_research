@startuml

class Loan {
  #Date amount
  -Date duration
  +processQuantity()
  +calculateName()
}
class Deposit {
  -Date score
  -int code
  +long status
  #String note
  #float amount
  +savePrice()
  +findUpdatedat()
  +findPhone()
}
class Transfer {
  -String phone
  #boolean updatedAt
  +sendLevel()
  +saveUpdatedat()
  +deleteStatus()
}
abstract class Withdrawal {
  -double level
  +float amount
  +deleteCreatedat()
  +findQuantity()
  +processTotal()
  +deleteQuantity()
}
abstract class Account {
  +String type
  #double name
  #long status
  +float amount
  +sendDescription()
  +cancelAddress()
}
Account --> Loan : "0..1"
Transfer --|> Deposit
Transfer --> Loan : "0..1"
Transfer --|> Withdrawal
@enduml