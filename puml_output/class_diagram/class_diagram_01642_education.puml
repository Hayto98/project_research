@startuml
skinparam monochrome true
class Library {
  +Date price
  #String address
  +Date description
  +createName()
  +updateLevel()
}
class Teacher {
  -boolean updatedAt
  +String name
  -long address
  +createPrice()
  +deleteAddress()
  +processStatus()
}
class Attendance {
  #long updatedAt
  -String id
  -Date code
  +validateLevel()
  +validateQuantity()
  +updateActive()
  +savePhone()
}
class Classroom {
  #boolean amount
  -float quantity
  +createAddress()
  +cancelId()
  +updateCreatedat()
}
Classroom --|> Library
note right of Library : Education domain
@enduml