@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Profile {
  -boolean note
  #float duration
  +float phone
  +cancelId()
  +processStatus()
}
class Message {
  #int score
  -double address
  #String type
  +long updatedAt
  +validateAddress()
  +setQuantity()
}
class User {
  +Date total
  -double price
  +setDuration()
  +findQuantity()
  +sendId()
  +cancelId()
}
abstract class Story {
  -String address
  #float note
  +sendName()
  +updateEmail()
  +setPhone()
}
class Hashtag {
  -float note
  #long status
  +saveQuantity()
  +getName()
  +processId()
  +setPrice()
}
abstract class Post {
  -boolean note
  #float total
  +getType()
  +cancelDescription()
  +validateEmail()
}
class Follower {
  +Date updatedAt
  -String name
  +Date type
  -float createdAt
  #float active
  +setDescription()
  +updateActive()
  +cancelDuration()
  +deleteActive()
}
Post --|> Message
User ..|> Follower
note right of Profile : Social Media domain
@enduml