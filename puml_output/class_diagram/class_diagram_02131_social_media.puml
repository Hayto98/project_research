@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Profile {
  -boolean note
  #float duration
  +float phone
  +getCode()
  +updateDuration()
}
abstract class Message {
  #long description
  #float phone
  +findAddress()
  +sendDescription()
  +findName()
  +cancelNote()
}
class User {
  -long active
  +long code
  +Date description
  +float address
  -double amount
  +updateAddress()
}
abstract class Story {
  #String price
  -String status
  -Date quantity
  -double active
  +boolean id
  +createStatus()
  +validateDescription()
  +processQuantity()
}
class Hashtag {
  -Date code
  +double phone
  #long id
  -Date status
  +cancelTotal()
  +processQuantity()
  +cancelCode()
}
class Post {
  +double price
  -double total
  +updateActive()
  +deleteActive()
  +setPhone()
}
class Follower {
  +float email
  -int id
  #boolean price
  +String updatedAt
  +processCode()
  +validatePhone()
  +calculateUpdatedat()
  +validateScore()
}
Follower --> Post : "*"
Profile ..|> Post
Message --> Hashtag : "0..1"
Post --|> Hashtag
Post --|> Message
User ..|> Follower
@enduml