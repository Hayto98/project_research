@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Branch {
  #long address
  #boolean name
  +double phone
  -float email
  +setId()
  +createPhone()
}
interface Statement {
  #long description
  +boolean total
  +Date note
  -int duration
  -float status
  +createUpdatedat()
}
class Account {
  -double createdAt
  +float price
  -int code
  +int active
  +float address
  +calculateCode()
  +updateLevel()
}
interface Teller {
  #long price
  +Date duration
  +long description
  -int type
  -int id
  +validateEmail()
}
class Loan {
  #double quantity
  +double description
  -boolean price
  -Date type
  -int score
  +findAddress()
  +updateId()
}
abstract class Beneficiary {
  +long level
  -double address
  -String code
  -float total
  -long amount
  +findPhone()
  +sendName()
}
class Interest {
  #int description
  +Date note
  +Date email
  +sendAmount()
  +deleteLevel()
  +setPhone()
  +createActive()
}
Teller --> Loan : "1"
Account --|> Interest
Interest --|> Statement
Branch --o Statement
Beneficiary ..> Interest : "*"
Account ..|> Statement
note right of Branch : Banking domain
@enduml