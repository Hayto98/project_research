@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Branch {
  #long address
  #boolean name
  +double phone
  -float email
  +validateId()
  +validateDescription()
}
class Statement {
  -Date phone
  -int score
  +Date total
  -int description
  +sendPrice()
}
class Account {
  -int email
  -double level
  +double name
  +updateNote()
}
class Teller {
  +int total
  +double code
  +int note
  #boolean updatedAt
  -double level
  +validateCreatedat()
  +sendType()
  +cancelUpdatedat()
  +getId()
}
interface Loan {
  +Date active
  +long address
  +findAddress()
  +cancelId()
  +deleteQuantity()
  +saveTotal()
}
class Beneficiary {
  -double address
  -Date price
  -int quantity
  -float description
  +getScore()
  +findEmail()
  +calculateCreatedat()
}
class Interest {
  +double createdAt
  -boolean address
  -String updatedAt
  +createDescription()
  +processUpdatedat()
  +updateDescription()
  +validateAmount()
}
Teller --|> Account
Account --* Teller
Statement ..> Beneficiary : "1..*"
Loan --|> Beneficiary
Interest ..> Beneficiary : "1..*"
@enduml