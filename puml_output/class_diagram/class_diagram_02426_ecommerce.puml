@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Review {
  -boolean createdAt
  #double phone
  #String amount
  #Date active
  #long id
  +calculateName()
  +cancelPrice()
  +updateUpdatedat()
}
class Wishlist {
  -float address
  +boolean status
  +sendStatus()
  +cancelCode()
  +setTotal()
  +processStatus()
}
interface Cart {
  -int level
  -long type
  +long price
  #String createdAt
  -String name
  +getAddress()
  +sendEmail()
  +findPrice()
}
interface Order {
  -float duration
  -float email
  +sendLevel()
  +getAddress()
  +updateActive()
}
class Customer {
  -int duration
  #long status
  +Date address
  +findStatus()
}
Cart --o Wishlist
Order --|> Review
Wishlist --|> Customer
@enduml