@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Classroom {
  -Date type
  #String code
  #Date active
  #float createdAt
  -Date id
  +sendLevel()
  +cancelType()
  +findDuration()
}
class Exam {
  +String address
  -float score
  #boolean email
  #long description
  +processCode()
  +updateLevel()
  +updateCode()
}
class Grade {
  +String active
  -double name
  +sendActive()
  +validateCreatedat()
  +validateAmount()
}
class Book {
  #float amount
  -Date email
  +String quantity
  +String total
  +updateAddress()
  +setStatus()
  +createAmount()
  +cancelDescription()
}
abstract class Student {
  -String duration
  #int note
  +boolean name
  +saveQuantity()
  +createScore()
}
Exam --o Grade
Classroom ..|> Student
Grade ..|> Book
note right of Classroom : Education domain
@enduml