@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Classroom {
  -Date type
  #String code
  #Date active
  #float createdAt
  -Date id
  +findDuration()
  +getCode()
  +cancelLevel()
}
interface Exam {
  #boolean duration
  -float amount
  #int score
  +String address
  -float active
  +cancelId()
  +saveAmount()
  +deleteType()
}
class Grade {
  #int level
  #Date updatedAt
  +boolean code
  +updateActive()
}
class Book {
  -int note
  -int address
  +long score
  #int active
  +getNote()
  +setNote()
  +getAmount()
}
abstract class Student {
  -int status
  -String description
  #String name
  +processUpdatedat()
  +processScore()
  +sendStatus()
}
Exam ..|> Book
Student --|> Book
Grade --> Classroom : "0..1"
Classroom ..> Exam : "1..*"
@enduml