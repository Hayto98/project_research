@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Appointment {
  -String createdAt
  -int price
  +deleteEmail()
  +calculateLevel()
  +createQuantity()
}
abstract class Diagnosis {
  #double score
  -double phone
  -float level
  +String quantity
  +Date duration
  +validatePrice()
  +validateTotal()
}
class Nurse {
  -boolean id
  +Date name
  +updateScore()
  +deleteDescription()
  +calculateNote()
  +getAddress()
}
interface Prescription {
  -int description
  -long type
  +cancelType()
  +setCreatedat()
  +validateNote()
}
Nurse --o Appointment
Appointment ..> Nurse : "*"
@enduml