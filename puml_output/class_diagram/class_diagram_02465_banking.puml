@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Card {
  #String note
  +Date address
  #long status
  +processPhone()
  +deleteStatus()
}
class Transaction {
  +boolean email
  +double score
  +double updatedAt
  +deletePrice()
  +cancelStatus()
  +updateCreatedat()
  +validateAmount()
}
abstract class Withdrawal {
  +int price
  -long level
  +findActive()
  +findActive()
}
interface Statement {
  +Date id
  +double price
  +getPhone()
  +processActive()
  +saveId()
  +saveCode()
}
interface Account {
  -Date score
  #float description
  +Date note
  +calculateUpdatedat()
  +deleteNote()
}
interface Interest {
  +int duration
  -String createdAt
  +float score
  +cancelUpdatedat()
  +validateQuantity()
}
class Customer {
  -double phone
  +boolean name
  +String active
  #int quantity
  +processPrice()
}
Interest ..|> Statement
Customer --|> Statement
Account --o Statement
Transaction --* Card
note right of Card : Banking domain
@enduml