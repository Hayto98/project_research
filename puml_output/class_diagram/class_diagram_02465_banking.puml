@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Card {
  #String note
  +Date address
  #long status
  +deleteActive()
  +sendPhone()
}
class Transaction {
  -boolean updatedAt
  #boolean duration
  +deleteAddress()
  +setId()
}
class Withdrawal {
  #String name
  +float note
  #int total
  -int description
  -Date price
  +saveCode()
}
interface Statement {
  -int description
  #boolean phone
  +updateCreatedat()
}
class Account {
  -double description
  #Date updatedAt
  +Date price
  +boolean total
  #int name
  +setDuration()
  +updateId()
}
abstract class Interest {
  +double active
  #int id
  #float description
  #boolean total
  +boolean updatedAt
  +setDuration()
}
class Customer {
  -long id
  #Date code
  -long createdAt
  -String updatedAt
  +processLevel()
  +sendScore()
  +sendEmail()
}
Card ..> Customer : "0..1"
Card --o Statement
Withdrawal --o Interest
Customer --o Transaction
Card --o Account
Statement --|> Transaction
@enduml