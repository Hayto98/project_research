@startuml
skinparam defaultFontSize 11
class Notification {
  -int score
  +long duration
  #long note
  +updateActive()
}
class User {
  #int description
  #boolean createdAt
  +saveUpdatedat()
  +createEmail()
  +updateAmount()
}
class Profile {
  #String name
  #boolean total
  +int phone
  +calculateDescription()
  +calculateName()
}
class Post {
  -int name
  -double updatedAt
  +String createdAt
  #float note
  +deleteScore()
  +getAmount()
}
abstract class Follower {
  +long name
  #String score
  +int type
  +long level
  +Date email
  +updateAddress()
  +sendType()
  +updateDescription()
}
User ..|> Follower
Notification --* Post
note right of Notification : Social Media domain
@enduml