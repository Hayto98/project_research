@startuml
skinparam defaultFontSize 11
class Notification {
  -int score
  +long duration
  #long note
  +createScore()
}
interface User {
  +Date code
  +boolean description
  +findStatus()
  +findAddress()
  +cancelAddress()
}
class Profile {
  +double amount
  #long description
  #String duration
  +findPhone()
  +sendEmail()
}
abstract class Post {
  -Date price
  +int name
  +float quantity
  +saveCreatedat()
  +validateNote()
  +cancelAddress()
  +sendName()
}
class Follower {
  +boolean active
  +int createdAt
  +validateUpdatedat()
  +savePhone()
  +getUpdatedat()
  +createStatus()
}
Post ..|> Profile
Profile ..|> Notification
User --* Follower
@enduml