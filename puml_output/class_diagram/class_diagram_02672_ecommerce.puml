@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
abstract class Cart {
  +String price
  +double id
  #int status
  -int name
  +createAmount()
  +getTotal()
}
class Return {
  #Date phone
  #long amount
  +processCode()
  +processId()
  +updateTotal()
}
class Order {
  #float type
  +long total
  +double quantity
  +cancelDuration()
}
abstract class Review {
  +Date active
  +boolean type
  +saveCode()
  +processTotal()
  +deletePrice()
}
Cart ..|> Return
Order ..> Return : "*"
@enduml