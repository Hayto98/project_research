@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
abstract class Cart {
  +String price
  +double id
  #int status
  -int name
  +validateCreatedat()
  +updateId()
}
class Return {
  +boolean level
  -int quantity
  #Date email
  +processDuration()
  +calculateQuantity()
}
class Order {
  +boolean status
  -String type
  #float code
  +boolean price
  +calculateNote()
  +processCreatedat()
  +setType()
}
class Review {
  +long quantity
  #int type
  +float status
  #long phone
  +updateId()
  +deleteName()
}
Return --|> Cart
Return --o Order
note right of Cart : Ecommerce domain
@enduml