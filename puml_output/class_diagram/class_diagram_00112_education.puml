@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
abstract class Schedule {
  +String score
  +String quantity
  +int active
  +double level
  #long description
  +sendEmail()
  +findScore()
  +validateTotal()
}
class Department {
  #float quantity
  #boolean amount
  -double type
  -Date phone
  #Date address
  +saveType()
}
class Attendance {
  +Date description
  #long status
  -boolean updatedAt
  +getDescription()
  +getPhone()
  +calculateUpdatedat()
}
class Course {
  -long level
  -boolean price
  +sendUpdatedat()
  +calculateNote()
  +validatePhone()
  +deleteAmount()
}
abstract class Library {
  #String score
  +boolean duration
  #String note
  -long amount
  +float status
  +calculateCode()
}
class Grade {
  #double phone
  -float status
  #boolean type
  -boolean address
  +calculateId()
  +setStatus()
}
Department ..|> Course
Department --|> Library
Grade ..> Attendance : "1..*"
Attendance --* Grade
Grade --|> Course
@enduml