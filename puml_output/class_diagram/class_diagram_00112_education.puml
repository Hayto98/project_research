@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
abstract class Schedule {
  +String score
  +String quantity
  +int active
  +double level
  #long description
  +updateQuantity()
  +findCreatedat()
  +processQuantity()
}
class Department {
  -long score
  #Date phone
  #String address
  +int active
  +String level
  +deleteQuantity()
  +processActive()
}
class Attendance {
  -boolean name
  #double duration
  #int price
  +double type
  #double address
  +sendScore()
  +processAmount()
  +saveStatus()
  +saveName()
}
class Course {
  +float note
  #String email
  +deleteLevel()
  +createPhone()
  +setDuration()
  +processAddress()
}
interface Library {
  +boolean address
  -int active
  #double phone
  +int description
  #String name
  +findAddress()
  +validateQuantity()
  +createNote()
}
class Grade {
  -Date name
  #float score
  +getNote()
  +validateNote()
  +updateName()
}
Schedule --|> Department
Course ..> Attendance : "1"
note right of Schedule : Education domain
@enduml