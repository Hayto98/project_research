@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
abstract class Warehouse {
  +long id
  +float description
  -boolean updatedAt
  +findDescription()
  +cancelStatus()
  +createTotal()
}
class Customer {
  +int code
  #boolean score
  -float status
  +processAmount()
  +processPrice()
  +saveType()
}
class Supplier {
  #double price
  -long level
  +long quantity
  #float id
  -double type
  +findAmount()
  +getPrice()
  +cancelCreatedat()
  +updateName()
}
abstract class Return {
  #Date level
  +Date address
  -int duration
  #long score
  +long email
  +createScore()
  +validatePrice()
  +validateNote()
}
Supplier --* Customer
Return --o Customer
Warehouse ..> Return : "0..1"
@enduml