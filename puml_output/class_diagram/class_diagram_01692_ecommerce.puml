@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
abstract class Warehouse {
  +long id
  +float description
  -boolean updatedAt
  +cancelCode()
  +findAmount()
  +deleteCode()
}
interface Customer {
  #boolean amount
  -float createdAt
  +setUpdatedat()
  +updatePrice()
  +calculateLevel()
}
class Supplier {
  -double type
  -int level
  +findNote()
  +calculateDuration()
  +calculateTotal()
}
abstract class Return {
  #long type
  -long duration
  +saveDescription()
  +saveQuantity()
  +updateLevel()
}
Customer --* Return
Customer ..|> Supplier
Return --* Customer
note right of Warehouse : Ecommerce domain
@enduml