@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
abstract class Staff {
  #Date type
  -boolean phone
  +long score
  -boolean amount
  -float total
  +saveType()
  +updateLevel()
  +deleteType()
}
abstract class Restaurant {
  -float price
  #String active
  +float createdAt
  #boolean address
  +savePhone()
  +findCode()
}
interface Invoice {
  #boolean name
  +boolean type
  +createPhone()
  +savePrice()
  +deleteDescription()
  +findAddress()
}
class Payment {
  #double total
  #Date name
  +calculatePhone()
  +findScore()
  +findPhone()
  +getName()
}
abstract class Amenity {
  #double name
  #Date quantity
  -double amount
  -boolean type
  +calculateUpdatedat()
  +createUpdatedat()
  +deleteUpdatedat()
  +deleteUpdatedat()
}
Staff --|> Invoice
Payment --|> Invoice
Restaurant --* Staff
Amenity --o Payment
note right of Staff : Hotel domain
@enduml