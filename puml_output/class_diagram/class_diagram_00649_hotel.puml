@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
abstract class Staff {
  #Date type
  -boolean phone
  +long score
  -boolean amount
  -float total
  +validateDescription()
  +processNote()
  +processScore()
}
abstract class Restaurant {
  -long level
  -boolean description
  +long type
  +calculateLevel()
  +cancelPrice()
  +deleteNote()
  +setDescription()
}
interface Invoice {
  +double phone
  #boolean code
  +boolean level
  +validateLevel()
  +sendAddress()
  +findCode()
  +updatePhone()
}
abstract class Payment {
  +double description
  +boolean address
  -float updatedAt
  +deletePhone()
  +getAddress()
  +calculateLevel()
  +findEmail()
}
class Amenity {
  +Date name
  -int duration
  -boolean total
  -Date phone
  +saveName()
  +cancelPhone()
  +processId()
  +cancelAmount()
}
Payment ..|> Amenity
Invoice ..|> Restaurant
Restaurant ..|> Amenity
Staff --|> Invoice
@enduml