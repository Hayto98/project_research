@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
abstract class Catalog {
  #long description
  +int email
  -double level
  +int amount
  +findCode()
  +deleteAmount()
  +findName()
}
class Reservation {
  +boolean name
  #boolean status
  -String quantity
  -boolean duration
  +validateId()
  +setQuantity()
}
class Fine {
  #long active
  -Date email
  +getUpdatedat()
  +calculatePrice()
}
interface Book {
  -int score
  -double address
  -boolean amount
  -double id
  -float email
  +sendId()
}
Fine --|> Catalog
Book ..|> Catalog
note right of Catalog : Library domain
@enduml