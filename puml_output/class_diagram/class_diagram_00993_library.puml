@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
abstract class Catalog {
  #long description
  +int email
  -double level
  +int amount
  +sendUpdatedat()
  +createAddress()
  +deleteScore()
}
class Reservation {
  +Date quantity
  +long email
  +cancelEmail()
}
interface Fine {
  +String status
  -String phone
  #String updatedAt
  #long address
  +deletePhone()
  +saveName()
  +cancelName()
}
class Book {
  -Date updatedAt
  #boolean price
  +createStatus()
  +validateType()
  +calculateCreatedat()
  +createCode()
}
Fine ..|> Reservation
@enduml