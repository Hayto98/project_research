@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Cart {
  +String type
  #String id
  #float name
  -long code
  +processCreatedat()
  +getAddress()
  +calculateQuantity()
  +sendDescription()
}
class Coupon {
  -int id
  -float updatedAt
  -Date address
  -Date status
  +findLevel()
}
class Invoice {
  #String active
  +double description
  -double price
  -int score
  -long id
  +deleteType()
  +updateId()
  +deleteName()
  +findLevel()
}
class Return {
  +boolean id
  #int name
  +String quantity
  +Date status
  +setActive()
  +findPhone()
  +processTotal()
}
Return ..> Coupon : "*"
Invoice --> Coupon : "1..*"
Invoice --|> Return
@enduml