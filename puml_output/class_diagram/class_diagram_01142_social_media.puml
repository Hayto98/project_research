@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
interface Profile {
  +String duration
  -boolean email
  +long description
  #boolean total
  +calculateType()
  +createCreatedat()
}
interface Hashtag {
  +Date name
  -long phone
  #float code
  +boolean duration
  +getPhone()
}
class User {
  #String score
  #boolean status
  +processDuration()
}
class Post {
  +Date phone
  #long note
  +getLevel()
}
abstract class Comment {
  #int level
  +boolean duration
  #double phone
  -double createdAt
  +boolean active
  +setLevel()
}
class Notification {
  #int type
  #int score
  #String amount
  +deleteDuration()
  +cancelCode()
  +deleteScore()
}
Notification --> User : "*"
Post --> Notification : "1..*"
@enduml