@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
interface Profile {
  +String duration
  -boolean email
  +long description
  #boolean total
  +deleteLevel()
  +createName()
}
class Hashtag {
  +Date duration
  -long name
  +sendName()
}
abstract class User {
  #String code
  #boolean score
  +int status
  +setPhone()
  +processCreatedat()
  +saveDuration()
}
class Post {
  -float code
  #Date price
  +updateCreatedat()
  +saveCreatedat()
  +setScore()
}
abstract class Comment {
  #float note
  +double name
  #boolean status
  #int description
  #int updatedAt
  +saveName()
  +validateNote()
}
abstract class Notification {
  -double code
  #long address
  #double price
  +cancelTotal()
}
Profile ..> Hashtag : "0..1"
Comment --|> Post
User --o Post
User ..> Notification : "1"
note right of Profile : Social Media domain
@enduml