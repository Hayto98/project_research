@startuml
skinparam monochrome true
class Reservation {
  -long code
  -Date phone
  -float score
  +cancelCreatedat()
  +processActive()
  +deleteCreatedat()
  +processQuantity()
}
interface Staff {
  -int level
  +String type
  +updateId()
}
class Restaurant {
  -Date name
  +Date type
  #int score
  +calculateCode()
  +calculateLevel()
}
class Housekeeping {
  -int phone
  -float active
  +Date note
  #int address
  +String description
  +cancelEmail()
  +createPhone()
  +getEmail()
}
interface Guest {
  -double phone
  -long status
  +String score
  +findTotal()
  +sendPrice()
  +getUpdatedat()
}
class Booking {
  #int total
  #double price
  #String score
  #int quantity
  +createQuantity()
  +createId()
}
Restaurant ..|> Staff
Guest ..> Staff : "1"
@enduml