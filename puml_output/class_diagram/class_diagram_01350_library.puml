@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
interface Shelf {
  +double name
  -boolean quantity
  -Date level
  +String total
  +getScore()
}
class Reservation {
  +Date type
  +float createdAt
  #int description
  -int updatedAt
  -double price
  +cancelTotal()
  +cancelEmail()
  +createType()
  +cancelDuration()
}
interface Author {
  -int address
  +float active
  +Date email
  +findDescription()
  +updateId()
  +createPrice()
}
interface Book {
  -String email
  -Date status
  -float updatedAt
  +getPhone()
  +setCreatedat()
  +updateUpdatedat()
  +deletePhone()
}
Book --o Author
Shelf ..> Book : "*"
Reservation --|> Author
@enduml