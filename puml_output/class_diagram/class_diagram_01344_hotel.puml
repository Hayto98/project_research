@startuml
skinparam monochrome true
skinparam defaultFontSize 11
abstract class Restaurant {
  #boolean phone
  #boolean quantity
  -int duration
  +float status
  +findId()
  +deleteActive()
  +findType()
}
interface CheckIn {
  -boolean total
  -long level
  +findAddress()
  +getAddress()
  +createCreatedat()
  +updateUpdatedat()
}
class Service {
  #int createdAt
  #Date duration
  #double updatedAt
  #int description
  +processQuantity()
  +findAmount()
  +getDuration()
}
class Amenity {
  +String phone
  #long email
  +float id
  +setLevel()
  +setUpdatedat()
}
Service --|> CheckIn
Restaurant ..> Amenity : "1..*"
@enduml