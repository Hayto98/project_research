@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Tracking {
  +boolean email
  #long name
  #double note
  +updateActive()
}
class Vehicle {
  #double type
  -float total
  #Date score
  #String updatedAt
  +calculateStatus()
}
interface Customer {
  -long duration
  #boolean level
  -float updatedAt
  #long name
  +updatePhone()
}
interface Manifest {
  +float code
  #int price
  +findPrice()
  +calculateEmail()
}
class Package {
  #String code
  -Date note
  +sendAddress()
  +processType()
}
interface DeliveryNote {
  -int note
  -String amount
  +double updatedAt
  +int address
  -boolean email
  +createTotal()
  +setCode()
  +sendPhone()
}
Tracking --* Customer
Tracking --o Manifest
DeliveryNote ..> Manifest : "0..1"
@enduml