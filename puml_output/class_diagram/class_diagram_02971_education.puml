@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
abstract class Book {
  +double status
  #float duration
  #double email
  -long total
  -Date amount
  +updateEmail()
  +getLevel()
  +createLevel()
  +deleteQuantity()
}
class Library {
  #double quantity
  -Date amount
  #String description
  +saveTotal()
  +validateUpdatedat()
}
class Classroom {
  #int type
  #long createdAt
  #Date duration
  #String id
  +calculateName()
  +processActive()
}
class Assignment {
  #float quantity
  -double duration
  +cancelTotal()
}
class Department {
  +int status
  +boolean code
  +calculateNote()
  +processQuantity()
  +setEmail()
}
interface Attendance {
  #String description
  +int quantity
  +calculateDescription()
}
Department ..> Assignment : "1"
Assignment --o Classroom
@enduml