@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
abstract class Book {
  +double status
  #float duration
  #double email
  -long total
  -Date amount
  +calculateCode()
  +findStatus()
  +findEmail()
  +deleteQuantity()
}
class Library {
  +double type
  +boolean phone
  -double id
  +processId()
  +sendUpdatedat()
}
interface Classroom {
  +long level
  #String code
  -float description
  -boolean address
  +calculateId()
  +getCode()
  +setStatus()
}
class Assignment {
  #boolean amount
  -int duration
  +validateDuration()
}
class Department {
  +float quantity
  +Date code
  +boolean status
  +saveId()
  +processPhone()
  +processCreatedat()
  +saveTotal()
}
class Attendance {
  #boolean status
  +long level
  -int active
  #Date note
  +long duration
  +validateTotal()
  +validateDescription()
}
Book --o Attendance
Book --> Classroom : "*"
Classroom --|> Department
Library --> Book : "1"
note right of Book : Education domain
@enduml