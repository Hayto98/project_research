@startuml

class Department {
  #String description
  -float active
  +sendId()
}
class Enrollment {
  +Date active
  -float type
  -float price
  +long phone
  #Date level
  +findScore()
  +findEmail()
}
class Course {
  +float createdAt
  #Date name
  +deleteType()
  +setCreatedat()
  +getQuantity()
  +deleteCreatedat()
}
class Grade {
  #long quantity
  +String id
  +getQuantity()
  +findTotal()
  +processType()
  +saveQuantity()
}
abstract class Assignment {
  -long quantity
  -float score
  #Date amount
  +cancelName()
  +sendUpdatedat()
  +updateScore()
}
interface Schedule {
  #int quantity
  -long updatedAt
  +long phone
  #boolean active
  -Date note
  +getId()
  +createName()
}
interface Exam {
  -long duration
  #String phone
  #long level
  -int address
  +long createdAt
  +findCode()
}
Exam ..|> Enrollment
Enrollment --o Assignment
note right of Department : Education domain
@enduml