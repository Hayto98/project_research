@startuml

class Department {
  #String description
  -float active
  +getCreatedat()
}
class Enrollment {
  -long active
  #boolean price
  -int duration
  #long type
  +validateDescription()
  +validateCreatedat()
  +cancelAddress()
}
class Course {
  +float description
  #Date name
  -int createdAt
  #double level
  +updateDescription()
}
class Grade {
  -String amount
  #long createdAt
  +String code
  -String status
  +createTotal()
  +cancelCreatedat()
  +cancelLevel()
}
abstract class Assignment {
  -long quantity
  -float type
  #Date updatedAt
  -boolean duration
  +boolean amount
  +getTotal()
  +createStatus()
}
interface Schedule {
  #int quantity
  -long updatedAt
  +long phone
  #boolean active
  -Date note
  +savePhone()
  +deleteEmail()
}
class Exam {
  -long name
  #int level
  -long price
  #String phone
  +findQuantity()
  +deleteAddress()
  +setPrice()
}
Course ..> Schedule : "1"
Schedule --|> Department
@enduml