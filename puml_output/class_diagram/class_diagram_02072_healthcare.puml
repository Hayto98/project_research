@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Insurance {
  +long price
  #float score
  #double address
  #Date note
  +updateActive()
}
abstract class MedicalRecord {
  -long total
  +boolean level
  #float quantity
  +Date id
  +updateNote()
  +setScore()
  +savePhone()
}
abstract class Ward {
  -long active
  #Date total
  #float updatedAt
  #Date name
  -long amount
  +getPrice()
}
class Billing {
  #Date score
  #String description
  -double name
  #float price
  +Date code
  +calculateLevel()
  +getPhone()
}
abstract class Hospital {
  -int score
  #long quantity
  +saveEmail()
  +findNote()
}
class Nurse {
  -String description
  +double quantity
  +boolean createdAt
  #long address
  +setDescription()
  +getPrice()
  +savePrice()
  +setTotal()
}
Insurance ..> Ward : "1..*"
Hospital --> Billing : "*"
Nurse --* Billing
MedicalRecord --* Nurse
note right of Insurance : Healthcare domain
@enduml