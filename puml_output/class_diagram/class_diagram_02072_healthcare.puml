@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Insurance {
  +long price
  #float score
  #double address
  #Date note
  +validateNote()
}
interface MedicalRecord {
  -int quantity
  #boolean total
  +Date duration
  #long id
  +double price
  +sendAmount()
}
class Ward {
  +int level
  -long note
  #Date active
  #float total
  #Date updatedAt
  +setPrice()
  +deleteCode()
  +updateUpdatedat()
  +processScore()
}
class Billing {
  -String address
  #Date score
  #String price
  -double description
  #float name
  +calculateUpdatedat()
  +sendId()
}
abstract class Hospital {
  +boolean phone
  -double type
  +validateActive()
  +createQuantity()
}
class Nurse {
  -float note
  +boolean amount
  -long quantity
  +int description
  +validatePhone()
  +findDuration()
  +saveActive()
  +getNote()
}
Insurance --|> MedicalRecord
Billing --|> Nurse
Billing --|> Ward
Nurse ..> Ward : "1..*"
Hospital --> Billing : "*"
@enduml