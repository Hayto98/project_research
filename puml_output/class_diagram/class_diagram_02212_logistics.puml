@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
interface Depot {
  -int price
  +double level
  +getActive()
  +deleteUpdatedat()
  +sendLevel()
}
class Driver {
  +String id
  +long total
  +saveLevel()
  +processName()
  +deleteDescription()
  +findStatus()
}
class Vehicle {
  -double total
  -int price
  #double score
  +createPrice()
}
class Route {
  #String amount
  -String phone
  #int level
  #boolean updatedAt
  +sendNote()
}
Depot --* Vehicle
@enduml