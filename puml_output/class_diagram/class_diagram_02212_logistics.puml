@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
interface Depot {
  -int price
  +double level
  +findLevel()
  +createLevel()
  +saveName()
}
class Driver {
  +boolean name
  #String id
  #int createdAt
  -float phone
  #Date type
  +sendType()
  +calculateAddress()
  +deleteDuration()
  +calculateCode()
}
abstract class Vehicle {
  -long phone
  +Date amount
  +createStatus()
}
interface Route {
  +String duration
  #long code
  #boolean updatedAt
  +saveNote()
}
Driver --o Route
Route ..> Driver : "*"
note right of Depot : Logistics domain
@enduml