@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
interface Nurse {
  #Date address
  -float id
  -Date email
  +cancelEmail()
  +calculateUpdatedat()
  +updateTotal()
  +saveStatus()
}
interface Doctor {
  #Date type
  +Date updatedAt
  +String createdAt
  -float amount
  +float description
  +sendTotal()
  +sendCreatedat()
}
abstract class Appointment {
  #double description
  +long total
  +float level
  +createAmount()
  +findDescription()
}
class MedicalRecord {
  #Date email
  #Date status
  +updateActive()
  +cancelStatus()
  +processTotal()
}
interface Patient {
  +double price
  #long email
  +getId()
  +findType()
  +updateCode()
  +calculateCreatedat()
}
interface Billing {
  +boolean type
  +float code
  +getScore()
  +deleteCreatedat()
  +deleteType()
  +createQuantity()
}
class Treatment {
  #boolean name
  +Date active
  +processUpdatedat()
}
Nurse --* Billing
Billing ..> Appointment : "1..*"
Appointment --|> Nurse
Patient --o Billing
Nurse --* Doctor
Treatment --* Nurse
@enduml