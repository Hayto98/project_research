@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Hashtag {
  #float description
  -float score
  +deleteQuantity()
}
interface Album {
  -Date note
  -Date createdAt
  #Date description
  #String status
  +createScore()
  +updateLevel()
}
class Profile {
  #String createdAt
  +String id
  +boolean quantity
  -double description
  #boolean name
  +sendDescription()
}
class Report {
  #double address
  #float status
  -String note
  +sendPrice()
  +findCode()
  +processAmount()
  +validatePrice()
}
class User {
  -float active
  #long phone
  +deleteLevel()
  +findPrice()
  +findStatus()
  +saveScore()
}
abstract class Story {
  +long amount
  #String level
  +double type
  -String score
  +validateCreatedat()
  +deleteNote()
  +saveNote()
}
class Message {
  +String total
  -long quantity
  #String status
  +saveDescription()
  +updateUpdatedat()
  +calculateDescription()
}
Story ..> Album : "0..1"
User --|> Profile
@enduml