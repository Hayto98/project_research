@startuml
skinparam monochrome true
skinparam ArrowColor #555555
interface Vehicle {
  -float address
  #Date status
  #int duration
  +updateCode()
  +processDuration()
  +saveCode()
  +saveActive()
}
class Route {
  +long name
  +double type
  -float id
  +setStatus()
  +validateId()
  +updateType()
  +setQuantity()
}
class FuelLog {
  -float code
  +float price
  +updateCode()
}
class Customer {
  #long address
  #String type
  -Date price
  -String note
  -Date email
  +processPrice()
}
class Driver {
  -Date address
  -long quantity
  #int createdAt
  #Date name
  -double duration
  +processEmail()
  +setTotal()
}
class Warehouse {
  #int duration
  #int code
  +deleteTotal()
  +updateUpdatedat()
  +savePhone()
  +updateType()
}
Route --|> Warehouse
Customer --o FuelLog
Route ..> Vehicle : "0..1"
note right of Vehicle : Logistics domain
@enduml