@startuml
skinparam monochrome true
skinparam ArrowColor #555555
interface Vehicle {
  -float address
  #Date status
  #int duration
  +findAddress()
  +setScore()
  +updateId()
  +sendStatus()
}
class Route {
  +double duration
  +float code
  +long active
  +double email
  -float description
  +deleteQuantity()
  +setStatus()
  +calculateLevel()
  +findCode()
}
class FuelLog {
  +Date type
  +float status
  +double quantity
  +getName()
  +setUpdatedat()
  +deleteLevel()
}
class Customer {
  -Date code
  #double duration
  -double total
  +deleteType()
  +validateDuration()
  +deletePhone()
}
class Driver {
  -int price
  -float status
  -boolean duration
  -int level
  +long note
  +getActive()
  +cancelId()
  +getNote()
}
interface Warehouse {
  -float email
  -String note
  -int createdAt
  +validateActive()
}
Warehouse ..> Route : "0..1"
Warehouse --> Driver : "*"
@enduml