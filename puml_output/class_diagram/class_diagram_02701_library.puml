@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Renewal {
  -boolean name
  -long price
  +Date score
  #Date createdAt
  +createDuration()
  +validateScore()
  +createStatus()
  +processAmount()
}
class Author {
  +double price
  #boolean active
  +createAmount()
}
interface Librarian {
  -Date level
  +int price
  +setNote()
  +findUpdatedat()
}
class Shelf {
  #boolean type
  -float score
  +double active
  -String address
  #double id
  +createDuration()
  +validateName()
}
class Member {
  #boolean updatedAt
  -Date quantity
  +float type
  +int total
  +long status
  +cancelLevel()
  +sendActive()
}
class Catalog {
  -boolean quantity
  -int total
  -String phone
  +getTotal()
  +setAddress()
  +saveAmount()
}
Member --* Catalog
Librarian --> Author : "1"
Librarian ..|> Renewal
Catalog --o Librarian
@enduml