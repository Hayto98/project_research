@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Renewal {
  -boolean name
  -long price
  +Date score
  #Date createdAt
  +calculateAddress()
  +sendCode()
  +updateCode()
  +calculateActive()
}
class Author {
  #double active
  -Date id
  +int phone
  +double duration
  #String status
  +processScore()
  +sendAddress()
  +getActive()
  +cancelPrice()
}
class Librarian {
  -int price
  #double code
  +long note
  -double amount
  +boolean duration
  +saveStatus()
  +getCreatedat()
  +getPhone()
}
interface Shelf {
  -double duration
  #Date code
  -double amount
  +deleteQuantity()
  +getPhone()
  +updateScore()
}
abstract class Member {
  #String level
  -String quantity
  +float phone
  #float createdAt
  +calculateCreatedat()
  +validateUpdatedat()
  +findPhone()
}
class Catalog {
  +double price
  #String code
  -double status
  +boolean id
  +getAmount()
  +cancelAmount()
  +validateCreatedat()
  +validateUpdatedat()
}
Member --> Librarian : "1..*"
Member ..|> Renewal
Librarian ..> Member : "*"
note right of Renewal : Library domain
@enduml