@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
abstract class Fine {
  -double email
  +Date name
  -Date createdAt
  +setAmount()
  +deleteId()
}
class Member {
  -Date quantity
  #double email
  +setActive()
  +cancelTotal()
}
class Author {
  +boolean code
  +int score
  +sendLevel()
  +setLevel()
}
interface Librarian {
  +String address
  +boolean active
  -long updatedAt
  -float level
  +findAddress()
  +calculateScore()
  +processTotal()
  +validateScore()
}
class Shelf {
  +float description
  -boolean level
  +updateAddress()
  +saveAmount()
}
class Catalog {
  +boolean address
  #String code
  +double amount
  #boolean level
  +float phone
  +findTotal()
  +updateDuration()
  +processNote()
}
class Publisher {
  -Date phone
  +float name
  #double amount
  +findDescription()
  +findTotal()
}
Member --* Librarian
Shelf --|> Author
Author ..|> Catalog
Shelf --o Librarian
Member --o Catalog
note right of Fine : Library domain
@enduml