@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
abstract class Fine {
  -double email
  +Date name
  -Date createdAt
  +createPhone()
  +updateType()
}
class Member {
  #Date address
  #long code
  +sendType()
  +sendScore()
  +setCreatedat()
}
interface Author {
  #Date updatedAt
  #String code
  +boolean active
  +boolean total
  +int createdAt
  +sendQuantity()
  +processId()
}
class Librarian {
  +String address
  +boolean active
  -long updatedAt
  -float level
  +setCode()
  +getDuration()
  +calculateCreatedat()
  +deleteAmount()
}
interface Shelf {
  #float total
  +boolean phone
  +float score
  -boolean email
  #int status
  +saveTotal()
  +setScore()
}
class Catalog {
  +boolean description
  #int total
  #String address
  +processPrice()
  +findUpdatedat()
  +saveDuration()
}
class Publisher {
  #float note
  +float active
  +setCreatedat()
  +findAmount()
  +sendEmail()
}
Librarian ..|> Publisher
Member --|> Author
Member ..> Librarian : "0..1"
Publisher --o Shelf
Member ..> Catalog : "0..1"
Catalog --o Librarian
@enduml