@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Account {
  #boolean description
  #double total
  #int duration
  +savePrice()
  +updateActive()
}
interface Interest {
  #float name
  #float address
  +cancelCode()
}
class Transaction {
  -float active
  +int id
  +Date price
  +boolean total
  #long status
  +sendName()
}
abstract class Beneficiary {
  -double active
  #long description
  #long quantity
  +sendTotal()
  +validateTotal()
  +cancelAmount()
}
class Customer {
  -float name
  -int email
  +calculateType()
}
class Transfer {
  +boolean createdAt
  #float description
  +validateLevel()
  +deleteActive()
  +saveDuration()
}
interface Deposit {
  -boolean status
  -boolean name
  #Date note
  -boolean type
  -double phone
  +saveAmount()
  +findId()
}
Account --* Deposit
Beneficiary --o Interest
Transaction ..|> Beneficiary
Transaction --o Account
Deposit ..> Account : "1..*"
Transfer --|> Customer
@enduml