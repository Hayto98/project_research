@startuml
skinparam ArrowColor #555555
interface Department {
  #long phone
  +float price
  #double quantity
  #long status
  -long amount
  +createId()
}
abstract class Grade {
  -String address
  +float status
  +int active
  +long note
  +getCreatedat()
  +processPrice()
}
class Exam {
  +boolean total
  #int level
  -int id
  -String phone
  +validateType()
}
class Book {
  +String active
  -float type
  -long createdAt
  +int duration
  #int name
  +deleteQuantity()
  +sendName()
  +updateQuantity()
}
class Assignment {
  #float status
  #long level
  -float quantity
  #long price
  +setCode()
  +saveName()
  +findEmail()
}
interface Classroom {
  -String note
  +String email
  +cancelId()
  +sendCode()
  +saveType()
  +setDescription()
}
class Enrollment {
  #long quantity
  #long updatedAt
  #int total
  +int description
  +createStatus()
}
Exam --o Classroom
Enrollment ..> Grade : "1..*"
Exam --o Book
Grade --o Enrollment
@enduml