@startuml
skinparam ArrowColor #555555
interface Department {
  #long phone
  +float price
  #double quantity
  #long status
  -long amount
  +calculateAddress()
}
class Grade {
  -String active
  +float note
  +deleteName()
}
class Exam {
  -double score
  #Date updatedAt
  +long email
  +sendActive()
  +updateEmail()
}
class Book {
  #double id
  +boolean duration
  +String quantity
  +double note
  +validateCreatedat()
  +deleteAmount()
  +createStatus()
  +processName()
}
class Assignment {
  #float level
  -boolean quantity
  +validateLevel()
  +validateQuantity()
  +findPrice()
}
interface Classroom {
  -String note
  +String email
  +validateNote()
  +setCreatedat()
  +saveAddress()
  +createUpdatedat()
}
abstract class Enrollment {
  #int active
  +int email
  +boolean address
  +validatePrice()
  +updatePhone()
  +createNote()
}
Grade --o Enrollment
Grade --> Exam : "0..1"
Book --* Classroom
Department --o Exam
Department --> Classroom : "1"
note right of Department : Education domain
@enduml