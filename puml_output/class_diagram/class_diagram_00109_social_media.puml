@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
interface Comment {
  #int description
  +Date score
  -String name
  #int createdAt
  +getUpdatedat()
  +cancelDescription()
  +validateEmail()
}
interface Notification {
  -double phone
  +long quantity
  +calculateAmount()
  +setAmount()
  +sendAddress()
  +deletePhone()
}
abstract class Profile {
  -Date name
  +double address
  +boolean active
  -Date price
  #long createdAt
  +validateCreatedat()
}
class Message {
  -float total
  +double level
  +calculatePrice()
  +setCreatedat()
  +calculateDescription()
}
class Follower {
  -boolean type
  +int description
  +createTotal()
  +deleteEmail()
}
abstract class Post {
  #float description
  -long address
  +deleteName()
  +findActive()
  +calculateType()
}
class Like {
  +String email
  +int description
  -long name
  +sendStatus()
  +calculateAddress()
}
Comment ..> Follower : "*"
Follower ..|> Message
Profile ..|> Comment
Profile --* Like
Post --o Notification
@enduml