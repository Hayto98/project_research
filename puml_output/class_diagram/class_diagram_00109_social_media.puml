@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
interface Comment {
  #int description
  +Date score
  -String name
  #int createdAt
  +findStatus()
  +sendId()
  +validateQuantity()
}
abstract class Notification {
  -double id
  +float address
  -boolean type
  -int note
  -Date email
  +processAmount()
  +cancelPhone()
}
class Profile {
  +double description
  #float email
  +deleteTotal()
  +sendDuration()
  +validateScore()
  +findCreatedat()
}
interface Message {
  -boolean type
  +int description
  +findTotal()
  +sendCode()
}
class Follower {
  -double quantity
  +int email
  -int active
  +String address
  +setUpdatedat()
}
abstract class Post {
  #Date createdAt
  -boolean amount
  -int note
  -String id
  +createAddress()
  +validateUpdatedat()
}
abstract class Like {
  #String score
  #float type
  -int updatedAt
  #Date note
  -boolean description
  +getTotal()
  +deletePhone()
  +saveType()
  +saveActive()
}
Notification --> Message : "1"
Notification --> Like : "*"
Message --> Post : "1..*"
Follower ..> Like : "0..1"
Comment ..|> Notification
note right of Comment : Social Media domain
@enduml