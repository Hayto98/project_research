@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
interface Return {
  -long id
  +Date email
  -int status
  -float active
  +deleteNote()
  +calculateName()
}
class Product {
  #long note
  #String price
  -String status
  +calculateNote()
  +getDescription()
  +createCreatedat()
}
interface Category {
  -float phone
  #String id
  +validateTotal()
  +deleteNote()
  +updateType()
  +deletePhone()
}
class Shipment {
  -int phone
  -int description
  +double updatedAt
  +savePhone()
}
class Review {
  -long createdAt
  #String address
  -int phone
  -float total
  #String status
  +deleteAddress()
  +findScore()
  +processTotal()
}
class Payment {
  #int updatedAt
  #long phone
  +cancelCode()
  +getPrice()
  +createAddress()
}
interface Supplier {
  +long phone
  #String note
  +calculateEmail()
  +cancelType()
  +createId()
}
Category --> Supplier : "1"
Return ..|> Product
Payment --* Review
Review --|> Supplier
Shipment ..|> Payment
@enduml