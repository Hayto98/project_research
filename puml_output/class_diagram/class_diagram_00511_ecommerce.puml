@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
interface Return {
  -long id
  +Date email
  -int status
  -float active
  +getAddress()
  +getScore()
}
interface Product {
  #long note
  #String price
  -String status
  +updateDescription()
  +sendCode()
  +validateId()
}
abstract class Category {
  +int note
  +Date name
  +deleteUpdatedat()
  +createUpdatedat()
  +processDescription()
}
class Shipment {
  +long active
  -float name
  #double level
  +double phone
  -Date price
  +processUpdatedat()
}
class Review {
  -int duration
  -double level
  +saveId()
}
class Payment {
  -float amount
  +boolean level
  +long address
  #float quantity
  +getEmail()
  +sendId()
  +sendPhone()
  +getPrice()
}
class Supplier {
  +int active
  +Date duration
  #long level
  #float name
  +processUpdatedat()
}
Return ..|> Product
Payment --|> Category
Category --o Product
Payment --o Shipment
note right of Return : Ecommerce domain
@enduml