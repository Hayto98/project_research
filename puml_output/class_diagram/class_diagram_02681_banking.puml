@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
abstract class Teller {
  +float id
  #long type
  +validateActive()
  +updatePrice()
  +findStatus()
}
class Transfer {
  +String code
  +boolean id
  -long amount
  +getType()
  +sendAmount()
  +createType()
}
class Branch {
  +long total
  -String active
  #long createdAt
  +findCode()
  +processAmount()
}
class Card {
  +int active
  +double level
  -String id
  +setQuantity()
  +validateAmount()
}
Branch --|> Teller
Transfer --> Card : "1"
@enduml