@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
abstract class Teller {
  +float id
  #long type
  +cancelId()
  +getCode()
  +updateCode()
}
class Transfer {
  #long name
  -Date id
  -String level
  +deleteTotal()
  +sendCreatedat()
}
class Branch {
  -String total
  +Date code
  +boolean phone
  #String updatedAt
  +deleteCode()
  +calculateQuantity()
}
class Card {
  +String email
  -String phone
  #Date level
  +validateDuration()
  +cancelId()
}
Card ..|> Branch
Teller ..|> Card
note right of Teller : Banking domain
@enduml