@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Hashtag {
  -long name
  #double level
  #String score
  +Date note
  -double createdAt
  +processDuration()
  +findNote()
  +findDescription()
  +processStatus()
}
abstract class Follower {
  #long status
  +int price
