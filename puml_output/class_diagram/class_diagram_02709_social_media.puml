@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Hashtag {
  -long name
  #double level
  #String score
  +Date note
  -double createdAt
  +updateCode()
  +cancelPhone()
  +calculateQuantity()
  +findStatus()
}
abstract class Follower {
  +long status
  -Date email
  #Date description
  +saveScore()
  +sendPhone()
  +deleteQuantity()
}
interface Story {
  +float id
  -Date address
  +long quantity
  +updateAddress()
}
abstract class User {
  -Date address
  +String price
  -long quantity
  +createType()
  +updateActive()
  +findDescription()
  +cancelCode()
}
class Like {
  #int description
  +String name
  +float duration
  #String score
  +updateEmail()
  +deleteLevel()
}
Like --> Hashtag : "1"
Hashtag ..|> User
Story --> Hashtag : "1..*"
note right of Hashtag : Social Media domain
@enduml