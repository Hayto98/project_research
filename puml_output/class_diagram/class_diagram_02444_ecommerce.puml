@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
abstract class Category {
  -Date code
  #String email
  -Date phone
  +float score
  +validateQuantity()
  +getEmail()
  +findPrice()
}
abstract class Invoice {
  #float id
  +boolean status
  +String score
  +updateEmail()
  +getPhone()
}
class Warehouse {
  #String active
  -int price
  +double phone
  +saveUpdatedat()
  +processNote()
  +calculateActive()
}
class Customer {
  #Date score
  +int email
  +String address
  #Date name
  +long description
  +findId()
  +cancelTotal()
  +createNote()
}
abstract class Supplier {
  -Date name
  +Date amount
  -double level
  +updateAddress()
  +validateDescription()
  +findActive()
}
Category --* Warehouse
Customer --|> Supplier
Warehouse --* Supplier
@enduml