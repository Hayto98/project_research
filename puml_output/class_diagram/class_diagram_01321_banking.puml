@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
interface Interest {
  #float name
  #int active
  -int id
  +createPhone()
  +setEmail()
  +setActive()
  +setActive()
}
class Card {
  -double email
  #String code
  #Date phone
  +processLevel()
}
abstract class Customer {
  -String type
  -boolean active
  +String name
  +double phone
  +boolean address
  +sendType()
  +processAmount()
  +createActive()
  +setTotal()
}
class Deposit {
  #boolean type
  -float quantity
  #int id
  +processEmail()
  +saveType()
}
class Loan {
  -float price
  +long name
  #long createdAt
  #boolean score
  +int status
  +processPrice()
  +setStatus()
  +validateId()
  +createPhone()
}
Loan --> Deposit : "1"
Interest --> Customer : "0..1"
Customer --|> Card
note right of Interest : Banking domain
@enduml