@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
interface Interest {
  #float name
  #int active
  -int id
  +cancelPhone()
  +processStatus()
  +updateUpdatedat()
  +deleteCreatedat()
}
class Card {
  +long active
  +boolean status
  +processScore()
  +createPrice()
  +saveAmount()
}
class Customer {
  -double type
  -boolean level
  +createAmount()
}
class Deposit {
  +double name
  +boolean price
  -boolean updatedAt
  -double duration
  +validateStatus()
  +deleteId()
}
class Loan {
  +float total
  -long name
  +calculateDescription()
}
Customer ..|> Card
Deposit ..> Customer : "*"
Card --o Deposit
Interest ..|> Card
@enduml