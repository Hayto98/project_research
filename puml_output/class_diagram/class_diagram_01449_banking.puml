@startuml
skinparam defaultFontSize 11
class Account {
  +float quantity
  +boolean phone
  #float createdAt
  +sendPhone()
  +validateName()
  +deleteActive()
  +updateEmail()
}
abstract class Loan {
  +long phone
  +double active
  +findCode()
  +findScore()
}
interface Interest {
  -Date updatedAt
  #float amount
  #float score
  +setCreatedat()
  +cancelActive()
}
abstract class Branch {
  #double name
  -String score
  #float createdAt
  +createCreatedat()
  +cancelDuration()
  +cancelAmount()
  +findAddress()
}
class Deposit {
  +int address
  -int active
  +savePhone()
  +cancelDuration()
  +calculateCreatedat()
  +updateName()
}
Branch --|> Account
Account --|> Loan
note right of Account : Banking domain
@enduml