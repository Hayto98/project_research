@startuml
skinparam defaultFontSize 11
class Account {
  +float quantity
  +boolean phone
  #float createdAt
  +createDescription()
  +processStatus()
  +deleteCode()
  +saveDescription()
}
class Loan {
  #double active
  +Date updatedAt
  -boolean email
  +createAmount()
}
class Interest {
  +boolean updatedAt
  -Date code
  #float score
  #float amount
  #float duration
  +cancelStatus()
  +saveNote()
}
interface Branch {
  -String level
  #float updatedAt
  -long name
  +float createdAt
  #boolean note
  +sendDescription()
  +createLevel()
}
class Deposit {
  -Date active
  #int name
  +sendPhone()
  +updateDescription()
}
Interest ..|> Branch
Loan ..|> Account
Branch --|> Account
@enduml