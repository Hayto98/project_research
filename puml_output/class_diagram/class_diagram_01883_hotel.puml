@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
abstract class Guest {
  #int active
  +double address
  +createStatus()
}
class Booking {
  +double description
  #String amount
  #long total
  -long status
  -int name
  +calculateAddress()
  +sendCreatedat()
}
class Reservation {
  +String duration
  +double note
  #String quantity
  +setScore()
  +processStatus()
}
class Invoice {
  -Date name
  #String createdAt
  -String status
  +processLevel()
  +processName()
  +sendCreatedat()
  +saveDuration()
}
class Amenity {
  +boolean active
  #boolean type
  +int level
  +int total
  +setActive()
  +calculatePrice()
  +cancelStatus()
  +cancelPhone()
}
class CheckOut {
  #long total
  -Date email
  #int status
  +saveAmount()
  +sendEmail()
  +updateDescription()
}
class Payment {
  -double id
  #boolean quantity
  +updatePhone()
  +cancelStatus()
  +deleteScore()
  +createTotal()
}
CheckOut ..> Guest : "*"
Invoice --> Guest : "1"
Reservation ..> Amenity : "1"
Booking --|> Payment
Guest --o CheckOut
@enduml