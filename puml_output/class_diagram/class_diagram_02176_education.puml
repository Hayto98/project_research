@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Library {
  #Date updatedAt
  #long price
  +getTotal()
  +getDuration()
  +deleteId()
}
class Course {
  +boolean email
  -boolean score
  -boolean price
  +getNote()
  +saveId()
  +updateScore()
}
class Attendance {
  -int active
  #double duration
  #float price
  +cancelType()
  +findDescription()
}
class Teacher {
  -String address
  -float level
  +long price
  +String total
  -Date email
  +calculateName()
  +createNote()
  +setActive()
}
class Schedule {
  #double price
  #Date status
  +boolean total
  +updateEmail()
  +cancelCode()
  +createDescription()
}
class Enrollment {
  -float description
  +long price
  +double name
  +saveCreatedat()
  +savePhone()
}
class Classroom {
  #Date description
  -long level
  #long status
  +double total
  +saveTotal()
  +setName()
  +createPrice()
}
Teacher --* Library
Library --> Teacher : "*"
Schedule ..|> Course
Attendance --|> Enrollment
@enduml