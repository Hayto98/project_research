@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Patient {
  #int active
  #Date id
  +savePrice()
  +setType()
}
interface Nurse {
  +long code
  #int name
  +long type
  #double price
  +cancelAmount()
}
class Appointment {
  +Date duration
  #int active
  #double address
  +float note
  +updateAddress()
  +findCreatedat()
}
class LabTest {
  #boolean name
  #String active
  +double email
  +boolean phone
  #Date type
  +processNote()
  +updateAddress()
  +updateAddress()
}
class Doctor {
  #boolean name
  -Date score
  -boolean type
  +Date active
  +cancelTotal()
  +cancelPrice()
  +deleteNote()
  +findActive()
}
class Prescription {
  -float score
  #long status
  +setStatus()
  +updatePrice()
  +validateUpdatedat()
}
Prescription --* Appointment
LabTest --|> Patient
Prescription ..> Doctor : "0..1"
Prescription ..|> Patient
Patient --|> Prescription
note right of Patient : Healthcare domain
@enduml