@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Patient {
  #int active
  #Date id
  +validatePrice()
  +calculateCode()
}
class Nurse {
  -int score
  -Date quantity
  +String code
  -Date name
  -Date type
  +createNote()
}
interface Appointment {
  -Date code
  #float score
  #float active
  +cancelQuantity()
  +getName()
  +updateUpdatedat()
}
interface LabTest {
  +long note
  #int id
  -double description
  +getActive()
}
interface Doctor {
  +int phone
  -int type
  #Date active
  #boolean score
  +sendCode()
  +saveAmount()
  +cancelNote()
}
class Prescription {
  +boolean address
  -boolean createdAt
  #boolean duration
  +createLevel()
  +createQuantity()
  +processId()
}
Prescription --> LabTest : "*"
Doctor ..|> LabTest
LabTest --|> Doctor
@enduml