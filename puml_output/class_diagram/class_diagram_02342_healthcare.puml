@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Treatment {
  +double total
  -double price
  -float name
  #String description
  +float active
  +calculateNote()
  +calculateTotal()
}
abstract class Diagnosis {
  -int email
  -boolean updatedAt
  +String note
  #long active
  +float name
  +setDescription()
  +calculateCreatedat()
  +getUpdatedat()
  +findActive()
}
abstract class Billing {
  -String level
  +int active
  #boolean code
  -Date status
  -Date updatedAt
  +findQuantity()
}
class Patient {
  -float note
  +double updatedAt
  -Date duration
  +long active
  +setNote()
  +createLevel()
  +processNote()
  +createType()
}
Billing ..|> Patient
Patient ..> Diagnosis : "1"
Diagnosis --> Billing : "1"
@enduml