@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
abstract class Branch {
  +float quantity
  +String address
  #long status
  +validateType()
}
class Member {
  -double quantity
  #boolean phone
  +long code
  #String level
  +updateLevel()
  +processQuantity()
  +processActive()
  +processPhone()
}
class Renewal {
  +double name
  -String duration
  -int price
  +int level
  +validateCreatedat()
  +updateCreatedat()
}
class Shelf {
  -String id
  #double level
  +Date description
  +calculateDuration()
  +sendActive()
  +updateType()
  +getDuration()
}
class Publisher {
  -boolean status
  +double id
  #Date email
  #float updatedAt
  +sendId()
  +createDuration()
}
class Fine {
  -String phone
  -float email
  -long type
  -Date total
  +createName()
  +updateScore()
  +cancelCode()
  +setTotal()
}
interface Author {
  -boolean id
  +boolean name
  -boolean email
  +updateTotal()
  +findDuration()
  +setScore()
}
Renewal --* Shelf
Fine --> Author : "1"
@enduml