@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Grade {
  +boolean email
  -Date score
  #String duration
  #long code
  +validateStatus()
  +validateCreatedat()
}
class Schedule {
  -Date level
  +Date description
  +double name
  +createPhone()
  +getPhone()
}
class Exam {
  #float quantity
  +Date price
  -Date active
  #boolean email
  +long address
  +updateAmount()
}
class Assignment {
  +boolean duration
  -float quantity
  -boolean phone
  -double description
  +findAmount()
  +getType()
  +cancelUpdatedat()
  +sendName()
}
class Teacher {
  #float id
  +float quantity
  #long price
  -Date phone
  -long status
  +deleteAmount()
  +validateName()
}
interface Department {
  #double level
  -Date quantity
  +boolean updatedAt
  #String createdAt
  +long address
  +createUpdatedat()
  +findId()
}
Assignment --|> Schedule
Department ..|> Exam
@enduml