@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Grade {
  +boolean email
  -Date score
  #String duration
  #long code
  +deleteAmount()
  +deleteLevel()
}
class Schedule {
  #String email
  -int code
  +calculateAmount()
}
abstract class Exam {
  #float price
  +Date active
  -Date email
  #boolean address
  +createCode()
  +validateDuration()
}
class Assignment {
  -boolean phone
  -double description
  -double level
  +Date email
  +updateNote()
  +getQuantity()
  +calculateLevel()
  +findPhone()
}
class Teacher {
  -int address
  -double email
  #boolean price
  +cancelQuantity()
  +updateCreatedat()
  +validateTotal()
  +processCode()
}
interface Department {
  +boolean name
  +String phone
  +deleteId()
  +saveQuantity()
  +deletePhone()
  +calculateDescription()
}
Teacher --|> Assignment
Grade --o Department
note right of Grade : Education domain
@enduml