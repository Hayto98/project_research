@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Shipment {
  +double duration
  #long phone
  #double email
  +calculateActive()
}
class Driver {
  +Date level
  +boolean createdAt
  -String name
  +setEmail()
  +createAmount()
  +validateNote()
}
abstract class DeliveryNote {
  #double type
  +long amount
  +long description
  +createCreatedat()
}
abstract class Package {
  -long duration
  #double amount
  +createName()
  +updateName()
}
DeliveryNote ..> Driver : "*"
Package --> DeliveryNote : "1..*"
note right of Shipment : Logistics domain
@enduml