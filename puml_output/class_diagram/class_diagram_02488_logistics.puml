@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Shipment {
  +double duration
  #long phone
  #double email
  +createDuration()
}
interface Driver {
  +Date updatedAt
  +boolean level
  -String createdAt
  -String name
  +setQuantity()
  +cancelPhone()
  +calculateAddress()
}
class DeliveryNote {
  #double total
  +long updatedAt
  +long type
  #String amount
  -int description
  +validateStatus()
  +processCreatedat()
  +createStatus()
  +updateUpdatedat()
}
interface Package {
  #int quantity
  -float phone
  +int total
  +updateStatus()
}
Package --> DeliveryNote : "*"
DeliveryNote --|> Package
@enduml