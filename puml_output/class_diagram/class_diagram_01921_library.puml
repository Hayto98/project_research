@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Publisher {
  -boolean status
  +float amount
  #String email
  #double name
  -double total
  +sendEmail()
  +calculateId()
}
class Loan {
  #long type
  #double total
  +createPrice()
  +setLevel()
  +calculateUpdatedat()
}
class Renewal {
  +Date total
  +long amount
  +setQuantity()
  +validatePrice()
  +findTotal()
}
class Librarian {
  #boolean price
  -long quantity
  +updateName()
}
class Catalog {
  +Date price
  -double total
  -double type
  +double score
  +deleteEmail()
  +findQuantity()
  +findPrice()
  +setName()
}
interface Shelf {
  +Date amount
  -double active
  -String address
  #boolean updatedAt
  +updateAmount()
  +setPhone()
}
Renewal ..|> Loan
Renewal ..|> Shelf
Librarian --o Shelf
Renewal --* Catalog
note right of Publisher : Library domain
@enduml