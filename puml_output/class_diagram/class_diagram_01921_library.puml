@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Publisher {
  -boolean status
  +float amount
  #String email
  #double name
  -double total
  +createUpdatedat()
  +validateAmount()
}
abstract class Loan {
  +double email
  -Date score
  +setCode()
  +cancelCode()
  +createAmount()
}
class Renewal {
  +double code
  +String level
  #int price
  -boolean updatedAt
  #float duration
  +createPhone()
  +saveLevel()
  +getNote()
}
class Librarian {
  #boolean total
  -long status
  +int id
  +float price
  +Date quantity
  +deleteLevel()
  +cancelType()
  +saveTotal()
}
abstract class Catalog {
  -double type
  +double duration
  -int createdAt
  -Date note
  -Date price
  +cancelEmail()
  +createType()
  +validateType()
  +deleteNote()
}
interface Shelf {
  +Date amount
  -double active
  -String address
  #boolean updatedAt
  +findAddress()
  +findId()
}
Renewal --* Librarian
Loan --* Shelf
@enduml