@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Booking {
  +int type
  #double email
  +validateEmail()
  +sendAddress()
  +sendCreatedat()
}
class Payment {
  +float price
  -int code
  +String level
  +setPhone()
  +calculateDuration()
}
interface Guest {
  -double address
  #String id
  +calculateTotal()
  +sendScore()
}
class Staff {
  -double active
  #long price
  +findQuantity()
}
class Service {
  #float description
  +long phone
  #double id
  +cancelName()
  +getCreatedat()
}
class Amenity {
  +long note
  +boolean code
  +Date price
  +getScore()
  +cancelUpdatedat()
}
class Invoice {
  #boolean note
  #long updatedAt
  #float email
  -Date code
  +deleteEmail()
  +setAddress()
}
Staff ..|> Booking
Payment ..> Invoice : "1"
note right of Booking : Hotel domain
@enduml