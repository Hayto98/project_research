@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Booking {
  +int type
  #double email
  +saveScore()
  +calculateScore()
  +sendQuantity()
}
class Payment {
  +Date status
  +String description
  -int price
  +validateId()
  +saveTotal()
}
class Guest {
  #boolean phone
  +long price
  +validateScore()
}
abstract class Staff {
  -boolean createdAt
  #long price
  +findPrice()
}
abstract class Service {
  +Date total
  -int level
  #int phone
  +Date active
  +processEmail()
  +validatePrice()
  +updatePrice()
}
interface Amenity {
  +boolean phone
  +String type
  +getAmount()
  +sendLevel()
}
class Invoice {
  +long note
  +boolean code
  +Date price
  +cancelTotal()
  +getCreatedat()
}
Payment --* Invoice
Staff --* Payment
Amenity --|> Service
Service --> Invoice : "1..*"
Amenity ..> Guest : "0..1"
Payment --|> Guest
@enduml