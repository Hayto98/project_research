@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Depot {
  +String price
  #long email
  +Date status
  +long id
  #long active
  +createName()
  +getQuantity()
  +processPhone()
  +calculateEmail()
}
class Driver {
  #int total
  -boolean description
  +int quantity
  +setScore()
  +getPhone()
  +getPrice()
  +updateDuration()
}
class DeliveryNote {
  #long address
  -float quantity
  -Date note
  +deleteEmail()
  +deleteActive()
  +updateDuration()
}
interface Warehouse {
  -int active
  -int name
  -long type
  +createAmount()
  +updateType()
  +savePrice()
  +cancelActive()
}
interface Customer {
  #long name
  +int active
  +boolean id
  +float email
  +cancelEmail()
  +cancelType()
}
interface Vehicle {
  #double duration
  #String code
  #boolean id
  -double updatedAt
  +calculateId()
  +cancelId()
  +cancelStatus()
}
Vehicle --* Driver
Driver --* Warehouse
Vehicle --o DeliveryNote
Driver --o DeliveryNote
@enduml