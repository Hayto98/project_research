@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
interface Assignment {
  #float amount
  +double total
  +findCode()
  +saveUpdatedat()
  +getLevel()
}
interface Library {
  +boolean createdAt
  -boolean code
  -float status
  #float amount
  +Date email
  +calculateDuration()
  +calculateEmail()
}
class Schedule {
  #String status
  -Date description
  -double active
  -int code
  +float name
  +findDuration()
  +sendPrice()
  +sendCreatedat()
}
interface Department {
  +float id
  #double level
  +String phone
  +float note
  +Date description
  +processStatus()
  +getActive()
  +getQuantity()
}
class Student {
  -long score
  #Date level
  -long code
  -int id
  +createDescription()
  +processCode()
  +getName()
  +createQuantity()
}
Library --o Student
Schedule --|> Assignment
Student ..> Department : "0..1"
@enduml