@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Statement {
  +double level
  #boolean note
  #float createdAt
  +String status
  +double updatedAt
  +validateUpdatedat()
  +deleteCreatedat()
  +processCreatedat()
}
interface Interest {
  -double code
  -float duration
  -String createdAt
  +validateLevel()
  +processQuantity()
  +validateType()
}
class Customer {
  -long createdAt
  #String status
  #boolean note
  -boolean phone
  +getPrice()
  +validateStatus()
}
class Withdrawal {
  #double total
  +String active
  #Date name
  +sendCreatedat()
  +updatePrice()
  +calculateStatus()
}
interface Account {
  +float email
  -int address
  -String description
  +createAddress()
  +cancelCreatedat()
  +saveLevel()
}
abstract class Branch {
  -int description
  #int score
  +findPhone()
  +getType()
  +savePrice()
}
class Transfer {
  #int createdAt
  #String score
  +setPrice()
  +savePhone()
  +updateQuantity()
  +cancelAddress()
}
Interest --> Withdrawal : "0..1"
Statement --> Interest : "*"
note right of Statement : Banking domain
@enduml