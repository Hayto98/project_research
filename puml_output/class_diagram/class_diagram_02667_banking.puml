@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Statement {
  +double level
  #boolean note
  #float createdAt
  +String status
  +double updatedAt
  +calculateCreatedat()
  +createScore()
  +getEmail()
}
class Interest {
  #int createdAt
  -double active
  -float duration
  -String code
  #long level
  +savePrice()
  +deleteDuration()
  +getNote()
}
class Customer {
  -long status
  -Date quantity
  +float createdAt
  #boolean duration
  -boolean note
  +calculateEmail()
  +deleteAmount()
}
class Withdrawal {
  +double description
  #String level
  +savePhone()
  +validatePhone()
  +findStatus()
  +cancelDescription()
}
interface Account {
  -String score
  #boolean createdAt
  +long level
  -Date price
  +setQuantity()
  +cancelStatus()
}
abstract class Branch {
  -long phone
  #int code
  #float duration
  +validateTotal()
  +updateUpdatedat()
  +cancelName()
  +updateScore()
}
class Transfer {
  -Date amount
  -int duration
  #Date quantity
  +int phone
  #boolean name
  +getQuantity()
  +setName()
}
Transfer --o Statement
Branch ..|> Customer
Branch --* Transfer
Account --|> Customer
Interest --> Withdrawal : "0..1"
@enduml