@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
interface Service {
  #double amount
  +float address
  #double level
  #int status
  +findTotal()
  +deletePhone()
  +setAddress()
  +processQuantity()
}
class Staff {
  #float total
  +double active
  #long updatedAt
  +double description
  -String createdAt
  +saveId()
  +createAmount()
  +getCode()
}
interface Reservation {
  +long type
  #boolean amount
  +boolean id
  #long phone
  +validatePhone()
  +setAddress()
  +processQuantity()
}
abstract class Restaurant {
  #float description
  #Date quantity
  #String createdAt
  +sendAddress()
  +validateDescription()
  +updateEmail()
  +updatePrice()
}
abstract class Housekeeping {
  +double price
  +long quantity
  #String note
  #String duration
  -Date name
  +sendAddress()
  +createDescription()
}
interface Invoice {
  #boolean level
  +int total
  +Date createdAt
  -double address
  -float active
  +setId()
}
class Guest {
  #float note
  +double updatedAt
  +sendActive()
  +findLevel()
}
Guest ..> Staff : "1"
Restaurant ..|> Staff
Restaurant --> Service : "*"
Service ..> Guest : "1"
@enduml