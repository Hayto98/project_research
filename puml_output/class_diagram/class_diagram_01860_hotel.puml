@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
interface Service {
  #double amount
  +float address
  #double level
  #int status
  +sendName()
  +deleteNote()
  +calculateDuration()
  +findActive()
}
class Staff {
  -Date createdAt
  -String level
  -long amount
  +validateName()
}
class Reservation {
  +long type
  #boolean amount
  +boolean id
  #long phone
  +setScore()
  +getType()
  +updateDescription()
}
class Restaurant {
  -String status
  -boolean total
  -double email
  +processDuration()
  +calculateScore()
  +sendLevel()
}
class Housekeeping {
  #String type
  #String description
  -Date address
  +createActive()
  +cancelActive()
}
abstract class Invoice {
  +int createdAt
  #long address
  -long level
  +boolean active
  #int amount
  +processUpdatedat()
}
interface Guest {
  +Date total
  #String createdAt
  +double type
  +updateNote()
  +setScore()
}
Restaurant --|> Service
Invoice ..|> Service
Staff ..> Guest : "1..*"
Guest --o Reservation
Housekeeping ..|> Restaurant
note right of Service : Hotel domain
@enduml