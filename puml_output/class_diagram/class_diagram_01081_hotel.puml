@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
abstract class CheckIn {
  #Date level
  #String total
  -String createdAt
  +String email
  +long score
  +cancelDescription()
}
interface Restaurant {
  +int duration
  -boolean type
  +float quantity
  #int address
  +boolean description
  +sendDuration()
  +updateQuantity()
  +getDescription()
  +updateDescription()
}
class Staff {
  #float phone
  +Date duration
  #int id
  +double email
  +calculateDuration()
  +validateCreatedat()
  +saveCreatedat()
  +createAmount()
}
class Service {
  +double score
  -Date email
  #String level
  -boolean description
  -boolean quantity
  +sendLevel()
}
class Booking {
  +String amount
  #double address
  +int description
  #double email
  #boolean total
  +setAddress()
  +deleteLevel()
  +saveName()
  +sendAmount()
}
interface Invoice {
  #String active
  #String amount
  #Date level
  +updateEmail()
  +sendEmail()
  +cancelDuration()
}
interface Reservation {
  +float address
  -long updatedAt
  -float description
  #String code
  +setPhone()
  +findTotal()
  +calculateTotal()
}
Restaurant --* Booking
Invoice ..|> Service
CheckIn ..> Reservation : "0..1"
Reservation --* Booking
Booking ..> Reservation : "1"
@enduml