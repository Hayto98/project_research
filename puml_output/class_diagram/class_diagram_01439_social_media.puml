@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Post {
  +Date email
  -Date score
  -double note
  #double quantity
  -int createdAt
  +processNote()
  +updateDescription()
}
interface Group {
  #double score
  +double code
  #double phone
  +deleteName()
  +findCreatedat()
  +cancelDuration()
  +createDescription()
}
class User {
  -long createdAt
  +float price
  #boolean name
  +setAddress()
  +updateUpdatedat()
}
class Message {
  -int phone
  -boolean price
  #float name
  +processUpdatedat()
  +deleteAmount()
}
Message --> User : "0..1"
Group ..> Message : "0..1"
@enduml