@startuml
skinparam monochrome true
abstract class Branch {
  -float address
  #boolean price
  -int description
  #float code
  +calculateType()
}
class Statement {
  #boolean name
  #boolean updatedAt
  +long score
  -double id
  -int amount
  +processDuration()
}
class Interest {
  #Date duration
  -Date createdAt
  -String amount
  +long score
  +findAddress()
  +validateAddress()
  +processName()
  +saveEmail()
}
abstract class Transaction {
  -int duration
  #float status
  +int level
  +findType()
  +findStatus()
  +validateCreatedat()
  +sendEmail()
}
class Deposit {
  +String amount
  #boolean name
  +String createdAt
  +cancelId()
  +setDuration()
  +setLevel()
  +updateType()
}
abstract class Teller {
  -String email
  +long duration
  #String quantity
  #boolean score
  +cancelActive()
  +validateDescription()
  +processEmail()
}
Transaction --> Branch : "1"
Transaction ..> Statement : "0..1"
Transaction --o Teller
Interest --o Deposit
Deposit ..> Transaction : "*"
@enduml