@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
interface Guest {
  -String type
  +double address
  +deleteTotal()
}
class Restaurant {
  #float status
  +double score
  +setPrice()
}
interface CheckOut {
  -String amount
  +Date name
  #boolean status
  +updateEmail()
  +updatePhone()
  +updateAmount()
  +findPhone()
}
class Reservation {
  #long phone
  -Date createdAt
  #long amount
  +calculateStatus()
  +sendActive()
  +processAmount()
  +createActive()
}
abstract class Invoice {
  #int note
  -float address
  #String score
  -float name
  +createDescription()
  +cancelAmount()
}
class Housekeeping {
  #boolean type
  #int quantity
  +Date address
  +createTotal()
}
Guest --o Invoice
Reservation ..|> Invoice
Restaurant --* Guest
Reservation --o Guest
@enduml