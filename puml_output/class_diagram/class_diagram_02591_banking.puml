@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Deposit {
  #String type
  -String active
  #long phone
  #String amount
  +float email
  +deleteAmount()
  +findActive()
  +updateTotal()
}
interface Loan {
  +double status
  -boolean active
  +String email
  +setCode()
  +processType()
}
abstract class Withdrawal {
  +String level
  +Date amount
  +boolean active
  +updateAmount()
  +validateUpdatedat()
}
class Card {
  #int updatedAt
  -float total
  #String price
  -long id
  +cancelQuantity()
  +getName()
  +getActive()
}
Card --o Loan
Card --o Withdrawal
Loan --|> Withdrawal
note right of Deposit : Banking domain
@enduml