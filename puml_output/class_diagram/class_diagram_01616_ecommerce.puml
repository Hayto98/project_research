@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Cart {
  +long active
  #Date code
  +String price
  -Date name
  +saveNote()
  +validateLevel()
}
class Return {
  #double updatedAt
  +float type
  #long name
  -String phone
  +setEmail()
  +updateEmail()
  +sendStatus()
  +saveQuantity()
}
class Customer {
  +int email
  -boolean type
  +long address
  +saveActive()
  +updateUpdatedat()
  +calculateNote()
}
class Payment {
  -float code
  -Date address
  +cancelScore()
  +savePrice()
}
class Order {
  +boolean code
  #String active
  +float amount
  #int updatedAt
  -String total
  +findAmount()
  +deleteName()
}
Cart ..|> Return
Payment ..|> Customer
@enduml