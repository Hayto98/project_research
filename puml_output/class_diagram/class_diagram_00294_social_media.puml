@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Follower {
  #Date phone
  +float updatedAt
  -int total
  -long level
  #boolean amount
  +deleteUpdatedat()
  +saveAddress()
}
abstract class User {
  -int status
  -long duration
  #double active
  #String address
  +updatePrice()
  +getUpdatedat()
  +validateScore()
  +processLevel()
}
abstract class Notification {
  +String quantity
  #Date price
  -float id
  +double active
  +setType()
}
class Album {
  -int name
  -float type
  +double price
  +updateCreatedat()
  +findStatus()
  +getLevel()
  +findType()
}
class Comment {
  +String total
  +double price
  +processActive()
}
class Profile {
  -long status
  -float address
  -boolean type
  +float createdAt
  +saveQuantity()
}
interface Message {
  -boolean name
  -int active
  -int id
  +boolean level
  +validateId()
  +findLevel()
  +saveAddress()
  +validateType()
}
Album ..|> Message
Comment ..|> Profile
User ..> Profile : "0..1"
@enduml