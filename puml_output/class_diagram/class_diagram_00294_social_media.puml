@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Follower {
  #Date phone
  +float updatedAt
  -int total
  -long level
  #boolean amount
  +cancelAmount()
  +calculatePhone()
}
class User {
  -int active
  -long address
  +sendCode()
  +calculateId()
  +validateTotal()
  +calculateActive()
}
class Notification {
  +Date price
  #double id
  +double active
  +int name
  +updateName()
}
abstract class Album {
  #double phone
  #String updatedAt
  +String address
  #double createdAt
  -String note
  +updatePrice()
}
interface Comment {
  #Date createdAt
  #long email
  +validateType()
}
class Profile {
  +int quantity
  #float phone
  -float price
  +float createdAt
  +sendEmail()
}
interface Message {
  #boolean description
  -String quantity
  +float createdAt
  -double code
  +deleteActive()
  +findUpdatedat()
  +calculatePrice()
  +deleteUpdatedat()
}
Album --> User : "*"
Notification ..> Message : "*"
Comment --> Notification : "0..1"
Album --> Profile : "1..*"
note right of Follower : Social Media domain
@enduml