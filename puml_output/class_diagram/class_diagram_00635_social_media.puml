@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
interface Notification {
  -float score
  -int quantity
  +boolean price
  #float name
  +createPhone()
  +updatePrice()
  +cancelCreatedat()
}
abstract class Story {
  +long phone
  +double total
  +saveDescription()
}
class Report {
  +long score
  -boolean type
  -boolean id
  #Date code
  +deleteId()
}
interface Follower {
  +Date amount
  +boolean email
  -boolean quantity
  -int address
  -float status
  +calculateAmount()
  +validateActive()
  +getCreatedat()
  +sendDuration()
}
class User {
  #float id
  +double address
  -float type
  +createName()
  +getPhone()
  +cancelPrice()
  +createId()
}
interface Group {
  #String createdAt
  +String address
  #long email
  #double description
  -int id
  +calculateUpdatedat()
}
class Album {
  -Date price
  -long level
  +double id
  +deleteNote()
  +findStatus()
  +savePhone()
}
Album ..|> Follower
Album --* User
Story --o Notification
Group --* Story
@enduml