@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
interface Notification {
  -float score
  -int quantity
  +boolean price
  #float name
  +setId()
  +calculateType()
  +getPhone()
}
abstract class Story {
  -Date quantity
  +Date createdAt
  +cancelQuantity()
  +sendType()
  +getCode()
}
class Report {
  #double quantity
  +long score
  -Date type
  #Date status
  +setDescription()
  +findCreatedat()
  +cancelEmail()
}
interface Follower {
  +String createdAt
  -Date price
  -Date level
  +double note
  -float amount
  +processTotal()
  +saveActive()
  +processCreatedat()
  +validateEmail()
}
class User {
  +boolean id
  -float code
  +processCreatedat()
  +getUpdatedat()
  +cancelCreatedat()
  +calculateLevel()
}
class Group {
  +Date address
  +long duration
  -float description
  +float total
  #float level
  +deleteStatus()
  +calculateUpdatedat()
  +createType()
}
class Album {
  -boolean email
  +long active
  #String amount
  +setTotal()
  +saveAddress()
  +cancelId()
}
Follower --> User : "1"
User ..> Report : "0..1"
note right of Notification : Social Media domain
@enduml