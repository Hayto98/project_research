@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
interface Book {
  +float name
  -boolean description
  +String createdAt
  +long code
  +processAmount()
  +createPrice()
  +sendNote()
}
class Publisher {
  -float quantity
  +int note
  +calculateStatus()
}
class Member {
  -boolean level
  #String duration
  -String description
  +createDescription()
  +sendPrice()
  +deletePhone()
  +validateTotal()
}
class Reservation {
  -String score
  -double code
  +float total
  -long note
  #boolean active
  +saveCreatedat()
  +createDuration()
}
class Fine {
  -int note
  #Date code
  -float score
  +createAmount()
  +validateName()
  +deleteAddress()
}
class Shelf {
  -boolean quantity
  +double name
  +double score
  +String address
  +validatePhone()
  +cancelScore()
}
class Librarian {
  -int amount
  #boolean total
  +getUpdatedat()
  +setScore()
}
Member --o Publisher
Reservation ..|> Publisher
Member ..|> Shelf
note right of Book : Library domain
@enduml