@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
interface Book {
  +float name
  -boolean description
  +String createdAt
  +long code
  +findActive()
  +saveUpdatedat()
  +updateCode()
}
class Publisher {
  #float price
  #String score
  -Date note
  -float name
  +calculateLevel()
  +updateUpdatedat()
  +sendNote()
}
class Member {
  #Date status
  +long duration
  +Date updatedAt
  -long description
  +boolean phone
  +validateQuantity()
  +validatePrice()
  +updateTotal()
  +setDuration()
}
class Reservation {
  #boolean amount
  -double type
  -String score
  -double code
  +float total
  +validateAmount()
  +setActive()
  +cancelName()
}
interface Fine {
  #int createdAt
  -String email
  #boolean duration
  +deleteAddress()
  +saveDescription()
  +createType()
  +createPrice()
}
class Shelf {
  -long amount
  -float phone
  -String name
  #boolean description
  +processScore()
  +getDuration()
  +deleteName()
}
interface Librarian {
  +String type
  +long status
  -boolean price
  +getQuantity()
  +processQuantity()
  +validatePrice()
}
Reservation ..|> Member
Fine ..|> Librarian
Book --|> Publisher
@enduml