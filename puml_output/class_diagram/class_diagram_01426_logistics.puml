@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
abstract class Vehicle {
  +int createdAt
  -String amount
  -long note
  +float score
  +calculateUpdatedat()
  +sendPhone()
  +calculatePrice()
  +savePhone()
}
abstract class Shipment {
  -long price
  #boolean score
  #Date name
  +int duration
  +validateAddress()
  +updateDuration()
  +calculateCode()
  +validateScore()
}
class Package {
  #String address
  +String amount
  +boolean updatedAt
  +saveName()
  +calculateActive()
  +deleteId()
  +validateNote()
}
class Route {
  -Date status
  +float type
  -int quantity
  #String description
  +calculateStatus()
  +validateStatus()
  +validateQuantity()
}
class Manifest {
  -Date status
  +float code
  +int quantity
  -String duration
  -long email
  +updateActive()
  +getDescription()
  +sendCreatedat()
  +saveAmount()
}
Manifest --> Shipment : "1"
Package --|> Route
Shipment ..> Route : "1..*"
@enduml