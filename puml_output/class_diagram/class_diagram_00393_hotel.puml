@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Room {
  -float type
  -boolean note
  +double total
  #float name
  +boolean status
  +deleteDuration()
  +processDuration()
  +saveId()
}
class Payment {
  #double phone
  +float description
  +int active
  +setQuantity()
  +cancelId()
  +createName()
}
class Amenity {
  -boolean code
  #int name
  +long amount
  -Date type
  +saveName()
  +processNote()
  +validateActive()
}
class Booking {
  +Date phone
  #boolean note
  +calculatePhone()
  +setCode()
}
class Housekeeping {
  -String phone
  -String type
  #long description
  +calculateActive()
}
Payment --|> Housekeeping
Amenity --|> Room
@enduml