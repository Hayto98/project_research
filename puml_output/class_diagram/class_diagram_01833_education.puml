@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Exam {
  +Date status
  +int active
  #String createdAt
  #float score
  #int note
  +createId()
}
interface Library {
  +double status
  #String name
  -Date address
  -float quantity
  +boolean code
  +sendEmail()
  +saveScore()
}
abstract class Course {
  #boolean email
  -String level
  #String type
  +validateStatus()
  +setQuantity()
  +processCode()
  +getPrice()
}
interface Book {
  +long address
  -Date score
  +sendAddress()
  +createEmail()
}
abstract class Student {
  -double status
  +int active
  -long phone
  -String duration
  +calculateEmail()
  +setName()
  +sendCreatedat()
  +findCreatedat()
}
class Teacher {
  +int active
  -Date type
  +setPhone()
  +sendStatus()
}
class Enrollment {
  -long price
  -String phone
  -String id
  +int description
  +updateId()
  +updateScore()
  +validateUpdatedat()
  +sendAddress()
}
Student --o Teacher
Library --* Enrollment
Library --|> Exam
Library ..|> Book
Course ..|> Exam
@enduml