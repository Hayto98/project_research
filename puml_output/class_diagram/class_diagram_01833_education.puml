@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Exam {
  +Date status
  +int active
  #String createdAt
  #float score
  #int note
  +cancelType()
}
class Library {
  -String duration
  +double address
  +processAddress()
}
class Course {
  +float createdAt
  #long phone
  #double type
  +getId()
  +calculateId()
  +cancelId()
  +validateScore()
}
class Book {
  -String note
  #boolean description
  -String email
  -double duration
  +updatePrice()
  +createPhone()
}
class Student {
  #float name
  +float id
  #double type
  +int email
  -Date level
  +cancelStatus()
  +cancelPhone()
}
abstract class Teacher {
  -String id
  -String description
  +int type
  #double email
  +createNote()
  +sendTotal()
  +deleteCreatedat()
  +validateUpdatedat()
}
class Enrollment {
  +long description
  +float note
  +sendNote()
  +saveCode()
}
Student ..|> Course
Teacher --|> Book
Book ..> Teacher : "1..*"
Course --o Book
Teacher --* Course
note right of Exam : Education domain
@enduml