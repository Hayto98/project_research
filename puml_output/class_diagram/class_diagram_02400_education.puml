@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Assignment {
  -int description
  +String updatedAt
  +Date amount
  +int quantity
  +saveCode()
  +sendUpdatedat()
  +calculateAddress()
  +cancelType()
}
interface Attendance {
  -String price
  +long level
  #boolean phone
  +calculateNote()
  +findLevel()
  +updateTotal()
  +findName()
}
class Department {
  #boolean email
  -Date code
  +cancelName()
  +findCode()
}
class Enrollment {
  +double phone
  #String email
  #int updatedAt
  #float description
  -long level
  +deleteAddress()
  +getQuantity()
  +getDuration()
  +savePhone()
}
class Student {
  -double active
  +String address
  #String name
  +updatePhone()
  +processCode()
}
abstract class Exam {
  #float level
  +Date active
  -float address
  -float price
  +Date code
  +calculatePhone()
}
Exam --|> Student
Assignment ..> Attendance : "1..*"
Department --o Student
Assignment --* Enrollment
@enduml