@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Assignment {
  -int description
  +String updatedAt
  +Date amount
  +int quantity
  +calculateAmount()
  +sendAmount()
  +calculateLevel()
  +cancelPhone()
}
abstract class Attendance {
  #boolean description
  -int phone
  +cancelName()
  +getEmail()
  +cancelCode()
}
interface Department {
  -long description
  +int phone
  -String id
  -boolean note
  +findUpdatedat()
}
abstract class Enrollment {
  +boolean note
  -String updatedAt
  -double name
  +String status
  +updateId()
}
abstract class Student {
  #float level
  +Date active
  -float address
  -float price
  +Date code
  +createQuantity()
}
interface Exam {
  #Date code
  -long updatedAt
  +getTotal()
  +validateUpdatedat()
  +processId()
  +getQuantity()
}
Student --> Department : "1"
Exam ..> Enrollment : "*"
Exam ..|> Student
Enrollment --o Student
note right of Assignment : Education domain
@enduml