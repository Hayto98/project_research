@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Enrollment {
  -float updatedAt
  +Date description
  -boolean createdAt
  +float address
  -String total
  +sendPrice()
  +setDuration()
  +validateStatus()
  +cancelCode()
}
interface Attendance {
  +Date createdAt
  -float description
  +int duration
  #String note
  +deleteId()
  +findUpdatedat()
}
class Assignment {
  #long amount
  -boolean active
  -double code
  #float status
  +boolean level
  +findCreatedat()
  +saveTotal()
  +deleteNote()
  +setPrice()
}
abstract class Classroom {
  +float email
  +long score
  +calculateCreatedat()
  +processStatus()
}
class Course {
  +float description
  #float status
  +deleteScore()
  +processCreatedat()
  +updateDuration()
  +findAddress()
}
class Grade {
  -String duration
  +Date phone
  +validateScore()
  +processId()
}
Grade ..> Enrollment : "1"
Enrollment ..|> Grade
Course ..> Assignment : "*"
@enduml