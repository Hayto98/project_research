@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
abstract class Shipment {
  -float description
  +boolean amount
  +boolean type
  #double address
  #double phone
  +setDescription()
}
interface Manifest {
  +float createdAt
  +boolean quantity
  +double duration
  #boolean total
  +calculateAddress()
  +savePhone()
  +updateNote()
  +sendType()
}
class Package {
  +long active
  #boolean updatedAt
  +float id
  #Date phone
  -String code
  +calculateQuantity()
}
abstract class Customer {
  -int email
  #int note
  +boolean type
  #String updatedAt
  +calculateQuantity()
  +createNote()
  +setActive()
}
class FuelLog {
  +long id
  #long status
  #long note
  +cancelUpdatedat()
}
Shipment --> FuelLog : "*"
Customer ..> Manifest : "1"
Manifest --> FuelLog : "1"
FuelLog --o Shipment
@enduml