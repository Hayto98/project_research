@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Customer {
  #int active
  +boolean score
  +boolean amount
  -long duration
  +deleteDescription()
  +cancelLevel()
  +saveDuration()
}
class Return {
  -Date phone
  -boolean description
  +updateTotal()
  +createAddress()
  +sendLevel()
}
class Supplier {
  -float address
  -Date active
  +long level
  +cancelScore()
  +setDescription()
}
abstract class Coupon {
  #boolean description
  #int score
  #boolean level
  +String id
  -Date active
  +saveType()
  +setId()
  +deleteType()
}
Supplier --|> Customer
Return --o Customer
note right of Customer : Ecommerce domain
@enduml