@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Customer {
  #int active
  +boolean score
  +boolean amount
  -long duration
  +calculateAddress()
  +findStatus()
  +updateAmount()
}
class Return {
  -Date status
  -boolean phone
  -int description
  +cancelAddress()
  +validateDuration()
  +findPrice()
  +deleteUpdatedat()
}
class Supplier {
  -float address
  -Date active
  +long level
  +savePrice()
  +cancelAmount()
}
class Coupon {
  #int total
  #float score
  #float note
  +setName()
}
Return --o Customer
Supplier ..> Coupon : "*"
@enduml