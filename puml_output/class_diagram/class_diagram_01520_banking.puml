@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
interface Deposit {
  -float active
  #long level
  +String address
  +findEmail()
}
class Transaction {
  -String createdAt
  #Date status
  +updateAddress()
  +deleteUpdatedat()
}
class Customer {
  +Date quantity
  #int price
  +long email
  +Date score
  +String total
  +getActive()
  +deleteEmail()
}
abstract class Account {
  -int createdAt
  -float type
  #int name
  +String description
  #int id
  +cancelPrice()
  +validateType()
  +cancelDuration()
}
class Card {
  -long amount
  -float level
  -int createdAt
  +getAmount()
  +saveId()
  +findTotal()
}
interface Withdrawal {
  #Date level
  #int updatedAt
  #Date amount
  +cancelAddress()
  +cancelActive()
}
Customer ..|> Card
Withdrawal ..|> Card
Transaction --* Account
@enduml