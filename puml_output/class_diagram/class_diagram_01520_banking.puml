@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
interface Deposit {
  -float active
  #long level
  +String address
  +findPhone()
}
class Transaction {
  #Date status
  +Date price
  #String name
  +createPrice()
  +findEmail()
  +createScore()
  +calculateCode()
}
class Customer {
  #String email
  +float id
  +findType()
  +saveActive()
}
abstract class Account {
  #Date duration
  +String type
  -int name
  +sendAmount()
  +getId()
  +saveCreatedat()
}
class Card {
  -double updatedAt
  -int amount
  -Date createdAt
  +float type
  +cancelUpdatedat()
  +deleteActive()
}
interface Withdrawal {
  -boolean level
  +long active
  #int createdAt
  +deleteType()
  +validateType()
}
Withdrawal --|> Account
Customer --|> Card
Customer --|> Withdrawal
Deposit --o Transaction
note right of Deposit : Banking domain
@enduml