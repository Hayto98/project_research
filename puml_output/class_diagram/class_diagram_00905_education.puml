@startuml
skinparam shadowing true
class Library {
  #String status
  +int code
  -String updatedAt
  +float quantity
  -Date price
  +sendLevel()
  +setUpdatedat()
  +createType()
}
abstract class Grade {
  #float name
  -int code
  +getUpdatedat()
  +saveNote()
  +setLevel()
}
interface Attendance {
  +Date active
  #float description
  +int type
  #float amount
  #double createdAt
  +setStatus()
  +updatePhone()
  +getId()
}
interface Teacher {
  -Date updatedAt
  +double id
  -String score
  +saveAddress()
  +deleteCode()
  +setUpdatedat()
  +createStatus()
}
abstract class Course {
  +float total
  +String note
  +long email
  #long description
  #String status
  +cancelDuration()
  +sendId()
  +processType()
}
Attendance ..> Course : "1"
Teacher --o Grade
Library ..|> Teacher
@enduml