@startuml
skinparam shadowing true
class Library {
  #String status
  +int code
  -String updatedAt
  +float quantity
  -Date price
  +getType()
  +getName()
  +setLevel()
}
abstract class Grade {
  #boolean email
  -boolean createdAt
  +double description
  +updateDescription()
  +findScore()
}
class Attendance {
  -String active
  #double total
  #float score
  +updateId()
  +sendAddress()
}
class Teacher {
  +boolean quantity
  -double code
  -double price
  #long amount
  +String phone
  +updateStatus()
}
class Course {
  -double address
  -long id
  #String phone
  #double createdAt
  +processStatus()
  +processAmount()
}
Library --o Attendance
Grade --* Attendance
Teacher --|> Attendance
Library --o Grade
note right of Library : Education domain
@enduml