@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Wishlist {
  -long phone
  +long email
  -long code
  +long price
  #float status
  +createPrice()
}
class Cart {
  #double phone
  +boolean score
  -Date createdAt
  +String description
  +float note
  +validateCode()
  +validateDuration()
  +cancelEmail()
  +deleteQuantity()
}
interface Return {
  +double createdAt
  -Date code
  +saveName()
}
interface Payment {
  #int note
  #Date type
  -String description
  +processUpdatedat()
  +deletePhone()
}
class Product {
  -Date id
  #Date name
  #float price
  -Date note
  +String duration
  +createScore()
}
Return ..> Cart : "0..1"
Payment --* Product
Wishlist ..|> Return
@enduml