@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Wishlist {
  -long phone
  +long email
  -long code
  +long price
  #float status
  +calculateCreatedat()
}
abstract class Cart {
  #double score
  +boolean createdAt
  -Date description
  +String note
  +calculateDescription()
}
class Return {
  #int status
  +int name
  +createCode()
  +calculateScore()
  +sendLevel()
  +saveLevel()
}
class Payment {
  +boolean type
  #int level
  +float description
  +double score
  +String quantity
  +processId()
  +calculateScore()
  +findLevel()
  +processUpdatedat()
}
class Product {
  -Date updatedAt
  +Date phone
  +saveType()
  +calculateQuantity()
}
Return --|> Cart
Wishlist --> Product : "0..1"
note right of Wishlist : Ecommerce domain
@enduml