@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Doctor {
  +double amount
  -double updatedAt
  #String type
  +updateDuration()
  +updateDuration()
}
interface MedicalRecord {
  #float level
  -boolean phone
  #boolean note
  +getPhone()
}
class Ward {
  #boolean code
  -long description
  +double name
  +processActive()
  +calculateActive()
  +processDescription()
  +cancelUpdatedat()
}
class LabTest {
  -Date address
  -Date total
  -Date type
  +int description
  +float level
  +updateCreatedat()
  +calculateUpdatedat()
}
Doctor --o Ward
MedicalRecord --|> LabTest
note right of Doctor : Healthcare domain
@enduml