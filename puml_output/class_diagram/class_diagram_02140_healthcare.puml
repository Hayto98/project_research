@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Doctor {
  +double amount
  -double updatedAt
  #String type
  +cancelNote()
  +findUpdatedat()
}
class MedicalRecord {
  #float level
  -boolean phone
  #boolean note
  +setUpdatedat()
}
class Ward {
  #float description
  +Date code
  #double duration
  +processAmount()
  +deleteAmount()
  +createDescription()
}
abstract class LabTest {
  #int active
  +double total
  -float duration
  -boolean note
  -int description
  +deleteCode()
  +findStatus()
  +updateEmail()
  +getActive()
}
Doctor --|> LabTest
MedicalRecord ..|> Doctor
LabTest --o Doctor
@enduml