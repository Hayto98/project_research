@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Author {
  -long name
  +float email
  +cancelType()
  +deleteNote()
  +processId()
}
class Publisher {
  #float status
  -double note
  #String duration
  +boolean total
  +deleteName()
}
abstract class Librarian {
  +long phone
  #Date total
  +int type
  -float createdAt
  +findLevel()
  +validatePhone()
  +saveTotal()
}
class Member {
  +long phone
  +float name
  -boolean total
  +deleteActive()
  +deleteTotal()
  +saveAmount()
}
class Book {
  #boolean note
  -float amount
  +saveQuantity()
  +processScore()
}
abstract class Reservation {
  -String amount
  #long score
  +int total
  -long code
  +savePhone()
  +processScore()
  +calculateNote()
}
Librarian --o Reservation
Book --|> Librarian
@enduml