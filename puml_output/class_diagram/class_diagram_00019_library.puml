@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Author {
  -long name
  +float email
  +getLevel()
  +deleteLevel()
  +createStatus()
}
abstract class Publisher {
  -boolean total
  +String quantity
  +createType()
}
class Librarian {
  -Date total
  #int type
  +long createdAt
  -float id
  +deleteLevel()
}
class Member {
  +float name
  -boolean total
  -double id
  -String address
  +processAmount()
}
interface Book {
  #int amount
  #boolean description
  -boolean total
  +long email
  +saveEmail()
}
class Reservation {
  +float address
  +int email
  -long quantity
  +cancelQuantity()
  +getQuantity()
  +createCode()
  +validateDescription()
}
Author --* Publisher
Librarian --|> Book
Librarian ..> Author : "0..1"
note right of Author : Library domain
@enduml