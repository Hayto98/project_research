@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
abstract class Transfer {
  +double code
  -double amount
  #Date price
  +saveUpdatedat()
}
class Transaction {
  +Date email
  -boolean phone
  +float updatedAt
  +double address
  +sendCreatedat()
}
interface Statement {
  -String level
  +float price
  #long active
  +int updatedAt
  +cancelPrice()
  +calculateAmount()
}
class Withdrawal {
  #boolean score
  -Date amount
  -boolean updatedAt
  -long type
  +int description
  +createNote()
  +saveActive()
  +updatePhone()
  +createCreatedat()
}
interface Card {
  #boolean type
  +int note
  #int createdAt
  +double name
  +validateDuration()
  +createCode()
}
abstract class Branch {
  -boolean address
  +long level
  #double phone
  -int active
  +getLevel()
  +processType()
  +updateName()
}
Branch --> Transaction : "0..1"
Transaction --* Transfer
note right of Transfer : Banking domain
@enduml