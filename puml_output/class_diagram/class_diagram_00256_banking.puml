@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
abstract class Transfer {
  +double code
  -double amount
  #Date price
  +getStatus()
}
class Transaction {
  -int quantity
  #long email
  +updateAmount()
  +setCreatedat()
}
class Statement {
  #int updatedAt
  #long type
  #double id
  +validateUpdatedat()
  +saveEmail()
}
class Withdrawal {
  -int id
  +double createdAt
  #Date amount
  +int price
  +createCreatedat()
  +calculateDescription()
  +createDescription()
  +saveStatus()
}
abstract class Card {
  -long score
  -float note
  #boolean address
  +float status
  -long createdAt
  +getQuantity()
  +findQuantity()
}
abstract class Branch {
  +double createdAt
  #float name
  +float status
  -boolean description
  -Date duration
  +createId()
}
Statement --> Branch : "1..*"
Card --> Withdrawal : "1"
Statement --* Withdrawal
Transaction ..> Card : "1..*"
Transfer --o Card
@enduml