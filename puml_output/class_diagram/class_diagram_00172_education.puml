@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Assignment {
  -int total
  +int note
  -int active
  -String address
  +processPrice()
  +calculateDescription()
  +getAddress()
}
class Teacher {
  -float createdAt
  -Date name
  +findDuration()
}
abstract class Library {
  +Date active
  #boolean id
  #boolean updatedAt
  #int description
  +saveLevel()
  +sendDuration()
  +sendDuration()
}
class Department {
  -int code
  +float description
  -boolean createdAt
  #float address
  -float updatedAt
  +cancelName()
}
class Schedule {
  +int price
  -int updatedAt
  +int active
  +createDuration()
  +setName()
  +cancelNote()
}
class Exam {
  +long name
  #double active
  -Date level
  #String note
  -boolean description
  +processEmail()
  +deleteAddress()
  +getScore()
  +updateId()
}
class Student {
  #double type
  #int email
  #Date name
  #boolean active
  +setDuration()
  +createAddress()
  +validatePrice()
  +findEmail()
}
Student --|> Assignment
Assignment --|> Teacher
Assignment ..> Exam : "1..*"
Exam --|> Assignment
note right of Assignment : Education domain
@enduml