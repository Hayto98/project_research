@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Assignment {
  -int total
  +int note
  -int active
  -String address
  +sendCreatedat()
  +saveCode()
  +getStatus()
}
abstract class Teacher {
  +int name
  +float address
  -float level
  +cancelPrice()
  +setUpdatedat()
  +sendDescription()
  +cancelUpdatedat()
}
interface Library {
  +Date email
  #boolean active
  #boolean id
  #int updatedAt
  #long description
  +deleteType()
  +processScore()
}
abstract class Department {
  -int description
  -int createdAt
  +deletePhone()
}
class Schedule {
  +double id
  +float level
  #String name
  +double duration
  +deleteQuantity()
  +sendId()
}
class Exam {
  #Date duration
  -float status
  #double name
  #String note
  +findEmail()
  +setType()
  +setQuantity()
  +sendDescription()
}
class Student {
  #double price
  -long note
  +long name
  +Date email
  +updateId()
  +updateDuration()
}
Library --* Department
Assignment --> Exam : "*"
@enduml