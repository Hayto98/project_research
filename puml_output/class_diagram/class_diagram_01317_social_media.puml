@startuml

class Group {
  +boolean type
  +double email
  +deleteName()
  +createUpdatedat()
}
class Post {
  +Date price
  -Date code
  -long total
  +float phone
  +findCode()
}
class Message {
  -int phone
  #long note
  #float level
  +long description
  +setType()
  +processCode()
  +calculateLevel()
}
class User {
  -Date price
  #String address
  +Date phone
  #float name
  #float note
  +cancelDuration()
  +cancelId()
  +findLevel()
  +getLevel()
}
interface Hashtag {
  +int amount
  #long createdAt
  -float quantity
  -long type
  -int price
  +updateQuantity()
}
abstract class Story {
  +boolean createdAt
  #Date type
  -Date total
  +sendQuantity()
  +findName()
  +createCode()
}
abstract class Comment {
  +Date level
  +Date id
  -boolean quantity
  +float updatedAt
  +processCreatedat()
}
Story --o Comment
Hashtag --> Story : "1"
Hashtag --* Message
Group --> Message : "1..*"
Hashtag ..|> User
note right of Group : Social Media domain
@enduml