@startuml
skinparam shadowing true
class Ward {
  +double duration
  #long phone
  #double id
  +int score
  +Date description
  +calculateAmount()
}
class Prescription {
  +boolean price
  -int quantity
  +long total
  #String type
  +validateScore()
}
interface Appointment {
  +boolean email
  -boolean note
  +deleteLevel()
}
class Hospital {
  #float score
  +String id
  +updateScore()
  +processTotal()
  +cancelAmount()
}
abstract class Treatment {
  #Date address
  #float name
  -boolean price
  -long id
  +cancelType()
  +findName()
}
Ward ..> Hospital : "1..*"
Treatment --|> Appointment
Ward --o Treatment
Hospital --o Prescription
@enduml