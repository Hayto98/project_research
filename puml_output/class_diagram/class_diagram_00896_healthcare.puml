@startuml
skinparam shadowing true
class Ward {
  +double duration
  #long phone
  #double id
  +int score
  +Date description
  +processId()
}
interface Prescription {
  +boolean price
  -int quantity
  +long total
  #String type
  +validateDuration()
}
class Appointment {
  #String note
  -String status
  #boolean score
  +boolean email
  +setDuration()
}
class Hospital {
  -String score
  #Date total
  #float email
  -boolean address
  -long name
  +cancelId()
  +processPhone()
}
interface Treatment {
  #double code
  #Date status
  #float id
  +double price
  +createScore()
  +processName()
  +cancelNote()
  +processCreatedat()
}
Appointment --> Hospital : "0..1"
Ward --o Hospital
Ward --o Treatment
note right of Ward : Healthcare domain
@enduml