@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class CheckIn {
  -int price
  #Date updatedAt
  +saveId()
  +findScore()
  +deleteScore()
  +createName()
}
abstract class Room {
  #Date id
  -long duration
  #String code
  -float active
  +String score
  +setAmount()
  +saveCode()
}
class Housekeeping {
  -String note
  #double price
  -int phone
  +String level
  +deleteAmount()
  +setQuantity()
}
class Guest {
  +Date phone
  #float id
  +Date amount
  +boolean updatedAt
  +double score
  +setDescription()
  +createScore()
}
abstract class Invoice {
  #boolean duration
  #boolean price
  +Date type
  +saveAmount()
  +validatePhone()
  +findPhone()
  +cancelAddress()
}
Guest --* CheckIn
Housekeeping ..|> Guest
note right of CheckIn : Hotel domain
@enduml