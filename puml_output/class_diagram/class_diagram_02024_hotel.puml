@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class CheckIn {
  -int price
  #Date updatedAt
  +calculateUpdatedat()
  +cancelName()
  +cancelTotal()
  +deleteLevel()
}
interface Room {
  -double score
  +String email
  +boolean name
  +updateNote()
}
abstract class Housekeeping {
  +float score
  #int id
  +int phone
  #String amount
  +getActive()
  +calculateScore()
}
abstract class Guest {
  -int phone
  +String price
  #int level
  +int id
  +long type
  +cancelType()
  +createName()
}
class Invoice {
  +String amount
  #boolean updatedAt
  +cancelPrice()
}
Invoice --o Room
Room ..> CheckIn : "0..1"
@enduml