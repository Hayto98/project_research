@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Shipment {
  #String note
  #long status
  +long email
  +validateCreatedat()
}
interface Route {
  +String duration
  -Date createdAt
  +String address
  +updateId()
}
abstract class FuelLog {
  -long amount
  +int address
  -int code
  +getId()
  +createNote()
  +sendActive()
  +deleteScore()
}
interface Depot {
  -long email
  #long score
  -boolean name
  -Date type
  +findActive()
  +validateScore()
  +saveDescription()
}
abstract class Customer {
  #Date code
  -long phone
  +processQuantity()
  +calculateDescription()
  +setScore()
}
Customer --> Depot : "*"
Shipment --o Customer
Route --|> FuelLog
Shipment ..> Depot : "0..1"
@enduml