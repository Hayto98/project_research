@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class DeliveryNote {
  #boolean name
  +boolean address
  +saveDescription()
  +saveActive()
}
class Vehicle {
  +int email
  -float description
  -float note
  +Date total
  +validateAmount()
  +findCreatedat()
  +cancelLevel()
  +createDuration()
}
class Package {
  +boolean quantity
  -float amount
  #float score
  +validateCreatedat()
  +deleteDuration()
  +getStatus()
  +validateActive()
}
class Shipment {
  +String status
  #double email
  +deleteLevel()
  +createId()
  +findTotal()
  +getCode()
}
class Depot {
  +double code
  +long email
  -long id
  +processStatus()
  +sendDescription()
}
class Manifest {
  -float code
  +boolean id
  #int address
  +sendName()
  +findType()
  +validateCode()
  +createName()
}
Package --* Depot
Shipment ..|> Manifest
Package --|> Manifest
@enduml