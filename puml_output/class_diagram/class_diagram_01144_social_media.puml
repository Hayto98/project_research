@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Hashtag {
  +int email
  #long score
  #int type
  #float code
  +deleteNote()
}
interface Post {
  +boolean quantity
  -Date name
  #Date updatedAt
  +String status
  -String createdAt
  +getDuration()
}
abstract class Profile {
  #long id
  -float total
  +double quantity
  +processCode()
  +createPhone()
  +saveAddress()
}
abstract class Follower {
  +long id
  -boolean description
  +long status
  +int note
  +saveType()
}
class Notification {
  +long score
  +long address
  +createScore()
  +setQuantity()
  +createId()
}
interface Album {
  +float email
  #int note
  -float createdAt
  -Date phone
  +processCreatedat()
  +createLevel()
  +findNote()
}
Hashtag ..|> Notification
Profile --> Album : "*"
Follower ..> Post : "0..1"
@enduml