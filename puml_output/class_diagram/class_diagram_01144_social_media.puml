@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Hashtag {
  +int email
  #long score
  #int type
  #float code
  +getScore()
}
interface Post {
  +boolean quantity
  -Date name
  #Date updatedAt
  +String status
  -String createdAt
  +processScore()
}
interface Profile {
  #long id
  -float total
  +double quantity
  +getStatus()
  +deletePrice()
  +createId()
}
class Follower {
  -long note
  #float name
  +validateStatus()
}
class Notification {
  #boolean status
  -String code
  +updateAddress()
  +createUpdatedat()
  +cancelAddress()
}
class Album {
  -Date createdAt
  -Date phone
  +int duration
  +boolean score
  +long note
  +cancelTotal()
  +processAmount()
  +saveActive()
}
Follower --o Hashtag
Notification --* Album
Notification ..> Hashtag : "*"
note right of Hashtag : Social Media domain
@enduml