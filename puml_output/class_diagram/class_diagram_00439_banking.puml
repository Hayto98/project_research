@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Customer {
  +long note
  -Date address
  #long updatedAt
  +saveActive()
  +calculateId()
  +updateCreatedat()
}
abstract class Transaction {
  #boolean note
  +Date total
  +findAmount()
  +getTotal()
}
interface Teller {
  -int score
  #double phone
  -float duration
  #long type
  #float address
  +saveEmail()
  +calculatePrice()
}
class Transfer {
  +float phone
  +Date type
  +boolean id
  +createEmail()
  +sendLevel()
}
interface Branch {
  +boolean duration
  +float total
  +updateNote()
  +findPhone()
  +validateQuantity()
}
Branch --|> Customer
Teller ..> Customer : "0..1"
Customer --* Transaction
@enduml