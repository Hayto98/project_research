@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Department {
  -int description
  #long active
  #int updatedAt
  #float name
  +Date email
  +deletePhone()
}
class Grade {
  +int note
  #double type
  #String code
  #Date name
  +getPrice()
  +createPhone()
}
class Schedule {
  +boolean code
  +Date address
  -Date duration
  +getEmail()
  +deleteDescription()
}
interface Assignment {
  -int id
  #float price
  #Date amount
  +sendCode()
  +getDuration()
}
class Book {
  +boolean type
  #double total
  -boolean active
  #long price
  +saveDuration()
}
class Course {
  -long score
  -Date amount
  -double quantity
  +getTotal()
  +deleteAmount()
}
class Exam {
  #double total
  -long phone
  #Date id
  +calculateScore()
  +getTotal()
}
Course ..> Assignment : "1..*"
Course ..|> Schedule
note right of Department : Education domain
@enduml