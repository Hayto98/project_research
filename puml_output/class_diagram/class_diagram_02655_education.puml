@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Department {
  -int description
  #long active
  #int updatedAt
  #float name
  +Date email
  +calculateAddress()
}
class Grade {
  -String score
  +String address
  +Date note
  +deleteUpdatedat()
  +setName()
  +getName()
  +updateId()
}
class Schedule {
  -int price
  #int quantity
  +processCreatedat()
}
class Assignment {
  +Date name
  -Date active
  +saveEmail()
  +calculateType()
}
class Book {
  +boolean description
  -int active
  -int createdAt
  +sendQuantity()
  +getType()
}
class Course {
  #boolean address
  #float type
  -int total
  +findScore()
  +setAddress()
  +findUpdatedat()
  +validateAddress()
}
class Exam {
  -double description
  -long score
  #float amount
  +processLevel()
  +validateActive()
  +getTotal()
}
Assignment ..|> Grade
Exam ..|> Schedule
@enduml