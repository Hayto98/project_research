@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
abstract class Return {
  +int address
  -boolean price
  +double note
  +cancelPhone()
  +calculateTotal()
}
class Shipment {
  #double price
  #String quantity
  +int email
  #String level
  +float id
  +saveName()
  +cancelUpdatedat()
  +updateAmount()
  +findCreatedat()
}
interface Supplier {
  -boolean code
  +float address
  +boolean active
  -long note
  +Date duration
  +calculateNote()
  +sendDescription()
  +sendUpdatedat()
  +deleteQuantity()
}
class Review {
  +boolean name
  +float price
  +findNote()
  +calculateEmail()
  +sendPhone()
  +processId()
}
class Wishlist {
  +boolean type
  -float price
  +float active
  +createActive()
}
abstract class Coupon {
  #boolean createdAt
  +double address
  #int description
  +Date quantity
  +updateAmount()
  +saveTotal()
}
class Order {
  #int status
  #float id
  +int price
  +findId()
}
Shipment --o Order
Coupon ..> Order : "1..*"
Review --> Return : "0..1"
Wishlist --* Shipment
Order --|> Shipment
Order ..> Return : "*"
@enduml