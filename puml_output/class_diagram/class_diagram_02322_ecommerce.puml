@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
interface Customer {
  -int createdAt
  +String email
  #double total
  #float quantity
  +setDescription()
  +updatePhone()
  +createDescription()
  +updateAddress()
}
interface Shipment {
  -String code
  +long duration
  -double createdAt
  +int score
  -int level
  +getTotal()
  +validateEmail()
  +createQuantity()
  +updateId()
}
class Category {
  +long amount
  -Date phone
  +getTotal()
}
class Order {
  #Date note
  +double level
  #Date code
  #Date phone
  +cancelUpdatedat()
  +processType()
  +setTotal()
  +validateId()
}
abstract class Invoice {
  +double duration
  +long amount
  +cancelPrice()
}
interface Coupon {
  +double code
  +String description
  #float updatedAt
  +double status
  -int createdAt
  +getPrice()
  +findUpdatedat()
}
class Wishlist {
  -float price
  #float phone
  +String address
  -boolean email
  -String total
  +findCreatedat()
  +cancelType()
  +findPrice()
  +sendTotal()
}
Customer --> Shipment : "1"
Invoice ..|> Order
Order --* Coupon
Customer --> Wishlist : "*"
Order --o Customer
@enduml