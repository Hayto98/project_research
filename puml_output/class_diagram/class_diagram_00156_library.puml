@startuml
skinparam monochrome true
class Reservation {
  -Date createdAt
  #String active
  #int description
  +double phone
  -String note
  +findCode()
}
class Fine {
  -float note
  +Date code
  #long amount
  #float email
  -String score
  +findType()
  +getId()
  +setDescription()
}
interface Catalog {
  +Date amount
  -int type
  +cancelCode()
  +deleteDuration()
  +getLevel()
  +getType()
}
abstract class Librarian {
  #double code
  -double level
  +setLevel()
  +findActive()
  +calculateStatus()
  +createId()
}
Catalog --o Librarian
Fine --> Reservation : "*"
note right of Reservation : Library domain
@enduml