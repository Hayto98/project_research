@startuml
skinparam monochrome true
class Reservation {
  -Date createdAt
  #String active
  #int description
  +double phone
  -String note
  +calculateLevel()
}
class Fine {
  +long note
  #int duration
  -float code
  +cancelPrice()
  +getUpdatedat()
}
interface Catalog {
  +String address
  +float id
  +float quantity
  #float type
  +findId()
}
abstract class Librarian {
  #boolean note
  -boolean description
  +float score
  +sendActive()
  +updatePrice()
}
Librarian --|> Fine
Reservation --> Catalog : "*"
@enduml