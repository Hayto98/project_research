@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
interface Course {
  #float name
  -int phone
  -float note
  +createDuration()
  +calculateScore()
  +getUpdatedat()
  +deleteStatus()
}
class Library {
  #Date name
  -long email
  -float createdAt
  #long price
  +getStatus()
  +getStatus()
}
abstract class Student {
  #int total
  -boolean active
  +calculateDuration()
  +getActive()
  +updateScore()
}
interface Teacher {
  +long address
  #boolean duration
  +boolean createdAt
  +float level
  +String total
  +getDescription()
  +createCode()
  +validateNote()
}
interface Department {
  -long quantity
  #double status
  -long address
  +String total
  #int updatedAt
  +processActive()
  +createId()
}
Library ..> Department : "1..*"
Student ..|> Teacher
Course --|> Library
note right of Course : Education domain
@enduml