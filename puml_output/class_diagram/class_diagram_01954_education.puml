@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
interface Course {
  #float name
  -int phone
  -float note
  +calculatePhone()
  +deleteDescription()
  +saveName()
  +setAmount()
}
interface Library {
  +float updatedAt
  +long amount
  +setPhone()
}
class Student {
  -float price
  #long duration
  #int address
  +getAmount()
}
class Teacher {
  #String status
  -boolean note
  +createAmount()
  +saveActive()
}
interface Department {
  #float total
  #boolean id
  #double active
  -long createdAt
  +calculateName()
  +cancelCreatedat()
}
Student --> Library : "0..1"
Course --> Department : "1..*"
@enduml