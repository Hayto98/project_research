@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
interface Classroom {
  #String id
  -String phone
  #double level
  #String total
  +long description
  +processLevel()
  +calculateCreatedat()
  +getCode()
}
class Student {
  -boolean duration
  #float id
  +deletePhone()
  +cancelAmount()
  +processId()
}
interface Enrollment {
  #float address
  +boolean type
  -int status
  +sendNote()
}
abstract class Attendance {
  +int active
  #String createdAt
  +boolean email
  +validateStatus()
  +validateId()
  +calculateStatus()
  +sendDescription()
}
class Teacher {
  +Date address
  +long type
  +String description
  +sendCode()
  +cancelCreatedat()
  +findName()
  +calculateQuantity()
}
interface Assignment {
  -long email
  +Date score
  +String note
  +float updatedAt
  +setDuration()
  +processLevel()
}
class Library {
  -long email
  -double quantity
  +double createdAt
  +getName()
  +createDuration()
  +createEmail()
  +deletePhone()
}
Teacher --|> Library
Enrollment --|> Classroom
Classroom --* Teacher
Enrollment --|> Assignment
Classroom --> Library : "1"
@enduml