@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
interface Classroom {
  #String id
  -String phone
  #double level
  #String total
  +long description
  +calculateAddress()
  +cancelDescription()
  +saveId()
}
interface Student {
  #float total
  #long level
  +validateType()
  +cancelStatus()
}
interface Enrollment {
  +float active
  #String quantity
  +findType()
  +updateActive()
}
class Attendance {
  +boolean code
  #float description
  -float score
  +Date id
  +updateAddress()
  +processDescription()
  +setName()
}
class Teacher {
  -boolean status
  -boolean price
  -long note
  +saveUpdatedat()
  +calculateQuantity()
  +getStatus()
  +setCreatedat()
}
class Assignment {
  -long amount
  -double createdAt
  +double email
  #Date quantity
  #boolean level
  +calculateTotal()
  +cancelActive()
  +getAddress()
  +getCode()
}
class Library {
  #String email
  -Date id
  -float status
  #Date code
  +createQuantity()
  +updateAddress()
  +sendCode()
  +calculateAmount()
}
Assignment ..|> Teacher
Student ..> Classroom : "1..*"
note right of Classroom : Education domain
@enduml