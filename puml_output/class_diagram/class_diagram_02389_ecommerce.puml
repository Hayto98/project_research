@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Return {
  -String id
  +long address
  +double updatedAt
  +long quantity
  #long phone
  +validateEmail()
}
class Wishlist {
  -Date note
  +double type
  -long amount
  -String description
  -boolean email
  +createAmount()
  +getActive()
  +setPhone()
  +sendPhone()
}
interface Coupon {
  #int duration
  #double description
  -boolean name
  -double address
  -boolean updatedAt
  +validateStatus()
  +updateName()
  +deleteActive()
  +findEmail()
}
class Shipment {
  -long status
  -String duration
  -Date phone
  #String amount
  +setScore()
  +setAmount()
}
Shipment ..> Wishlist : "1..*"
Shipment --> Coupon : "0..1"
note right of Return : Ecommerce domain
@enduml