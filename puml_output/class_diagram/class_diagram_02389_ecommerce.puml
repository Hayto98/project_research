@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Return {
  -String id
  +long address
  +double updatedAt
  +long quantity
  #long phone
  +findQuantity()
}
class Wishlist {
  -float duration
  #double active
  #int type
  +setQuantity()
  +findCreatedat()
}
abstract class Coupon {
  -double price
  +double total
  +validateAddress()
  +calculateAddress()
  +deleteNote()
  +sendQuantity()
}
class Shipment {
  #int active
  +long phone
  +Date score
  +Date note
  +processPhone()
  +deleteDuration()
  +calculatePrice()
  +deleteCreatedat()
}
Shipment --> Coupon : "*"
Coupon ..|> Return
Return --> Shipment : "1..*"
@enduml