@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Follower {
  +String id
  +double phone
  +deleteName()
}
class Message {
  #String status
  -int price
  -boolean email
  +float duration
  #int name
  +updateAmount()
  +processId()
  +calculateCode()
}
abstract class Report {
  -int duration
  -boolean email
  #boolean code
  +sendPrice()
}
class Comment {
  +float price
  #Date phone
  #Date status
  #String name
  +double address
  +processType()
  +createUpdatedat()
}
Comment --> Follower : "0..1"
Comment --* Report
Report --|> Message
@enduml