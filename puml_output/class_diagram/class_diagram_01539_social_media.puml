@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Follower {
  +String id
  +double phone
  +createEmail()
}
interface Message {
  #String status
  -int price
  -boolean email
  +float duration
  #int name
  +cancelPrice()
  +processDescription()
  +findDuration()
}
class Report {
  -boolean quantity
  #boolean description
  +savePhone()
}
abstract class Comment {
  +float duration
  #Date phone
  #Date status
  #String name
  +double address
  +calculateActive()
  +validateActive()
}
Message ..|> Report
Comment --* Report
Report --|> Message
note right of Follower : Social Media domain
@enduml