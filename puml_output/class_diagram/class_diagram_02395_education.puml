@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
abstract class Department {
  +int amount
  -float duration
  +sendActive()
  +findName()
  +saveDuration()
}
class Library {
  -float updatedAt
  +boolean description
  +deleteAddress()
  +sendNote()
  +createActive()
}
class Exam {
  -Date status
  #float duration
  +setAddress()
}
class Attendance {
  #String level
  -boolean name
  +long quantity
  -Date updatedAt
  +setEmail()
  +cancelName()
}
class Schedule {
  #int phone
  +boolean updatedAt
  +updateDescription()
  +setDuration()
  +cancelCode()
  +saveCreatedat()
}
interface Book {
  #double createdAt
  -String note
  -long type
  -int description
  +processQuantity()
  +deleteAddress()
}
class Classroom {
  +double quantity
  -long level
  +sendEmail()
}
Department --o Classroom
Library --* Exam
Book --|> Exam
Department --|> Book
@enduml