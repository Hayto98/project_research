@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
abstract class Department {
  +int amount
  -float duration
  +cancelLevel()
  +cancelQuantity()
  +cancelName()
}
class Library {
  -int price
  +long updatedAt
  -String score
  +setType()
}
class Exam {
  -int email
  #String level
  -boolean name
  +validateAddress()
  +saveCreatedat()
}
class Attendance {
  +boolean code
  #double phone
  +double updatedAt
  -Date createdAt
  +updateDuration()
  +processType()
  +deleteTotal()
}
abstract class Schedule {
  -int type
  +String email
  +updateLevel()
  +cancelName()
}
class Book {
  -float price
  +int email
  +getName()
  +calculateDescription()
  +createAddress()
}
class Classroom {
  +int status
  +double id
  +findScore()
  +setCode()
  +setTotal()
  +sendDescription()
}
Book --* Classroom
Schedule ..> Library : "1..*"
Attendance --> Library : "*"
Library --o Book
note right of Department : Education domain
@enduml