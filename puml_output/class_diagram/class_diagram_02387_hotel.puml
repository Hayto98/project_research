@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
abstract class Reservation {
  #boolean duration
  +float total
  +long id
  #float quantity
  +createAmount()
}
interface Room {
  -long quantity
  -int id
  -long status
  +cancelType()
}
abstract class Booking {
  #boolean name
  -String phone
  +setScore()
  +findCreatedat()
  +findDescription()
}
class CheckIn {
  #double updatedAt
  #float description
  #boolean score
  +boolean id
  +float name
  +cancelCreatedat()
  +processStatus()
}
Booking --o CheckIn
Reservation ..|> CheckIn
CheckIn --> Room : "0..1"
@enduml