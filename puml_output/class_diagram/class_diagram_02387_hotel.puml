@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
abstract class Reservation {
  #boolean duration
  +float total
  +long id
  #float quantity
  +validateLevel()
}
class Room {
  -int id
  -long status
  +float note
  -String phone
  +validateActive()
}
interface Booking {
  -float status
  +int address
  #Date email
  +String updatedAt
  +findActive()
  +deleteScore()
  +deleteCreatedat()
  +calculatePhone()
}
abstract class CheckIn {
  +float level
  #float type
  -double code
  #int name
  +calculateStatus()
  +updateNote()
  +updateScore()
}
Booking --> Reservation : "0..1"
note right of Reservation : Hotel domain
@enduml