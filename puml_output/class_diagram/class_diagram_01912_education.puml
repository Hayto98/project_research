@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Course {
  #int code
  -double quantity
  #Date address
  +deleteEmail()
}
interface Student {
  +double price
  #long code
  +findTotal()
}
class Schedule {
  #int level
  -int phone
  -String createdAt
  +findPrice()
  +sendPhone()
  +updateDescription()
  +processDuration()
}
class Teacher {
  -float amount
  #double address
  -double createdAt
  -boolean phone
  +double active
  +saveDescription()
  +setPhone()
  +processCreatedat()
}
Student --> Schedule : "0..1"
Schedule ..|> Student
@enduml