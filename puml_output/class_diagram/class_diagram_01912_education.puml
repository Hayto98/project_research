@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Course {
  #int code
  -double quantity
  #Date address
  +sendName()
}
abstract class Student {
  #long id
  #String type
  +updateLevel()
}
class Schedule {
  +long duration
  +double amount
  #long email
  +updateAmount()
  +calculateAmount()
}
class Teacher {
  #double phone
  -double duration
  -boolean price
  +calculateDuration()
}
Course --> Teacher : "0..1"
Schedule ..|> Student
note right of Course : Education domain
@enduml