@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Enrollment {
  +Date address
  #boolean type
  +String status
  +Date note
  -double duration
  +createActive()
  +validateName()
  +setLevel()
  +saveLevel()
}
class Teacher {
  #boolean phone
  #long address
  -float amount
  +createId()
  +updateLevel()
  +deleteAddress()
}
class Student {
  #boolean amount
  -Date name
  #float createdAt
  -Date score
  +cancelPrice()
  +findEmail()
  +saveCreatedat()
  +createId()
}
class Department {
  -float total
  +long active
  +String type
  -Date name
  -long status
  +createName()
  +findDescription()
  +validatePhone()
  +deleteId()
}
class Exam {
  +double active
  -double note
  #boolean updatedAt
  #boolean address
  -boolean name
  +createDescription()
  +calculateQuantity()
  +calculateNote()
}
interface Library {
  #long level
  #float address
  -String phone
  +float note
  +int createdAt
  +findScore()
}
class Attendance {
  +boolean duration
  #String type
  +calculateAddress()
  +saveAddress()
  +setDuration()
}
Student --|> Exam
Student ..> Department : "1"
Enrollment --* Student
Department --|> Enrollment
Teacher --|> Enrollment
@enduml