@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Enrollment {
  +Date address
  #boolean type
  +String status
  +Date note
  -double duration
  +validateType()
  +deleteAddress()
  +updatePhone()
  +validateAmount()
}
interface Teacher {
  +long type
  #boolean active
  -Date phone
  #float quantity
  +saveName()
  +findCreatedat()
}
interface Student {
  #double score
  #long price
  +double note
  +sendType()
  +getStatus()
  +calculateAmount()
  +createUpdatedat()
}
class Department {
  #String email
  +float address
  -boolean price
  -int note
  +getCreatedat()
  +processTotal()
  +processActive()
}
interface Exam {
  +boolean score
  #double address
  #boolean active
  -long total
  +findActive()
  +cancelCreatedat()
  +findQuantity()
  +saveEmail()
}
class Library {
  #String updatedAt
  -Date amount
  +sendScore()
  +findStatus()
}
interface Attendance {
  +int description
  #long score
  #String name
  -double email
  #boolean amount
  +setEmail()
}
Department --|> Enrollment
Enrollment ..|> Student
Enrollment ..> Attendance : "*"
note right of Enrollment : Education domain
@enduml