@startuml
skinparam defaultFontSize 11
class Deposit {
  -Date createdAt
  #boolean status
  #boolean active
  -float address
  #long quantity
  +updateLevel()
}
class Branch {
  #double address
  -long active
  #float id
  +validateActive()
  +findTotal()
  +setTotal()
}
abstract class Withdrawal {
  #String description
  -int total
  +findId()
  +cancelScore()
  +saveEmail()
}
class Card {
  #String email
  #float price
  -int code
  -Date createdAt
  +getActive()
}
class Interest {
  +int amount
  +Date quantity
  +Date updatedAt
  #int duration
  #boolean score
  +processQuantity()
  +sendCreatedat()
}
class Transaction {
  -int quantity
  #Date description
  +boolean code
  +saveEmail()
  +updateCode()
  +setType()
}
Deposit ..|> Transaction
Interest ..> Transaction : "1"
@enduml