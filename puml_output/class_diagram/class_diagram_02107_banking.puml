@startuml
skinparam defaultFontSize 11
class Deposit {
  -Date createdAt
  #boolean status
  #boolean active
  -float address
  #long quantity
  +createCreatedat()
}
class Branch {
  -boolean active
  #boolean id
  -boolean note
  -float quantity
  +cancelStatus()
  +deleteTotal()
  +saveName()
  +createDescription()
}
class Withdrawal {
  -double name
  +boolean address
  +Date level
  +saveAddress()
}
class Card {
  +int id
  #Date quantity
  +int type
  +int amount
  #int level
  +findActive()
  +deleteName()
}
abstract class Interest {
  -int updatedAt
  #Date quantity
  +boolean description
  -String code
  +cancelId()
  +setCode()
}
class Transaction {
  -int status
  +String level
  +createType()
  +getCreatedat()
}
Deposit --|> Withdrawal
Withdrawal --o Transaction
Card ..> Deposit : "*"
note right of Deposit : Banking domain
@enduml