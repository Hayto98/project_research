@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
interface CheckIn {
  #float note
  #long description
  #boolean amount
  #float email
  -double updatedAt
  +sendDescription()
  +cancelNote()
  +processQuantity()
}
class Invoice {
  -String amount
  -String address
  +calculateScore()
  +deleteName()
}
class Service {
  +double amount
  #Date phone
  #String name
  -boolean score
  -Date description
  +findQuantity()
}
class Payment {
  #float level
  -double active
  +deleteNote()
}
class Room {
  -double level
  +double phone
  +createDuration()
  +sendCode()
  +saveNote()
  +sendScore()
}
Room --> CheckIn : "1..*"
Payment --> Service : "*"
@enduml