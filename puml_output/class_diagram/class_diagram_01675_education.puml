@startuml

class Course {
  -float level
  +float createdAt
  +cancelScore()
  +sendNote()
  +findStatus()
  +getDescription()
}
class Classroom {
  +String description
  #Date level
  -Date status
  -float createdAt
  +deleteQuantity()
  +getCode()
  +setAmount()
}
class Attendance {
  #String name
  #double score
  #Date note
  -String total
  +long description
  +updateAmount()
  +getAmount()
  +getStatus()
}
class Book {
  #int price
  +double code
  #double id
  +float description
  +cancelType()
  +processAddress()
  +findTotal()
  +saveType()
}
class Assignment {
  #double address
  +String score
  -String status
  +int updatedAt
  +Date quantity
  +getQuantity()
  +getStatus()
  +cancelCode()
  +findScore()
}
Book --* Assignment
Classroom ..|> Assignment
Classroom --|> Attendance
Attendance --* Course
@enduml