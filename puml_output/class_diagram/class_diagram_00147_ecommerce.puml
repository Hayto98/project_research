@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
interface Customer {
  +boolean name
  #Date updatedAt
  -float duration
  -int score
  #double total
  +processCreatedat()
  +getName()
  +validateAmount()
  +deletePrice()
}
class Return {
  #float total
  #double active
  +calculateLevel()
}
class Supplier {
  #double createdAt
  +boolean level
  +String name
  #long total
  +getName()
  +saveLevel()
  +cancelQuantity()
  +validateActive()
}
interface Shipment {
  #String note
  -double address
  +calculateDuration()
}
Return --o Supplier
Customer --|> Return
note right of Customer : Ecommerce domain
@enduml