@startuml
skinparam monochrome true
skinparam defaultFontSize 11
interface Beneficiary {
  #Date id
  +long status
  +saveStatus()
  +cancelNote()
}
class Transfer {
  +boolean quantity
  #int phone
  #double code
  +processNote()
  +createAddress()
}
class Statement {
  -boolean duration
  -boolean code
  +cancelLevel()
  +getId()
  +calculateAddress()
}
class Card {
  #long name
  +String active
  -String email
  #boolean id
  +deleteLevel()
  +deleteLevel()
}
Transfer --> Beneficiary : "*"
Card ..> Beneficiary : "1..*"
note right of Beneficiary : Banking domain
@enduml