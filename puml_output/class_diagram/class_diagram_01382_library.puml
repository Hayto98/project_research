@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
interface Member {
  -float total
  #float price
  +Date score
  -long level
  -long phone
  +findDuration()
  +processScore()
  +processActive()
  +createUpdatedat()
}
class Catalog {
  -float score
  -double createdAt
  #float phone
  #long type
  #int quantity
  +sendId()
  +findPhone()
  +processScore()
  +setPrice()
}
class Loan {
  +Date id
  +float status
  #double active
  -int code
  +validateStatus()
  +findQuantity()
}
class Librarian {
  -float code
  -double total
  +int createdAt
  +float description
  +validateTotal()
  +saveDescription()
  +getScore()
}
Librarian ..|> Member
Loan ..|> Catalog
Catalog ..|> Librarian
note right of Member : Library domain
@enduml