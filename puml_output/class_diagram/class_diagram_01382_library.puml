@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
interface Member {
  -float total
  #float price
  +Date score
  -long level
  -long phone
  +cancelDescription()
  +cancelLevel()
  +deleteDescription()
  +createId()
}
abstract class Catalog {
  #float active
  #int quantity
  -double updatedAt
  -double level
  -double total
  +findDuration()
  +createScore()
  +getAddress()
}
interface Loan {
  #String phone
  -long note
  +processName()
  +deleteId()
  +updateName()
}
interface Librarian {
  #double code
  -int status
  +processStatus()
  +setStatus()
}
Loan ..> Librarian : "1..*"
Member ..> Loan : "*"
Catalog ..|> Loan
@enduml