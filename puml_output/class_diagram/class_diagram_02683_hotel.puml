@startuml

abstract class Staff {
  -int active
  +boolean createdAt
  -float description
  #Date price
  +getCreatedat()
  +saveQuantity()
  +sendLevel()
  +deleteEmail()
}
class Room {
  -float price
  +float id
  +sendTotal()
}
class Service {
  -String duration
  -float level
  #float quantity
  -String note
  +double updatedAt
  +deleteActive()
  +sendPhone()
  +saveStatus()
}
abstract class Payment {
  -float duration
  +boolean code
  +processCreatedat()
}
interface Restaurant {
  -Date score
  +String createdAt
  +createAddress()
  +findAmount()
}
class Guest {
  -int name
  -float active
  #boolean level
  +createStatus()
}
abstract class Housekeeping {
  -double address
  +float name
  +double phone
  -long duration
  +int description
  +cancelPhone()
}
Payment ..> Staff : "1..*"
Staff ..> Payment : "1..*"
Housekeeping --* Room
Housekeeping ..|> Staff
@enduml