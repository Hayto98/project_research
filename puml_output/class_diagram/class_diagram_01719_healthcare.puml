@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Patient {
  #int level
  #Date amount
  #float duration
  #float description
  +getId()
  +sendDuration()
  +saveTotal()
}
class Hospital {
  #String name
  -boolean duration
  #long updatedAt
  -boolean active
  +calculateDescription()
  +validateScore()
}
abstract class Ward {
  #String address
  -double createdAt
  #Date description
  +cancelNote()
  +setCode()
  +updateId()
  +savePrice()
}
interface Treatment {
  -long level
  #Date note
  -double email
  -int duration
  -double total
  +findQuantity()
  +processScore()
  +deleteUpdatedat()
}
Patient ..|> Treatment
Ward --o Treatment
note right of Patient : Healthcare domain
@enduml