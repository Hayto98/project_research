@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Patient {
  #int level
  #Date amount
  #float duration
  #float description
  +updateActive()
  +calculateLevel()
  +updatePrice()
}
interface Hospital {
  #boolean phone
  +double address
  #Date name
  -double score
  #int updatedAt
  +setType()
  +saveCreatedat()
  +sendAmount()
  +sendCode()
}
class Ward {
  -boolean createdAt
  #double description
  #double status
  +String note
  +setCreatedat()
  +updatePrice()
}
abstract class Treatment {
  -long level
  #Date note
  -double email
  -int duration
  -double total
  +sendUpdatedat()
  +getNote()
  +processTotal()
}
Hospital --> Patient : "1"
Patient --* Treatment
@enduml