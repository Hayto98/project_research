@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
interface Wishlist {
  +long name
  +int code
  +long duration
  +int price
  +cancelLevel()
}
abstract class Payment {
  -String duration
  #String price
  -double description
  -long name
  -int type
  +sendPrice()
}
abstract class Invoice {
  +double name
  -float duration
  +processActive()
  +validateLevel()
  +updateScore()
}
abstract class Order {
  +boolean duration
  +long email
  +boolean address
  +processStatus()
}
abstract class Customer {
  #Date active
  #float email
  #long amount
  -float name
  +setActive()
  +getAmount()
  +saveCode()
}
abstract class Shipment {
  -Date updatedAt
  +double total
  #long duration
  +validateScore()
  +cancelNote()
  +deleteTotal()
}
class Cart {
  #float active
  #long phone
  #String price
  -long note
  +String name
  +sendQuantity()
  +calculateActive()
}
Payment --> Customer : "*"
Cart ..> Shipment : "*"
Customer ..> Order : "1..*"
Invoice --|> Payment
Shipment --* Payment
@enduml