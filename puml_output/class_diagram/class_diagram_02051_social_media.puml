@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Profile {
  #boolean price
  -Date type
  #int description
  +long amount
  #float total
  +cancelDescription()
}
abstract class Report {
  +String note
  +boolean score
  -int phone
  +String name
  +double level
  +calculateStatus()
}
interface Story {
  #float description
  +boolean email
  #boolean level
  +createId()
  +createActive()
}
class Hashtag {
  +Date active
  +String status
  -int price
  +updateQuantity()
}
class Post {
  #float score
  #double createdAt
  +sendQuantity()
  +createLevel()
}
abstract class Like {
  -boolean price
  -long duration
  +int total
  #String quantity
  +cancelName()
}
Profile --> Post : "1..*"
Hashtag --|> Report
Hashtag ..|> Profile
Profile --|> Report
@enduml