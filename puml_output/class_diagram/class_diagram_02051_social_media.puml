@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Profile {
  #boolean price
  -Date type
  #int description
  +long amount
  #float total
  +findType()
}
abstract class Report {
  +int score
  #long phone
  +String name
  +int level
  -String description
  +deleteEmail()
  +findEmail()
}
class Story {
  #String address
  -int createdAt
  #float updatedAt
  +setTotal()
  +deleteCode()
}
class Hashtag {
  #float score
  #double createdAt
  +sendPrice()
  +saveEmail()
}
abstract class Post {
  +int total
  #String quantity
  #Date phone
  +Date address
  -String score
  +calculateAmount()
  +setTotal()
  +setCreatedat()
}
class Like {
  +Date status
  -boolean name
  -String createdAt
  +processUpdatedat()
}
Post --|> Hashtag
Like --|> Post
Story --> Like : "1..*"
note right of Profile : Social Media domain
@enduml