@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Transaction {
  -String score
  -Date updatedAt
  +long amount
  +long quantity
  +calculateDescription()
  +processActive()
  +updateDescription()
}
interface Teller {
  +int updatedAt
  +double type
  #float email
  +calculateActive()
}
class Branch {
  #long name
  -float price
  +int code
  +calculateLevel()
  +cancelDuration()
}
abstract class Statement {
  +float amount
  -String code
  -String name
  -Date status
  +cancelTotal()
  +validateStatus()
}
class Card {
  -float name
  #boolean active
  +int address
  #float note
  +float amount
  +saveLevel()
  +sendScore()
}
interface Deposit {
  +float status
  -int score
  #long email
  -float type
  #boolean level
  +sendAddress()
  +calculateId()
}
Deposit --> Teller : "1..*"
Statement --o Deposit
Transaction --|> Deposit
@enduml