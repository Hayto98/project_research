@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Enrollment {
  -long status
  -Date id
  +double updatedAt
  #Date total
  +saveCode()
  +validateEmail()
  +cancelCode()
  +setId()
}
class Grade {
  +Date id
  +float score
  +int active
  +String code
  +validateId()
  +createDescription()
}
class Student {
  #long score
  +long description
  +boolean createdAt
  -double email
  +double level
  +createLevel()
}
class Classroom {
  -long active
  -String total
  +deleteId()
  +cancelUpdatedat()
  +getDescription()
}
class Book {
  -float address
  #boolean createdAt
  +boolean level
  +boolean duration
  +Date quantity
  +updateTotal()
  +savePhone()
  +cancelTotal()
}
Student --|> Book
Grade --> Enrollment : "*"
note right of Enrollment : Education domain
@enduml