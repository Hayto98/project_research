@startuml
skinparam defaultFontSize 13
abstract class Publisher {
  #Date code
  #double type
  +long updatedAt
  -long status
  +calculateLevel()
  +deleteEmail()
  +cancelStatus()
}
class Book {
  +float total
  +double amount
  #String createdAt
  +getQuantity()
}
class Loan {
  #double address
  +long note
  +Date total
  #String amount
  +createCode()
  +sendAmount()
  +saveName()
}
abstract class Author {
  #boolean description
  #Date email
  #boolean code
  #String active
  -float score
  +sendAddress()
  +createUpdatedat()
  +cancelNote()
}
class Shelf {
  #float phone
  -long code
  +int status
  -double total
  #String createdAt
  +findTotal()
  +savePhone()
  +cancelName()
  +createName()
}
Book --* Shelf
Book --|> Author
Author --o Book
Loan ..|> Shelf
@enduml