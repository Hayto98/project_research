@startuml
skinparam defaultFontSize 13
abstract class Publisher {
  #Date code
  #double type
  +long updatedAt
  -long status
  +setStatus()
  +cancelCreatedat()
  +calculateAmount()
}
class Book {
  +float createdAt
  +boolean note
  +long score
  +findNote()
  +calculateAmount()
  +findTotal()
}
class Loan {
  #double status
  -boolean name
  #double address
  +float amount
  +setActive()
  +findCode()
  +sendActive()
}
interface Author {
  -boolean address
  +String phone
  +validateCode()
  +setTotal()
  +updateLevel()
  +processQuantity()
}
class Shelf {
  -float price
  +Date note
  -Date code
  +updateEmail()
  +deleteLevel()
}
Publisher ..|> Author
Author --* Loan
Book ..> Publisher : "1"
note right of Publisher : Library domain
@enduml