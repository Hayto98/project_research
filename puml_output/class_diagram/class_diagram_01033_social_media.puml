@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Group {
  -int updatedAt
  +boolean type
  -long quantity
  +sendId()
}
class Hashtag {
  #double score
  +float amount
  +int email
  +calculatePhone()
  +calculateAddress()
}
abstract class Report {
  -float type
  +String active
  +float updatedAt
  -boolean code
  +sendName()
}
class Notification {
  -Date description
  -long phone
  +createActive()
  +updatePrice()
  +createLevel()
  +sendCode()
}
class User {
  -Date score
  #Date note
  #boolean code
  -String updatedAt
  +processUpdatedat()
  +processActive()
}
class Like {
  -String level
  -double description
  +deleteDuration()
  +saveNote()
  +deleteScore()
  +processActive()
}
Report --> Group : "1"
Group ..|> Like
Like ..|> Report
@enduml