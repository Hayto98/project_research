@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Appointment {
  #float total
  -double level
  +boolean duration
  -float note
  #long type
  +setNote()
  +calculateId()
  +createDescription()
  +setCode()
}
interface Doctor {
  -boolean email
  +Date createdAt
  -boolean id
  +validatePrice()
}
interface MedicalRecord {
  +Date id
  #int amount
  -Date active
  +float quantity
  +updateAddress()
  +setType()
  +processUpdatedat()
}
class Patient {
  #double type
  #boolean status
  -boolean score
  +updateDuration()
  +deleteUpdatedat()
  +calculateDescription()
  +findPrice()
}
abstract class Prescription {
  #Date description
  -String type
  +createType()
}
class Nurse {
  -Date id
  #long name
  -float code
  #Date duration
  +validateTotal()
  +calculateNote()
  +saveAmount()
}
abstract class Insurance {
  #String level
  #int status
  -float address
  +saveUpdatedat()
  +validateActive()
  +validatePhone()
}
Patient ..> Prescription : "*"
Insurance --|> Prescription
MedicalRecord --> Patient : "*"
Doctor --|> Nurse
@enduml