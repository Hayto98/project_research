@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
abstract class Beneficiary {
  #float score
  #double phone
  -float active
  +deletePhone()
  +saveTotal()
  +deleteAmount()
}
class Withdrawal {
  -boolean code
  #String createdAt
  #double quantity
  +int description
  -int name
  +cancelDescription()
}
class Customer {
  +Date phone
  +long name
  -String note
  +updateScore()
  +deleteLevel()
  +saveAmount()
  +savePrice()
}
abstract class Account {
  +long updatedAt
  +boolean type
  +processQuantity()
  +saveDuration()
  +updateId()
}
abstract class Interest {
  -String level
  +boolean duration
  +float id
  +deleteAddress()
  +getLevel()
  +cancelEmail()
}
Account --* Interest
Beneficiary --* Withdrawal
Beneficiary ..|> Customer
@enduml