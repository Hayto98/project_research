@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Booking {
  +long status
  +boolean name
  #long score
  +updateTotal()
  +updateType()
  +getActive()
  +sendDuration()
}
class Guest {
  +long id
  -boolean email
  #boolean level
  -long updatedAt
  +processPhone()
  +deleteTotal()
  +deleteCode()
}
class Invoice {
  #double price
  #int type
  -int active
  +findCode()
}
class Room {
  -long note
  #Date code
  #Date phone
  +boolean status
  +String updatedAt
  +findName()
}
class CheckIn {
  -float level
  +long name
  +boolean phone
  -double email
  +int note
  +getName()
  +calculateAmount()
  +sendScore()
  +processName()
}
abstract class Reservation {
  #Date level
  #Date amount
  #String price
  +cancelEmail()
  +deleteId()
}
interface Amenity {
  +boolean id
  +int updatedAt
  +Date description
  #String note
  +deleteType()
}
Amenity --> Invoice : "1"
CheckIn --|> Room
Room --* Reservation
Amenity --o Booking
Invoice --* CheckIn
@enduml