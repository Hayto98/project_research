@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class DeliveryNote {
  #int createdAt
  +float name
  -int level
  -int active
  #Date address
  +validateName()
}
class Warehouse {
  #Date email
  +long code
  +String level
  -int updatedAt
  +cancelLevel()
}
interface Inventory {
  #String phone
  #Date note
  -String quantity
  -long address
  +updateName()
  +deleteStatus()
  +cancelScore()
}
interface Shipment {
  +int address
  #String total
  #int price
  +updateType()
  +findActive()
  +saveId()
}
class Manifest {
  +boolean total
  +Date updatedAt
  -float email
  +String code
  #String name
  +sendScore()
  +processId()
  +findLevel()
  +setType()
}
class Customer {
  #Date type
  #long quantity
  #long updatedAt
  #float email
  +Date score
  +validateCreatedat()
}
abstract class Depot {
  #boolean email
  +long name
  +double createdAt
  +long type
  +saveAddress()
  +findDuration()
  +validatePrice()
}
Inventory --* DeliveryNote
Warehouse --o DeliveryNote
Customer --* Depot
@enduml