@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class DeliveryNote {
  #int createdAt
  +float name
  -int level
  -int active
  #Date address
  +processName()
}
class Warehouse {
  -int code
  +long duration
  +boolean updatedAt
  +boolean name
  +validateNote()
  +createAddress()
  +findStatus()
}
class Inventory {
  #long total
  +Date quantity
  +validateTotal()
  +calculateName()
}
class Shipment {
  +double updatedAt
  +Date quantity
  +processTotal()
}
class Manifest {
  #long code
  +String name
  #String description
  #double updatedAt
  +cancelDescription()
  +setNote()
  +findType()
  +createUpdatedat()
}
class Customer {
  +Date phone
  #float email
  +int score
  +createEmail()
  +getCreatedat()
  +processDuration()
  +sendId()
}
class Depot {
  -int price
  #Date createdAt
  #Date phone
  +validateName()
  +validateDescription()
}
Shipment ..> Customer : "1..*"
Warehouse --o Shipment
note right of DeliveryNote : Logistics domain
@enduml