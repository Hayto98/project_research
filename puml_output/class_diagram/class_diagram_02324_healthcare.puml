@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Nurse {
  #Date createdAt
  #double score
  #long description
  +int address
  #int status
  +validateType()
  +saveCode()
  +sendCreatedat()
}
abstract class Billing {
  -int name
  +Date level
  +long phone
  -double amount
  +Date type
  +processType()
  +deleteDescription()
  +setPhone()
  +deleteQuantity()
}
class Appointment {
  +String price
  #int type
  +deleteEmail()
  +getDuration()
}
class Doctor {
  +String createdAt
  +String level
  +deleteStatus()
}
class Ward {
  -int phone
  #long amount
  -Date duration
  +calculateId()
}
Billing --> Ward : "0..1"
Billing --o Doctor
Nurse ..|> Billing
@enduml