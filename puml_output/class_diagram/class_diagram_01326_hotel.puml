@startuml
skinparam shadowing true
class Payment {
  #long description
  +double score
  +Date code
  -int level
  +validateNote()
  +setCreatedat()
  +savePhone()
}
interface Invoice {
  +String duration
  -boolean quantity
  +Date score
  +updateLevel()
  +findStatus()
  +cancelAmount()
}
class Guest {
  +Date note
  #int duration
  #long price
  #float total
  +setScore()
  +cancelId()
  +setCreatedat()
}
class Reservation {
  #Date price
  +Date createdAt
  -float email
  +double total
  +long name
  +processPhone()
}
class Service {
  +int quantity
  #Date email
  #long note
  +findCreatedat()
  +setPhone()
  +sendEmail()
}
class CheckIn {
  #long updatedAt
  +int active
  +double email
  -boolean address
  +long quantity
  +cancelActive()
  +setCode()
  +saveCode()
  +getPrice()
}
Service ..> Guest : "1..*"
CheckIn --|> Service
@enduml