@startuml
skinparam shadowing true
class Payment {
  #long description
  +double score
  +Date code
  -int level
  +updateName()
  +cancelActive()
  +updateDuration()
}
class Invoice {
  +Date name
  #long type
  -Date active
  +validateNote()
}
abstract class Guest {
  #long total
  #float description
  +double createdAt
  -int address
  -double quantity
  +cancelUpdatedat()
}
abstract class Reservation {
  +float note
  +int description
  -long email
  +updateCreatedat()
  +saveAddress()
  +createEmail()
  +cancelCreatedat()
}
class Service {
  #long updatedAt
  +int active
  +double email
  -boolean address
  +long quantity
  +cancelPrice()
  +setActive()
  +createQuantity()
  +findActive()
}
class CheckIn {
  -String description
  #float code
  -boolean address
  -long name
  +Date total
  +updateCreatedat()
  +deleteUpdatedat()
  +saveScore()
}
CheckIn ..> Payment : "*"
Reservation --o Invoice
Reservation --o Payment
Invoice ..|> Payment
note right of Payment : Hotel domain
@enduml