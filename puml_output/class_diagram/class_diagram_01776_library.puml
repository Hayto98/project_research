@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Book {
  +boolean phone
  +long type
  -String level
  #Date price
  -int createdAt
  +setEmail()
  +processType()
}
class Reservation {
  #String updatedAt
  -float createdAt
  +Date total
  +saveDuration()
  +deleteUpdatedat()
  +findLevel()
}
interface Librarian {
  +double level
  +boolean code
  +cancelLevel()
  +createPrice()
}
interface Author {
  -String active
  #long price
  +String phone
  +double level
  #double address
  +findDuration()
  +findDescription()
  +sendDuration()
}
Librarian --o Reservation
Book ..|> Librarian
Reservation ..|> Librarian
@enduml