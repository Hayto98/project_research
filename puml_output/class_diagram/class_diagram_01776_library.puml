@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Book {
  +boolean phone
  +long type
  -String level
  #Date price
  -int createdAt
  +validatePrice()
  +deleteLevel()
}
class Reservation {
  -float createdAt
  +Date total
  -boolean code
  +cancelCode()
}
class Librarian {
  #double amount
  -double duration
  #long price
  -String active
  #long type
  +setName()
}
abstract class Author {
  -double level
  #Date quantity
  +boolean active
  +boolean price
  #float duration
  +cancelAmount()
  +createScore()
}
Book --* Reservation
Reservation --o Author
Author --o Reservation
note right of Book : Library domain
@enduml