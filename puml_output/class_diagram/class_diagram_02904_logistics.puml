@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Vehicle {
  -int description
  #int name
  +Date email
  #float type
  +cancelQuantity()
  +deleteName()
  +processLevel()
}
abstract class Shipment {
  #float duration
  -String code
  #Date type
  -String amount
  +getEmail()
  +saveTotal()
}
class DeliveryNote {
  +String address
  #String phone
  +setNote()
  +deleteTotal()
  +saveLevel()
  +createQuantity()
}
interface Tracking {
  -boolean createdAt
  -float active
  -double updatedAt
  +processUpdatedat()
  +saveTotal()
}
Vehicle --o DeliveryNote
DeliveryNote --> Vehicle : "0..1"
note right of Vehicle : Logistics domain
@enduml