@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Vehicle {
  -int description
  #int name
  +Date email
  #float type
  +getName()
  +deleteUpdatedat()
  +sendUpdatedat()
}
class Shipment {
  -float name
  #String type
  -int total
  +processQuantity()
  +getScore()
  +updateScore()
}
class DeliveryNote {
  -Date createdAt
  -Date name
  +validatePhone()
  +createActive()
  +sendLevel()
}
class Tracking {
  -String code
  -int duration
  +updateAddress()
  +cancelActive()
  +validateAmount()
  +createTotal()
}
Shipment --> Vehicle : "0..1"
DeliveryNote --* Tracking
Tracking --> Shipment : "0..1"
@enduml