@startuml
skinparam monochrome true
skinparam defaultFontSize 11
interface Housekeeping {
  -String id
  #float score
  +createNote()
  +updateLevel()
}
interface Room {
  +int email
  -boolean status
  +int phone
  -String type
  -long quantity
  +cancelQuantity()
}
class Invoice {
  #boolean status
  -double duration
  +saveCode()
  +getDuration()
  +findEmail()
}
abstract class CheckIn {
  -boolean quantity
  +Date updatedAt
  +double score
  +Date address
  +cancelUpdatedat()
  +saveScore()
  +createStatus()
  +validateNote()
}
interface Reservation {
  #double note
  +float phone
  +setUpdatedat()
  +deleteDuration()
  +getEmail()
  +findId()
}
interface Restaurant {
  +double price
  -String email
  -double phone
  +sendAmount()
  +getScore()
  +createUpdatedat()
}
interface CheckOut {
  -boolean active
  +String email
  +String code
  +double amount
  +long name
  +processAddress()
  +setPrice()
}
Restaurant --|> Reservation
Restaurant ..> Invoice : "*"
CheckIn --* Restaurant
@enduml