@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
abstract class Renewal {
  #boolean active
  -int level
  #Date description
  #double note
  #float updatedAt
  +processDescription()
}
abstract class Member {
  #double updatedAt
  #String quantity
  #long price
  -boolean score
  -long note
  +sendAddress()
  +deletePhone()
  +updateNote()
  +findQuantity()
}
class Reservation {
  +boolean duration
  +float note
  -float createdAt
  +updateTotal()
  +createPhone()
}
interface Shelf {
  -float amount
  +int price
  -double email
  +float level
  +getUpdatedat()
  +updateDescription()
  +findAddress()
  +sendDescription()
}
Member ..> Renewal : "*"
Shelf ..|> Renewal
note right of Renewal : Library domain
@enduml