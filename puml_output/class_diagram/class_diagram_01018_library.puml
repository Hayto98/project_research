@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
abstract class Renewal {
  #boolean active
  -int level
  #Date description
  #double note
  #float updatedAt
  +sendName()
}
class Member {
  -Date note
  -float updatedAt
  #String quantity
  #long price
  -boolean active
  +deleteName()
  +updateNote()
  +cancelQuantity()
  +cancelAmount()
}
class Reservation {
  #float phone
  #long updatedAt
  -int note
  +saveNote()
  +saveQuantity()
  +getQuantity()
  +createAddress()
}
abstract class Shelf {
  -boolean updatedAt
  #Date total
  #long email
  +saveCode()
  +sendDescription()
}
Shelf --|> Member
Member --o Shelf
@enduml