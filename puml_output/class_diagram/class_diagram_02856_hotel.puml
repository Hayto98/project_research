@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class CheckOut {
  #String score
  +boolean active
  +long amount
  -boolean level
  +setNote()
  +setCreatedat()
  +saveType()
}
class Booking {
  +String phone
  -String createdAt
  -boolean amount
  +long price
  +sendAmount()
}
class Restaurant {
  -String duration
  #float score
  +cancelActive()
  +calculateAmount()
}
abstract class Service {
  +Date updatedAt
  -String note
  +long level
  +setTotal()
  +cancelName()
  +sendDuration()
}
class Payment {
  -Date address
  +boolean price
  +setLevel()
}
class Room {
  +double email
  #long phone
  +processType()
  +saveType()
  +findType()
}
class Staff {
  +double amount
  -Date level
  +String address
  #float createdAt
  +float quantity
  +setActive()
  +findScore()
}
Service --> Staff : "0..1"
Room --|> Booking
Payment --|> Service
Service --* Booking
@enduml