@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Category {
  +long quantity
  #boolean total
  +Date address
  -long amount
  +saveCreatedat()
  +setCode()
}
class Wishlist {
  +Date price
  #double score
  +deletePhone()
  +findCode()
}
abstract class Return {
  #long createdAt
  +boolean price
  +boolean email
  -double amount
  +deleteDescription()
}
class Product {
  #long note
  #Date type
  +float updatedAt
  #Date price
  +String status
  +deletePrice()
  +deleteTotal()
  +saveLevel()
}
abstract class Coupon {
  +Date active
  #long score
  +setDescription()
  +processDuration()
  +saveActive()
  +findStatus()
}
class Cart {
  -double description
  -Date price
  +boolean note
  +cancelId()
  +saveUpdatedat()
  +createPrice()
  +saveQuantity()
}
Return --* Product
Wishlist --* Product
@enduml