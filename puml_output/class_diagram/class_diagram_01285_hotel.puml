@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Payment {
  -String id
  #long level
  #double duration
  #long createdAt
  #float code
  +saveNote()
  +findQuantity()
  +findPhone()
  +setName()
}
class Service {
  -boolean total
  -Date updatedAt
  +float address
  +String status
  #long price
  +saveDescription()
  +createDuration()
  +updateUpdatedat()
  +deleteActive()
}
interface Invoice {
  #float status
  +boolean phone
  #double createdAt
  #boolean code
  +processDescription()
}
abstract class Booking {
  -String level
  +int active
  +createPhone()
  +calculateCode()
}
class Amenity {
  #int name
  +String createdAt
  -int description
  #long address
  +double id
  +calculateNote()
}
class CheckOut {
  -float duration
  +float note
  #long address
  +long updatedAt
  #boolean createdAt
  +deleteUpdatedat()
  +setStatus()
}
class Staff {
  +long price
  -long type
  -Date total
  +float note
  +processActive()
  +cancelDuration()
  +findStatus()
  +saveType()
}
CheckOut --* Staff
Booking ..|> Service
Amenity --o Invoice
Booking ..|> CheckOut
Staff --* Invoice
@enduml