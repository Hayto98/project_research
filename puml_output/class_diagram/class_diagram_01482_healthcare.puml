@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
interface Doctor {
  -boolean amount
  +float score
  #boolean note
  +Date quantity
  -double createdAt
  +updateCode()
  +setTotal()
  +deletePhone()
}
class Diagnosis {
  +long description
  #double note
  -long amount
  -float quantity
  +calculateLevel()
  +saveNote()
}
class Hospital {
  #boolean level
  -long name
  +long address
  +saveName()
  +processStatus()
  +savePhone()
}
class Ward {
  #boolean id
  +float createdAt
  -float score
  +validateName()
  +setType()
  +findTotal()
  +updateName()
}
abstract class Patient {
  #boolean description
  #String quantity
  -boolean amount
  -float name
  +updateDuration()
  +calculateId()
  +calculatePrice()
}
Doctor --* Ward
Doctor --|> Diagnosis
Ward --o Patient
Diagnosis ..|> Ward
@enduml