@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
interface Doctor {
  -boolean amount
  +float score
  #boolean note
  +Date quantity
  -double createdAt
  +createPhone()
  +findPhone()
  +deleteNote()
}
interface Diagnosis {
  -boolean duration
  -long quantity
  -long createdAt
  +updateUpdatedat()
  +deleteLevel()
}
class Hospital {
  -boolean duration
  -double phone
  -String address
  +int status
  +updateScore()
}
interface Ward {
  +float email
  +double note
  -int type
  +saveAmount()
  +getDuration()
  +findCode()
}
abstract class Patient {
  #double quantity
  -String id
  #Date name
  #float active
  #int level
  +calculatePrice()
}
Diagnosis ..|> Ward
Patient --|> Ward
Ward ..|> Hospital
note right of Doctor : Healthcare domain
@enduml