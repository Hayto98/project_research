@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class User {
  +Date note
  #String type
  -boolean phone
  +updateStatus()
  +savePrice()
  +findPhone()
  +validateName()
}
class Album {
  #double status
  +long address
  -String quantity
  -String code
  +deleteAmount()
  +getAmount()
  +sendPrice()
  +findActive()
}
interface Profile {
  -float quantity
  #boolean duration
  -boolean createdAt
  +boolean status
  #float active
  +setCreatedat()
  +saveDescription()
}
class Message {
  +float description
  +boolean active
  #String score
  +double phone
  +String id
  +calculateDuration()
}
abstract class Report {
  +float code
  #long updatedAt
  +deleteName()
  +sendPhone()
}
class Hashtag {
  +String price
  #double score
  #int active
  +float id
  -double total
  +createId()
  +sendType()
}
class Like {
  -int email
  +int amount
  #long description
  +validateStatus()
  +sendDuration()
  +processScore()
  +sendCreatedat()
}
Message ..> Album : "*"
Message ..|> User
note right of User : Social Media domain
@enduml