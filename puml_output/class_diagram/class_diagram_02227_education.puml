@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Department {
  -boolean status
  +int total
  +int type
  +long name
  +sendNote()
}
class Course {
  +boolean active
  -float createdAt
  -boolean description
  -double note
  -Date email
  +getScore()
  +createName()
}
class Assignment {
  +int active
  +boolean type
  #long amount
  +float address
  -long description
  +sendPhone()
  +validateName()
  +setAddress()
  +setQuantity()
}
class Library {
  #double name
  +int email
  #float address
  +double duration
  #Date type
  +findTotal()
  +updateType()
}
class Classroom {
  -float createdAt
  #Date total
  +setLevel()
  +validateTotal()
  +validatePrice()
}
class Schedule {
  #float phone
  #String id
  +createType()
  +processDuration()
  +validateUpdatedat()
  +processUpdatedat()
}
Classroom --o Course
Classroom --> Library : "*"
Library ..> Schedule : "1"
Classroom --> Schedule : "1"
Course --o Classroom
@enduml