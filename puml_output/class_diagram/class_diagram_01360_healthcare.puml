@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Treatment {
  -boolean createdAt
  +Date total
  #Date price
  -Date type
  #boolean quantity
  +saveEmail()
  +createPrice()
  +sendUpdatedat()
  +cancelUpdatedat()
}
class MedicalRecord {
  #String price
  -double status
  -Date phone
  +sendNote()
  +updateDescription()
  +saveUpdatedat()
}
interface LabTest {
  +double price
  -double updatedAt
  -long note
  #String address
  +processUpdatedat()
  +validateDuration()
  +saveQuantity()
}
class Insurance {
  -String active
  #boolean duration
  +String updatedAt
  -Date total
  #float note
  +setEmail()
  +saveActive()
  +createId()
}
class Doctor {
  #long description
  #int id
  +updateAmount()
  +updatePhone()
  +findCreatedat()
  +cancelQuantity()
}
class Nurse {
  +float createdAt
  +float name
  -double email
  #double type
  #double address
  +validateActive()
  +updateDescription()
}
Doctor --* LabTest
Nurse ..> Doctor : "1"
Insurance --|> Doctor
Treatment --> Doctor : "*"
Nurse ..|> Insurance
@enduml