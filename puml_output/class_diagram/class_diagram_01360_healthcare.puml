@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Treatment {
  -boolean createdAt
  +Date total
  #Date price
  -Date type
  #boolean quantity
  +getPrice()
  +getStatus()
  +deletePrice()
  +setPhone()
}
interface MedicalRecord {
  -Date note
  -int type
  +saveLevel()
  +cancelLevel()
}
interface LabTest {
  +double price
  -double updatedAt
  -long note
  #String address
  +deleteAddress()
  +deletePhone()
  +calculateActive()
}
interface Insurance {
  -String total
  #boolean level
  +String note
  +savePhone()
  +validateScore()
  +validatePhone()
  +saveCode()
}
class Doctor {
  #Date address
  -Date amount
  +processPhone()
  +findNote()
  +updateName()
}
class Nurse {
  #double address
  #double updatedAt
  #int name
  #int quantity
  #Date type
  +cancelQuantity()
  +createActive()
  +findCode()
  +calculateActive()
}
Treatment --> Doctor : "*"
Nurse ..|> Insurance
note right of Treatment : Healthcare domain
@enduml