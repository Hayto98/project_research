@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class MedicalRecord {
  #int amount
  +boolean duration
  -double price
  +calculateId()
}
class Billing {
  +float createdAt
  #double name
  +calculateId()
  +calculatePrice()
}
interface Hospital {
  #int updatedAt
  #boolean duration
  -Date level
  +processDuration()
  +createStatus()
}
interface Patient {
  -long type
  -float name
  #double code
  +deleteCode()
}
interface Insurance {
  -float code
  -String name
  +calculateCreatedat()
  +setName()
}
class Prescription {
  #float type
  -double score
  -boolean amount
  -Date updatedAt
  +processLevel()
}
Prescription --|> Billing
MedicalRecord --* Insurance
Hospital --* Billing
Hospital --* Patient
@enduml