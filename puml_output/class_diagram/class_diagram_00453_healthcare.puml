@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class MedicalRecord {
  #int amount
  +boolean duration
  -double price
  +getPhone()
}
interface Billing {
  +float createdAt
  #double name
  +getScore()
  +sendLevel()
}
class Hospital {
  #boolean updatedAt
  -Date duration
  #int amount
  +sendLevel()
  +deleteType()
}
class Patient {
  -float email
  #double phone
  +validateLevel()
}
class Insurance {
  -String name
  +long total
  +validateAddress()
}
abstract class Prescription {
  -boolean updatedAt
  -Date phone
  #Date price
  +calculateAddress()
}
MedicalRecord --> Prescription : "1..*"
Hospital --* Billing
Hospital --* Patient
note right of MedicalRecord : Healthcare domain
@enduml