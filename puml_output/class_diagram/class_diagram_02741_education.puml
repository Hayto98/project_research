@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Student {
  #Date duration
  -Date amount
  +deleteNote()
  +calculateUpdatedat()
  +calculateAddress()
}
class Library {
  #float code
  +float phone
  -boolean name
  -double price
  +getAmount()
  +findCode()
  +sendAddress()
  +deleteCreatedat()
}
class Course {
  #float score
  +long code
  -boolean duration
  +boolean email
  +setName()
  +findName()
  +deleteCreatedat()
  +validateId()
}
interface Department {
  +float updatedAt
  +boolean score
  #long level
  +double createdAt
  -float amount
  +getActive()
  +updateStatus()
  +setEmail()
}
Student ..|> Department
Student ..|> Library
Course --o Library
note right of Student : Education domain
@enduml