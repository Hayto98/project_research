@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Student {
  #Date duration
  -Date amount
  +deleteScore()
  +validatePrice()
  +validateTotal()
}
abstract class Library {
  +long updatedAt
  +Date price
  -float address
  #float name
  +float score
  +deleteDescription()
  +processPhone()
  +getId()
  +deletePrice()
}
abstract class Course {
  #long amount
  +int code
  +deletePhone()
  +validateScore()
  +calculateDuration()
}
class Department {
  #float createdAt
  #double quantity
  +String total
  #float description
  +processUpdatedat()
}
Course --> Student : "*"
Library ..> Course : "0..1"
@enduml