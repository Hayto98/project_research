@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
interface Student {
  +String id
  -long price
  +cancelType()
  +setType()
  +updateAddress()
  +updateActive()
}
class Enrollment {
  -int phone
  #Date name
  +boolean description
  #long total
  +findScore()
  +validateLevel()
  +saveCreatedat()
  +getPhone()
}
class Teacher {
  -boolean description
  #long total
  #Date duration
  +validateDuration()
  +setDuration()
  +createEmail()
  +sendCreatedat()
}
class Book {
  +float duration
  +int amount
  #String level
  #boolean id
  +deleteEmail()
  +cancelCode()
  +setDuration()
}
abstract class Library {
  -Date duration
  #boolean quantity
  +int type
  +getDescription()
}
interface Classroom {
  -boolean description
  +String createdAt
  +cancelName()
  +savePhone()
  +updateQuantity()
  +validateName()
}
Teacher --> Classroom : "*"
Library --* Enrollment
Library ..> Book : "1..*"
Student ..> Library : "1"
Student --|> Classroom
@enduml