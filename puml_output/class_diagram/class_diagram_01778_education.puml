@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Exam {
  +double name
  +long code
  #boolean note
  -int quantity
  #Date active
  +getCode()
  +setUpdatedat()
}
interface Course {
  -int amount
  #float total
  +double active
  +getUpdatedat()
  +updateActive()
}
interface Department {
  #long phone
  +String price
  +long address
  +validateType()
  +updateUpdatedat()
  +processAmount()
  +cancelNote()
}
abstract class Classroom {
  -long email
  -String description
  +calculateEmail()
  +saveScore()
}
Classroom --|> Course
Exam --* Classroom
Department --* Course
@enduml