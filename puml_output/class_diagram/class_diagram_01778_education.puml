@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Exam {
  +double name
  +long code
  #boolean note
  -int quantity
  #Date active
  +cancelName()
  +cancelScore()
}
class Course {
  +boolean total
  +double active
  +float email
  +findLevel()
}
class Department {
  +int price
  -Date address
  #float phone
  -float name
  +setCreatedat()
}
abstract class Classroom {
  -long email
  -String description
  +getPhone()
  +findAddress()
}
Department ..> Exam : "1"
Exam --> Course : "1..*"
Department --|> Course
note right of Exam : Education domain
@enduml