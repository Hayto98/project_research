@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Warehouse {
  +Date createdAt
  #boolean active
  +long email
  -int code
  +sendStatus()
  +getQuantity()
  +getLevel()
}
interface Customer {
  +Date score
  +double level
  -double code
  +sendTotal()
  +processEmail()
}
interface Inventory {
  #float total
  +boolean updatedAt
  +deleteId()
  +processPrice()
  +createTotal()
  +updateEmail()
}
class Shipment {
  +int total
  #Date quantity
  +deleteTotal()
  +createAmount()
}
class Route {
  -boolean createdAt
  +boolean phone
  #float updatedAt
  +validateLevel()
}
abstract class Package {
  +boolean address
  +int createdAt
  #Date description
  +String updatedAt
  +deletePhone()
  +saveNote()
}
class Vehicle {
  +String duration
  #String active
  #long description
  #boolean note
  +sendCreatedat()
  +createActive()
  +processDescription()
}
Shipment --* Warehouse
Route --|> Shipment
Package ..|> Warehouse
note right of Warehouse : Logistics domain
@enduml