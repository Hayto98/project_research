@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Warehouse {
  +Date createdAt
  #boolean active
  +long email
  -int code
  +deletePhone()
  +findDuration()
  +createPhone()
}
class Customer {
  #float name
  #Date level
  #Date score
  +String amount
  +createPrice()
}
class Inventory {
  #Date amount
  +Date score
  -int total
  #float type
  +boolean email
  +validateCreatedat()
  +cancelTotal()
  +deleteActive()
  +saveCode()
}
class Shipment {
  -int updatedAt
  +float email
  #Date level
  +float name
  +double total
  +saveAddress()
  +createScore()
  +createCode()
}
class Route {
  +long updatedAt
  #Date type
  -float duration
  #long active
  +getTotal()
  +cancelDuration()
  +createCreatedat()
}
class Package {
  +boolean level
  #int name
  +processActive()
}
class Vehicle {
  +double note
  +String code
  #String address
  #long active
  +createUpdatedat()
  +saveNote()
  +deleteCreatedat()
}
Vehicle ..|> Shipment
Package --o Inventory
Warehouse --o Inventory
Warehouse --o Route
Warehouse --|> Package
Customer --* Package
@enduml