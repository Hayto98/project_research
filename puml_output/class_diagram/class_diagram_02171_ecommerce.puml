@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Invoice {
  -String amount
  +String type
  +sendPhone()
  +updateDuration()
  +processScore()
}
class Shipment {
  -boolean address
  +float type
  -double name
  -int description
  +double phone
  +processLevel()
  +calculateId()
  +setPhone()
}
class Warehouse {
  #double status
  +float address
  #long email
  +long description
  -String note
  +calculateActive()
  +setPhone()
  +sendActive()
  +calculateDuration()
}
abstract class Cart {
  -double note
  -Date description
  +double amount
  +long name
  +createCreatedat()
  +findCode()
  +validatePhone()
}
abstract class Supplier {
  #int description
  +Date name
  -int id
  -long score
  #long phone
  +validateAddress()
  +deleteCreatedat()
}
interface Coupon {
  -long status
  #double quantity
  +int score
  +boolean updatedAt
  +createName()
}
Supplier --|> Coupon
Shipment ..|> Invoice
Coupon --* Supplier
@enduml