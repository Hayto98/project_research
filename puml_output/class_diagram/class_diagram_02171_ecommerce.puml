@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Invoice {
  -String amount
  +String type
  +validateId()
  +updateNote()
  +validateType()
}
class Shipment {
  #int duration
  -double phone
  -int price
  +processEmail()
  +calculateName()
}
interface Warehouse {
  #int total
  -Date status
  -String address
  #long email
  +validatePrice()
  +setNote()
}
interface Cart {
  -double email
  -Date note
  +double description
  +long amount
  -int name
  +setType()
  +processDescription()
  +getId()
}
class Supplier {
  +long active
  -float description
  #long status
  #Date note
  +createEmail()
  +cancelQuantity()
}
class Coupon {
  #double score
  +int updatedAt
  +boolean note
  +double quantity
  +cancelActive()
  +getUpdatedat()
}
Shipment --* Supplier
Supplier ..> Cart : "1..*"
note right of Invoice : Ecommerce domain
@enduml