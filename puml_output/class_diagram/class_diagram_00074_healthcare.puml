@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Billing {
  -boolean score
  #String duration
  -long amount
  +findActive()
  +calculateCreatedat()
  +findNote()
}
class Ward {
  -long email
  -boolean createdAt
  +boolean duration
  +createName()
}
class Insurance {
  #Date type
  #float total
  -int address
  +cancelAddress()
}
interface Nurse {
  #float duration
  +double level
  #boolean updatedAt
  +boolean email
  #Date id
  +createNote()
  +updateType()
  +deleteName()
}
Billing ..|> Insurance
Nurse ..|> Ward
note right of Billing : Healthcare domain
@enduml