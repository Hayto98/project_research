@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Billing {
  -boolean score
  #String duration
  -long amount
  +validateTotal()
  +createDescription()
  +sendScore()
}
class Ward {
  -long code
  -boolean description
  +boolean email
  +long createdAt
  +String score
  +getActive()
  +findStatus()
}
abstract class Insurance {
  #boolean address
  -boolean email
  #float amount
  +float status
  -String duration
  +calculateCode()
  +cancelPrice()
}
interface Nurse {
  -float active
  +double address
  +String quantity
  +createUpdatedat()
  +sendType()
  +processQuantity()
}
Billing --o Insurance
Nurse --> Billing : "1..*"
@enduml