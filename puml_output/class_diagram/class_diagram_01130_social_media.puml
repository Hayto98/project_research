@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Hashtag {
  #Date email
  -long quantity
  -double note
  +long updatedAt
  +calculateName()
}
interface Story {
  -boolean price
  +int email
  +int active
  +createLevel()
  +createLevel()
  +findEmail()
}
class Follower {
  #long code
  -boolean description
  #boolean level
  +saveUpdatedat()
}
class Album {
  #double address
  -String status
  -double type
  +findName()
  +cancelScore()
  +saveStatus()
  +validateEmail()
}
abstract class Profile {
  +String address
  -Date note
  +String score
  +findActive()
  +findDescription()
  +setCreatedat()
  +getNote()
}
Album ..> Profile : "*"
Album --|> Follower
Profile ..|> Hashtag
note right of Hashtag : Social Media domain
@enduml