@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Reservation {
  +float address
  +float id
  -float duration
  -String total
  +createPhone()
  +findNote()
}
class Service {
  -double duration
  -int level
  -long name
  #double id
  #int email
  +processTotal()
  +updateId()
  +findStatus()
}
class Staff {
  #float code
  -String price
  -Date name
  -float score
  +validateName()
}
class Payment {
  #boolean description
  +String price
  +processEmail()
  +findCreatedat()
}
class Restaurant {
  #float updatedAt
  #Date quantity
  #float score
  +getUpdatedat()
  +processName()
}
Staff --> Restaurant : "0..1"
Staff --|> Service
Restaurant ..> Reservation : "1..*"
note right of Reservation : Hotel domain
@enduml