@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Reservation {
  +float address
  +float id
  -float duration
  -String total
  +cancelAddress()
  +cancelId()
}
abstract class Service {
  #long note
  -double level
  -int name
  -long id
  +saveLevel()
  +setPrice()
  +validatePrice()
  +validateQuantity()
}
interface Staff {
  #float type
  +long total
  #long updatedAt
  +double id
  +processCreatedat()
}
class Payment {
  #String code
  +float price
  +int type
  #Date status
  #double address
  +cancelEmail()
  +deleteDescription()
}
class Restaurant {
  -boolean email
  #float createdAt
  #Date updatedAt
  #float score
  +String active
  +getUpdatedat()
  +sendName()
}
Staff --* Restaurant
Restaurant --* Service
@enduml