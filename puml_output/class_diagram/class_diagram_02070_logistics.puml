@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Customer {
  #String address
  #boolean note
  +Date duration
  +int active
  #Date name
  +updateLevel()
  +findQuantity()
  +deleteEmail()
}
abstract class Inventory {
  +double code
  +long phone
  +double active
  +saveId()
}
class Warehouse {
  +float description
  +boolean createdAt
  -String level
  #float id
  +saveType()
  +getEmail()
  +processEmail()
  +validateId()
}
class Manifest {
  -long email
  -boolean code
  +cancelAmount()
  +sendName()
}
abstract class Vehicle {
  #double price
  -double id
  #double code
  -long updatedAt
  +createDuration()
  +createName()
  +calculateScore()
}
Manifest ..|> Inventory
Manifest --* Warehouse
@enduml