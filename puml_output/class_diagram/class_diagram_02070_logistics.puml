@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Customer {
  #String address
  #boolean note
  +Date duration
  +int active
  #Date name
  +createAddress()
  +calculateCreatedat()
  +setPhone()
}
interface Inventory {
  -float type
  +double amount
  +getCreatedat()
}
class Warehouse {
  +float createdAt
  +boolean duration
  -String id
  +deleteLevel()
  +setAmount()
  +getEmail()
  +setType()
}
class Manifest {
  -double active
  +String createdAt
  #int score
  #double type
  -double price
  +validatePhone()
  +sendPhone()
  +calculateNote()
  +createStatus()
}
abstract class Vehicle {
  -Date updatedAt
  -float total
  #boolean phone
  +sendCode()
}
Manifest --|> Vehicle
Warehouse --o Manifest
Customer --o Vehicle
note right of Customer : Logistics domain
@enduml