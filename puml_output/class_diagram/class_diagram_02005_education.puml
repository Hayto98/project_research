@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
interface Student {
  +float name
  -String code
  +long duration
  -long price
  +processQuantity()
  +deleteTotal()
  +createLevel()
  +validatePhone()
}
class Grade {
  #int amount
  -float price
  +calculateStatus()
  +calculateName()
}
interface Library {
  #boolean address
  +double createdAt
  +int quantity
  #long note
  +saveActive()
  +sendName()
  +deleteCreatedat()
}
abstract class Classroom {
  +long active
  +boolean address
  -int note
  #boolean type
  -double duration
  +findNote()
}
Classroom --|> Student
Student ..> Grade : "*"
note right of Student : Education domain
@enduml