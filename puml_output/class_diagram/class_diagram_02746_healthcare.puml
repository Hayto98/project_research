@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class LabTest {
  -int phone
  +Date name
  +createDescription()
  +getName()
}
class Diagnosis {
  +float quantity
  +boolean status
  -String type
  +updateAmount()
  +processPhone()
  +setCreatedat()
  +getActive()
}
class Prescription {
  -long createdAt
  -Date amount
  +String code
  +boolean updatedAt
  +String description
  +saveUpdatedat()
}
abstract class Doctor {
  +boolean email
  #Date amount
  +getEmail()
  +deletePhone()
}
class Treatment {
  #long phone
  +boolean quantity
  +float status
  #float note
  +int amount
  +validateStatus()
  +deleteDescription()
}
class Hospital {
  #double updatedAt
  -double description
  +int level
  +updateAmount()
  +deletePrice()
  +processActive()
  +saveScore()
}
Doctor ..> Hospital : "0..1"
Doctor --|> Treatment
Hospital ..|> Prescription
LabTest --> Hospital : "0..1"
Hospital --> Doctor : "0..1"
@enduml