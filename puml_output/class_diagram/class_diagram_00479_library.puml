@startuml
skinparam monochrome true
skinparam shadowing true
class Shelf {
  -String createdAt
  +double id
  +long status
  +float price
  +Date score
  +saveAmount()
  +createDescription()
  +saveName()
}
class Branch {
  -boolean quantity
  +boolean status
  -double level
  +long address
  -Date note
  +validateName()
  +getTotal()
  +validateScore()
  +sendNote()
}
abstract class Catalog {
  #float level
  +int id
  #float createdAt
  +deleteTotal()
  +saveCreatedat()
}
class Loan {
  -float phone
  #boolean address
  -int name
  +cancelType()
  +setDuration()
}
class Renewal {
  +float description
  -int quantity
  -long type
  #String active
  +findName()
  +deleteId()
  +createCreatedat()
}
class Publisher {
  #float type
  +long phone
  #double createdAt
  +validateEmail()
}
abstract class Fine {
  +long id
  -Date quantity
  #float active
  +Date note
  +saveActive()
  +calculateTotal()
}
Shelf --o Branch
Catalog --|> Fine
Fine --> Catalog : "1"
Shelf --> Publisher : "0..1"
Fine --o Renewal
note right of Shelf : Library domain
@enduml