@startuml
skinparam monochrome true
skinparam shadowing true
class Shelf {
  -String createdAt
  +double id
  +long status
  +float price
  +Date score
  +updatePhone()
  +saveAddress()
  +cancelPhone()
}
class Branch {
  -String updatedAt
  +long total
  +createActive()
  +findDescription()
  +calculateType()
  +cancelTotal()
}
interface Catalog {
  #double price
  -String description
  +double email
  -Date duration
  +createPrice()
  +processId()
  +getAmount()
  +getStatus()
}
class Loan {
  +int createdAt
  #float score
  +calculateAddress()
  +setNote()
}
class Renewal {
  #long description
  #String phone
  +getUpdatedat()
  +validateTotal()
  +findDescription()
  +updateQuantity()
}
abstract class Publisher {
  #boolean description
  -long type
  +long status
  +validateType()
  +createUpdatedat()
  +createCreatedat()
  +saveStatus()
}
abstract class Fine {
  -Date note
  +int phone
  +long code
  +getTotal()
  +processActive()
}
Catalog ..|> Renewal
Renewal --* Branch
Publisher --|> Loan
Catalog ..> Fine : "*"
Catalog --> Shelf : "1..*"
@enduml