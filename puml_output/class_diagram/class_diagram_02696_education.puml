@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
interface Library {
  +String quantity
  -Date createdAt
  +double total
  -boolean description
  +cancelStatus()
  +calculateDescription()
  +processId()
  +sendName()
}
class Assignment {
  +Date description
  +String name
  +calculateNote()
}
class Enrollment {
  #double active
  +String total
  +findUpdatedat()
}
abstract class Classroom {
  #Date amount
  -String score
  +validateScore()
}
class Course {
  +Date price
  -float email
  +double type
  #int phone
  +getDuration()
  +findStatus()
  +setStatus()
}
class Department {
  -float status
  #long address
  #double price
  -int id
  +boolean duration
  +deleteLevel()
  +validateEmail()
}
interface Book {
  +Date code
  +String note
  -int price
  -Date quantity
  +deleteName()
  +sendScore()
}
Enrollment --* Library
Book ..> Enrollment : "1"
note right of Library : Education domain
@enduml