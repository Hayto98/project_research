@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
interface Library {
  +String quantity
  -Date createdAt
  +double total
  -boolean description
  +sendDescription()
  +sendActive()
  +setStatus()
  +deleteEmail()
}
abstract class Assignment {
  #String type
  +float id
  #String active
  +savePhone()
  +deleteScore()
}
class Enrollment {
  -String name
  +boolean price
  +cancelScore()
  +deleteAmount()
  +sendStatus()
  +setStatus()
}
class Classroom {
  +int updatedAt
  #float total
  +cancelTotal()
  +setUpdatedat()
  +sendPhone()
  +saveActive()
}
class Course {
  +Date price
  -float email
  +double type
  #int phone
  +setName()
  +setPhone()
  +calculateDescription()
}
class Department {
  -String status
  -double quantity
  +deleteQuantity()
}
abstract class Book {
  +boolean score
  +int price
  #long type
  -boolean updatedAt
  +setDescription()
  +createName()
  +cancelPrice()
}
Enrollment ..> Assignment : "0..1"
Library ..|> Enrollment
Enrollment ..|> Department
Assignment --|> Department
Course ..|> Book
@enduml