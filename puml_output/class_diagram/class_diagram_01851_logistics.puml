@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Route {
  -Date id
  #Date phone
  #int level
  -Date name
  +validateStatus()
  +cancelName()
}
class DeliveryNote {
  -double note
  #Date type
  +deleteTotal()
  +deletePrice()
  +createScore()
  +saveUpdatedat()
}
class Vehicle {
  #boolean email
  #boolean active
  -boolean level
  -long createdAt
  -Date amount
  +processScore()
  +findTotal()
  +getNote()
  +validateDescription()
}
class Depot {
  +double email
  -Date createdAt
  +setCreatedat()
  +deleteEmail()
}
class FuelLog {
  +double type
  -int id
  #long duration
  +float address
  +Date updatedAt
  +processCreatedat()
  +deleteId()
}
Route ..|> FuelLog
FuelLog --o Vehicle
note right of Route : Logistics domain
@enduml