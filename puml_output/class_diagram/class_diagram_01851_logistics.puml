@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Route {
  -Date id
  #Date phone
  #int level
  -Date name
  +findCode()
  +createPhone()
}
interface DeliveryNote {
  -Date address
  -double name
  +processEmail()
  +setCreatedat()
  +processCreatedat()
  +updateCode()
}
abstract class Vehicle {
  -Date total
  #Date description
  +String price
  +validateAddress()
  +getScore()
  +saveDescription()
  +processId()
}
interface Depot {
  #double amount
  #float active
  -long score
  +sendDuration()
  +createDuration()
  +sendName()
  +cancelAmount()
}
abstract class FuelLog {
  +long note
  +long address
  +setDescription()
  +setNote()
}
DeliveryNote ..|> Route
DeliveryNote --|> Vehicle
Depot --|> FuelLog
@enduml