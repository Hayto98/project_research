@startuml
skinparam monochrome true
skinparam defaultFontSize 11
interface Statement {
  +int quantity
  -float address
  #double score
  +float email
  +validateCode()
  +saveAddress()
}
class Beneficiary {
  -boolean email
  -boolean amount
  +long description
  -boolean quantity
  +sendPhone()
  +setCreatedat()
  +deleteUpdatedat()
  +processNote()
}
class Interest {
  +float duration
  +long phone
  -float address
  +String level
  +cancelPrice()
  +updateActive()
  +saveName()
  +calculateName()
}
class Teller {
  #double phone
  -double code
  +sendId()
}
class Loan {
  +long id
  +boolean status
  #int address
  #double phone
  +getAmount()
  +cancelPhone()
  +updateAmount()
  +saveStatus()
}
class Customer {
  +long id
  #String email
  +findUpdatedat()
  +calculateQuantity()
  +calculateType()
}
class Account {
  #boolean email
  #int amount
  #float status
  +saveStatus()
  +processTotal()
  +deleteQuantity()
  +processDescription()
}
Interest --|> Loan
Statement --* Loan
Statement --o Interest
Beneficiary ..> Account : "*"
Loan --> Statement : "1..*"
Loan --* Interest
@enduml