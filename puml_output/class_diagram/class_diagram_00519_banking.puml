@startuml
skinparam monochrome true
skinparam defaultFontSize 11
interface Statement {
  +int quantity
  -float address
  #double score
  +float email
  +deleteAmount()
  +createQuantity()
}
class Beneficiary {
  #long description
  #float quantity
  +long address
  +cancelScore()
  +calculatePhone()
  +findLevel()
  +saveCode()
}
class Interest {
  +long address
  -float score
  +String phone
  -Date name
  +calculateAddress()
}
class Teller {
  #double phone
  -double code
  +updateDescription()
}
interface Loan {
  +long id
  +boolean status
  #int address
  #double phone
  +saveEmail()
  +createName()
  +getEmail()
  +getAddress()
}
class Customer {
  -int duration
  +float total
  #boolean amount
  #int description
  +processStatus()
  +createActive()
  +createLevel()
  +setStatus()
}
interface Account {
  +Date code
  -boolean email
  +boolean price
  #long createdAt
  +createUpdatedat()
  +deleteScore()
  +calculateNote()
}
Customer --* Account
Interest --> Teller : "1..*"
Account --* Beneficiary
Customer --|> Teller
note right of Statement : Banking domain
@enduml