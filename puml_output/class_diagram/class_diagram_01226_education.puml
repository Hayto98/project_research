@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
interface Classroom {
  +long email
  #long price
  +updatePrice()
}
class Library {
  -int active
  -boolean price
  +calculateEmail()
}
class Book {
  -Date phone
  #int name
  -String total
  -long duration
  #boolean price
  +setPrice()
  +setTotal()
}
class Grade {
  +double phone
  +float status
  +createScore()
  +getName()
  +validateDuration()
}
class Course {
  #Date code
  +boolean active
  -String duration
  -int updatedAt
  +saveId()
  +deleteActive()
}
class Schedule {
  -String id
  #int name
  -long updatedAt
  +boolean email
  +deleteTotal()
  +deleteId()
  +cancelActive()
  +saveId()
}
Classroom --> Grade : "1"
