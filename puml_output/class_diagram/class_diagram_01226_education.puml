@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
interface Classroom {
  +long email
  #long price
  +getPhone()
}
class Library {
  +int email
  #Date description
  #double quantity
  -String active
  #double code
  +calculateAddress()
  +findDescription()
  +processCode()
}
class Book {
  -String duration
  -Date level
  +String amount
  -int quantity
  +updateAddress()
  +setAddress()
  +setActive()
}
class Grade {
  +float description
  -int score
  +String total
  +findStatus()
  +validateId()
  +getUpdatedat()
  +findEmail()
}
class Course {
  -long level
  +boolean description
  +cancelName()
  +setName()
  +processLevel()
  +setAddress()
}
class Schedule {
  -double price
  +float id
  #Date phone
  +double address
  +getStatus()
  +findId()
  +getEmail()
  +calculateActive()
}
Course --* Classroom
Course --> Library : "*"
Grade --> Book : "0..1"
note right of Classroom : Education domain
@enduml