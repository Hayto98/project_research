@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Customer {
  +double amount
  +Date address
  +int duration
  +cancelNote()
}
class Tracking {
  #String type
  #long description
  +int price
  +boolean phone
  +long amount
  +validateAddress()
  +calculateNote()
  +saveNote()
}
class Shipment {
  +String amount
  +int name
  -int total
  +createPhone()
}
class Warehouse {
  +Date total
  +long price
  #int score
  +float description
  +cancelLevel()
  +cancelStatus()
}
abstract class Inventory {
  -String quantity
  +long description
  #int status
  +cancelEmail()
}
class Package {
  #String amount
  +String description
  +setAddress()
  +deleteId()
  +validateLevel()
}
class Route {
  +String code
  +boolean name
  -float quantity
  +String id
  +long duration
  +updateActive()
}
Inventory --o Shipment
Route --|> Package
note right of Customer : Logistics domain
@enduml