@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Customer {
  +double amount
  +Date address
  +int duration
  +calculateTotal()
}
interface Tracking {
  -boolean description
  #int price
  #String type
  #long duration
  +int level
  +setAddress()
  +getLevel()
}
class Shipment {
  #double address
  -int duration
  +String total
  -String note
  +cancelNote()
}
class Warehouse {
  -long updatedAt
  -double name
  #boolean email
  +String phone
  +calculatePhone()
}
class Inventory {
  -float createdAt
  +Date level
  -int status
  +validateLevel()
}
class Package {
  #int amount
  +boolean phone
  +deleteType()
  +cancelStatus()
  +sendLevel()
}
class Route {
  +String description
  -String score
  -int status
  +calculateCreatedat()
}
Tracking --|> Warehouse
Customer ..> Shipment : "1"
Customer --|> Route
Tracking --* Inventory
Route --|> Customer
Tracking --|> Shipment
@enduml