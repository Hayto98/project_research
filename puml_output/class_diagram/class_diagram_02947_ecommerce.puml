@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
abstract class Warehouse {
  #int note
  +long name
  +Date updatedAt
  +float type
  -double createdAt
  +validateNote()
  +calculateQuantity()
  +calculateType()
  +processType()
}
class Return {
  #int description
  #long id
  +saveTotal()
}
class Category {
  -long updatedAt
  #boolean price
  +float address
  -float id
  #boolean email
  +sendActive()
  +calculatePhone()
}
class Payment {
  +double active
  #double id
  +long email
  +String description
  +createCreatedat()
  +findStatus()
  +calculateAmount()
}
class Supplier {
  #long code
  +Date level
  -String address
  #Date name
  +updateType()
  +validateCreatedat()
  +deleteTotal()
}
class Invoice {
  +long type
  +Date duration
  +boolean score
  +double total
  +setStatus()
  +getLevel()
  +saveAddress()
  +findStatus()
}
class Customer {
  #double phone
  +int level
  -boolean name
  +int code
  -float duration
  +calculateScore()
}
Supplier --o Warehouse
Supplier ..> Invoice : "1"
Category ..> Customer : "1"
Return --|> Payment
Supplier --* Category
Invoice ..|> Return
@enduml