@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class CheckOut {
  +Date quantity
  +double phone
  -int updatedAt
  -String score
  +calculatePhone()
  +validateStatus()
  +setEmail()
}
abstract class Reservation {
  #float price
  #boolean quantity
  +double code
  +double amount
  #long email
  +getStatus()
  +setNote()
  +sendType()
  +saveQuantity()
}
class Restaurant {
  #Date address
  -double amount
  +boolean quantity
  +deleteCode()
  +cancelStatus()
  +saveUpdatedat()
}
interface Amenity {
  -float code
  -Date total
  -boolean createdAt
  -long status
  +validateEmail()
}
interface Guest {
  -boolean updatedAt
  #float id
  -double createdAt
  #long phone
  +deleteNote()
  +cancelNote()
  +processStatus()
}
class Room {
  -double amount
  #int quantity
  +createAddress()
  +getId()
  +updateLevel()
  +calculateLevel()
}
CheckOut --o Amenity
Restaurant --* Guest
Amenity --|> Room
@enduml