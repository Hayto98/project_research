@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class CheckOut {
  +Date quantity
  +double phone
  -int updatedAt
  -String score
  +createAddress()
  +processNote()
  +calculateQuantity()
}
class Reservation {
  -int email
  -Date score
  -double updatedAt
  +deleteCode()
  +cancelAmount()
  +validateAmount()
  +createDuration()
}
abstract class Restaurant {
  #boolean status
  #long level
  +float phone
  -int score
  +long code
  +saveEmail()
  +cancelAddress()
  +createId()
  +setLevel()
}
class Amenity {
  -boolean id
  #float createdAt
  -double phone
  +validateName()
  +updatePhone()
  +getName()
}
class Guest {
  +double type
  -float duration
  -String updatedAt
  -double total
  +findScore()
  +createEmail()
  +saveScore()
}
abstract class Room {
  -float id
  #String score
  #int createdAt
  +double code
  -long total
  +updateAddress()
  +calculateStatus()
  +calculateNote()
  +validatePrice()
}
Guest --> Room : "*"
Amenity --> Restaurant : "0..1"
note right of CheckOut : Hotel domain
@enduml