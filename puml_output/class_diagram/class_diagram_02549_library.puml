@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Shelf {
  +Date note
  #int updatedAt
  +saveCode()
}
class Book {
  #boolean address
  -String status
  -String name
  +boolean price
  #String createdAt
  +findAmount()
  +sendTotal()
  +createStatus()
}
interface Reservation {
  +String code
  #String description
  -int active
  -double status
  +sendCreatedat()
}
class Catalog {
  +long score
  +double code
  #double createdAt
  +updateQuantity()
}
Catalog --> Reservation : "1"
Shelf --* Book
note right of Shelf : Library domain
@enduml