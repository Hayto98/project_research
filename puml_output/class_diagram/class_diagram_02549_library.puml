@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Shelf {
  +Date note
  #int updatedAt
  +calculateType()
}
class Book {
  -int type
  #boolean address
  -String status
  -String name
  +getQuantity()
  +setStatus()
}
class Reservation {
  +Date score
  #long total
  +int email
  +sendId()
}
class Catalog {
  -double total
  +boolean updatedAt
  +cancelDescription()
  +saveStatus()
}
Book --|> Reservation
Book --* Shelf
@enduml