@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Branch {
  -int price
  +double id
  +String score
  +validateLevel()
  +createAmount()
  +deleteNote()
  +processAddress()
}
abstract class Author {
  -int quantity
  -double note
  +setType()
}
class Catalog {
  #boolean address
  #long price
  +sendNote()
  +sendDuration()
}
class Loan {
  -boolean quantity
  #float amount
  +Date email
  -String duration
  +sendStatus()
  +cancelCreatedat()
  +sendName()
  +processEmail()
}
Catalog ..|> Branch
Author --|> Branch
Branch ..|> Author
note right of Branch : Library domain
@enduml