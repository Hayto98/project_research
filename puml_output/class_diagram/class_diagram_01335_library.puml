@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Branch {
  -int price
  +double id
  +String score
  +saveScore()
  +savePrice()
  +createQuantity()
  +updateAddress()
}
class Author {
  -String note
  -double duration
  -int address
  +getAddress()
  +deleteId()
  +validateDescription()
  +savePrice()
}
class Catalog {
  +long type
  -float code
  +sendPrice()
  +sendNote()
  +setAddress()
}
abstract class Loan {
  -Date quantity
  -long duration
  #boolean amount
  +createTotal()
}
Branch --o Catalog
Author --|> Catalog
@enduml