@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
abstract class Ward {
  -double email
  -int id
  +int phone
  #boolean quantity
  #double createdAt
  +setPrice()
  +createDescription()
  +setLevel()
  +createAmount()
}
class Hospital {
  -double amount
  +Date phone
  +float quantity
  #Date total
  -float score
  +cancelCreatedat()
  +validateUpdatedat()
}
interface Insurance {
  -String level
  +Date score
  +Date id
  #boolean amount
  +deleteDuration()
  +getLevel()
  +processDuration()
}
abstract class LabTest {
  #long createdAt
  #int duration
  +Date total
  +int phone
  +long address
  +deleteUpdatedat()
  +getTotal()
  +saveCode()
  +sendActive()
}
abstract class Nurse {
  -double active
  #Date updatedAt
  #double price
  #boolean phone
  +saveCreatedat()
  +cancelScore()
  +calculateScore()
}
interface Billing {
  #float active
  -boolean phone
  #boolean updatedAt
  -double id
  +createDuration()
  +findPrice()
}
class Appointment {
  -double level
  -int status
  -boolean id
  -long description
  +findUpdatedat()
}
LabTest ..|> Billing
Appointment ..> Hospital : "0..1"
Ward --o Insurance
Appointment --> Billing : "0..1"
Billing --o LabTest
Ward --* Hospital
note right of Ward : Healthcare domain
@enduml