@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
abstract class Ward {
  -double email
  -int id
  +int phone
  #boolean quantity
  #double createdAt
  +setDescription()
  +saveName()
  +cancelPhone()
  +getEmail()
}
class Hospital {
  -float amount
  #long createdAt
  -long total
  -double duration
  +updateId()
}
class Insurance {
  #Date createdAt
  #boolean duration
  #float address
  +int updatedAt
  -String quantity
  +validatePrice()
  +sendId()
}
interface LabTest {
  -int description
  +double name
  #Date type
  #long total
  +getCode()
  +saveScore()
  +createUpdatedat()
}
class Nurse {
  +long status
  -int updatedAt
  +processPhone()
  +processCode()
}
abstract class Billing {
  -boolean score
  -boolean active
  +deleteAmount()
  +createAmount()
}
abstract class Appointment {
  #boolean type
  -float active
  #boolean score
  #Date email
  #long createdAt
  +validatePrice()
  +updateStatus()
  +setName()
}
Nurse --> Billing : "1..*"
LabTest ..|> Billing
Insurance ..> Nurse : "*"
Hospital --> Insurance : "1"
@enduml