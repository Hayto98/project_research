@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Deposit {
  -String id
  -boolean createdAt
  +processPrice()
  +saveCreatedat()
}
class Transfer {
  +double level
  -String address
  #double active
  +double note
  +createDescription()
}
class Loan {
  #int total
  -String address
  +Date duration
  #long level
  +String phone
  +findQuantity()
  +setPrice()
  +processId()
}
class Card {
  -float duration
  -float name
  +String createdAt
  -long type
  +validateId()
  +calculateName()
  +findDuration()
}
class Transaction {
  #Date code
  -long duration
  +float status
  #Date amount
  +float createdAt
  +setUpdatedat()
}
Card ..|> Loan
Deposit ..|> Transfer
Card --|> Transaction
note right of Deposit : Banking domain
@enduml