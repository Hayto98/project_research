@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Booking {
  +long name
  +Date updatedAt
  +boolean score
  #int email
  -float note
  +findDuration()
  +sendStatus()
  +deleteType()
  +updateDescription()
}
class Housekeeping {
  +double duration
  -double level
  +Date description
  -boolean name
  -boolean phone
  +deleteUpdatedat()
  +sendUpdatedat()
  +setCode()
}
abstract class Reservation {
  +boolean note
  #int createdAt
  +long quantity
  +float id
  #float total
  +getActive()
}
abstract class Service {
  #String score
  -float name
  -int amount
  +processAmount()
}
class Amenity {
  +double phone
  +double description
  +String price
  +findEmail()
  +calculateDescription()
  +sendActive()
}
Service --|> Amenity
@enduml