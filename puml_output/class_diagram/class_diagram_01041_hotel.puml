@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Booking {
  +long name
  +Date updatedAt
  +boolean score
  #int email
  -float note
  +sendCreatedat()
  +getType()
  +cancelLevel()
  +deleteName()
}
interface Housekeeping {
  +Date status
  -boolean type
  -boolean level
  -boolean price
  +calculateNote()
  +updateQuantity()
  +getTotal()
  +deleteActive()
}
class Reservation {
  +Date address
  -int createdAt
  #String score
  +cancelCode()
  +calculateNote()
}
class Service {
  +long code
  +double email
  +calculateDescription()
}
abstract class Amenity {
  #boolean status
  +double phone
  +setPrice()
  +sendTotal()
  +createAddress()
  +updateType()
}
Housekeeping --|> Amenity
Amenity ..> Reservation : "1..*"
note right of Booking : Hotel domain
@enduml