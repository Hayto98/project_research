@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Depot {
  +boolean level
  +long amount
  -boolean type
  -int quantity
  +Date createdAt
  +cancelDescription()
  +validateDescription()
}
class Manifest {
  -boolean total
  -float createdAt
  #Date active
  +findPhone()
  +setCode()
  +processDuration()
}
class Driver {
  +double quantity
  #boolean level
  #double score
  -String createdAt
  -long active
  +validatePrice()
  +calculateCreatedat()
}
class Warehouse {
  -double email
  +float status
  -boolean duration
  +processQuantity()
}
abstract class Package {
  #String type
  -float quantity
  +float total
  +double phone
  +getCreatedat()
  +saveUpdatedat()
  +createDescription()
  +processAmount()
}
interface DeliveryNote {
  -long price
  +float status
  -Date address
  +calculateAmount()
  +findTotal()
  +getPrice()
}
DeliveryNote ..> Depot : "1"
Driver ..> Manifest : "1"
Depot --> Manifest : "1"
@enduml