@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class User {
  -long email
  -String active
  -long updatedAt
  #float level
  +cancelAddress()
  +updateAddress()
  +getAddress()
  +saveCode()
}
class Comment {
  -double phone
  +long amount
  #int type
  +setPrice()
}
abstract class Post {
  -long email
  -long duration
  +long code
  +String total
  +setCreatedat()
}
class Story {
  #int type
  #int level
  -String name
  #long total
  #int createdAt
  +sendAddress()
  +createPrice()
  +sendType()
}
class Like {
  #float price
  #int quantity
  +sendTotal()
  +calculateEmail()
}
User --|> Story
Like --o Comment
Comment ..> Like : "1"
@enduml