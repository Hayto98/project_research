@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class User {
  -long email
  -String active
  -long updatedAt
  #float level
  +createTotal()
  +calculateAmount()
  +deletePhone()
  +deleteType()
}
class Comment {
  -long name
  -long email
  +double active
  -long createdAt
  -long status
  +createStatus()
}
class Post {
  #double code
  -boolean active
  +calculateCreatedat()
}
class Story {
  #int price
  #long name
  -double address
  +getPrice()
  +createActive()
  +saveUpdatedat()
}
interface Like {
  +double id
  +float name
  #float price
  +calculateCreatedat()
  +updateStatus()
}
User --|> Post
Story --> Comment : "1..*"
User --> Story : "1..*"
Comment ..|> User
note right of User : Social Media domain
@enduml