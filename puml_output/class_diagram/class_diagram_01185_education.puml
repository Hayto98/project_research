@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
interface Attendance {
  -double email
  -Date description
  +Date createdAt
  +float price
  +String code
  +deleteType()
  +validateType()
  +saveType()
  +validateDuration()
}
class Grade {
  -String code
  #String description
  -double total
  -Date level
  +findUpdatedat()
  +sendPhone()
}
class Assignment {
  +float price
  +String address
  +validateType()
  +updateDuration()
  +getAmount()
}
class Book {
  +int quantity
  +boolean active
  #long total
  +findDescription()
  +getUpdatedat()
  +getQuantity()
}
Book ..|> Attendance
Attendance --|> Grade
Assignment --> Book : "1"
@enduml