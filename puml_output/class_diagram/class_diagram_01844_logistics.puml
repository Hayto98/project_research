@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Driver {
  -Date type
  +long note
  +String code
  +findUpdatedat()
  +calculateDescription()
  +processPhone()
}
abstract class Manifest {
  -double active
  -Date phone
  +long amount
  +double email
  +updateId()
  +getAddress()
  +getId()
}
interface Shipment {
  -boolean phone
  -float quantity
  -long code
  -String type
  #boolean createdAt
  +getStatus()
}
interface Package {
  -float code
  #double email
  +boolean status
  +double name
  +processDescription()
  +createQuantity()
  +deleteType()
}
abstract class Route {
  +float phone
  -int total
  #long note
  -boolean amount
  +validateStatus()
  +findUpdatedat()
}
abstract class Vehicle {
  +String price
  +Date updatedAt
  #long type
  #float level
  -Date amount
  +cancelPhone()
  +updateStatus()
  +cancelNote()
}
Route --o Manifest
Vehicle --|> Manifest
Vehicle --o Shipment
Vehicle --|> Driver
@enduml