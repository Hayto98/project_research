@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Driver {
  -Date type
  +long note
  +String code
  +cancelType()
  +createActive()
  +validateAmount()
}
class Manifest {
  -float price
  #long phone
  #double status
  -boolean quantity
  -Date name
  +findQuantity()
  +setType()
  +findLevel()
}
interface Shipment {
  -long type
  -String level
  #boolean email
  +sendPhone()
}
class Package {
  #double status
  +boolean score
  +double name
  -long phone
  +findType()
  +findDuration()
  +createPhone()
}
abstract class Route {
  -boolean amount
  +float name
  #float email
  -double createdAt
  -int address
  +updateAmount()
  +getStatus()
  +deleteAddress()
  +saveEmail()
}
class Vehicle {
  -Date updatedAt
  +float createdAt
  +float email
  #long amount
  +findId()
  +setPhone()
  +createNote()
  +setCode()
}
Route ..> Driver : "1"
Driver --o Package
Vehicle --o Manifest
Driver --o Route
note right of Driver : Logistics domain
@enduml