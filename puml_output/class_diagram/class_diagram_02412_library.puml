@startuml

class Branch {
  #float id
  #float active
  #boolean amount
  +int level
  +calculateDuration()
}
abstract class Fine {
  #long active
  #double id
  +String duration
  #String total
  +createDuration()
  +validateTotal()
  +deleteDuration()
  +saveNote()
}
interface Librarian {
  -int quantity
  #float note
  #String duration
  -String score
  +float total
  +updateId()
  +sendType()
  +findDuration()
}
interface Shelf {
  #long price
  -int quantity
  +getAddress()
  +updateAmount()
}
abstract class Renewal {
  #boolean amount
  +double updatedAt
  +saveNote()
  +processType()
  +cancelNote()
  +findAmount()
}
interface Loan {
  +int amount
  #String score
  +long updatedAt
  +processQuantity()
  +validateCode()
  +updateName()
}
class Author {
  -long address
  +String id
  +createPrice()
  +cancelEmail()
  +setEmail()
}
Branch --* Librarian
Librarian --> Renewal : "*"
Librarian ..> Fine : "*"
Loan --|> Shelf
Fine ..|> Librarian
Renewal --|> Librarian
@enduml