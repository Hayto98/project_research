@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Grade {
  -String score
  -String code
  -double note
  +saveUpdatedat()
}
class Course {
  #String score
  -long createdAt
  +deletePhone()
  +saveName()
}
abstract class Classroom {
  #long type
  #int updatedAt
  -String id
  #boolean code
  +int address
  +createAddress()
  +calculateAddress()
}
class Enrollment {
  -long note
  +long total
  -int quantity
  -int level
  +validateActive()
}
class Schedule {
  -double duration
  #double id
  +findId()
}
interface Assignment {
  -String type
  -Date createdAt
  #int quantity
  -String note
  -float level
  +setPhone()
  +saveDuration()
  +cancelLevel()
}
Enrollment ..|> Assignment
Assignment --* Schedule
Enrollment --* Course
Course ..|> Grade
Course --* Assignment
@enduml