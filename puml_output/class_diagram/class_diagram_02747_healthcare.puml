@startuml

interface Patient {
  -Date active
  #String name
  #String type
  -boolean code
  +deleteScore()
  +sendActive()
  +createId()
  +createLevel()
}
abstract class Prescription {
  +String status
  #long id
  +createScore()
  +calculateType()
  +updateDuration()
  +processUpdatedat()
}
abstract class LabTest {
  #double type
  -String phone
  +int status
  #Date email
  +saveTotal()
}
abstract class Treatment {
  #String name
  +long amount
  +validateTotal()
  +calculateDescription()
  +cancelType()
  +updatePrice()
}
interface Nurse {
  -double duration
  -int description
  #Date note
  +updateDuration()
}
LabTest ..> Treatment : "1"
Patient --> Treatment : "*"
Prescription ..|> LabTest
Nurse --o Treatment
@enduml