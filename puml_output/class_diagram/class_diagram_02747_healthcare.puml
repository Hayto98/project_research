@startuml

interface Patient {
  -Date active
  #String name
  #String type
  -boolean code
  +deleteDuration()
  +findTotal()
  +saveDuration()
  +getStatus()
}
class Prescription {
  -boolean name
  -int active
  +deleteType()
}
class LabTest {
  -String duration
  +int phone
  #Date status
  #String email
  #double note
  +getAmount()
}
class Treatment {
  #int address
  #int type
  -long id
  +processUpdatedat()
  +saveName()
  +getActive()
  +createPrice()
}
class Nurse {
  #double type
  +Date level
  +deleteDuration()
  +processNote()
  +setLevel()
}
LabTest ..|> Nurse
Patient --* Treatment
Treatment --> Nurse : "1..*"
note right of Patient : Healthcare domain
@enduml