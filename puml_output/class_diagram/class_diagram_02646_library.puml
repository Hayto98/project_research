@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
abstract class Librarian {
  +boolean name
  +int address
  #int amount
  +deleteAmount()
  +saveLevel()
}
abstract class Reservation {
  -float createdAt
  #String quantity
  +deleteScore()
}
abstract class Branch {
  +double total
  -int name
  +long description
  -long quantity
  +cancelPrice()
}
class Book {
  -double address
  #boolean amount
  +long active
  +long phone
  +double level
  +updateDuration()
  +deleteType()
  +validatePrice()
  +deleteCode()
}
Branch ..> Book : "1"
Branch --* Librarian
note right of Librarian : Library domain
@enduml