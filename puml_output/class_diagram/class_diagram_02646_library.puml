@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
abstract class Librarian {
  +boolean name
  +int address
  #int amount
  +getEmail()
  +setDuration()
}
class Reservation {
  +int code
  #Date createdAt
  -float quantity
  -float price
  -String id
  +getNote()
  +getEmail()
}
abstract class Branch {
  +boolean updatedAt
  #double id
  +float quantity
  -Date price
  -float email
  +getScore()
  +cancelId()
}
class Book {
  +long total
  +double score
  #double active
  +boolean name
  +double email
  +cancelPrice()
  +validateLevel()
  +calculateDescription()
}
Reservation ..> Branch : "1"
Librarian --> Reservation : "1"
Branch --* Librarian
@enduml