@startuml
skinparam monochrome true
skinparam defaultFontSize 11
interface Notification {
  +String email
  +Date status
  +float score
  +validateAmount()
  +getPrice()
  +getEmail()
}
abstract class Post {
  #long active
  #boolean quantity
  #String status
  #boolean id
  +saveScore()
  +processQuantity()
  +sendName()
  +processType()
}
abstract class Follower {
  +boolean total
  #int score
  -double email
  #long createdAt
  -float note
  +sendCode()
  +cancelPhone()
  +processAddress()
}
class Album {
  +long code
  #double address
  +validateStatus()
  +cancelPhone()
  +setAmount()
}
class Report {
  -float level
  #int status
  #long createdAt
  +long price
  +validateType()
  +validatePrice()
  +sendTotal()
}
Notification --* Post
Post --o Follower
@enduml