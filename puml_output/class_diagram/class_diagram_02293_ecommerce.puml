@startuml
skinparam defaultFontSize 11
class Wishlist {
  +String code
  -int note
  #float price
  #float active
  +saveDuration()
  +processActive()
  +calculateLevel()
  +sendScore()
}
interface Cart {
  +int type
  -double address
  -Date price
  -String updatedAt
  +calculateStatus()
}
interface Review {
  +double email
  +float id
  #float type
  -int price
  +createActive()
  +updateName()
  +saveLevel()
  +validateUpdatedat()
}
class Order {
  #boolean level
  +String id
  +long amount
  #int active
  +setPhone()
}
abstract class Payment {
  #Date active
  +float amount
  +setEmail()
  +calculateTotal()
  +processCreatedat()
  +updateDuration()
}
Review ..> Cart : "0..1"
Payment --> Review : "*"
@enduml