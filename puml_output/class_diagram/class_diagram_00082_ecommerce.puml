@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Return {
  -double description
  -double total
  +float name
  #float phone
  +calculateNote()
}
class Review {
  +long level
  -String id
  +deleteId()
  +deleteDuration()
  +deleteStatus()
  +validateEmail()
}
class Coupon {
  -int address
  +Date quantity
  +sendName()
}
class Shipment {
  +double id
  +String score
  +deleteDescription()
  +validatePrice()
}
class Invoice {
  +double amount
  #double level
  #Date status
  #boolean name
  +deleteDescription()
  +cancelLevel()
}
Invoice ..|> Review
Return --> Invoice : "*"
Return ..> Shipment : "*"
@enduml