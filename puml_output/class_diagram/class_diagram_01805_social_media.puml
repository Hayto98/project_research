@startuml
skinparam shadowing true
class Profile {
  #float duration
  #int score
  #double amount
  #boolean createdAt
  +setStatus()
}
class Group {
  #int score
  -Date email
  #boolean phone
  #boolean createdAt
  +getCode()
}
interface Story {
  -long phone
  #long description
  -Date note
  +boolean id
  #String createdAt
  +setScore()
  +validateCode()
  +calculateAmount()
}
interface Message {
  #long total
  -int price
  -long description
  -boolean type
  -long quantity
  +updateCode()
}
class Hashtag {
  #String updatedAt
  #float duration
  -double name
  -String score
  #float level
  +deletePhone()
  +createPhone()
  +processScore()
}
Profile --> Message : "1..*"
Story ..> Hashtag : "*"
note right of Profile : Social Media domain
@enduml