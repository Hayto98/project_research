@startuml
skinparam shadowing true
class Profile {
  #float duration
  #int score
  #double amount
  #boolean createdAt
  +validateStatus()
}
class Group {
  #float id
  -float address
  +setPhone()
  +cancelNote()
  +updateId()
}
class Story {
  +boolean active
  -long duration
  +double score
  +int name
  -long level
  +createActive()
  +setPrice()
  +cancelScore()
}
class Message {
  #long quantity
  +double code
  +sendAmount()
  +updateCode()
}
abstract class Hashtag {
  -int price
  -long description
  -boolean type
  -long quantity
  +int active
  +cancelTotal()
}
Message ..|> Group
Profile --> Hashtag : "0..1"
Hashtag --> Profile : "*"
Message --|> Story
@enduml