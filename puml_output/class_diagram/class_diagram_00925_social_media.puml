@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
abstract class Follower {
  #String note
  -String quantity
  +findEmail()
}
class Group {
  +int description
  #float note
  +long active
  +saveStatus()
  +validateType()
  +createAddress()
}
class Report {
  +Date address
  +long score
  #Date id
  #String description
  +deleteQuantity()
}
interface Hashtag {
  +int updatedAt
  -boolean score
  -String active
  +updateAmount()
  +calculatePhone()
  +deleteAddress()
  +processDescription()
}
class Like {
  #float level
  -int status
  +Date active
  +calculateCreatedat()
}
interface Post {
  #double amount
  #Date address
  #String level
  -float updatedAt
  +Date type
  +setScore()
}
abstract class Album {
  #float name
  #String address
  #double phone
  +long code
  -String score
  +setCode()
  +validateDescription()
  +sendDuration()
}
Album --* Group
Album --> Post : "*"
@enduml