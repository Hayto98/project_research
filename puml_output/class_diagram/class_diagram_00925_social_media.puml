@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
abstract class Follower {
  #String note
  -String quantity
  +updateDuration()
}
class Group {
  +boolean note
  +long active
  -float description
  +validateAddress()
}
class Report {
  #float description
  +long name
  +setStatus()
}
interface Hashtag {
  +int updatedAt
  -boolean score
  -String active
  +createUpdatedat()
  +createQuantity()
  +updateLevel()
  +setActive()
}
interface Like {
  #double amount
  +long createdAt
  -Date name
  +double address
  +findName()
  +validateUpdatedat()
  +saveId()
  +saveType()
}
abstract class Post {
  +long address
  #float phone
  +saveType()
}
class Album {
  -Date phone
  #float status
  +float active
  +long score
  +setTotal()
  +validateTotal()
  +saveActive()
  +createDuration()
}
Like --* Post
Group --> Follower : "0..1"
Report ..|> Group
note right of Follower : Social Media domain
@enduml