@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Customer {
  #Date name
  +float price
  #float createdAt
  +calculateCreatedat()
}
abstract class Transfer {
  +int status
  +boolean total
  +findDuration()
}
class Deposit {
  -float level
  -double status
  #boolean id
  +cancelId()
  +validateLevel()
  +updateCode()
}
class Statement {
  -String active
  #Date price
  +double phone
  -float email
  #float address
  +deleteAmount()
  +setAmount()
}
class Account {
  -String level
  +Date id
  +saveCode()
}
abstract class Teller {
  +float type
  -int active
  +float note
  #double email
  #double duration
  +validateUpdatedat()
  +setDuration()
  +updateActive()
}
interface Branch {
  +long score
  +String duration
  +calculateDescription()
  +getQuantity()
  +createName()
}
Account ..|> Customer
Transfer --o Branch
Deposit --|> Branch
@enduml