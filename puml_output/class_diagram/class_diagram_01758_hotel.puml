@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Invoice {
  -long type
  #long name
  #boolean total
  +setEmail()
}
abstract class Housekeeping {
  -double updatedAt
  #float amount
  #float duration
  +sendDuration()
  +getPhone()
  +validateDescription()
}
class Amenity {
  +double active
  +float address
  +getStatus()
  +findPhone()
  +validateNote()
  +saveActive()
}
class CheckIn {
  -double score
  +long amount
  +String description
  -boolean id
  -boolean price
  +createDescription()
  +sendEmail()
}
class Payment {
  -long phone
  #double updatedAt
  +findId()
  +createType()
  +setCode()
}
abstract class Staff {
  +Date score
  #boolean code
  #double id
  +saveStatus()
  +createNote()
}
Housekeeping --> Payment : "1"
Invoice ..> CheckIn : "0..1"
Staff --o Housekeeping
@enduml