@startuml
skinparam monochrome true
skinparam shadowing true
class Guest {
  -boolean status
  #long active
  +double price
  +float level
  #int address
  +updatePhone()
  +calculatePhone()
  +calculateNote()
}
class Room {
  -boolean quantity
  +Date level
  +saveStatus()
  +getScore()
  +findDescription()
  +createEmail()
}
class Housekeeping {
  #double active
  -double address
  +boolean type
  #String phone
  +deleteId()
  +calculateQuantity()
}
class Reservation {
  -boolean level
  -String score
  +float code
  +validateStatus()
}
interface Restaurant {
  #Date address
  -String email
  +processUpdatedat()
}
abstract class Staff {
  +int id
  +boolean phone
  #int total
  +deleteType()
  +setPrice()
  +findQuantity()
  +deleteId()
}
Room --> Guest : "*"
Housekeeping --* Guest
Housekeeping --o Room
note right of Guest : Hotel domain
@enduml