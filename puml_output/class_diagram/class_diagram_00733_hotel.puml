@startuml
skinparam monochrome true
skinparam shadowing true
class Guest {
  -boolean status
  #long active
  +double price
  +float level
  #int address
  +getPrice()
  +sendEmail()
  +validateDescription()
}
class Room {
  -boolean phone
  -boolean total
  +Date note
  -Date address
  +float code
  +getCreatedat()
}
class Housekeeping {
  -float email
  -Date phone
  -boolean quantity
  -double active
  +setType()
  +calculateActive()
  +validateTotal()
  +updatePrice()
}
interface Reservation {
  -int description
  #float id
  +boolean total
  +calculateCreatedat()
}
interface Restaurant {
  #boolean name
  +Date id
  -Date duration
  -float phone
  #Date status
  +findNote()
  +getLevel()
  +saveAmount()
  +sendNote()
}
abstract class Staff {
  +int id
  +boolean phone
  #int total
  +saveQuantity()
  +validateUpdatedat()
  +validateDescription()
  +getType()
}
Staff ..|> Housekeeping
Guest ..|> Restaurant
Room --> Guest : "*"
Housekeeping --* Guest
Housekeeping --o Room
@enduml