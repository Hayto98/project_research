@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
abstract class Guest {
  #int description
  #int code
  +createEmail()
  +findEmail()
}
class Payment {
  #String updatedAt
  +boolean price
  -boolean quantity
  +cancelName()
}
class Restaurant {
  +float quantity
  #double createdAt
  #int address
  #long total
  +processDescription()
  +createNote()
  +saveStatus()
}
class Invoice {
  -String code
  +String address
  +String duration
  +deleteTotal()
  +validateCode()
  +cancelUpdatedat()
}
Invoice ..|> Payment
Restaurant ..> Invoice : "0..1"
@enduml