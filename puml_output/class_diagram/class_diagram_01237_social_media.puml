@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
abstract class Comment {
  -double code
  #float phone
  +getDescription()
  +processLevel()
  +cancelCreatedat()
}
abstract class Like {
  #String total
  #boolean note
  -long address
  +long email
  +setUpdatedat()
  +setType()
  +createScore()
}
class Profile {
  -double level
  -Date type
  +long status
  +Date email
  +processCreatedat()
  +validateNote()
  +sendNote()
}
class Notification {
  +int name
  #boolean phone
  -boolean duration
  #Date active
  -String description
  +cancelDuration()
  +sendCode()
}
Notification --o Like
Comment --> Notification : "0..1"
@enduml