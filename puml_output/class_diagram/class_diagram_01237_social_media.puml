@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
abstract class Comment {
  -double code
  #float phone
  +calculateTotal()
  +processPhone()
  +calculateNote()
}
interface Like {
  #boolean level
  -long email
  +long score
  -String id
  +updateCreatedat()
  +saveAddress()
}
interface Profile {
  #int status
  -String email
  #long address
  +int type
  -double phone
  +validateLevel()
}
class Notification {
  -boolean status
  #Date updatedAt
  -String active
  +saveNote()
  +deleteLevel()
}
Profile --> Like : "1"
Like ..|> Profile
Notification ..> Comment : "*"
note right of Comment : Social Media domain
@enduml