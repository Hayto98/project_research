@startuml
skinparam monochrome true
abstract class Payment {
  #Date createdAt
  #String updatedAt
  #long price
  -boolean code
  +calculateTotal()
}
class Guest {
  -long email
  +float address
  #Date createdAt
  -int code
  +cancelCreatedat()
  +deleteCode()
  +validatePrice()
  +deleteEmail()
}
class CheckOut {
  +float score
  +double phone
  +double note
  -String quantity
  -boolean active
  +processAddress()
  +saveAmount()
}
class Service {
  +Date duration
  -int phone
  #int amount
  +setId()
  +createDescription()
  +saveId()
}
Service --> Guest : "1..*"
Guest --|> CheckOut
note right of Payment : Hotel domain
@enduml