@startuml
skinparam monochrome true
abstract class Payment {
  #Date createdAt
  #String updatedAt
  #long price
  -boolean code
  +saveCode()
}
abstract class Guest {
  #long quantity
  +float email
  +setTotal()
}
class CheckOut {
  +double duration
  #Date phone
  +createCode()
  +deleteEmail()
}
class Service {
  -Date price
  #boolean description
  -double email
  #long level
  +cancelLevel()
  +cancelType()
  +setDescription()
}
Service --o Payment
@enduml