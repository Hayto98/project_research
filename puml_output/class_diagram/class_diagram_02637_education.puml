@startuml
skinparam monochrome true
skinparam defaultFontSize 13
abstract class Attendance {
  #Date total
  #Date note
  +setCreatedat()
  +processPrice()
  +setName()
}
class Student {
  #double amount
  -Date name
  +String duration
  #double note
  +validateUpdatedat()
  +findAddress()
}
interface Schedule {
  #Date status
  -String level
  #Date name
  #float address
  -Date updatedAt
  +setQuantity()
  +validateUpdatedat()
  +findTotal()
  +createTotal()
}
abstract class Classroom {
  -Date total
  #double description
  #long name
  #double duration
  #String note
  +createStatus()
  +findLevel()
}
abstract class Grade {
  +boolean code
  +boolean name
  #String type
  +cancelAddress()
  +updateScore()
  +setAddress()
}
Classroom --|> Student
Schedule --* Attendance
Classroom --|> Grade
@enduml