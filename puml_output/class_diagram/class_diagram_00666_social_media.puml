@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Profile {
  #int description
  -boolean id
  +deleteStatus()
}
class Follower {
  -boolean score
  #float description
  +String type
  +float note
  #int total
  +processUpdatedat()
  +createId()
  +deleteTotal()
}
class Like {
  +long level
  #double amount
  #double email
  #boolean status
  +getScore()
}
abstract class Comment {
  -double active
  #Date updatedAt
  +saveId()
  +cancelType()
}
interface Group {
  +int address
  -Date phone
  #float createdAt
  -double active
  +sendPrice()
}
Like ..> Group : "*"
Profile --o Group
Profile --* Comment
Like ..> Profile : "1"
note right of Profile : Social Media domain
@enduml