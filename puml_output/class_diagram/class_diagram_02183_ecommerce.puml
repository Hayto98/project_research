@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Return {
  +float total
  #float duration
  +float description
  +findName()
  +getDescription()
  +deleteType()
}
interface Review {
  -double address
  +Date amount
  #String updatedAt
  -int quantity
  -long id
  +sendTotal()
  +updateUpdatedat()
  +createDescription()
  +validateName()
}
interface Shipment {
  +float name
  -String quantity
  #long email
  +int amount
  #Date code
  +processPrice()
  +saveCode()
  +updateScore()
}
class Invoice {
  #double address
  -double code
  #double updatedAt
  +validateDescription()
  +processName()
  +setUpdatedat()
}
class Order {
  -long active
  +long description
  +long status
  +int address
  +cancelCreatedat()
  +sendPrice()
  +setScore()
}
Invoice --|> Return
Order --o Shipment
note right of Return : Ecommerce domain
@enduml