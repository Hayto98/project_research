@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Return {
  +float total
  #float duration
  +float description
  +getActive()
  +processQuantity()
  +getUpdatedat()
}
class Review {
  -int amount
  +long type
  +long note
  +processUpdatedat()
  +sendUpdatedat()
  +setQuantity()
  +createNote()
}
interface Shipment {
  -long quantity
  -boolean createdAt
  +saveType()
  +calculateNote()
  +findAddress()
  +deleteCreatedat()
}
class Invoice {
  #long name
  #long score
  #int price
  #float duration
  +processAmount()
}
class Order {
  +boolean quantity
  #long name
  +saveName()
  +findStatus()
  +setDescription()
  +getDuration()
}
Order ..|> Review
Shipment ..> Return : "0..1"
@enduml