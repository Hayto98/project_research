@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Shipment {
  +double description
  -Date active
  #long level
  -String amount
  +cancelCreatedat()
}
class Supplier {
  -int status
  +float updatedAt
  +validateQuantity()
}
interface Review {
  -float duration
  #double id
  +setLevel()
  +calculateAmount()
}
class Wishlist {
  -int createdAt
  -float score
  #Date quantity
  +boolean type
  +setCode()
  +setScore()
}
class Return {
  +long active
  #long phone
  +String updatedAt
  +double code
  +findQuantity()
  +cancelLevel()
  +saveStatus()
}
class Payment {
  -String status
  -float amount
  +cancelDescription()
  +saveType()
  +findName()
  +getStatus()
}
class Coupon {
  +long description
  #boolean quantity
  #int name
  +validateCode()
  +getLevel()
}
Coupon --|> Return
Wishlist --|> Shipment
Wishlist --* Return
@enduml