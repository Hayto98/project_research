@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Catalog {
  #boolean total
  #Date quantity
  #double updatedAt
  +updateAmount()
}
class Publisher {
  #int type
  -Date description
  -String id
  +Date phone
  +createAmount()
  +sendUpdatedat()
  +deleteCode()
  +sendId()
}
class Branch {
  #Date type
  #float status
  +saveDuration()
  +sendType()
}
class Loan {
  #String createdAt
  +boolean name
  -String updatedAt
  +double email
  +cancelStatus()
  +calculateId()
  +sendDuration()
  +saveCreatedat()
}
class Member {
  +double quantity
  #double price
  -Date id
  -Date level
  +getPhone()
  +findNote()
  +setEmail()
}
class Reservation {
  -Date note
  #long description
  -float amount
  -float active
  +validateStatus()
  +saveDuration()
}
interface Fine {
  +boolean score
  -double active
  #String createdAt
  +saveName()
  +validateActive()
  +findDescription()
  +findLevel()
}
Branch --> Catalog : "*"
Publisher ..|> Catalog
Loan ..> Fine : "1..*"
Member ..> Fine : "1"
note right of Catalog : Library domain
@enduml