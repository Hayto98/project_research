@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Catalog {
  #boolean total
  #Date quantity
  #double updatedAt
  +saveNote()
}
class Publisher {
  -int score
  #Date address
  +updateTotal()
}
class Branch {
  -int price
  #int code
  +String level
  #String duration
  +cancelEmail()
  +deleteActive()
}
class Loan {
  #String duration
  -int active
  #String type
  +calculateScore()
  +processId()
}
class Member {
  +int active
  -Date quantity
  +deleteUpdatedat()
  +saveLevel()
  +updateUpdatedat()
  +processLevel()
}
class Reservation {
  -float description
  -double score
  +float level
  +validateQuantity()
  +saveAmount()
  +calculatePrice()
  +validateName()
}
abstract class Fine {
  +float address
  -int name
  -double phone
  +int note
  +sendPrice()
  +cancelActive()
  +calculateScore()
}
Fine --> Branch : "0..1"
Branch ..> Catalog : "0..1"
Fine --> Member : "0..1"
Publisher --* Member
Loan --|> Member
@enduml