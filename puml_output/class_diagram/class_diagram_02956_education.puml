@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Teacher {
  -long name
  -Date amount
  +setAmount()
}
abstract class Assignment {
  -int type
  #Date price
  #String phone
  +cancelType()
  +sendQuantity()
  +cancelName()
}
class Attendance {
  #float name
  -float active
  +boolean duration
  #Date address
  #float score
  +findQuantity()
  +calculateDuration()
}
abstract class Classroom {
  -Date name
  #boolean price
  #boolean address
  -long status
  +double quantity
  +getPhone()
  +createType()
}
Teacher --o Assignment
Attendance ..> Assignment : "*"
Assignment --> Attendance : "0..1"
note right of Teacher : Education domain
@enduml