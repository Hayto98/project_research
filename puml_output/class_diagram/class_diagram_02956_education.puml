@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Teacher {
  -long name
  -Date amount
  +getType()
}
class Assignment {
  -int level
  #Date description
  #String type
  #long price
  #double phone
  +deleteDescription()
  +calculateEmail()
  +setPrice()
}
class Attendance {
  #float name
  -float active
  +boolean duration
  #Date address
  #float score
  +setCreatedat()
  +processNote()
}
class Classroom {
  -boolean duration
  #float note
  +long total
  -Date name
  #boolean price
  +sendPhone()
  +processCreatedat()
  +processCode()
  +sendType()
}
Assignment --* Teacher
Attendance ..> Assignment : "1..*"
Teacher --o Assignment
@enduml