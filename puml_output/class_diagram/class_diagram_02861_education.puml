@startuml

interface Student {
  +float amount
  -double code
  +boolean active
  +cancelPhone()
}
class Grade {
  #double quantity
  #float price
  +float name
  +long description
  +processActive()
  +updateCreatedat()
  +updateNote()
}
class Assignment {
  -boolean name
  #long level
  -Date code
  #String amount
  +processId()
  +calculateAddress()
}
class Attendance {
  -String address
  -float type
  #long description
  +double score
  #int name
  +deleteCode()
  +validateDuration()
}
class Department {
  -int active
  #String price
  +String note
  +deleteActive()
  +validatePrice()
}
abstract class Classroom {
  -int address
  +double name
  +cancelDescription()
  +calculateAddress()
  +setName()
}
Student ..|> Attendance
Grade --> Student : "*"
Grade --o Attendance
note right of Student : Education domain
@enduml