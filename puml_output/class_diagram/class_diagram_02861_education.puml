@startuml

interface Student {
  +float amount
  -double code
  +boolean active
  +deleteUpdatedat()
}
class Grade {
  +int phone
  #double quantity
  #float price
  +setActive()
}
class Assignment {
  +float phone
  +double type
  +boolean active
  #long updatedAt
  +getUpdatedat()
}
interface Attendance {
  #Date amount
  -long price
  +updateStatus()
}
abstract class Department {
  #String price
  -Date address
  +findActive()
  +setLevel()
  +setPhone()
}
class Classroom {
  -float type
  #long code
  +processType()
  +saveUpdatedat()
}
Grade --|> Classroom
Assignment ..|> Department
Grade --o Department
@enduml