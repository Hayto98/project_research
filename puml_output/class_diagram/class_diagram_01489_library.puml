@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Catalog {
  -Date address
  #int note
  #Date type
  #double score
  +sendAmount()
  +validateLevel()
  +deletePhone()
}
class Publisher {
  -double status
  +float duration
  +long amount
  +calculateEmail()
}
class Author {
  #boolean score
  +double status
  -Date code
  +calculateTotal()
  +calculateId()
  +setLevel()
}
class Librarian {
  +double code
  #Date duration
  #int updatedAt
  +float createdAt
  +getEmail()
  +updateId()
  +cancelType()
}
class Member {
  +Date name
  #boolean code
  +float address
  -double createdAt
  +validateAmount()
  +cancelDescription()
  +deleteDescription()
  +createLevel()
}
abstract class Loan {
  -float name
  #double type
  +float address
  +String active
  +sendType()
  +deleteEmail()
  +saveScore()
  +setUpdatedat()
}
abstract class Shelf {
  #boolean code
  #Date phone
  +float updatedAt
  +String quantity
  #boolean name
  +calculateCode()
}
Publisher --> Shelf : "*"
Author ..> Librarian : "0..1"
Publisher --|> Loan
@enduml