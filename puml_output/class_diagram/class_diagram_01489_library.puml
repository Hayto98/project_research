@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Catalog {
  -Date address
  #int note
  #Date type
  #double score
  +sendAddress()
  +deleteStatus()
  +setLevel()
}
class Publisher {
  +float price
  +int amount
  #String description
  +float quantity
  #boolean code
  +calculatePrice()
  +findEmail()
}
class Author {
  +Date amount
  #int phone
  +int code
  +cancelDuration()
  +updateId()
  +validateDescription()
  +findAddress()
}
class Librarian {
  #boolean duration
  #long code
  +setScore()
  +sendCreatedat()
}
class Member {
  #double total
  -boolean email
  -float price
  #double phone
  +float name
  +getType()
  +validateName()
}
abstract class Loan {
  #boolean code
  #Date phone
  +float updatedAt
  +String quantity
  #boolean name
  +calculateDescription()
}
class Shelf {
  -Date score
  #int type
  +float phone
  +createAddress()
}
Author ..|> Shelf
Member --|> Publisher
Librarian ..|> Loan
Shelf --|> Catalog
note right of Catalog : Library domain
@enduml