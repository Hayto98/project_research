@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Supplier {
  -boolean active
  #Date price
  -String name
  -long level
  #String updatedAt
  +processStatus()
}
interface Order {
  #int price
  #double active
  +boolean type
  +getQuantity()
  +processAmount()
  +sendEmail()
}
class Product {
  -int status
  #double type
  -double quantity
  -double note
  #boolean amount
  +validateUpdatedat()
  +getDuration()
}
class Category {
  +double note
  +boolean score
  +sendPhone()
  +deletePhone()
}
interface Invoice {
  +float updatedAt
  #boolean active
  +float email
  -int amount
  #Date type
  +setActive()
}
class Coupon {
  -int active
  #int quantity
  +updateStatus()
}
class Payment {
  +String amount
  -long total
  #String level
  +float name
  -double code
  +saveTotal()
  +setType()
  +sendStatus()
}
Order --|> Supplier
Category --* Supplier
Supplier ..|> Product
Coupon ..> Order : "*"
@enduml