@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Notification {
  -Date description
  #float email
  -float duration
  +findActive()
  +deleteDescription()
}
class Album {
  #long name
  -long active
  #int phone
  +processCode()
  +createCode()
}
interface Comment {
  -double updatedAt
  #float type
  +boolean note
  -double active
  -Date price
  +getNote()
  +saveStatus()
}
interface User {
  -int duration
  #int type
  -double address
  -float score
  +findDuration()
  +updateId()
}
Album --o User
Notification --* Album
note right of Notification : Social Media domain
@enduml