@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Notification {
  -Date description
  #float email
  -float duration
  +setCode()
  +sendQuantity()
}
class Album {
  #boolean createdAt
  #long description
  #long name
  +deleteCreatedat()
  +setId()
  +updateType()
}
class Comment {
  #int code
  -Date quantity
  -float duration
  #Date active
  -double total
  +calculatePrice()
  +saveStatus()
  +saveType()
  +createCode()
}
interface User {
  #String total
  #long note
  #float createdAt
  -long name
  -double level
  +setAddress()
  +validateQuantity()
}
User ..|> Album
Album --|> Comment
Album --* Notification
@enduml