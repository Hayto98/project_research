@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Teller {
  #boolean phone
  +String address
  -Date name
  -Date code
  +boolean id
  +calculateActive()
}
abstract class Transaction {
  #float level
  #Date score
  +float name
  +setAmount()
}
class Withdrawal {
  -String note
  -String address
  +Date name
  #double price
  -long quantity
  +findTotal()
  +saveAmount()
}
class Interest {
  -String id
  #double code
  +updateQuantity()
}
interface Branch {
  #float code
  #int active
  +long amount
  #String duration
  +getEmail()
  +validateAddress()
}
class Customer {
  #String updatedAt
  +Date description
  -int address
  +String note
  +createUpdatedat()
  +saveEmail()
}
class Deposit {
  +int id
  -boolean active
  +Date score
  #String phone
  +updateQuantity()
}
Customer ..|> Deposit
Interest --> Transaction : "1..*"
Transaction ..> Interest : "*"
@enduml