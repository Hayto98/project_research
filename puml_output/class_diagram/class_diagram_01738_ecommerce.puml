@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Supplier {
  +boolean level
  +String type
  -float duration
  +deleteDescription()
  +validateStatus()
}
class Payment {
  -String email
  +double type
  +long status
  +validateCreatedat()
  +findScore()
}
interface Warehouse {
  #String code
  -boolean description
  +cancelName()
}
class Category {
  -boolean id
  +int type
  +cancelLevel()
  +calculateQuantity()
}
class Wishlist {
  -boolean id
  +long status
  +findDescription()
  +createNote()
  +saveId()
  +validateNote()
}
class Cart {
  -float score
  -int updatedAt
  #boolean active
  -Date amount
  #double level
  +updateLevel()
  +findCreatedat()
  +saveCode()
}
Supplier --o Wishlist
Category ..|> Wishlist
Cart ..|> Warehouse
Warehouse ..> Category : "0..1"
Wishlist ..|> Warehouse
@enduml