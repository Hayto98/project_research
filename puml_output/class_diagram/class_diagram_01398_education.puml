@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Attendance {
  +double note
  #double price
  #int status
  +updateId()
  +findDescription()
  +validatePrice()
}
class Classroom {
  +String code
  +String total
  #int id
  #long note
  +calculateStatus()
  +createName()
  +saveQuantity()
}
class Book {
  +boolean address
  -boolean duration
  +getNote()
  +calculateNote()
  +sendPhone()
  +cancelType()
}
class Teacher {
  -boolean level
  +int description
  #int code
  #Date score
  +findId()
  +updateType()
}
class Department {
  +Date id
  -int type
  +Date quantity
  +int level
  -int status
  +processStatus()
}
abstract class Assignment {
  +String updatedAt
  +int description
  -float quantity
  +boolean id
  -int status
  +calculateActive()
}
class Exam {
  +int createdAt
  -boolean quantity
  -double description
  -boolean duration
  +createDescription()
  +saveActive()
}
Assignment --|> Exam
Attendance --* Assignment
Attendance --o Exam
note right of Attendance : Education domain
@enduml