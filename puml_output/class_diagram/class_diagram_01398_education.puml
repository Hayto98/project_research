@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Attendance {
  +double note
  #double price
  #int status
  +processActive()
  +findTotal()
  +updatePrice()
}
class Classroom {
  -String price
  -String code
  +String phone
  +float level
  +getActive()
  +getNote()
}
interface Book {
  #Date total
  #long status
  -String quantity
  -long name
  +findDescription()
}
class Teacher {
  #double id
  +long note
  #int total
  #String level
  +long phone
  +deleteAddress()
}
class Department {
  +boolean id
  -String updatedAt
  -Date type
  +sendStatus()
  +processNote()
  +validateUpdatedat()
}
class Assignment {
  +Date email
  +int description
  +setLevel()
  +updateDuration()
  +deleteTotal()
  +findActive()
}
class Exam {
  +float score
  +int note
  +String updatedAt
  +double description
  +boolean quantity
  +deleteAddress()
  +findNote()
  +calculateCode()
}
Attendance ..|> Book
Book ..|> Classroom
Attendance --o Classroom
Department --o Book
Book ..|> Department
@enduml