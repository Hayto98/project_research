@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
abstract class Hashtag {
  -boolean description
  +double quantity
  +validateDescription()
  +updateName()
  +processDuration()
  +validateAmount()
}
class Follower {
  #Date quantity
  #String type
  +float duration
  +Date amount
  +validateTotal()
  +sendAmount()
  +findEmail()
  +calculateId()
}
interface User {
  #long name
  -long quantity
  +updateNote()
  +sendScore()
}
abstract class Notification {
  +long duration
  -float name
  +Date description
  #float id
  -int createdAt
  +sendTotal()
  +processScore()
}
Follower --* Hashtag
User --> Hashtag : "1..*"
Notification --> Hashtag : "0..1"
@enduml