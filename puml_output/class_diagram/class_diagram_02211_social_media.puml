@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
abstract class Hashtag {
  -boolean description
  +double quantity
  +setUpdatedat()
  +createAmount()
  +saveEmail()
  +createDuration()
}
abstract class Follower {
  #double amount
  #boolean id
  +Date status
  #String createdAt
  +createActive()
}
class User {
  -float address
  #double description
  #Date active
  #float price
  +deleteId()
}
class Notification {
  #float address
  #float type
  -int code
  +getType()
  +updateUpdatedat()
}
User --> Hashtag : "1..*"
Notification --> Hashtag : "0..1"
Notification --|> User
note right of Hashtag : Social Media domain
@enduml