@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Account {
  -String note
  #double amount
  #Date duration
  +getDuration()
  +saveId()
  +deleteDuration()
  +getScore()
}
class Customer {
  #double updatedAt
  +String name
  +sendTotal()
}
class Interest {
  -Date score
  -int name
  -Date phone
  -int amount
  +deleteQuantity()
  +savePrice()
  +deleteNote()
}
class Beneficiary {
  +boolean quantity
  -String type
  +updateNote()
  +setName()
  +saveActive()
  +validateEmail()
}
Customer --> Account : "*"
Beneficiary --|> Interest
Account --> Interest : "1"
note right of Account : Banking domain
@enduml