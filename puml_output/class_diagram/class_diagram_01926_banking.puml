@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Account {
  -String note
  #double amount
  #Date duration
  +setAmount()
  +calculateId()
  +setId()
  +cancelScore()
}
class Customer {
  +String duration
  +String id
  #double score
  +updateActive()
  +saveUpdatedat()
}
class Interest {
  +double name
  #double phone
  +double score
  #double duration
  +long level
  +processDescription()
  +findStatus()
}
abstract class Beneficiary {
  -double note
  +boolean name
  -String id
  +saveNote()
  +createName()
  +setDescription()
  +deleteNote()
}
Interest --> Customer : "0..1"
Account --o Interest
Beneficiary --|> Interest
@enduml