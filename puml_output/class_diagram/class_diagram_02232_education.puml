@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
interface Student {
  +String quantity
  #long note
  +calculateEmail()
  +processType()
}
class Assignment {
  #boolean total
  #boolean type
  #String score
  +updateTotal()
  +validatePhone()
  +findTotal()
}
class Grade {
  +String email
  #boolean status
  +setScore()
}
class Teacher {
  #long updatedAt
  #String level
  +String quantity
  -double phone
  +updateAddress()
  +sendType()
}
class Enrollment {
  +int price
  -boolean id
  #int phone
  -float active
  +findId()
  +createAddress()
  +savePrice()
}
Teacher ..|> Assignment
Enrollment --|> Teacher
note right of Student : Education domain
@enduml