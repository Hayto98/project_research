@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
interface Student {
  +String quantity
  #long note
  +updateEmail()
  +cancelDescription()
}
class Assignment {
  -boolean type
  #boolean description
  #boolean active
  #String createdAt
  -int total
  +findQuantity()
  +findCode()
  +sendStatus()
  +cancelUpdatedat()
}
abstract class Grade {
  +int name
  +boolean email
  +setStatus()
}
interface Teacher {
  -float email
  #long updatedAt
  #String quantity
  +sendTotal()
  +processLevel()
}
abstract class Enrollment {
  -int createdAt
  #long address
  -String score
  +getName()
  +findDuration()
  +validateEmail()
}
Grade --* Assignment
Grade --* Student
@enduml