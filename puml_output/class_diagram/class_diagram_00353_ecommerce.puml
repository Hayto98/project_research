@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Shipment {
  +float address
  #long id
  +String phone
  +getCreatedat()
  +findAmount()
  +setAmount()
  +getPhone()
}
class Payment {
  +long quantity
  -int address
  #String phone
  +double amount
  +setQuantity()
}
class Customer {
  #Date amount
  +double name
  +cancelAmount()
  +updateTotal()
  +setTotal()
}
interface Return {
  +int score
  #long phone
  -boolean quantity
  -float status
  -float note
  +getCreatedat()
  +saveEmail()
  +cancelType()
  +validateScore()
}
class Cart {
  -String status
  #int updatedAt
  -int level
  #float description
  -int quantity
  +updatePrice()
  +processCreatedat()
  +updateCode()
  +calculateCreatedat()
}
class Supplier {
  #Date name
  -boolean total
  -float updatedAt
  +validateDescription()
  +updateScore()
}
Supplier ..> Customer : "1..*"
Return --> Shipment : "0..1"
Customer ..> Shipment : "*"
@enduml