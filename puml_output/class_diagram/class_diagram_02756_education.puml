@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Department {
  -String address
  +long updatedAt
  +boolean amount
  +long email
  +setDuration()
}
abstract class Course {
  +long address
  -float amount
  #long note
  -String description
  -String total
  +cancelUpdatedat()
}
abstract class Classroom {
  #String name
  #String address
  +Date level
  -float id
  +sendDuration()
}
class Exam {
  #long email
  -boolean code
  -boolean level
  +double score
  +setDuration()
  +getQuantity()
}
Department --* Classroom
Course ..|> Classroom
Classroom ..|> Exam
@enduml