@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Beneficiary {
  +String score
  -double quantity
  #Date price
  -int duration
  +double active
  +deleteDuration()
  +getUpdatedat()
  +deleteAddress()
  +sendPhone()
}
class Transaction {
  +double total
  -String status
  -boolean createdAt
  -float amount
  +sendStatus()
  +updateUpdatedat()
}
interface Statement {
  +boolean description
  #Date id
  +Date status
  -double price
  -boolean code
  +findDuration()
  +processUpdatedat()
}
class Transfer {
  -Date note
  -float description
  -String code
  +long email
  +int amount
  +setDuration()
  +processAmount()
  +getUpdatedat()
  +getType()
}
class Account {
  -double address
  -Date score
  +findActive()
  +findScore()
  +createScore()
}
interface Interest {
  +String phone
  -Date address
  +validateUpdatedat()
}
abstract class Customer {
  #long amount
  -Date quantity
  +findDuration()
  +deleteUpdatedat()
  +setCode()
}
Account --|> Transaction
Transfer --> Statement : "1..*"
Transfer ..> Beneficiary : "1..*"
Transaction --* Customer
note right of Beneficiary : Banking domain
@enduml