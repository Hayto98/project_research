@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
interface Payment {
  +double name
  -double total
  #long createdAt
  #long level
  +boolean active
  +getLevel()
  +saveActive()
  +createUpdatedat()
}
class Review {
  -double amount
  -boolean note
  -long active
  -long level
  +double code
  +cancelAmount()
  +setCreatedat()
  +validateCreatedat()
  +getCode()
}
class Category {
  +String createdAt
  -Date phone
  +int name
  -String code
  +setLevel()
  +calculateUpdatedat()
  +updateLevel()
}
class Return {
  #int description
  -boolean type
  -float note
  +validatePhone()
  +findActive()
}
class Warehouse {
  -Date address
  #int note
  +double updatedAt
  +long createdAt
  -long duration
  +getScore()
}
abstract class Customer {
  #boolean price
  #boolean code
  +double status
  +float name
  +setQuantity()
  +calculateEmail()
}
Customer ..|> Warehouse
Payment --* Return
Review --* Customer
@enduml