@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
abstract class Group {
  -String phone
  #double price
  #float duration
  +boolean active
  -Date updatedAt
  +createType()
}
interface User {
  -Date status
  +double phone
  #double note
  +double description
  +sendCreatedat()
}
class Comment {
  #float address
  +Date name
  #long duration
  #double price
  +calculateAmount()
}
class Story {
  +double description
  #String email
  #Date type
  +Date phone
  +long quantity
  +processStatus()
  +setCode()
}
class Post {
  #double amount
  #long id
  +getQuantity()
  +updateAddress()
  +validateTotal()
  +processEmail()
}
interface Message {
  #boolean status
  #int type
  +cancelPhone()
  +findEmail()
}
Story --|> User
Post --> Story : "1..*"
note right of Group : Social Media domain
@enduml