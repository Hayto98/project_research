@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
abstract class Group {
  -String phone
  #double price
  #float duration
  +boolean active
  -Date updatedAt
  +validateAmount()
}
abstract class User {
  -Date status
  +double phone
  #double note
  +double description
  +updateNote()
}
class Comment {
  -long score
  +long active
  +setPhone()
  +sendStatus()
  +calculateNote()
  +getActive()
}
class Story {
  #double active
  +long code
  -float price
  -float amount
  -int status
  +calculatePrice()
  +saveEmail()
  +createNote()
  +updateNote()
}
class Post {
  -String address
  +String level
  +float description
  +getDuration()
}
class Message {
  #Date note
  -float phone
  +getNote()
}
Message --* Comment
Message --o Story
@enduml