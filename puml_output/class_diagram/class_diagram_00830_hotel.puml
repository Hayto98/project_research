@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
abstract class CheckOut {
  #float duration
  -double phone
  -double email
  +cancelQuantity()
  +createNote()
  +getStatus()
}
class Staff {
  #long address
  #Date type
  +sendDuration()
}
abstract class Booking {
  +double status
  #boolean email
  #long price
  +processTotal()
}
abstract class Restaurant {
  -double code
  +float phone
  -boolean note
  +findActive()
  +updateAmount()
  +updateLevel()
}
class Amenity {
  +boolean duration
  -double address
  +int type
  #long name
  +int total
  +calculateId()
  +updatePhone()
  +deleteStatus()
  +saveId()
}
Restaurant --|> CheckOut
Booking --> Restaurant : "1"
Staff --> Booking : "1"
@enduml