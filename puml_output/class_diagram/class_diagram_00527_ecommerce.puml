@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
interface Category {
  +boolean total
  -String phone
  #boolean duration
  +boolean status
  +findDescription()
}
interface Return {
  -double email
  +Date description
  +String score
  +findType()
  +updateActive()
  +validateTotal()
}
class Warehouse {
  +boolean email
  -String total
  -boolean type
  -String price
  #boolean quantity
  +findCreatedat()
  +setCode()
}
class Customer {
  #long amount
  +double address
  +double active
  -int quantity
  +setUpdatedat()
  +cancelEmail()
}
abstract class Review {
  #float level
  -int code
  -String type
  #float total
  +findType()
  +updateAddress()
}
class Cart {
  #Date duration
  -Date createdAt
  +deleteAddress()
  +processUpdatedat()
}
Return ..|> Warehouse
Cart --|> Customer
note right of Category : Ecommerce domain
@enduml