@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
interface Category {
  +boolean total
  -String phone
  #boolean duration
  +boolean status
  +validateTotal()
}
class Return {
  -double email
  +Date description
  +String score
  +cancelUpdatedat()
  +updateAmount()
  +findActive()
}
class Warehouse {
  -double total
  -long quantity
  +boolean duration
  -String email
  +setPhone()
  +deleteCode()
  +getLevel()
  +setAddress()
}
interface Customer {
  #float createdAt
  +long code
  +long level
  +getActive()
  +cancelId()
  +setQuantity()
}
class Review {
  +Date updatedAt
  +boolean type
  #long note
  #Date duration
  -long description
  +sendName()
}
abstract class Cart {
  +long amount
  +String price
  #int name
  #Date duration
  -Date type
  +updateCode()
  +findPhone()
}
Customer --|> Return
Return ..|> Warehouse
Cart --|> Customer
Review --|> Cart
@enduml