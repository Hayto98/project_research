@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Album {
  #boolean createdAt
  -long duration
  +long description
  +findTotal()
}
interface Report {
  +float updatedAt
  -Date note
  -int quantity
  -String total
  #float type
  +deleteQuantity()
  +findName()
  +cancelScore()
}
class Like {
  -Date price
  -String type
  #long code
  #int duration
  #Date note
  +cancelAddress()
  +setActive()
  +sendActive()
}
class Group {
  #double quantity
  #float type
  #long name
  +double phone
  -double amount
  +createEmail()
  +setTotal()
}
Report --* Group
Group --> Report : "*"
@enduml