@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Album {
  #boolean createdAt
  -long duration
  +long description
  +sendPrice()
}
class Report {
  -Date quantity
  -int total
  -String active
  #float type
  -String status
  +calculatePrice()
  +processCode()
}
abstract class Like {
  #Date quantity
  -long total
  #long status
  -long email
  -float amount
  +validateAmount()
}
interface Group {
  +float address
  -float name
  +int price
  -long duration
  #boolean score
  +calculateActive()
  +savePrice()
  +findAmount()
  +getUpdatedat()
}
Album --|> Group
note right of Album : Social Media domain
@enduml