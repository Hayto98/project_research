@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Invoice {
  -boolean score
  #boolean status
  +String price
  #Date level
  +validateUpdatedat()
}
abstract class Reservation {
  -int phone
  -float address
  +double score
  -Date code
  +getDescription()
  +getNote()
}
class Housekeeping {
  #long price
  +boolean description
  +double duration
  -float type
  +long active
  +setActive()
}
interface CheckIn {
  -float level
  +int description
  -long duration
  #double status
  +setCode()
  +saveCreatedat()
}
class CheckOut {
  -int description
  +Date name
  +long duration
  +deleteQuantity()
}
CheckOut ..|> Reservation
CheckIn --* Housekeeping
note right of Invoice : Hotel domain
@enduml