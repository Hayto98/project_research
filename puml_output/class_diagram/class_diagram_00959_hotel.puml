@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Invoice {
  -boolean score
  #boolean status
  +String price
  #Date level
  +processCreatedat()
}
class Reservation {
  -long note
  #String level
  -int address
  +createEmail()
  +getUpdatedat()
  +sendEmail()
}
abstract class Housekeeping {
  -long description
  -double id
  +Date duration
  -double name
  +updateAddress()
  +processStatus()
  +processPrice()
  +createStatus()
}
class CheckIn {
  #boolean price
  #boolean description
  -boolean address
  +int code
  +double active
  +getTotal()
}
abstract class CheckOut {
  +Date score
  +float total
  -float amount
  #float status
  +createCreatedat()
  +processQuantity()
}
CheckIn ..|> Reservation
Invoice --|> Housekeeping
@enduml