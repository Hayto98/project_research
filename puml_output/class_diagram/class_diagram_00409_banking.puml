@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
interface Statement {
  #boolean address
  #long note
  -Date score
  +createDuration()
  +setAmount()
}
class Transfer {
  -String quantity
  +String type
  +cancelAddress()
  +calculateAddress()
  +cancelName()
}
class Teller {
  -double createdAt
  #float updatedAt
  -float score
  +double amount
  +findDuration()
  +deleteDuration()
  +findType()
  +setCreatedat()
}
abstract class Beneficiary {
  -float total
  -String description
  -String code
  #long name
  -long active
  +getAmount()
  +validatePhone()
  +findId()
  +cancelCode()
}
class Deposit {
  -String price
  -double amount
  #float updatedAt
  +float description
  +updateType()
  +updateNote()
  +saveLevel()
}
class Interest {
  +String duration
  -Date status
  +updatePrice()
  +sendId()
}
Interest ..> Statement : "1..*"
Teller --* Transfer
Interest --> Deposit : "1"
Deposit ..> Transfer : "0..1"
Interest --> Teller : "0..1"
@enduml