@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Housekeeping {
  -float price
  -boolean createdAt
  -String status
  -boolean updatedAt
  -int duration
  +cancelAddress()
}
class Payment {
  -long name
  #boolean level
  +sendQuantity()
  +setId()
  +calculateScore()
  +createDescription()
}
class Service {
  #double quantity
  -String status
  #String email
  -double id
  +findStatus()
}
abstract class CheckIn {
  +long note
  #String type
  +String total
  -double score
  #Date description
  +updateNote()
}
class Amenity {
  +float quantity
  -Date duration
  #float id
  +float amount
  #double note
  +calculateEmail()
  +validateEmail()
  +sendActive()
  +sendAddress()
}
Payment ..|> Amenity
Housekeeping --* CheckIn
@enduml