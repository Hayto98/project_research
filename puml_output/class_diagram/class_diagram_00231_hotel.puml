@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Housekeeping {
  -float price
  -boolean createdAt
  -String status
  -boolean updatedAt
  -int duration
  +createPhone()
}
class Payment {
  -Date level
  #double note
  +sendCreatedat()
  +validateQuantity()
  +findStatus()
}
class Service {
  -String level
  #String total
  +processName()
  +saveNote()
  +processNote()
  +processLevel()
}
abstract class CheckIn {
  +String description
  -double duration
  #Date address
  +boolean active
  -boolean name
  +createQuantity()
  +getAmount()
  +processId()
  +processCode()
}
interface Amenity {
  +int note
  +Date name
  +double status
  -String email
  #double price
  +calculatePrice()
  +sendType()
  +setPrice()
}
Amenity --o CheckIn
CheckIn ..> Housekeeping : "1"
CheckIn --|> Service
note right of Housekeeping : Hotel domain
@enduml