@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Amenity {
  +String price
  +boolean level
  #float email
  #long description
  #double note
  +validateQuantity()
  +findPrice()
  +getCode()
}
class Reservation {
  +boolean quantity
  -Date address
  #float amount
  +setAmount()
  +setNote()
  +sendPrice()
}
class CheckIn {
  #Date code
  -long type
  +deleteUpdatedat()
}
interface Room {
  +boolean price
  #boolean score
  #float phone
  -float id
  +int duration
  +sendPrice()
  +setAmount()
}
Room --|> Reservation
Amenity --* Reservation
@enduml