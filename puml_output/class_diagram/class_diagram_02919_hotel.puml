@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Amenity {
  +String price
  +boolean level
  #float email
  #long description
  #double note
  +deleteActive()
  +cancelCreatedat()
  +updateQuantity()
}
class Reservation {
  -Date code
  -boolean total
  +float quantity
  +findType()
}
class CheckIn {
  -boolean status
  -String level
  -float active
  +boolean type
  +setDescription()
  +deleteName()
  +calculatePrice()
}
class Room {
  +int phone
  +float quantity
  +createCode()
  +getUpdatedat()
  +sendPhone()
}
CheckIn --> Room : "*"
Reservation --> CheckIn : "0..1"
note right of Amenity : Hotel domain
@enduml