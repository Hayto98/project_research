@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
interface Tracking {
  +Date level
  +Date updatedAt
  -int duration
  -int score
  +validateName()
  +createPhone()
  +sendLevel()
  +calculateCode()
}
class FuelLog {
  #Date score
  -float description
  +calculateType()
  +updateId()
  +calculateTotal()
}
class Route {
  #int duration
  +int name
  -float score
  -boolean total
  -int id
  +createScore()
  +setTotal()
}
abstract class Manifest {
  #String id
  -Date total
  +updateActive()
  +createId()
  +processTotal()
  +validateDescription()
}
abstract class DeliveryNote {
  -float duration
  -long price
  +long amount
  +calculateStatus()
  +sendLevel()
  +setStatus()
}
class Depot {
  +String price
  #Date note
  #float active
  #long name
  -float email
  +sendType()
  +deleteScore()
  +processQuantity()
}
Tracking ..> Depot : "1..*"
Depot ..|> Route
DeliveryNote --|> Depot
@enduml