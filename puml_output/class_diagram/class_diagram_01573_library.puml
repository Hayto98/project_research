@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Fine {
  #String updatedAt
  +long note
  +processNote()
  +saveAddress()
  +sendDescription()
  +sendUpdatedat()
}
class Member {
  +long total
  -long updatedAt
  +long price
  -String type
  -boolean level
  +getType()
  +createCreatedat()
}
class Reservation {
  +double code
  #float duration
  +calculateActive()
}
class Branch {
  #double phone
  -int address
  #long code
  -Date total
  +findLevel()
}
abstract class Publisher {
  -String email
  +int type
  #float status
  +deleteNote()
  +saveScore()
  +getQuantity()
}
class Librarian {
  -String id
  +float quantity
  -Date amount
  +validateName()
}
Branch --* Member
@enduml