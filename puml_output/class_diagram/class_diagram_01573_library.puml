@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Fine {
  #String updatedAt
  +long note
  +saveAmount()
  +findAmount()
  +processTotal()
  +updatePrice()
}
abstract class Member {
  -int description
  -long address
  +double price
  +setDescription()
  +createName()
}
class Reservation {
  #float id
  #boolean note
  +sendCode()
}
class Branch {
  -int address
  #long code
  -Date total
  +float price
  +cancelCreatedat()
  +findEmail()
  +processDuration()
  +setTotal()
}
class Publisher {
  +long amount
  #long active
  +String address
  +saveAmount()
  +processName()
  +setEmail()
}
class Librarian {
  -int active
  +int code
  #double price
  #String description
  +Date phone
  +calculatePrice()
}
Fine --o Librarian
Branch --> Fine : "1"
Reservation --> Publisher : "*"
Reservation --* Librarian
note right of Fine : Library domain
@enduml