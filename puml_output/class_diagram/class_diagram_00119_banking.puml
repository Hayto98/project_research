@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
interface Statement {
  -boolean email
  -String total
  +int id
  -Date code
  +setPrice()
  +getAddress()
}
interface Transfer {
  +float updatedAt
  +float total
  -float phone
  +float description
  +findStatus()
  +getDescription()
  +calculateName()
  +processName()
}
abstract class Deposit {
  #boolean updatedAt
  #long price
  +createType()
  +calculateAmount()
  +sendEmail()
}
interface Loan {
  -float active
  +long amount
  +String phone
  +createAmount()
}
class Withdrawal {
  #int quantity
  +double description
  -boolean phone
  +validateAddress()
  +saveTotal()
  +validateCreatedat()
}
interface Transaction {
  -double score
  +double createdAt
  -String status
  -int id
  +createScore()
  +updateCode()
  +processAmount()
}
class Account {
  +String type
  -double id
  #long phone
  -boolean updatedAt
  #String active
  +validateTotal()
  +processQuantity()
  +cancelScore()
}
Withdrawal --|> Statement
Statement --o Transaction
Account --> Loan : "*"
Withdrawal --* Transaction
@enduml