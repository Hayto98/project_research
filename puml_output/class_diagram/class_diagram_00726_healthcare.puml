@startuml
skinparam monochrome true
skinparam shadowing true
interface MedicalRecord {
  -Date createdAt
  +double level
  -int quantity
  +cancelName()
  +updateId()
}
class Treatment {
  #long updatedAt
  #long note
  +String total
  -Date address
  +createType()
  +findQuantity()
  +saveName()
  +cancelCode()
}
class Patient {
  #double address
  +long total
  +long note
  -long duration
  +setTotal()
  +cancelDescription()
  +cancelStatus()
}
class LabTest {
  +boolean name
  -double note
  -double updatedAt
  +validateActive()
  +sendActive()
  +getLevel()
}
Treatment --|> LabTest
MedicalRecord --> LabTest : "1"
LabTest --> Patient : "1..*"
@enduml