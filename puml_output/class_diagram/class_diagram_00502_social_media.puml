@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
abstract class Notification {
  #long address
  +String id
  -double price
  #double code
  +double description
  +cancelQuantity()
  +findStatus()
  +saveNote()
  +createCode()
}
abstract class Post {
  +float createdAt
  #Date updatedAt
  -float quantity
  -double price
  +processLevel()
  +updateCreatedat()
  +calculateStatus()
  +sendDescription()
}
class Story {
  +double createdAt
  -double code
  #boolean name
  +findType()
  +createStatus()
}
class Report {
  #int phone
  -Date email
  #boolean note
  +long active
  +double address
  +setId()
  +validateCreatedat()
  +sendAmount()
}
class Message {
  -long price
  #long score
  +setActive()
  +createType()
  +updateAddress()
  +calculateNote()
}
interface Profile {
  #String level
  +double phone
  -int id
  +boolean quantity
  #double note
  +createPrice()
  +setPhone()
}
class Comment {
  #Date score
  #double amount
  #boolean level
  #Date type
  +getActive()
  +processNote()
  +updateScore()
  +setQuantity()
}
Report ..|> Notification
Profile ..|> Message
Notification --o Story
@enduml