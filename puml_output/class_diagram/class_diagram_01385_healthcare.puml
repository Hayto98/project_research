@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Doctor {
  +Date active
  #float level
  +boolean quantity
  +validateEmail()
  +cancelEmail()
}
class Ward {
  -long updatedAt
  #double code
  #Date price
  +getCreatedat()
}
class Nurse {
  +String duration
  #Date amount
  -double note
  +float status
  +sendPrice()
}
class Treatment {
  -String level
  +Date type
  +float description
  +String score
  +String id
  +validateEmail()
  +sendAmount()
  +calculateNote()
}
abstract class Patient {
  #Date amount
  -double description
  +float score
  +Date id
  -int note
  +createStatus()
  +createScore()
  +saveEmail()
}
Doctor ..> Patient : "1..*"
Nurse --* Doctor
note right of Doctor : Healthcare domain
@enduml