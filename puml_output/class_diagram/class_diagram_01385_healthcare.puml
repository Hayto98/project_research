@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
class Doctor {
  +Date active
  #float level
  +boolean quantity
  +createActive()
  +calculateUpdatedat()
}
class Ward {
  #double quantity
  -long updatedAt
  #double level
  #Date code
  +updatePrice()
}
class Nurse {
  +String quantity
  #Date amount
  -double note
  +float status
  +cancelAmount()
}
abstract class Treatment {
  -int total
  +String level
  +saveId()
  +processName()
  +createTotal()
  +findNote()
}
class Patient {
  -long updatedAt
  -boolean code
  +cancelCreatedat()
  +createName()
}
Treatment ..|> Patient
Ward --o Doctor
Doctor ..> Patient : "*"
@enduml