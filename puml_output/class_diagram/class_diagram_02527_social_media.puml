@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
interface Album {
  -long price
  +boolean email
  -double type
  +float code
  -String id
  +createUpdatedat()
}
interface Message {
  #double score
  +long code
  +sendAmount()
  +setCode()
}
class Notification {
  -double status
  +int total
  #float active
  #boolean description
  #Date email
  +setCreatedat()
  +sendEmail()
  +validateCreatedat()
}
class Hashtag {
  #boolean price
  -double total
  +setCreatedat()
  +getEmail()
  +validatePrice()
  +processAmount()
}
interface Post {
  +boolean total
  +int score
  -long amount
  -Date type
  +getUpdatedat()
  +createDuration()
}
interface Group {
  +double note
  #boolean description
  #long total
  +float code
  +getId()
}
class Profile {
  -boolean amount
  -float duration
  -long price
  +Date phone
  +String active
  +sendActive()
  +validateStatus()
  +updateUpdatedat()
  +updateLevel()
}
Group --> Notification : "*"
Message --> Group : "1"
Notification ..|> Profile
Hashtag --o Album
note right of Album : Social Media domain
@enduml