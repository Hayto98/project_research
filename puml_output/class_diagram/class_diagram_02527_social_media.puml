@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
interface Album {
  -long price
  +boolean email
  -double type
  +float code
  -String id
  +getNote()
}
class Message {
  #double score
  +long code
  +sendAmount()
  +validateQuantity()
}
class Notification {
  #float description
  +Date total
  +processAddress()
  +setDuration()
  +calculateLevel()
  +calculateActive()
}
class Hashtag {
  #float email
  #boolean type
  #Date code
  #boolean description
  +saveType()
  +processAmount()
  +setQuantity()
}
class Post {
  -float address
  -Date createdAt
  #long duration
  -double name
  +validateStatus()
}
class Group {
  -float email
  -int phone
  +cancelUpdatedat()
  +findType()
  +setNote()
}
interface Profile {
  +long type
  -long updatedAt
  #int code
  +processPrice()
}
Group --> Profile : "1..*"
Hashtag --o Message
Profile --|> Album
Hashtag --> Post : "1..*"
@enduml