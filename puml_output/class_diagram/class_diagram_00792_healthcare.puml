@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Treatment {
  #long amount
  -long price
  -long description
  +double score
  +float phone
  +calculateName()
  +setType()
  +sendId()
  +findPrice()
}
abstract class MedicalRecord {
  #float description
  #String level
  +validateNote()
  +calculateCreatedat()
  +setPrice()
}
interface Billing {
  +Date active
  +double updatedAt
  -long level
  +boolean type
  -Date score
  +deleteActive()
  +calculateTotal()
  +processLevel()
  +getDuration()
}
class Hospital {
  #String active
  -long level
  +calculateNote()
  +createLevel()
  +sendAddress()
  +findAmount()
}
interface Diagnosis {
  -float quantity
  #float description
  #String name
  +float status
  +saveActive()
  +savePhone()
  +deleteDescription()
}
Hospital ..|> Billing
Treatment --|> MedicalRecord
note right of Treatment : Healthcare domain
@enduml