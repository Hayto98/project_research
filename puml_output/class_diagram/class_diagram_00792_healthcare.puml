@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Treatment {
  #long amount
  -long price
  -long description
  +double score
  +float phone
  +validateLevel()
  +saveName()
  +validateDescription()
  +deleteTotal()
}
class MedicalRecord {
  +Date type
  -Date score
  +deleteNote()
  +validateCode()
  +savePrice()
  +updateScore()
}
class Billing {
  +double phone
  #Date note
  #boolean total
  #double createdAt
  +processPrice()
  +validateUpdatedat()
}
class Hospital {
  -int id
  #long price
  #boolean note
  +deleteScore()
  +cancelScore()
  +updateNote()
  +cancelCreatedat()
}
abstract class Diagnosis {
  -long level
  #double name
  -double duration
  -float code
  #boolean score
  +validateTotal()
  +updateType()
  +deleteUpdatedat()
}
Billing --|> MedicalRecord
Treatment --> Hospital : "1"
MedicalRecord ..> Billing : "1..*"
@enduml