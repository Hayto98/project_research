@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Payment {
  #String status
  +String address
  +float amount
  +calculatePhone()
  +sendQuantity()
  +cancelCode()
}
interface Room {
  #String description
  -Date note
  +boolean phone
  +setPrice()
  +setEmail()
  +sendStatus()
  +calculateNote()
}
interface CheckOut {
  +double id
  #String note
  #long type
  +findCreatedat()
  +findAddress()
  +processPrice()
  +cancelEmail()
}
class Amenity {
  +float note
  -float email
  #int createdAt
  #double status
  +validateScore()
  +createStatus()
}
Room ..> CheckOut : "*"
Room --o Payment
Payment --|> CheckOut
note right of Payment : Hotel domain
@enduml