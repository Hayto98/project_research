@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Payment {
  #String status
  +String address
  +float amount
  +createDuration()
  +createAmount()
  +getCreatedat()
}
class Room {
  +Date active
  -float createdAt
  +updateQuantity()
  +getCode()
  +calculateEmail()
}
class CheckOut {
  -String duration
  -boolean price
  +double status
  +validatePrice()
  +getActive()
  +sendAmount()
  +sendId()
}
class Amenity {
  #float type
  #Date status
  -Date duration
  +Date code
  -double email
  +setPhone()
  +cancelPhone()
  +sendPhone()
  +setScore()
}
Amenity --* CheckOut
Room ..|> Payment
CheckOut ..|> Amenity
@enduml