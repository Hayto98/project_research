@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Classroom {
  #double updatedAt
  #String quantity
  +createPhone()
  +cancelDescription()
}
class Course {
  +int description
  #Date score
  +double quantity
  -Date createdAt
  -String status
  +createLevel()
  +processStatus()
  +getPhone()
  +sendPhone()
}
interface Exam {
  -boolean status
  -float type
  +cancelLevel()
  +getLevel()
  +cancelName()
}
class Library {
  +int name
  #String note
  #String price
  #long level
  -int duration
  +saveStatus()
}
class Schedule {
  +int createdAt
  -boolean updatedAt
  #double phone
  +double price
  -long address
  +createLevel()
}
class Department {
  #double address
  +Date level
  #long updatedAt
  #long total
  +double code
  +findDuration()
  +findStatus()
  +savePrice()
}
class Student {
  +double active
  -String code
  +long price
  -long note
  +cancelUpdatedat()
  +getAddress()
  +getAmount()
}
Library --> Classroom : "1..*"
Classroom --> Course : "0..1"
Student --* Schedule
Student --* Classroom
note right of Classroom : Education domain
@enduml