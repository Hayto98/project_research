@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Classroom {
  #double updatedAt
  #String quantity
  +processCreatedat()
  +sendAddress()
}
class Course {
  #long quantity
  +String total
  +int description
  +getId()
  +updateTotal()
}
class Exam {
  #double price
  +String quantity
  +createDescription()
  +processScore()
  +updateTotal()
}
interface Library {
  -boolean status
  -float type
  +setId()
  +calculateLevel()
  +savePrice()
}
class Schedule {
  +double amount
  -boolean type
  +savePhone()
  +updateName()
  +getTotal()
  +cancelScore()
}
class Department {
  +String email
  #String price
  +cancelPrice()
}
interface Student {
  +int createdAt
  -boolean updatedAt
  #double phone
  +double price
  -long address
  +findTotal()
}
Student --* Schedule
Schedule --* Library
Schedule --o Course
Classroom --o Schedule
@enduml