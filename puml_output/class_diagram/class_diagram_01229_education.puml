@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
interface Course {
  +boolean updatedAt
  -String address
  -boolean code
  +findPhone()
  +setScore()
  +getCreatedat()
}
abstract class Student {
  #double type
  -boolean score
  +int createdAt
  +boolean id
  +getScore()
}
class Book {
  -long phone
  #Date description
  #double updatedAt
  +processPrice()
  +createStatus()
  +updateScore()
  +deleteAmount()
}
class Teacher {
  +float name
  #int note
  -long phone
  -String createdAt
  +getActive()
  +setId()
  +cancelDescription()
}
interface Schedule {
  -float total
  +float score
  +updateDescription()
  +calculatePrice()
  +getTotal()
}
Course ..> Schedule : "1"
Student ..> Course : "*"
Teacher --|> Course
Student ..> Schedule : "0..1"
@enduml