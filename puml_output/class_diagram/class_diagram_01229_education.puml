@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
interface Course {
  +boolean updatedAt
  -String address
  -boolean code
  +deleteScore()
  +calculateQuantity()
  +processScore()
}
class Student {
  -boolean level
  +int price
  +sendStatus()
}
interface Book {
  +Date createdAt
  #boolean phone
  +calculateEmail()
  +saveLevel()
}
abstract class Teacher {
  +double updatedAt
  -int score
  +float price
  #int amount
  -long address
  +setQuantity()
  +findDuration()
  +findActive()
}
class Schedule {
  #int score
  #String email
  +Date updatedAt
  +int phone
  #String createdAt
  +calculateId()
  +getAmount()
  +deleteActive()
  +cancelDuration()
}
Teacher --o Student
Course --> Teacher : "1..*"
note right of Course : Education domain
@enduml