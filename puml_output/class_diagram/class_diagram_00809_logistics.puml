@startuml
skinparam monochrome true
skinparam shadowing true
class DeliveryNote {
  -long price
  +String status
  #Date type
  +boolean id
  +deleteUpdatedat()
  +sendCreatedat()
  +createDuration()
  +createCreatedat()
}
class Vehicle {
  #float status
  #long address
  +double name
  #int quantity
  +saveName()
  +createPhone()
  +createAddress()
  +processLevel()
}
class Inventory {
  #double email
  +float quantity
  #String score
  +updateNote()
  +findId()
  +saveUpdatedat()
}
class Driver {
  -Date address
  -double code
  +long description
  +setCreatedat()
  +getScore()
}
class FuelLog {
  #long createdAt
  -boolean status
  #double description
  +cancelUpdatedat()
  +sendDuration()
  +updateId()
  +cancelAddress()
}
class Package {
  -String note
  -long description
  #boolean address
  -float amount
  -float id
  +cancelTotal()
  +deleteAddress()
}
FuelLog ..> Driver : "1"
DeliveryNote ..|> Package
Package ..> Driver : "*"
note right of DeliveryNote : Logistics domain
@enduml