@startuml
skinparam monochrome true
skinparam shadowing true
class DeliveryNote {
  -long price
  +String status
  #Date type
  +boolean id
  +updateType()
  +deleteAddress()
  +sendAmount()
  +updateDescription()
}
class Vehicle {
  -boolean createdAt
  +long amount
  #float quantity
  #long status
  +createName()
  +createTotal()
}
class Inventory {
  -boolean name
  -int email
  -float phone
  -float quantity
  #Date address
  +sendStatus()
  +validateCreatedat()
  +getUpdatedat()
  +setActive()
}
class Driver {
  -int createdAt
  -String note
  +long id
  #long updatedAt
  +calculateAddress()
  +calculatePhone()
  +findTotal()
  +saveAddress()
}
class FuelLog {
  #int id
  +String score
  +boolean amount
  +updateLevel()
  +saveActive()
  +saveType()
}
interface Package {
  #float price
  -String updatedAt
  #float active
  -double createdAt
  +float id
  +deleteScore()
  +updateActive()
  +saveCode()
}
Inventory --> Package : "1..*"
Driver --> Vehicle : "*"
@enduml