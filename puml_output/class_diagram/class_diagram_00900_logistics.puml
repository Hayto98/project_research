@startuml
skinparam monochrome true
skinparam shadowing true
class Inventory {
  +int name
  -int level
  +boolean email
  #double duration
  +long code
  +getQuantity()
  +processTotal()
  +updateActive()
}
class Shipment {
  #String email
  #long amount
  +long name
  +getScore()
}
class Driver {
  -int id
  #Date description
  #float amount
  +processName()
  +sendNote()
  +deleteEmail()
  +cancelScore()
}
class Package {
  +Date type
  +long name
  +long note
  #long code
  +validateEmail()
}
class Tracking {
  -double address
  +String quantity
  +getEmail()
}
interface Vehicle {
  -boolean total
  -int name
  +int duration
  -String active
  +int price
  +sendId()
}
Driver ..|> Inventory
Vehicle --* Inventory
@enduml