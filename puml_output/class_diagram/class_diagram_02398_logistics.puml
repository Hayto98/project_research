@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
abstract class Depot {
  -int code
  -float score
  +getLevel()
  +deleteCreatedat()
  +processCode()
}
class Inventory {
  -float email
  #Date level
  -double createdAt
  +getNote()
  +findUpdatedat()
}
class Tracking {
  #Date updatedAt
  -int note
  #long score
  -boolean name
  +deleteStatus()
  +getScore()
}
class Vehicle {
  #boolean id
  +String price
  +getId()
  +deletePhone()
  +createEmail()
}
class Customer {
  -long updatedAt
  -String price
  -long phone
  -double amount
  #long level
  +processUpdatedat()
  +findEmail()
  +findId()
  +getDescription()
}
Tracking --* Inventory
Depot --o Vehicle
Tracking --> Vehicle : "0..1"
Customer --|> Depot
@enduml