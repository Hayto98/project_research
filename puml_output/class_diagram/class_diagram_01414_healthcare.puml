@startuml
skinparam defaultFontSize 13
abstract class Appointment {
  #double code
  #long amount
  +String id
  +createCreatedat()
}
class Patient {
  #Date code
  -Date email
  +Date duration
  -float createdAt
  -Date price
  +validateAddress()
}
abstract class LabTest {
  +boolean type
  -int address
  #long duration
  +getQuantity()
}
abstract class Ward {
  #String score
  +boolean phone
  +Date id
  +updateId()
  +deleteName()
  +setTotal()
  +calculateCode()
}
LabTest ..|> Ward
Patient --|> LabTest
note right of Appointment : Healthcare domain
@enduml