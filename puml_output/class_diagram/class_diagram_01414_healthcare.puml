@startuml
skinparam defaultFontSize 13
abstract class Appointment {
  #double code
  #long amount
  +String id
  +calculatePhone()
}
class Patient {
  +double note
  #Date code
  -Date email
  +Date level
  +saveLevel()
  +calculateAmount()
  +calculateUpdatedat()
  +findType()
}
interface LabTest {
  -float phone
  #int address
  +calculateCreatedat()
  +findName()
  +validateUpdatedat()
  +validateQuantity()
}
interface Ward {
  -Date createdAt
  -float score
  +boolean phone
  -Date code
  +Date id
  +calculateLevel()
}
Patient --> LabTest : "*"
Patient ..|> Appointment
@enduml