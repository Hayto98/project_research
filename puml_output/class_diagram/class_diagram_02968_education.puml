@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Attendance {
  #int description
  -float type
  -String createdAt
  -boolean code
  +validateTotal()
  +setAmount()
}
class Library {
  -String active
  #long type
  +int total
  +validateQuantity()
}
class Student {
  -int createdAt
  +long active
  -String duration
  #String address
  -float type
  +sendUpdatedat()
}
class Grade {
  +String id
  -Date code
  -float updatedAt
  #Date email
  +getStatus()
  +saveCode()
  +deletePrice()
}
class Book {
  -float note
  -Date quantity
  -float updatedAt
  +boolean phone
  +String amount
  +sendType()
  +setAmount()
  +saveQuantity()
  +calculateTotal()
}
abstract class Assignment {
  +double address
  #float type
  +String amount
  #String total
  #boolean updatedAt
  +deleteAmount()
  +cancelDuration()
}
class Schedule {
  -Date score
  #double phone
  +processCode()
}
Library --|> Assignment
Assignment --|> Book
note right of Attendance : Education domain
@enduml