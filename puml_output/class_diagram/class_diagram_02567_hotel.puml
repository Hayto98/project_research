@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class CheckIn {
  -double score
  +Date duration
  +float total
  +processUpdatedat()
  +findNote()
  +updateAddress()
  +cancelPrice()
}
abstract class Amenity {
  #long active
  #boolean quantity
  +boolean description
  +boolean code
  +processName()
  +cancelCode()
}
interface Service {
  -boolean level
  -String active
  +deleteEmail()
  +validateCreatedat()
  +createNote()
  +getType()
}
class Guest {
  #long phone
  #float price
  +validateId()
  +cancelEmail()
  +findScore()
}
class Booking {
  +float phone
  #boolean quantity
  +deleteStatus()
  +cancelLevel()
  +updateTotal()
}
abstract class Payment {
  #boolean address
  -String level
  -long description
  +boolean total
  +createScore()
  +findType()
  +findCode()
}
class Staff {
  +boolean updatedAt
  +String description
  +processTotal()
}
Payment --o Staff
Payment --|> CheckIn
Amenity --* Payment
Service --o Booking
@enduml