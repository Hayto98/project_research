@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Account {
  -boolean id
  +boolean createdAt
  -Date active
  -int level
  -int score
  +findNote()
  +createScore()
}
abstract class Branch {
  +String name
  -double type
  -double status
  +float total
  -boolean amount
  +validateActive()
  +findId()
  +sendQuantity()
}
class Statement {
  #String active
  #boolean score
  +setDuration()
  +updateActive()
}
class Customer {
  +Date note
  -long score
  +String id
  +long name
  +saveTotal()
  +cancelStatus()
  +cancelCreatedat()
}
interface Interest {
  +boolean email
  +double createdAt
  -double description
  -String name
  +processName()
  +saveDuration()
  +getDuration()
}
class Transfer {
  -long type
  #boolean amount
  #String code
  -String createdAt
  +validateTotal()
  +getNote()
  +saveNote()
  +processPhone()
}
Customer --o Account
Customer --> Branch : "*"
@enduml