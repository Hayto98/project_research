@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Account {
  -boolean id
  +boolean createdAt
  -Date active
  -int level
  -int score
  +setUpdatedat()
  +processNote()
}
class Branch {
  -double status
  -double total
  +float amount
  -boolean score
  -boolean code
  +sendAmount()
  +setActive()
}
interface Statement {
  +String active
  +long level
  +sendId()
  +getCode()
  +savePrice()
  +validateCreatedat()
}
class Customer {
  -Date email
  #boolean quantity
  -long code
  +saveDescription()
  +getCode()
}
interface Interest {
  -double total
  +long duration
  +cancelEmail()
}
class Transfer {
  #boolean amount
  #String code
  -String createdAt
  #boolean email
  #float active
  +findQuantity()
  +updateStatus()
  +calculateStatus()
  +calculateTotal()
}
Interest --o Customer
Statement ..> Interest : "*"
Statement ..> Customer : "1..*"
note right of Account : Banking domain
@enduml