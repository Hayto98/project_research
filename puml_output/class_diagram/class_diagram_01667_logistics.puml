@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Depot {
  +boolean id
  #float type
  +findAddress()
}
class Vehicle {
  #Date name
  #Date type
  -double level
  +validateEmail()
  +processScore()
  +setDuration()
}
class Warehouse {
  +String duration
  +String description
  #int quantity
  +createDescription()
}
interface Driver {
  +String note
  +double duration
  +saveId()
  +createAddress()
  +calculateActive()
}
class Customer {
  -long createdAt
  +int description
  -double total
  -float duration
  +updateUpdatedat()
}
class DeliveryNote {
  -boolean amount
  +int code
  #float createdAt
  +boolean score
  +processStatus()
}
DeliveryNote --o Customer
DeliveryNote --> Depot : "1"
Depot ..> DeliveryNote : "0..1"
note right of Depot : Logistics domain
@enduml