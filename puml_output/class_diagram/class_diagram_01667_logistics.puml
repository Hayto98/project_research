@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Depot {
  +boolean id
  #float type
  +setCreatedat()
}
class Vehicle {
  -Date amount
  #boolean name
  #long type
  +getDuration()
  +cancelId()
  +findCreatedat()
  +cancelCode()
}
interface Warehouse {
  +Date duration
  #int phone
  +createAddress()
  +setStatus()
  +saveId()
}
class Driver {
  #String id
  -float quantity
  -String description
  +findAddress()
}
abstract class Customer {
  #float id
  #boolean email
  +long address
  +int total
  +createType()
  +updateDescription()
  +cancelQuantity()
  +createActive()
}
class DeliveryNote {
  #String phone
  +int price
  +float level
  +deleteScore()
  +setPrice()
  +getLevel()
}
DeliveryNote --* Vehicle
Customer ..|> Vehicle
@enduml