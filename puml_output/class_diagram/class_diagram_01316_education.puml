@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Library {
  -boolean updatedAt
  -String createdAt
  +boolean name
  +String duration
  +long active
  +deleteDescription()
  +deleteDescription()
  +sendCreatedat()
}
interface Attendance {
  +float code
  +float status
  +deleteTotal()
}
class Schedule {
  #Date createdAt
  #double id
  +deleteEmail()
}
abstract class Grade {
  #float type
  +boolean quantity
  -String level
  +double duration
  -String amount
  +createDuration()
}
abstract class Exam {
  +float id
  -String duration
  +String description
  +calculateTotal()
  +findTotal()
  +setAmount()
  +validatePrice()
}
Library ..> Exam : "*"
Attendance ..> Library : "1..*"
Grade --|> Attendance
note right of Library : Education domain
@enduml