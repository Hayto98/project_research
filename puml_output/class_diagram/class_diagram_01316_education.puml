@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Library {
  -boolean updatedAt
  -String createdAt
  +boolean name
  +String duration
  +long active
  +createCreatedat()
  +validateCreatedat()
  +validateQuantity()
}
class Attendance {
  +String active
  +float name
  +int code
  +findAddress()
  +getType()
  +getTotal()
  +setName()
}
interface Schedule {
  -long status
  -boolean description
  -int email
  #float type
  +boolean active
  +getLevel()
  +saveNote()
  +saveName()
}
class Grade {
  -Date score
  #double status
  +deleteId()
  +processName()
}
class Exam {
  +String id
  -double note
  #double code
  +validatePhone()
  +sendUpdatedat()
  +sendType()
  +saveAddress()
}
Grade --|> Library
Library --|> Attendance
@enduml