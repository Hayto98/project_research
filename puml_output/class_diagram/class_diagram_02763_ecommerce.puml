@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Supplier {
  +int level
  #int amount
  #Date description
  -int note
  +setStatus()
  +processLevel()
}
class Order {
  #long type
  +float score
  +float updatedAt
  +cancelName()
  +updateAddress()
  +cancelPrice()
  +validateDuration()
}
abstract class Customer {
  #Date price
  +String active
  +int amount
  #long status
  +cancelEmail()
}
class Payment {
  -float code
  -Date total
  +float level
  +sendPhone()
  +setPhone()
}
class Category {
  -double score
  -boolean code
  +long email
  +int level
  +findLevel()
}
class Wishlist {
  -float address
  -double type
  -Date active
  -Date status
  -Date email
  +sendDuration()
  +createPrice()
  +setDescription()
}
class Coupon {
  -long total
  #double phone
  -int description
  +calculateAmount()
}
Payment --* Coupon
Customer --o Order
Customer --|> Coupon
Coupon --> Category : "1"
Category --o Customer
note right of Supplier : Ecommerce domain
@enduml