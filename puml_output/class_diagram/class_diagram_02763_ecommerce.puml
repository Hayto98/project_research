@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Supplier {
  +int level
  #int amount
  #Date description
  -int note
  +setStatus()
  +updateName()
}
abstract class Order {
  #int description
  #long type
  +getPrice()
}
class Customer {
  -float duration
  #boolean name
  #double createdAt
  #float address
  #boolean price
  +saveName()
  +calculateStatus()
  +createUpdatedat()
}
class Payment {
  +int name
  #long duration
  +deleteUpdatedat()
}
class Category {
  -double amount
  -Date code
  +float total
  +createStatus()
  +createAmount()
}
class Wishlist {
  -String email
  -double quantity
  -boolean score
  +long code
  +validateQuantity()
}
class Coupon {
  #String total
  -long address
  -double type
  +deleteType()
  +deleteLevel()
  +findActive()
  +updateAddress()
}
Wishlist --> Customer : "1..*"
Coupon --|> Payment
Order ..> Wishlist : "0..1"
Coupon --o Order
@enduml