@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Report {
  -double updatedAt
  #Date active
  +boolean level
  +cancelQuantity()
  +processPrice()
}
abstract class Comment {
  #String createdAt
  -long active
  +sendAmount()
  +cancelEmail()
  +getScore()
  +calculateName()
}
abstract class Profile {
  +boolean duration
  -String address
  +calculateName()
  +getName()
}
interface Story {
  -Date id
  -float type
  #boolean total
  -String createdAt
  -double status
  +deleteCreatedat()
}
Report ..> Story : "*"
Story --o Profile
Story --* Report
@enduml