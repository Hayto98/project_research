@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Report {
  -double updatedAt
  #Date active
  +boolean level
  +processUpdatedat()
  +calculateName()
}
class Comment {
  -boolean price
  +boolean quantity
  +findPrice()
  +sendActive()
  +setDuration()
}
interface Profile {
  #int name
  -float level
  #double note
  #String duration
  +calculateCreatedat()
  +saveStatus()
  +calculateTotal()
  +findScore()
}
class Story {
  +long note
  -String type
  +saveTotal()
  +calculatePrice()
}
Report ..|> Comment
Story ..> Profile : "0..1"
note right of Report : Social Media domain
@enduml