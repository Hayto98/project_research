@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Teacher {
  +long id
  -long quantity
  -boolean email
  +double level
  +getStatus()
  +processNote()
  +calculateUpdatedat()
  +processCode()
}
class Book {
  -double createdAt
  #boolean updatedAt
  #float phone
  +int price
  +saveActive()
  +calculateEmail()
}
class Exam {
  -boolean createdAt
  +String amount
  #long email
  #float quantity
  +cancelActive()
}
abstract class Classroom {
  #String level
  #Date price
  #float type
  -String active
  +cancelId()
}
Teacher ..> Exam : "1..*"
Exam --> Book : "0..1"
@enduml