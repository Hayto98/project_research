@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Teacher {
  +long id
  -long quantity
  -boolean email
  +double level
  +saveId()
  +updateAddress()
  +updateUpdatedat()
  +validatePrice()
}
class Book {
  +boolean duration
  +long score
  -int active
  +long id
  -long amount
  +setAddress()
  +findId()
}
interface Exam {
  #Date duration
  #float address
  -String price
  +long type
  #String status
  +saveQuantity()
}
class Classroom {
  -int level
  -int amount
  +long description
  -long note
  +boolean phone
  +createNote()
}
Classroom --|> Exam
Book ..> Exam : "0..1"
note right of Teacher : Education domain
@enduml