@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
abstract class FuelLog {
  +float quantity
  +boolean name
  #boolean id
  +getCode()
  +createEmail()
}
abstract class DeliveryNote {
  -long total
  -int status
  +String description
  -boolean quantity
  +deleteCreatedat()
  +processStatus()
  +saveCode()
  +saveNote()
}
abstract class Package {
  #int updatedAt
  #long amount
  #int quantity
  -long type
  #String name
  +processId()
}
interface Warehouse {
  +boolean active
  +boolean description
  +saveCode()
  +cancelPrice()
  +setUpdatedat()
}
class Customer {
  +int active
  +double code
  #double total
  #String updatedAt
  -long duration
  +getCreatedat()
  +deleteAddress()
  +validateLevel()
}
abstract class Manifest {
  #double phone
  -double duration
  +cancelNote()
  +createAmount()
}
interface Driver {
  #long quantity
  +Date type
  +saveDuration()
}
Warehouse --o DeliveryNote
Manifest --o Customer
Customer ..> Warehouse : "1..*"
Customer ..|> Manifest
FuelLog ..|> Driver
@enduml