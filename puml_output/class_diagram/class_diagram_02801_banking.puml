@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Deposit {
  #double description
  -float type
  +boolean score
  #String level
  #String id
  +sendActive()
  +sendCreatedat()
}
interface Customer {
  +float status
  -boolean note
  +sendName()
  +cancelNote()
}
abstract class Statement {
  +long note
  +boolean status
  -String code
  +float score
  +createUpdatedat()
  +validateEmail()
  +saveId()
  +processCode()
}
class Beneficiary {
  -float phone
  #boolean email
  #double active
  +findEmail()
  +createDuration()
}
Beneficiary ..|> Statement
Customer --|> Statement
Beneficiary --o Customer
@enduml