@startuml
skinparam monochrome true
skinparam shadowing true
abstract class Classroom {
  -double id
  +boolean note
  +updateStatus()
  +updateNote()
  +setScore()
  +deleteEmail()
}
abstract class Grade {
  +long address
  +String note
  +Date level
  -long email
  +String name
  +deleteType()
  +getId()
  +cancelPrice()
}
abstract class Exam {
  #float amount
  #boolean code
  #float total
  -double level
  +boolean price
  +createUpdatedat()
  +sendAddress()
}
class Assignment {
  -String email
  #long level
  +Date total
  +float updatedAt
  +updateCode()
  +getStatus()
}
Exam --* Classroom
Assignment --|> Classroom
Classroom ..> Exam : "*"
@enduml