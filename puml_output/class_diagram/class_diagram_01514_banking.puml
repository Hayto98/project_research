@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
abstract class Withdrawal {
  +long note
  +Date id
  +String email
  #long price
  +setPrice()
}
class Branch {
  #boolean phone
  -int note
  #Date price
  -int status
  +setAddress()
  +cancelDuration()
}
abstract class Interest {
  -long type
  -Date code
  +long level
  +boolean score
  #long description
  +validateTotal()
  +sendType()
  +cancelDuration()
}
interface Teller {
  -boolean active
  #int createdAt
  +cancelEmail()
  +validateName()
  +processQuantity()
  +cancelStatus()
}
interface Transaction {
  #String active
  #boolean email
  +Date score
  +findScore()
  +saveCode()
  +setStatus()
}
class Transfer {
  #String phone
  -boolean level
  +deleteCode()
  +createCreatedat()
}
class Statement {
  #Date level
  +boolean amount
  +sendCode()
  +processStatus()
  +saveDescription()
}
Teller --o Interest
Withdrawal --* Interest
Branch --|> Transfer
Transfer ..|> Statement
Interest --|> Withdrawal
Teller --o Transaction
@enduml