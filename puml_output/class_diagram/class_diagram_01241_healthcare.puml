@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Appointment {
  -String status
  +String type
  +findAmount()
}
class Doctor {
  -String note
  +float score
  -boolean active
  -float id
  +boolean code
  +cancelLevel()
  +deleteActive()
  +sendUpdatedat()
}
abstract class Nurse {
  -float quantity
  -float type
  #double updatedAt
  #double phone
  +Date price
  +createName()
  +getName()
  +validatePrice()
}
abstract class Hospital {
  +float updatedAt
  -Date quantity
  -int address
  +cancelScore()
  +deleteName()
  +setCode()
}
class Treatment {
  -String name
  +int amount
  +cancelLevel()
}
class Patient {
  #String phone
  -String price
  +String code
  -boolean address
  #String email
  +sendEmail()
  +saveDescription()
  +getActive()
  +calculateUpdatedat()
}
Doctor --* Patient
Treatment --o Nurse
Nurse ..> Patient : "1"
@enduml