@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Branch {
  #Date total
  +float createdAt
  +setTotal()
  +getStatus()
  +createCode()
}
class Teller {
  -long price
  -String amount
  -int note
  +validateCreatedat()
  +processCreatedat()
  +getDuration()
  +setScore()
}
class Card {
  #String total
  +double price
  +saveType()
}
class Customer {
  -Date id
  #float createdAt
  +double type
  -Date status
  -String updatedAt
  +saveId()
}
class Withdrawal {
  #float amount
  #Date price
  #long note
  -String id
  +boolean status
  +createScore()
  +sendDescription()
  +findPrice()
  +calculateDuration()
}
class Deposit {
  #float duration
  -double total
  +getScore()
  +updateCode()
  +updateActive()
  +getAmount()
}
Card --o Teller
Branch --> Customer : "0..1"
Card --|> Customer
Customer --|> Branch
Card --> Deposit : "*"
note right of Branch : Banking domain
@enduml