@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class Appointment {
  #double price
  #long note
  -String createdAt
  +sendAmount()
}
class Treatment {
  +double name
  #double email
  +cancelAddress()
}
abstract class Patient {
  +float updatedAt
  #float status
  +deleteCreatedat()
  +validateActive()
  +deleteUpdatedat()
}
class Insurance {
  #int email
  -double quantity
  +saveLevel()
  +sendDuration()
  +saveTotal()
}
abstract class Prescription {
  -float email
  #long note
  #double id
  #double score
  +long code
  +updateAmount()
}
class MedicalRecord {
  +String score
  #Date quantity
  #double updatedAt
  #boolean amount
  +calculateCode()
  +createPhone()
}
Patient ..|> Prescription
Appointment --|> Patient
Appointment --> Prescription : "*"
@enduml