@startuml
skinparam defaultFontSize 13
class Attendance {
  +long updatedAt
  #Date code
  -Date createdAt
  +processScore()
  +createPrice()
  +cancelQuantity()
  +setPrice()
}
interface Library {
  +int code
  +double updatedAt
  +double phone
  -long id
  #Date active
  +cancelDuration()
  +validatePrice()
  +getDuration()
  +updateDescription()
}
class Grade {
  #boolean address
  #long name
  +deleteTotal()
  +getLevel()
  +setDuration()
  +calculateName()
}
class Teacher {
  #double note
  -long active
  +updatePhone()
  +calculateDuration()
  +sendName()
  +deleteEmail()
}
class Book {
  #String total
  -Date code
  #long status
  +String id
  +setLevel()
  +cancelTotal()
  +updateUpdatedat()
}
interface Assignment {
  -double id
  -String price
  +calculateId()
}
Teacher --* Assignment
Grade --* Book
Teacher --o Book
Assignment ..> Grade : "*"
Attendance --|> Library
note right of Attendance : Education domain
@enduml