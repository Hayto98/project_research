@startuml
skinparam defaultFontSize 13
class Attendance {
  +long updatedAt
  #Date code
  -Date createdAt
  +sendCode()
  +calculateDuration()
  +updateLevel()
  +calculateCode()
}
interface Library {
  +int status
  -String price
  #Date active
  +int note
  +setType()
  +sendScore()
}
class Grade {
  +boolean note
  +int quantity
  -String total
  -float address
  +Date price
  +findLevel()
  +cancelQuantity()
  +findPhone()
}
abstract class Teacher {
  #boolean level
  -String code
  +findNote()
}
abstract class Book {
  -boolean phone
  #float duration
  +float note
  +long createdAt
  -long level
  +sendLevel()
  +processNote()
  +getType()
  +getQuantity()
}
class Assignment {
  -Date score
  #long code
  +cancelStatus()
  +getCode()
}
Attendance --> Book : "*"
Library --> Assignment : "1"
Attendance --o Teacher
Teacher --|> Assignment
@enduml