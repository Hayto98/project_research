@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
interface Insurance {
  +Date id
  -long updatedAt
  +double type
  +int createdAt
  #double description
  +processUpdatedat()
  +sendUpdatedat()
}
abstract class Treatment {
  #int phone
  -boolean duration
  +int type
  +deletePrice()
  +calculateCode()
  +cancelCode()
  +calculateLevel()
}
class Diagnosis {
  #int quantity
  +boolean note
  #float price
  +double phone
  +deleteActive()
  +findAmount()
  +findName()
  +setPhone()
}
class Patient {
  #double status
  #long level
  +validateType()
  +processScore()
}
class Nurse {
  +long score
  #double status
  #String phone
  +setLevel()
  +cancelStatus()
  +calculateEmail()
  +setType()
}
class Prescription {
  +float code
  -double status
  +long description
  +findType()
  +cancelTotal()
}
Insurance ..> Nurse : "1"
Treatment --o Diagnosis
Insurance ..|> Treatment
@enduml