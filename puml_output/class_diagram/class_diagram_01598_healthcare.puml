@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
interface Insurance {
  +Date id
  -long updatedAt
  +double type
  +int createdAt
  #double description
  +deletePrice()
  +sendLevel()
}
class Treatment {
  #int phone
  +double type
  -double amount
  -float total
  +createQuantity()
  +processPrice()
}
class Diagnosis {
  #boolean description
  #boolean updatedAt
  -double price
  +cancelDuration()
  +findCreatedat()
  +getStatus()
  +saveLevel()
}
interface Patient {
  #float score
  +Date email
  -String amount
  -boolean code
  -Date duration
  +sendNote()
}
class Nurse {
  +int name
  +String description
  +deletePhone()
  +calculateUpdatedat()
}
class Prescription {
  +boolean id
  #boolean active
  +int updatedAt
  +processStatus()
  +saveUpdatedat()
  +deletePrice()
}
Nurse --o Insurance
Treatment ..|> Nurse
note right of Insurance : Healthcare domain
@enduml