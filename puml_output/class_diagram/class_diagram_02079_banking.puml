@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Branch {
  #int address
  #double updatedAt
  +calculateActive()
  +deleteAmount()
}
class Customer {
  +int quantity
  #Date price
  #int total
  #Date id
  +float email
  +findAddress()
}
class Deposit {
  #boolean phone
  +int code
  #boolean updatedAt
  +int duration
  -Date createdAt
  +processName()
  +getActive()
  +calculateDuration()
}
abstract class Transaction {
  +Date active
  #long total
  +float address
  #String price
  #boolean email
  +processNote()
  +createQuantity()
  +processNote()
}
interface Withdrawal {
  #String code
  -long address
  +findAmount()
  +validateType()
  +calculateDescription()
  +saveStatus()
}
Deposit --> Customer : "1"
Deposit --> Transaction : "*"
note right of Branch : Banking domain
@enduml