@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Branch {
  #int address
  #double updatedAt
  +findAmount()
  +sendDescription()
}
interface Customer {
  -long amount
  -Date code
  -String active
  +updateActive()
  +processActive()
  +updateNote()
}
interface Deposit {
  +boolean description
  -float code
  -String address
  +calculateLevel()
  +findName()
}
class Transaction {
  #boolean score
  +int createdAt
  -Date level
  +saveAmount()
  +setAmount()
  +processQuantity()
}
class Withdrawal {
  -Date duration
  -boolean price
  -int total
  #Date active
  -String score
  +cancelName()
}
Withdrawal --o Deposit
Transaction --* Deposit
Transaction --> Withdrawal : "1"
Branch ..> Deposit : "1"
@enduml