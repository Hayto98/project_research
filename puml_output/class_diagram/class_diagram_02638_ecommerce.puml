@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Category {
  -long code
  #String phone
  -long updatedAt
  +findAmount()
}
class Coupon {
  -Date level
  #long description
  #Date amount
  +float email
  -String id
  +setStatus()
  +updateAddress()
}
class Customer {
  #float createdAt
  -String active
  #float quantity
  -double address
  +updateType()
  +findTotal()
  +calculateEmail()
}
abstract class Shipment {
  -Date email
  #String code
  -boolean phone
  +long status
  -Date amount
  +validateAmount()
  +deleteDescription()
}
class Review {
  -long price
  -long total
  +long quantity
  +float active
  +cancelDuration()
  +setAmount()
  +calculateLevel()
  +findEmail()
}
class Invoice {
  -String level
  +int status
  +Date description
  +updateType()
  +calculateTotal()
  +updateActive()
  +processNote()
}
Coupon --|> Customer
Review ..|> Customer
Review --|> Shipment
Shipment ..|> Customer
Shipment --> Invoice : "1"
@enduml