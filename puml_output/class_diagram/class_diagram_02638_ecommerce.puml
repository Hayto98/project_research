@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Category {
  -long code
  #String phone
  -long updatedAt
  +calculateDescription()
}
abstract class Coupon {
  #float amount
  +double level
  #Date email
  +saveDescription()
  +calculateName()
  +updateStatus()
}
class Customer {
  #float createdAt
  -String active
  #float quantity
  -double address
  +deleteName()
  +processPrice()
  +createCode()
}
class Shipment {
  -Date score
  #String amount
  +sendAmount()
  +validateNote()
  +saveCreatedat()
}
class Review {
  -Date level
  -Date active
  -Date duration
  +sendQuantity()
  +createType()
  +validateCode()
}
class Invoice {
  #int note
  #float quantity
  +deleteType()
}
Category ..|> Coupon
Invoice ..|> Shipment
note right of Category : Ecommerce domain
@enduml