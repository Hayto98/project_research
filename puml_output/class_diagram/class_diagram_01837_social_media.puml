@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Post {
  -boolean description
  -int status
  +String type
  +sendDescription()
  +calculatePhone()
}
interface Story {
  #double description
  #int phone
  -long score
  #double note
  +getPrice()
}
class Message {
  -String note
  -int duration
  +sendScore()
}
class User {
  #float active
  #int type
  -float status
  +deleteEmail()
  +validateId()
  +createDescription()
}
interface Album {
  +String code
  +double email
  #long createdAt
  +long level
  #long active
  +createId()
  +deletePhone()
  +cancelUpdatedat()
}
Post --* Album
Post ..> Story : "0..1"
note right of Post : Social Media domain
@enduml