@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Post {
  -boolean description
  -int status
  +String type
  +setAddress()
  +saveQuantity()
}
abstract class Story {
  #double score
  #double email
  #int description
  -long phone
  +saveUpdatedat()
  +getDescription()
  +saveId()
  +findType()
}
class Message {
  -String description
  -int level
  +float id
  #boolean note
  #int active
  +getScore()
  +sendCreatedat()
}
class User {
  -long phone
  +long quantity
  +boolean description
  +getLevel()
  +createNote()
  +sendAddress()
  +updateDescription()
}
class Album {
  #long updatedAt
  +long status
  #long level
  #long note
  +cancelTotal()
  +sendType()
  +saveQuantity()
}
Album --|> Story
Post --* Album
Post ..> Story : "0..1"
@enduml