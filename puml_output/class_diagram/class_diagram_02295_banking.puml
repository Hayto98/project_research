@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Loan {
  #float phone
  #boolean code
  -float updatedAt
  #float note
  +calculateEmail()
  +getAddress()
}
class Transfer {
  -Date price
  +int description
  #boolean address
  +double code
  +createQuantity()
}
class Deposit {
  +float note
  #int price
  +deleteTotal()
}
interface Beneficiary {
  -boolean description
  -int createdAt
  #float type
  #float phone
  +long address
  +getStatus()
  +calculateScore()
  +updateTotal()
}
abstract class Transaction {
  +long price
  #int active
  +double quantity
  +validateEmail()
  +deleteAddress()
  +processScore()
  +sendType()
}
abstract class Branch {
  #int amount
  +double level
  -float phone
  -boolean total
  +boolean createdAt
  +findAddress()
  +deleteTotal()
  +saveCreatedat()
  +findAddress()
}
Transaction ..> Branch : "1..*"
Branch --* Transfer
note right of Loan : Banking domain
@enduml