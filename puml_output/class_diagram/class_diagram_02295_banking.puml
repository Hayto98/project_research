@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Loan {
  #float phone
  #boolean code
  -float updatedAt
  #float note
  +saveType()
  +findAmount()
}
class Transfer {
  -Date address
  -int description
  +validatePrice()
  +processAddress()
  +cancelUpdatedat()
}
interface Deposit {
  +float total
  #boolean status
  +validateLevel()
  +processLevel()
}
class Beneficiary {
  #double quantity
  +float updatedAt
  #int name
  +int note
  +updatePhone()
  +sendLevel()
  +updateNote()
  +sendCode()
}
class Transaction {
  -double duration
  #double type
  +Date phone
  +calculateScore()
}
class Branch {
  #int status
  -double total
  +sendScore()
  +getScore()
}
Transfer ..> Deposit : "0..1"
Transfer --> Beneficiary : "*"
Deposit ..|> Branch
Deposit --> Beneficiary : "*"
@enduml