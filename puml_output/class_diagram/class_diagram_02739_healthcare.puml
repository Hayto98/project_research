@startuml
skinparam defaultFontSize 13
abstract class Nurse {
  #boolean phone
  #Date quantity
  +updateUpdatedat()
}
interface Billing {
  +float total
  +Date type
  #int email
  -double id
  #float score
  +updateId()
}
class Appointment {
  #float duration
  -boolean createdAt
  #double quantity
  -String name
  +createType()
  +setCreatedat()
  +cancelTotal()
}
class Prescription {
  #Date duration
  -int address
  -double amount
  +deleteAmount()
  +updateName()
}
Appointment --|> Nurse
Billing --o Appointment
@enduml