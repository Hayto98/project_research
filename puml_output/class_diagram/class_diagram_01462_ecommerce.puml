@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Wishlist {
  #int phone
  #float note
  -double createdAt
  -int address
  +setStatus()
  +validateCreatedat()
}
abstract class Order {
  #Date price
  -int description
  +String quantity
  -float active
  #int duration
  +findPrice()
  +getLevel()
  +updateStatus()
}
class Cart {
  #int email
  -double type
  +int id
  +cancelAmount()
}
class Customer {
  +String quantity
  #boolean code
  +long type
  #String amount
  +updateAmount()
  +updateType()
  +findStatus()
}
Customer --|> Wishlist
Order --o Wishlist
note right of Wishlist : Ecommerce domain
@enduml