@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Wishlist {
  #int phone
  #float note
  -double createdAt
  -int address
  +updateCreatedat()
  +createPhone()
}
class Order {
  +long createdAt
  #boolean note
  -boolean price
  #double score
  +processDuration()
  +createPhone()
}
abstract class Cart {
  #int quantity
  +String price
  +Date id
  +findActive()
  +setPhone()
  +deleteStatus()
}
class Customer {
  +String note
  #float price
  #Date code
  +validateLevel()
  +cancelScore()
}
Cart ..> Order : "1"
Customer --|> Wishlist
@enduml