@startuml
skinparam monochrome true
skinparam defaultFontSize 11
interface Profile {
  +float duration
  +int description
  #boolean amount
  -float level
  +validateTotal()
  +setType()
  +getUpdatedat()
}
class Message {
  #int updatedAt
  #double total
  +String quantity
  +createScore()
  +sendLevel()
  +sendPhone()
}
class Story {
  +float type
  -Date level
  +cancelActive()
}
class User {
  #Date email
  #String updatedAt
  -double type
  +long createdAt
  +validateActive()
  +cancelScore()
}
class Like {
  +long createdAt
  -double description
  +setAddress()
  +deleteUpdatedat()
  +setPrice()
  +calculateId()
}
abstract class Comment {
  #long phone
  #boolean code
  +getId()
}
class Notification {
  -Date duration
  -boolean updatedAt
  -long code
  #double name
  +findTotal()
  +setId()
  +createStatus()
  +sendActive()
}
Comment ..> Like : "1"
User --|> Notification
Profile --o Like
Profile --o Notification
Like --* User
@enduml