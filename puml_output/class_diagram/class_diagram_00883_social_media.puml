@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Like {
  -String updatedAt
  -long type
  +double phone
  +updateDuration()
  +createId()
}
class Story {
  +String amount
  #Date type
  #long quantity
  +long note
  #float price
  +getActive()
  +getAddress()
}
abstract class Album {
  #Date phone
  #Date updatedAt
  -String quantity
  +long address
  +setPrice()
  +saveLevel()
}
class Post {
  #Date id
  -double type
  -float score
  #Date updatedAt
  #double total
  +cancelNote()
  +deleteDuration()
  +cancelDuration()
  +validateLevel()
}
interface Report {
  +int duration
  -String amount
  #String id
  -float code
  -float score
  +validateAmount()
  +cancelId()
}
Like --o Report
Post --|> Story
Post --* Like
note right of Like : Social Media domain
@enduml