@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
abstract class Patient {
  +boolean duration
  -boolean price
  #long active
  +updateUpdatedat()
  +calculateType()
  +saveLevel()
}
class Treatment {
  #float email
  #boolean name
