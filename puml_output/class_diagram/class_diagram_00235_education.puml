@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
abstract class Library {
  #int id
  -long description
  #Date address
  -String status
  +int type
  +calculateCode()
  +sendId()
  +validateScore()
}
interface Course {
  +long updatedAt
  +double description
  +int duration
  #double active
  -boolean quantity
  +deleteQuantity()
  +cancelId()
}
abstract class Schedule {
  -double email
  #Date address
  +int updatedAt
  -long type
  +validateDuration()
}
abstract class Enrollment {
  +boolean score
  #long type
  -String email
  +int name
  +processStatus()
}
interface Exam {
  #float updatedAt
  +float address
  -String note
  #String level
  -float status
  +validateLevel()
  +findLevel()
  +saveCreatedat()
}
interface Book {
  #long status
  -double createdAt
  +setScore()
  +getUpdatedat()
  +deleteDescription()
}
Course ..|> Book
Schedule --> Library : "1"
note right of Library : Education domain
@enduml