@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
abstract class Library {
  #int id
  -long description
  #Date address
  -String status
  +int type
  +saveLevel()
  +cancelCreatedat()
  +createId()
}
class Course {
  #Date phone
  #double score
  +deleteId()
  +findPhone()
}
interface Schedule {
  -String active
  -int quantity
  +boolean amount
  +cancelId()
  +createStatus()
  +cancelNote()
  +saveAddress()
}
class Enrollment {
  #long price
  -float address
  +getId()
  +createPrice()
}
abstract class Exam {
  -String description
  -boolean total
  +updateLevel()
  +createStatus()
  +getQuantity()
  +setId()
}
abstract class Book {
  -String name
  +int amount
  +double score
  +boolean address
  +sendNote()
  +validateScore()
  +sendCode()
  +sendUpdatedat()
}
Book ..> Library : "0..1"
Schedule ..> Library : "1"
Schedule --* Book
Book ..> Exam : "0..1"
@enduml