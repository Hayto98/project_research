@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Post {
  +String code
  #double phone
  +int status
  +sendDuration()
  +cancelStatus()
}
class Comment {
  -String email
  -float status
  -double score
  -Date name
  +sendPrice()
  +processUpdatedat()
}
class Story {
  +int note
  +double level
  +String quantity
  +boolean description
  +sendCode()
}
class Group {
  +Date price
  #String id
  +updateTotal()
  +setAmount()
  +validateQuantity()
}
Story --|> Group
Post ..|> Comment
note right of Post : Social Media domain
@enduml