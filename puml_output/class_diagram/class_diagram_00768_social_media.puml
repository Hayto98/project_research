@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Post {
  +String code
  #double phone
  +int status
  +setAddress()
  +processPhone()
}
interface Comment {
  -String name
  #String quantity
  +setName()
  +saveAmount()
  +saveLevel()
}
abstract class Story {
  -int total
  +long active
  -boolean description
  #long level
  #Date price
  +calculateId()
  +findPhone()
}
class Group {
  #Date id
  +Date status
  +boolean description
  +double active
  +int level
  +deleteName()
}
Group ..|> Post
Story ..|> Comment
@enduml