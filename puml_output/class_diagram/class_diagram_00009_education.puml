@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Book {
  #String total
  +float type
  -long amount
  +float id
  -long level
  +sendPhone()
  +validateCreatedat()
  +saveTotal()
  +processEmail()
}
abstract class Department {
  -boolean active
  +Date price
  +cancelName()
}
class Exam {
  #int status
  -boolean name
  +float price
  +updateTotal()
  +getActive()
  +setName()
}
class Library {
  -float active
  #String id
  -String type
  +saveAmount()
  +setDuration()
  +sendEmail()
}
class Teacher {
  -int status
  +int description
  -int name
  -double createdAt
  +setStatus()
  +calculateLevel()
  +updateLevel()
}
class Enrollment {
  +long amount
  -String code
  +validateAddress()
}
Library --> Department : "0..1"
Department --o Teacher
Library ..|> Teacher
@enduml