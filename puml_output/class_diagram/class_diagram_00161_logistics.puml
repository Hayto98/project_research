@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Driver {
  #int name
  #String total
  #float phone
  +saveDuration()
  +calculateNote()
  +sendQuantity()
}
class Depot {
  +String note
  #boolean status
  +cancelDuration()
  +cancelPrice()
  +setUpdatedat()
}
abstract class Warehouse {
  +float email
  +boolean id
  +calculateDuration()
  +sendType()
}
class FuelLog {
  -long type
  +float amount
  +updateStatus()
  +cancelScore()
}
class Package {
  #float status
  +Date address
  +String price
  +float note
  +saveQuantity()
  +getAmount()
}
Depot ..|> Warehouse
Warehouse --> Driver : "0..1"
Driver --> Warehouse : "1..*"
@enduml