@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Driver {
  #int name
  #String total
  #float phone
  +cancelCreatedat()
  +sendQuantity()
  +setNote()
}
class Depot {
  -Date status
  #String active
  +saveId()
  +findEmail()
  +getCreatedat()
  +updateDuration()
}
interface Warehouse {
  -float score
  +long description
  -String status
  +updateName()
  +validateStatus()
}
class FuelLog {
  #int note
  +Date id
  -Date amount
  +Date level
  #long score
  +createName()
  +cancelCreatedat()
}
class Package {
  #Date level
  +Date email
  #int createdAt
  #boolean price
  +sendType()
}
Package --o Depot
FuelLog --* Depot
Warehouse --* Depot
note right of Driver : Logistics domain
@enduml