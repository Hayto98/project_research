@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
abstract class Profile {
  #Date address
  -long score
  +String quantity
  -int duration
  -int price
  +deleteQuantity()
  +calculateTotal()
  +saveNote()
  +saveStatus()
}
class Report {
  -double amount
  +boolean status
  +findName()
  +getAmount()
}
class Message {
  #double duration
  +float phone
  -long amount
  +double id
  +updateAddress()
  +deletePrice()
  +getId()
}
class User {
  #double price
  +int description
  +saveNote()
  +cancelName()
  +findActive()
  +processNote()
}
interface Hashtag {
  #double active
  +String name
  +validateScore()
  +validateCreatedat()
  +createPrice()
  +sendActive()
}
Profile --|> Report
Hashtag ..|> Profile
Report ..> Hashtag : "*"
Message --o Hashtag
note right of Profile : Social Media domain
@enduml