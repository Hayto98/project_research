@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
abstract class Profile {
  #Date address
  -long score
  +String quantity
  -int duration
  -int price
  +deleteScore()
  +cancelAddress()
  +saveCode()
  +getPhone()
}
abstract class Report {
  +Date quantity
  +String active
  +deleteActive()
  +processPrice()
  +sendActive()
}
interface Message {
  -Date name
  -boolean id
  -int amount
  +getCode()
}
abstract class User {
  -long email
  +float duration
  -int description
  +deleteNote()
  +updateActive()
  +getAmount()
  +savePhone()
}
class Hashtag {
  -Date description
  -boolean score
  #Date type
  +Date name
  #float updatedAt
  +deleteDuration()
  +updateNote()
  +createUpdatedat()
  +setDuration()
}
Hashtag ..> Profile : "*"
Report ..> Profile : "*"
@enduml