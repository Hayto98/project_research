@startuml
skinparam defaultFontSize 13
interface Tracking {
  +float quantity
  -Date name
  +sendEmail()
  +deleteTotal()
}
class Warehouse {
  -float active
  -String level
  +int id
  +float createdAt
  +updateCode()
}
class Package {
  #boolean email
  -String level
  -long description
  +double type
  +deleteAddress()
  +processPrice()
}
class Route {
  -int total
  #boolean code
  +createPrice()
  +calculateNote()
  +createCode()
}
interface Shipment {
  -long id
  #double total
  -long duration
  +deleteType()
  +findPrice()
  +findUpdatedat()
  +findActive()
}
class FuelLog {
  #long phone
  +double type
  +sendNote()
  +saveCode()
  +deleteEmail()
}
interface DeliveryNote {
  #Date price
  -long code
  +saveType()
  +updatePhone()
  +updateActive()
}
Tracking --|> Package
Package --* Tracking
Package ..> Shipment : "0..1"
Warehouse --o DeliveryNote
@enduml