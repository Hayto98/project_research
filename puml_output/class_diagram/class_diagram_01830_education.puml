@startuml
skinparam defaultFontSize 11
class Course {
  -double score
  #String status
  +float level
  -boolean amount
  #double type
  +calculateQuantity()
}
class Assignment {
  #double createdAt
  +boolean phone
  -Date duration
  +Date name
  +processUpdatedat()
  +deleteTotal()
  +saveType()
  +updateType()
}
class Book {
  #boolean code
  -long score
  +double amount
  +double level
  +saveQuantity()
  +deletePrice()
  +sendEmail()
  +sendDuration()
}
class Library {
  #int duration
  #int updatedAt
  +sendDescription()
  +createCode()
  +deleteEmail()
  +cancelPrice()
}
class Schedule {
  #double score
  #double duration
  #int total
  #long price
  +cancelId()
}
Library ..|> Assignment
Course ..|> Library
Library --> Schedule : "1"
Book --> Schedule : "0..1"
@enduml