@startuml
skinparam defaultFontSize 11
class Course {
  -double score
  #String status
  +float level
  -boolean amount
  #double type
  +calculateQuantity()
}
interface Assignment {
  #double createdAt
  +boolean phone
  -Date duration
  +Date name
  +deleteAmount()
  +getScore()
  +createCode()
  +sendAmount()
}
class Book {
  -double address
  +double description
  +Date price
  #String updatedAt
  +cancelUpdatedat()
}
class Library {
  -float note
  #boolean amount
  -double name
  +sendNote()
  +sendDescription()
  +sendAddress()
  +findStatus()
}
class Schedule {
  #double createdAt
  -boolean description
  #String code
  -long type
  #float duration
  +processStatus()
  +processDescription()
}
Assignment --* Course
Library --o Book
note right of Course : Education domain
@enduml