@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Author {
  +float name
  +Date phone
  #Date id
  +boolean total
  +setNote()
}
class Loan {
  #int description
  #boolean email
  +getEmail()
  +updateName()
  +getQuantity()
}
class Fine {
  -double type
  #String total
  -int active
  +String phone
  #float duration
  +deleteLevel()
  +createTotal()
  +createLevel()
  +setTotal()
}
class Member {
  -boolean phone
  #double total
  -int description
  -String status
  +long quantity
  +sendActive()
  +processQuantity()
  +validateLevel()
  +findAmount()
}
Loan --o Member
Member --o Author
@enduml