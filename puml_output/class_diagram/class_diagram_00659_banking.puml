@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
abstract class Interest {
  #long id
  +long createdAt
  +float email
  +cancelActive()
  +savePrice()
  +deletePrice()
  +getQuantity()
}
class Deposit {
  +String amount
  -boolean price
  +updateType()
  +sendCreatedat()
  +calculateLevel()
}
class Transfer {
  -double email
  -double name
  -float status
  +boolean phone
  #double price
  +sendStatus()
  +calculateCode()
}
class Loan {
  #double email
  #boolean score
  #double code
  +Date active
  +calculateDescription()
  +processAddress()
  +getCode()
}
class Card {
  +boolean duration
  #boolean level
  #String name
  -double email
  +deleteCreatedat()
}
Card --o Transfer
Interest ..|> Loan
Interest --|> Deposit
@enduml