@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Room {
  #boolean description
  -boolean email
  #float active
  -boolean address
  +createQuantity()
  +processDuration()
}
class CheckIn {
  #long active
  +double type
  +String note
  +sendAmount()
}
class Staff {
  -int amount
  #long score
  +String total
  +validateScore()
  +calculateStatus()
}
interface Invoice {
  #float level
  #float total
  +createAmount()
  +setStatus()
  +updateStatus()
}
class Housekeeping {
  #long createdAt
  #float score
  -int price
  +getStatus()
  +cancelNote()
  +findActive()
}
interface Restaurant {
  #boolean email
  +long active
  +long level
  #float description
  #String amount
  +calculateType()
  +cancelStatus()
  +createCode()
  +saveCode()
}
class Booking {
  +int note
  #String status
  -double active
  +int amount
  -String description
  +cancelNote()
  +sendId()
  +createUpdatedat()
  +sendType()
}
Housekeeping --> Invoice : "*"
CheckIn ..|> Booking
Invoice --> CheckIn : "1..*"
@enduml