@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Room {
  #boolean description
  -boolean email
  #float active
  -boolean address
  +createUpdatedat()
  +getUpdatedat()
}
interface CheckIn {
  +String note
  #float quantity
  +float status
  #int total
  +float name
  +createUpdatedat()
  +cancelEmail()
  +setName()
  +updateAddress()
}
interface Staff {
  #float level
  #float total
  +validateStatus()
  +updateAmount()
  +updateCreatedat()
}
interface Invoice {
  -boolean phone
  -Date price
  -float updatedAt
  #boolean duration
  +int createdAt
  +createName()
}
class Housekeeping {
  +int duration
  -int price
  +processStatus()
  +sendAmount()
  +deleteName()
  +updateName()
}
abstract class Restaurant {
  +int description
  #int amount
  #float note
  -boolean code
  -int type
  +deleteNote()
  +updateActive()
}
class Booking {
  -double description
  +float address
  +double phone
  #Date type
  +calculateCode()
  +updateAddress()
  +findCreatedat()
  +calculateCode()
}
CheckIn --o Restaurant
Housekeeping --|> Booking
Housekeeping --|> CheckIn
note right of Room : Hotel domain
@enduml