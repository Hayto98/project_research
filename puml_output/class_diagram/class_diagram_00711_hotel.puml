@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
abstract class Guest {
  #Date active
  +boolean total
  -float amount
  +processActive()
  +saveType()
  +setType()
  +sendLevel()
}
class Reservation {
  +Date quantity
  +long description
  +getEmail()
  +sendScore()
  +calculateQuantity()
  +calculateAmount()
}
abstract class Room {
  +float note
  #boolean amount
  #long email
  +double createdAt
  +deleteCode()
  +createType()
  +getAmount()
}
abstract class Restaurant {
  -int email
  +String phone
  +String note
  +saveId()
  +cancelActive()
}
Restaurant --|> Guest
Room --|> Guest
note right of Guest : Hotel domain
@enduml