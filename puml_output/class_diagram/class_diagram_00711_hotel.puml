@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
abstract class Guest {
  #Date active
  +boolean total
  -float amount
  +setActive()
  +sendCode()
  +getScore()
  +createEmail()
}
abstract class Reservation {
  #Date type
  #long active
  +cancelAddress()
}
class Room {
  -String name
  #long phone
  +setTotal()
  +sendStatus()
  +getAddress()
  +processUpdatedat()
}
abstract class Restaurant {
  +float note
  #boolean amount
  #long email
  +double createdAt
  +validateCode()
  +validatePhone()
  +deleteCreatedat()
}
Guest --o Restaurant
Reservation --* Room
Room --o Reservation
@enduml