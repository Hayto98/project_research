@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Order {
  #float score
  -int duration
  +Date email
  +saveId()
  +calculateQuantity()
  +saveQuantity()
  +updateCreatedat()
}
class Wishlist {
  +long address
  +double price
  -long note
  +float updatedAt
  +updateNote()
  +updateDuration()
}
interface Cart {
  #int level
  -Date createdAt
  -float code
  +saveScore()
  +validateDescription()
}
interface Warehouse {
  -double price
  -float amount
  -int total
  +long name
  +deleteId()
}
class Customer {
  +float quantity
  -long description
  +updateCreatedat()
  +saveEmail()
}
class Coupon {
  #float duration
  +double type
  +calculateStatus()
}
class Review {
  +boolean id
  +long email
  #String phone
  +updateScore()
}
Customer --* Review
Coupon ..|> Cart
@enduml