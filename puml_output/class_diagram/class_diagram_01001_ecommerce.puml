@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Order {
  #float score
  -int duration
  +Date email
  +getTotal()
  +deleteUpdatedat()
  +createAddress()
  +calculateNote()
}
class Wishlist {
  -long quantity
  +float createdAt
  +boolean total
  +cancelUpdatedat()
}
interface Cart {
  #long code
  +long amount
  #long note
  +deleteTotal()
  +sendName()
  +calculateNote()
  +calculateAddress()
}
class Warehouse {
  #float address
  +Date status
  +saveQuantity()
}
interface Customer {
  +float id
  +long note
  +boolean email
  +saveUpdatedat()
  +processName()
  +findStatus()
  +saveDescription()
}
class Coupon {
  -Date duration
  +String phone
  #float amount
  +boolean description
  +saveAddress()
  +updateUpdatedat()
  +getCode()
}
class Review {
  #long phone
  -boolean active
  #Date level
  -Date email
  -float updatedAt
  +processCreatedat()
  +processType()
  +calculateDuration()
  +createPrice()
}
Warehouse --* Coupon
Customer ..> Order : "*"
note right of Order : Ecommerce domain
@enduml