@startuml
skinparam monochrome true
skinparam ArrowColor #555555
interface Notification {
  +String quantity
  #double name
  +updateQuantity()
  +findEmail()
}
class Post {
  +double duration
  #Date phone
  -float name
  #long total
  +calculateType()
  +createQuantity()
}
interface User {
  -long name
  -long email
  +double amount
  #float total
  +deletePrice()
  +updatePrice()
  +saveDescription()
}
class Story {
  #int phone
  +long updatedAt
  #boolean status
  #float total
  +setQuantity()
  +createId()
  +validateActive()
  +cancelTotal()
}
User --|> Story
Notification --> Story : "1..*"
Notification ..> User : "1"
note right of Notification : Social Media domain
@enduml