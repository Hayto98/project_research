@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
abstract class LabTest {
  #float price
  +String email
  +double note
  +calculateScore()
  +deleteDuration()
  +deleteName()
}
class Doctor {
  +boolean quantity
  #boolean updatedAt
  #float description
  +sendUpdatedat()
  +deletePhone()
  +setCode()
  +findAmount()
}
class Appointment {
  +String quantity
  -String level
  +String price
  +deleteType()
}
class Treatment {
  #Date duration
  +double amount
  +sendTotal()
  +getId()
  +getUpdatedat()
}
Appointment ..|> Treatment
LabTest --> Treatment : "*"
Appointment ..> Doctor : "1..*"
note right of LabTest : Healthcare domain
@enduml