@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
abstract class LabTest {
  #float price
  +String email
  +double note
  +saveCode()
  +saveActive()
  +createNote()
}
class Doctor {
  -float name
  #int quantity
  #float updatedAt
  +deletePhone()
  +cancelTotal()
}
interface Appointment {
  +Date active
  +long updatedAt
  #int description
  -boolean phone
  -String status
  +createAmount()
}
class Treatment {
  +double status
  -Date active
  +Date id
  +createUpdatedat()
  +getActive()
}
Treatment --> Doctor : "*"
LabTest --|> Treatment
@enduml