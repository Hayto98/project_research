@startuml
skinparam monochrome true
skinparam ArrowColor #555555
abstract class Branch {
  -float phone
  -boolean status
  #float total
  +cancelAddress()
  +processStatus()
  +calculateUpdatedat()
  +findNote()
}
class Transaction {
  +long total
  -String level
  +setDuration()
  +createName()
  +updateTotal()
  +validateAddress()
}
abstract class Loan {
  -Date type
  -float name
  +validateScore()
  +saveLevel()
  +deleteStatus()
  +deleteActive()
}
abstract class Account {
  #int createdAt
  #long updatedAt
  #String active
  +processUpdatedat()
  +createScore()
  +cancelEmail()
}
Loan ..|> Transaction
Account ..> Loan : "1..*"
@enduml