@startuml
skinparam monochrome true
skinparam ArrowColor #555555
abstract class Branch {
  -float phone
  -boolean status
  #float total
  +createPhone()
  +saveCode()
  +createId()
  +saveTotal()
}
interface Transaction {
  +boolean phone
  -double price
  +createType()
  +getType()
  +getEmail()
}
abstract class Loan {
  +boolean address
  #int type
  #long total
  #String amount
  -int createdAt
  +setId()
  +sendQuantity()
}
abstract class Account {
  -boolean type
  -double email
  -long total
  +saveLevel()
  +cancelCreatedat()
  +validateScore()
}
Loan --* Branch
Account ..> Loan : "0..1"
Branch --o Account
note right of Branch : Banking domain
@enduml