@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Driver {
  -String createdAt
  #Date note
  +calculateStatus()
  +findId()
  +cancelTotal()
  +updateAddress()
}
class DeliveryNote {
  #Date address
  #boolean status
  -boolean note
  +deleteQuantity()
  +setAmount()
  +processAddress()
  +findEmail()
}
abstract class Depot {
  +String updatedAt
  #int id
  +int score
  -long address
  -Date code
  +sendActive()
  +setName()
  +createPrice()
  +findDescription()
}
class Tracking {
  -String description
  +boolean address
  +updateUpdatedat()
  +deleteDescription()
}
class FuelLog {
  -boolean createdAt
  #String address
  +boolean quantity
  -boolean price
  #long type
  +updateActive()
  +setLevel()
  +deleteQuantity()
  +sendStatus()
}
class Vehicle {
  +long phone
  -int total
  -int address
  +updateCreatedat()
  +deleteAddress()
}
class Customer {
  #double level
  #String duration
  #boolean active
  +float name
  +setAddress()
}
Customer ..> FuelLog : "1"
Tracking ..|> Driver
Customer ..|> Depot
Vehicle --* Customer
DeliveryNote --|> FuelLog
@enduml