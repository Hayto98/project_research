@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Driver {
  -String createdAt
  #Date note
  +findAmount()
  +getCreatedat()
  +deleteAddress()
  +setNote()
}
interface DeliveryNote {
  #int level
  +float note
  #long status
  +int duration
  +Date type
  +setUpdatedat()
  +calculateEmail()
}
class Depot {
  +long duration
  -String id
  +boolean price
  +String createdAt
  #Date code
  +processCreatedat()
  +validateLevel()
}
class Tracking {
  #float type
  #long address
  -String name
  +String score
  +Date price
  +findPhone()
  +cancelTotal()
}
class FuelLog {
  -int address
  #int duration
  +Date createdAt
  +createLevel()
}
interface Vehicle {
  #boolean price
  +float id
  +sendNote()
}
interface Customer {
  +float price
  -int code
  +updateLevel()
  +setDuration()
  +deleteCreatedat()
}
Customer ..> Vehicle : "1"
FuelLog --* Depot
Depot --|> Customer
DeliveryNote --o Vehicle
Tracking --|> Depot
note right of Driver : Logistics domain
@enduml