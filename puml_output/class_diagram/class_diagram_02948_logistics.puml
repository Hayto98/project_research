@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
abstract class Inventory {
  +double note
  #String updatedAt
  +updateDuration()
  +createAddress()
  +cancelId()
  +findDuration()
}
class DeliveryNote {
  +String active
  +Date name
  +deleteCode()
  +validateId()
}
interface Driver {
  -boolean score
  -double updatedAt
  #double status
  +processType()
  +sendNote()
  +saveType()
  +calculateType()
}
class Depot {
  +Date score
  #double createdAt
  +double amount
  +boolean name
  +findCreatedat()
}
Inventory ..> Driver : "*"
Driver --|> Inventory
Depot --* DeliveryNote
@enduml