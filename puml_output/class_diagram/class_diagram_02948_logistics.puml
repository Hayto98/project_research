@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
abstract class Inventory {
  +double note
  #String updatedAt
  +getCode()
  +validateActive()
  +createId()
  +sendName()
}
class DeliveryNote {
  -String createdAt
  #int amount
  +cancelStatus()
  +calculateScore()
}
abstract class Driver {
  +long total
  #boolean level
  +int duration
  #boolean price
  +int updatedAt
  +updateType()
  +updateLevel()
  +sendName()
  +createEmail()
}
class Depot {
  -boolean email
  #boolean code
  #boolean name
  #float price
  -float active
  +calculateStatus()
}
Depot --o Driver
Driver --* Depot
Inventory ..> DeliveryNote : "0..1"
note right of Inventory : Logistics domain
@enduml