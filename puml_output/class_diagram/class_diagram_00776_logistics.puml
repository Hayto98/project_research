@startuml
skinparam monochrome true
class Vehicle {
  -int code
  -float level
  -int quantity
  +boolean price
  +String amount
  +createDescription()
}
class Manifest {
  #boolean score
  +String name
  #Date id
  +saveAddress()
  +findDescription()
  +validateTotal()
}
abstract class Driver {
  +String description
  -long active
  +createAddress()
}
class Shipment {
  +boolean description
  +long phone
  +int active
  +validateDescription()
  +findScore()
}
class Inventory {
  #Date level
  +double code
  +boolean quantity
  +boolean email
  +findPrice()
  +saveType()
  +setCreatedat()
}
Manifest --* Driver
Manifest --* Vehicle
Manifest ..|> Shipment
Vehicle --|> Manifest
note right of Vehicle : Logistics domain
@enduml