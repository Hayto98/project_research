@startuml
skinparam monochrome true
class Vehicle {
  -int code
  -float level
  -int quantity
  +boolean price
  +String amount
  +calculateScore()
}
class Manifest {
  +float createdAt
  #boolean score
  +String name
  +cancelDuration()
  +createTotal()
  +saveCreatedat()
}
class Driver {
  #String total
  +long price
  -String name
  -Date description
  +deleteQuantity()
  +findId()
  +setLevel()
}
class Shipment {
  +int duration
  +long updatedAt
  +float address
  +setId()
  +cancelUpdatedat()
  +setScore()
}
class Inventory {
  #Date quantity
  +double email
  +deleteDescription()
}
Inventory ..> Driver : "*"
Shipment ..|> Vehicle
@enduml