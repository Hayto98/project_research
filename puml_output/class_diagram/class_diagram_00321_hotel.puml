@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Invoice {
  -String code
  +long id
  +double amount
  +validateCode()
}
class Housekeeping {
  +double createdAt
  -int email
  +createScore()
  +saveEmail()
  +processPhone()
}
abstract class Booking {
  #Date status
  +float phone
  +calculatePrice()
  +cancelCreatedat()
}
interface Restaurant {
  #boolean active
  +long status
  -double address
  +updateQuantity()
  +processId()
}
class Room {
  #Date updatedAt
  -Date amount
  +getAmount()
  +sendQuantity()
}
Invoice --* Housekeeping
Booking ..> Housekeeping : "*"
Restaurant ..|> Booking
@enduml