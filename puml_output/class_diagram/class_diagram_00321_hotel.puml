@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Invoice {
  -String code
  +long id
  +double amount
  +deleteStatus()
}
class Housekeeping {
  -int email
  #long updatedAt
  +String total
  +cancelActive()
  +setStatus()
  +validateActive()
  +findDescription()
}
class Booking {
  -boolean level
  #int score
  -double updatedAt
  -int active
  #float status
  +setUpdatedat()
  +deleteAddress()
  +saveScore()
}
class Restaurant {
  +Date status
  -double active
  -int updatedAt
  +long email
  -int phone
  +deleteStatus()
  +findQuantity()
  +getId()
  +deleteTotal()
}
class Room {
  -long amount
  -float name
  +Date duration
  +calculatePhone()
}
Restaurant ..> Housekeeping : "0..1"
Invoice ..> Restaurant : "1..*"
note right of Invoice : Hotel domain
@enduml