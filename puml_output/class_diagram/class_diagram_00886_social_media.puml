@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Album {
  +long level
  #long price
  +createAmount()
}
interface Group {
  #double address
  #boolean quantity
  -double email
  -String amount
  +cancelNote()
  +getScore()
}
class Like {
  -Date quantity
  -Date createdAt
  +int updatedAt
  #String score
  +cancelCreatedat()
  +createActive()
  +updateCode()
  +processCode()
}
class User {
  +int phone
  +float active
  +boolean amount
  #double createdAt
  +boolean description
  +calculateTotal()
  +processDuration()
  +deleteCreatedat()
}
class Comment {
  +double phone
  -String active
  +updateType()
  +cancelDuration()
  +getDuration()
}
class Story {
  -long description
  #boolean score
  +calculateTotal()
  +sendDescription()
  +cancelEmail()
}
Group --|> Story
Comment ..> Album : "*"
Like --* Album
@enduml