@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Customer {
  #long score
  +float type
  +cancelUpdatedat()
  +setNote()
}
abstract class Depot {
  #long email
  #int type
  +long quantity
  #long updatedAt
  +double address
  +getId()
  +createId()
  +validateScore()
}
class Warehouse {
  +boolean createdAt
  +boolean level
  #Date active
  #boolean address
  +double quantity
  +validateDescription()
  +getPhone()
  +setAddress()
}
abstract class Driver {
  +int address
  -String price
  -double score
  -long createdAt
  #String code
  +calculatePhone()
}
abstract class DeliveryNote {
  -Date id
  +double note
  +String score
  -float updatedAt
  +findEmail()
  +getAddress()
}
abstract class Route {
  +int total
  #int email
  -float note
  -double duration
  +sendActive()
  +getName()
  +getUpdatedat()
  +calculateStatus()
}
class Shipment {
  +int note
  #boolean price
  #Date email
  +setTotal()
  +findDuration()
  +saveCreatedat()
}
Customer --> Route : "1"
Depot ..> Shipment : "0..1"
DeliveryNote --o Warehouse
@enduml