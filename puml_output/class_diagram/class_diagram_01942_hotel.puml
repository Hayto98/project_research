@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Housekeeping {
  #double active
  #String amount
  +processTotal()
  +sendAddress()
}
class Reservation {
  #double phone
  -float updatedAt
  +double status
  -long total
  #long name
  +findQuantity()
  +cancelActive()
  +getEmail()
}
class Guest {
  #float note
  #boolean price
  -String quantity
  +float active
  +updateActive()
  +calculatePhone()
  +createScore()
  +findQuantity()
}
class Room {
  -int active
  -float status
  +getCreatedat()
  +saveAmount()
}
class Payment {
  -Date createdAt
  -long quantity
  +double total
  #double id
  +validateDuration()
  +createTotal()
  +findTotal()
  +validateEmail()
}
class Invoice {
  #Date level
  +long status
  +long total
  #Date quantity
  +Date active
  +updateLevel()
  +updateScore()
  +calculateName()
  +updateTotal()
}
Reservation --> Room : "1..*"
Housekeeping ..|> Invoice
Payment ..> Housekeeping : "1"
note right of Housekeeping : Hotel domain
@enduml