@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Housekeeping {
  #double active
  #String amount
  +cancelCode()
  +findAmount()
}
interface Reservation {
  +double id
  #String note
  #double phone
  -float updatedAt
  +findActive()
  +deleteLevel()
}
abstract class Guest {
  +long address
  -boolean phone
  -double quantity
  -Date active
  +deleteUpdatedat()
  +deleteType()
  +calculateActive()
}
interface Room {
  -long id
  #boolean duration
  #Date type
  -long createdAt
  #String price
  +deleteCreatedat()
}
class Payment {
  #Date amount
  -Date name
  #float createdAt
  +long duration
  -String quantity
  +calculateDescription()
  +processStatus()
  +deleteCode()
}
class Invoice {
  -Date duration
  -long total
  -float level
  -double phone
  #String quantity
  +findScore()
  +findTotal()
  +createQuantity()
  +createLevel()
}
Guest --* Housekeeping
Invoice ..> Housekeeping : "*"
@enduml