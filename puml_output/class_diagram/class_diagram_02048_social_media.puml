@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
interface Post {
  +double duration
  +double id
  -String updatedAt
  -Date status
  -int phone
  +processPrice()
  +sendQuantity()
}
class Group {
  -float updatedAt
  +String name
  #double total
  #long id
  +double price
  +findTotal()
  +findEmail()
  +setAmount()
}
interface User {
  #String phone
  +int code
  +Date address
  #String total
  -double updatedAt
  +cancelQuantity()
  +setUpdatedat()
}
interface Hashtag {
  -int email
  #double description
  +long amount
  -Date level
  +processPhone()
  +createActive()
  +createEmail()
}
Group ..> User : "1..*"
User --o Group
Hashtag ..|> Post
@enduml