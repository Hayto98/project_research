@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
interface Post {
  +double duration
  +double id
  -String updatedAt
  -Date status
  -int phone
  +updateActive()
  +validateType()
}
class Group {
  #double total
  -float id
  +setScore()
  +calculateAddress()
}
class User {
  #Date address
  -double score
  #int total
  #String phone
  +int code
  +saveCode()
}
abstract class Hashtag {
  #Date updatedAt
  +float note
  +int name
  -int quantity
  #double email
  +createAddress()
}
User --o Hashtag
Group ..> User : "1..*"
User --o Group
note right of Post : Social Media domain
@enduml