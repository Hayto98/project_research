@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Profile {
  +float amount
  #long price
  #int status
  #float address
  +cancelCreatedat()
  +sendStatus()
  +getDescription()
  +getUpdatedat()
}
abstract class Album {
  +boolean email
  +long createdAt
  +processCreatedat()
  +validatePrice()
  +deleteLevel()
  +processId()
}
abstract class Comment {
  #boolean duration
  +float total
  +long score
  #double status
  +String note
  +createAmount()
}
class Like {
  -boolean id
  +long duration
  +float phone
  +boolean level
  +sendEmail()
  +setTotal()
}
interface Notification {
  -String price
  -int email
  -boolean name
  #long updatedAt
  +setQuantity()
  +validateAddress()
  +calculateStatus()
  +sendActive()
}
class Report {
  +String type
  #long quantity
  +boolean code
  #double status
  +double phone
  +deleteNote()
  +setStatus()
  +setName()
}
Comment ..|> Like
Comment ..> Report : "*"
Like --o Comment
Like --o Album
@enduml