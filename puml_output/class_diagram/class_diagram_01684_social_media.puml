@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Profile {
  +float amount
  #long price
  #int status
  #float address
  +calculateTotal()
  +cancelName()
  +saveEmail()
  +cancelCreatedat()
}
class Album {
  #float email
  #double total
  +cancelTotal()
  +sendScore()
  +setNote()
  +saveScore()
}
class Comment {
  +String phone
  +long price
  +validateId()
  +getPhone()
}
class Like {
  #boolean active
  #boolean code
  +int phone
  -float createdAt
  #Date description
  +calculateEmail()
  +getUpdatedat()
  +createStatus()
}
abstract class Notification {
  -Date phone
  -float score
  -long active
  +sendType()
}
abstract class Report {
  +Date code
  -int status
  #float phone
  #double updatedAt
  +processQuantity()
}
Profile --o Report
Comment ..|> Like
note right of Profile : Social Media domain
@enduml