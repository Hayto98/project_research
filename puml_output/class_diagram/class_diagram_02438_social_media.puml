@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Group {
  +long code
  -String score
  #float createdAt
  #float email
  #boolean updatedAt
  +sendType()
  +cancelUpdatedat()
  +getEmail()
  +findQuantity()
}
class Like {
  #String note
  -double code
  -int address
  -long level
  -Date total
  +deletePrice()
  +setName()
  +findQuantity()
}
interface User {
  +Date level
  +String price
  +double duration
  +float updatedAt
  +double description
  +processLevel()
  +setPrice()
  +setAddress()
  +findPrice()
}
class Report {
  #String name
  -double level
  +String note
  #float active
  +findQuantity()
  +createDuration()
  +sendId()
}
abstract class Story {
  +float phone
  +Date status
  +processCode()
  +updateDescription()
  +createAddress()
  +sendActive()
}
class Comment {
  +boolean email
  #float updatedAt
  -String score
  +findUpdatedat()
  +getCode()
  +processUpdatedat()
}
class Hashtag {
  #boolean name
  +double price
  +boolean code
  +getName()
}
Hashtag --|> Like
Comment --o User
@enduml