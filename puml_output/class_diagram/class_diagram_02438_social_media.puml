@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Group {
  +long code
  -String score
  #float createdAt
  #float email
  #boolean updatedAt
  +findDescription()
  +validateEmail()
  +processNote()
  +setAddress()
}
class Like {
  -long code
  -Date phone
  -double note
  +long quantity
  #double amount
  +calculateUpdatedat()
  +deleteAmount()
  +saveStatus()
  +setCreatedat()
}
abstract class User {
  -double status
  #boolean type
  +createName()
  +cancelNote()
}
interface Report {
  +String note
  #float price
  +validatePrice()
  +updatePrice()
  +setPhone()
}
class Story {
  -String createdAt
  +String level
  +updateEmail()
  +updateScore()
}
class Comment {
  +double status
  +Date email
  #int amount
  -String quantity
  #String createdAt
  +deleteName()
}
class Hashtag {
  #float updatedAt
  #float score
  +int status
  -double active
  #Date note
  +calculateDuration()
  +processQuantity()
  +getDuration()
  +findDescription()
}
User --|> Report
Comment --|> Report
Story ..> Comment : "1"
note right of Group : Social Media domain
@enduml