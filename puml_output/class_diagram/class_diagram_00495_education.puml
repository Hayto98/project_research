@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
interface Enrollment {
  #String score
  +float type
  +saveId()
  +updatePrice()
  +calculateAmount()
  +saveType()
}
interface Teacher {
  -float address
  -float description
  +int type
  #boolean amount
  +cancelDuration()
}
class Student {
  #double email
  #long active
  -String address
  -long duration
  +calculateLevel()
  +deleteAddress()
  +deleteTotal()
  +setAddress()
}
interface Attendance {
  #String price
  +float note
  +int status
  +createQuantity()
  +findCreatedat()
  +processType()
  +deleteStatus()
}
class Assignment {
  #boolean note
  -String updatedAt
  -Date name
  +cancelDescription()
  +createStatus()
  +createTotal()
  +processAddress()
}
abstract class Classroom {
  -boolean email
  #long total
  -long amount
  #float phone
  +calculateCode()
  +processUpdatedat()
  +cancelAmount()
}
Student --* Attendance
Student ..|> Classroom
Teacher --* Assignment
@enduml