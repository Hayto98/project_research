@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
interface Enrollment {
  #String score
  +float type
  +getId()
  +processScore()
  +sendEmail()
  +validateDescription()
}
abstract class Teacher {
  +Date quantity
  #String type
  #long name
  +createActive()
  +validateEmail()
  +sendTotal()
}
interface Student {
  -float price
  +float id
  #boolean quantity
  +double address
  +setCode()
  +updateStatus()
  +updateType()
  +createEmail()
}
abstract class Attendance {
  #boolean createdAt
  -String note
  -Date updatedAt
  #boolean name
  +findScore()
  +findPrice()
  +cancelActive()
  +validateEmail()
}
abstract class Assignment {
  #long phone
  -long address
  #float active
  +calculateAmount()
  +sendDescription()
  +createNote()
}
class Classroom {
  +float phone
  -double createdAt
  +String level
  #String duration
  +deleteCode()
  +updateEmail()
}
Student ..|> Assignment
Attendance ..|> Student
Student --o Enrollment
Assignment --|> Attendance
note right of Enrollment : Education domain
@enduml