@startuml
skinparam defaultFontSize 11
class Fine {
  -int code
  #Date total
  +int note
  #long updatedAt
  +processName()
  +sendActive()
  +validateId()
}
class Loan {
  +float createdAt
  -long email
  +int phone
  +int name
  +long price
  +validateDuration()
  +findActive()
}
abstract class Catalog {
  +Date amount
  #double type
  +String duration
  #long email
  +deleteEmail()
  +cancelQuantity()
  +sendCreatedat()
}
class Book {
  #long score
  #long total
  #Date address
  +createPhone()
  +getTotal()
}
Fine ..|> Loan
Loan ..|> Fine
Book --o Fine
@enduml