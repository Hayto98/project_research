@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Tracking {
  +float duration
  -boolean phone
  +setUpdatedat()
}
class Warehouse {
  #String code
  -Date quantity
  +createNote()
  +cancelQuantity()
}
class Shipment {
  +double score
  -float createdAt
  -float quantity
  #String duration
  +float id
  +deleteAmount()
}
interface Manifest {
  #long score
  +Date quantity
  +cancelQuantity()
  +findUpdatedat()
}
class Package {
  +Date code
  #int status
  +getDuration()
}
Shipment ..|> Warehouse
Package --|> Manifest
note right of Tracking : Logistics domain
@enduml