@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Tracking {
  +float duration
  -boolean phone
  +deleteQuantity()
}
class Warehouse {
  +long level
  #String name
  +sendDuration()
  +deleteAddress()
  +sendAddress()
  +processTotal()
}
interface Shipment {
  -long phone
  +int total
  -long score
  -float createdAt
  +getType()
}
class Manifest {
  #long amount
  #long level
  +Date name
  +processId()
  +cancelAddress()
}
class Package {
  +int code
  #Date duration
  +calculateEmail()
  +saveId()
}
Package --* Tracking
Package ..|> Warehouse
Package --|> Manifest
@enduml