@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
interface Hospital {
  +boolean score
  -int duration
  +double active
  #String description
  #String total
  +getType()
  +sendPhone()
  +sendDuration()
}
class Appointment {
  #float id
  -float email
  -float amount
  +float name
  #float price
  +cancelCreatedat()
  +sendPrice()
}
abstract class Diagnosis {
  -long type
  -int email
  -Date name
  +float updatedAt
  -double active
  +savePhone()
  +processId()
  +sendActive()
  +processAmount()
}
class LabTest {
  #boolean phone
  #int amount
  -double total
  +Date status
  #boolean address
  +findCreatedat()
  +cancelActive()
  +createAmount()
  +createCode()
}
abstract class Doctor {
  -long id
  #long name
  -Date level
  #float price
  +processDescription()
}
class Patient {
  #float price
  +double id
  #long status
  -String description
  +calculateQuantity()
  +processNote()
  +sendQuantity()
}
Doctor --* Appointment
LabTest --* Doctor
Hospital ..|> Doctor
Patient --|> LabTest
Appointment ..> Hospital : "1"
@enduml