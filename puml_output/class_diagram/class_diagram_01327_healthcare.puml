@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
interface Hospital {
  +boolean score
  -int duration
  +double active
  #String description
  #String total
  +setPhone()
  +saveEmail()
  +calculateId()
}
class Appointment {
  #float name
  -float level
  -float price
  +cancelDescription()
  +calculateTotal()
}
abstract class Diagnosis {
  -long email
  -int level
  -Date name
  +float updatedAt
  -double active
  +getLevel()
  +cancelCode()
  +setPrice()
  +validateDuration()
}
class LabTest {
  -String status
  #float level
  #boolean address
  -long amount
  #long type
  +calculateAddress()
  +getName()
}
class Doctor {
  -Date type
  +Date email
  -double phone
  +float address
  #boolean id
  +deleteActive()
}
class Patient {
  #boolean email
  #float address
  -boolean status
  +long quantity
  -boolean total
  +getDuration()
  +updatePrice()
  +getUpdatedat()
}
Patient --|> Hospital
Hospital --* Diagnosis
note right of Hospital : Healthcare domain
@enduml