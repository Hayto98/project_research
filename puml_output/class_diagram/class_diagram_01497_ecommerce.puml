@startuml
skinparam shadowing true
class Cart {
  #String updatedAt
  +Date score
  +cancelDuration()
  +createNote()
  +sendScore()
  +updateLevel()
}
class Category {
  +int updatedAt
  -String note
  +boolean type
  +float name
  #float id
  +sendId()
}
interface Return {
  #String duration
  +int level
  +calculateScore()
  +saveId()
  +getUpdatedat()
}
class Review {
  +int price
  #double name
  #Date duration
  #Date code
  +validateAddress()
  +cancelName()
  +calculateName()
  +processDescription()
}
class Shipment {
  +double amount
  +Date type
  #double quantity
  #boolean name
  +int address
  +sendQuantity()
  +updateDuration()
}
class Warehouse {
  #double status
  +Date note
  +float code
  -int email
  -long price
  +processQuantity()
  +calculatePrice()
}
class Invoice {
  #long id
  +float updatedAt
  -int description
  +Date quantity
  +createCode()
}
Return --o Cart
Review --o Invoice
Shipment ..|> Warehouse
Warehouse --o Invoice
@enduml