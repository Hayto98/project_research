@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
abstract class Loan {
  #float updatedAt
  +boolean score
  +sendAddress()
}
class Renewal {
  +double amount
  -Date score
  +calculateId()
  +getScore()
}
class Shelf {
  -long name
  #boolean address
  -String type
  +findEmail()
  +validateName()
  +getLevel()
}
class Book {
  #int description
  +String updatedAt
  +long score
  +long id
  -Date address
  +findAmount()
}
class Member {
  -float type
  #boolean score
  +float level
  #Date id
  +processCreatedat()
  +cancelEmail()
}
class Catalog {
  -float score
  +String updatedAt
  +calculateCode()
  +saveId()
  +cancelNote()
  +cancelQuantity()
}
interface Librarian {
  #double id
  #int status
  +String address
  +boolean email
  +deleteAddress()
  +deleteTotal()
}
Member ..|> Librarian
Shelf --o Member
Catalog ..> Renewal : "1..*"
@enduml