@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
abstract class Loan {
  #float updatedAt
  +boolean score
  +createUpdatedat()
}
class Renewal {
  -Date score
  +String name
  #long type
  +getAddress()
  +saveType()
}
class Shelf {
  -double duration
  +int active
  -int quantity
  #float name
  +findLevel()
  +saveScore()
}
class Book {
  +long active
  +long amount
  -Date level
  +double name
  +sendAddress()
  +processScore()
  +cancelScore()
}
class Member {
  +int duration
  +boolean score
  #int id
  -float updatedAt
  +setLevel()
}
abstract class Catalog {
  +String name
  #long createdAt
  -Date note
  -boolean active
  +String quantity
  +deleteLevel()
}
class Librarian {
  +long description
  #double active
  #int score
  +createId()
  +setScore()
  +updateAmount()
}
Shelf --|> Catalog
Renewal --> Loan : "0..1"
Loan --> Catalog : "1"
Loan --* Renewal
note right of Loan : Library domain
@enduml