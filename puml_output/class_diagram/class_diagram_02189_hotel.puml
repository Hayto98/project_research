@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Staff {
  #String total
  #Date address
  -long name
  #long score
  #double phone
  +processAmount()
  +sendScore()
  +calculateDescription()
}
abstract class Payment {
  +boolean type
  +float code
  +updateType()
  +processPhone()
  +processPrice()
  +calculateDescription()
}
class Room {
  -Date note
  #int type
  -float duration
  +findCode()
  +saveActive()
  +cancelName()
  +getLevel()
}
class Housekeeping {
  -String score
  #boolean quantity
  #String code
  +findNote()
  +savePhone()
  +deleteStatus()
}
abstract class Reservation {
  -String type
  #long duration
  +saveDescription()
  +setUpdatedat()
  +deleteUpdatedat()
}
Payment --> Housekeeping : "*"
Staff ..|> Housekeeping
Room --o Reservation
Staff --> Payment : "1..*"
@enduml