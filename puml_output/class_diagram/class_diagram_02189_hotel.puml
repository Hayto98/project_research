@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Staff {
  #String total
  #Date address
  -long name
  #long score
  #double phone
  +setPrice()
  +findType()
  +saveActive()
}
interface Payment {
  +boolean type
  +float code
  +deleteUpdatedat()
  +findQuantity()
  +updateNote()
  +saveType()
}
abstract class Room {
  #Date updatedAt
  +Date total
  +int level
  #long phone
  +calculateStatus()
}
interface Housekeeping {
  +Date address
  -String code
  +findType()
  +calculateId()
  +savePhone()
  +createName()
}
interface Reservation {
  -int price
  -boolean total
  -float status
  +setCreatedat()
  +sendLevel()
  +validateDescription()
  +sendLevel()
}
Reservation ..|> Room
Staff --|> Payment
Reservation --o Housekeeping
note right of Staff : Hotel domain
@enduml