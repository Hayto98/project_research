@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Story {
  -double quantity
  +int duration
  +boolean createdAt
  +deleteCreatedat()
  +deleteStatus()
  +sendStatus()
}
interface User {
  +String phone
  +String status
  #String quantity
  #boolean address
  +int description
  +processEmail()
}
class Comment {
  +int status
  +int total
  +getScore()
  +sendName()
}
class Follower {
  +Date active
  +float price
  #float duration
  -Date total
  +deleteScore()
}
abstract class Group {
  +long price
  +double updatedAt
  +findDuration()
  +findStatus()
}
class Notification {
  -float active
  +int code
  +sendAddress()
  +calculateAmount()
}
class Like {
  -boolean id
  #String total
  +updatePhone()
  +findPhone()
  +validateDescription()
  +createDuration()
}
Follower --o Group
User --> Like : "1"
User ..> Story : "1"
Follower --|> User
Story --|> Like
Follower --> Comment : "1..*"
note right of Story : Social Media domain
@enduml