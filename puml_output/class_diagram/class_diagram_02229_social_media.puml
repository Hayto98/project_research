@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Story {
  -double quantity
  +int duration
  +boolean createdAt
  +calculateAddress()
  +calculateNote()
  +validateQuantity()
}
class User {
  -float score
  +Date note
  +validateDuration()
  +cancelLevel()
  +validateCreatedat()
}
class Comment {
  #String amount
  #boolean code
  +getEmail()
}
class Follower {
  #double email
  +int address
  +int active
  +float code
  +boolean status
  +cancelLevel()
}
class Group {
  +Date active
  +float price
  #float duration
  -Date total
  +getEmail()
}
interface Notification {
  +double code
  #int price
  #boolean updatedAt
  #Date status
  +long email
  +createDescription()
}
class Like {
  -double updatedAt
  +String description
  +String amount
  -long active
  +calculateCode()
}
Comment --* Notification
Like ..|> Comment
Comment --> Group : "*"
@enduml