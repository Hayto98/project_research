@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
interface User {
  +long duration
  +double description
  #Date name
  -float id
  -float address
  +createUpdatedat()
  +saveStatus()
}
class Group {
  +double level
  +float quantity
  #long amount
  +saveScore()
  +validateEmail()
  +validatePhone()
}
class Album {
  -long quantity
  -Date description
  #long level
  #int type
  -String code
  +deleteDescription()
  +findPhone()
  +updateId()
  +updateCreatedat()
}
interface Post {
  #double phone
  -float level
  #double name
  +updateCreatedat()
  +deletePhone()
}
class Notification {
  #Date total
  #float description
  +Date address
  +long duration
  #int quantity
  +updateAmount()
  +setDuration()
  +processStatus()
  +calculatePhone()
}
class Message {
  +Date active
  +float name
  #float level
  +saveDuration()
  +validateEmail()
  +createId()
  +sendDuration()
}
Notification --> Post : "0..1"
Post ..|> Album
note right of User : Social Media domain
@enduml