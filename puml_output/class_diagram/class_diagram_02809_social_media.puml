@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
interface User {
  +long duration
  +double description
  #Date name
  -float id
  -float address
  +processDescription()
  +processPrice()
}
class Group {
  #boolean updatedAt
  -int level
  +validateName()
  +sendId()
}
interface Album {
  -long address
  +Date score
  #Date duration
  -long email
  +findPhone()
  +getName()
}
abstract class Post {
  -Date type
  #long address
  +findQuantity()
  +updateActive()
}
abstract class Notification {
  +int description
  #int phone
  #int updatedAt
  +cancelPrice()
  +processId()
  +savePhone()
}
abstract class Message {
  +long level
  -Date price
  -double amount
  +long updatedAt
  -boolean createdAt
  +cancelActive()
  +setScore()
  +setCode()
}
Message --* Group
Notification --o Group
Group --|> Message
@enduml