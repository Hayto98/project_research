@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
abstract class Hashtag {
  #double createdAt
  #Date name
  +calculatePrice()
  +cancelId()
  +findNote()
  +processNote()
}
interface Story {
  #String quantity
  +boolean price
  #int address
  #long description
  +deleteAddress()
  +processAmount()
}
class Message {
  +boolean createdAt
  -int total
  +String type
  +updateScore()
}
class Album {
  +boolean name
  +String level
  -int total
  -float code
  +findEmail()
  +validateId()
}
class Like {
  -boolean level
  -String updatedAt
  +sendType()
}
class Report {
  -float address
  +String status
  +long email
  +validateAmount()
}
Report ..|> Message
Hashtag --o Like
Album --o Message
@enduml