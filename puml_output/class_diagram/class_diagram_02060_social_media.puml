@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
abstract class Profile {
  #double type
  -int note
  +double createdAt
  +saveActive()
}
abstract class Hashtag {
  +Date createdAt
  -String note
  #float quantity
  -float email
  +sendScore()
  +cancelCode()
  +saveCode()
  +setLevel()
}
class Message {
  +long note
  +boolean status
  +findTotal()
  +updateNote()
  +validateAmount()
  +createType()
}
class Story {
  #float phone
  #String amount
  #int duration
  #boolean email
  +updatePrice()
  +processLevel()
  +findTotal()
}
interface Report {
  #float duration
  #double updatedAt
  #Date name
  +getPrice()
}
Report --> Hashtag : "*"
Hashtag ..|> Profile
note right of Profile : Social Media domain
@enduml