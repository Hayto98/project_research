@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
abstract class Room {
  +boolean id
  #String status
  #int createdAt
  -String description
  #long quantity
  +savePhone()
  +calculatePrice()
  +sendAddress()
}
class Payment {
  +float score
  +Date address
  +cancelCreatedat()
  +deleteCode()
  +deleteUpdatedat()
  +setScore()
}
class CheckIn {
  +float duration
  +Date phone
  +sendPrice()
  +setId()
  +setId()
  +setLevel()
}
class Invoice {
  -double email
  #String price
  -int active
  +createId()
}
class Booking {
  -long code
  #Date createdAt
  +Date id
  +boolean total
  #long price
  +updateCode()
  +createDuration()
  +cancelCreatedat()
  +setName()
}
Booking --> CheckIn : "1..*"
Room --> CheckIn : "1..*"
Payment ..|> Booking
note right of Room : Hotel domain
@enduml