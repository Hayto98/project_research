@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
abstract class Room {
  +boolean id
  #String status
  #int createdAt
  -String description
  #long quantity
  +validateStatus()
  +findStatus()
  +updateTotal()
}
abstract class Payment {
  +float score
  +Date address
  #float level
  -boolean code
  #float duration
  +saveQuantity()
  +getType()
}
class CheckIn {
  +Date code
  #long score
  +float id
  +cancelPrice()
}
interface Invoice {
  +String active
  #String price
  #int code
  -Date id
  #Date status
  +findDuration()
  +sendName()
  +calculateAmount()
  +validateActive()
}
class Booking {
  #double description
  +int status
  +double email
  -float id
  -long phone
  +cancelUpdatedat()
  +updateUpdatedat()
}
CheckIn ..|> Invoice
Room --> CheckIn : "0..1"
Room --o Booking
Booking --> CheckIn : "1..*"
@enduml