@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
interface Patient {
  -double name
  #int note
  #double type
  -boolean price
  +deleteEmail()
}
abstract class Insurance {
  +int description
  #double score
  +deleteUpdatedat()
  +processScore()
  +findPhone()
  +createAmount()
}
interface MedicalRecord {
  -Date updatedAt
  +boolean level
  -String type
  +int phone
  #double active
  +processTotal()
  +updateEmail()
  +sendActive()
  +processId()
}
interface Prescription {
  +long duration
  +long total
  #double code
  +processAddress()
  +setStatus()
  +updateType()
  +calculateDescription()
}
class Diagnosis {
  -float level
  -boolean duration
  -float status
  #boolean type
  +cancelName()
  +validateCode()
  +updateName()
}
abstract class Appointment {
  +String email
  #float price
  +validateStatus()
}
interface Treatment {
  -boolean name
  +boolean note
  #float total
  -float duration
  -double createdAt
  +getEmail()
  +validateEmail()
  +setNote()
  +saveNote()
}
Patient --o Insurance
Insurance --o Appointment
@enduml