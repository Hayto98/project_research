@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Package {
  #Date quantity
  #Date level
  +updateScore()
  +findLevel()
  +findPrice()
  +validateName()
}
class FuelLog {
  +Date amount
  -String status
  -long id
  +setPhone()
  +findCreatedat()
  +findStatus()
  +setUpdatedat()
}
class Customer {
  +double price
  +String email
  -double active
  -boolean amount
  +saveUpdatedat()
  +updateCreatedat()
  +findCode()
  +deleteCreatedat()
}
abstract class Tracking {
  #String phone
  #boolean type
  -Date level
  +setLevel()
}
Customer ..> FuelLog : "1..*"
Package ..|> Tracking
@enduml