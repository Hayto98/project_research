@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Package {
  #Date quantity
  #Date level
  +findActive()
  +processUpdatedat()
  +saveCreatedat()
  +deleteDuration()
}
class FuelLog {
  +long name
  -double note
  +saveName()
  +findId()
  +findQuantity()
}
abstract class Customer {
  +String active
  -double amount
  -boolean level
  -Date price
  +createType()
  +updatePhone()
  +processType()
}
class Tracking {
  -double duration
  #boolean status
  #float description
  -String phone
  +updateStatus()
}
Package --* Customer
FuelLog ..|> Customer
note right of Package : Logistics domain
@enduml