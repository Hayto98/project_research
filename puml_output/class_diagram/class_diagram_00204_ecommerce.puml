@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Wishlist {
  +double status
  #Date duration
  #long address
  +setPhone()
  +findActive()
  +findPrice()
}
class Review {
  #long amount
  +float address
  +sendName()
  +findCreatedat()
  +validateId()
}
class Order {
  +long level
  #int address
  #String note
  -boolean id
  +calculateLevel()
  +validateNote()
}
interface Return {
  +long address
  #float status
  -String level
  +updatePrice()
  +saveNote()
}
abstract class Cart {
  -double note
  +double email
  +int code
  +updateId()
  +saveId()
  +calculateName()
}
abstract class Coupon {
  -boolean code
  +Date level
  +processPrice()
  +setDescription()
}
Cart ..> Wishlist : "1..*"
Cart --> Order : "1..*"
@enduml