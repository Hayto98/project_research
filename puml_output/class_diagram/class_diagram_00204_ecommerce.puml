@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Wishlist {
  +double status
  #Date duration
  #long address
  +cancelType()
  +sendCode()
  +setAmount()
}
class Review {
  -String name
  -long level
  #long address
  -String type
  +createDuration()
  +deleteStatus()
}
class Order {
  -String updatedAt
  +String level
  -boolean createdAt
  +getDuration()
  +deleteId()
  +updateNote()
  +cancelUpdatedat()
}
abstract class Return {
  -String code
  +float type
  -Date note
  +long createdAt
  +getCode()
  +cancelQuantity()
  +sendName()
  +findUpdatedat()
}
class Cart {
  +Date code
  #Date active
  +sendAddress()
  +sendQuantity()
  +calculatePhone()
}
class Coupon {
  +double email
  -int type
  #float address
  -float score
  +updateUpdatedat()
  +validateAmount()
}
Return ..|> Coupon
Review --* Order
Order --|> Review
note right of Wishlist : Ecommerce domain
@enduml