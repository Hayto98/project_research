@startuml
skinparam monochrome true
class Staff {
  -long updatedAt
  #int level
  +long name
  +sendLevel()
  +deleteUpdatedat()
  +deleteType()
}
abstract class Room {
  +double active
  -double price
  -int amount
  #double score
  +updatePhone()
  +getScore()
}
interface Booking {
  +String price
  #String id
  #long address
  -Date level
  #boolean duration
  +getNote()
  +getDescription()
  +calculateAmount()
  +updateTotal()
}
abstract class Guest {
  -boolean status
  #float id
  +cancelCode()
}
interface Reservation {
  +Date description
  -String score
  -boolean phone
  +Date updatedAt
  +float active
  +sendNote()
  +sendCreatedat()
  +getCode()
}
class Service {
  +long createdAt
  +Date active
  #float status
  #int total
  #float level
  +sendScore()
  +calculateNote()
  +getEmail()
  +processDuration()
}
class CheckIn {
  #String total
  -Date phone
  #double updatedAt
  +validateCreatedat()
  +calculateAddress()
  +getPrice()
}
Staff ..|> Service
Staff --> Room : "1"
Booking --o Room
Service --> Reservation : "0..1"
Reservation --* Guest
note right of Staff : Hotel domain
@enduml