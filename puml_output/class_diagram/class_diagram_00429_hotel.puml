@startuml
skinparam monochrome true
class Staff {
  -long updatedAt
  #int level
  +long name
  +deletePhone()
  +findPrice()
  +saveDuration()
}
class Room {
  -boolean amount
  -int type
  +int note
  +setTotal()
  +validateName()
  +deleteEmail()
  +calculateLevel()
}
class Booking {
  +int active
  -String total
  #boolean duration
  +sendScore()
  +sendTotal()
  +validateStatus()
  +calculateCreatedat()
}
class Guest {
  #float createdAt
  #boolean status
  -String name
  -String address
  +double active
  +processActive()
  +processLevel()
}
abstract class Reservation {
  -boolean status
  #float id
  +findDescription()
}
class Service {
  +Date description
  -String score
  -boolean phone
  +Date updatedAt
  +float active
  +createStatus()
  +getDescription()
  +createName()
}
interface CheckIn {
  -float name
  +boolean code
  #Date address
  +getPhone()
}
CheckIn --* Staff
Room --> Service : "0..1"
Reservation --> Guest : "*"
Guest --* Staff
Guest ..|> Reservation
@enduml