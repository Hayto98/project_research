@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
abstract class Department {
  #Date score
  -long level
  #long description
  +sendLevel()
  +findActive()
  +calculateNote()
  +deleteScore()
}
class Teacher {
  #float quantity
  -Date status
  +calculateTotal()
  +cancelStatus()
}
interface Enrollment {
  +double phone
  #boolean amount
  #double type
  +boolean address
  #String name
  +setScore()
  +getCreatedat()
  +createCreatedat()
  +setTotal()
}
class Book {
  #boolean phone
  #Date quantity
  -double amount
  -float code
  +updateDescription()
  +setCreatedat()
}
class Course {
  -double address
  +boolean note
  +calculateScore()
  +findActive()
  +updateLevel()
  +findTotal()
}
Book --> Department : "1"
Course ..|> Book
Book --|> Teacher
note right of Department : Education domain
@enduml