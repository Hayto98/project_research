@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
abstract class Department {
  #Date score
  -long level
  #long description
  +createDescription()
  +cancelActive()
  +calculateDescription()
  +sendQuantity()
}
abstract class Teacher {
  +float description
  #float score
  -Date createdAt
  #int name
  -double quantity
  +calculatePrice()
}
abstract class Enrollment {
  #String amount
  +double type
  #boolean score
  #double address
  +findName()
}
interface Book {
  #String note
  +long status
  +getDuration()
  +setStatus()
}
abstract class Course {
  +boolean address
  #boolean phone
  #double quantity
  -long amount
  +sendId()
  +createCreatedat()
}
Teacher ..> Department : "1"
Enrollment --* Book
@enduml