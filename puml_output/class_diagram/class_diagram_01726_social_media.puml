@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
interface Hashtag {
  -int level
  +float price
  +String active
  #Date duration
  +calculateName()
}
class Album {
  +boolean updatedAt
  #String id
  -long active
  +getPhone()
  +findLevel()
}
abstract class Post {
  #boolean note
  #String name
  #boolean price
  +long total
  +getId()
  +findScore()
  +getStatus()
}
class Notification {
  #String type
  #int total
  +getTotal()
  +updateName()
  +createQuantity()
  +validateDuration()
}
Post --* Album
Hashtag --|> Album
Album --o Hashtag
@enduml