@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
abstract class Order {
  +boolean status
  #Date address
  -float createdAt
  +float duration
  +setAddress()
  +cancelAddress()
  +getNote()
}
class Warehouse {
  #double address
  +double amount
  +long total
  #float description
  -float updatedAt
  +updateCreatedat()
  +cancelStatus()
  +createDescription()
  +deleteId()
}
abstract class Review {
  +String description
  +long email
  +double name
  +validateName()
  +calculateUpdatedat()
}
class Supplier {
  +String status
  -boolean description
  +updateAddress()
  +findAmount()
  +saveTotal()
  +sendType()
}
class Invoice {
  +boolean address
  #long code
  -boolean name
  -boolean id
  +saveCode()
  +calculateActive()
  +processAddress()
  +createTotal()
}
class Payment {
  +boolean active
  +double quantity
  -double score
  +getNote()
  +setName()
}
class Coupon {
  +float total
  +long active
  +Date phone
  +Date address
  -Date status
  +deleteNote()
}
Review ..> Warehouse : "1..*"
Payment --> Order : "*"
@enduml