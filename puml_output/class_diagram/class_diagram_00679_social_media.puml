@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
abstract class Group {
  -boolean duration
  #long name
  +calculateDuration()
  +cancelStatus()
  +deleteCode()
}
class Report {
  +Date phone
  -Date price
  +int description
  #boolean score
  -int name
  +calculateCode()
  +cancelLevel()
}
class Comment {
  +Date name
  #float duration
  #boolean level
  +updateScore()
  +cancelEmail()
  +processLevel()
  +createDuration()
}
abstract class Follower {
  #boolean address
  -Date total
  +float code
  -int note
  +String description
  +findCreatedat()
  +saveTotal()
  +getScore()
  +calculateNote()
}
Group ..> Follower : "1"
Report ..|> Comment
Comment --|> Report
note right of Group : Social Media domain
@enduml