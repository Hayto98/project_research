@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
abstract class Group {
  -boolean duration
  #long name
  +saveCode()
  +sendActive()
  +getQuantity()
}
class Report {
  -double code
  +Date duration
  +boolean type
  +calculateId()
}
class Comment {
  -int updatedAt
  #float score
  +deleteAmount()
  +findNote()
}
interface Follower {
  +float amount
  +String name
  +getTotal()
  +saveActive()
  +updateAmount()
  +cancelActive()
}
Follower --* Comment
Follower --* Report
Follower --o Group
@enduml