@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Service {
  -String phone
  +int description
  #float id
  +savePhone()
  +createPrice()
}
class Room {
  -boolean quantity
  #int description
  +setAmount()
  +setActive()
  +deleteTotal()
  +processActive()
}
class CheckOut {
  -String price
  +long updatedAt
  -double description
  #long status
  +deleteStatus()
  +cancelType()
  +setAddress()
}
abstract class Amenity {
  -float level
  #double address
  -int id
  +double price
  +findNote()
  +calculateEmail()
  +calculateLevel()
}
abstract class Housekeeping {
  #float duration
  #double level
  +boolean code
  -String description
  +long type
  +validateScore()
  +deleteTotal()
}
class Payment {
  -long duration
  #boolean price
  +boolean total
  +float quantity
  +updateAmount()
  +processNote()
  +deleteAddress()
  +cancelPhone()
}
Service ..> Payment : "1..*"
Payment ..> Room : "1..*"
Service ..|> Housekeeping
Amenity ..> Housekeeping : "0..1"
@enduml