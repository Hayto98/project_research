@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Post {
  #Date phone
  +boolean email
  +Date type
  +Date amount
  +updateCreatedat()
  +saveActive()
}
class Report {
  -long type
  +Date amount
  +double name
  -Date description
  +deleteName()
  +calculateEmail()
  +deleteLevel()
}
abstract class Message {
  #long level
  #float type
  -Date updatedAt
  +boolean name
  +findName()
}
abstract class Profile {
  +float note
  #String code
  +cancelName()
  +sendActive()
  +getLevel()
  +saveTotal()
}
class Story {
  +String phone
  #long type
  +String quantity
  +double status
  +boolean level
  +sendTotal()
  +processScore()
}
class Comment {
  #boolean name
  #float active
  +float updatedAt
  +String total
  #double createdAt
  +sendDuration()
}
class Like {
  +int code
  -Date id
  -Date phone
  +int active
  #int quantity
  +processTotal()
  +findCreatedat()
  +saveNote()
  +sendCreatedat()
}
Message --o Report
Message ..> Like : "*"
Like ..> Report : "1"
Message --|> Story
Report --o Like
Like ..|> Comment
note right of Post : Social Media domain
@enduml