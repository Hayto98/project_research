@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Post {
  #Date phone
  +boolean email
  +Date type
  +Date amount
  +deleteAddress()
  +sendEmail()
}
interface Report {
  +int phone
  -long type
  +Date amount
  +validateUpdatedat()
  +deleteName()
}
class Message {
  +boolean name
  #double price
  #long email
  +processDuration()
  +saveDescription()
  +findTotal()
  +getCreatedat()
}
class Profile {
  -boolean total
  +double updatedAt
  +String name
  #String score
  +processEmail()
  +setUpdatedat()
  +createUpdatedat()
  +getScore()
}
class Story {
  -float status
  +double level
  +String type
  #long phone
  +String score
  +calculateQuantity()
  +sendType()
}
class Comment {
  #long score
  #double total
  #String note
  +updatePhone()
  +cancelCreatedat()
}
class Like {
  #double description
  #String code
  +setDuration()
  +cancelPrice()
  +processAddress()
}
Post --|> Comment
Message ..> Story : "1..*"
Report --o Like
Comment ..> Message : "0..1"
Report ..|> Story
@enduml