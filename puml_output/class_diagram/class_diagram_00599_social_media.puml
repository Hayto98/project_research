@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Hashtag {
  -String id
  #long duration
  #float quantity
  #Date score
  +Date type
  +sendUpdatedat()
  +findQuantity()
}
interface Like {
  #Date active
  +boolean price
  -int address
  #double name
  +processAmount()
  +cancelQuantity()
}
class User {
  #int id
  #String name
  #long quantity
  +String phone
  +cancelId()
  +saveCreatedat()
}
class Story {
  +long email
  -double id
  +Date quantity
  +sendDescription()
  +calculateCreatedat()
  +cancelDescription()
}
abstract class Group {
  -long phone
  -boolean description
  -int type
  -boolean address
  #boolean duration
  +deleteName()
}
Group ..> Like : "0..1"
Hashtag --> Story : "1"
@enduml