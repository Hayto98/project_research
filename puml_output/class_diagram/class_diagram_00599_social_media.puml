@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Hashtag {
  -String id
  #long duration
  #float quantity
  #Date score
  +Date type
  +findAddress()
  +sendEmail()
}
interface Like {
  #double address
  +String name
  -long amount
  #Date type
  -String description
  +createPhone()
}
interface User {
  +boolean name
  +long quantity
  -int amount
  +createId()
  +createName()
}
class Story {
  #double total
  -long status
  +float address
  -float score
  +validateTotal()
  +validatePhone()
  +cancelPhone()
}
class Group {
  #int duration
  #boolean score
  #float name
  #boolean email
  +String createdAt
  +sendId()
  +findAmount()
  +getDuration()
  +findActive()
}
Like --* Hashtag
Like --* Story
Group ..|> Like
note right of Hashtag : Social Media domain
@enduml