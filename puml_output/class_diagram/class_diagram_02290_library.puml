@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Author {
  #Date name
  +float createdAt
  +cancelId()
}
class Catalog {
  +String note
  +String code
  +setUpdatedat()
}
class Librarian {
  +boolean createdAt
  -Date updatedAt
  +createCode()
  +validateAddress()
  +cancelTotal()
  +getAddress()
}
class Publisher {
  -double description
  -long total
  #boolean active
  +processId()
}
Catalog ..|> Publisher
Librarian ..> Publisher : "0..1"
note right of Author : Library domain
@enduml