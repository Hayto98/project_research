@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Author {
  #Date name
  +float createdAt
  +setDuration()
}
interface Catalog {
  -Date code
  +int status
  +deleteEmail()
}
class Librarian {
  +float name
  +boolean status
  +sendEmail()
}
class Publisher {
  -String level
  -long note
  #double type
  +calculateCreatedat()
}
Catalog ..|> Librarian
Publisher --o Librarian
@enduml