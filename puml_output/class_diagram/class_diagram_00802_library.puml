@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Catalog {
  #int active
  -long code
  #long createdAt
  +double score
  #double description
  +saveId()
  +createLevel()
  +cancelUpdatedat()
  +validatePrice()
}
class Reservation {
  #float score
  -long description
  -double amount
  +findAddress()
  +findQuantity()
  +deleteAddress()
}
class Book {
  -boolean price
  +long name
  +Date description
  -String updatedAt
  +findNote()
  +saveAmount()
  +findCreatedat()
  +sendEmail()
}
class Shelf {
  #int total
  -long code
  +long name
  #String duration
  #String status
  +calculateCreatedat()
  +updateScore()
}
class Publisher {
  #float address
  +Date level
  +Date amount
  #String total
  +boolean price
  +updateCreatedat()
  +sendId()
  +getActive()
}
class Author {
  #float address
  #String createdAt
  +processType()
  +createPrice()
  +cancelQuantity()
  +deleteTotal()
}
Book --> Publisher : "1..*"
Reservation ..|> Publisher
note right of Catalog : Library domain
@enduml