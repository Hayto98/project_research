@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Catalog {
  #int active
  -long code
  #long createdAt
  +double score
  #double description
  +sendDuration()
  +processCode()
  +updateLevel()
  +savePrice()
}
interface Reservation {
  +boolean phone
  +int price
  #float updatedAt
  +calculatePhone()
  +calculateCreatedat()
  +cancelQuantity()
}
class Book {
  #long quantity
  #double amount
  +int address
  +long level
  +deleteName()
}
class Shelf {
  #long code
  +double total
  -float note
  +String amount
  #double createdAt
  +cancelAmount()
}
class Publisher {
  +double email
  +float code
  +boolean phone
  -Date level
  -Date name
  +processNote()
  +calculateLevel()
  +saveDuration()
}
class Author {
  #boolean price
  -int name
  +boolean amount
  #String id
  +boolean score
  +calculateStatus()
}
Author ..|> Book
Publisher --o Catalog
@enduml