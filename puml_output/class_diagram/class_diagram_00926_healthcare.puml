@startuml
skinparam ArrowColor #555555
class Patient {
  #int code
  +boolean status
  +boolean duration
  +getEmail()
  +calculateName()
  +createLevel()
  +cancelStatus()
}
class Diagnosis {
  #String amount
  -double duration
  +getAmount()
  +sendDescription()
}
class Billing {
  #boolean note
  -float code
  +boolean id
  +float price
  #double level
  +calculateUpdatedat()
  +setPrice()
  +getDescription()
}
class Insurance {
  #Date description
  #Date phone
  +validateType()
  +saveQuantity()
}
class Nurse {
  -float name
  #boolean total
  +Date type
  #boolean code
  +saveAmount()
}
abstract class Treatment {
  -Date address
  #long total
  +saveLevel()
}
interface Appointment {
  -int code
  +boolean createdAt
  -float active
  +updateType()
  +calculatePrice()
}
Patient ..> Treatment : "1"
Appointment ..> Treatment : "0..1"
Nurse ..|> Diagnosis
Nurse --|> Treatment
Diagnosis ..> Nurse : "0..1"
Insurance --o Treatment
@enduml