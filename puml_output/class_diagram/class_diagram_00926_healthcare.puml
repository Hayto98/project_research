@startuml
skinparam ArrowColor #555555
class Patient {
  #int code
  +boolean status
  +boolean duration
  +deleteAddress()
  +findCode()
  +createId()
  +deleteAmount()
}
class Diagnosis {
  -Date note
  +String createdAt
  #double updatedAt
  #String price
  +updateDuration()
  +getDuration()
  +processLevel()
}
class Billing {
  #Date status
  #Date description
  +float phone
  +setQuantity()
  +getTotal()
}
abstract class Insurance {
  #int quantity
  #Date level
  +processTotal()
}
class Nurse {
  #int total
  #Date phone
  +int quantity
  #double id
  +setDuration()
  +processScore()
}
class Treatment {
  #Date score
  +float level
  #Date name
  +cancelDescription()
  +updateActive()
}
class Appointment {
  #double duration
  #double updatedAt
  -Date type
  +processEmail()
  +findName()
  +findTotal()
}
Insurance --> Nurse : "1"
Treatment ..|> Patient
note right of Patient : Healthcare domain
@enduml