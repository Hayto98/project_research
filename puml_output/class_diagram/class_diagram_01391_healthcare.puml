@startuml
skinparam monochrome true
skinparam shadowing true
interface Ward {
  #long type
  -double level
  +validateEmail()
  +setId()
}
abstract class Diagnosis {
  +int status
  +float active
  #String updatedAt
  -Date id
  -double address
  +updateScore()
  +createId()
  +getPhone()
}
interface Hospital {
  #float address
  #long name
  #double total
  +String price
  +double phone
  +setId()
  +validateName()
  +findEmail()
  +deleteDescription()
}
abstract class Appointment {
  -Date type
  #double name
  +deleteEmail()
}
class Nurse {
  -Date name
  -boolean email
  -boolean code
  +createAddress()
  +findId()
}
Nurse --> Diagnosis : "1..*"
Ward ..|> Diagnosis
@enduml