@startuml
skinparam monochrome true
skinparam shadowing true
interface Ward {
  #long type
  -double level
  +setDuration()
  +processActive()
}
interface Diagnosis {
  +int status
  +float active
  #String updatedAt
  -Date id
  -double address
  +findTotal()
  +sendActive()
  +processAddress()
}
class Hospital {
  +String price
  +double phone
  -boolean active
  -boolean level
  -String total
  +getAddress()
  +saveLevel()
  +calculateId()
  +updateDescription()
}
class Appointment {
  -boolean code
  +String note
  +String type
  #float active
  +sendPhone()
  +setUpdatedat()
}
class Nurse {
  +long createdAt
  #double email
  +createName()
}
Diagnosis ..> Hospital : "1"
Appointment --* Diagnosis
note right of Ward : Healthcare domain
@enduml