@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Room {
  #float active
  -Date description
  -float code
  +calculateNote()
  +calculatePrice()
}
class Reservation {
  -boolean phone
  +Date score
  +updatePhone()
  +createCreatedat()
  +findLevel()
  +cancelEmail()
}
class CheckIn {
  #String type
  #String score
  -Date level
  +double phone
  -double name
  +updateCreatedat()
  +cancelPhone()
  +createName()
}
interface CheckOut {
  -Date total
  +Date score
  +Date updatedAt
  +long duration
  -boolean amount
  +updateCode()
  +calculateScore()
  +calculatePrice()
  +sendEmail()
}
class Staff {
  +boolean level
  #boolean createdAt
  -int total
  +int amount
  +findActive()
  +createId()
}
abstract class Payment {
  -double quantity
  #boolean address
  +int active
  +Date total
  +calculateAmount()
  +processName()
}
Staff --o Payment
Reservation --o Payment
Room --> Staff : "1"
CheckIn ..|> Payment
Room ..> Payment : "1"
note right of Room : Hotel domain
@enduml