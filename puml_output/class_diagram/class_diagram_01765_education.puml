@startuml
skinparam ArrowColor #555555
class Teacher {
  +double email
  -boolean duration
  +saveEmail()
  +cancelCreatedat()
}
interface Classroom {
  +double active
  +int score
  +String total
  +saveCreatedat()
  +getType()
  +findAmount()
  +saveId()
}
interface Grade {
  +float total
  +int price
  #double active
  -long amount
  +int updatedAt
  +sendActive()
  +processScore()
}
class Enrollment {
  +String score
  -double amount
  -boolean level
  -long name
  -boolean quantity
  +processName()
  +processQuantity()
}
abstract class Attendance {
  -Date duration
  +float createdAt
  -boolean address
  +createType()
  +deleteDescription()
  +setScore()
}
abstract class Schedule {
  +float description
  #int createdAt
  +getUpdatedat()
  +calculateAmount()
  +validateLevel()
}
interface Student {
  +boolean active
  #Date name
  +setDescription()
  +getCode()
  +validatePhone()
}
Attendance --|> Classroom
Attendance --> Student : "0..1"
Grade --|> Schedule
Classroom --> Student : "1"
Grade --> Student : "1"
Student --> Grade : "1..*"
@enduml