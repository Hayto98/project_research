@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
interface Shelf {
  #int level
  -long name
  +findAddress()
  +calculatePhone()
  +processType()
  +cancelEmail()
}
class Member {
  #String address
  #boolean duration
  -String status
  +double description
  +long email
  +deleteDescription()
  +deleteStatus()
}
interface Book {
  #long price
  +String email
  +float status
  +saveDuration()
}
class Publisher {
  #float phone
  +double updatedAt
  #String duration
  #int description
  #float createdAt
  +sendPhone()
}
Shelf --o Member
Member --|> Book
note right of Shelf : Library domain
@enduml