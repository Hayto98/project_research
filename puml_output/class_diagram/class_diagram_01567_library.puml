@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
interface Shelf {
  #int level
  -long name
  +getActive()
  +validateScore()
  +processLevel()
  +deleteCode()
}
abstract class Member {
  -String level
  +long email
  #String phone
  #boolean price
  -String address
  +saveCode()
  +deleteEmail()
}
class Book {
  +String active
  #int updatedAt
  -long description
  #String score
  +createCode()
  +cancelEmail()
  +processCreatedat()
}
class Publisher {
  -float duration
  -Date name
  +setDuration()
  +processStatus()
}
Member ..|> Book
Publisher --|> Book
@enduml