@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
interface Profile {
  -float type
  #Date updatedAt
  +saveCreatedat()
  +validateUpdatedat()
}
class Comment {
  -long phone
  +String description
  +double active
  +findQuantity()
  +sendUpdatedat()
}
class Report {
  -long note
  #double description
  -float code
  -String id
  +boolean name
  +processPrice()
  +createType()
  +createAddress()
}
class Story {
  +long description
  +String active
  +validateAddress()
}
class Like {
  -String active
  +long status
  -float description
  #boolean total
  #boolean note
  +getName()
  +calculateQuantity()
  +updateType()
}
Comment --* Report
Comment --> Profile : "0..1"
@enduml