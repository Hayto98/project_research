@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
abstract class Student {
  -double duration
  +int address
  #Date quantity
  #double code
  +cancelAddress()
  +saveTotal()
  +updateType()
}
class Library {
  -String level
  -double phone
  +findScore()
  +createActive()
}
abstract class Assignment {
  +boolean score
  #int active
  +int price
  +long description
  +int address
  +createCode()
  +processTotal()
  +saveNote()
}
abstract class Classroom {
  #Date description
  #float name
  +boolean id
  +long total
  +Date score
  +createId()
  +processDescription()
  +setUpdatedat()
}
class Teacher {
  #Date id
  +double level
  -float code
  +sendPrice()
  +setNote()
  +deleteQuantity()
  +setEmail()
}
Teacher --> Assignment : "0..1"
Student --o Assignment
Classroom --> Teacher : "0..1"
Assignment --* Teacher
note right of Student : Education domain
@enduml