@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
abstract class Student {
  -double duration
  +int address
  #Date quantity
  #double code
  +getCode()
  +calculateName()
  +cancelScore()
}
abstract class Library {
  #Date type
  #boolean description
  -long code
  +validateUpdatedat()
}
abstract class Assignment {
  -double score
  #float quantity
  #double active
  +validateScore()
  +getTotal()
}
interface Classroom {
  -String code
  +long amount
  -String name
  +sendStatus()
  +saveTotal()
  +processLevel()
  +sendDuration()
}
abstract class Teacher {
  +Date price
  #float description
  #float name
  +boolean id
  +long total
  +processNote()
  +deleteEmail()
}
Assignment --o Student
Library ..> Student : "0..1"
Assignment --|> Library
@enduml