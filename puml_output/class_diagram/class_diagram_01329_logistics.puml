@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Manifest {
  +int id
  -int note
  -String active
  +cancelQuantity()
  +cancelType()
}
interface Warehouse {
  -boolean description
  #double amount
  +updateStatus()
}
abstract class Shipment {
  #String code
  #boolean updatedAt
  +findId()
  +getStatus()
  +sendEmail()
}
class Inventory {
  #float price
  +int name
  +getActive()
  +processActive()
  +sendCreatedat()
  +getPrice()
}
class FuelLog {
  #long code
  -long phone
  +setCreatedat()
  +processDuration()
}
class Customer {
  #long status
  +Date code
  -String note
  #double id
  #int email
  +createEmail()
  +createPhone()
}
class Package {
  +float description
  #String status
  +getStatus()
  +calculateCode()
  +updateDuration()
  +updatePrice()
}
Package --|> Shipment
Warehouse --|> Package
@enduml