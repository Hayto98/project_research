@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Teller {
  -boolean active
  +String duration
  +long phone
  #double status
  +createPhone()
  +sendEmail()
  +validateActive()
  +createDescription()
}
class Transaction {
  #int phone
  -boolean code
  #boolean amount
  +validatePhone()
}
class Account {
  #double phone
  +long price
  -long type
  +long score
  +validateEmail()
  +calculatePhone()
  +createAmount()
  +saveQuantity()
}
class Statement {
  -int total
  #long note
  +findCode()
  +processTotal()
}
interface Beneficiary {
  -double email
  -float address
  +createCode()
}
Teller --o Account
Statement --* Teller
Transaction --o Beneficiary
@enduml