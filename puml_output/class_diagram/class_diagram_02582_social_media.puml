@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
abstract class User {
  #boolean duration
  +double status
  +deletePrice()
  +getPrice()
  +deleteEmail()
}
abstract class Follower {
  -double createdAt
  +double duration
  +double description
  +sendCode()
  +getPhone()
  +validatePrice()
  +sendStatus()
}
class Message {
  #float note
  -String score
  #long duration
  +boolean name
  +deleteUpdatedat()
  +updateUpdatedat()
  +getPrice()
  +findPhone()
}
interface Profile {
  -boolean email
  #double duration
  +int code
  #String amount
  +processScore()
  +saveCode()
  +createType()
}
interface Hashtag {
  #float total
  #long id
  +saveScore()
  +processDescription()
}
abstract class Report {
  +boolean total
  +float name
  +createActive()
  +calculateDescription()
}
class Comment {
  #long updatedAt
  -boolean amount
  #double address
  #long level
  #float active
  +processLevel()
}
Report ..> Message : "*"
Message --> Report : "0..1"
Message ..> Comment : "1"
note right of User : Social Media domain
@enduml