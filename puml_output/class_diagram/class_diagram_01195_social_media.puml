@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Follower {
  -float id
  #Date amount
  -String updatedAt
  +double price
  -double description
  +deletePhone()
}
interface Album {
  -Date total
  -double description
  #boolean address
  +savePrice()
  +updateDuration()
  +calculateQuantity()
}
interface Group {
  -boolean score
  -int type
  +sendAmount()
}
class Comment {
  #String name
  +String score
  +float address
  +createActive()
  +findActive()
  +updateLevel()
  +sendAddress()
}
class User {
  #float id
  -int name
  +boolean score
  -boolean note
  #long duration
  +saveTotal()
  +updateDuration()
  +validateEmail()
  +processPrice()
}
Group --o Follower
Follower --o Group
Follower ..|> User
note right of Follower : Social Media domain
@enduml