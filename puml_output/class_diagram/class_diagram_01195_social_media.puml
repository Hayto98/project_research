@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Follower {
  -float id
  #Date amount
  -String updatedAt
  +double price
  -double description
  +saveAddress()
}
class Album {
  -Date total
  -double description
  #boolean address
  +createId()
  +sendPrice()
  +createPrice()
}
class Group {
  #double quantity
  +String score
  #int id
  +int type
  #String active
  +sendStatus()
  +cancelAmount()
  +updateActive()
}
class Comment {
  -boolean createdAt
  #boolean total
  +findName()
  +setAddress()
}
class User {
  #double total
  #Date id
  +float name
  +processActive()
  +cancelEmail()
  +saveDuration()
  +deleteAmount()
}
Group ..> Comment : "*"
Album ..> Group : "1..*"
Comment --* User
Group --o Follower
@enduml