@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
abstract class Album {
  #int active
  -int name
  #Date level
  #long quantity
  +saveName()
  +getPrice()
  +saveCreatedat()
  +findActive()
}
class Comment {
  #boolean id
  +Date price
  -Date quantity
  #Date description
  #long level
  +calculateAddress()
}
abstract class User {
  -Date note
  #Date description
  -int status
  -float code
  #Date name
  +calculateQuantity()
  +getTotal()
}
abstract class Hashtag {
  -float active
  -String name
  #Date updatedAt
  +calculateDescription()
  +cancelPhone()
  +sendDuration()
  +saveStatus()
}
Album --o Comment
User --|> Hashtag
Hashtag --|> Comment
note right of Album : Social Media domain
@enduml