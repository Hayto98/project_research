@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
abstract class Album {
  #int active
  -int name
  #Date level
  #long quantity
  +getName()
  +sendDuration()
  +setUpdatedat()
  +updateDuration()
}
abstract class Comment {
  +double active
  -Date email
  #float note
  +findPrice()
  +cancelActive()
}
abstract class User {
  +double quantity
  -double active
  #float duration
  +createName()
  +deleteEmail()
  +saveDescription()
  +createCreatedat()
}
class Hashtag {
  #float name
  #Date type
  +updateStatus()
  +setTotal()
  +getDuration()
}
Hashtag --|> Comment
@enduml