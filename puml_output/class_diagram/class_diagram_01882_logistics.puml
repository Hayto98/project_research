@startuml
skinparam defaultFontSize 11
interface Route {
  -float phone
  +int name
  +getPrice()
  +setCode()
  +updateActive()
}
class FuelLog {
  #boolean note
  #long status
  #float price
  +long active
  -float code
  +findQuantity()
  +processUpdatedat()
  +cancelDescription()
  +findDescription()
}
abstract class Package {
  #float active
  #long quantity
  -String score
  +deleteEmail()
  +createScore()
}
interface Vehicle {
  -int description
  +Date duration
  #boolean createdAt
  +createCode()
  +calculateActive()
  +deletePrice()
  +createPhone()
}
class Depot {
  +Date description
  -Date address
  -float phone
  -double score
  -int type
  +setStatus()
  +cancelQuantity()
}
Package --> Vehicle : "1"
Route ..|> FuelLog
Vehicle ..> Depot : "0..1"
@enduml