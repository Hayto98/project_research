@startuml
skinparam defaultFontSize 11
interface Route {
  -float phone
  +int name
  +findId()
  +updateType()
  +processStatus()
}
abstract class FuelLog {
  #float level
  +long quantity
  +sendActive()
  +sendScore()
  +findType()
  +validateAmount()
}
interface Package {
  +int createdAt
  +Date active
  #int quantity
  +int email
  +long type
  +deleteLevel()
  +processAmount()
}
interface Vehicle {
  #long status
  -double name
  +Date type
  -Date description
  -float address
  +processPrice()
  +updateCreatedat()
  +setNote()
  +processPhone()
}
abstract class Depot {
  +double status
  #boolean createdAt
  +saveActive()
  +updatePhone()
  +getCode()
  +createActive()
}
Package --o FuelLog
Depot --> FuelLog : "1"
Route --> Vehicle : "*"
note right of Route : Logistics domain
@enduml