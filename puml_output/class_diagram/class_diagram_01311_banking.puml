@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
interface Beneficiary {
  +String id
  +Date createdAt
  +int type
  -Date phone
  +setType()
  +createDuration()
  +updateId()
}
interface Transfer {
  #float description
  -long type
  +boolean address
  #boolean total
  +String score
  +processAddress()
  +sendId()
  +setName()
  +getDescription()
}
abstract class Interest {
  +Date description
  +int amount
  +findQuantity()
  +saveAddress()
  +findDuration()
  +createDescription()
}
class Customer {
  +long price
  -double status
  #String type
  -boolean active
  -int name
  +updateActive()
  +sendTotal()
  +setEmail()
}
abstract class Statement {
  -int phone
  -float code
  -long status
  +getName()
  +findPrice()
}
abstract class Branch {
  #float type
  +String status
  +int note
  #int level
  +String email
  +findName()
  +validateQuantity()
  +cancelCode()
  +saveQuantity()
}
class Loan {
  -Date description
  #boolean createdAt
  #double score
  #int name
  +getName()
  +validateType()
  +sendDescription()
  +sendActive()
}
Loan ..|> Branch
Beneficiary --o Customer
@enduml