@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Beneficiary {
  +boolean status
  +boolean type
  #Date quantity
  +cancelPrice()
  +createEmail()
  +calculateAddress()
  +updatePrice()
}
class Transaction {
  +int price
  #float status
  +boolean updatedAt
  +validateUpdatedat()
  +cancelName()
}
interface Interest {
  #Date status
  +double name
  +double phone
  #Date description
  +setScore()
}
interface Branch {
  +float phone
  +boolean id
  -boolean name
  #String updatedAt
  +createCreatedat()
  +validateDescription()
  +setName()
}
Beneficiary ..|> Branch
Beneficiary ..> Interest : "1"
note right of Beneficiary : Banking domain
@enduml