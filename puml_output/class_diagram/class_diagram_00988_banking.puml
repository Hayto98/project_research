@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Beneficiary {
  +boolean status
  +boolean type
  #Date quantity
  +findName()
  +processScore()
  +createDuration()
  +deletePhone()
}
class Transaction {
  -boolean price
  +float address
  -String updatedAt
  +float duration
  +createCreatedat()
  +cancelAmount()
}
class Interest {
  #float phone
  #boolean updatedAt
  -String name
  +updateTotal()
}
class Branch {
  -Date type
  #String id
  +cancelAmount()
}
Interest --> Beneficiary : "1"
Transaction --|> Beneficiary
Interest --> Branch : "1"
@enduml