@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Prescription {
  +int updatedAt
  #String duration
  +createPhone()
  +getDescription()
  +savePhone()
}
class Treatment {
  +long type
  +boolean score
  +cancelPrice()
}
class Insurance {
  #Date level
  #String note
  #double createdAt
  +boolean score
  +findPrice()
  +findEmail()
  +cancelQuantity()
}
class Appointment {
  #int price
  +String level
  +getScore()
  +deleteId()
}
Insurance --|> Prescription
Appointment --o Insurance
@enduml