@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Prescription {
  +int updatedAt
  #String duration
  +setName()
  +createLevel()
  +cancelStatus()
}
abstract class Treatment {
  #int phone
  #float id
  #float status
  +cancelDuration()
  +processCreatedat()
  +sendLevel()
}
class Insurance {
  #long price
  #double description
  +getPrice()
  +cancelCreatedat()
}
class Appointment {
  #String duration
  -String createdAt
  +processLevel()
}
Appointment --|> Treatment
Insurance --* Treatment
Appointment --* Prescription
note right of Prescription : Healthcare domain
@enduml