@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
abstract class Interest {
  +boolean note
  #int level
  +sendActive()
  +deleteDuration()
}
class Branch {
  +float amount
  +int code
  +createCode()
  +sendDuration()
  +getCreatedat()
  +setEmail()
}
abstract class Transfer {
  #long price
  #float description
  -boolean note
  #double amount
  +validateTotal()
}
class Transaction {
  #String code
  #String total
  +sendUpdatedat()
}
interface Card {
  +Date phone
  -float price
  -double code
  +setActive()
}
interface Statement {
  -Date amount
  +Date updatedAt
  +String price
  +long name
  +cancelAmount()
}
interface Account {
  #long level
  +long code
  -String email
  +sendName()
  +processName()
  +cancelName()
  +findDuration()
}
Card --|> Transfer
Statement --* Interest
Statement --* Account
Transfer ..> Interest : "*"
Interest --* Statement
Statement ..|> Transfer
@enduml