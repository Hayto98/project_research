@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Review {
  -boolean id
  +String phone
  -long email
  +updateType()
  +savePhone()
  +createTotal()
}
interface Warehouse {
  +float status
  +double id
  -long updatedAt
  +createNote()
  +cancelId()
  +sendDuration()
}
class Cart {
  #Date active
  +float score
  #boolean total
  +Date updatedAt
  -float quantity
  +saveNote()
  +setType()
  +createStatus()
  +setStatus()
}
class Coupon {
  #boolean createdAt
  +String note
  +double quantity
  +cancelId()
  +updateCode()
}
class Supplier {
  +float type
  -Date score
  +Date active
  -int price
  +deleteDescription()
  +validateTotal()
  +findActive()
  +updateAmount()
}
Review --|> Cart
Coupon --|> Cart
@enduml