@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Review {
  -boolean id
  +String phone
  -long email
  +deleteName()
  +findLevel()
  +deleteStatus()
}
class Warehouse {
  -long createdAt
  -long updatedAt
  #long price
  +sendScore()
  +saveTotal()
  +saveUpdatedat()
  +createDuration()
}
class Cart {
  +boolean type
  +int total
  +float createdAt
  +processQuantity()
  +sendActive()
}
class Coupon {
  #float createdAt
  +long price
  +createType()
  +sendActive()
}
abstract class Supplier {
  #float address
  -int updatedAt
  +cancelType()
  +calculateId()
  +sendPhone()
  +getType()
}
Review --* Supplier
Coupon --> Review : "1"
Cart --> Warehouse : "0..1"
note right of Review : Ecommerce domain
@enduml