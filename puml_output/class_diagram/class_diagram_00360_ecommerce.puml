@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
abstract class Category {
  #String description
  #float note
  #Date status
  +int name
  +updateDuration()
  +saveName()
  +calculateScore()
  +getScore()
}
interface Wishlist {
  +boolean name
  +boolean description
  #float code
  -float email
  +sendDuration()
  +getStatus()
  +processUpdatedat()
  +saveScore()
}
class Supplier {
  -double email
  #int amount
  -String description
  +validateQuantity()
  +processScore()
  +savePhone()
}
class Return {
  #double address
  -float quantity
  +boolean phone
  +deleteActive()
  +getEmail()
  +cancelAmount()
}
interface Warehouse {
  -String description
  -Date score
  +long updatedAt
  +Date note
  +deleteEmail()
  +createCode()
}
Warehouse --o Category
@enduml