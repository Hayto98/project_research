@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
abstract class Category {
  #String description
  #float note
  #Date status
  +int name
  +getPrice()
  +createActive()
  +sendDuration()
  +validateName()
}
class Wishlist {
  #int email
  #boolean description
  +processAmount()
  +validateAddress()
  +saveUpdatedat()
}
class Supplier {
  -boolean duration
  +long description
  +Date note
  +deleteName()
  +updateUpdatedat()
  +validateDuration()
}
class Return {
  -int note
  #boolean price
  #long id
  +Date quantity
  +saveNote()
  +calculateCode()
}
class Warehouse {
  #float phone
  +int name
  +sendName()
}
Warehouse ..|> Category
Supplier --o Warehouse
Warehouse ..|> Return
note right of Category : Ecommerce domain
@enduml