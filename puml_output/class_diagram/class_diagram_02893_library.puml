@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
abstract class Publisher {
  -double quantity
  -float address
  #boolean phone
  +boolean total
  +validateCreatedat()
  +processNote()
  +findStatus()
}
interface Branch {
  -Date level
  #long phone
  -int total
  +Date id
  +float quantity
  +createPrice()
}
class Member {
  -Date email
  #boolean total
  #long createdAt
  +long code
  -int address
  +deleteNote()
  +calculateScore()
}
class Renewal {
  #boolean amount
  #String email
  #boolean duration
  #boolean score
  +createDescription()
  +getType()
  +getActive()
}
Branch ..|> Publisher
Publisher --o Renewal
@enduml