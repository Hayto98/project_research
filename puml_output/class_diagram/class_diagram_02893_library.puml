@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
abstract class Publisher {
  -double quantity
  -float address
  #boolean phone
  +boolean total
  +deleteScore()
  +processLevel()
  +validateTotal()
}
class Branch {
  +String quantity
  #float score
  +float email
  +double price
  +processEmail()
  +calculateCreatedat()
  +setAddress()
}
class Member {
  +String updatedAt
  -float quantity
  +long address
  +long description
  +deleteScore()
  +sendActive()
}
class Renewal {
  +int active
  #String code
  +double updatedAt
  #int amount
  +deleteCreatedat()
  +getScore()
  +validateId()
  +findName()
}
Renewal --|> Member
Publisher --|> Renewal
note right of Publisher : Library domain
@enduml