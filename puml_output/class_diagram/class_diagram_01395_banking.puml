@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
interface Interest {
  +double id
  #int note
  +updatePhone()
  +deleteId()
  +updateAddress()
}
class Customer {
  #long code
  +Date updatedAt
  +boolean amount
  +long active
  +boolean createdAt
  +setCode()
  +saveUpdatedat()
  +findStatus()
  +deleteAddress()
}
abstract class Branch {
  +boolean description
  #long score
  #long status
  +boolean createdAt
  +double duration
  +cancelName()
}
abstract class Account {
  +long name
  #Date level
  +saveTotal()
  +calculateAddress()
  +findAmount()
}
class Transaction {
  +boolean active
  #float address
  +getLevel()
}
class Statement {
  +double updatedAt
  +double code
  #double id
  #boolean createdAt
  #Date type
  +getNote()
  +processNote()
}
class Card {
  #boolean email
  #double createdAt
  +int note
  -int amount
  +processTotal()
  +sendCode()
  +processPrice()
  +saveAmount()
}
Card ..> Transaction : "1"
Statement --> Card : "0..1"
Branch ..> Statement : "*"
Customer --> Transaction : "1..*"
@enduml