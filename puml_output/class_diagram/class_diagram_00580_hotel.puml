@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
abstract class Housekeeping {
  -int note
  #long createdAt
  +long quantity
  -long email
  +calculatePhone()
  +cancelStatus()
  +cancelType()
}
interface CheckIn {
  -float amount
  #float price
  +cancelLevel()
  +processEmail()
}
class Room {
  -double updatedAt
  #String address
  -Date note
  +deletePhone()
  +updateUpdatedat()
}
class Guest {
  -float amount
  #double active
  +long name
  +float address
  +saveUpdatedat()
  +processLevel()
  +calculateId()
  +deleteDuration()
}
Guest ..> CheckIn : "0..1"
Room --o Guest
@enduml