@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
abstract class Billing {
  #boolean email
  #Date code
  +double quantity
  -String updatedAt
  +calculateScore()
  +deleteScore()
}
abstract class Nurse {
  #boolean score
  -float phone
  +sendActive()
  +validateEmail()
}
class MedicalRecord {
  #String quantity
  -double status
  +boolean updatedAt
  +String amount
  +double level
  +processEmail()
}
abstract class Hospital {
  #int quantity
  #double amount
  #double email
  -String status
  -int name
  +updateQuantity()
  +saveCreatedat()
  +cancelType()
}
abstract class Prescription {
  #boolean note
  -Date code
  +findEmail()
  +sendDuration()
  +createAddress()
  +createCreatedat()
}
Hospital --|> Nurse
Prescription --> Hospital : "1"
Prescription --|> Nurse
@enduml