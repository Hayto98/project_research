@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
abstract class Account {
  -int price
  -float amount
  #double note
  +boolean quantity
  +setAmount()
}
class Customer {
  +int amount
  -int phone
  +calculateLevel()
  +updateQuantity()
  +updateQuantity()
}
abstract class Statement {
  #boolean type
  +int amount
  -float quantity
  +getScore()
}
abstract class Deposit {
  +long address
  #int phone
  +boolean type
  +float note
  +validateQuantity()
  +processAmount()
}
class Card {
  +Date updatedAt
  #boolean score
  #int name
  +Date type
  +getAmount()
  +setEmail()
  +createDescription()
  +getStatus()
}
interface Transaction {
  #double phone
  +double description
  #String duration
  +processAddress()
  +updateActive()
  +deleteActive()
}
Transaction --|> Account
Deposit --* Card
Customer ..|> Account
note right of Account : Banking domain
@enduml