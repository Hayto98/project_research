@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
abstract class Account {
  -int price
  -float amount
  #double note
  +boolean quantity
  +validateId()
}
class Customer {
  +int id
  -int amount
  -double phone
  +findScore()
  +saveNote()
}
class Statement {
  +double updatedAt
  +String type
  #boolean amount
  -long quantity
  -long description
  +sendCode()
  +deleteAddress()
  +validateAmount()
  +saveUpdatedat()
}
class Deposit {
  #int duration
  -long description
  +calculateTotal()
  +processUpdatedat()
  +processPrice()
  +validateDuration()
}
class Card {
  #Date type
  #Date code
  +sendEmail()
  +cancelName()
}
abstract class Transaction {
  -long amount
  +String code
  +getPrice()
}
Statement --* Customer
Transaction ..|> Deposit
Deposit --> Account : "1..*"
@enduml