@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Statement {
  +int quantity
  +double duration
  #boolean phone
  #float status
  +cancelId()
  +findUpdatedat()
}
class Deposit {
  -long duration
  +String amount
  -String price
  +float note
  #Date address
  +findNote()
  +findName()
  +saveScore()
}
class Interest {
  #String name
  -boolean amount
  +saveDescription()
  +validateDescription()
  +processNote()
}
interface Beneficiary {
  #Date createdAt
  -int active
  #long code
  +createType()
  +validateUpdatedat()
  +processLevel()
}
abstract class Account {
  #long updatedAt
  +long note
  +float level
  +getType()
  +cancelType()
}
class Teller {
  #double email
  -boolean createdAt
  +sendScore()
  +sendAmount()
}
Account ..|> Teller
Beneficiary --* Interest
Teller --|> Beneficiary
Deposit --* Teller
Account --o Statement
note right of Statement : Banking domain
@enduml