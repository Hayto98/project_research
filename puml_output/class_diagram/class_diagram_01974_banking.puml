@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Statement {
  +int quantity
  +double duration
  #boolean phone
  #float status
  +createNote()
  +getDescription()
}
interface Deposit {
  -boolean updatedAt
  #boolean amount
  +calculateCode()
  +createName()
}
class Interest {
  +String phone
  #Date name
  #long id
  #float address
  +setCode()
  +calculateStatus()
  +cancelType()
  +calculateEmail()
}
interface Beneficiary {
  +Date id
  +double name
  +updateAddress()
  +setLevel()
  +updateAmount()
}
class Account {
  +Date type
  +boolean note
  #boolean active
  +setPhone()
}
abstract class Teller {
  -float active
  -float address
  -Date quantity
  +getId()
  +savePrice()
}
Deposit ..> Teller : "*"
Beneficiary --* Account
Statement --|> Interest
Account --|> Deposit
@enduml