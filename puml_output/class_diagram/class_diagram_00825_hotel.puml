@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Room {
  #String type
  +long email
  #long quantity
  +deleteQuantity()
}
class Booking {
  -Date duration
  #Date name
  #Date updatedAt
  +processLevel()
}
interface Service {
  +boolean active
  #long quantity
  +int phone
  +getStatus()
  +validateDescription()
  +deletePrice()
}
abstract class Reservation {
  -Date phone
  #float email
  +validateQuantity()
  +createCreatedat()
}
interface Payment {
  -float note
  +String type
  #double active
  -boolean createdAt
  +cancelId()
  +saveDescription()
  +validateId()
}
Service --o Booking
Service --* Room
Service ..|> Payment
Booking --|> Service
@enduml