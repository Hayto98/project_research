@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Interest {
  -boolean total
  -Date note
  #float name
  -int type
  +saveNote()
  +cancelAddress()
  +setStatus()
}
abstract class Beneficiary {
  #Date name
  -int level
  +int score
  +processAmount()
}
interface Account {
  -long amount
  #double duration
  +double status
  +Date total
  -int phone
  +findUpdatedat()
  +setLevel()
}
class Transfer {
  #Date total
  #String address
  +validateQuantity()
  +setName()
}
Interest --> Account : "1"
Account --|> Transfer
Beneficiary --|> Account
@enduml