@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Treatment {
  +String total
  +int level
  #String score
  +setScore()
  +validateActive()
}
abstract class Appointment {
  -boolean address
  -boolean email
  +Date quantity
  #float note
  +findPrice()
  +setAddress()
  +validateTotal()
  +setCreatedat()
}
class Diagnosis {
  +Date createdAt
  +Date status
  -float duration
  +int score
  -boolean name
  +cancelAddress()
  +updateScore()
}
class Nurse {
  -Date note
  #String price
  +saveDescription()
}
class Doctor {
  +int name
  +long active
  +validatePhone()
}
Treatment ..|> Appointment
Diagnosis --o Doctor
note right of Treatment : Healthcare domain
@enduml