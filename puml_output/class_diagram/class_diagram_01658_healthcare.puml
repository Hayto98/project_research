@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Treatment {
  +String total
  +int level
  #String score
  +calculateType()
  +createAddress()
}
interface Appointment {
  -long active
  #double price
  -boolean address
  -boolean score
  +processNote()
}
interface Diagnosis {
  +int price
  +double status
  #int address
  +Date score
  +int total
  +processPhone()
}
class Nurse {
  +long total
  #int amount
  +calculateNote()
  +getCreatedat()
  +updateLevel()
}
class Doctor {
  -boolean price
  +String phone
  #int code
  +String name
  -float description
  +sendPhone()
}
Appointment ..> Treatment : "0..1"
Appointment ..> Diagnosis : "1..*"
Nurse --> Diagnosis : "0..1"
@enduml