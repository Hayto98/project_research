@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
abstract class Shipment {
  #String status
  +String score
  +cancelName()
}
interface Customer {
  +long total
  -String description
  +long code
  #boolean quantity
  +validateActive()
  +saveName()
}
interface Manifest {
  -boolean duration
  #float createdAt
  +String email
  +boolean code
  -String active
  +calculateScore()
  +createEmail()
  +saveCode()
}
abstract class Warehouse {
  -boolean score
  #float updatedAt
  +boolean duration
  #boolean description
  +getName()
  +deleteNote()
  +setUpdatedat()
}
abstract class Route {
  +long score
  #Date duration
  -int id
  +String status
  +validateName()
  +processPrice()
  +setId()
}
Customer --|> Warehouse
Route --* Warehouse
Manifest --|> Customer
@enduml