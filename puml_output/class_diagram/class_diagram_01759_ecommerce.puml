@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Product {
  #boolean amount
  +Date description
  +Date score
  #int note
  +calculateAmount()
  +deleteEmail()
  +deletePrice()
}
interface Wishlist {
  -String email
  #long duration
  +getActive()
  +cancelName()
  +processName()
}
class Order {
  +Date name
  #long type
  +updateAmount()
  +saveUpdatedat()
  +saveCreatedat()
  +calculateUpdatedat()
}
interface Invoice {
  +float code
  -double quantity
  -boolean amount
  -String phone
  +int type
  +updatePhone()
}
Invoice --|> Product
Wishlist --o Invoice
note right of Product : Ecommerce domain
@enduml