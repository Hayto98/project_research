@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Product {
  #boolean amount
  +Date description
  +Date score
  #int note
  +saveName()
  +findTotal()
  +createCode()
}
class Wishlist {
  #boolean description
  -double price
  +float id
  #long email
  +validateDescription()
  +processName()
  +sendQuantity()
}
interface Order {
  -String type
  +double name
  +calculateStatus()
  +getAmount()
}
class Invoice {
  +boolean createdAt
  -String amount
  -int updatedAt
  #boolean duration
  -float total
  +validateStatus()
  +setStatus()
  +getDescription()
  +validateUpdatedat()
}
Order --* Invoice
Product ..|> Invoice
@enduml