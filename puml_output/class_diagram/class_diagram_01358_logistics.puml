@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
interface Driver {
  -int price
  +double quantity
  +String email
  #int active
  +double total
  +saveCode()
  +validateDescription()
  +findStatus()
  +deleteEmail()
}
abstract class Package {
  -boolean total
  -Date email
  +Date level
  #float address
  -String name
  +setId()
  +createNote()
  +getDescription()
  +processPrice()
}
interface DeliveryNote {
  +long total
  -String name
  #double createdAt
  +float phone
  -float note
  +deleteCode()
  +calculateTotal()
}
interface Manifest {
  #Date id
  #String phone
  #Date address
  +findLevel()
  +createTotal()
  +updateCreatedat()
  +saveEmail()
}
interface FuelLog {
  -double score
  -boolean active
  +boolean level
  +findName()
  +saveAmount()
  +saveQuantity()
  +updateAmount()
}
class Depot {
  -int price
  +long phone
  -boolean type
  #Date name
  +getAddress()
  +sendPrice()
}
FuelLog --* Manifest
Package --* FuelLog
Manifest --> FuelLog : "0..1"
@enduml