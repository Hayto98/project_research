@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
interface Driver {
  -int price
  +double quantity
  +String email
  #int active
  +double total
  +calculateTotal()
  +calculateTotal()
  +createEmail()
  +validateName()
}
abstract class Package {
  #boolean createdAt
  -double total
  +int code
  -boolean level
  -String updatedAt
  +processStatus()
  +sendNote()
  +updateEmail()
}
class DeliveryNote {
  -long level
  #Date active
  #String createdAt
  #Date id
  +findName()
  +findDuration()
  +updateScore()
  +sendActive()
}
class Manifest {
  +String total
  -float active
  -long amount
  -String price
  -int note
  +validateAddress()
  +sendDescription()
}
abstract class FuelLog {
  +boolean duration
  -double price
  #boolean email
  +getQuantity()
  +setActive()
}
class Depot {
  -int description
  #double price
  #int amount
  +processName()
  +updateDuration()
  +saveEmail()
}
Manifest --> Package : "1..*"
Depot --* DeliveryNote
FuelLog --|> Depot
note right of Driver : Logistics domain
@enduml