@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Product {
  #boolean active
  +String code
  #Date duration
  -Date address
  +float total
  +deleteAddress()
  +deleteQuantity()
  +calculateCode()
}
class Warehouse {
  #Date quantity
  #String status
  -String active
  +createPhone()
  +setTotal()
  +updateCreatedat()
}
abstract class Review {
  #double description
  #long updatedAt
  #Date name
  +findStatus()
}
interface Payment {
  +Date type
  #int score
  -float quantity
  #String active
  +long name
  +updateLevel()
}
abstract class Shipment {
  -Date code
  -boolean updatedAt
  #String total
  +saveEmail()
}
interface Invoice {
  #Date updatedAt
  -long level
  +findEmail()
  +createStatus()
  +sendPrice()
}
interface Coupon {
  +boolean amount
  #Date price
  +validateDuration()
}
Invoice ..|> Warehouse
Product ..|> Payment
@enduml