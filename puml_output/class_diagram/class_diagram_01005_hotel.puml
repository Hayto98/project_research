@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Staff {
  #String type
  -float createdAt
  +createPhone()
  +processActive()
}
class Housekeeping {
  #long id
  #float code
  +createName()
  +getAddress()
  +calculateQuantity()
  +createCode()
}
class Amenity {
  +float total
  #float amount
  +findQuantity()
  +cancelAmount()
  +sendLevel()
  +sendUpdatedat()
}
abstract class Service {
  #long price
  -boolean email
  #long total
  +sendName()
  +createName()
}
abstract class Booking {
  +String quantity
  -String level
  +cancelLevel()
}
interface Payment {
  -boolean duration
  +float id
  +createDuration()
  +getUpdatedat()
  +calculateActive()
  +getNote()
}
Staff --|> Booking
Service --* Amenity
Amenity --|> Booking
Housekeeping ..|> Amenity
note right of Staff : Hotel domain
@enduml