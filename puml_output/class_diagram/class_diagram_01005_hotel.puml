@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Staff {
  #String type
  -float createdAt
  +updateLevel()
  +getName()
}
class Housekeeping {
  #long active
  #float phone
  -long id
  #String score
  +long code
  +getNote()
  +processPhone()
  +validateAddress()
  +findNote()
}
class Amenity {
  +float total
  #float amount
  +updateScore()
  +createQuantity()
  +saveDuration()
  +processUpdatedat()
}
interface Service {
  -Date type
  -boolean amount
  -double price
  +setType()
  +calculateActive()
  +deleteNote()
}
class Booking {
  +long total
  #float level
  +validateEmail()
}
class Payment {
  #boolean level
  #float status
  +validateActive()
}
Service --|> Booking
Payment --* Service
@enduml