@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Statement {
  -double email
  -boolean level
  #long score
  +int description
  -boolean active
  +processPhone()
  +updateActive()
  +sendQuantity()
}
interface Loan {
  +String price
  -long total
  +findQuantity()
  +processEmail()
}
class Customer {
  +int createdAt
  +String type
  #float code
  +String phone
  +setType()
  +calculatePhone()
  +calculateCreatedat()
}
interface Beneficiary {
  +int code
  +double active
  +calculateUpdatedat()
  +sendActive()
  +findCreatedat()
  +validateName()
}
interface Deposit {
  #Date address
  #float note
  +float status
  -long amount
  +deleteEmail()
  +processDescription()
}
class Teller {
  #float duration
  -float email
  +sendDescription()
  +cancelTotal()
  +setAmount()
  +deleteUpdatedat()
}
Customer ..> Teller : "*"
note right of Statement : Banking domain
@enduml