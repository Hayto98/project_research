@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Statement {
  -double email
  -boolean level
  #long score
  +int description
  -boolean active
  +validateUpdatedat()
  +updateTotal()
  +saveNote()
}
interface Loan {
  -String level
  +float score
  -long name
  +float price
  +findType()
  +calculateAmount()
  +calculateScore()
}
class Customer {
  +int createdAt
  +String type
  #float code
  +String phone
  +deletePhone()
  +setStatus()
  +sendName()
}
abstract class Beneficiary {
  +boolean total
  +int createdAt
  +double score
  -float code
  +createScore()
  +sendAmount()
  +updateNote()
  +deleteType()
}
class Deposit {
  +Date name
  +boolean phone
  #boolean address
  +float note
  +deleteName()
  +validateQuantity()
  +getDescription()
  +updateType()
}
class Teller {
  -boolean description
  #int createdAt
  #double name
  +Date email
  +int address
  +processNote()
  +createLevel()
}
Customer ..> Teller : "*"
@enduml