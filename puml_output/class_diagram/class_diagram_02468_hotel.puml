@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
interface Staff {
  +String phone
  #long code
  #Date price
  +createEmail()
}
class Payment {
  +int name
  -Date id
  +float updatedAt
  #boolean level
  +updateUpdatedat()
  +validatePhone()
  +processNote()
  +updateActive()
}
interface Reservation {
  #Date id
  -float description
  -double updatedAt
  +double phone
  +sendName()
}
class Guest {
  +long email
  -long level
  #int score
  +Date active
  -Date code
  +updateTotal()
  +validateAmount()
}
abstract class Restaurant {
  #String score
  #boolean email
  +double active
  #double address
  +int code
  +getStatus()
  +getPrice()
  +sendId()
}
interface Housekeeping {
  #float address
  +boolean amount
  +boolean name
  -int quantity
  +cancelUpdatedat()
}
class Booking {
  -double amount
  +float active
  +setAddress()
}
Housekeeping ..> Booking : "1"
Booking ..|> Housekeeping
Housekeeping ..|> Staff
Booking --|> Staff
Restaurant --* Reservation
note right of Staff : Hotel domain
@enduml