@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
interface Staff {
  +String phone
  #long code
  #Date price
  +cancelAddress()
}
class Payment {
  +int email
  +float name
  +sendNote()
  +cancelQuantity()
}
class Reservation {
  -int createdAt
  #float updatedAt
  #boolean phone
  -String score
  #int note
  +findCode()
  +savePrice()
}
abstract class Guest {
  #String note
  +double updatedAt
  #long price
  #Date id
  +processQuantity()
}
class Restaurant {
  #int phone
  +double score
  -Date updatedAt
  +double level
  -Date type
  +getScore()
  +createActive()
  +processAmount()
}
interface Housekeeping {
  -boolean active
  -int name
  +sendDescription()
  +createQuantity()
}
class Booking {
  #String id
  #long price
  +setAmount()
  +validateQuantity()
  +updateId()
}
Restaurant --* Housekeeping
Housekeeping --> Staff : "0..1"
@enduml