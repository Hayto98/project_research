@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
interface Student {
  -Date address
  -double type
  +getName()
  +getCode()
}
class Schedule {
  -Date address
  +long description
  -double email
  #int id
  +cancelUpdatedat()
  +setPhone()
  +setType()
  +cancelPhone()
}
interface Classroom {
  +String note
  +boolean type
  +getName()
  +updateType()
  +sendNote()
}
abstract class Attendance {
  -String code
  #boolean email
  +saveActive()
  +cancelActive()
}
class Library {
  #String updatedAt
  +Date active
  +processName()
  +findType()
}
class Department {
  -double quantity
  -long score
  +updateDescription()
  +saveAddress()
}
Student ..|> Library
Classroom --o Department
@enduml