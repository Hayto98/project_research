@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Route {
  -Date phone
  #float note
  +savePrice()
  +deleteUpdatedat()
}
interface Tracking {
  -float description
  -double active
  +findEmail()
  +savePrice()
  +validateUpdatedat()
  +processCode()
}
abstract class Inventory {
  -int active
  +boolean duration
  +getCreatedat()
  +processType()
  +calculateNote()
  +createCreatedat()
}
interface Driver {
  -Date amount
  -String active
  -double address
  #double status
  #boolean code
  +processAddress()
  +validateAmount()
  +deletePrice()
  +calculateDescription()
}
interface Customer {
  -boolean price
  #Date score
  +boolean total
  #double email
  +getEmail()
  +processScore()
  +savePhone()
}
class Shipment {
  #float level
  -String status
  +calculateUpdatedat()
}
class DeliveryNote {
  #long status
  #double total
  #String name
  +double createdAt
  -Date id
  +sendAddress()
  +savePhone()
}
Shipment --* Tracking
Tracking --* Shipment
Tracking ..|> Inventory
Tracking --> DeliveryNote : "0..1"
Driver --> DeliveryNote : "0..1"
@enduml