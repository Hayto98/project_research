@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Album {
  #float level
  +Date status
  -boolean email
  +calculateEmail()
  +findLevel()
  +createLevel()
}
interface Comment {
  -int code
  -double score
  -String email
  +cancelUpdatedat()
  +updateCreatedat()
  +saveDuration()
  +cancelScore()
}
class Follower {
  +long id
  -boolean total
  -int active
  +saveLevel()
}
interface Notification {
  #boolean note
  +int score
  #Date phone
  +long price
  #float name
  +processPrice()
  +calculateLevel()
  +validateName()
  +sendAddress()
}
Notification --> Album : "1"
Album --|> Comment
@enduml