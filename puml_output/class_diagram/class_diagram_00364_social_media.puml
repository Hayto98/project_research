@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Album {
  #float level
  +Date status
  -boolean email
  +getScore()
  +updateCode()
  +findScore()
}
class Comment {
  +float amount
  -Date address
  #Date type
  -float note
  +getTotal()
  +sendCode()
}
class Follower {
  #double duration
  -float address
  #Date createdAt
  #long name
  +getActive()
  +updateCreatedat()
  +cancelAmount()
  +validateNote()
}
class Notification {
  +double email
  +Date name
  #long price
  #long description
  +long status
  +setPrice()
  +getScore()
  +updateEmail()
}
Comment --|> Notification
Notification --> Album : "1"
note right of Album : Social Media domain
@enduml