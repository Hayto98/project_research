@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Vehicle {
  -float type
  +long quantity
  +calculatePhone()
  +findDescription()
  +sendId()
  +deleteEmail()
}
class DeliveryNote {
  -int id
  #double note
  +boolean type
  #float address
  +validateCreatedat()
  +deletePhone()
  +updateType()
  +sendCreatedat()
}
abstract class Depot {
  -Date total
  -long status
  +sendUpdatedat()
  +deleteActive()
  +deleteStatus()
}
class Shipment {
  #double active
  #String note
  -String amount
  +getNote()
  +setScore()
  +cancelDescription()
}
class Package {
  +boolean active
  #double price
  +processUpdatedat()
}
Depot --* Package
Package ..> DeliveryNote : "0..1"
Vehicle --|> Depot
Package --> Shipment : "1"
@enduml