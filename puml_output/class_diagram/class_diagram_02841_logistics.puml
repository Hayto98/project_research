@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Vehicle {
  -float type
  +long quantity
  +createDuration()
  +updateCreatedat()
  +sendQuantity()
  +saveId()
}
abstract class DeliveryNote {
  +boolean level
  #float address
  #Date type
  -int createdAt
  +double score
  +getTotal()
  +saveStatus()
  +createPrice()
  +validateEmail()
}
abstract class Depot {
  #double createdAt
  +Date active
  +findStatus()
  +validateName()
  +saveEmail()
  +createCreatedat()
}
interface Shipment {
  +boolean active
  #double price
  +deleteEmail()
}
class Package {
  +Date duration
  #long updatedAt
  +float score
  #boolean createdAt
  +cancelId()
  +updateName()
  +saveAddress()
  +findNote()
}
Package --|> Shipment
Package --o Vehicle
Vehicle --> Shipment : "0..1"
Depot --> Package : "1"
note right of Vehicle : Logistics domain
@enduml