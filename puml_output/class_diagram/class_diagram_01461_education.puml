@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Exam {
  +boolean price
  #Date updatedAt
  -double total
  +double description
  +getPhone()
  +getDuration()
}
class Grade {
  #float createdAt
  +int description
  +float price
  +updateNote()
  +sendScore()
  +saveTotal()
  +setId()
}
class Classroom {
  #String quantity
  #String createdAt
  +findPhone()
  +saveType()
  +createAddress()
}
class Course {
  -Date phone
  +String address
  -long quantity
  -Date email
  +String createdAt
  +processEmail()
  +deletePhone()
  +getDuration()
  +validateType()
}
interface Attendance {
  +Date name
  #boolean score
  +double note
  +cancelPrice()
  +saveCode()
  +processAddress()
  +createScore()
}
class Department {
  +float note
  -String duration
  -String phone
  +float name
  +createActive()
  +findEmail()
  +getTotal()
}
Exam ..|> Course
Classroom --> Grade : "1"
Classroom ..|> Attendance
Attendance --|> Classroom
note right of Exam : Education domain
@enduml