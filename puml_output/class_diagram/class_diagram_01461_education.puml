@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Exam {
  +boolean price
  #Date updatedAt
  -double total
  +double description
  +setUpdatedat()
  +sendPhone()
}
class Grade {
  -float description
  #float createdAt
  +int duration
  +validateDescription()
  +getStatus()
}
abstract class Classroom {
  #double note
  +String active
  -float score
  +cancelAddress()
}
class Course {
  -Date duration
  -Date code
  +sendAddress()
  +updateCode()
  +validateScore()
  +cancelType()
}
class Attendance {
  -Date phone
  +String address
  -long quantity
  -Date email
  +String createdAt
  +validateName()
  +deleteName()
  +deleteScore()
  +processStatus()
}
class Department {
  #double type
  +Date active
  #boolean amount
  +double name
  +processId()
  +processType()
  +calculateUpdatedat()
  +processScore()
}
Course --* Classroom
Attendance --* Exam
@enduml