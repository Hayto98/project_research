@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
interface DeliveryNote {
  #long email
  +long quantity
  +processActive()
}
abstract class Shipment {
  -boolean amount
  -Date score
  -Date note
  +String code
  #double status
  +deleteLevel()
  +createAddress()
  +findNote()
}
class Route {
  +long amount
  +Date code
  -boolean duration
  +String id
  +deleteDescription()
  +sendPrice()
}
class Package {
  -Date price
  +long amount
  -int quantity
  #int email
  +saveCreatedat()
}
abstract class Manifest {
  -Date type
  +float createdAt
  +float duration
  +saveTotal()
  +processCreatedat()
  +sendId()
  +findAmount()
}
class Customer {
  +boolean level
  -Date quantity
  +int note
  -String price
  +validateUpdatedat()
  +setCreatedat()
  +cancelCode()
  +createType()
}
DeliveryNote --* Shipment
Route ..|> Package
note right of DeliveryNote : Logistics domain
@enduml