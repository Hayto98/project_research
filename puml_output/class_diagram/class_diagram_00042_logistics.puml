@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
interface DeliveryNote {
  #long email
  +long quantity
  +cancelLevel()
}
abstract class Shipment {
  +long total
  #double amount
  #double score
  #int note
  +Date code
  +cancelPhone()
  +createCode()
  +cancelActive()
  +processDescription()
}
class Route {
  +String updatedAt
  -String address
  #double amount
  #int code
  +boolean score
  +validateQuantity()
  +deleteEmail()
}
class Package {
  #float status
  #boolean address
  -long price
  #int amount
  -double quantity
  +deleteType()
  +setType()
}
class Manifest {
  +double note
  -Date amount
  +float type
  +updateCode()
}
abstract class Customer {
  +long type
  #long createdAt
  -double active
  +boolean id
  -Date amount
  +findPhone()
  +calculateCreatedat()
}
Package ..|> Route
DeliveryNote --> Shipment : "1"
@enduml