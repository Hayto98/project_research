@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Shelf {
  +float name
  #float updatedAt
  -Date amount
  +createAmount()
  +createDuration()
  +findActive()
  +saveAddress()
}
class Reservation {
  -Date updatedAt
  #boolean level
  #Date email
  +calculateScore()
  +updatePhone()
  +cancelNote()
}
class Branch {
  #int createdAt
  #float level
  -long email
  #long address
  +getDuration()
  +validateLevel()
  +sendAmount()
  +updateScore()
}
interface Loan {
  +boolean score
  +double total
  +deleteAmount()
  +createTotal()
}
abstract class Author {
  #double email
  -double note
  #long phone
  -boolean address
  +saveCreatedat()
  +cancelName()
  +deleteCode()
}
class Catalog {
  +int name
  #int amount
  +validatePhone()
  +saveType()
  +validateCode()
  +sendScore()
}
class Publisher {
  +float address
  #boolean id
  #Date amount
  +findType()
  +sendLevel()
}
Reservation --* Catalog
Catalog --* Publisher
Reservation --|> Author
note right of Shelf : Library domain
@enduml