@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Shelf {
  +float name
  #float updatedAt
  -Date amount
  +calculatePhone()
  +deleteEmail()
  +saveAddress()
  +findDescription()
}
interface Reservation {
  -Date description
  #boolean createdAt
  #Date updatedAt
  -double email
  +findCode()
  +processEmail()
}
abstract class Branch {
  #Date email
  #long createdAt
  +calculatePrice()
  +getEmail()
  +findType()
}
class Loan {
  #float phone
  #Date note
  +float name
  +boolean address
  +calculatePrice()
}
abstract class Author {
  +float score
  +int updatedAt
  -double note
  +createQuantity()
  +findType()
  +findCreatedat()
  +processTotal()
}
class Catalog {
  -boolean note
  -Date address
  +boolean duration
  +int level
  +deleteType()
}
class Publisher {
  +int name
  #int amount
  +validateScore()
  +deleteCode()
  +cancelDuration()
  +sendName()
}
Shelf --> Author : "0..1"
Reservation --|> Branch
Reservation --> Shelf : "0..1"
Catalog --> Loan : "0..1"
@enduml