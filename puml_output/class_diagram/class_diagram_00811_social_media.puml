@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class User {
  -String price
  +int email
  -double type
  +String description
  +calculatePhone()
  +findLevel()
  +deleteName()
  +processPrice()
}
abstract class Report {
  +float active
  #float quantity
  -float address
  #long duration
  +Date description
  +sendQuantity()
  +updatePhone()
  +processDuration()
  +findPhone()
}
class Like {
  #String name
  +String type
  -double active
  +sendDuration()
  +saveActive()
  +saveDescription()
  +validateDescription()
}
interface Notification {
  -boolean total
  -int type
  +boolean level
  #int phone
  #Date id
  +validateLevel()
  +deleteNote()
}
abstract class Hashtag {
  +boolean total
  +long level
  -float description
  +cancelEmail()
  +sendCode()
  +getId()
  +updateEmail()
}
abstract class Comment {
  +Date active
  +String name
  +float status
  +validateCreatedat()
  +validateCreatedat()
  +cancelName()
}
