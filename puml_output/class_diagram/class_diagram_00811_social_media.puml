@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class User {
  -String price
  +int email
  -double type
  +String description
  +cancelCreatedat()
  +deleteType()
  +processStatus()
  +createLevel()
}
interface Report {
  -double name
  #float type
  -float price
  +deleteDescription()
  +createUpdatedat()
  +setType()
}
class Like {
  +long duration
  -boolean phone
  #Date amount
  -int price
  +String quantity
  +deletePhone()
  +findPrice()
  +getQuantity()
  +processQuantity()
}
class Notification {
  #double address
  #boolean type
  +validateScore()
  +setType()
}
interface Hashtag {
  -boolean total
  -int type
  +boolean level
  #int phone
  #Date id
  +calculateCreatedat()
  +setCreatedat()
}
interface Comment {
  -boolean note
  +int price
  #String description
  +findCreatedat()
  +deleteTotal()
  +sendCreatedat()
}
Hashtag --|> User
User --* Report
Notification --> Report : "1"
@enduml