@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
abstract class Invoice {
  -String status
  -int updatedAt
  #String code
  -double address
  +validateScore()
  +validateEmail()
}
class Booking {
  #double name
  -String amount
  #Date note
  #long code
  +updateAmount()
  +validateName()
}
class CheckOut {
  #Date quantity
  +double createdAt
  +float level
  #int duration
  #long amount
  +validateStatus()
}
interface Payment {
  -int active
  +boolean id
  +int address
  #boolean level
  #String amount
  +calculateUpdatedat()
  +getType()
  +updateCode()
  +sendTotal()
}
class Reservation {
  #long description
  -Date name
  #long updatedAt
  -double status
  +setAmount()
  +cancelLevel()
  +saveAmount()
  +deleteUpdatedat()
}
class Staff {
  -long phone
  -boolean address
  #long createdAt
  +double score
  +boolean code
  +saveCreatedat()
}
Booking ..|> Staff
Staff --> Reservation : "*"
Staff --> Payment : "*"
Reservation ..|> Booking
Reservation --> Staff : "1"
@enduml