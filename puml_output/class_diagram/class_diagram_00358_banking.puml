@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Branch {
  +float description
  +double email
  -float status
  +Date total
  -long phone
  +saveCreatedat()
  +getEmail()
  +getTotal()
  +createType()
}
class Beneficiary {
  +int address
  -double id
  +validateTotal()
}
abstract class Transfer {
  #float name
  +Date email
  +double updatedAt
  +double description
  +String price
  +createCreatedat()
  +calculateNote()
  +createType()
}
class Deposit {
  +boolean createdAt
  -long note
  #boolean total
  +Date level
  +setTotal()
  +deleteQuantity()
  +findCreatedat()
}
Branch ..|> Transfer
Deposit --o Branch
@enduml