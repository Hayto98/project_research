@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Branch {
  +float description
  +double email
  -float status
  +Date total
  -long phone
  +validateDescription()
  +updateQuantity()
  +getAddress()
  +getUpdatedat()
}
class Beneficiary {
  -int total
  +double id
  #float type
  +Date score
  +double name
  +calculateDescription()
}
class Transfer {
  +double description
  -double createdAt
  +boolean name
  -long phone
  +saveAddress()
}
class Deposit {
  +boolean email
  +double total
  +calculateType()
  +deleteDescription()
}
Branch --|> Deposit
Branch ..|> Beneficiary
note right of Branch : Banking domain
@enduml