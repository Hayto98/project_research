@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Nurse {
  -int price
  #double updatedAt
  +float amount
  +String id
  +setId()
  +saveAddress()
  +getType()
  +saveDescription()
}
interface Insurance {
  -double status
  -double total
  -String description
  +boolean id
  +float note
  +findId()
  +setScore()
  +createCreatedat()
}
class Prescription {
  #boolean amount
  #long address
  +findAmount()
  +createActive()
}
abstract class Diagnosis {
  -String description
  #double score
  +createTotal()
  +updateEmail()
  +calculateDuration()
}
class Doctor {
  #boolean code
  +float type
  #boolean active
  +validateActive()
}
Doctor --* Insurance
Insurance --|> Prescription
note right of Nurse : Healthcare domain
@enduml