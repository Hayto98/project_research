@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Nurse {
  -int price
  #double updatedAt
  +float amount
  +String id
  +setStatus()
  +findLevel()
  +sendLevel()
  +cancelTotal()
}
class Insurance {
  #double type
  +double description
  +findEmail()
  +setName()
}
abstract class Prescription {
  +String total
  #int duration
  -Date type
  +String phone
  +updateDescription()
  +sendId()
  +sendType()
}
class Diagnosis {
  +float address
  #Date level
  +long email
  +updateName()
  +validateCreatedat()
  +sendAmount()
  +getName()
}
abstract class Doctor {
  #Date active
  -long total
  +createScore()
  +cancelPhone()
  +processLevel()
  +cancelUpdatedat()
}
Insurance --|> Doctor
Diagnosis --> Insurance : "1"
Prescription --> Insurance : "0..1"
@enduml