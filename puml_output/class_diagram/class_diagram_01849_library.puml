@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Shelf {
  -long total
  +double price
  +getType()
  +cancelCode()
}
abstract class Publisher {
  -Date amount
  -boolean score
  #float updatedAt
  #double description
  -double note
  +createTotal()
  +setStatus()
  +processNote()
  +deleteId()
}
abstract class Loan {
  +int active
  +float phone
  +String description
  #String email
  +long duration
  +saveActive()
  +findUpdatedat()
  +updatePhone()
  +calculateName()
}
abstract class Renewal {
  +long amount
  -boolean type
  -Date note
  +long id
  +processQuantity()
  +calculateCode()
  +sendPrice()
}
class Librarian {
  #boolean level
  #String price
  -boolean name
  #double code
  -int type
  +findAddress()
}
class Catalog {
  #boolean updatedAt
  -double level
  #float score
  -float status
  +cancelScore()
  +validateStatus()
  +cancelName()
  +cancelDescription()
}
Catalog --* Publisher
Shelf --o Publisher
note right of Shelf : Library domain
@enduml