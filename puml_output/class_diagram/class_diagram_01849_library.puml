@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Shelf {
  -long total
  +double price
  +validateLevel()
  +deleteTotal()
}
class Publisher {
  #int level
  +double code
  -Date type
  -boolean price
  #float amount
  +validateUpdatedat()
  +processLevel()
  +calculateCode()
  +findTotal()
}
class Loan {
  +double code
  -boolean status
  -int note
  #Date score
  #long description
  +updateName()
  +calculateNote()
  +cancelNote()
}
class Renewal {
  -double name
  #boolean description
  +sendNote()
  +createAmount()
}
abstract class Librarian {
  +double note
  -String phone
  +calculateName()
  +updateLevel()
}
interface Catalog {
  -double name
  +boolean phone
  -int level
  -boolean type
  +createEmail()
  +getUpdatedat()
  +saveEmail()
  +validatePhone()
}
Catalog ..> Librarian : "1"
Renewal --> Librarian : "*"
Renewal --|> Publisher
Catalog ..> Loan : "0..1"
Loan --> Publisher : "1"
@enduml