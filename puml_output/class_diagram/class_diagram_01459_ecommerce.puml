@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Category {
  -boolean address
  +double phone
  +processAddress()
}
interface Product {
  #double name
  -int amount
  -double duration
  -long quantity
  -double phone
  +createId()
  +deleteStatus()
}
abstract class Cart {
  #float active
  #double description
  -int amount
  -double phone
  +cancelType()
  +createUpdatedat()
  +processDescription()
  +processLevel()
}
class Return {
  #long description
  +String amount
  +long createdAt
  #long score
  #String name
  +calculateEmail()
}
interface Invoice {
  +boolean updatedAt
  -String amount
  -int note
  +createScore()
  +createLevel()
  +validateAmount()
  +calculateScore()
}
class Order {
  -float level
  #Date amount
  -float id
  -int description
  +updateActive()
  +setLevel()
  +sendScore()
}
Order --|> Category
Return ..> Category : "1"
Order --|> Cart
Return --o Cart
@enduml