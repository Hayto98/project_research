@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Fine {
  #Date address
  +long score
  -String note
  +double amount
  #long phone
  +setEmail()
  +findEmail()
  +findPhone()
  +setUpdatedat()
}
abstract class Librarian {
  -float code
  #int amount
  +double id
  -float address
  +saveTotal()
}
class Catalog {
  -double type
  #String updatedAt
  #double active
  -long code
  +saveAmount()
  +createQuantity()
  +sendPrice()
}
class Publisher {
  +String total
  -long name
  +sendId()
}
Fine --* Catalog
Fine --|> Librarian
@enduml