@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Fine {
  #Date address
  +long score
  -String note
  +double amount
  #long phone
  +validateDescription()
  +getTotal()
  +findAddress()
  +setAmount()
}
class Librarian {
  -long total
  +Date score
  +float amount
  -double id
  +findActive()
  +setEmail()
}
abstract class Catalog {
  -long note
  -long address
  +getTotal()
  +getCode()
  +setPhone()
}
class Publisher {
  #boolean createdAt
  +boolean status
  +getNote()
  +setCode()
  +setEmail()
}
Publisher --* Librarian
Fine --> Publisher : "1..*"
Librarian ..> Publisher : "*"
note right of Fine : Library domain
@enduml