@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
interface Schedule {
  -long quantity
  +int id
  -boolean updatedAt
  -float address
  +createQuantity()
  +calculateDescription()
  +validateDescription()
  +findPrice()
}
abstract class Course {
  +String level
  +boolean id
  +Date phone
  -float address
  +float active
  +deleteDescription()
  +deletePhone()
  +sendQuantity()
  +calculateLevel()
}
class Exam {
  #String active
  #Date name
  -double email
  +saveQuantity()
  +sendAmount()
  +setCode()
  +createDuration()
}
abstract class Library {
  +Date email
  -float level
  +Date active
  +updateQuantity()
}
Exam --o Schedule
Exam ..> Library : "*"
Library ..> Schedule : "*"
note right of Schedule : Education domain
@enduml