@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Wishlist {
  +String level
  +Date id
  +int updatedAt
  -double quantity
  #float total
  +findAmount()
}
class Supplier {
  -String status
  -float duration
  #boolean total
  +double type
  +long note
  +calculateTotal()
  +getType()
}
interface Cart {
  +String active
  -long level
  #int status
  -double address
  -double email
  +createDescription()
}
class Warehouse {
  +double level
  -long type
  +String note
  -float updatedAt
  -float address
  +calculateLevel()
  +setStatus()
}
Cart ..|> Warehouse
Warehouse ..|> Cart
Supplier --o Wishlist
@enduml