@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
abstract class Product {
  #float score
  #float total
  +float code
  +String description
  #float amount
  +updateDescription()
  +calculateDescription()
}
class Supplier {
  -long score
  +int active
  +boolean name
  +calculateName()
}
abstract class Shipment {
  -Date phone
  +long id
  +updateStatus()
  +cancelUpdatedat()
  +setPrice()
  +cancelId()
}
class Wishlist {
  #int score
  +boolean level
  -float active
  -double email
  +calculatePhone()
}
interface Review {
  #boolean description
  #Date code
  -boolean score
  +saveDescription()
  +updateTotal()
}
class Payment {
  +Date phone
  +String price
  +long level
  +saveScore()
  +getEmail()
}
Payment --> Supplier : "*"
Shipment --> Wishlist : "1..*"
note right of Product : Ecommerce domain
@enduml