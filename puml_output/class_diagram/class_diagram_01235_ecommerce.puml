@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
abstract class Product {
  #float score
  #float total
  +float code
  +String description
  #float amount
  +processActive()
  +validateCode()
}
abstract class Supplier {
  #Date status
  +long createdAt
  -int score
  +sendNote()
  +deleteUpdatedat()
}
class Shipment {
  -Date name
  +long type
  -int duration
  +boolean phone
  +float id
  +getDescription()
}
abstract class Wishlist {
  #Date address
  #boolean quantity
  +findName()
  +cancelNote()
  +createPhone()
}
interface Review {
  #long total
  #Date price
  +int id
  #Date duration
  +setAddress()
}
interface Payment {
  +int active
  -double amount
  -int description
  #String updatedAt
  +int total
  +sendType()
  +validateDescription()
  +getCreatedat()
}
Payment --|> Review
Shipment ..> Product : "0..1"
Review --* Wishlist
@enduml