@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
abstract class Exam {
  +boolean code
  +String name
  +boolean updatedAt
  +cancelUpdatedat()
  +sendName()
  +cancelEmail()
}
abstract class Course {
  #long price
  +int note
  +processAmount()
  +getName()
  +updateActive()
}
abstract class Attendance {
  #String code
  #Date score
  -float duration
  #long note
  +cancelPrice()
  +updateAddress()
}
abstract class Student {
  +boolean code
  -long type
  +processName()
}
class Department {
  -long description
  -int address
  #int name
  -Date code
  +deleteStatus()
}
Course --> Student : "0..1"
Department ..> Attendance : "0..1"
Student --* Course
Attendance --o Course
note right of Exam : Education domain
@enduml