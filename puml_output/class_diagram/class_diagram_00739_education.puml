@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
abstract class Exam {
  +boolean code
  +String name
  +boolean updatedAt
  +deleteDescription()
  +sendNote()
  +deleteTotal()
}
interface Course {
  -String level
  -double email
  +saveQuantity()
  +updateScore()
  +findQuantity()
}
abstract class Attendance {
  #double name
  -float duration
  #String updatedAt
  +deleteDuration()
}
interface Student {
  #long score
  #float quantity
  +findName()
  +saveName()
}
class Department {
  +boolean type
  -long name
  +float code
  -String duration
  +updateNote()
  +updateTotal()
  +validateCreatedat()
}
Exam --o Department
Attendance ..|> Student
Department --* Course
@enduml