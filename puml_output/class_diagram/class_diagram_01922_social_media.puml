@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Story {
  -float duration
  #long type
  #boolean id
  #String total
  +sendType()
  +updateCreatedat()
  +updateDuration()
  +setNote()
}
abstract class Album {
  +Date duration
  #boolean updatedAt
  +float phone
  +cancelDuration()
  +processStatus()
  +cancelPhone()
}
class Comment {
  -Date phone
  #float score
  +getScore()
}
class Post {
  -int updatedAt
  -Date code
  #long active
  +calculateQuantity()
  +createAmount()
  +getPhone()
}
Story ..> Post : "*"
Album --|> Story
@enduml