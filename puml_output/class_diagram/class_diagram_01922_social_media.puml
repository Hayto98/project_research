@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Story {
  -float duration
  #long type
  #boolean id
  #String total
  +getTotal()
  +calculateDescription()
  +cancelUpdatedat()
  +validateUpdatedat()
}
interface Album {
  -long quantity
  +float phone
  +sendPrice()
  +findStatus()
  +sendEmail()
}
class Comment {
  +double code
  #float active
  #long type
  +calculatePhone()
  +calculateAddress()
  +cancelStatus()
}
class Post {
  +double score
  +float id
  +Date updatedAt
  +double createdAt
  #long duration
  +createUpdatedat()
  +saveDuration()
  +deleteDuration()
}
Album ..|> Story
Story --o Post
note right of Story : Social Media domain
@enduml