@startuml
skinparam ArrowColor #555555
class Supplier {
  #long note
  -int amount
  +cancelActive()
}
class Category {
  #Date email
  -int note
  -float code
  #long duration
  +findCreatedat()
  +setAmount()
  +updateStatus()
  +sendDescription()
}
class Return {
  -Date name
  -boolean score
  +long amount
  #String active
  +getCreatedat()
  +deleteEmail()
  +createLevel()
  +calculateName()
}
class Product {
  +float id
  +float phone
  #Date name
  +sendPrice()
}
class Payment {
  -boolean price
  -long id
  +calculateStatus()
  +setNote()
}
Supplier --* Return
Return ..|> Supplier
@enduml