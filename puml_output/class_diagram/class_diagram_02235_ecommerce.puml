@startuml
skinparam ArrowColor #555555
class Supplier {
  #long note
  -int amount
  +cancelQuantity()
}
class Category {
  +double note
  #long code
  -long email
  +float address
  +validateName()
}
interface Return {
  #String active
  -float type
  #String address
  +sendAddress()
  +findQuantity()
  +updateId()
  +cancelPhone()
}
class Product {
  +double id
  +long code
  #double phone
  +saveCreatedat()
  +findTotal()
  +cancelId()
}
class Payment {
  #Date id
  -String phone
  +float status
  -String level
  +calculateNote()
  +findUpdatedat()
  +setDescription()
  +cancelNote()
}
Return --o Product
Return ..> Category : "*"
note right of Supplier : Ecommerce domain
@enduml