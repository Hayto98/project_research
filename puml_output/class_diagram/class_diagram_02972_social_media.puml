@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Hashtag {
  #double code
  #String address
  #long price
  +sendEmail()
}
class Album {
  #float active
  -Date address
  +Date quantity
  #String createdAt
  +validateAmount()
  +sendAddress()
  +createType()
  +processQuantity()
}
abstract class Like {
  -Date total
  +String code
  -long createdAt
  +createUpdatedat()
}
class Report {
  +String active
  +boolean description
  -double total
  -float amount
  +deleteNote()
}
class Profile {
  -int level
  -Date amount
  +int email
  #double name
  #boolean note
  +createTotal()
  +validateDuration()
  +calculateScore()
}
Hashtag --* Report
Profile --* Album
@enduml