@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Hashtag {
  #double code
  #String address
  #long price
  +updateEmail()
}
class Album {
  #Date quantity
  +double createdAt
  -long email
  #String level
  +deleteTotal()
  +setCreatedat()
  +calculateCode()
  +setNote()
}
class Like {
  -boolean active
  +double quantity
  +setId()
  +setLevel()
}
class Report {
  #int address
  -Date status
  #String name
  -double level
  +float price
  +findUpdatedat()
  +updateNote()
  +cancelScore()
}
class Profile {
  -boolean email
  #boolean description
  +long name
  #String price
  +setLevel()
  +processTotal()
  +getPhone()
}
Report --> Like : "1..*"
Album --> Hashtag : "*"
Hashtag --* Report
note right of Hashtag : Social Media domain
@enduml