@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Shipment {
  -boolean score
  +boolean active
  +findPrice()
  +validateQuantity()
}
class Order {
  -int address
  +int type
  -float duration
  -int createdAt
  #double level
  +findEmail()
  +sendPrice()
}
interface Customer {
  #int active
  -boolean quantity
  +sendDescription()
  +createDuration()
  +cancelDescription()
  +setCode()
}
class Review {
  #int type
  -float quantity
  #String address
  -long name
  +double active
  +sendUpdatedat()
  +setAmount()
}
class Coupon {
  #Date phone
  #double level
  #boolean description
  +Date id
  -double note
  +processActive()
  +cancelName()
  +validateId()
  +processAmount()
}
Coupon ..> Order : "*"
Coupon --|> Shipment
note right of Shipment : Ecommerce domain
@enduml