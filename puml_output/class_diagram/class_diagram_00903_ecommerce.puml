@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Shipment {
  -boolean score
  +boolean active
  +calculateType()
  +saveDescription()
}
abstract class Order {
  -long quantity
  #Date address
  +double note
  -int level
  +updateType()
}
class Customer {
  #double updatedAt
  #boolean total
  +Date createdAt
  #long email
  +cancelAddress()
  +savePrice()
}
abstract class Review {
  +String email
  -double description
  -long code
  +setUpdatedat()
}
interface Coupon {
  -long quantity
  +double active
  +boolean id
  +cancelEmail()
  +validateQuantity()
}
Review --> Customer : "0..1"
Shipment --> Review : "*"
Coupon ..> Order : "1..*"
@enduml