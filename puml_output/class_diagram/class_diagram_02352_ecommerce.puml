@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Review {
  +boolean description
  +boolean status
  +double name
  +float code
  -String total
  +updateStatus()
}
class Order {
  -String quantity
  -long code
  +long amount
  +double status
  +getTotal()
  +sendCode()
  +sendUpdatedat()
}
class Product {
  #boolean description
  #long createdAt
  -String amount
  +deletePrice()
  +sendDuration()
  +cancelStatus()
  +findType()
}
class Payment {
  #float description
  +String quantity
  +boolean status
  +updateLevel()
  +validateQuantity()
}
Order ..|> Product
Review ..> Product : "1"
@enduml