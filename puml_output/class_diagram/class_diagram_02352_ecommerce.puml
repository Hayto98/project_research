@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Review {
  +boolean description
  +boolean status
  +double name
  +float code
  -String total
  +updateAmount()
}
class Order {
  -String code
  -long amount
  +long score
  +double status
  +updateNote()
  +findUpdatedat()
  +deleteDescription()
}
class Product {
  -String duration
  #double level
  -Date address
  +deleteAmount()
}
class Payment {
  #int status
  -int updatedAt
  #double duration
  +boolean amount
  +deleteCode()
  +sendId()
}
Product ..> Order : "1..*"
Order ..> Payment : "1..*"
Payment --|> Review
note right of Review : Ecommerce domain
@enduml