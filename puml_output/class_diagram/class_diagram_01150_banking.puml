@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
abstract class Loan {
  -float duration
  #String status
  -String phone
  +findPrice()
  +createPrice()
}
interface Card {
  -int name
  #int total
  +cancelScore()
  +updateUpdatedat()
  +processPrice()
  +processDescription()
}
class Branch {
  -String status
  -int level
  +Date quantity
  +int name
  -Date score
  +cancelTotal()
  +updateScore()
  +deleteQuantity()
}
abstract class Transaction {
  #float phone
  -int duration
  +getDuration()
  +deleteEmail()
  +deleteDuration()
  +findLevel()
}
abstract class Teller {
  -double status
  -double code
  -String createdAt
  #long level
  -boolean amount
  +sendAddress()
  +sendPhone()
  +findPhone()
  +getActive()
}
interface Account {
  -int address
  -float phone
  +findPhone()
  +sendUpdatedat()
}
class Beneficiary {
  -float type
  +float phone
  +int duration
  #int quantity
  +setActive()
  +updateCreatedat()
  +saveAddress()
}
Beneficiary ..|> Teller
Branch --o Loan
Branch ..> Account : "1..*"
Card --* Teller
Branch --o Beneficiary
@enduml