@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
interface Tracking {
  -boolean status
  -boolean code
  #double level
  +String quantity
  -int description
  +findUpdatedat()
  +sendScore()
  +sendUpdatedat()
  +cancelStatus()
}
class Inventory {
  -int id
  -float duration
  -double note
  +cancelStatus()
  +calculateDuration()
  +setCreatedat()
}
class Warehouse {
  +Date createdAt
  -boolean address
  #int score
  +sendDescription()
  +findTotal()
}
interface DeliveryNote {
  #long address
  -boolean quantity
  #boolean id
  #int code
  +createLevel()
  +cancelStatus()
}
interface Manifest {
  +float note
  +float price
  +setAmount()
  +updateTotal()
}
interface Depot {
  +boolean updatedAt
  -int email
  -String price
  +saveScore()
  +createId()
  +createPhone()
  +getCreatedat()
}
interface FuelLog {
  #float createdAt
  +double name
  +String price
  #long quantity
  -Date amount
  +validateNote()
}
Inventory ..> FuelLog : "1"
Depot --> DeliveryNote : "0..1"
FuelLog --> Manifest : "*"
FuelLog --> DeliveryNote : "1..*"
Warehouse --* Tracking
@enduml