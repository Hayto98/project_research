@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
interface Shelf {
  #boolean name
  +Date status
  +sendAddress()
  +findDuration()
  +updatePhone()
}
abstract class Catalog {
  +int quantity
  -float createdAt
  +int code
  #long level
  #boolean address
  +findEmail()
}
interface Librarian {
  -Date description
  +double code
  +setType()
  +setQuantity()
  +createQuantity()
}
interface Book {
  -Date score
  #String createdAt
  +getDuration()
}
interface Loan {
  -Date duration
  #int code
  #float updatedAt
  #double email
  +setQuantity()
  +savePhone()
  +findCreatedat()
}
class Renewal {
  #float status
  #int email
  +long total
  -long code
  +String score
  +sendEmail()
  +validatePrice()
}
Shelf ..|> Book
Catalog --> Shelf : "*"
note right of Shelf : Library domain
@enduml