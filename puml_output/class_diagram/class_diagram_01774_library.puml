@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
interface Shelf {
  #boolean name
  +Date status
  +saveActive()
  +deleteEmail()
  +cancelDuration()
}
class Catalog {
  -Date phone
  -float note
  +Date score
  +updateAmount()
}
interface Librarian {
  -float address
  +int status
  #long updatedAt
  +createLevel()
}
class Book {
  -Date description
  +double code
  +findNote()
  +createTotal()
  +getId()
}
class Loan {
  #float email
  #int quantity
  -Date score
  #String id
  +validateStatus()
}
class Renewal {
  -Date duration
  #int code
  #float updatedAt
  #double email
  +createAddress()
  +getNote()
  +processNote()
}
Renewal --* Catalog
Book --* Shelf
Book ..> Loan : "0..1"
@enduml