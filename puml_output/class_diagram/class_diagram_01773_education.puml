@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Library {
  +Date status
  #int code
  -float name
  +deleteId()
  +setScore()
}
abstract class Attendance {
  -String email
  -double active
  -Date score
  -long name
  -Date updatedAt
  +deleteNote()
  +updateActive()
}
interface Course {
  +long active
  #long note
  +double phone
  -boolean quantity
  #Date type
  +saveCreatedat()
  +cancelEmail()
  +findPrice()
  +findCreatedat()
}
class Teacher {
  +int status
  -long code
  +findName()
  +getAddress()
}
abstract class Assignment {
  #double createdAt
  +float address
  +Date phone
  -int code
  +deleteScore()
  +findPrice()
}
class Book {
  -int score
  #double quantity
  -boolean level
  -String phone
  #Date active
  +calculateUpdatedat()
  +findTotal()
  +cancelName()
}
abstract class Grade {
  -double note
  -int level
  +setLevel()
  +processActive()
  +updateDuration()
  +sendQuantity()
}
Assignment --* Teacher
Library ..|> Attendance
note right of Library : Education domain
@enduml