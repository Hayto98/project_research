@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
interface Depot {
  #boolean createdAt
  #int email
  +long id
  #int amount
  -String score
  +validateLevel()
  +validateCode()
  +calculateName()
  +deleteAmount()
}
abstract class DeliveryNote {
  +String email
  +int type
  +calculateUpdatedat()
  +validateUpdatedat()
  +calculatePrice()
  +validatePhone()
}
interface Warehouse {
  -boolean createdAt
  +double phone
  +double updatedAt
  +float duration
  +findActive()
}
class Route {
  +boolean type
  -long status
  +getTotal()
  +processPrice()
}
class Shipment {
  -float description
  +int status
  #float level
  +processLevel()
  +deleteScore()
  +createLevel()
}
class Package {
  -long score
  #long description
  #int id
  #Date quantity
  -double phone
  +getTotal()
  +cancelDuration()
  +deleteEmail()
  +processActive()
}
interface Driver {
  #int type
  -int createdAt
  +deleteDescription()
  +saveType()
  +saveId()
}
Depot --|> Warehouse
Shipment --> Package : "1"
Shipment --|> Driver
@enduml