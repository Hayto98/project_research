@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Invoice {
  +Date total
  -long price
  -double type
  #int active
  +float id
  +updateTotal()
  +cancelCreatedat()
  +validatePrice()
}
abstract class Review {
  -long total
  #String createdAt
  +saveScore()
}
interface Return {
  +double note
  +Date active
  #Date duration
  #float id
  +calculateDescription()
  +calculateLevel()
  +sendLevel()
  +saveActive()
}
interface Cart {
  +Date total
  -Date address
  #int name
  -float price
  +findLevel()
  +findEmail()
}
Return --|> Review
Return --o Cart
@enduml