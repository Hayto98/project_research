@startuml

class Invoice {
  +double total
  +boolean active
  +saveQuantity()
  +sendType()
  +getQuantity()
}
class Booking {
  +Date code
  -int description
  +long duration
  +Date id
  +cancelNote()
}
class Housekeeping {
  -long price
  #double duration
  +Date address
  +long amount
  -double level
  +findQuantity()
  +calculateName()
}
interface Guest {
  +String phone
  +boolean type
  #boolean updatedAt
  +getLevel()
  +createDescription()
  +processId()
}
class Amenity {
  -String description
  +Date updatedAt
  +int name
  +float duration
  -long status
  +findDuration()
  +deleteEmail()
}
abstract class Room {
  +double phone
  -float active
  #int updatedAt
  -boolean note
  +processCreatedat()
}
abstract class Service {
  -Date status
  +int phone
  #Date active
  #int note
  #int level
  +calculateActive()
  +updateStatus()
  +calculateStatus()
  +sendCreatedat()
}
Room --> Amenity : "1"
Service --|> Invoice
Service --|> Guest
Housekeeping --|> Room
Room ..> Booking : "1"
Guest --> Booking : "1"
@enduml