@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Comment {
  +int description
  #double type
  +createScore()
  +getId()
}
abstract class Message {
  +float phone
  #Date status
  +updateEmail()
}
abstract class Album {
  #float email
  -boolean code
  +float id
  +processScore()
  +getLevel()
}
abstract class Profile {
  +boolean name
  -String code
  +createAmount()
}
class Follower {
  +double name
  #String score
  #Date duration
  -long email
  +int createdAt
  +cancelScore()
  +saveUpdatedat()
  +calculatePrice()
  +createScore()
}
Message ..|> Follower
Message --o Profile
@enduml