@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Comment {
  +int description
  #double type
  +updateType()
  +saveTotal()
}
interface Message {
  +float phone
  #Date status
  +calculatePrice()
}
class Album {
  +float code
  +float id
  +Date quantity
  -float active
  +getCode()
}
class Profile {
  +boolean name
  +boolean id
  #long phone
  #int quantity
  +double note
  +savePhone()
}
class Follower {
  #Date createdAt
  #int note
  +deleteUpdatedat()
}
Message --o Profile
Comment --* Profile
note right of Comment : Social Media domain
@enduml