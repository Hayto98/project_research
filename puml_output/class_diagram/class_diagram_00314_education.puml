@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Assignment {
  #int type
  #String amount
  -boolean note
  -Date createdAt
  #int name
  +sendAddress()
  +getAmount()
  +createCode()
}
class Course {
  +Date status
  +long address
  #float total
  -double price
  -Date email
  +sendName()
  +validatePrice()
  +sendTotal()
}
class Exam {
  #int id
  +long createdAt
  #double email
  +deleteDescription()
  +validateDuration()
  +findType()
}
class Attendance {
  #String updatedAt
  -boolean createdAt
  #Date status
  +processPrice()
}
class Teacher {
  #String status
  +Date createdAt
  -int email
  #double total
  +createAmount()
  +findAddress()
}
Exam --o Course
Course --* Attendance
Exam --o Assignment
note right of Assignment : Education domain
@enduml