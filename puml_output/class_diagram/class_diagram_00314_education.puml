@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Assignment {
  #int type
  #String amount
  -boolean note
  -Date createdAt
  #int name
  +setAddress()
  +calculateCreatedat()
  +processCode()
}
class Course {
  -double code
  -long amount
  +Date note
  +long status
  +deleteId()
  +deletePrice()
  +calculateAmount()
  +setScore()
}
class Exam {
  #float address
  -String price
  +updateDuration()
  +calculateUpdatedat()
}
class Attendance {
  #long createdAt
  +int code
  -boolean email
  #double price
  +findPhone()
  +createScore()
  +saveNote()
}
class Teacher {
  #Date type
  +float score
  +findEmail()
  +sendPrice()
  +createPrice()
  +validateCode()
}
Assignment ..> Course : "1..*"
Attendance ..|> Assignment
Exam --> Course : "*"
@enduml