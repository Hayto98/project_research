@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
abstract class Classroom {
  -int name
  #long active
  -float quantity
  +deleteTotal()
  +saveUpdatedat()
  +cancelAmount()
  +calculateQuantity()
}
interface Schedule {
  +float address
  #float status
  #String updatedAt
  +double total
  +boolean id
  +getLevel()
}
interface Library {
  +float description
  -double updatedAt
  #Date duration
  #Date level
  +setDuration()
  +validateLevel()
  +updateType()
}
abstract class Course {
  +boolean duration
  +String type
  +long amount
  +processName()
  +validateUpdatedat()
  +calculateName()
}
interface Enrollment {
  +int id
  #boolean type
  +int score
  +Date createdAt
  +calculateTotal()
}
interface Grade {
  #long note
  +int type
  #int score
  -String code
  +getPrice()
  +validateDescription()
}
Classroom ..|> Library
Enrollment --o Schedule
Course --|> Grade
note right of Classroom : Education domain
@enduml