@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
abstract class Classroom {
  -int name
  #long active
  -float quantity
  +calculateAddress()
  +getAddress()
  +updateQuantity()
  +calculateUpdatedat()
}
class Schedule {
  -String total
  +double quantity
  +String price
  +updateActive()
}
abstract class Library {
  +Date duration
  #boolean id
  +findPhone()
  +updateStatus()
  +getEmail()
}
class Course {
  #Date note
  #Date price
  +validateId()
  +validateActive()
  +calculateName()
}
interface Enrollment {
  #double type
  +String price
  #float description
  +updateUpdatedat()
  +sendLevel()
}
class Grade {
  +double address
  +boolean type
  -float name
  #String duration
  +createStatus()
  +getDuration()
  +updatePhone()
  +calculateNote()
}
Schedule --|> Enrollment
Schedule ..> Classroom : "1"
@enduml