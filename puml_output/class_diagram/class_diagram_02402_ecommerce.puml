@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Warehouse {
  -String description
  #float phone
  +findUpdatedat()
  +getDuration()
  +calculatePhone()
  +setPhone()
}
class Wishlist {
  +Date createdAt
  -Date updatedAt
  +float quantity
  -String active
  +calculateEmail()
  +validateType()
  +processDescription()
  +findPrice()
}
class Product {
  -String id
  -long address
  #int status
  +updateDuration()
  +createPrice()
}
class Review {
  +long active
  -long code
  -double note
  #String type
  +setTotal()
}
class Category {
  +int total
  +long level
  +long status
  +int code
  +double type
  +setPhone()
}
abstract class Supplier {
  -Date duration
  -Date level
  #Date phone
  +calculateDuration()
  +setQuantity()
  +processCreatedat()
}
Product ..> Category : "1..*"
Category ..|> Supplier
Category ..|> Wishlist
Supplier --|> Wishlist
note right of Warehouse : Ecommerce domain
@enduml