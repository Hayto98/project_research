@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Warehouse {
  -String description
  #float phone
  +calculateStatus()
  +sendNote()
  +calculateId()
  +sendLevel()
}
interface Wishlist {
  #int phone
  #int code
  -boolean duration
  +Date address
  -Date score
  +getDescription()
}
class Product {
  #long total
  -double price
  +getEmail()
  +sendUpdatedat()
  +deleteAmount()
  +findNote()
}
class Review {
  +double duration
  +long address
  +findStatus()
  +setType()
  +saveType()
}
interface Category {
  +long createdAt
  #boolean email
  #String price
  +calculateTotal()
  +getUpdatedat()
  +findActive()
  +saveTotal()
}
class Supplier {
  #String address
  +String quantity
  -String type
  -double total
  +createType()
}
Supplier --|> Review
Wishlist --* Supplier
@enduml