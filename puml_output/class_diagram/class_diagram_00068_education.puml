@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Book {
  +long createdAt
  #float address
  +createStatus()
}
class Enrollment {
  +float total
  #boolean status
  -boolean id
  #boolean note
  +getTotal()
}
interface Grade {
  -long quantity
  #int updatedAt
  #float duration
  -float price
  +processPhone()
  +createLevel()
  +findAmount()
  +calculateEmail()
}
class Schedule {
  -boolean name
  -Date duration
  -Date status
  +long total
  +long price
  +processName()
  +validateAddress()
  +processPrice()
}
abstract class Department {
  #long status
  #Date quantity
  +cancelCode()
}
Schedule --o Enrollment
Grade --|> Department
note right of Book : Education domain
@enduml