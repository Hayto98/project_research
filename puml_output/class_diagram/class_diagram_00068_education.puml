@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Book {
  +long createdAt
  #float address
  +processDescription()
}
class Enrollment {
  +String address
  -String total
  +cancelActive()
  +calculateDescription()
  +processEmail()
}
class Grade {
  -long total
  +long level
  +createActive()
  +findQuantity()
  +deleteDescription()
  +validateQuantity()
}
class Schedule {
  -String type
  #double phone
  +String email
  +double amount
  -double price
  +findStatus()
  +sendCreatedat()
  +processNote()
}
class Department {
  +long updatedAt
  -double phone
  -float level
  #double note
  +updateUpdatedat()
}
Grade ..> Department : "1"
Department --* Book
Schedule --o Enrollment
@enduml