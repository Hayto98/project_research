@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Customer {
  +double description
  +String price
  #float status
  +float duration
  #String score
  +cancelNote()
  +deleteCode()
  +sendTotal()
  +getAddress()
}
abstract class Depot {
  #double email
  +float type
  #String createdAt
  #double code
  +double active
  +sendCode()
  +saveCreatedat()
}
class Package {
  -String createdAt
  +float code
  +calculateLevel()
  +sendCreatedat()
  +setQuantity()
}
class Driver {
  #int updatedAt
  +double amount
  #long note
  +setPrice()
  +cancelQuantity()
  +findCreatedat()
}
interface Warehouse {
  -int amount
  +double code
  #double price
  +cancelStatus()
}
Warehouse --* Package
Depot --* Driver
Driver --o Package
@enduml