@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Customer {
  +double description
  +String price
  #float status
  +float duration
  #String score
  +updatePhone()
  +getTotal()
  +processType()
  +createType()
}
class Depot {
  +float code
  #String type
  +setNote()
  +deleteNote()
  +validateDescription()
  +setCreatedat()
}
class Package {
  #boolean name
  +int status
  +float phone
  #double type
  #int amount
  +calculateEmail()
}
class Driver {
  -float email
  -int level
  +double createdAt
  #double amount
  +String code
  +createLevel()
  +cancelEmail()
  +deleteNote()
}
class Warehouse {
  +int email
  -float total
  -float name
  +Date updatedAt
  +String price
  +setName()
}
Customer --* Driver
Package --o Warehouse
note right of Customer : Logistics domain
@enduml