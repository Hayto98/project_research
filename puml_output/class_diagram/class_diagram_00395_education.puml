@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
interface Exam {
  -float id
  #float createdAt
  +createName()
  +createActive()
  +sendDescription()
}
class Student {
  +boolean name
  -Date code
  -Date score
  +Date email
  +long id
  +sendLevel()
  +updateLevel()
  +calculateActive()
}
class Attendance {
  #Date id
  #long updatedAt
  -Date createdAt
  -float amount
  +long type
  +saveScore()
  +getUpdatedat()
  +deleteDescription()
}
abstract class Enrollment {
  +String email
  +float amount
  #float price
  #Date active
  +float level
  +processCode()
  +saveAmount()
  +getDescription()
  +updateCode()
}
class Classroom {
  +double note
  #Date duration
  #int level
  -int name
  +int active
  +cancelDescription()
  +processName()
  +findPrice()
}
Attendance --|> Exam
Enrollment --|> Student
@enduml