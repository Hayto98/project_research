@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
interface Exam {
  -float id
  #float createdAt
  +processAddress()
  +deleteScore()
  +saveScore()
}
abstract class Student {
  #boolean code
  -Date score
  +deleteLevel()
}
abstract class Attendance {
  #Date createdAt
  #long duration
  -boolean email
  +double active
  +updateCreatedat()
}
class Enrollment {
  #float phone
  -long price
  #double type
  -Date code
  -int address
  +sendActive()
  +sendAmount()
  +deleteId()
  +setDuration()
}
class Classroom {
  -double id
  +String note
  +double status
  #Date level
  #int active
  +updateUpdatedat()
  +deletePhone()
  +findId()
  +sendDescription()
}
Exam --o Classroom
Classroom --|> Student
Student --o Attendance
note right of Exam : Education domain
@enduml