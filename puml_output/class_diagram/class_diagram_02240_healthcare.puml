@startuml
skinparam ArrowColor #555555
abstract class Ward {
  +String duration
  #double level
  +calculateDescription()
  +calculatePrice()
}
class Prescription {
  #Date updatedAt
  #long name
  +boolean phone
  -String level
  -String address
  +sendStatus()
  +calculateNote()
}
class Doctor {
  +String price
  #String name
  #long status
  -String level
  +setCreatedat()
  +calculateScore()
  +findUpdatedat()
  +cancelNote()
}
abstract class Hospital {
  #double createdAt
  -Date amount
  +float updatedAt
  -float quantity
  +calculatePrice()
}
Ward ..|> Doctor
Hospital --o Doctor
Hospital ..> Ward : "*"
@enduml