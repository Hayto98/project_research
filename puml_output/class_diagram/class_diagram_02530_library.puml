@startuml
skinparam monochrome true
skinparam shadowing true
class Loan {
  +float status
  -long duration
  +saveScore()
  +validateId()
  +findScore()
  +createActive()
}
class Fine {
  #boolean level
  +String address
  -long duration
  -float status
  -double email
  +calculateStatus()
  +setPrice()
}
class Publisher {
  +String duration
  #String type
  -int total
  +sendAmount()
  +deleteLevel()
  +updateType()
  +saveStatus()
}
class Branch {
  -long level
  -double phone
  #String price
  #Date type
  #float quantity
  +deleteScore()
  +setDescription()
  +validateCreatedat()
  +validatePrice()
}
abstract class Member {
  +String description
  -int name
  +sendName()
  +deleteActive()
}
Branch --o Loan
Loan --> Member : "*"
@enduml