@startuml
skinparam monochrome true
skinparam shadowing true
class Loan {
  +float status
  -long duration
  +validateStatus()
  +createAddress()
  +setTotal()
  +cancelAddress()
}
class Fine {
  #int email
  +long active
  +validatePrice()
  +processAmount()
  +findCreatedat()
}
class Publisher {
  +float total
  #float id
  -boolean status
  +float name
  +double quantity
  +calculateType()
  +createQuantity()
  +validateNote()
}
abstract class Branch {
  #double level
  +String duration
  +saveType()
  +saveCode()
}
class Member {
  -int code
  +double duration
  +calculatePrice()
  +saveName()
  +processCode()
  +getLevel()
}
Branch --|> Member
Loan --* Fine
Publisher --* Branch
Branch --* Loan
note right of Loan : Library domain
@enduml