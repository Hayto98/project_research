@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
abstract class Invoice {
  +double email
  #float createdAt
  -boolean updatedAt
  -int level
  +sendAddress()
  +validateName()
  +findUpdatedat()
  +createPrice()
}
abstract class CheckOut {
  +double amount
  +float price
  -double name
  #long active
  +createPhone()
}
abstract class Booking {
  -double code
  #boolean email
  #double duration
  #int createdAt
  +float updatedAt
  +calculateDescription()
  +cancelCode()
  +setId()
}
class Guest {
  #Date level
  +Date id
  #Date duration
  +double type
  +deleteUpdatedat()
  +savePrice()
}
class Room {
  -String id
  #String level
  #String code
  #double address
  +createPrice()
}
class Housekeeping {
  +int score
  +Date id
  -boolean address
  #boolean total
  +saveNote()
  +createPhone()
  +cancelNote()
  +deleteCode()
}
Room ..|> Guest
Guest ..> Invoice : "0..1"
Guest --o Room
Booking --|> Housekeeping
@enduml