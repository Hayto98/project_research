@startuml

class Group {
  -long name
  +long createdAt
  #Date level
  #boolean phone
  +updatePhone()
  +getPrice()
  +validateEmail()
  +getAmount()
}
abstract class Comment {
  #boolean phone
  -double code
  +long description
  +getLevel()
  +createId()
  +calculateActive()
  +processId()
}
interface User {
  -long price
  #Date status
  #int description
  +createCode()
  +setLevel()
  +calculateLevel()
  +updateCreatedat()
}
abstract class Post {
  -int level
  +boolean createdAt
  -long status
  +calculateStatus()
  +findTotal()
}
interface Like {
  #double email
  -Date note
  -float type
  -String description
  +setDuration()
}
Post --* Comment
Comment --o Post
@enduml