@startuml

class Group {
  -long name
  +long createdAt
  #Date level
  #boolean phone
  +saveStatus()
  +saveType()
  +updatePhone()
  +setDescription()
}
interface Comment {
  #boolean price
  #int id
  -String quantity
  +long total
