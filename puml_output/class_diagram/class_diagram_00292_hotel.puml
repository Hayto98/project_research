@startuml
skinparam defaultFontSize 11
interface Service {
  #int status
  +int name
  +String email
  +float level
  +findId()
}
interface Restaurant {
  -String phone
  +float active
  -String type
  +float createdAt
  +deleteLevel()
}
abstract class Housekeeping {
  #int quantity
  +boolean code
  #boolean phone
  +float name
  +long level
  +updateDuration()
  +getTotal()
  +setAddress()
  +deleteUpdatedat()
}
class Amenity {
  #boolean total
  -float duration
  +double quantity
  #long id
  -Date createdAt
  +calculateName()
  +setUpdatedat()
}
class Invoice {
  +float phone
  #Date amount
  -int duration
  +deleteQuantity()
  +updateStatus()
  +calculateId()
  +validateCode()
}
class Reservation {
  +boolean email
  +String total
  +boolean updatedAt
  +createCode()
  +deleteTotal()
  +cancelQuantity()
  +getDescription()
}
Service --> Housekeeping : "1..*"
Housekeeping ..> Restaurant : "1..*"
@enduml