@startuml
skinparam monochrome true
skinparam defaultFontSize 11
interface Grade {
  -float level
  +int updatedAt
  -float active
  -float type
  -float status
  +sendAmount()
  +setLevel()
  +cancelActive()
  +calculateUpdatedat()
}
class Enrollment {
  #String address
  +int code
  -double type
  +calculatePhone()
  +processStatus()
}
interface Classroom {
  #float description
  +float quantity
  +double code
  +updateId()
  +cancelPhone()
}
class Attendance {
  #String type
  +Date email
  -boolean duration
  +boolean price
  +validateAddress()
  +calculateEmail()
  +updateEmail()
}
abstract class Assignment {
  +int phone
  #float code
  #double level
  +String status
  #String email
  +findScore()
}
abstract class Teacher {
  -float total
  #String amount
  +createDescription()
  +calculateCreatedat()
  +setCreatedat()
  +createScore()
}
Assignment --> Teacher : "*"
Teacher --* Classroom
Attendance --|> Teacher
note right of Grade : Education domain
@enduml