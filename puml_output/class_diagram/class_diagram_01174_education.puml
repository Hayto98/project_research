@startuml
skinparam monochrome true
skinparam defaultFontSize 11
interface Grade {
  -float level
  +int updatedAt
  -float active
  -float type
  -float status
  +sendAmount()
  +cancelName()
  +processUpdatedat()
  +getType()
}
interface Enrollment {
  -Date updatedAt
  +int address
  +long amount
  -int level
  -Date code
  +createNote()
  +validateUpdatedat()
  +updateUpdatedat()
}
interface Classroom {
  #float description
  +float quantity
  +double code
  +cancelNote()
  +processCode()
}
interface Attendance {
  -double email
  #String quantity
  +Date type
  -boolean duration
  +getCreatedat()
  +sendAddress()
}
class Assignment {
  -Date total
  -Date email
  -float createdAt
  +Date level
  +saveActive()
}
class Teacher {
  +String amount
  #String duration
  #float score
  +Date total
  +validateDescription()
  +deleteQuantity()
  +setNote()
  +findId()
}
Teacher --o Grade
Classroom --o Enrollment
Enrollment ..|> Grade
Classroom ..|> Assignment
Assignment --> Teacher : "*"
@enduml