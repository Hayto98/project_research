@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
abstract class Order {
  +int amount
  -boolean updatedAt
  #long createdAt
  +calculateUpdatedat()
  +cancelQuantity()
  +cancelDuration()
  +setDescription()
}
class Invoice {
  -Date phone
  +boolean duration
  -long code
  +setCreatedat()
  +createQuantity()
  +getTotal()
}
class Supplier {
  +Date note
  +Date name
  -Date amount
  -long score
  -Date email
  +deleteUpdatedat()
  +createDuration()
}
abstract class Payment {
  -boolean active
  -double name
  +getAddress()
  +validateStatus()
}
Invoice --* Order
Supplier ..> Payment : "*"
@enduml