@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
abstract class Order {
  +int amount
  -boolean updatedAt
  #long createdAt
  +saveNote()
  +saveCode()
  +createDescription()
  +validatePhone()
}
class Invoice {
  #long id
  +Date score
  +boolean price
  -double quantity
  +int address
  +cancelEmail()
  +getAmount()
}
abstract class Supplier {
  +boolean email
  +double duration
  #long amount
  -float price
  +double type
  +deleteUpdatedat()
  +validateEmail()
  +saveTotal()
}
class Payment {
  +float createdAt
  #float status
  +cancelEmail()
  +sendEmail()
}
Invoice ..> Payment : "0..1"
Order ..> Supplier : "0..1"
note right of Order : Ecommerce domain
@enduml