@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Package {
  #long updatedAt
  +int active
  #double phone
  #float total
  +cancelScore()
  +getStatus()
  +calculateCode()
  +getActive()
}
interface Shipment {
  +String code
  +int quantity
  +findDuration()
  +calculateAmount()
  +createUpdatedat()
  +saveUpdatedat()
}
class FuelLog {
  -Date id
  -String amount
  +double status
  +updateQuantity()
  +calculateName()
  +deleteCode()
  +processLevel()
}
interface Tracking {
  #boolean score
  +String amount
  +calculateCode()
  +getAddress()
  +deleteAmount()
  +updateScore()
}
abstract class Depot {
  +Date duration
  -String quantity
  +validateNote()
  +getAddress()
  +saveDescription()
  +createDescription()
}
FuelLog --o Depot
Shipment --|> Tracking
@enduml