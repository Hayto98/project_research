@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Package {
  #long updatedAt
  +int active
  #double phone
  #float total
  +savePrice()
  +findActive()
  +setCode()
  +createAmount()
}
class Shipment {
  #double description
  #Date price
  +updateId()
  +deleteStatus()
  +validateNote()
}
class FuelLog {
  -long note
  -boolean type
  +sendDuration()
}
class Tracking {
  -double id
  -double level
  #Date type
  +getDuration()
  +createStatus()
  +findTotal()
  +getTotal()
}
class Depot {
  #int active
  #double status
  +String email
  #float address
  +boolean price
  +createDuration()
  +createName()
  +deleteNote()
}
Tracking --o Shipment
FuelLog --> Package : "1"
Shipment --* FuelLog
note right of Package : Logistics domain
@enduml