@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Depot {
  -float createdAt
  -long id
  #Date address
  +cancelLevel()
  +findDuration()
  +createAmount()
  +validateAmount()
}
abstract class Inventory {
  -String quantity
  +double address
  -float note
  #String name
  +createLevel()
  +deletePhone()
}
class Route {
  +int score
  #double note
  +validateAddress()
  +setEmail()
  +createStatus()
  +calculateDescription()
}
abstract class Tracking {
  -String score
  +long name
  -double address
  +String quantity
  -int duration
  +createType()
}
class Customer {
  +long createdAt
  #int total
  #double description
  -Date note
  +double name
  +setId()
  +saveType()
  +findDuration()
  +getDescription()
}
Route ..|> Depot
Depot --> Tracking : "1..*"
Depot --* Route
note right of Depot : Logistics domain
@enduml