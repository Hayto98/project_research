@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Depot {
  -float createdAt
  -long id
  #Date address
  +findDescription()
  +savePrice()
  +setAmount()
  +createTotal()
}
interface Inventory {
  #long amount
  -Date address
  -double duration
  +double type
  +cancelEmail()
}
abstract class Route {
  -String status
  #Date description
  -String email
  +Date level
  -double phone
  +updateId()
  +deleteId()
  +setEmail()
}
class Tracking {
  -float email
  -boolean status
  +long price
  #Date description
  +saveCreatedat()
  +getPhone()
  +validateId()
}
class Customer {
  -int phone
  +long total
  #double updatedAt
  -boolean status
  +processActive()
  +createEmail()
  +getDuration()
  +setPrice()
}
Inventory --|> Tracking
Depot ..> Route : "0..1"
Tracking ..> Customer : "0..1"
@enduml