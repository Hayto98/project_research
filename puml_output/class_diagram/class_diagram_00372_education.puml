@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
interface Teacher {
  #Date name
  -Date price
  #boolean type
  +updateType()
  +getQuantity()
}
class Library {
  +double level
  +long quantity
  -int email
  +long updatedAt
  -String active
  +validateEmail()
  +sendType()
  +calculateCreatedat()
}
class Schedule {
  #String address
  -float name
  +Date phone
  -long email
  +setActive()
}
abstract class Book {
  #float total
  #String phone
  +deleteTotal()
}
abstract class Grade {
  -int duration
  -int email
  +Date id
  +boolean total
  +validateStatus()
  +getNote()
}
class Attendance {
  +float price
  +float score
  +Date active
  +String level
  +sendType()
}
Schedule --* Library
Book ..|> Attendance
Attendance --|> Grade
Library ..|> Schedule
Library ..|> Attendance
note right of Teacher : Education domain
@enduml