@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
interface Teacher {
  #Date name
  -Date price
  #boolean type
  +sendEmail()
  +sendCreatedat()
}
class Library {
  -int address
  #Date active
  +int note
  -float quantity
  +findScore()
  +deleteAmount()
}
class Schedule {
  #long email
  -long type
  #double name
  +sendUpdatedat()
  +processActive()
  +updatePrice()
  +validateScore()
}
class Book {
  #String phone
  -float email
  +calculateStatus()
}
abstract class Grade {
  #String status
  -boolean code
  #long active
  #float total
  +validateActive()
}
interface Attendance {
  -long amount
  #long total
  +findUpdatedat()
}
Book --o Library
Library ..> Teacher : "1"
Grade --* Library
Attendance --|> Teacher
Book --* Schedule
@enduml