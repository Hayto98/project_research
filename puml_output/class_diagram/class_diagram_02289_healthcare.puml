@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Treatment {
  #double active
  +String createdAt
  +saveStatus()
  +sendCreatedat()
  +setCode()
}
class Patient {
  #float level
  #Date address
  -int score
  -int code
  +long id
  +processAmount()
  +setPhone()
  +setType()
  +sendActive()
}
abstract class Insurance {
  +double id
  +long name
  +processStatus()
  +saveLevel()
}
interface Nurse {
  +String quantity
  -String status
  +setActive()
  +processStatus()
  +sendAmount()
}
abstract class LabTest {
  #float description
  +double updatedAt
  #int phone
  #float score
  #boolean note
  +setTotal()
  +saveTotal()
  +saveLevel()
}
interface Ward {
  -String name
  +float duration
  #boolean total
  -boolean note
  -Date quantity
  +saveDescription()
  +processPrice()
}
abstract class Billing {
  -String total
  +boolean note
  #boolean name
  -float active
  +findStatus()
  +processActive()
  +calculateUpdatedat()
  +processName()
}
LabTest ..|> Treatment
Patient ..> Insurance : "1..*"
Ward ..> Billing : "0..1"
Nurse ..> LabTest : "1..*"
note right of Treatment : Healthcare domain
@enduml