@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
class Treatment {
  #double active
  +String createdAt
  +setScore()
  +deleteQuantity()
  +findPrice()
}
class Patient {
  #Date code
  #double name
  +calculateUpdatedat()
  +sendAmount()
  +saveLevel()
}
class Insurance {
  +double active
  +String type
  +createPrice()
  +processTotal()
  +processUpdatedat()
}
class Nurse {
  #double code
  +float type
  +String score
  +double active
  +cancelAddress()
  +setAddress()
}
class LabTest {
  +int status
  +long level
  +Date score
  -float name
  +float quantity
  +updateName()
  +createStatus()
  +createEmail()
  +deleteId()
}
class Ward {
  -float type
  #float description
  +double updatedAt
  #int phone
  #float active
  +findEmail()
  +cancelEmail()
  +getAddress()
}
abstract class Billing {
  -String name
  +float duration
  #boolean total
  -boolean note
  -Date quantity
  +updateAddress()
  +getStatus()
}
Billing --o Nurse
Nurse --o Insurance
Nurse --> Treatment : "*"
@enduml