@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
abstract class Reservation {
  #double name
  -float type
  -double level
  +cancelDuration()
}
class Author {
  #int score
  #long level
  -long code
  +processLevel()
  +saveUpdatedat()
  +findPrice()
  +sendAmount()
}
class Loan {
  #Date type
  #String total
  +int amount
  +int duration
  +savePrice()
  +processQuantity()
  +getCreatedat()
}
class Member {
  -boolean code
  +int address
  +Date active
  #boolean note
  #double level
  +sendDuration()
  +updateEmail()
  +saveId()
}
class Branch {
  -String duration
  +double name
  #long updatedAt
  -Date email
  +deleteDescription()
  +updateType()
}
class Shelf {
  -String email
  #String status
  +createPrice()
  +createCode()
}
abstract class Publisher {
  #boolean name
  +float active
  +int status
  #Date description
  +getUpdatedat()
  +deleteCode()
  +saveAddress()
}
Reservation --> Member : "0..1"
Reservation --|> Author
Branch ..|> Publisher
Author --* Shelf
Shelf --|> Loan
note right of Reservation : Library domain
@enduml