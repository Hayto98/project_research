@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
abstract class Reservation {
  #double name
  -float type
  -double level
  +findUpdatedat()
}
interface Author {
  #float description
  #Date score
  +sendQuantity()
}
class Loan {
  #Date quantity
  +Date duration
  -boolean total
  +Date type
  +calculateScore()
}
abstract class Member {
  +String amount
  +long type
  #Date active
  -double id
  -String score
  +setStatus()
  +sendScore()
}
class Branch {
  #float active
  +int note
  +Date address
  #boolean total
  +getAmount()
  +validateTotal()
  +calculatePhone()
  +cancelAmount()
}
interface Shelf {
  -boolean email
  +float id
  +float amount
  +deletePrice()
  +findEmail()
  +sendTotal()
}
class Publisher {
  +double quantity
  -Date price
  +long createdAt
  +double description
  +boolean active
  +cancelDuration()
}
Author --o Loan
Loan --o Reservation
Publisher --|> Loan
Branch ..|> Reservation
Shelf ..|> Branch
Publisher ..|> Reservation
@enduml