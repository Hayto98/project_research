@startuml
skinparam shadowing true
class Comment {
  #boolean amount
  #int note
  -Date total
  +updatePhone()
  +validateAddress()
}
abstract class User {
  +Date email
  #long phone
  +createPrice()
}
class Story {
  #float code
  -double amount
  +cancelLevel()
  +setId()
}
class Message {
  +boolean updatedAt
  +float price
  #String phone
  +double total
  +saveTotal()
  +createQuantity()
}
Message --o Comment
User ..|> Comment
note right of Comment : Social Media domain
@enduml