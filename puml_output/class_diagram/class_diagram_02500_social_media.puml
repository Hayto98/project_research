@startuml
skinparam shadowing true
class Comment {
  #boolean amount
  #int note
  -Date total
  +calculateNote()
  +updateTotal()
}
class User {
  +Date total
  #long status
  +long email
  -long phone
  +getLevel()
}
class Story {
  #Date type
  +long description
  #float code
  +Date id
  +deleteCode()
  +setAddress()
  +getDescription()
  +updateEmail()
}
class Message {
  #Date status
  #boolean amount
  #int note
  +validateAddress()
  +validateTotal()
  +processDescription()
  +createCode()
}
Comment ..|> User
Comment --|> Message
Message ..|> User
@enduml