@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
abstract class Customer {
  +double total
  #float quantity
  +int level
  #boolean email
  -String id
  +createStatus()
  +sendName()
  +cancelUpdatedat()
  +validateLevel()
}
class Branch {
  #boolean active
  #boolean code
  +String email
  -boolean type
  +createStatus()
}
class Transfer {
  -double amount
  +float id
  #boolean status
  +setNote()
  +deleteUpdatedat()
  +calculateDescription()
  +getAmount()
}
class Deposit {
  #double active
  +String code
  -boolean total
  +findDescription()
  +cancelScore()
  +findId()
}
Deposit --o Transfer
Transfer --> Branch : "0..1"
@enduml