@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
abstract class Customer {
  +double total
  #float quantity
  +int level
  #boolean email
  -String id
  +sendType()
  +findDescription()
  +createActive()
  +setEmail()
}
abstract class Branch {
  #String status
  #int address
  +deleteId()
  +setEmail()
}
abstract class Transfer {
  -boolean duration
  #Date level
  +Date price
  +sendCode()
  +calculateDuration()
}
abstract class Deposit {
  #Date name
  +boolean email
  #int quantity
  +savePrice()
  +createEmail()
  +cancelDescription()
  +sendDuration()
}
Transfer ..> Deposit : "1"
Deposit ..> Transfer : "0..1"
note right of Customer : Banking domain
@enduml