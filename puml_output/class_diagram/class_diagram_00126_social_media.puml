@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Report {
  +Date level
  #double note
  #float updatedAt
  +createCreatedat()
}
abstract class Comment {
  #Date note
  -float amount
  +long duration
  #double address
  +getPrice()
}
abstract class Follower {
  -long name
  +int address
  #float price
  +double level
  #float score
  +deleteCreatedat()
  +sendScore()
  +updateCreatedat()
}
interface Hashtag {
  +boolean type
  -double phone
  +createQuantity()
  +setName()
  +setPrice()
  +deleteCode()
}
interface Group {
  #String score
  #String total
  +calculateDuration()
  +calculateEmail()
  +createPrice()
  +setCreatedat()
}
Group ..> Hashtag : "0..1"
Comment --o Report
note right of Report : Social Media domain
@enduml