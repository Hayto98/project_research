@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
interface Service {
  -boolean createdAt
  -Date type
  +long address
  +cancelType()
  +setId()
  +processQuantity()
}
interface CheckOut {
  -int active
  -float note
  +double score
  +setQuantity()
  +saveAddress()
}
abstract class Staff {
  #boolean note
  +long email
  +getScore()
  +processPrice()
  +calculateAddress()
  +cancelCreatedat()
}
interface Room {
  #float price
  #boolean note
  -float score
  -double createdAt
  #float code
  +processName()
}
class Amenity {
  +double level
  +boolean email
  -int updatedAt
  +boolean note
  +sendName()
  +saveEmail()
  +saveAddress()
}
CheckOut --> Room : "1..*"
Amenity --o CheckOut
@enduml