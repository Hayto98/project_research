@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
interface Service {
  -boolean createdAt
  -Date type
  +long address
  +cancelName()
  +saveScore()
  +deleteActive()
}
abstract class CheckOut {
  +double description
  #String note
  -long code
  #boolean price
  +long createdAt
  +sendUpdatedat()
  +deleteTotal()
  +sendDuration()
  +cancelType()
}
abstract class Staff {
  -double score
  #float createdAt
  +String code
  -float active
  -float price
  +updateNote()
  +deletePrice()
  +updateDuration()
}
class Room {
  -String status
  +String level
  #int quantity
  +sendScore()
  +sendPhone()
  +saveLevel()
  +cancelAmount()
}
abstract class Amenity {
  -double name
  +long type
  +setAmount()
}
Staff --|> CheckOut
note right of Service : Hotel domain
@enduml