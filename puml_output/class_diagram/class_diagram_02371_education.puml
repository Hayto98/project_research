@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Attendance {
  -boolean phone
  #long amount
  -int active
  +long level
  +getDuration()
  +validateActive()
  +createName()
}
abstract class Department {
  +boolean amount
  +Date address
  +boolean type
  #boolean name
  +deleteType()
  +setActive()
}
class Exam {
  +Date updatedAt
  #String createdAt
  +findQuantity()
}
class Classroom {
  +Date level
  +Date createdAt
  #long code
  +long score
  +float note
  +getNote()
  +sendDuration()
  +createDescription()
  +validateCreatedat()
}
class Book {
  #boolean createdAt
  +long total
  -int address
  #double updatedAt
  +sendCode()
}
abstract class Schedule {
  +long quantity
  #double level
  +double active
  #long address
  +float phone
  +validateActive()
  +sendStatus()
  +processActive()
  +updateCreatedat()
}
Classroom --> Department : "0..1"
Exam --|> Attendance
Schedule --o Exam
Department ..> Classroom : "0..1"
Department --o Book
note right of Attendance : Education domain
@enduml