@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Attendance {
  -boolean phone
  #long amount
  -int active
  +long level
  +setUpdatedat()
  +findUpdatedat()
  +validateScore()
}
interface Department {
  -double name
  #String price
  +boolean quantity
  +Date amount
  +findPrice()
}
interface Exam {
  #String description
  +Date type
  +int code
  +calculateStatus()
  +processId()
}
class Classroom {
  #boolean quantity
  -Date email
  +findNote()
  +cancelStatus()
}
interface Book {
  +float amount
  -String description
  -boolean phone
  #long name
  +long email
  +findAddress()
  +cancelAmount()
}
interface Schedule {
  #boolean createdAt
  +long total
  -int address
  #double updatedAt
  +sendAmount()
}
Classroom --* Schedule
Schedule --> Book : "1..*"
@enduml