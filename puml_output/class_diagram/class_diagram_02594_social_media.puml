@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Post {
  #int createdAt
  +float id
  +String quantity
  #boolean type
  +double phone
  +calculateAmount()
  +sendEmail()
}
abstract class Follower {
  +Date name
  +boolean address
  -double phone
  #double quantity
  #int active
  +getName()
  +getPhone()
  +getName()
  +setCreatedat()
}
class User {
  +long quantity
  -double status
  #Date price
  -double level
  -long amount
  +setAmount()
  +findScore()
  +findEmail()
}
class Hashtag {
  +long updatedAt
  +float amount
  +boolean quantity
  +createLevel()
  +validateActive()
  +cancelCreatedat()
  +sendDescription()
}
class Profile {
  #long phone
  -double id
  +int name
  +updateId()
  +getCreatedat()
}
User ..|> Post
User ..> Follower : "1"
note right of Post : Social Media domain
@enduml