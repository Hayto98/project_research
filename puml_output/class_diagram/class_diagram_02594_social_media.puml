@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Post {
  #int createdAt
  +float id
  +String quantity
  #boolean type
  +double phone
  +saveCode()
  +findId()
}
interface Follower {
  #long price
  -long duration
  +Date name
  +boolean address
  +calculateQuantity()
  +updateId()
  +saveAmount()
}
class User {
  +String name
  #Date duration
  +String level
  -long phone
  +Date id
  +cancelEmail()
  +processId()
  +calculateUpdatedat()
  +createCode()
}
class Hashtag {
  -long address
  -String type
  +Date email
  #Date price
  +findStatus()
  +updatePrice()
  +cancelUpdatedat()
}
class Profile {
  -String amount
  +boolean quantity
  -long updatedAt
  +updateCreatedat()
  +calculateActive()
  +validateDescription()
}
Follower ..|> Profile
Follower --|> User
Profile ..> Post : "1..*"
User --|> Hashtag
@enduml