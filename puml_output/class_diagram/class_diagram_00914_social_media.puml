@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class Hashtag {
  #Date description
  #int level
  #Date updatedAt
  +findUpdatedat()
  +setUpdatedat()
  +cancelScore()
}
class Profile {
  -float amount
  -double total
  +setStatus()
  +saveActive()
  +getPrice()
}
class Report {
  #Date email
  #float phone
  +cancelName()
  +getUpdatedat()
  +processPrice()
}
class Follower {
  #double id
  #long status
  -boolean price
  -float note
  #float phone
  +cancelNote()
  +createQuantity()
}
interface Album {
  #String level
  -long note
  #float status
  +boolean amount
  +processUpdatedat()
  +calculateUpdatedat()
}
interface User {
  #int code
  #String phone
  +Date amount
  +boolean status
  +calculatePrice()
  +getUpdatedat()
}
class Like {
  +String type
  #Date score
  +boolean id
  +validateDuration()
  +getCode()
}
Hashtag --|> Album
Profile --* Album
Like --* Hashtag
Hashtag --* User
Follower --|> Report
Album --o User
note right of Hashtag : Social Media domain
@enduml