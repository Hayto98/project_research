@startuml
skinparam defaultFontSize 11
class Exam {
  +Date score
  #Date address
  +setAmount()
  +processAddress()
  +processType()
}
interface Enrollment {
  #float amount
  #boolean status
  -float updatedAt
  +int email
  #long name
  +setAmount()
  +getStatus()
  +createPhone()
  +setCreatedat()
}
class Course {
  #double quantity
  +float score
  #int total
  #boolean name
  #String amount
  +sendNote()
  +setPrice()
  +calculateActive()
}
abstract class Assignment {
  +Date email
  #long createdAt
  +updateDuration()
}
class Teacher {
  -float address
  -String type
  -Date amount
  #Date duration
  +updateQuantity()
  +validateActive()
}
class Library {
  #Date score
  +double name
  +setLevel()
  +calculateLevel()
  +deleteName()
}
abstract class Grade {
  +boolean status
  -float duration
  +Date address
  -boolean id
  +deleteType()
  +deleteDescription()
}
Exam ..> Teacher : "1..*"
Grade --|> Teacher
Teacher --|> Grade
note right of Exam : Education domain
@enduml