@startuml
skinparam defaultFontSize 11
class Exam {
  +Date score
  #Date address
  +getType()
  +setAmount()
  +findTotal()
}
class Enrollment {
  +int address
  -boolean note
  #boolean type
  +Date level
  #boolean amount
  +cancelLevel()
  +validateDescription()
  +createCreatedat()
}
class Course {
  +long total
  -String status
  +String amount
  -long name
  +setUpdatedat()
  +processUpdatedat()
  +calculateTotal()
  +savePrice()
}
abstract class Assignment {
  -boolean description
  -String active
  -double code
  +saveId()
  +sendAddress()
  +sendId()
  +createPhone()
}
interface Teacher {
  #long id
  -Date updatedAt
  +long email
  -float quantity
  +updatePrice()
  +processLevel()
  +createType()
}
class Library {
  +Date quantity
  #Date address
  #String active
  +getScore()
}
class Grade {
  -long address
  +String code
  #long total
  +String amount
  #float name
  +calculateType()
  +validateId()
  +updateScore()
  +cancelCreatedat()
}
Enrollment --o Grade
Grade ..|> Library
Exam ..> Teacher : "1..*"
Grade --|> Teacher
Teacher --|> Grade
@enduml