@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
abstract class Customer {
  +Date id
  -int description
  -String email
  -Date phone
  +saveLevel()
  +findTotal()
  +processNote()
  +processScore()
}
interface Shipment {
  -long total
  -double address
  +float score
  +updateName()
  +deleteLevel()
  +deleteCode()
  +updateDescription()
}
abstract class Manifest {
  -float score
  #int code
  -double note
  -String active
  +float updatedAt
  +findPhone()
  +getTotal()
}
abstract class DeliveryNote {
  -boolean note
  -float address
  -boolean total
  +validateCreatedat()
  +setDescription()
  +calculateDuration()
  +processPrice()
}
class Inventory {
  #String id
  +double score
  +long level
  #double total
  +sendEmail()
  +createCode()
}
class Package {
  -boolean name
  -Date level
  +int phone
  -int active
  +Date total
  +validateCode()
  +findEmail()
}
Customer ..|> Inventory
Manifest --o Shipment
Inventory --o Manifest
@enduml