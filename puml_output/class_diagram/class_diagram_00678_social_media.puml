@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Album {
  #boolean type
  +float createdAt
  #float note
  #float score
  +long id
  +sendDescription()
}
abstract class Post {
  +long createdAt
  +String level
  #long type
  +updateActive()
  +processLevel()
  +deleteStatus()
  +calculateId()
}
abstract class Story {
  #double address
  -float level
  +calculatePhone()
}
class Comment {
  -Date id
  #Date level
  +double name
  +float quantity
  +float active
  +saveLevel()
  +updateAddress()
  +findUpdatedat()
  +saveQuantity()
}
interface User {
  -double score
  #String updatedAt
  +cancelScore()
  +getAmount()
  +calculateAmount()
  +setScore()
}
interface Message {
  #long active
  #float id
  -double name
  +setTotal()
  +getType()
  +saveAddress()
}
Story ..> Comment : "1..*"
Message --o Story
@enduml