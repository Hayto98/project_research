@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Album {
  #boolean type
  +float createdAt
  #float note
  #float score
  +long id
  +processLevel()
}
class Post {
  -String level
  +boolean type
  -double updatedAt
  +calculateName()
}
abstract class Story {
  #double address
  -float level
  +createId()
}
abstract class Comment {
  #long level
  #boolean name
  +calculateScore()
  +saveAmount()
  +processAmount()
}
class User {
  -Date duration
  +double description
  #Date name
  -Date updatedAt
  #Date phone
  +sendId()
  +getScore()
}
class Message {
  +String note
  -double quantity
  #long level
  #long code
  +sendAmount()
  +createCreatedat()
  +setName()
  +validateUpdatedat()
}
Comment --o Album
Story ..|> Comment
User ..|> Comment
note right of Album : Social Media domain
@enduml