@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Prescription {
  -Date quantity
  -Date id
  #double duration
  +boolean price
  +getCode()
}
interface Diagnosis {
  #Date note
  #boolean duration
  +cancelDescription()
  +updateTotal()
  +validateCode()
}
interface LabTest {
  -String id
  -double description
  -String status
  +double createdAt
  #double name
  +createPhone()
  +saveEmail()
  +getCode()
}
interface Doctor {
  +long id
  -boolean score
  #float type
  +updatePrice()
  +createName()
  +processDescription()
  +getAddress()
}
class Ward {
  -String level
  -double type
  +long price
  +String amount
  +float code
  +sendActive()
  +validateEmail()
  +getId()
  +sendDuration()
}
class Nurse {
  -long address
  #Date type
  #String createdAt
  +int active
  +String email
  +validateAmount()
}
class Insurance {
  #String note
  +Date email
  +saveQuantity()
  +validateStatus()
  +calculatePrice()
  +validatePrice()
}
Diagnosis --* Doctor
Nurse --|> Diagnosis
LabTest ..|> Diagnosis
Nurse --|> Prescription
@enduml