@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Shelf {
  +String note
  +String quantity
  #Date total
  #long active
  +deleteNote()
  +createDescription()
  +sendNote()
  +validateUpdatedat()
}
class Publisher {
  +int updatedAt
  +int active
  +calculateCreatedat()
  +getDescription()
}
class Book {
  +double note
  -double id
  +int active
  +getEmail()
}
class Loan {
  #Date code
  +Date status
  #long phone
  -boolean address
  #String price
  +setScore()
  +updateAddress()
}
Publisher --|> Loan
Book ..> Loan : "*"
note right of Shelf : Library domain
@enduml