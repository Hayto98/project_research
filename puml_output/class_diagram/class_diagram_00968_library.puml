@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Shelf {
  +String note
  +String quantity
  #Date total
  #long active
  +validateCreatedat()
  +deleteDuration()
  +validateAmount()
  +processPhone()
}
class Publisher {
  #String address
  +int updatedAt
  +float code
  +double name
  +String level
  +sendTotal()
  +setType()
}
abstract class Book {
  -double active
  -int description
  +createNote()
  +processAmount()
}
class Loan {
  -long email
  -boolean total
  #int code
  #Date status
  +getPhone()
  +calculateDuration()
  +sendStatus()
}
Publisher ..> Shelf : "0..1"
Book ..> Shelf : "0..1"
@enduml