@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Wishlist {
  #long active
  -Date type
  +String total
  +String level
  #String quantity
  +calculateStatus()
  +processType()
}
abstract class Product {
  -float active
  +Date name
  +findScore()
  +findTotal()
}
class Category {
  +float note
  -Date score
  +sendCreatedat()
  +updateLevel()
  +validateAddress()
}
class Payment {
  #float type
  #Date description
  -boolean name
  -int score
  +int quantity
  +updateCode()
  +createQuantity()
  +setEmail()
}
Category ..> Wishlist : "1"
Payment ..|> Category
Payment ..> Wishlist : "*"
@enduml