@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
class Wishlist {
  #long active
  -Date type
  +String total
  +String level
  #String quantity
  +findPrice()
  +processStatus()
}
interface Product {
  #int price
  -float description
  +getNote()
}
interface Category {
  -long quantity
  -int duration
  +processDescription()
  +getName()
  +createDuration()
  +saveNote()
}
interface Payment {
  -double description
  -int status
  #String createdAt
  -Date address
  +boolean quantity
  +updateType()
  +sendDuration()
  +setId()
  +cancelCreatedat()
}
