@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Transfer {
  +float name
  -boolean price
  #Date quantity
  +Date id
  #boolean updatedAt
  +findLevel()
  +setLevel()
  +deleteAddress()
  +processUpdatedat()
}
abstract class Interest {
  +double email
  +double createdAt
  +setAmount()
  +findEmail()
  +calculateType()
  +setPrice()
}
interface Statement {
  -Date email
  -Date price
  #int active
  +int total
  +cancelDescription()
  +updateScore()
}
class Customer {
  +float score
  +double active
  -long status
  +double id
  #double email
  +createEmail()
}
Interest ..> Statement : "1..*"
Customer --o Statement
@enduml