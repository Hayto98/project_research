@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Transfer {
  +float name
  -boolean price
  #Date quantity
  +Date id
  #boolean updatedAt
  +deleteUpdatedat()
  +deleteType()
  +getEmail()
  +updateDescription()
}
abstract class Interest {
  #boolean type
  -long price
  -Date active
  +calculateAddress()
  +findActive()
  +updateAmount()
  +updateDuration()
}
class Statement {
  +String type
  -int score
  +double active
  +validateAmount()
  +calculateType()
  +getName()
  +updateDuration()
}
interface Customer {
  +Date price
  #float duration
  +float active
  -float amount
  +getLevel()
  +deleteAmount()
  +cancelAmount()
}
Interest ..|> Customer
Transfer --|> Statement
note right of Transfer : Banking domain
@enduml