@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
abstract class Treatment {
  +float address
  #boolean score
  +getName()
}
class Patient {
  +float quantity
  #boolean active
  +Date score
  -float duration
  #long email
  +processActive()
  +sendName()
  +sendPhone()
}
abstract class Hospital {
  -double level
  -long updatedAt
  -int code
  -Date createdAt
  #long address
  +sendTotal()
  +findPhone()
}
class Diagnosis {
  +int name
  +String id
  -Date type
  +validateCreatedat()
}
interface Insurance {
  -double code
  -int description
  +deleteType()
}
class Appointment {
  +float description
  -String active
  +updateTotal()
  +createScore()
  +getNote()
}
class Nurse {
  -int code
  +float type
  -int description
  -long total
  +deleteTotal()
  +deleteActive()
  +createScore()
}
Treatment ..> Hospital : "*"
Treatment --|> Diagnosis
Hospital --o Nurse
Treatment ..> Insurance : "1..*"
Patient --o Diagnosis
Insurance --> Nurse : "0..1"
@enduml