@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Doctor {
  +int amount
  -Date note
  -long score
  -long id
  +double level
  +createQuantity()
  +createScore()
}
interface Appointment {
  +long type
  +double duration
  -String email
  -long level
  +updateLevel()
}
class Insurance {
  #double description
  #long amount
  -String address
  +validateNote()
  +calculatePhone()
  +getStatus()
}
class Ward {
  #long name
  #Date email
  #boolean active
  -int status
  +updateNote()
}
class Diagnosis {
  -float level
  +double updatedAt
  #long quantity
  -boolean description
  #boolean score
  +sendType()
  +setDuration()
  +createId()
}
class Patient {
  +int score
  #double status
  -double total
  #boolean code
  +Date createdAt
  +getEmail()
  +cancelCreatedat()
}
class Prescription {
  -float email
  +float id
  -Date total
  +float type
  +calculateActive()
  +updateId()
  +processUpdatedat()
}
Insurance --o Ward
Patient --o Ward
note right of Doctor : Healthcare domain
@enduml