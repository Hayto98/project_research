@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Doctor {
  +int amount
  -Date note
  -long score
  -long id
  +double level
  +deleteCreatedat()
  +calculatePhone()
}
class Appointment {
  +long type
  +double duration
  -String email
  -long level
  +updateStatus()
}
interface Insurance {
  +float level
  #int duration
  +saveCreatedat()
  +getDescription()
}
interface Ward {
  -double address
  -String duration
  +long name
  -float email
  +boolean phone
  +updatePhone()
  +findDescription()
  +cancelActive()
}
interface Diagnosis {
  -int phone
  #float active
  +processDuration()
}
abstract class Patient {
  #float note
  #float level
  +processDescription()
  +validateDescription()
}
interface Prescription {
  +double duration
  #long quantity
  -boolean note
  +cancelAmount()
  +sendCreatedat()
  +setDescription()
}
Prescription --|> Insurance
Doctor --> Ward : "1"
Diagnosis --|> Ward
Prescription --|> Appointment
Appointment --o Diagnosis
@enduml