@startuml
skinparam monochrome true
skinparam shadowing true
class User {
  -double email
  +String phone
  #float code
  #boolean updatedAt
  -boolean type
  +getNote()
  +validateAddress()
  +setDuration()
  +calculatePrice()
}
interface Follower {
  #String note
  #long email
  +createUpdatedat()
  +findAddress()
  +deleteTotal()
  +createScore()
}
interface Hashtag {
  #long quantity
  #int score
  -long name
  +getEmail()
  +validateLevel()
}
class Story {
  -String note
  +int description
  -long amount
  #long score
  +cancelActive()
  +processName()
}
abstract class Comment {
  #int price
  #double createdAt
  +processAddress()
  +processLevel()
  +sendPhone()
  +setUpdatedat()
}
class Message {
  #double quantity
  #boolean phone
  +boolean note
  +long score
  +processEmail()
}
Follower --o Hashtag
Comment --* User
User --o Comment
User --o Follower
note right of User : Social Media domain
@enduml