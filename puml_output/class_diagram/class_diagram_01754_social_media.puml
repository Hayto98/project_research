@startuml
skinparam monochrome true
skinparam shadowing true
class User {
  -double email
  +String phone
  #float code
  #boolean updatedAt
  -boolean type
  +setName()
  +deletePrice()
  +findQuantity()
  +findStatus()
}
class Follower {
  -boolean duration
  #Date total
  +deletePrice()
}
class Hashtag {
  -int email
  #Date price
  +getEmail()
  +deleteType()
  +deleteEmail()
}
abstract class Story {
  #boolean score
  +boolean active
  -Date amount
  +double quantity
  +deleteType()
  +processDuration()
  +setDuration()
}
class Comment {
  -int phone
  #float level
  +Date duration
  #float email
  +calculateCode()
  +setUpdatedat()
}
class Message {
  +boolean quantity
  #double duration
  +double email
  +findTotal()
}
Message ..> Follower : "0..1"
Comment --o Story
Story --o Hashtag
Message --> Comment : "1..*"
User ..> Follower : "1"
@enduml