@startuml
skinparam monochrome true
skinparam defaultFontSize 11
abstract class Librarian {
  #float note
  +long quantity
  +setNote()
  +processAmount()
  +cancelPhone()
  +findCode()
}
class Fine {
  +float id
  -int note
  -Date createdAt
  #float phone
  -long level
  +updateCreatedat()
  +deleteId()
  +createActive()
}
class Branch {
  #float code
  #boolean duration
  +boolean note
  #float total
  +createNote()
  +cancelAddress()
  +saveTotal()
  +createScore()
}
interface Renewal {
  +boolean price
  -int amount
  -float active
  +updateAmount()
  +setLevel()
}
Branch --|> Fine
Librarian --o Fine
Renewal ..|> Librarian
note right of Librarian : Library domain
@enduml