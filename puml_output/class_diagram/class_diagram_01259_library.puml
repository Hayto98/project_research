@startuml
skinparam monochrome true
skinparam defaultFontSize 11
abstract class Librarian {
  #float note
  +long quantity
  +getLevel()
  +findEmail()
  +calculateAmount()
  +deletePhone()
}
abstract class Fine {
  +Date level
  #double phone
  #String code
  +saveTotal()
  +sendEmail()
  +getAmount()
  +sendPhone()
}
abstract class Branch {
  -Date price
  #float amount
  +validateScore()
  +updateCreatedat()
  +deleteCode()
}
class Renewal {
  #long description
  -String id
  +double email
  +setCreatedat()
  +validateLevel()
  +setActive()
  +cancelDuration()
}
Renewal --o Fine
Branch --o Renewal
@enduml