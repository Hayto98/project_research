@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
abstract class Route {
  -int score
  #long phone
  +processDescription()
  +saveCode()
}
abstract class Shipment {
  -boolean total
  #Date description
  #float active
  -float createdAt
  +double email
  +validateNote()
}
class Manifest {
  -double phone
  -long type
  +String address
  #float email
  +createPhone()
  +setPrice()
  +cancelUpdatedat()
  +sendType()
}
interface Inventory {
  +double amount
  #double total
  +int status
  +cancelTotal()
}
class DeliveryNote {
  #long note
  +int total
  +deleteName()
}
interface Driver {
  +long duration
  -long createdAt
  -String quantity
  +double total
  +calculateLevel()
}
class FuelLog {
  +String amount
  +String quantity
  -String level
  +long type
  +setDuration()
  +cancelCreatedat()
}
FuelLog --* Manifest
DeliveryNote ..|> Shipment
note right of Route : Logistics domain
@enduml