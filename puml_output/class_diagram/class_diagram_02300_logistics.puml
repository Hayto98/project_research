@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
abstract class Route {
  -int score
  #long phone
  +sendCreatedat()
  +cancelPrice()
}
class Shipment {
  #Date total
  -int type
  +saveActive()
  +cancelScore()
}
class Manifest {
  +long active
  -Date price
  +long createdAt
  -double note
  +cancelPhone()
  +processDescription()
  +saveName()
}
abstract class Inventory {
  -String name
  -float duration
  #int total
  #double quantity
  +createCode()
  +setNote()
}
class DeliveryNote {
  -String note
  +String level
  +findCode()
  +validateActive()
  +getCreatedat()
  +cancelStatus()
}
abstract class Driver {
  +String duration
  #long quantity
  #int updatedAt
  #long amount
  -String name
  +saveScore()
  +createQuantity()
  +deleteCreatedat()
}
class FuelLog {
  #String total
  #long id
  +long duration
  +sendName()
  +createId()
  +getTotal()
}
Shipment --o Route
Route --* Shipment
@enduml