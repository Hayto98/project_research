@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Branch {
  -long score
  #int name
  #int duration
  +sendName()
  +deletePrice()
  +cancelCreatedat()
  +calculateEmail()
}
interface Shelf {
  #double code
  #float status
  +saveAmount()
  +calculateId()
  +setStatus()
  +processUpdatedat()
}
class Catalog {
  #float name
  #String total
  #String createdAt
  #float id
  +deleteName()
  +processStatus()
  +processCreatedat()
}
class Author {
  -Date code
  -Date updatedAt
  +String duration
  #long level
  -long name
  +deleteNote()
  +validateCreatedat()
  +findAddress()
}
class Loan {
  +String id
  #boolean updatedAt
  +processCode()
  +cancelDuration()
}
class Member {
  -Date amount
  #int description
  +Date id
  +sendCreatedat()
}
interface Reservation {
  #int updatedAt
  -float price
  +getUpdatedat()
}
Member --|> Branch
Branch ..|> Reservation
Shelf ..> Catalog : "1..*"
note right of Branch : Library domain
@enduml