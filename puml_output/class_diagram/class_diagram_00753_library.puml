@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Branch {
  -long score
  #int name
  #int duration
  +sendQuantity()
  +setUpdatedat()
  +setPrice()
  +setType()
}
abstract class Shelf {
  #float total
  +String email
  #double id
  +sendDuration()
  +validateQuantity()
  +processLevel()
  +updatePrice()
}
class Catalog {
  +float type
  -String updatedAt
  +sendId()
  +setCode()
  +updatePrice()
  +createStatus()
}
class Author {
  +String active
  -String quantity
  +saveLevel()
  +cancelNote()
  +findCode()
  +validateStatus()
}
abstract class Loan {
  +boolean updatedAt
  +long code
  +processNote()
  +saveEmail()
  +getType()
  +cancelAmount()
}
class Member {
  -int phone
  #long quantity
  +String amount
  +int note
  +updateActive()
}
interface Reservation {
  #int type
  +int code
  +long quantity
  +deleteAddress()
  +getStatus()
}
Member --|> Reservation
Loan ..> Shelf : "1"
Shelf --> Author : "0..1"
Reservation --|> Catalog
Branch ..|> Shelf
Member --|> Branch
@enduml