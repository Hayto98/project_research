@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
abstract class Wishlist {
  -int note
  -boolean amount
  -boolean phone
  +float score
  +saveDescription()
  +setQuantity()
  +sendQuantity()
  +saveTotal()
}
interface Cart {
  #int id
  -String level
  +processType()
  +sendNote()
  +saveEmail()
}
class Category {
  -Date updatedAt
  +float address
  #float type
  +boolean email
  +sendDescription()
}
class Return {
  +boolean score
  -String total
  -double note
  +Date active
  +processActive()
}
Cart --o Wishlist
Category --|> Return
note right of Wishlist : Ecommerce domain
@enduml