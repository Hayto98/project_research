@startuml
skinparam monochrome true
skinparam shadowing true
class Post {
  +long email
  #String code
  +boolean total
  #boolean price
  +findAmount()
  +setAddress()
  +validateNote()
  +createScore()
}
interface Story {
  +float name
  #long address
  #long status
  +int createdAt
  #Date total
  +processQuantity()
}
class Notification {
  -boolean phone
  #Date description
  +String duration
  +setAddress()
  +deleteStatus()
  +setStatus()
  +calculateAddress()
}
class User {
  +int duration
  +float note
  #boolean level
  #double price
  +boolean id
  +createPhone()
  +setName()
  +sendStatus()
  +setCreatedat()
}
abstract class Hashtag {
  -double name
  +String level
  +deleteId()
  +deleteLevel()
}
class Follower {
  -Date description
  -Date id
  +int score
  +setName()
}
interface Album {
  -double note
  -Date email
  -String createdAt
  +String name
  +saveCode()
  +deleteScore()
}
Post --|> User
Album ..> Story : "*"
User --o Story
Notification --|> Post
Post --> Hashtag : "1..*"
note right of Post : Social Media domain
@enduml