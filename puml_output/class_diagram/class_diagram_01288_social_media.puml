@startuml
skinparam monochrome true
skinparam shadowing true
class Post {
  +long email
  #String code
  +boolean total
  #boolean price
  +cancelUpdatedat()
  +processUpdatedat()
  +setDescription()
  +createActive()
}
class Story {
  -String email
  +double score
  +float active
  #long type
  #long name
  +deleteEmail()
  +validateNote()
}
interface Notification {
  +int note
  -int quantity
  +updateEmail()
  +getCreatedat()
  +sendAmount()
}
class User {
  -int type
  +String status
  +getPhone()
}
class Hashtag {
  -boolean price
  #String note
  +int level
  +saveStatus()
}
interface Follower {
  +float description
  #String price
  +int quantity
  -float phone
  #String code
  +saveDuration()
}
abstract class Album {
  +boolean updatedAt
  +int name
  #int createdAt
  +boolean description
  #long id
  +sendUpdatedat()
  +processPrice()
  +getEmail()
  +setId()
}
Post --> Album : "1..*"
User ..|> Notification
@enduml