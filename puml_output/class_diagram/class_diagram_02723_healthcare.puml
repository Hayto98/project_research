@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Treatment {
  -Date amount
  +Date createdAt
  -Date email
  +createStatus()
}
interface Billing {
  -boolean id
  +long address
  +updateCode()
  +updateLevel()
}
interface Diagnosis {
  +int createdAt
  #boolean total
  #float name
  +deleteCreatedat()
  +cancelCreatedat()
  +findLevel()
  +calculateTotal()
}
class LabTest {
  #int phone
  +double status
  +calculateStatus()
}
abstract class Doctor {
  +double updatedAt
  -Date email
  +String quantity
  -long note
  +deleteDescription()
  +updateName()
  +calculateActive()
  +findEmail()
}
class Nurse {
  #Date updatedAt
  +long description
  -long phone
  -double address
  #int quantity
  +saveTotal()
}
class Insurance {
  #int address
  #long duration
  -float score
  +boolean price
  +String email
  +setAmount()
}
Doctor --> Insurance : "1..*"
Treatment --|> Diagnosis
@enduml