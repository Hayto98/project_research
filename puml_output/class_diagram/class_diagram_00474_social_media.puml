@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Like {
  -long status
  #long phone
  +createPrice()
  +createDescription()
}
class Message {
  +boolean type
  -boolean phone
  -long email
  +double note
  +Date code
  +processType()
  +findQuantity()
  +sendPrice()
}
interface Group {
  -boolean quantity
  #float phone
  -int active
  #boolean total
  #String amount
  +validateAmount()
}
abstract class Follower {
  +float quantity
  +Date amount
  -int id
  +createUpdatedat()
  +processType()
  +setCreatedat()
  +sendPhone()
}
Follower --* Group
Message ..> Follower : "1"
Message ..> Group : "1..*"
note right of Like : Social Media domain
@enduml