@startuml
skinparam monochrome true
skinparam defaultFontSize 11
abstract class Customer {
  -String status
  #int createdAt
  #String description
  -long active
  +validatePrice()
}
interface Payment {
  #double updatedAt
  -double status
  +sendLevel()
  +validateStatus()
  +saveNote()
}
interface Supplier {
  -boolean total
  #Date id
  +String description
  -long name
  -String price
  +validateDuration()
}
class Wishlist {
  #long code
  -Date id
  #long quantity
  +Date address
  +long score
  +updateStatus()
  +deleteActive()
  +deleteName()
}
Payment --* Customer
Wishlist ..|> Payment
@enduml