@startuml
skinparam monochrome true
skinparam defaultFontSize 11
abstract class Customer {
  -String status
  #int createdAt
  #String description
  -long active
  +saveDuration()
}
class Payment {
  -long status
  +boolean price
  #double note
  +findId()
  +deleteName()
  +calculateType()
  +cancelStatus()
}
class Supplier {
  -String address
  -String price
  #String code
  -float score
  +createScore()
  +createNote()
  +saveScore()
}
class Wishlist {
  +double amount
  -float address
  +float quantity
  +getPhone()
  +savePrice()
}
Payment --* Customer
Payment --o Wishlist
Supplier ..> Wishlist : "1..*"
note right of Customer : Ecommerce domain
@enduml