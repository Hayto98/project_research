@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
interface Comment {
  #int updatedAt
  #boolean price
  +validateLevel()
  +calculateDuration()
}
class Notification {
  #double price
  #int duration
  +double id
  #String level
  #float code
  +updateActive()
  +calculateActive()
  +createTotal()
}
class Profile {
  +boolean status
  +long code
  +String createdAt
  +findId()
  +sendScore()
  +cancelDuration()
}
interface Post {
  -int note
  +boolean total
  +Date updatedAt
  #String price
  +deleteTotal()
  +saveLevel()
}
class User {
  -double duration
  +Date code
  +int name
  +deleteStatus()
  +getLevel()
  +setScore()
}
class Group {
  +String duration
  +double score
  +boolean description
  -long phone
  #int level
  +validatePrice()
  +cancelName()
  +validateAddress()
  +validateQuantity()
}
Post --* Notification
Comment --> Profile : "*"
note right of Comment : Social Media domain
@enduml