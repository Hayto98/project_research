@startuml
skinparam defaultFontSize 11
class Tracking {
  #long type
  -Date note
  +updateType()
  +updateAddress()
  +calculateEmail()
}
class Customer {
  -float amount
  #String total
  #float email
  +calculateAmount()
  +createScore()
  +setAmount()
}
class Package {
  +long note
  +int quantity
  +String level
  +sendPrice()
  +updateUpdatedat()
  +createDescription()
}
class Vehicle {
  -String id
  -long total
  +updateType()
  +setCreatedat()
  +calculateLevel()
}
class Shipment {
  #boolean quantity
  -double phone
  -boolean total
  #long address
  +Date level
  +sendStatus()
  +cancelUpdatedat()
  +setUpdatedat()
}
class FuelLog {
  #float type
  #boolean total
  +processDuration()
  +findScore()
}
abstract class Depot {
  #Date level
  +int description
  #String price
  +calculateScore()
}
Depot --* Vehicle
FuelLog ..|> Customer
Package --|> Shipment
Tracking ..|> Customer
@enduml