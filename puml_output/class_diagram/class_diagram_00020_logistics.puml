@startuml
skinparam defaultFontSize 11
class Tracking {
  #long type
  -Date note
  +deleteName()
  +validateAmount()
  +findAmount()
}
abstract class Customer {
  +float note
  +int code
  #double email
  -Date duration
  +getPhone()
  +getCreatedat()
  +updateId()
}
class Package {
  #boolean active
  +String createdAt
  +calculateId()
  +calculateAddress()
  +createAmount()
  +findEmail()
}
abstract class Vehicle {
  #boolean phone
  -double total
  -boolean address
  #long duration
  +saveAddress()
  +findName()
}
class Shipment {
  #float type
  #boolean total
  +updateQuantity()
  +processCreatedat()
}
interface FuelLog {
  +Date duration
  +String price
  -Date amount
  +validateCreatedat()
  +updateType()
  +validateDuration()
  +getCode()
}
class Depot {
  #long address
  #float score
  -int level
  +validateStatus()
  +sendAddress()
  +findScore()
}
Depot --* Shipment
Shipment ..> Vehicle : "*"
note right of Tracking : Logistics domain
@enduml