@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
interface Nurse {
  +float createdAt
  -long code
  +long quantity
  #double id
  +createUpdatedat()
}
interface Billing {
  -float address
  +String level
  +findPhone()
  +cancelPhone()
}
class Appointment {
  #long description
  #int total
  +long price
  +float duration
  +deleteCreatedat()
  +cancelStatus()
  +calculatePrice()
}
class Patient {
  #double updatedAt
  +int note
  +saveTotal()
}
class Insurance {
  -int score
  #Date amount
  #boolean code
  -String updatedAt
  +processPhone()
  +processQuantity()
  +createEmail()
  +deleteId()
}
interface Doctor {
  #boolean address
  -int id
  +processActive()
  +deleteAmount()
  +calculateType()
  +validateDescription()
}
abstract class LabTest {
  +boolean email
  +String createdAt
  +sendAmount()
  +validateNote()
}
Appointment ..> Doctor : "1..*"
LabTest --* Doctor
Insurance --> Billing : "1"
Patient --* Nurse
@enduml