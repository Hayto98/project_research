@startuml
skinparam monochrome true
skinparam defaultFontSize 13
abstract class Patient {
  -String description
  +int note
  #double name
  #String id
  +float status
  +saveDescription()
  +createActive()
  +deleteEmail()
}
class Nurse {
  -int id
  #boolean status
  -long name
  +createTotal()
}
class Treatment {
  #double price
  #boolean description
  #Date quantity
  +updateAmount()
}
interface LabTest {
  #boolean createdAt
  #boolean active
  +findCreatedat()
  +getEmail()
  +updateAddress()
  +processDescription()
}
class Appointment {
  -float type
  -float phone
  #float id
  -boolean total
  +cancelActive()
}
class Hospital {
  +Date quantity
  #int total
  #String duration
  -String createdAt
  #int active
  +validateQuantity()
  +setCreatedat()
  +saveCode()
}
Appointment --* Patient
Hospital ..> Patient : "0..1"
Treatment ..|> Hospital
@enduml