@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
abstract class Withdrawal {
  -String price
  +String total
  #boolean updatedAt
  +saveLevel()
  +processAmount()
  +setName()
}
interface Deposit {
  +String score
  -int createdAt
  #int total
  -long level
  +deleteName()
  +deletePrice()
  +processPrice()
}
class Teller {
  +Date total
  #long createdAt
  #int address
  -long amount
  +cancelType()
  +calculateActive()
  +processCode()
}
interface Loan {
  -long code
  -long status
  -boolean total
  +float id
  +getType()
}
class Card {
  #float updatedAt
  +long id
  +int price
  #float amount
  +calculateActive()
  +updateDuration()
  +validateName()
}
class Customer {
  +long duration
  #int code
  #float id
  +int description
  +long name
  +processDuration()
  +deleteCreatedat()
  +processTotal()
  +createEmail()
}
Customer --> Teller : "*"
Withdrawal --|> Deposit
Loan --* Card
Card ..> Deposit : "1"
note right of Withdrawal : Banking domain
@enduml