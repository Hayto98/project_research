@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
abstract class Withdrawal {
  -String price
  +String total
  #boolean updatedAt
  +processNote()
  +cancelActive()
  +deleteDuration()
}
class Deposit {
  -boolean name
  +double level
  +cancelEmail()
  +validateEmail()
}
abstract class Teller {
  -long score
  +String amount
  +double note
  +calculateUpdatedat()
  +saveCode()
  +createQuantity()
  +validateType()
}
class Loan {
  #Date createdAt
  -boolean level
  +long address
  -long amount
  #double id
  +findDuration()
  +cancelQuantity()
  +setDescription()
  +calculateActive()
}
class Card {
  -String duration
  -long status
  +validateScore()
  +sendCode()
  +findUpdatedat()
}
class Customer {
  -long id
  #int type
  +calculateCode()
}
Customer --* Deposit
Deposit --> Customer : "1..*"
Loan ..|> Card
@enduml