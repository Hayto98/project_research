@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
interface Route {
  #long createdAt
  -long amount
  +float price
  +getPrice()
  +processTotal()
}
class Driver {
  -boolean code
  #long duration
  +boolean status
  -boolean name
  +updatePhone()
  +deleteNote()
  +deletePhone()
}
interface FuelLog {
  #int active
  #double name
  -double price
  +deleteId()
}
class Vehicle {
  +long name
  +long note
  #int type
  +float total
  +createId()
  +updateCreatedat()
}
class Depot {
  -long createdAt
  #int score
  #long active
  +cancelAmount()
  +getCreatedat()
}
interface Customer {
  #int note
  -int quantity
  -long score
  +cancelPhone()
  +updateCreatedat()
  +validateTotal()
}
Vehicle ..> Route : "1..*"
Driver ..|> Depot
Customer --> Vehicle : "1..*"
FuelLog --o Vehicle
@enduml