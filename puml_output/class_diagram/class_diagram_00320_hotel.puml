@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Staff {
  #float level
  +double phone
  #boolean amount
  -double duration
  +processAmount()
  +saveAddress()
  +processEmail()
  +saveQuantity()
}
class CheckOut {
  -int total
  #boolean level
  #float duration
  #float score
  +processActive()
  +sendNote()
}
abstract class Restaurant {
  -Date code
  -String score
  -boolean address
  #long note
  +updateStatus()
}
class Guest {
  #Date active
  +int note
  +String status
  #long level
  +getTotal()
  +saveAddress()
  +saveUpdatedat()
  +saveDuration()
}
Guest --|> Staff
Guest ..> Restaurant : "1"
Restaurant --o Staff
@enduml