@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Staff {
  #float level
  +double phone
  #boolean amount
  -double duration
  +setAmount()
  +cancelDescription()
  +createPhone()
  +calculateLevel()
}
interface CheckOut {
  +int total
  -float type
  -String description
  #long active
  #float updatedAt
  +processEmail()
  +setPhone()
  +sendPhone()
  +findCode()
}
class Restaurant {
  +double email
  #Date active
  +int note
  +getLevel()
  +validateType()
}
class Guest {
  -int level
  +double duration
  #Date email
  +validateCode()
}
Staff ..|> Restaurant
CheckOut ..> Restaurant : "0..1"
CheckOut ..|> Staff
note right of Staff : Hotel domain
@enduml