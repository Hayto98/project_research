@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
class Guest {
  -long duration
  #String level
  -String active
  #float id
  +sendNote()
}
abstract class Payment {
  +boolean type
  +long note
  +float createdAt
  #int updatedAt
  +processQuantity()
  +findActive()
}
class Invoice {
  #int id
  -float price
  -float code
  +long type
  -long active
  +sendTotal()
  +setPhone()
  +sendId()
}
class CheckOut {
  -int duration
  #boolean level
  -long score
  +processActive()
}
class Booking {
  +boolean quantity
  -float active
  +createQuantity()
}
CheckOut ..|> Invoice
Guest --* CheckOut
@enduml