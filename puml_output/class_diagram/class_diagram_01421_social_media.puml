@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Message {
  +String note
  -double price
  -Date email
  -String level
  +deleteType()
  +setEmail()
  +processScore()
}
class Post {
  #boolean address
  #long total
  -Date type
  +updateDuration()
  +findAmount()
  +findNote()
}
class Report {
  #long amount
  #boolean score
  +boolean updatedAt
  +getLevel()
}
interface Profile {
  #float email
  +int description
  +boolean code
  +sendPrice()
  +deleteQuantity()
  +sendCreatedat()
  +cancelId()
}
interface Follower {
  +int price
  +Date active
  +boolean duration
  #boolean description
  +updateActive()
  +calculateActive()
}
interface User {
  #Date score
  -double quantity
  +findName()
}
User ..> Profile : "1"
Report --|> Follower
Report ..> Message : "*"
Follower ..> Message : "0..1"
@enduml