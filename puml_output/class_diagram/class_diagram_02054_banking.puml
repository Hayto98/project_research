@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
interface Branch {
  #double price
  -String updatedAt
  +long phone
  -float duration
  +setDescription()
  +setEmail()
  +cancelType()
  +findCode()
}
interface Customer {
  -double updatedAt
  #boolean createdAt
  -float active
  #boolean total
  #double address
  +sendDescription()
  +calculateName()
}
abstract class Teller {
  #String duration
  #long name
  +saveUpdatedat()
}
class Account {
  +String id
  +String updatedAt
  -double status
  +Date description
  #float duration
  +calculateCreatedat()
}
abstract class Loan {
  +boolean createdAt
  +Date amount
  -Date address
  -long email
  -Date updatedAt
  +getTotal()
  +createCode()
  +saveDescription()
}
class Statement {
  +long active
  #boolean email
  +boolean updatedAt
  #String id
  +String score
  +sendDuration()
  +validateQuantity()
  +getAmount()
}
Customer ..|> Teller
Account --> Branch : "0..1"
Teller --* Account
Account --* Customer
Customer --> Account : "*"
note right of Branch : Banking domain
@enduml