@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
interface Branch {
  #double price
  -String updatedAt
  +long phone
  -float duration
  +cancelStatus()
  +setLevel()
  +sendDescription()
  +setActive()
}
class Customer {
  +int level
  #boolean type
  #double code
  -double note
  +setId()
  +setPhone()
  +deleteLevel()
  +createDuration()
}
interface Teller {
  -String amount
  #String active
  #String description
  #long total
  +Date name
  +updateType()
  +deletePhone()
}
abstract class Account {
  +String updatedAt
  +String status
  +setName()
  +findType()
}
class Loan {
  #float code
  -int name
  +float price
  -Date createdAt
  #long note
  +createScore()
  +getScore()
}
class Statement {
  +double email
  -String address
  #float quantity
  +int level
  +findDuration()
  +getQuantity()
  +findCreatedat()
  +validateStatus()
}
Branch ..|> Loan
Customer --> Teller : "0..1"
Loan ..|> Branch
@enduml