@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
abstract class Housekeeping {
  #int price
  #Date address
  +findLevel()
}
interface Room {
  +String score
  #long email
  -float phone
  +int address
  +setTotal()
  +findDescription()
  +calculateNote()
}
abstract class Payment {
  +Date name
  -Date address
  #boolean type
  #long code
  +calculateAddress()
}
class Invoice {
  #Date address
  +Date total
  +String updatedAt
  +Date level
  +updateEmail()
  +createAddress()
}
Invoice --* Payment
Housekeeping --o Invoice
@enduml