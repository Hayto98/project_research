@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
abstract class Exam {
  #String price
  +int level
  +boolean description
  +int code
  +processQuantity()
  +setNote()
}
abstract class Grade {
  -double code
  -boolean active
  -int note
  #boolean phone
  #boolean level
  +saveId()
  +updateActive()
  +cancelDescription()
}
interface Book {
  -float total
  +boolean active
  #double phone
  +validateAmount()
}
class Library {
  +String duration
  -long total
  +int name
  +cancelLevel()
  +getCreatedat()
}
class Attendance {
  -Date price
  #String updatedAt
  +cancelCode()
  +calculateEmail()
  +updateStatus()
}
interface Schedule {
  -long type
  -long score
  -int note
  +cancelAddress()
}
class Enrollment {
  +String createdAt
  -double description
  -Date email
  #Date quantity
  -Date updatedAt
  +saveNote()
  +deleteCreatedat()
  +deleteDescription()
}
Library --o Enrollment
Grade --> Library : "1..*"
@enduml