@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
interface Order {
  +Date level
  #int description
  +long amount
  -float score
  +deleteQuantity()
}
abstract class Warehouse {
  -double status
  #int code
  #String email
  +getScore()
  +setPrice()
  +createQuantity()
}
class Wishlist {
  #long score
  +Date duration
  -double id
  +double note
  +updateUpdatedat()
  +setQuantity()
}
class Product {
  -boolean amount
  #boolean createdAt
  #String phone
  -double level
  #boolean name
  +deleteId()
  +getDescription()
  +getCode()
  +deleteAddress()
}
abstract class Customer {
  #String description
  #float amount
  -Date type
  +processAddress()
}
interface Coupon {
  +boolean active
  +Date score
  -String description
  +double price
  +cancelEmail()
  +findLevel()
}
class Invoice {
  -double description
  -String quantity
  #long type
  +calculateCreatedat()
  +calculateDuration()
  +processNote()
  +processEmail()
}
Product --* Order
Invoice --o Warehouse
note right of Order : Ecommerce domain
@enduml