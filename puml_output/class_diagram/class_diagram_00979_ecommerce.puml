@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
interface Order {
  +Date level
  #int description
  +long amount
  -float score
  +validateCode()
}
class Warehouse {
  -float updatedAt
  #int status
  #String code
  #boolean email
  -String note
  +setCreatedat()
}
abstract class Wishlist {
  -boolean quantity
  -int status
  #double phone
  -int id
  +saveQuantity()
  +calculateType()
  +sendId()
  +deleteAddress()
}
class Product {
  -boolean updatedAt
  +String price
  -boolean amount
  #boolean createdAt
  +setAmount()
}
abstract class Customer {
  +String level
  +float total
  +long description
  -Date id
  #int name
  +deleteScore()
  +validateName()
}
class Coupon {
  #boolean id
  +Date note
  #boolean address
  #double email
  +createDescription()
  +saveLevel()
}
class Invoice {
  #long code
  #boolean id
  #String note
  +int active
  #float createdAt
  +setDuration()
  +findActive()
  +validateDuration()
}
Product ..> Order : "1..*"
Product ..|> Invoice
Product --o Customer
Coupon --o Product
Wishlist --|> Coupon
@enduml