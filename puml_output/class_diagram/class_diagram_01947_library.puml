@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Renewal {
  -Date address
  -float score
  -float email
  +updateAddress()
  +cancelId()
  +calculateUpdatedat()
}
class Book {
  +int email
  -Date note
  #boolean code
  #Date updatedAt
  +deletePrice()
}
class Author {
  +int total
  +long phone
  +double description
  +deleteDescription()
}
class Member {
  #float updatedAt
  +int total
  #boolean status
  +float amount
  +processDuration()
  +updateDescription()
  +setStatus()
}
interface Branch {
  +Date score
  +boolean active
  +String email
  -double price
  +Date status
  +deleteDuration()
  +processId()
  +updateDescription()
  +getDuration()
}
Member --> Branch : "1"
Book ..|> Branch
Author --|> Book
Member ..|> Author
note right of Renewal : Library domain
@enduml