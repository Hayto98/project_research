@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Renewal {
  -Date address
  -float score
  -float email
  +cancelNote()
  +saveDescription()
  +calculateName()
}
interface Book {
  -long total
  #long updatedAt
  +saveUpdatedat()
  +createAddress()
  +createScore()
  +updateUpdatedat()
}
class Author {
  -Date level
  #String duration
  +double name
  -int amount
  +findPhone()
}
class Member {
  +long createdAt
  #Date note
  -int id
  -Date description
  +calculateAddress()
}
interface Branch {
  +float amount
  -double level
  #int score
  +validateEmail()
  +updateUpdatedat()
}
Branch --> Member : "1..*"
Member ..|> Renewal
Renewal --|> Book
Author --|> Member
@enduml