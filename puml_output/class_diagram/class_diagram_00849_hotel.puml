@startuml
skinparam shadowing true
class Invoice {
  #double code
  -String level
  #int quantity
  +findPrice()
  +setStatus()
  +calculateActive()
}
abstract class Housekeeping {
  -long email
  -String active
  +int total
  -boolean status
  +deleteNote()
  +validatePrice()
  +processAmount()
  +calculateId()
}
class Room {
  #String createdAt
  #Date email
  #Date note
  +findAddress()
  +updateQuantity()
  +processName()
}
interface Guest {
  -boolean id
  -float note
  -String phone
  +validateType()
  +processScore()
}
interface CheckIn {
  -double code
  -boolean createdAt
  +boolean level
  +cancelDuration()
}
CheckIn ..|> Housekeeping
Invoice ..> Guest : "0..1"
Housekeeping --o Guest
@enduml