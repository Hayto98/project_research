@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
interface Inventory {
  #long address
  #Date score
  #String status
  #Date active
  +setDuration()
  +deleteCode()
}
class Vehicle {
  -long code
  #float id
  -double createdAt
  -int quantity
  +calculateAmount()
}
class Package {
  +double level
  #boolean total
  +deleteScore()
  +findEmail()
}
class Driver {
  +double note
  -int status
  #float description
  #long id
  +sendDuration()
  +savePrice()
}
Package --o Inventory
@enduml