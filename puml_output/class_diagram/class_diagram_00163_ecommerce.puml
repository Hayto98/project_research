@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Coupon {
  -String name
  #String createdAt
  +calculateAmount()
  +processEmail()
}
class Invoice {
  #String type
  #long amount
  +float status
  -String createdAt
  +boolean name
  +validateCode()
  +saveCreatedat()
  +deleteTotal()
  +deleteEmail()
}
interface Supplier {
  +float type
  +int phone
  +int total
  #int score
  +saveStatus()
}
abstract class Order {
  #int code
  #long type
  +Date total
  #double description
  +deletePhone()
}
class Cart {
  -boolean type
  +Date description
  -boolean email
  +boolean code
  +getDescription()
  +calculateUpdatedat()
  +setEmail()
  +calculateEmail()
}
class Customer {
  -String email
  #Date description
  -boolean code
  +Date createdAt
  +long status
  +updateId()
}
Supplier --o Order
Coupon ..|> Invoice
Invoice ..> Cart : "*"
Order --* Supplier
@enduml