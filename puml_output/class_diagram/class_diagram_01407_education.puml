@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
interface Attendance {
  #long name
  -boolean code
  +int amount
  +long total
  -Date quantity
  +validateNote()
}
class Book {
  #int total
  -String quantity
  -boolean price
  -Date description
  +float updatedAt
  +findPhone()
  +updateQuantity()
  +findStatus()
  +calculateName()
}
abstract class Schedule {
  -String amount
  #String score
  #boolean name
  -boolean note
  +double address
  +sendStatus()
  +validateEmail()
  +updateNote()
  +deleteDescription()
}
interface Student {
  #boolean note
  #long amount
  #String code
  #double status
  +deleteEmail()
  +updateActive()
  +saveAddress()
  +findScore()
}
interface Exam {
  #int price
  #long description
  +int status
  #Date total
  -double createdAt
  +sendDescription()
  +createCreatedat()
}
Book --> Schedule : "1"
Attendance ..|> Student
Attendance --|> Schedule
Attendance --> Book : "0..1"
@enduml