@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Prescription {
  +boolean id
  #String total
  -Date quantity
  +String status
  -int level
  +calculateQuantity()
}
interface Nurse {
  #boolean name
  #long quantity
  +findCreatedat()
  +processId()
}
class Appointment {
  +double active
  #String updatedAt
  #boolean description
  +deletePrice()
  +deleteUpdatedat()
  +cancelName()
  +updateName()
}
abstract class LabTest {
  +double email
  +double note
  -boolean phone
  +calculateName()
  +sendPrice()
}
class Diagnosis {
  +float quantity
  #String id
  #boolean note
  -double createdAt
  +Date address
  +sendEmail()
  +deleteStatus()
  +deleteAddress()
  +createDuration()
}
class Billing {
  #boolean price
  +float status
  +calculatePrice()
  +getScore()
  +processNote()
  +sendNote()
}
class Insurance {
  +String duration
  #String price
  -long total
  +sendLevel()
  +updateType()
}
Appointment ..|> LabTest
Appointment --> Diagnosis : "1..*"
Nurse ..|> Appointment
Insurance ..|> Appointment
note right of Prescription : Healthcare domain
@enduml