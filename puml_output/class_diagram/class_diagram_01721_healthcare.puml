@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Prescription {
  +boolean id
  #String total
  -Date quantity
  +String status
  -int level
  +processType()
}
class Nurse {
  #boolean name
  #long quantity
  +setCode()
  +calculateNote()
}
abstract class Appointment {
  #int id
  #float amount
  +cancelTotal()
  +cancelQuantity()
}
class LabTest {
  +String description
  -int price
  -double duration
  -float updatedAt
  +double name
  +cancelCreatedat()
}
class Diagnosis {
  #Date total
  -int name
  #boolean active
  +calculatePhone()
  +processCode()
  +sendCode()
  +sendEmail()
}
interface Billing {
  +Date createdAt
  #Date code
  #double total
  #float price
  +setLevel()
  +createPhone()
  +createEmail()
}
class Insurance {
  +boolean email
  #String createdAt
  -double status
  -String price
  +saveAmount()
  +sendQuantity()
  +sendPrice()
  +deletePrice()
}
Nurse --o Diagnosis
LabTest --|> Nurse
@enduml