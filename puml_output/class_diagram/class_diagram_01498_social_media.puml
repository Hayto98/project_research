@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Report {
  -long active
  +float amount
  +float code
  #boolean status
  +long price
  +processNote()
  +getDescription()
  +deleteName()
}
interface Follower {
  -boolean price
  #String amount
  -boolean status
  +calculateId()
  +cancelAmount()
}
class Message {
  -float note
  #boolean active
  +findActive()
  +cancelPrice()
}
class Album {
  -boolean createdAt
  #boolean total
  +float updatedAt
  +Date id
  +int description
  +validateEmail()
  +cancelEmail()
  +calculateAmount()
  +updateDuration()
}
class Like {
  -long score
  #String level
  +int phone
  #long description
  +validateDuration()
  +updateCreatedat()
  +updatePhone()
  +deleteScore()
}
class Story {
  #int amount
  +double status
  #long phone
  #int quantity
  -int price
  +saveDuration()
  +processActive()
}
abstract class Hashtag {
  -double amount
  -int email
  #String note
  #boolean quantity
  #long total
  +setId()
  +deleteAddress()
}
Hashtag --* Message
Album --o Story
@enduml