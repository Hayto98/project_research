@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Report {
  -long active
  +float amount
  +float code
  #boolean status
  +long price
  +saveEmail()
  +sendUpdatedat()
  +calculateAmount()
}
class Follower {
  +boolean level
  +String duration
  -Date id
  #float type
  -float updatedAt
  +processEmail()
  +sendPrice()
}
class Message {
  #Date updatedAt
  #String id
  +Date score
  +int description
  #double address
  +setNote()
}
class Album {
  #long email
  +long score
  +cancelStatus()
  +updateCreatedat()
  +cancelPhone()
}
abstract class Like {
  #String amount
  -long createdAt
  -Date note
  +String duration
  +cancelEmail()
  +sendCreatedat()
  +validateUpdatedat()
  +updateLevel()
}
class Story {
  -double price
  -long amount
  +Date email
  +boolean note
  #boolean quantity
  +deleteDuration()
  +updateCode()
  +validateQuantity()
}
abstract class Hashtag {
  #long active
  +long level
  +int id
  +int address
  #double description
  +findDescription()
  +getQuantity()
  +setPrice()
}
Hashtag --> Report : "0..1"
Report --o Follower
note right of Report : Social Media domain
@enduml