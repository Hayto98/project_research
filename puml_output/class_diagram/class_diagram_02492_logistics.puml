@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
interface Shipment {
  #int address
  #boolean updatedAt
  +processAmount()
}
class FuelLog {
  #int status
  #long active
  -float name
  +validateEmail()
  +sendAmount()
  +saveTotal()
}
interface Depot {
  +boolean id
  #Date amount
  +calculateScore()
  +findLevel()
  +getCode()
  +calculateCode()
}
abstract class Customer {
  -int active
  #long description
  +sendTotal()
  +findDescription()
  +cancelAddress()
  +calculateLevel()
}
Depot --> Shipment : "*"
FuelLog ..|> Customer
@enduml