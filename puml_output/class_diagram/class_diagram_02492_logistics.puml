@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
interface Shipment {
  #int address
  #boolean updatedAt
  +setEmail()
}
interface FuelLog {
  #int status
  #long active
  -float name
  +setScore()
  +findDuration()
  +findId()
}
class Depot {
  -float id
  #double score
  -boolean note
  +sendDescription()
}
class Customer {
  #long address
  +long price
  +float id
  +deletePhone()
  +updateEmail()
  +updatePhone()
  +processDuration()
}
Depot --* Shipment
Customer ..|> Shipment
Depot --|> Customer
note right of Shipment : Logistics domain
@enduml