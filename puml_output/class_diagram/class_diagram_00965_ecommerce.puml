@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
interface Order {
  #float price
  -boolean id
  +cancelDuration()
  +deleteActive()
  +validateId()
  +updateAddress()
}
class Product {
  +Date description
  #int total
  -Date duration
  +cancelTotal()
}
class Shipment {
  +Date amount
  +boolean total
  +Date level
  +findNote()
  +createUpdatedat()
  +saveName()
  +calculateScore()
}
abstract class Warehouse {
  +Date updatedAt
  #long quantity
  +long email
  +boolean note
  +calculateCreatedat()
}
interface Cart {
  #long id
  -float type
  +cancelUpdatedat()
}
abstract class Invoice {
  +String total
  +long id
  -int score
  +float level
  +cancelDuration()
  +getEmail()
  +getPrice()
}
class Return {
  +float name
  -String type
  +int description
  +getScore()
  +createStatus()
  +validateType()
}
Product --o Order
Order --* Return
Shipment --|> Order
Return ..|> Shipment
@enduml