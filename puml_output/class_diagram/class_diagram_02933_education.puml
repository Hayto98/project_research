@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Teacher {
  #long duration
  -int type
  -int level
  +findPrice()
  +setScore()
  +calculateType()
}
interface Classroom {
  #boolean quantity
  #int status
  +int score
  +setType()
}
interface Library {
  #int total
  -int note
  +findName()
  +findQuantity()
  +calculateScore()
  +createCreatedat()
}
class Enrollment {
  +long quantity
  -Date code
  +saveName()
  +setPhone()
  +saveLevel()
}
class Course {
  -long phone
  -int id
  #String email
  +String type
  #boolean updatedAt
  +validateLevel()
  +deleteTotal()
  +setEmail()
  +validateDuration()
}
Teacher ..|> Library
Course --|> Library
Classroom ..|> Teacher
note right of Teacher : Education domain
@enduml