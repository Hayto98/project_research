@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Teacher {
  #long duration
  -int type
  -int level
  +getActive()
  +sendScore()
  +findNote()
}
interface Classroom {
  #boolean type
  #boolean level
  #int updatedAt
  +int quantity
  +String status
  +createEmail()
  +sendQuantity()
  +processNote()
  +saveTotal()
}
interface Library {
  #int total
  -int note
  +getActive()
  +deleteEmail()
  +getUpdatedat()
  +setPrice()
}
class Enrollment {
  +String price
  -Date score
  +int email
  -double createdAt
  +updatePhone()
  +sendDuration()
  +deleteNote()
}
class Course {
  +long level
  -int id
  -long total
  -int phone
  +createCreatedat()
}
Course --* Enrollment
Course --o Classroom
@enduml