@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Renewal {
  #boolean duration
  #long email
  +saveId()
}
class Publisher {
  #long price
  #Date quantity
  +findPhone()
  +deletePrice()
  +deleteAddress()
  +createPrice()
}
class Reservation {
  -int active
  +float id
  -double code
  +sendTotal()
  +savePrice()
}
class Fine {
  -boolean id
  -double updatedAt
  #float phone
  +calculateType()
  +cancelDescription()
  +validateEmail()
}
interface Branch {
  #String score
  #float quantity
  +double note
  +long description
  #long code
  +calculateStatus()
}
class Librarian {
  -long address
  #int status
  +String description
  -int name
  #String price
  +setDuration()
}
Fine ..|> Renewal
Renewal ..|> Publisher
Publisher ..> Fine : "1..*"
note right of Renewal : Library domain
@enduml