@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Shelf {
  -long score
  +boolean quantity
  -float email
  +createNote()
  +saveName()
  +getCode()
}
class Librarian {
  #double level
  +boolean name
  -long score
  +findScore()
  +findUpdatedat()
}
abstract class Fine {
  +long address
  #float code
  #double email
  -boolean amount
  +boolean status
  +saveCreatedat()
  +saveAmount()
  +createId()
  +calculateNote()
}
class Publisher {
  +int active
  #float note
  +float id
  #double price
  #long amount
  +saveId()
  +setDuration()
}
Shelf ..> Publisher : "*"
Shelf --|> Librarian
Publisher --* Shelf
note right of Shelf : Library domain
@enduml