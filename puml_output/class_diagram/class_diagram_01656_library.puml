@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Shelf {
  -long score
  +boolean quantity
  -float email
  +deleteName()
  +deletePrice()
  +validatePrice()
}
class Librarian {
  +boolean code
  +float quantity
  +createCode()
  +saveActive()
  +calculateCreatedat()
  +getTotal()
}
interface Fine {
  -String total
  -float active
  +float price
  +processDuration()
}
class Publisher {
  #float type
  +long score
  #String id
  -double note
  +double createdAt
  +updateActive()
  +createPrice()
  +findId()
  +cancelNote()
}
Shelf --o Fine
Fine ..|> Publisher
@enduml