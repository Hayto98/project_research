@startuml
skinparam shadowing true
class Reservation {
  +String id
  +Date duration
  #double email
  #double createdAt
  +deleteDuration()
}
interface Publisher {
  #float level
  +boolean active
  +int phone
  -Date note
  +updateId()
}
abstract class Branch {
  -Date address
  -long price
  -int updatedAt
  +float name
  -Date type
  +deletePrice()
}
abstract class Member {
  -float updatedAt
  #int price
  +getPrice()
}
class Loan {
  -float note
  #int email
  +findUpdatedat()
}
class Book {
  #double email
  #float address
  +float quantity
  #long createdAt
  +getCode()
  +sendName()
}
interface Renewal {
  -Date phone
  -boolean createdAt
  -int active
  +Date type
  +calculateAddress()
  +deleteDuration()
  +updateUpdatedat()
  +saveDescription()
}
Reservation --> Loan : "*"
Reservation ..|> Book
Reservation --|> Publisher
@enduml