@startuml
skinparam shadowing true
class Reservation {
  +String id
  +Date duration
  #double email
  #double createdAt
  +processActive()
}
class Publisher {
  -Date note
  #boolean status
  +Date description
  -Date createdAt
  +validatePrice()
  +updateName()
  +findType()
  +processType()
}
class Branch {
  -String createdAt
  +double description
  -float email
  #int name
  +float note
  +setNote()
  +createQuantity()
  +sendAmount()
}
class Member {
  -int duration
  #double quantity
  #float email
  +float address
  +saveAmount()
  +cancelType()
  +cancelQuantity()
}
class Loan {
  #long active
  #long type
  +int quantity
  +deleteNote()
  +setEmail()
  +getDuration()
  +sendDuration()
}
abstract class Book {
  #String createdAt
  +String status
  +cancelDuration()
  +findPhone()
}
class Renewal {
  -String code
  +int description
  #float createdAt
  +double level
  +sendDescription()
}
Loan --> Book : "1"
Branch --|> Publisher
note right of Reservation : Library domain
@enduml