@startuml
skinparam monochrome true
skinparam defaultFontSize 11
abstract class Teller {
  -boolean score
  +Date createdAt
  +validateNote()
  +updateNote()
  +validateScore()
}
class Branch {
  #Date address
  -boolean phone
  +findQuantity()
}
abstract class Transfer {
  -Date status
  #boolean phone
  +String email
  +findAmount()
}
abstract class Transaction {
  -boolean email
  -String name
  +getId()
}
Transfer --o Teller
Branch --|> Teller
Transaction ..> Branch : "*"
@enduml