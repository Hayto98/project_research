@startuml
skinparam monochrome true
skinparam defaultFontSize 11
abstract class Teller {
  -boolean score
  +Date createdAt
  +updateActive()
  +validatePhone()
  +cancelName()
}
class Branch {
  -double phone
  +Date score
  +Date active
  -Date code
  +validateActive()
  +sendId()
  +getActive()
}
class Transfer {
  -boolean type
  -String level
  +double status
  -long email
  +double name
  +deleteId()
  +sendTotal()
}
abstract class Transaction {
  +String id
  #String address
  #String email
  #Date status
  -Date name
  +createEmail()
  +setName()
  +getUpdatedat()
}
Branch --|> Transaction
Transfer --o Teller
note right of Teller : Banking domain
@enduml