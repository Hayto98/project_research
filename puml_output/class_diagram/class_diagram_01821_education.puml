@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Attendance {
  #boolean description
  -float active
  +Date level
  #Date name
  #String score
  +setActive()
  +createName()
}
class Exam {
  +float address
  -Date updatedAt
  #int name
  -double description
  +long duration
  +updatePhone()
  +findStatus()
}
class Grade {
  +Date name
  -String type
  +getTotal()
}
class Student {
  -boolean name
  #long updatedAt
  +boolean phone
  #Date description
  +int id
  +cancelAddress()
  +processTotal()
  +processStatus()
}
abstract class Book {
  +double status
  -double description
  +createUpdatedat()
  +calculateName()
  +deleteUpdatedat()
  +createAmount()
}
class Classroom {
  -boolean level
  +double amount
  +deletePrice()
  +processScore()
}
class Course {
  #int total
  -boolean address
  -String amount
  -int duration
  +savePhone()
  +sendActive()
}
Attendance --|> Student
Attendance --* Book
@enduml