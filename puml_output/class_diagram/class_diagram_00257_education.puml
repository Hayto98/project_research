@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Classroom {
  +double phone
  #int name
  -String updatedAt
  +long status
  +int description
  +findAmount()
}
interface Book {
  #String status
  -float level
  -int price
  -float duration
  -float phone
  +createType()
}
class Teacher {
  +boolean active
  #float code
  +float id
  +float duration
  #int phone
  +validateCreatedat()
  +findQuantity()
}
class Department {
  +Date address
  -String note
  #Date name
  +saveAmount()
  +validatePhone()
  +cancelLevel()
  +deleteScore()
}
interface Schedule {
  #boolean code
  +double note
  +cancelCreatedat()
}
class Course {
  -Date updatedAt
  +Date status
  -Date address
  +processName()
}
class Enrollment {
  +long name
  +int note
  -Date score
  -boolean createdAt
  +updateDuration()
  +sendUpdatedat()
  +processCreatedat()
}
Enrollment ..|> Schedule
Enrollment --* Book
Classroom ..|> Course
Teacher --o Enrollment
Course --> Classroom : "*"
@enduml