@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Classroom {
  +double phone
  #int name
  -String updatedAt
  +long status
  +int description
  +calculateScore()
}
abstract class Book {
  +long level
  #String price
  +createAmount()
  +processPrice()
  +getQuantity()
  +calculateActive()
}
class Teacher {
  +boolean active
  #float phone
  +setActive()
}
class Department {
  +long description
  -String address
  +Date phone
  +getLevel()
  +findType()
  +processCode()
}
class Schedule {
  #boolean code
  +double note
  +calculateCode()
}
class Course {
  #int status
  #double address
  #boolean quantity
  +getId()
}
class Enrollment {
  #int note
  +long level
  +deleteQuantity()
  +findPhone()
}
Teacher ..> Classroom : "*"
Enrollment ..|> Schedule
Enrollment --* Book
Classroom ..|> Course
Teacher --o Enrollment
Course --> Classroom : "*"
note right of Classroom : Education domain
@enduml