@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Teacher {
  #Date level
  #boolean status
  +float note
  -boolean address
  -int id
  +processAmount()
  +getPhone()
  +validateScore()
}
interface Attendance {
  +String id
  +String type
  +saveCode()
}
class Schedule {
  +float level
  +float price
  #float code
  +deleteQuantity()
}
class Exam {
  +double type
  -boolean duration
  +calculateAmount()
  +setCode()
  +getCode()
}
interface Enrollment {
  -boolean amount
  +double status
  +processUpdatedat()
}
class Assignment {
  #Date name
  -boolean duration
  +boolean type
  +long code
  -Date note
  +updateId()
}
class Classroom {
  +long note
  -float updatedAt
  -float total
  -long name
  -Date level
  +sendPrice()
  +calculateEmail()
  +createCode()
  +processUpdatedat()
}
Assignment --o Exam
Exam --o Enrollment
Exam --|> Teacher
Enrollment --o Exam
Attendance ..> Enrollment : "1"
Teacher ..|> Exam
@enduml