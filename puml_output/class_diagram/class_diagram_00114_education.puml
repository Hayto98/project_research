@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Teacher {
  #Date level
  #boolean status
  +float note
  -boolean address
  -int id
  +setTotal()
  +validateScore()
  +sendId()
}
class Attendance {
  -int updatedAt
  +float id
  #double duration
  #String name
  +float active
  +sendName()
}
class Schedule {
  +double name
  -boolean type
  #Date level
  +processLevel()
  +cancelId()
  +saveAmount()
}
class Exam {
  +float duration
  +Date id
  -Date total
  +String status
  +saveCode()
  +processDuration()
  +saveTotal()
  +sendId()
}
interface Enrollment {
  #boolean quantity
  #Date price
  +findQuantity()
}
abstract class Assignment {
  -long updatedAt
  -float total
  -long name
  -Date duration
  -Date amount
  +deleteAmount()
}
interface Classroom {
  +String total
  #double note
  -int active
  #Date type
  +String price
  +deleteId()
  +findNote()
  +saveEmail()
  +processDuration()
}
Teacher --o Enrollment
Exam --* Assignment
note right of Teacher : Education domain
@enduml