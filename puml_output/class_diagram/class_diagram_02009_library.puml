@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Branch {
  +Date description
  -long total
  -String updatedAt
  #Date id
  +deleteActive()
  +cancelId()
  +sendDuration()
  +updateCreatedat()
}
class Publisher {
  -double type
  #double active
  +cancelActive()
}
abstract class Catalog {
  -double phone
  -String id
  -float address
  #String email
  -float total
  +getQuantity()
}
abstract class Loan {
  +Date id
  +double name
  +long code
  -long updatedAt
  #String description
  +validateUpdatedat()
  +processType()
}
class Renewal {
  #Date phone
  -float address
  +float level
  +int quantity
  +savePrice()
  +deleteNote()
}
class Book {
  +String quantity
  +float description
  #Date type
  +long updatedAt
  #long phone
  +validateLevel()
  +getQuantity()
  +deleteId()
  +saveTotal()
}
class Member {
  +double updatedAt
  -float status
  #long createdAt
  #int name
  #boolean phone
  +cancelNote()
}
Catalog --|> Book
Publisher ..|> Member
Member --o Branch
Book ..|> Branch
Publisher --> Catalog : "0..1"
note right of Branch : Library domain
@enduml