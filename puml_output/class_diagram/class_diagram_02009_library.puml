@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Branch {
  +Date description
  -long total
  -String updatedAt
  #Date id
  +findPhone()
  +getScore()
  +sendActive()
  +processPhone()
}
class Publisher {
  -boolean createdAt
  -double address
  #double name
  +getDescription()
}
interface Catalog {
  -long note
  -double phone
  +long id
  #String address
  -float email
  +saveTotal()
}
class Loan {
  +int price
  #int total
  +Date id
  +double name
  +sendPhone()
}
class Renewal {
  -double code
  +Date updatedAt
  -long address
  -Date level
  +findLevel()
  +updateLevel()
  +setCreatedat()
}
abstract class Book {
  #Date id
  -int amount
  #double updatedAt
  +findDuration()
  +updateCode()
}
abstract class Member {
  +String description
  +float type
  #Date updatedAt
  +long phone
  +cancelCode()
  +findQuantity()
  +processEmail()
}
Catalog --|> Publisher
Book ..> Loan : "0..1"
@enduml