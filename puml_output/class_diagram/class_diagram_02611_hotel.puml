@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
abstract class Reservation {
  -float email
  +Date code
  -String address
  +setUpdatedat()
  +sendQuantity()
  +getType()
}
class CheckOut {
  -double price
  -long duration
  +sendAmount()
  +calculateDescription()
}
class Guest {
  #double type
  +long duration
  +boolean active
  #Date code
  +boolean address
  +deletePrice()
}
class Staff {
  -String duration
  #long description
  -Date address
  +boolean id
  #float price
  +calculateNote()
  +validateScore()
  +findQuantity()
  +deleteId()
}
abstract class Invoice {
  +long updatedAt
  +Date price
  #int amount
  #int type
  +calculateType()
  +processDuration()
  +validateScore()
}
interface Payment {
  #Date id
  #long duration
  -String address
  -double type
  -Date amount
  +calculateName()
  +cancelAddress()
}
abstract class Restaurant {
  #String email
  -long code
  +String level
  -long type
  +saveAmount()
  +findPrice()
}
Invoice ..|> CheckOut
Invoice --o Reservation
Guest --|> CheckOut
Staff --> CheckOut : "*"
@enduml