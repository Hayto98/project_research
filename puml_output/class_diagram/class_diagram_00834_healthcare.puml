@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
abstract class Hospital {
  #long status
  #int phone
  #String note
  +cancelQuantity()
  +updateActive()
}
class Billing {
  #long level
  -long type
  +processCode()
  +setQuantity()
}
interface Doctor {
  -float updatedAt
  #long address
  +double note
  -double description
  +getType()
}
class Ward {
  -int note
  +boolean phone
  +validateName()
}
Billing --|> Hospital
Ward --> Doctor : "1"
@enduml