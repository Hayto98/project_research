@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Library {
  -int updatedAt
  -long quantity
  +double code
  -Date createdAt
  +float active
  +calculateDuration()
  +sendTotal()
  +deleteLevel()
  +getDescription()
}
class Teacher {
  -double status
  #double address
  +int duration
  -boolean updatedAt
  +sendTotal()
  +calculateEmail()
}
class Schedule {
  +long email
  +long active
  -Date level
  -float name
  +createType()
  +deletePhone()
}
interface Attendance {
  -double score
  #Date quantity
  -float note
  +deleteId()
}
class Department {
  #String description
  +Date code
  -long createdAt
  #String note
  -boolean active
  +validateScore()
}
class Exam {
  +float description
  +long total
  #String quantity
  +saveCode()
  +getAmount()
}
interface Grade {
  -double quantity
  +Date code
  -double status
  +findQuantity()
}
Schedule ..> Exam : "0..1"
Teacher --* Department
note right of Library : Education domain
@enduml