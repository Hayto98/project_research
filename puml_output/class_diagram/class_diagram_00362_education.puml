@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Library {
  -int updatedAt
  -long quantity
  +double code
  -Date createdAt
  +float active
  +createPrice()
  +calculateStatus()
  +calculateUpdatedat()
  +deleteLevel()
}
interface Teacher {
  -float description
  +long level
  +boolean name
  +double duration
  -Date status
  +calculateEmail()
  +calculateNote()
  +setNote()
  +cancelActive()
}
class Schedule {
  #boolean price
  +int email
  -String quantity
  -double address
  #double level
  +validateAmount()
  +validateName()
}
class Attendance {
  -long score
  -boolean amount
  #double duration
  +int quantity
  +createAddress()
}
abstract class Department {
  -boolean code
  +int createdAt
  #double note
  +deleteStatus()
  +cancelStatus()
  +createPrice()
}
interface Exam {
  +int phone
  +double score
  +cancelNote()
  +updateCreatedat()
  +createScore()
}
class Grade {
  #String active
  +int amount
  +setTotal()
  +deleteEmail()
}
Library --o Schedule
Teacher --* Exam
@enduml