@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
class Notification {
  -float code
  #long createdAt
  #boolean name
  +Date total
  #boolean updatedAt
  +getId()
  +validateCode()
}
class Hashtag {
  +Date name
  #float score
  +boolean amount
  -String description
  -int address
  +calculateLevel()
  +validateAddress()
}
interface Group {
  +int address
  -String amount
  #long id
  +int quantity
  +updateNote()
  +updateAmount()
  +createUpdatedat()
}
class Report {
  +String status
  -float active
  +long note
  +Date total
  +setType()
  +createStatus()
  +findStatus()
  +processQuantity()
}
abstract class Like {
  -boolean amount
  -float note
  #Date type
  +updateType()
}
abstract class Follower {
  +boolean code
  #boolean description
  +long phone
  #int email
  +createEmail()
  +calculateQuantity()
  +cancelNote()
  +deleteEmail()
}
Group --o Notification
Follower --o Notification
Report --|> Notification
note right of Notification : Social Media domain
@enduml