@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Student {
  #boolean duration
  -boolean price
  +sendScore()
  +createId()
  +saveAddress()
}
class Library {
  -float createdAt
  #float name
  +cancelDuration()
  +cancelDescription()
}
abstract class Classroom {
  #Date updatedAt
  -String phone
  +processCode()
  +createAddress()
  +createLevel()
}
interface Assignment {
  -int phone
  +Date note
  +createName()
  +updateAmount()
  +calculateAmount()
}
interface Course {
  -String id
  -int active
  #int email
  -long type
  +setUpdatedat()
  +sendCreatedat()
  +setPrice()
  +setUpdatedat()
}
class Enrollment {
  #long score
  #boolean name
  -float type
  -int address
  #Date note
  +sendDuration()
  +sendScore()
  +findNote()
  +calculateLevel()
}
class Grade {
  +boolean note
  #long phone
  +findLevel()
  +cancelNote()
  +saveLevel()
  +createPhone()
}
Student --> Grade : "0..1"
Classroom --* Student
Library --> Assignment : "0..1"
Library ..|> Student
Course ..|> Enrollment
note right of Student : Education domain
@enduml