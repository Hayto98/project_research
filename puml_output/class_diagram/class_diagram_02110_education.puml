@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
class Student {
  #boolean duration
  -boolean price
  +getScore()
  +saveActive()
  +setTotal()
}
class Library {
  -float status
  #float code
  +float createdAt
  #boolean name
  +sendCreatedat()
  +calculateLevel()
}
interface Classroom {
  #Date updatedAt
  -String phone
  +calculateAmount()
  +getDuration()
  +sendStatus()
}
class Assignment {
  +Date address
  -Date email
  #Date score
  -double active
  +createScore()
  +createTotal()
}
class Course {
  +boolean name
  #float updatedAt
  #float amount
  #float total
  +setName()
  +createDescription()
  +findStatus()
}
class Enrollment {
  -long price
  #double status
  +int duration
  #Date amount
  +String updatedAt
  +validateEmail()
  +processScore()
  +createScore()
  +updateId()
}
class Grade {
  #long score
  #boolean name
  -float type
  -int address
  #Date note
  +getCreatedat()
  +setId()
  +saveActive()
  +sendStatus()
}
Enrollment --o Assignment
Course --|> Classroom
Grade --* Assignment
Library ..> Course : "1..*"
Assignment --> Enrollment : "*"
Enrollment --* Course
@enduml