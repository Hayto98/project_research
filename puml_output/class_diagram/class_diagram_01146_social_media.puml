@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Like {
  -boolean email
  +float quantity
  -float total
  #long level
  +float id
  +setNote()
  +setActive()
  +cancelStatus()
}
class Group {
  -float email
  -Date amount
  -boolean price
  +String updatedAt
  +long description
  +sendActive()
  +updateAddress()
  +saveName()
}
class Hashtag {
  +double address
  +long total
  +getType()
  +sendType()
}
class Notification {
  -String price
  -String id
  +boolean score
  #Date duration
  +processTotal()
}
class User {
  -int level
  #Date type
  #float duration
  +updateAddress()
  +processCreatedat()
}
interface Message {
  -long note
  -double amount
  -long quantity
  -boolean status
  +processScore()
}
Group ..|> Message
Message ..> User : "*"
Hashtag --o User
note right of Like : Social Media domain
@enduml