@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
class Like {
  -boolean email
  +float quantity
  -float total
  #long level
  +float id
  +createAddress()
  +deleteDuration()
  +validatePhone()
}
interface Group {
  -int createdAt
  -int price
  +validateScore()
  +deleteTotal()
}
abstract class Hashtag {
  -long active
  #boolean name
  +long status
  #String level
  +calculateEmail()
  +updateAmount()
  +findType()
}
class Notification {
  +float status
  #double type
  #double name
  -long email
  #double amount
  +calculateStatus()
}
interface User {
  #Date type
  #float code
  #boolean duration
  +double status
  -long active
  +findStatus()
  +cancelLevel()
}
interface Message {
  -double type
  +boolean address
  #long description
  -int updatedAt
  -String createdAt
  +findScore()
  +getNote()
  +processType()
}
Hashtag --> Message : "1"
Notification --> User : "1..*"
Group ..|> Message
Message ..> User : "*"
@enduml