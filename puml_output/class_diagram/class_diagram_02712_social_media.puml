@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
abstract class Hashtag {
  #double address
  +int code
  +updateAmount()
  +sendUpdatedat()
  +getName()
  +saveUpdatedat()
}
class Group {
  #String amount
  +long id
  #double note
  +sendDuration()
}
interface Album {
  #String id
  +long quantity
  +findUpdatedat()
  +calculateScore()
  +getDescription()
}
abstract class Comment {
  #boolean address
  +double active
  +saveEmail()
}
class Report {
  +boolean address
  #float type
  +double updatedAt
  +calculatePrice()
  +calculateDescription()
  +sendAmount()
}
abstract class User {
  -float amount
  +boolean note
  -int id
  #float name
  +findCode()
  +sendName()
}
Album --o Comment
Hashtag --o Comment
@enduml