@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
abstract class Hashtag {
  #double address
  +int code
  +findCode()
  +deleteAmount()
  +getNote()
  +sendId()
}
class Group {
  #boolean level
  +float total
  +float active
  -Date name
  +deleteEmail()
}
class Album {
  #boolean price
  +double status
  +String address
  +Date active
  +validateType()
  +updateName()
}
interface Comment {
  #Date type
  #double phone
  +deleteNote()
  +getName()
  +createUpdatedat()
}
interface Report {
  -double description
  #String active
  -double updatedAt
  -String phone
  +processDescription()
  +getAddress()
  +processId()
  +calculateType()
}
class User {
  #long id
  +String type
  +deleteUpdatedat()
  +calculateAddress()
  +validateQuantity()
  +deleteDuration()
}
Comment --|> Album
Report ..> Album : "1..*"
note right of Hashtag : Social Media domain
@enduml