@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Tracking {
  -double note
  +double type
  #float phone
  #boolean name
  +double total
  +getStatus()
  +deleteScore()
}
class Vehicle {
  #Date address
  #String updatedAt
  +double description
  +validateNote()
  +createName()
}
class Shipment {
  #Date code
  +double type
  -float score
  +int note
  +processId()
}
class Inventory {
  -float createdAt
  #boolean id
  #String quantity
  +saveScore()
  +calculateNote()
  +setId()
  +validateAmount()
}
class Manifest {
  -float level
  +long id
  +long description
  +validateName()
  +createPrice()
  +updatePhone()
}
class FuelLog {
  +Date updatedAt
  +String createdAt
  +Date level
  -boolean duration
  -double active
  +findDescription()
  +deleteStatus()
  +cancelActive()
}
Tracking --|> Inventory
Shipment --* Vehicle
Tracking --|> Manifest
Inventory --> FuelLog : "0..1"
@enduml