@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Tracking {
  -double note
  +double type
  #float phone
  #boolean name
  +double total
  +deleteAddress()
  +updateAddress()
}
class Vehicle {
  +double duration
  +int score
  +double id
  +createCode()
}
abstract class Shipment {
  +String score
  #long name
  +int price
  #String type
  -long status
  +savePrice()
}
class Inventory {
  +Date duration
  #Date email
  +Date id
  +createStatus()
  +createAmount()
}
class Manifest {
  +float type
  +int price
  #Date description
  +boolean level
  +getAmount()
  +getDescription()
}
class FuelLog {
  -String total
  -int address
  -long active
  +float type
  +boolean id
  +processType()
}
FuelLog ..|> Inventory
Inventory --* Vehicle
Tracking ..|> Inventory
note right of Tracking : Logistics domain
@enduml