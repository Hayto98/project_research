@startuml
skinparam monochrome true
skinparam shadowing true
interface Like {
  +float type
  +double name
  +processScore()
}
class Comment {
  #float amount
  #boolean type
  -double address
  +processEmail()
  +setId()
}
class Report {
  -float email
  #Date id
  #long type
  +saveNote()
  +processNote()
  +cancelId()
  +validateQuantity()
}
class Post {
  #float updatedAt
  #float total
  +float duration
  +long createdAt
  #float active
  +updateScore()
  +setDuration()
  +updateDescription()
}
abstract class Follower {
  -double quantity
  +Date description
  -float total
  #long id
  +calculateEmail()
  +saveCreatedat()
  +calculateDescription()
}
Post ..> Like : "*"
Comment --o Post
Like --* Report
@enduml