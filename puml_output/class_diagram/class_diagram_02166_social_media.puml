@startuml
skinparam monochrome true
skinparam shadowing true
interface Like {
  +float type
  +double name
  +updateUpdatedat()
}
class Comment {
  #boolean address
  #float level
  +int type
  -boolean total
  +Date description
  +validateScore()
  +findQuantity()
  +processCreatedat()
  +savePhone()
}
class Report {
  -boolean total
  +int updatedAt
  +saveStatus()
  +updateAddress()
}
interface Post {
  +double createdAt
  +double type
  -int quantity
  #long score
  +cancelQuantity()
  +getAddress()
  +findType()
}
class Follower {
  #long updatedAt
  -float level
  +Date total
  -boolean price
  +int id
  +cancelType()
  +createId()
  +processCreatedat()
  +getAmount()
}
Comment ..|> Follower
Report ..> Like : "0..1"
Follower --* Comment
Like ..|> Comment
note right of Like : Social Media domain
@enduml