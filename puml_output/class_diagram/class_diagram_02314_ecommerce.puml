@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
abstract class Warehouse {
  -String name
  #float createdAt
  #float price
  #float amount
  +validateLevel()
  +sendDuration()
  +createStatus()
  +cancelType()
}
class Invoice {
  #double score
  +boolean status
  -String createdAt
  +String phone
  +boolean type
  +findStatus()
  +validateTotal()
  +sendName()
  +getNote()
}
class Shipment {
  +Date createdAt
  +double code
  -long score
  +getScore()
  +createType()
  +setActive()
}
abstract class Product {
  -long duration
  #boolean phone
  #double description
  #Date total
  +Date address
  +cancelQuantity()
  +validateId()
}
interface Coupon {
  -long score
  -float level
  +int status
  +processId()
  +findType()
  +cancelPrice()
}
abstract class Cart {
  +long duration
  +boolean phone
  +long quantity
  +saveCode()
  +cancelCode()
  +findType()
}
Warehouse ..|> Shipment
Shipment ..|> Coupon
Coupon --o Warehouse
Cart --> Warehouse : "1"
@enduml