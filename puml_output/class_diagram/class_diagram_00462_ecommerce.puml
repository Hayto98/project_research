@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Order {
  -double duration
  +int status
  +deleteStatus()
}
interface Warehouse {
  -Date note
  +double email
  +getDescription()
  +updateType()
  +createUpdatedat()
  +cancelId()
}
interface Invoice {
  -long note
  #int description
  +sendActive()
  +createTotal()
  +deleteDescription()
  +deleteNote()
}
class Coupon {
  +long total
  -Date updatedAt
  +double amount
  -boolean description
  +int createdAt
  +createDescription()
}
interface Return {
  +long createdAt
  #String amount
  +Date description
  -int email
  -long price
  +cancelStatus()
  +createNote()
  +calculateDuration()
  +getPhone()
}
Invoice ..> Warehouse : "1..*"
Coupon --* Return
Order ..|> Return
Warehouse --> Invoice : "0..1"
@enduml