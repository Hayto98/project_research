@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class CheckOut {
  #double address
  +double price
  +updateEmail()
  +getEmail()
}
class Service {
  -int amount
  -Date description
  #boolean createdAt
  +sendPhone()
}
interface Payment {
  +double description
  +double total
  +long duration
  #String type
  -Date amount
  +calculateAddress()
  +updateNote()
}
abstract class Amenity {
  -double score
  #float quantity
  +calculateCode()
  +sendStatus()
  +calculateEmail()
}
interface Reservation {
  +double level
  -boolean id
  +double total
  -long status
  +createScore()
  +saveUpdatedat()
  +sendActive()
}
class CheckIn {
  +double price
  +Date description
  +saveCode()
  +updateScore()
  +createId()
  +cancelAmount()
}
interface Booking {
  -double status
  -Date total
  +String price
  +processCreatedat()
  +getEmail()
}
Payment ..|> CheckOut
CheckOut --o Booking
@enduml