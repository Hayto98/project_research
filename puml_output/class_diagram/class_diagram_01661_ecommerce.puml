@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
interface Supplier {
  -String description
  -boolean quantity
  -double id
  +saveAddress()
  +getQuantity()
  +createLevel()
  +updateDuration()
}
class Category {
  +int code
  #String id
  -float description
  +long score
  +sendQuantity()
}
abstract class Wishlist {
  +double description
  -int type
  -double duration
  #boolean address
  +sendDuration()
  +updateQuantity()
  +setPrice()
  +calculateCode()
}
class Return {
  #float duration
  +int price
  #long id
  +saveScore()
  +validateName()
}
class Product {
  +boolean description
  #double email
  #int status
  +long total
  -int type
  +findAddress()
  +cancelEmail()
}
interface Warehouse {
  -boolean duration
  +boolean type
  #boolean note
  +double status
  #double updatedAt
  +saveUpdatedat()
  +saveAddress()
  +setTotal()
  +findCode()
}
Wishlist ..> Category : "*"
Wishlist --> Product : "1"
@enduml