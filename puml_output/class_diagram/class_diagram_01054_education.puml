@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Enrollment {
  -long price
  #long note
  +sendAmount()
}
class Book {
  +int description
  +Date id
  -boolean name
  +processCode()
  +updateUpdatedat()
  +findType()
  +validatePhone()
}
class Course {
  +int quantity
  +Date total
  +cancelQuantity()
}
class Department {
  #Date amount
  #double note
  +getUpdatedat()
}
class Teacher {
  +double code
  +double price
  #String email
  +findCreatedat()
}
abstract class Attendance {
  -Date updatedAt
  +int email
  +calculatePhone()
  +sendTotal()
  +createAmount()
}
Course --o Teacher
Department --o Attendance
note right of Enrollment : Education domain
@enduml