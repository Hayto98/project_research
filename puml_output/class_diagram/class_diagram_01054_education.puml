@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Enrollment {
  -long price
  #long note
  +calculateDuration()
}
class Book {
  +int createdAt
  +String description
  #double id
  +saveAmount()
  +findNote()
  +calculateTotal()
  +findAddress()
}
class Course {
  -String address
  +int phone
  #Date id
  +boolean status
  -long quantity
  +processCreatedat()
}
class Department {
  -float level
  #Date type
  +String code
  -long name
  +double updatedAt
  +validateUpdatedat()
}
interface Teacher {
  #int active
  -Date code
  +cancelLevel()
}
class Attendance {
  -long email
  #double amount
  -int description
  #String address
  +cancelScore()
  +createStatus()
  +sendCode()
}
Department --> Attendance : "1"
Attendance ..> Department : "*"
Course ..> Attendance : "0..1"
Book --* Enrollment
Enrollment --|> Book
@enduml