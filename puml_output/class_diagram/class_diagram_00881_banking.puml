@startuml
skinparam defaultFontSize 11
class Statement {
  #String type
  -float score
  +deletePhone()
  +findStatus()
  +validateTotal()
  +updateCode()
}
class Customer {
  -Date note
  #int name
  #Date code
  +validatePhone()
  +findActive()
}
class Account {
  #int type
  #float price
  +calculatePhone()
  +deleteAmount()
  +saveQuantity()
  +sendQuantity()
}
interface Card {
  -boolean level
  #boolean active
  +createType()
}
interface Deposit {
  +double active
  +String createdAt
  #boolean level
  +double price
  +cancelStatus()
}
interface Interest {
  -int updatedAt
  -double type
  +sendQuantity()
  +createStatus()
  +getTotal()
}
class Loan {
  -Date total
  +Date amount
  +String status
  +validateName()
  +calculatePhone()
  +createId()
  +setActive()
}
Account --o Loan
Customer --> Card : "1"
Loan ..> Account : "1"
Loan --|> Customer
note right of Statement : Banking domain
@enduml