@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Service {
  +int phone
  #String active
  #long price
  #long code
  +calculatePhone()
  +processId()
}
abstract class Room {
  -int score
  -boolean createdAt
  #Date phone
  +getAmount()
}
abstract class Invoice {
  #double price
  +float description
  +saveId()
}
class Housekeeping {
  -double total
  #String updatedAt
  +boolean name
  -boolean note
  +findCode()
  +createScore()
  +validateId()
}
interface Staff {
  +double score
  +Date address
  #boolean price
  +processLevel()
  +processStatus()
  +deletePhone()
}
Invoice --|> Staff
Room ..|> Service
@enduml