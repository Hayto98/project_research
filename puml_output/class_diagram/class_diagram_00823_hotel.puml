@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
class Service {
  +int phone
  #String active
  #long price
  #long code
  +createLevel()
  +calculateAmount()
}
interface Room {
  -boolean phone
  #Date quantity
  +Date createdAt
  +getPrice()
  +cancelDescription()
  +findNote()
  +deleteId()
}
class Invoice {
  -long address
  -boolean total
  +String updatedAt
  #long name
  +validateUpdatedat()
  +setActive()
  +deleteScore()
}
class Housekeeping {
  -int amount
  -long price
  +int name
  +int quantity
  -float total
  +validateScore()
  +setId()
}
class Staff {
  +String id
  +Date active
  +double price
  -int email
  +validateType()
}
Housekeeping --|> Service
Staff ..|> Invoice
note right of Service : Hotel domain
@enduml