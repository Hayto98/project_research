@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
interface Warehouse {
  +boolean quantity
  +float id
  #int address
  +processQuantity()
  +calculateName()
}
class Vehicle {
  +double phone
  -long level
  #int createdAt
  +createEmail()
  +findId()
}
interface Customer {
  +String quantity
  #int address
  +float amount
  -int type
  +createName()
  +getAmount()
  +deletePrice()
}
abstract class Driver {
  #String createdAt
  #long address
  +float quantity
  #Date code
  +validateScore()
  +deleteNote()
  +updateNote()
}
class Depot {
  -float description
  #String duration
  -int amount
  -double phone
  +getId()
  +updateDescription()
  +saveEmail()
  +deleteType()
}
class Shipment {
  #float address
  +String name
  #long updatedAt
  +createPrice()
  +setScore()
  +getDescription()
  +sendUpdatedat()
}
interface Package {
  #Date name
  +boolean quantity
  +boolean id
  -int duration
  +createActive()
}
Customer --o Warehouse
Vehicle --* Customer
Driver --|> Depot
@enduml