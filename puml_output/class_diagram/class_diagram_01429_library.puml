@startuml
skinparam defaultFontSize 13
class Author {
  -String description
  #double code
  #Date note
  +boolean amount
  +sendDuration()
  +getPhone()
  +getName()
}
abstract class Catalog {
  #boolean note
  +int id
  -String level
  +Date amount
  -long email
  +cancelNote()
  +processUpdatedat()
  +processStatus()
}
class Librarian {
  -boolean email
  +String updatedAt
  #int total
  +deleteDuration()
  +setPhone()
  +deleteQuantity()
  +validateTotal()
}
abstract class Shelf {
  +long level
  +Date status
  +deletePrice()
  +processPrice()
  +setEmail()
  +sendId()
}
abstract class Book {
  #boolean id
  #Date active
  -String quantity
  +findId()
  +validateUpdatedat()
  +getUpdatedat()
}
class Branch {
  -int phone
  #float updatedAt
  +long address
  +setName()
  +findNote()
  +setAmount()
}
Librarian ..|> Catalog
Shelf --* Book
note right of Author : Library domain
@enduml