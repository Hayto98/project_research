@startuml
skinparam defaultFontSize 13
class Author {
  -String description
  #double code
  #Date note
  +boolean amount
  +getScore()
  +updateCreatedat()
  +getQuantity()
}
class Catalog {
  -String id
  +Date name
  +boolean note
  -boolean score
  +calculateAddress()
  +sendPhone()
}
class Librarian {
  -float type
  #Date phone
  +findLevel()
  +findEmail()
  +updateCreatedat()
  +deletePrice()
}
class Shelf {
  -double status
  #int quantity
  +boolean description
  +Date email
  -int updatedAt
  +deleteCode()
}
class Book {
  #String address
  +long total
  +Date price
  #float name
  +saveQuantity()
  +cancelDescription()
  +validateLevel()
  +saveLevel()
}
abstract class Branch {
  #double price
  +String code
  #boolean email
  #long active
  #boolean id
  +deleteEmail()
  +deleteNote()
  +processScore()
}
Branch --* Author
Catalog ..> Author : "0..1"
Author --* Catalog
Catalog --o Librarian
@enduml