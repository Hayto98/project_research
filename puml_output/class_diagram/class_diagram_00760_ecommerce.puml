@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Customer {
  -boolean createdAt
  #float note
  #Date price
  +cancelDescription()
  +cancelQuantity()
}
abstract class Invoice {
  -Date note
  #double description
  +cancelType()
  +setAmount()
  +findTotal()
}
class Shipment {
  -float email
  #double score
  +getCreatedat()
  +deletePhone()
}
class Wishlist {
  -float id
  -float phone
  +findStatus()
  +calculateDuration()
}
class Category {
  +double phone
  -boolean name
  +cancelAmount()
  +deleteName()
  +sendStatus()
  +setPrice()
}
abstract class Supplier {
  +boolean amount
  +float name
  -float type
  #boolean status
  +boolean code
  +getLevel()
}
abstract class Coupon {
  -Date email
  +String note
  +long type
  +int price
  +getLevel()
  +processQuantity()
  +sendQuantity()
  +getAddress()
}
Supplier --> Coupon : "*"
Invoice --|> Category
note right of Customer : Ecommerce domain
@enduml