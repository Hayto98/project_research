@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Customer {
  -boolean createdAt
  #float note
  #Date price
  +saveTotal()
  +calculateLevel()
}
interface Invoice {
  #String level
  -Date quantity
  +long type
  +processStatus()
  +calculateLevel()
  +deleteDescription()
  +validateName()
}
class Shipment {
  -boolean total
  -float status
  #double id
  +calculateId()
  +createEmail()
}
class Wishlist {
  +long phone
  -float quantity
  -float status
  +saveDescription()
  +validateId()
}
abstract class Category {
  -String active
  +double name
  +calculateActive()
  +sendName()
  +findLevel()
}
interface Supplier {
  +String amount
  -double name
  -int score
  +getId()
}
class Coupon {
  -float description
  #boolean name
  +getScore()
}
Customer ..> Category : "*"
Shipment --o Coupon
@enduml