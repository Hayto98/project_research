@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Grade {
  -double level
  +String phone
  -double createdAt
  +sendAmount()
}
abstract class Teacher {
  -boolean phone
  #long price
  +updateDescription()
  +processAddress()
  +saveType()
  +findType()
}
class Course {
  #double description
  #float id
  #Date note
  +float quantity
  #String phone
  +cancelQuantity()
}
class Enrollment {
  +long name
  #boolean createdAt
  -Date address
  +getScore()
  +findNote()
}
abstract class Attendance {
  -boolean id
  -long address
  +Date email
  +int total
  -double name
  +getDuration()
  +saveType()
  +setScore()
}
class Library {
  -Date id
  -Date status
  +long total
  +sendScore()
  +findDescription()
  +createCode()
  +validateEmail()
}
Teacher ..> Enrollment : "*"
Grade --|> Enrollment
Grade --> Attendance : "1"
Grade --o Teacher
@enduml