@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Grade {
  -double level
  +String phone
  -double createdAt
  +sendType()
}
class Teacher {
  -int price
  +double duration
  +String active
  -long email
  +savePrice()
  +sendActive()
  +findName()
}
class Course {
  +String note
  +float phone
  +updateAddress()
  +sendLevel()
  +validateUpdatedat()
}
interface Enrollment {
  +Date total
  -boolean duration
  +calculateName()
  +validateDuration()
  +createEmail()
}
class Attendance {
  -float description
  #long total
  +String level
  +calculateAddress()
}
class Library {
  #int email
  +long type
  +float price
  +findPrice()
  +setPrice()
  +getName()
  +cancelLevel()
}
Grade --o Teacher
Grade ..> Course : "1"
note right of Grade : Education domain
@enduml