@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Transaction {
  -double createdAt
  -String id
  -boolean level
  -double code
  +int type
  +findDuration()
  +calculateName()
  +findAmount()
}
class Withdrawal {
  #long active
  +float id
  +createId()
}
class Card {
  #long duration
  #float type
  +sendStatus()
}
class Loan {
  -float address
  #double name
  +processCode()
}
Transaction --* Loan
Loan ..|> Card
@enduml