@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Housekeeping {
  +int updatedAt
  +int createdAt
  #Date price
  #float note
  #int duration
  +sendCode()
}
abstract class Room {
  #double quantity
  #int status
  +updateName()
  +sendAddress()
}
interface Guest {
  #long quantity
  +float status
  #float level
  +calculateStatus()
  +createAddress()
  +deleteActive()
  +sendCreatedat()
}
class Payment {
  #float price
  -long phone
  #float updatedAt
  +Date status
  +setStatus()
}
class Booking {
  -String type
  +float duration
  -float code
  +saveCreatedat()
  +deleteDuration()
  +calculateQuantity()
  +createPhone()
}
Payment ..|> Housekeeping
Housekeeping ..|> Guest
note right of Housekeeping : Hotel domain
@enduml