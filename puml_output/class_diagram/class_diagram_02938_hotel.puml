@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Housekeeping {
  +int updatedAt
  +int createdAt
  #Date price
  #float note
  #int duration
  +calculateDuration()
}
class Room {
  #boolean code
  +int quantity
  +boolean status
  #long price
  #Date createdAt
  +setTotal()
  +validateId()
}
interface Guest {
  #float quantity
  -double id
  +setDuration()
}
class Payment {
  #String amount
  #long active
  -long score
  +Date createdAt
  +findTotal()
}
interface Booking {
  +String phone
  +boolean active
  +double name
  -String code
  +setUpdatedat()
  +validateQuantity()
  +processScore()
}
Payment ..|> Room
Booking --* Payment
Guest --|> Booking
@enduml