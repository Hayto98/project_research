@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Follower {
  #double code
  #boolean email
  +double type
  #long id
  +processNote()
}
interface Hashtag {
  +float updatedAt
  +double note
  -long active
  #boolean email
  #double phone
  +deleteLevel()
  +createCreatedat()
  +calculateName()
  +findTotal()
}
interface Message {
  -double code
  #int updatedAt
  -double email
  #boolean level
  +long type
  +createScore()
}
class Story {
  #Date score
  +int status
  +long active
  +findId()
}
class Album {
  +int updatedAt
  +long email
  #long quantity
  -float duration
  +sendUpdatedat()
  +saveName()
  +getStatus()
  +validateDuration()
}
interface Report {
  #Date quantity
  -double updatedAt
  +float email
  -boolean address
  +processEmail()
  +calculateCreatedat()
  +sendStatus()
  +calculateDescription()
}
Report --|> Follower
Hashtag --o Follower
@enduml