@startuml
skinparam ArrowColor #555555
class Attendance {
  +boolean updatedAt
  +float code
  #long score
  +setPhone()
  +calculateAmount()
  +setDescription()
  +setName()
}
abstract class Student {
  -boolean active
  +double score
  +validateStatus()
  +validateQuantity()
  +deleteScore()
}
class Course {
  -String updatedAt
  +String duration
  +saveCode()
  +findCode()
  +createAddress()
}
class Book {
  -Date type
  +float phone
  #boolean id
  +String amount
  +validateTotal()
  +getPrice()
}
interface Classroom {
  +long updatedAt
  #long description
  #double total
  +getDescription()
  +savePhone()
  +calculateQuantity()
  +findDescription()
}
interface Schedule {
  +float code
  -Date price
  +validateScore()
  +updateAmount()
  +calculateAmount()
}
abstract class Grade {
  +String address
  #Date email
  +int status
  +long updatedAt
  #String description
  +sendAddress()
  +cancelStatus()
}
Course ..> Student : "0..1"
Schedule ..> Classroom : "0..1"
Classroom ..> Course : "1"
note right of Attendance : Education domain
@enduml