@startuml
skinparam ArrowColor #555555
class Attendance {
  +boolean updatedAt
  +float code
  #long score
  +validateId()
  +cancelId()
  +saveCode()
  +deleteScore()
}
class Student {
  #String status
  #boolean name
  -boolean price
  +createNote()
}
abstract class Course {
  +boolean address
  -String status
  +float phone
  +long quantity
  +setUpdatedat()
}
class Book {
  +long code
  #Date duration
  -long email
  +int address
  +setCreatedat()
  +findId()
  +processCreatedat()
}
interface Classroom {
  -float id
  -String level
  -boolean description
  +validateNote()
  +setActive()
}
class Schedule {
  +float name
  +float email
  #long quantity
  -long type
  #float note
  +updateCode()
  +setPhone()
}
interface Grade {
  +float code
  -Date price
  +updateTotal()
  +sendAmount()
  +sendNote()
}
Book --o Student
Book --* Course
Schedule ..|> Attendance
@enduml