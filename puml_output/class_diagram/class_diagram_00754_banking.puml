@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
abstract class Transfer {
  -int type
  #int score
  -double description
  +cancelEmail()
}
class Transaction {
  +long phone
  -float active
  #int createdAt
  -boolean name
  +boolean total
  +sendPrice()
  +getName()
}
class Branch {
  #long amount
  -Date updatedAt
  -boolean name
  #float email
  #String quantity
  +cancelAmount()
  +validateName()
}
class Withdrawal {
  -int createdAt
  #int type
  +boolean status
  +String note
  +findPhone()
  +deleteStatus()
  +findPrice()
  +getQuantity()
}
class Interest {
  -long status
  -int type
  #boolean note
  #String phone
  +saveCreatedat()
}
class Beneficiary {
  +long score
  #String phone
  -Date id
  +processType()
}
class Teller {
  -double note
  #long amount
  +String createdAt
  +Date code
  +Date address
  +findId()
  +sendActive()
}
Branch --|> Transaction
Interest ..|> Beneficiary
Withdrawal ..> Interest : "1"
@enduml