@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Booking {
  +boolean status
  +boolean code
  -String quantity
  -double email
  +int active
  +cancelEmail()
  +processName()
}
class CheckOut {
  +String note
  -boolean level
  #float duration
  +sendNote()
  +findScore()
  +updateQuantity()
}
interface Service {
  +Date quantity
  #long note
  -long type
  +deletePrice()
  +processActive()
  +savePhone()
  +getPhone()
}
class Reservation {
  -boolean active
  #float total
  -long createdAt
  #Date type
  #long description
  +validateType()
  +cancelEmail()
  +saveDuration()
  +deletePhone()
}
CheckOut --* Service
Service --|> CheckOut
note right of Booking : Hotel domain
@enduml