@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Booking {
  +boolean status
  +boolean code
  -String quantity
  -double email
  +int active
  +processScore()
  +findDescription()
}
class CheckOut {
  +String name
  -boolean phone
  #float amount
  #long note
  #Date active
  +getActive()
  +sendAmount()
  +saveNote()
  +updateLevel()
}
interface Service {
  +Date quantity
  #long note
  -long type
  +createCode()
  +processType()
  +validateName()
  +calculateActive()
}
class Reservation {
  #double phone
  #double description
  +cancelCode()
  +setLevel()
}
Reservation --> CheckOut : "1..*"
Reservation --* Service
@enduml