@startuml
skinparam defaultFontSize 13
class Attendance {
  +float duration
  +boolean status
  #float updatedAt
  -float email
  -float price
  +saveType()
}
abstract class Enrollment {
  #String note
  -String code
  #Date type
  #double name
  +getDescription()
  +calculateNote()
  +createName()
  +deleteUpdatedat()
}
abstract class Exam {
  #Date score
  -Date updatedAt
  #boolean name
  -float duration
  -float type
  +validateCode()
  +deleteUpdatedat()
  +sendCreatedat()
  +cancelStatus()
}
class Classroom {
  -int phone
  -float description
  #Date code
  +String name
  +createPhone()
  +calculateUpdatedat()
  +processPhone()
  +getUpdatedat()
}
Exam ..|> Classroom
Attendance ..> Enrollment : "1"
Classroom ..|> Attendance
note right of Attendance : Education domain
@enduml