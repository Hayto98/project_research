@startuml
skinparam defaultFontSize 13
class Attendance {
  +float duration
  +boolean status
  #float updatedAt
  -float email
  -float price
  +cancelScore()
}
abstract class Enrollment {
  #String phone
  -String note
  #Date code
  #double type
  -String name
  +deleteLevel()
  +sendScore()
}
abstract class Exam {
  #double name
  #float description
  +Date updatedAt
  +String type
  +getCode()
  +setScore()
  +findAmount()
  +saveUpdatedat()
}
interface Classroom {
  +boolean address
  +float note
  #String phone
  +float code
  -long amount
  +setDescription()
  +deleteNote()
}
Enrollment ..> Classroom : "1"
Attendance --o Exam
Exam --o Enrollment
@enduml