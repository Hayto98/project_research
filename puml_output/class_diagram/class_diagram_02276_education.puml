@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Teacher {
  -double code
  #String price
  -double duration
  +Date level
  -int address
  +createCreatedat()
}
class Attendance {
  +boolean status
  #boolean description
  +calculateActive()
  +deleteAmount()
}
interface Library {
  #float type
  #double email
  +Date level
  +updateTotal()
  +getDescription()
  +processDuration()
  +cancelId()
}
class Course {
  +double level
  -Date duration
  -double updatedAt
  -float description
  +setCode()
}
class Book {
  #float address
  #boolean id
  -int total
  +boolean updatedAt
  +double amount
  +processQuantity()
  +setCreatedat()
  +findDescription()
  +calculatePhone()
}
abstract class Department {
  #boolean active
  +Date description
  #long total
  -long phone
  -long type
  +getCreatedat()
  +createTotal()
  +getName()
}
Teacher ..|> Course
Library --> Teacher : "1"
Library ..> Department : "0..1"
@enduml