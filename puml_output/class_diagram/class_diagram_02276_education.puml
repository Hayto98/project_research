@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Teacher {
  -double code
  #String price
  -double duration
  +Date level
  -int address
  +deleteAmount()
}
class Attendance {
  #Date description
  #int duration
  +sendScore()
  +updateType()
  +createEmail()
  +findTotal()
}
class Library {
  #float phone
  #int updatedAt
  #int duration
  +double amount
  -Date address
  +calculateTotal()
  +sendId()
  +findAmount()
  +processAddress()
}
class Course {
  +boolean updatedAt
  +double amount
  -String active
  #boolean note
  -double level
  +sendDescription()
  +calculatePhone()
  +processActive()
  +sendAmount()
}
interface Book {
  -boolean quantity
  #float address
  #Date email
  +String score
  +deleteQuantity()
  +getLevel()
  +getPhone()
  +validateDuration()
}
class Department {
  +float phone
  #boolean id
  +Date active
  #long updatedAt
  #double duration
  +sendEmail()
  +findAmount()
  +sendLevel()
  +setUpdatedat()
}
Teacher --|> Book
Library --o Book
note right of Teacher : Education domain
@enduml