@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
interface Payment {
  -int score
  +Date updatedAt
  +sendCreatedat()
  +deleteActive()
  +saveEmail()
  +savePrice()
}
class Invoice {
  +double total
  +boolean level
  +long email
  +setUpdatedat()
}
abstract class Wishlist {
  -long note
  -int address
  +double duration
  +Date email
  +validateUpdatedat()
  +calculateAddress()
  +getName()
  +findName()
}
abstract class Return {
  -int description
  +boolean total
  +sendAmount()
  +findActive()
  +sendDuration()
  +cancelLevel()
}
class Coupon {
  -int updatedAt
  #Date phone
  -String note
  +Date duration
  +findScore()
  +processActive()
  +validateName()
  +findName()
}
interface Shipment {
  +Date price
  -int email
  +processNote()
}
class Cart {
  #String id
  +double description
  +saveDescription()
  +createActive()
  +savePhone()
  +deleteNote()
}
Cart ..> Invoice : "0..1"
Invoice ..> Coupon : "0..1"
Cart --> Coupon : "1..*"
Return --o Cart
Return ..|> Wishlist
@enduml