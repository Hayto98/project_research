@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Card {
  -String score
  +double createdAt
  #String address
  +long amount
  +setTotal()
  +getUpdatedat()
  +cancelType()
}
class Transaction {
  -int name
  +boolean quantity
  +int duration
  +float id
  #long email
  +saveQuantity()
  +validateDuration()
}
class Interest {
  -Date phone
  +boolean active
  -float amount
  #double name
  +createPrice()
  +sendType()
}
class Loan {
  +float createdAt
  +long phone
  +findTotal()
}
abstract class Account {
  -String description
  #double score
  +boolean address
  +validateType()
  +createLevel()
}
Card --|> Account
Loan --> Card : "0..1"
Card --o Loan
Account --* Transaction
@enduml