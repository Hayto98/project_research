@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
class Card {
  -String score
  +double createdAt
  #String address
  +long amount
  +createCreatedat()
  +processName()
  +cancelQuantity()
}
class Transaction {
  +float email
  +boolean type
  +deleteCreatedat()
  +saveEmail()
}
class Interest {
  -boolean address
  +String email
  -Date phone
  +cancelPhone()
}
abstract class Loan {
  +boolean price
  -int email
  +long id
  +processDescription()
}
class Account {
  #int price
  #Date name
  +String type
  +float createdAt
  +setLevel()
  +deleteId()
  +processNote()
  +sendCreatedat()
}
Loan ..> Account : "*"
Transaction --* Account
Card ..|> Interest
note right of Card : Banking domain
@enduml