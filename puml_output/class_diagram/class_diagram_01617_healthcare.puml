@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
interface LabTest {
  +String note
  -Date name
  +findTotal()
  +cancelPrice()
}
interface Ward {
  #float updatedAt
  +Date active
  #long score
  +boolean note
  +float duration
  +sendDescription()
}
class MedicalRecord {
  +int quantity
  +float updatedAt
  #double email
  +calculateName()
}
class Diagnosis {
  -float score
  -long note
  -float active
  +int code
  -boolean updatedAt
  +processCreatedat()
  +getNote()
}
class Billing {
  #long description
  -String price
  +updateActive()
  +findId()
  +updateNote()
}
class Doctor {
  +String active
  +float level
  +createCode()
  +saveDuration()
  +processNote()
  +updateAmount()
}
MedicalRecord --o Doctor
Diagnosis --|> MedicalRecord
Ward --> Diagnosis : "1"
Doctor ..|> Ward
Ward --> LabTest : "1..*"
note right of LabTest : Healthcare domain
@enduml