@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
interface LabTest {
  +String note
  -Date name
  +getActive()
  +findAmount()
}
interface Ward {
  #int duration
  #float note
  +Date updatedAt
  #long active
  +boolean level
  +getPrice()
}
class MedicalRecord {
  +long name
  +int updatedAt
  +float quantity
  +validateEmail()
  +createPrice()
  +setUpdatedat()
  +updateDuration()
}
abstract class Diagnosis {
  -long active
  +int code
  -boolean updatedAt
  +double phone
  +String total
  +validateCode()
  +createDescription()
  +sendQuantity()
  +processQuantity()
}
class Billing {
  +boolean level
  #float phone
  +int email
  -Date status
  +String duration
  +calculateEmail()
  +updateDescription()
}
interface Doctor {
  +double quantity
  -long code
  -float note
  -long score
  +int updatedAt
  +deleteDescription()
  +getType()
  +cancelScore()
  +processPrice()
}
Ward --> LabTest : "1..*"
Diagnosis --o Ward
Diagnosis ..> Doctor : "1"
@enduml