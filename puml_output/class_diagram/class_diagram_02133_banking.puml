@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Account {
  -double active
  -int address
  +createPhone()
}
class Card {
  #Date active
  -boolean quantity
  +float duration
  +float price
  +long updatedAt
  +cancelPhone()
  +calculatePrice()
  +processPrice()
}
abstract class Teller {
  +float updatedAt
  +float name
  -String type
  -double active
  +int status
  +deleteUpdatedat()
}
class Withdrawal {
  +int phone
  #boolean name
  +String description
  +deletePrice()
  +getLevel()
}
class Deposit {
  #int level
  +float type
  +long updatedAt
  +processDuration()
  +cancelDuration()
}
abstract class Transfer {
  +boolean createdAt
  +float code
  -float score
  -Date price
  #Date id
  +findActive()
  +setAmount()
  +deleteCode()
  +sendId()
}
class Statement {
  #int total
  #float active
  +float address
  #boolean code
  +int note
  +sendQuantity()
}
Transfer --> Deposit : "0..1"
Account --* Teller
Deposit --* Withdrawal
Deposit --> Card : "0..1"
Account --* Deposit
@enduml