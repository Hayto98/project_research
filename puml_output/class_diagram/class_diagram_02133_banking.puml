@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
class Account {
  -double active
  -int address
  +setName()
}
interface Card {
  #Date active
  -boolean quantity
  +float duration
  +float price
  +long updatedAt
  +createScore()
  +updateType()
  +processUpdatedat()
}
class Teller {
  +long active
  -int status
  +boolean id
  +boolean score
  -int total
  +getDescription()
  +deleteUpdatedat()
  +findScore()
}
class Withdrawal {
  +double active
  +Date score
  +deleteLevel()
  +processUpdatedat()
  +saveUpdatedat()
}
class Deposit {
  +Date phone
  -double description
  +setScore()
  +calculateId()
}
class Transfer {
  #Date email
  #double quantity
  +validateCreatedat()
  +validateTotal()
  +calculateActive()
  +validateCode()
}
interface Statement {
  #Date description
  +boolean duration
  #Date score
  #boolean name
  #Date updatedAt
  +setEmail()
  +validateLevel()
}
Teller ..|> Deposit
Deposit --|> Card
Deposit --|> Teller
Statement ..> Teller : "0..1"
Withdrawal --|> Teller
note right of Account : Banking domain
@enduml