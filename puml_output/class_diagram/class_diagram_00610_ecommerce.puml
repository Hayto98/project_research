@startuml
skinparam monochrome true
skinparam defaultFontSize 11
class Customer {
  #boolean status
  #int note
  -double code
  #double description
  +long name
  +updateAddress()
  +calculateId()
  +cancelPrice()
}
interface Return {
  -String level
  #int address
  +Date active
  +cancelStatus()
  +saveType()
}
class Shipment {
  -boolean id
  #long price
  +cancelCreatedat()
  +createUpdatedat()
}
class Product {
  #String id
  -Date phone
  +boolean total
  +findEmail()
}
interface Wishlist {
  -float price
  #float quantity
  +processPhone()
  +updatePhone()
}
abstract class Warehouse {
  #String score
  -Date email
  #int createdAt
  +calculateLevel()
  +deleteAddress()
}
class Coupon {
  +float note
  +long address
  +long level
  +boolean price
  +validateDuration()
  +saveCreatedat()
  +saveName()
}
Shipment --* Return
Shipment --|> Warehouse
Coupon ..|> Return
Coupon --|> Shipment
Coupon --o Wishlist
note right of Customer : Ecommerce domain
@enduml