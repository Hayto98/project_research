@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
abstract class DeliveryNote {
  -float level
  +int email
  +boolean quantity
  -String total
  +int score
  +calculateScore()
}
class Depot {
  #Date duration
  -boolean address
  +int note
  -float total
  +long id
  +getUpdatedat()
  +findQuantity()
  +processDuration()
  +createTotal()
}
abstract class Inventory {
  +Date score
  -int id
  +String amount
  #int updatedAt
  +createAddress()
}
class Manifest {
  #long name
  +String quantity
  +boolean createdAt
  #Date type
  +validateScore()
  +deleteName()
  +deleteAmount()
}
class FuelLog {
  -String note
  -float phone
  +deleteLevel()
}
DeliveryNote --|> Depot
FuelLog --o DeliveryNote
DeliveryNote ..> Inventory : "1"
@enduml