@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Category {
  -double quantity
  +double code
  +getId()
  +deletePhone()
  +setPrice()
  +cancelPhone()
}
class Return {
  +boolean quantity
  #String duration
  +calculateAmount()
  +createCreatedat()
  +getQuantity()
}
class Warehouse {
  -boolean level
  #Date quantity
  -String score
  +float status
  +saveLevel()
  +saveUpdatedat()
  +getDescription()
  +updateLevel()
}
class Coupon {
  #String phone
  -int updatedAt
  -double price
  +Date name
  -long amount
  +getEmail()
  +sendStatus()
  +validateName()
  +validateNote()
}
class Product {
  +long quantity
  +int level
  +Date description
  #double name
  -int total
  +findNote()
  +getNote()
  +getPhone()
  +calculateDescription()
}
abstract class Shipment {
  #float email
  -int active
  #boolean price
  +sendScore()
}
Category --|> Product
Product --o Shipment
Category ..|> Coupon
note right of Category : Ecommerce domain
@enduml