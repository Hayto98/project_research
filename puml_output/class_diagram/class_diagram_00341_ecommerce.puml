@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
class Category {
  -double quantity
  +double code
  +deleteNote()
  +deletePhone()
  +updateDuration()
  +updateType()
}
class Return {
  +boolean price
  +long phone
  +getType()
  +getQuantity()
  +findDescription()
}
class Warehouse {
  +long price
  -long amount
  #boolean email
  -boolean createdAt
  +validateScore()
}
interface Coupon {
  +int status
  +boolean amount
  +boolean note
  -long updatedAt
  +updateCode()
  +cancelUpdatedat()
}
abstract class Product {
  -int amount
  -double name
  +sendDuration()
}
abstract class Shipment {
  +long type
  +long name
  -long email
  -float active
  +findName()
  +getEmail()
  +calculateId()
}
Return ..|> Warehouse
Return ..> Shipment : "*"
Warehouse ..> Return : "*"
Shipment --|> Coupon
@enduml