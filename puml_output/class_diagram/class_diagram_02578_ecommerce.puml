@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Shipment {
  -String active
  #Date level
  #long email
  #double id
  +createEmail()
  +sendDescription()
  +createPrice()
}
class Customer {
  -double status
  -String address
  +Date total
  +createStatus()
}
interface Payment {
  -double duration
  -Date createdAt
  +getAddress()
  +processUpdatedat()
  +getScore()
}
abstract class Warehouse {
  +float address
  -boolean total
  #double status
  -long description
  +saveAmount()
}
interface Order {
  -double amount
  +boolean note
  +double active
  #long id
  #Date duration
  +validateId()
  +saveDescription()
  +createDescription()
  +processName()
}
Warehouse --* Order
Shipment ..|> Warehouse
Payment --* Order
note right of Shipment : Ecommerce domain
@enduml