@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Shipment {
  -String active
  #Date level
  #long email
  #double id
  +updateLevel()
  +updateCreatedat()
  +calculateScore()
}
interface Customer {
  +String email
  -float price
  -long description
  +getNote()
  +saveEmail()
  +saveStatus()
  +validateDescription()
}
class Payment {
  #boolean quantity
  +Date status
  +getStatus()
  +processDescription()
}
abstract class Warehouse {
  +boolean email
  -boolean name
  -float address
  -Date note
  -String updatedAt
  +cancelLevel()
  +savePhone()
}
class Order {
  +Date quantity
  -boolean duration
  +int status
  -double amount
  +boolean note
  +sendCreatedat()
}
Payment --* Warehouse
Shipment --* Customer
Customer --|> Warehouse
@enduml