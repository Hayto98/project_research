@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Course {
  -Date name
  +String total
  +long score
  #int createdAt
  +sendType()
  +createAmount()
}
class Book {
  +long createdAt
  #long duration
  -double type
  +findQuantity()
  +getEmail()
  +updateDuration()
}
abstract class Classroom {
  +String email
  -double updatedAt
  +updateCreatedat()
  +calculatePrice()
  +getDuration()
}
abstract class Teacher {
  -long status
  -boolean quantity
  +getActive()
  +getDuration()
}
class Attendance {
  -Date phone
  #Date score
  #float price
  #String amount
  +setPrice()
}
Attendance ..> Teacher : "1..*"
Course ..> Book : "1..*"
Book --* Teacher
note right of Course : Education domain
@enduml