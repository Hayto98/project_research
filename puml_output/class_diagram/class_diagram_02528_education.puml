@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
class Course {
  -Date name
  +String total
  +long score
  #int createdAt
  +findPrice()
  +sendCreatedat()
}
class Book {
  +boolean description
  #double duration
  +long createdAt
  +createQuantity()
  +cancelCode()
  +calculatePhone()
}
class Classroom {
  #double email
  #String createdAt
  +sendStatus()
  +updateStatus()
  +processDuration()
}
class Teacher {
  -String price
  #double address
  +String updatedAt
  -long createdAt
  -double total
  +setName()
  +saveUpdatedat()
}
interface Attendance {
  #Date duration
  #long address
  +createStatus()
  +createDuration()
  +saveDuration()
}
Classroom ..> Course : "1"
Course --* Teacher
@enduml