@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
interface Prescription {
  -float score
  #String status
  -Date note
  -float phone
  #int level
  +cancelPhone()
  +createName()
}
interface Diagnosis {
  #double total
  +String quantity
  -int id
  -double name
  +processDescription()
}
interface Hospital {
  -boolean amount
  -double id
  +boolean duration
  +float active
  -Date phone
  +findType()
}
class Patient {
  #long total
  #boolean createdAt
  #long note
  +createPrice()
}
class Billing {
  #String score
  +double duration
  -String level
  +int email
  +validateAmount()
  +updateUpdatedat()
}
class Treatment {
  #float level
  -Date createdAt
  #int quantity
  +saveType()
  +validateCode()
  +createPrice()
  +deleteType()
}
Treatment ..> Patient : "*"
Prescription ..> Billing : "*"
Hospital ..|> Patient
@enduml