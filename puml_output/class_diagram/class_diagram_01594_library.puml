@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Shelf {
  +float total
  #float createdAt
  +findDescription()
  +cancelDuration()
  +calculateScore()
}
class Catalog {
  +boolean score
  -float description
  -String createdAt
  +float amount
  +updateAddress()
  +setLevel()
  +validateDescription()
  +validateEmail()
}
class Librarian {
  #String active
  -long type
  +String address
  #Date level
  #String id
  +findCreatedat()
  +getUpdatedat()
}
abstract class Fine {
  -int amount
  -float name
  +validatePrice()
  +deleteScore()
  +createPrice()
  +getDescription()
}
Shelf --> Fine : "0..1"
Shelf --* Catalog
@enduml