@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
class Shelf {
  +float total
  #float createdAt
  +cancelEmail()
  +updatePhone()
  +findScore()
}
interface Catalog {
  #long createdAt
  -String amount
  +float level
  +saveDescription()
  +setAmount()
  +cancelNote()
  +sendType()
}
class Librarian {
  +Date id
  #float code
  #String email
  +long address
  #double description
  +findAmount()
}
class Fine {
  +boolean description
  +String price
  #float type
  #int amount
  #String level
  +validateScore()
  +findUpdatedat()
  +setStatus()
}
Fine ..> Shelf : "*"
Fine --|> Librarian
Librarian --|> Catalog
note right of Shelf : Library domain
@enduml