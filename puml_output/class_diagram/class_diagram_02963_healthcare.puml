@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
interface Billing {
  +Date updatedAt
  #double level
  +int status
  #Date duration
  +calculateDuration()
  +sendDescription()
  +cancelUpdatedat()
  +sendUpdatedat()
}
class LabTest {
  -boolean level
  -long amount
  +long name
  +String quantity
  +sendDuration()
  +findTotal()
  +findCreatedat()
  +createName()
}
class MedicalRecord {
  -double address
  -String active
  #double createdAt
  +deleteUpdatedat()
}
class Hospital {
  +String total
  +int createdAt
  #long duration
  +long status
  #Date note
  +saveNote()
  +deletePrice()
  +createLevel()
}
class Nurse {
  #long createdAt
  +String score
  +long id
  +cancelQuantity()
  +calculatePhone()
  +cancelScore()
}
interface Ward {
  +long email
  #Date updatedAt
  -long phone
  +int price
  +int duration
  +setCreatedat()
  +updateNote()
}
Billing ..|> Ward
MedicalRecord --* Ward
@enduml