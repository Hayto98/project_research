@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
interface Member {
  #int score
  +double email
  -boolean description
  +setLevel()
  +cancelPrice()
  +findEmail()
}
abstract class Shelf {
  -long phone
  +boolean level
  #boolean total
  #float address
  +sendEmail()
  +createActive()
}
class Publisher {
  #float price
  #String status
  +int code
  +int address
  -long amount
  +deleteType()
  +getCode()
  +sendLevel()
  +saveTotal()
}
class Reservation {
  #int level
  +double active
  #double createdAt
  #long amount
  +double total
  +cancelScore()
  +deleteActive()
  +sendLevel()
}
Reservation --|> Member
Publisher ..|> Member
note right of Member : Library domain
@enduml