@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
abstract class Report {
  +Date code
  -boolean duration
  +calculateName()
  +findEmail()
}
interface Like {
  #String createdAt
  +int updatedAt
  -float status
  #String active
  +getCode()
  +cancelPrice()
}
class Notification {
  +boolean price
  #boolean email
  +float address
  -String quantity
  +Date total
  +sendUpdatedat()
}
class Hashtag {
  -boolean address
  +float status
  -Date phone
  +createActive()
  +sendStatus()
}
class Post {
  -String createdAt
  -Date duration
  #Date status
  -boolean phone
  +float amount
  +findType()
  +createStatus()
}
class Group {
  #boolean quantity
  +float id
  +updateEmail()
  +setAddress()
  +sendNote()
  +updatePrice()
}
class Profile {
  #boolean amount
  +boolean price
  +createName()
  +sendCode()
  +deleteStatus()
}
Report ..|> Post
Group --o Profile
Hashtag ..|> Report
note right of Report : Social Media domain
@enduml