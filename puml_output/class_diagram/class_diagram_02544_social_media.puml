@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
abstract class Report {
  +Date code
  -boolean duration
  +sendScore()
  +calculateStatus()
}
class Like {
  +boolean score
  #String quantity
  +int createdAt
  -float updatedAt
  +cancelAmount()
}
interface Notification {
  +Date name
  #double code
  -long price
  +createNote()
  +processPhone()
  +deleteType()
}
class Hashtag {
  #boolean code
  +boolean status
  +int quantity
  +long duration
  #Date id
  +deleteStatus()
}
class Post {
  #boolean active
  +float updatedAt
  +double address
  +int amount
  +long quantity
  +cancelPhone()
  +validateId()
}
class Group {
  +long duration
  +long id
  #String description
  #boolean type
  +float quantity
  +setDuration()
  +processActive()
  +setPrice()
  +updateQuantity()
}
class Profile {
  #double address
  +float score
  +processCode()
  +updateName()
  +calculateType()
  +saveAddress()
}
Post ..|> Profile
Post --* Notification
Report --|> Post
Like ..|> Report
@enduml