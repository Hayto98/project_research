@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
interface Vehicle {
  -boolean active
  +int address
  -Date duration
  #Date score
  +float level
  +cancelUpdatedat()
}
class Warehouse {
  -double email
  #boolean phone
  +setActive()
  +calculateScore()
  +getPrice()
}
interface Route {
  #Date score
  #float note
  +String code
  #double duration
  -boolean quantity
  +cancelDuration()
  +setCode()
}
class DeliveryNote {
  -double note
  +long total
  -float name
  +sendUpdatedat()
}
class Manifest {
  -String type
  -float active
  -boolean code
  -Date quantity
  +processStatus()
  +validateDescription()
}
DeliveryNote --* Warehouse
Vehicle ..> Warehouse : "0..1"
@enduml