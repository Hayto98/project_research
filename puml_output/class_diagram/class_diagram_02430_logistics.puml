@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
interface Vehicle {
  -boolean active
  +int address
  -Date duration
  #Date score
  +float level
  +findStatus()
}
class Warehouse {
  -float phone
  #float type
  -float price
  #double address
  +setQuantity()
}
interface Route {
  #int name
  #Date price
  +float address
  +processTotal()
  +getEmail()
}
abstract class DeliveryNote {
  #int email
  #long quantity
  -boolean status
  +createPrice()
}
class Manifest {
  +double note
  +long active
  +int price
  #int updatedAt
  -boolean phone
  +createUpdatedat()
}
Warehouse --* Route
Warehouse --> Manifest : "1"
Vehicle ..|> DeliveryNote
note right of Vehicle : Logistics domain
@enduml