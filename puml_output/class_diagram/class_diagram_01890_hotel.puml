@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Restaurant {
  -Date score
  -int createdAt
  +Date type
  -float description
  +cancelAmount()
  +updateScore()
}
class Staff {
  +boolean status
  #double quantity
  +String type
  #long level
  +cancelDuration()
  +setStatus()
  +saveNote()
}
class Invoice {
  +int phone
  -boolean note
  -int level
  #Date score
  #String email
  +validatePrice()
}
abstract class Service {
  +float email
  +int active
  +getUpdatedat()
  +saveQuantity()
  +processAddress()
}
interface Booking {
  +float quantity
  -String duration
  -long phone
  -float description
  +long createdAt
  +calculateId()
  +cancelCode()
}
Booking --* Restaurant
Restaurant ..|> Service
@enduml