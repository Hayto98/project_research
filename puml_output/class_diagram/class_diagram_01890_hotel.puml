@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Restaurant {
  -Date score
  -int createdAt
  +Date type
  -float description
  +sendQuantity()
  +createStatus()
}
interface Staff {
  #boolean type
  -float level
  +String quantity
  #long status
  +saveStatus()
  +updateId()
  +processPhone()
}
abstract class Invoice {
  #float note
  -int email
  #Date status
  #String amount
  #String type
  +setEmail()
  +findActive()
  +getId()
  +updateQuantity()
}
class Service {
  +float quantity
  -String duration
  -long phone
  -float description
  +long createdAt
  +getType()
  +setDuration()
}
class Booking {
  -float name
  -Date total
  #double amount
  #double score
  +deletePrice()
  +saveDescription()
  +setDuration()
  +setActive()
}
Restaurant --> Invoice : "*"
Service --* Staff
Booking --|> Restaurant
note right of Restaurant : Hotel domain
@enduml