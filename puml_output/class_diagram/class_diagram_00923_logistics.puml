@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
interface DeliveryNote {
  -String amount
  +int level
  +getCreatedat()
}
class Shipment {
  +boolean note
  +Date score
  -float quantity
  +Date name
  +calculateScore()
  +setPhone()
  +createNote()
  +deleteDuration()
}
class Manifest {
  #String id
  #double total
  -long status
  -String updatedAt
  +sendQuantity()
  +validateStatus()
  +processCreatedat()
  +saveNote()
}
abstract class Driver {
  +String note
  -long duration
  -float level
  +float name
  +processScore()
}
class Tracking {
  +int address
  -double createdAt
  #float price
  #String score
  #boolean type
  +saveAddress()
  +setQuantity()
  +getActive()
}
class Warehouse {
  +double note
  +float id
  -double level
  +getScore()
  +setAddress()
  +sendPhone()
  +validateDuration()
}
class Vehicle {
  -float amount
  #boolean total
  +long quantity
  +sendPhone()
  +updateLevel()
  +findStatus()
}
Shipment --* Tracking
Vehicle ..|> Manifest
Shipment --* Warehouse
Manifest --o Vehicle
@enduml