@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Fine {
  #boolean total
  -long level
  +String quantity
  +long id
  +int email
  +sendAddress()
  +cancelName()
  +saveTotal()
  +createNote()
}
class Renewal {
  -Date total
  -double score
  -boolean status
  -boolean email
  +saveAmount()
}
abstract class Book {
  #Date code
  #boolean status
  -float active
  -Date quantity
  +setPrice()
  +sendAmount()
}
interface Librarian {
  #double score
  #Date quantity
  #double amount
  +int code
  +float duration
  +setScore()
  +getPhone()
  +updateId()
  +saveDescription()
}
Fine --|> Librarian
Renewal --|> Fine
Book ..|> Renewal
@enduml