@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Fine {
  #boolean total
  -long level
  +String quantity
  +long id
  +int email
  +createName()
  +createTotal()
  +sendStatus()
  +createPrice()
}
abstract class Renewal {
  -float phone
  -float score
  +String note
  #long name
  #Date level
  +createCreatedat()
  +sendLevel()
  +calculateScore()
  +createAmount()
}
class Book {
  +int type
  -Date total
  -Date description
  +getName()
  +setUpdatedat()
  +getId()
  +cancelQuantity()
}
abstract class Librarian {
  #double level
  +int createdAt
  +float amount
  +sendCode()
  +validateStatus()
  +setEmail()
  +deleteStatus()
}
Librarian ..|> Fine
Renewal --|> Book
Librarian --|> Book
note right of Fine : Library domain
@enduml