@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Return {
  #String id
  +long type
  #Date updatedAt
  +calculateTotal()
}
class Shipment {
  -int active
  #Date address
  #double updatedAt
  #boolean code
  +findEmail()
  +setPhone()
}
class Warehouse {
  +double type
  +boolean quantity
  #boolean description
  +Date phone
  +Date price
  +createAmount()
  +findDuration()
}
interface Payment {
  +int updatedAt
  +String email
  -boolean amount
  +String code
  +int status
  +deleteLevel()
}
Shipment --|> Return
Warehouse ..|> Return
@enduml