@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Return {
  #String id
  +long type
  #Date updatedAt
  +createEmail()
}
interface Shipment {
  #Date updatedAt
  #double code
  #boolean price
  +boolean amount
  +cancelType()
}
abstract class Warehouse {
  -int description
  #boolean phone
  #int price
  #String status
  +validateActive()
  +cancelType()
}
class Payment {
  +String amount
  +long code
  #int status
  +String score
  +setDuration()
  +updateAmount()
}
Return --|> Shipment
Shipment --> Return : "1"
note right of Return : Ecommerce domain
@enduml