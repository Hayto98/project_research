@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
interface Branch {
  +float createdAt
  #int updatedAt
  +cancelTotal()
  +validateCreatedat()
  +updateQuantity()
}
class Reservation {
  +long total
  +float price
  -boolean level
  -float id
  +float score
  +deleteQuantity()
}
interface Loan {
  +long type
  +double status
  #String duration
  +deleteQuantity()
  +validateScore()
}
class Member {
  -String description
  +long address
  #float total
  #String duration
  -int phone
  +deleteType()
  +updatePrice()
  +updateAddress()
}
Branch ..|> Reservation
Member ..|> Reservation
Loan --o Branch
note right of Branch : Library domain
@enduml