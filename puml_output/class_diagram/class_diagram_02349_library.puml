@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
interface Branch {
  +float createdAt
  #int updatedAt
  +findDescription()
  +findAmount()
  +setQuantity()
}
class Reservation {
  -double updatedAt
  -float quantity
  #Date description
  +cancelTotal()
  +deleteAmount()
  +calculateNote()
  +cancelId()
}
class Loan {
  +long level
  #boolean price
  +double status
  +double code
  +deleteCreatedat()
  +processActive()
}
abstract class Member {
  -long amount
  #Date description
  +calculateDuration()
  +findType()
}
Reservation --o Member
Reservation --* Loan
Loan ..|> Branch
@enduml