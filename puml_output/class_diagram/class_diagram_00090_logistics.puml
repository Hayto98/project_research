@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class DeliveryNote {
  #long level
  -int id
  +saveName()
  +validateQuantity()
  +cancelAmount()
}
abstract class Package {
  +long total
  +Date type
  #double price
  +findLevel()
  +findNote()
  +calculateUpdatedat()
  +calculateEmail()
}
class Vehicle {
  +int type
  #double id
  -Date quantity
  +findQuantity()
  +createActive()
}
interface Manifest {
  #float score
  +int id
  +validateQuantity()
  +createId()
  +updateDuration()
  +setAmount()
}
interface Customer {
  +String quantity
  -String address
  -float active
  -boolean duration
  #Date score
  +validateCreatedat()
  +createName()
  +saveAddress()
}
interface Warehouse {
  +double address
  +float email
  #Date total
  #float name
  -long score
  +createUpdatedat()
}
abstract class Inventory {
  #double active
  +String amount
  +sendCode()
  +findActive()
  +setDescription()
  +createActive()
}
Customer ..> Warehouse : "0..1"
DeliveryNote --> Inventory : "1..*"
@enduml