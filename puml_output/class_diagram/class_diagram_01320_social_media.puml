@startuml
skinparam monochrome true
skinparam defaultFontSize 11
abstract class Message {
  -double email
  +Date score
  #double level
  +cancelType()
  +saveUpdatedat()
  +cancelId()
}
interface Hashtag {
  -String id
  -boolean type
  #String total
  -float score
  -Date updatedAt
  +validateStatus()
}
interface Group {
  #boolean score
  #float updatedAt
  -String note
  #int createdAt
  +setCode()
  +createLevel()
  +validateStatus()
  +saveDuration()
}
class Album {
  +Date level
  -boolean price
  -boolean quantity
  +cancelPrice()
  +saveCode()
}
class Report {
  +Date duration
  -long id
  +long name
  +createAddress()
}
class User {
  #double address
  #float score
  +processEmail()
  +updatePhone()
  +validateId()
  +validateDescription()
}
class Story {
  #double name
  +Date code
  +validateDuration()
  +deleteDuration()
  +createType()
  +cancelType()
}
Story --o User
User --|> Album
Report ..> Hashtag : "1..*"
@enduml