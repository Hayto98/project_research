@startuml
skinparam shadowing true
class Service {
  -float phone
  -Date status
  #boolean active
  +processCode()
  +validateNote()
  +processActive()
}
abstract class Staff {
  +int email
  +long createdAt
  +processType()
}
class Restaurant {
  #long score
  -double name
  #String type
  +Date address
  +processUpdatedat()
  +saveTotal()
  +setPrice()
}
interface Payment {
  #int status
  +String total
  #Date score
  #Date email
  -Date description
  +calculateNote()
  +processQuantity()
  +calculateNote()
  +updatePhone()
}
class Room {
  #long address
  #boolean quantity
  -int price
  -Date description
  -Date note
  +deleteNote()
  +findPhone()
}
class Housekeeping {
  #int status
  +long createdAt
  -int note
  +int code
  +int duration
  +saveType()
  +calculateType()
  +createUpdatedat()
  +saveCreatedat()
}
Staff ..|> Service
Housekeeping --> Staff : "*"
note right of Service : Hotel domain
@enduml