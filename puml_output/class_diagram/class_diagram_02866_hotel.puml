@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Room {
  +String code
  +boolean description
  #long score
  #long duration
  +deleteTotal()
  +getPrice()
  +calculateCreatedat()
}
interface Amenity {
  #long price
  -boolean status
  +float note
  #double active
  +findEmail()
  +createQuantity()
}
class Housekeeping {
  +int status
  #long description
  +String email
  +updateAmount()
  +sendAmount()
  +findAddress()
}
class Payment {
  -float quantity
  +Date score
  +String id
  +float level
  +double status
  +cancelName()
  +cancelId()
  +findQuantity()
  +getId()
}
Payment --o Amenity
Payment ..|> Housekeeping
Amenity --> Payment : "*"
@enduml