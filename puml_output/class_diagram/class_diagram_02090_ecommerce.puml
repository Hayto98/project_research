@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
interface Order {
  #boolean id
  -float type
  +cancelId()
  +updateName()
  +cancelDuration()
}
class Shipment {
  +long address
  -boolean updatedAt
  +Date level
  -long total
  +updateStatus()
  +calculateUpdatedat()
  +cancelPhone()
}
class Wishlist {
  -float quantity
  -int status
  +saveActive()
  +sendPhone()
  +calculateEmail()
  +createStatus()
}
abstract class Payment {
  +int phone
  +int amount
  +sendUpdatedat()
  +calculateUpdatedat()
  +calculateDuration()
  +cancelQuantity()
}
Payment ..> Shipment : "1..*"
Wishlist --|> Order
note right of Order : Ecommerce domain
@enduml