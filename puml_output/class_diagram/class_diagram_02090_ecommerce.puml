@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
interface Order {
  #boolean id
  -float type
  +deleteUpdatedat()
  +cancelTotal()
  +getName()
}
class Shipment {
  -Date level
  -int code
  +cancelCreatedat()
  +validateDescription()
}
class Wishlist {
  -int phone
  #Date createdAt
  +double duration
  +boolean address
  +saveScore()
  +createStatus()
  +getUpdatedat()
}
class Payment {
  #double status
  #boolean address
  #long note
  -long updatedAt
  +getUpdatedat()
  +validateEmail()
  +getPrice()
}
Order ..|> Shipment
Shipment --|> Order
Shipment --> Payment : "0..1"
@enduml