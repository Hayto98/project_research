@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Publisher {
  -int total
  -long address
  +getId()
  +processNote()
  +deleteScore()
  +findNote()
}
class Catalog {
  -float type
  #boolean phone
  -String id
  +String note
  +float status
  +calculateAmount()
  +calculateCode()
  +createTotal()
  +saveActive()
}
class Shelf {
  #boolean address
  #Date duration
  +long price
  -double note
  #String quantity
  +findAmount()
  +createDescription()
  +sendQuantity()
}
abstract class Fine {
  +String quantity
  -String level
  +String name
  -double phone
  +getAddress()
}
class Loan {
  +Date level
  #boolean status
  -long type
  +Date createdAt
  #long updatedAt
  +saveId()
}
abstract class Librarian {
  +int score
  -double note
  -long quantity
  -double total
  +createActive()
  +sendEmail()
  +findScore()
}
class Member {
  #String address
  #String email
  #String name
  #int active
  +getScore()
  +calculatePhone()
  +validateDescription()
  +processDuration()
}
Publisher ..|> Member
Member --> Fine : "1"
Member --> Shelf : "0..1"
@enduml