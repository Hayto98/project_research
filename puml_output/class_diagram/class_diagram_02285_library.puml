@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
class Publisher {
  -int total
  -long address
  +processAmount()
  +setAmount()
  +cancelType()
  +processPhone()
}
interface Catalog {
  -float note
  #boolean status
  +setAmount()
  +setStatus()
  +findType()
  +processPrice()
}
interface Shelf {
  #Date note
  -long address
  #boolean level
  #Date price
  +validatePrice()
  +processActive()
}
class Fine {
  -long total
  #Date active
  +long level
  +String price
  +setUpdatedat()
  +setNote()
  +processCode()
  +calculateQuantity()
}
abstract class Loan {
  +String type
  #boolean createdAt
  +createName()
  +findLevel()
  +validateStatus()
  +getTotal()
}
interface Librarian {
  +int score
  -double note
  -long quantity
  -double total
  +validateCreatedat()
  +createPhone()
  +saveEmail()
}
class Member {
  #String level
  #String name
  #String score
  #int active
  +sendQuantity()
  +updatePhone()
  +getId()
  +updateTotal()
}
Member --|> Librarian
Member --> Shelf : "0..1"
Publisher ..> Member : "0..1"
Librarian --* Publisher
Loan --* Publisher
note right of Publisher : Library domain
@enduml