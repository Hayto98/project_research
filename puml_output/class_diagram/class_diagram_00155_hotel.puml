@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Service {
  +int description
  #long createdAt
  +cancelPrice()
  +updateAddress()
  +deleteActive()
}
interface CheckIn {
  -String quantity
  #int name
  -int note
  +Date active
  +getScore()
  +calculateStatus()
}
interface CheckOut {
  #int note
  -boolean phone
  +setAmount()
  +deleteType()
  +createEmail()
}
class Invoice {
  -int type
  -boolean active
  +deleteName()
  +saveActive()
}
abstract class Housekeeping {
  #double description
  #double duration
  -String email
  +findUpdatedat()
  +createPrice()
}
class Restaurant {
  #boolean type
  +Date name
  +processScore()
  +saveAmount()
  +deletePhone()
  +sendStatus()
}
class Guest {
  +float level
  +int active
  +float code
  +deleteEmail()
  +cancelStatus()
  +setActive()
}
Service ..|> CheckIn
Housekeeping ..|> Service
@enduml