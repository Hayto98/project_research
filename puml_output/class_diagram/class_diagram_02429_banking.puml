@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
abstract class Loan {
  -boolean total
  +Date id
  +double type
  +updateName()
}
interface Statement {
  -Date address
  +long code
  -int createdAt
  +boolean amount
  #String total
  +getType()
}
interface Teller {
  +double total
  #int quantity
  +deleteType()
}
class Branch {
  #Date createdAt
  -long status
  #long duration
  +double updatedAt
  +sendQuantity()
  +validateTotal()
}
class Beneficiary {
  +float price
  +boolean description
  -float name
  +findTotal()
  +updatePhone()
  +saveCode()
  +cancelNote()
}
class Card {
  -String note
  #boolean level
  -float id
  +String duration
  +calculateAmount()
  +validateAmount()
  +sendScore()
}
abstract class Customer {
  #int address
  -String phone
  +updatePhone()
}
Teller --> Loan : "*"
Loan ..|> Beneficiary
Card --* Loan
Loan --* Statement
Teller --|> Beneficiary
@enduml