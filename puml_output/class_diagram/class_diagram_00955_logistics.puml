@startuml
skinparam defaultFontSize 13
abstract class Manifest {
  #float email
  #long active
  #long description
  #Date status
  +getAmount()
  +processName()
}
abstract class Tracking {
  #double price
  +boolean note
  #int id
  #long active
  #String code
  +deleteType()
}
class Shipment {
  +Date description
  #Date email
  -double id
  #float price
  +validateUpdatedat()
  +getNote()
  +findId()
  +createUpdatedat()
}
class Driver {
  #String phone
  #long note
  +cancelLevel()
}
class Customer {
  -double score
  #double note
  +deleteNote()
  +cancelEmail()
  +deleteDuration()
}
interface Inventory {
  -Date total
  -Date active
  +deleteDuration()
  +getCode()
}
Manifest --|> Tracking
Driver ..|> Customer
@enduml