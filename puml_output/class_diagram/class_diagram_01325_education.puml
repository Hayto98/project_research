@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
abstract class Library {
  -int duration
  #long quantity
  -Date email
  #long price
  #String type
  +calculateDescription()
}
interface Classroom {
  #String createdAt
  +float email
  #String active
  -String updatedAt
  -int description
  +validateQuantity()
  +processEmail()
  +processAddress()
}
class Book {
  -double address
  +String updatedAt
  +Date email
  +cancelLevel()
  +saveUpdatedat()
}
class Course {
  -long status
  #double phone
  +processCreatedat()
  +saveAddress()
  +deleteLevel()
  +getName()
}
class Student {
  #int type
  -int total
  +sendActive()
}
class Exam {
  #int level
  #long score
  +boolean phone
  +validateType()
}
Classroom ..|> Exam
Student ..> Classroom : "1..*"
Book ..|> Student
Classroom --o Student
note right of Library : Education domain
@enduml