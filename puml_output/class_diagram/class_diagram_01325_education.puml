@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
abstract class Library {
  -int duration
  #long quantity
  -Date email
  #long price
  #String type
  +createDuration()
}
class Classroom {
  #String createdAt
  +float email
  #String active
  -String updatedAt
  -int description
  +processStatus()
  +updateLevel()
  +createId()
}
abstract class Book {
  -int type
  -long address
  -int name
  +String description
  +saveDuration()
  +getActive()
}
interface Course {
  +long description
  -long score
  #double name
  +saveAmount()
  +processActive()
  +cancelDuration()
  +calculateName()
}
class Student {
  #String name
  -Date quantity
  +cancelActive()
  +validateQuantity()
  +createAmount()
  +validateNote()
}
class Exam {
  #long description
  #int level
  +deleteTotal()
  +validatePhone()
  +getStatus()
}
Book --* Course
Classroom ..|> Exam
@enduml