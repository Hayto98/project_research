@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Like {
  -float amount
  #int name
  +findPrice()
  +setStatus()
  +getStatus()
}
class User {
  -float total
  #Date score
  +saveCreatedat()
  +saveEmail()
}
class Notification {
  +float email
  -int price
  -long description
  +double code
  +findPrice()
}
class Story {
  -String price
  -float address
  -float email
  +int total
  +calculateCode()
  +createId()
  +processScore()
  +calculateEmail()
}
Story --* Like
Notification --|> User
@enduml