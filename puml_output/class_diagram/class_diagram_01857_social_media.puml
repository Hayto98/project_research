@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
class Like {
  -float amount
  #int name
  +sendStatus()
  +validateId()
  +calculateScore()
}
abstract class User {
  #long address
  -double name
  +float level
  +getNote()
}
class Notification {
  #String phone
  #long code
  -long total
  -Date status
  +calculateCode()
  +validateQuantity()
  +getAmount()
  +calculatePrice()
}
class Story {
  +long duration
  -long type
  +deleteTotal()
}
Story ..|> Like
Like ..> Story : "*"
note right of Like : Social Media domain
@enduml