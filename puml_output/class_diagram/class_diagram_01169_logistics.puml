@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
class DeliveryNote {
  +String level
  -int createdAt
  +calculateType()
  +calculateName()
}
class Driver {
  #float quantity
  #long createdAt
  #int score
  +saveDuration()
  +processTotal()
  +calculateEmail()
}
class Package {
  #String updatedAt
  -int status
  #double amount
  +float description
  +float code
  +processStatus()
  +processAmount()
  +cancelDuration()
}
class Tracking {
  -long id
  #Date type
  +float active
  +sendCode()
  +deleteNote()
  +validateLevel()
  +setCode()
}
abstract class Manifest {
  +boolean duration
  +String code
  #double score
  +sendPrice()
  +validateStatus()
  +getActive()
  +updateId()
}
class Depot {
  #Date description
  +String amount
  -Date createdAt
  +long type
  -long level
  +calculateScore()
}
Driver --> Depot : "1"
Manifest ..|> Package
Manifest --o Tracking
Depot ..|> Manifest
@enduml