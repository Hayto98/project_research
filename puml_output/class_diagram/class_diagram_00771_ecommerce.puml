@startuml
skinparam defaultFontSize 13
abstract class Wishlist {
  +float address
  #int status
  +float email
  #String updatedAt
  +setNote()
  +createLevel()
  +updateAddress()
  +processTotal()
}
class Payment {
  -double status
  -boolean code
  +Date score
  -double email
  -double updatedAt
  +calculateScore()
  +calculateAddress()
  +calculateTotal()
}
class Cart {
  +Date duration
  #int phone
  +findTotal()
}
interface Coupon {
  #Date createdAt
  +float level
  +boolean quantity
  +createCreatedat()
  +processPhone()
  +getType()
  +sendEmail()
}
Cart --|> Wishlist
Coupon --|> Cart
@enduml