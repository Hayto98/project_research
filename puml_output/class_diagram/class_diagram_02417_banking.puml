@startuml
skinparam defaultFontSize 13
class Transfer {
  +String price
  -Date duration
  +long score
  +sendStatus()
}
class Loan {
  #long id
  +Date price
  +cancelId()
}
interface Account {
  #double amount
  #long note
  +findUpdatedat()
}
class Teller {
  -boolean total
  #long quantity
  +long phone
  -Date amount
  +createTotal()
  +updateCreatedat()
  +createStatus()
  +cancelNote()
}
class Beneficiary {
  -float updatedAt
  #String code
  +float status
  +getDuration()
}
class Withdrawal {
  #float id
  +int price
  #double type
  +setPrice()
  +saveId()
  +calculateNote()
  +findUpdatedat()
}
Loan ..|> Beneficiary
Transfer --|> Beneficiary
Account --o Withdrawal
Loan --* Withdrawal
@enduml