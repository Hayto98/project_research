@startuml
skinparam defaultFontSize 13
class Transfer {
  +String price
  -Date duration
  +long score
  +findAddress()
}
class Loan {
  -String price
  #boolean level
  +validateActive()
}
interface Account {
  #double amount
  #long note
  +cancelQuantity()
}
interface Teller {
  -boolean total
  #long quantity
  +long phone
  -Date amount
  +findScore()
  +updateAmount()
  +deleteUpdatedat()
  +setStatus()
}
class Beneficiary {
  +int name
  +double duration
  +sendAmount()
  +deleteNote()
  +processName()
  +updateDuration()
}
interface Withdrawal {
  -long updatedAt
  -int duration
  +long name
  -Date status
  +deleteUpdatedat()
  +getAmount()
}
Account ..> Transfer : "1"
Beneficiary ..|> Loan
Withdrawal --|> Loan
note right of Transfer : Banking domain
@enduml