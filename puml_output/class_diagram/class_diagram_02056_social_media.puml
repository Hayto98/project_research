@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
abstract class User {
  -long total
  -long status
  -boolean quantity
  +sendPhone()
  +processType()
}
class Comment {
  #float duration
  +boolean id
  +String level
  #boolean updatedAt
  +deleteName()
  +updateName()
}
class Album {
  +Date createdAt
  +String id
  -long active
  +processCreatedat()
}
class Notification {
  -int id
  #float amount
  -long name
  -String updatedAt
  +validateAmount()
  +cancelDescription()
  +cancelLevel()
}
class Like {
  #boolean id
  #String note
  +calculateQuantity()
}
abstract class Report {
  #String level
  +int price
  #long status
  +setActive()
}
class Message {
  -float email
  -Date status
  -long quantity
  +double phone
  +int amount
  +sendPrice()
  +createEmail()
}
Like --|> Notification
User ..|> Notification
Like ..> Message : "1"
Message --* Report
note right of User : Social Media domain
@enduml