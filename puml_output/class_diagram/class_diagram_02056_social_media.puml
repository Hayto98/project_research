@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
abstract class User {
  -long total
  -long status
  -boolean quantity
  +cancelAmount()
  +cancelId()
}
abstract class Comment {
  #float phone
  +boolean email
  +String id
  #boolean score
  #Date updatedAt
  +saveTotal()
  +findPhone()
}
class Album {
  +Date name
  #String amount
  #int description
  +setStatus()
}
class Notification {
  -String status
  #int note
  #String createdAt
  #boolean name
  +findCode()
  +getTotal()
}
interface Like {
  -int phone
  #int total
  #float name
  #float address
  +deleteQuantity()
  +processCreatedat()
  +deleteType()
}
class Report {
  -double active
  #Date score
  #int id
  #double status
  +boolean total
  +createCode()
}
class Message {
  -long code
  +long duration
  #Date active
  #boolean id
  +cancelType()
  +processUpdatedat()
  +calculateQuantity()
}
Report --* Notification
Comment --|> Notification
Comment ..> Like : "0..1"
Like ..> Report : "*"
@enduml