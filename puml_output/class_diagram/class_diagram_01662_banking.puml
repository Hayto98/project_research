@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Interest {
  +double note
  -Date updatedAt
  #Date total
  +processStatus()
  +sendCode()
  +findQuantity()
}
class Loan {
  #float active
  +Date amount
  #float total
  #float status
  #float email
  +processTotal()
}
class Card {
  #float name
  +boolean price
  -long email
  +int address
  +long quantity
  +sendUpdatedat()
}
class Teller {
  #String amount
  +Date name
  +String email
  +calculateQuantity()
}
class Withdrawal {
  -float score
  -float code
  +float amount
  +cancelNote()
  +validatePrice()
}
Loan ..> Card : "1..*"
Card --|> Interest
note right of Interest : Banking domain
@enduml