@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Interest {
  +double note
  -Date updatedAt
  #Date total
  +findActive()
  +updatePhone()
  +updateUpdatedat()
}
interface Loan {
  -boolean quantity
  +double description
  +processNote()
}
interface Card {
  +float code
  -float status
  +double type
  -boolean total
  +savePrice()
  +findScore()
  +saveType()
}
interface Teller {
  +int duration
  +long phone
  +float level
  +deleteScore()
  +sendId()
}
class Withdrawal {
  +Date email
  +String status
  +saveType()
}
Card --> Interest : "0..1"
Withdrawal ..|> Interest
Card ..|> Withdrawal
@enduml