@startuml
skinparam shadowing true
interface LabTest {
  #long description
  #String total
  -int name
  +boolean active
  +createDescription()
  +updateActive()
  +processLevel()
}
interface Prescription {
  #int status
  #Date id
  +deleteName()
  +validateName()
  +setLevel()
}
class Patient {
  #String id
  #long name
  -Date address
  +long status
  +deletePrice()
  +deletePrice()
  +processNote()
}
abstract class Ward {
  +long note
  -String name
  -String duration
  #int quantity
  +updateName()
  +updateDuration()
  +deleteTotal()
}
class Treatment {
  #float active
  +int status
  -Date description
  +createName()
  +updateLevel()
  +sendTotal()
}
class Appointment {
  +long total
  +String type
  #float quantity
  -int active
  +saveDuration()
  +createCode()
}
Ward --|> LabTest
Patient ..> Ward : "1..*"
LabTest ..|> Patient
note right of LabTest : Healthcare domain
@enduml