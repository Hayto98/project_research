@startuml
skinparam shadowing true
interface LabTest {
  #long description
  #String total
  -int name
  +boolean active
  +deleteCreatedat()
  +setActive()
  +getActive()
}
class Prescription {
  #String active
  +String type
  #int duration
  +processUpdatedat()
  +createId()
  +savePhone()
}
class Patient {
  -float code
  #long level
  +findUpdatedat()
}
class Ward {
  #int status
  -boolean duration
  -int address
  -int phone
  +saveAmount()
  +getDescription()
  +cancelQuantity()
  +sendPhone()
}
abstract class Treatment {
  +long note
  -String quantity
  +processQuantity()
  +findDuration()
  +findId()
}
class Appointment {
  -Date name
  +int createdAt
  #String description
  +setAmount()
  +deleteStatus()
}
Prescription ..> Patient : "1..*"
Patient ..|> LabTest
Appointment --> Treatment : "*"
@enduml