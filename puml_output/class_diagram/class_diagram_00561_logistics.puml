@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
abstract class Tracking {
  +boolean status
  +Date total
  #float createdAt
  +deletePrice()
}
class Manifest {
  +long note
  #Date id
  -String description
  #int phone
  -double amount
  +getEmail()
  +findScore()
  +deleteUpdatedat()
  +deleteDescription()
}
class Route {
  #int level
  +Date code
  -long amount
  +long phone
  +cancelLevel()
  +calculateDescription()
}
class Shipment {
  +long phone
  -long active
  -Date code
  +getDescription()
}
class Depot {
  +String note
  #Date code
  #boolean quantity
  +double updatedAt
  +createEmail()
  +cancelAddress()
  +sendCreatedat()
  +sendLevel()
}
Depot --o Manifest
Manifest ..> Route : "1..*"
Manifest --* Shipment
@enduml