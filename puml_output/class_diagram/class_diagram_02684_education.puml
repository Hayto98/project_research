@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Library {
  +long name
  #boolean duration
  #long description
  #long total
  +calculateDescription()
  +sendCode()
  +saveId()
}
class Book {
  -float email
  +float address
  -boolean type
  +saveType()
  +saveActive()
}
class Assignment {
  -double price
  #int active
  +findStatus()
  +processEmail()
}
interface Attendance {
  -long email
  +double score
  +deleteActive()
}
abstract class Course {
  +double phone
  -String status
  +calculateEmail()
  +deletePrice()
}
Library ..> Attendance : "1"
Book --> Course : "1..*"
@enduml