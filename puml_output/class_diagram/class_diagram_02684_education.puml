@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
class Library {
  +long name
  #boolean duration
  #long description
  #long total
  +findNote()
  +getAmount()
  +deleteEmail()
}
class Book {
  #String type
  #double name
  #double total
  -boolean amount
  +int createdAt
  +createScore()
}
class Assignment {
  -String updatedAt
  -String note
  +double code
  -String type
  +getNote()
  +getStatus()
}
interface Attendance {
  -int status
  +boolean amount
  #double updatedAt
  #double address
  -boolean code
  +validatePhone()
  +findPrice()
  +findScore()
  +validateType()
}
abstract class Course {
  #int total
  -Date createdAt
  #double score
  #float type
  +createCreatedat()
}
Assignment --|> Course
Course --|> Assignment
Course --> Library : "0..1"
Book --* Course
note right of Library : Education domain
@enduml