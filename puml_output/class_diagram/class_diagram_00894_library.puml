@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
abstract class Book {
  -String email
  +boolean amount
  #boolean phone
  +sendUpdatedat()
  +findUpdatedat()
  +getActive()
}
abstract class Renewal {
  +int duration
  +boolean address
  -boolean note
  +sendNote()
  +calculateStatus()
  +setQuantity()
}
interface Catalog {
  +double id
  -float phone
  +processDuration()
  +updateLevel()
}
class Publisher {
  +long phone
  #double quantity
  -Date type
  -Date id
  +updateAddress()
  +processLevel()
  +sendScore()
  +deleteEmail()
}
class Loan {
  -int score
  -float description
  -boolean quantity
  +Date updatedAt
  +deleteAddress()
  +processDescription()
}
interface Shelf {
  -String status
  +int total
  -long email
  #long address
  +validateId()
}
abstract class Member {
  #String note
  +int duration
  -Date score
  +double address
  +long description
  +getUpdatedat()
}
Book ..|> Loan
Member ..> Renewal : "*"
@enduml