@startuml
skinparam monochrome true
class Customer {
  #float status
  -int score
  -Date type
  #float quantity
  +int phone
  +processCode()
}
class Transaction {
  #String name
  +float level
  #double score
  #long phone
  +saveActive()
  +findQuantity()
  +processCreatedat()
  +cancelId()
}
class Deposit {
  -boolean quantity
  +float duration
  +validatePrice()
  +saveCreatedat()
  +getTotal()
}
interface Withdrawal {
  -Date name
  +boolean total
  -double updatedAt
  -float quantity
  +processScore()
  +setScore()
  +calculateScore()
  +processActive()
}
abstract class Account {
  #double price
  +String updatedAt
  -double active
  +processScore()
}
class Teller {
  -boolean level
  #float price
  +setUpdatedat()
  +processPhone()
  +createUpdatedat()
}
abstract class Transfer {
  #Date type
  #float note
  #long score
  +calculateUpdatedat()
  +updateQuantity()
  +calculateCreatedat()
  +findAddress()
}
Transaction --* Customer
Transfer --|> Account
note right of Customer : Banking domain
@enduml