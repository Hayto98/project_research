@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
interface User {
  -double code
  -Date id
  -boolean name
  -long type
  +int email
  +findId()
  +setPhone()
}
class Story {
  #boolean active
  +long updatedAt
  -float description
  +deleteStatus()
}
abstract class Post {
  +boolean address
  +float duration
  #int id
  #String note
  #Date phone
  +setAmount()
}
interface Album {
  #int amount
  +String description
  -Date updatedAt
  +boolean address
  #String level
  +findTotal()
  +createStatus()
}
abstract class Report {
  +String email
  +int amount
  +float quantity
  +sendTotal()
  +validateAddress()
}
Story ..|> Album
Post --* Album
@enduml