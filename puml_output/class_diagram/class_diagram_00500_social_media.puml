@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
interface User {
  -double code
  -Date id
  -boolean name
  -long type
  +int email
  +deleteDuration()
  +validateDescription()
}
interface Story {
  -double description
  #float score
  +Date amount
  +processAddress()
  +validateId()
  +processPhone()
  +getActive()
}
class Post {
  #float score
  #double name
  +float id
  +cancelUpdatedat()
  +validateDescription()
}
class Album {
  #Date code
  +int note
  #double amount
  +findEmail()
  +deleteQuantity()
}
class Report {
  +float id
  +String amount
  +getUpdatedat()
  +findPrice()
  +deleteEmail()
}
Post --|> Story
User ..> Album : "0..1"
Report ..> User : "*"
note right of User : Social Media domain
@enduml