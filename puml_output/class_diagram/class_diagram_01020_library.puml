@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Fine {
  -long email
  #double name
  +float id
  +processId()
  +setStatus()
  +cancelDuration()
  +deleteTotal()
}
class Member {
  -int note
  -long total
  +long status
  #float address
  #String quantity
  +findDescription()
  +getStatus()
  +createLevel()
  +validateCode()
}
interface Librarian {
  +float name
  #int updatedAt
  +int address
  #double score
  +saveNote()
}
class Catalog {
  -boolean description
  -double email
  +processDescription()
  +processAddress()
}
abstract class Branch {
  -float description
  +double type
  +sendCode()
  +processName()
}
abstract class Shelf {
  +int status
  +String email
  +createScore()
  +processActive()
}
abstract class Author {
  #float phone
  +String address
  +int updatedAt
  +findEmail()
  +createLevel()
  +deleteCreatedat()
  +updateAddress()
}
Catalog --o Fine
Shelf --|> Fine
Shelf --|> Catalog
Librarian --> Fine : "*"
Member ..> Fine : "1..*"
Librarian ..|> Author
note right of Fine : Library domain
@enduml