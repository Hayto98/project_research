@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Fine {
  -long email
  #double name
  +float id
  +sendLevel()
  +validateName()
  +cancelTotal()
  +findNote()
}
class Member {
  -float total
  #double amount
  +long price
  +createEmail()
  +validateDuration()
  +sendType()
}
class Librarian {
  #int address
  +String name
  -boolean phone
  -float id
  +Date note
  +setUpdatedat()
  +validateNote()
  +setEmail()
}
class Catalog {
  +int duration
  #double updatedAt
  +findEmail()
}
abstract class Branch {
  -double id
  #double description
  +validateQuantity()
  +sendName()
  +setType()
  +cancelCode()
}
class Shelf {
  -int name
  #Date description
  +double type
  +double note
  +String createdAt
  +createScore()
  +saveNote()
  +processQuantity()
}
class Author {
  #double email
  #Date score
  +long note
  +validateNote()
  +calculateType()
  +saveActive()
}
Fine ..|> Author
Branch --o Shelf
@enduml