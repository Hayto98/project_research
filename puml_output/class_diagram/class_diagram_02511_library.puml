@startuml
skinparam ArrowColor #555555
class Fine {
  #boolean active
  -int note
  +updateTotal()
  +cancelNote()
}
interface Member {
  +float total
  -String score
  #long price
  +createName()
  +updateAddress()
  +deleteCreatedat()
  +processId()
}
interface Catalog {
  +boolean name
  #Date type
  -float createdAt
  +double price
  +processUpdatedat()
  +getScore()
}
interface Renewal {
  -boolean price
  +double createdAt
  +processLevel()
  +deleteEmail()
  +calculateTotal()
  +calculateAmount()
}
class Loan {
  +int updatedAt
  -int level
  #boolean price
  -double status
  +createScore()
  +cancelNote()
  +getActive()
  +deleteAmount()
}
Renewal --> Catalog : "0..1"
Renewal --> Member : "1"
Fine --> Catalog : "1"
note right of Fine : Library domain
@enduml