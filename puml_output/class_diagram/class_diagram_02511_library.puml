@startuml
skinparam ArrowColor #555555
class Fine {
  #boolean active
  -int note
  +processPrice()
  +getPhone()
}
interface Member {
  -String score
  #long amount
  #Date total
  -float price
  -String createdAt
  +validateDuration()
  +saveStatus()
}
class Catalog {
  +double type
  +float id
  -int phone
  +deleteLevel()
  +cancelStatus()
  +deleteActive()
  +updateAddress()
}
class Renewal {
  +double updatedAt
  #String id
  -double score
  -boolean level
  +long price
  +cancelCreatedat()
  +deleteScore()
  +validateStatus()
  +createCreatedat()
}
class Loan {
  +int level
  -int price
  #boolean status
  +calculateTotal()
  +sendScore()
  +updateCode()
}
Renewal ..> Catalog : "*"
Fine ..> Member : "0..1"
Catalog --* Renewal
Loan --o Member
@enduml