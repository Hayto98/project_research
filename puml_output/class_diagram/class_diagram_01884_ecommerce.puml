@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
abstract class Coupon {
  #Date type
  #long name
  #boolean status
  +processLevel()
  +setPrice()
  +calculateAddress()
}
class Shipment {
  #float email
  +String description
  -float note
  +int level
  -int total
  +setEmail()
}
class Order {
  #String name
  -boolean type
  +int quantity
  +long id
  #String note
  +cancelType()
  +sendId()
}
abstract class Wishlist {
  +int active
  #Date code
  +processStatus()
  +processDescription()
}
class Product {
  -String address
  +String type
  -double note
  #long level
  +sendLevel()
  +updateActive()
}
abstract class Payment {
  #Date level
  +boolean code
  -double active
  +deleteAmount()
  +cancelEmail()
}
class Customer {
  #Date phone
  +float code
  -double note
  #boolean duration
  #boolean description
  +calculateType()
  +createPrice()
  +processName()
  +processScore()
}
Shipment ..> Payment : "1"
Wishlist --> Customer : "1"
@enduml