@startuml
skinparam defaultFontSize 11
class Staff {
  +Date address
  #Date price
  +deleteDescription()
  +calculateAmount()
}
class Reservation {
  +Date active
  -double description
  +calculateDuration()
  +getCode()
  +sendQuantity()
}
interface Invoice {
  #Date score
  +boolean description
  +long note
  #float total
  +sendType()
}
class Room {
  +double status
  -float id
  +long total
  +validateLevel()
  +sendCreatedat()
  +validateScore()
  +updateScore()
}
interface CheckOut {
  #boolean email
  #float quantity
  #double note
  -String score
  +findQuantity()
}
interface Housekeeping {
  #long level
  +boolean note
  +float active
  +calculateCode()
}
Reservation ..|> CheckOut
Housekeeping --|> Staff
Staff ..> Housekeeping : "0..1"
CheckOut --> Invoice : "0..1"
Reservation --* Room
@enduml