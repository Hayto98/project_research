@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Package {
  -double phone
  -Date createdAt
  -double active
  #int total
  -String email
  +sendDescription()
  +updateName()
}
class Depot {
  #int amount
  +Date name
  +boolean level
  +processPrice()
}
interface Manifest {
  #float description
  -int score
  #long quantity
  -float code
  +calculateType()
  +cancelCreatedat()
}
class Inventory {
  -double createdAt
  -double total
  #Date name
  +getStatus()
  +findDescription()
  +setLevel()
  +saveActive()
}
Depot --|> Inventory
Inventory ..> Package : "1..*"
note right of Package : Logistics domain
@enduml