@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Package {
  -double phone
  -Date createdAt
  -double active
  #int total
  -String email
  +calculateActive()
  +saveQuantity()
}
class Depot {
  +String email
  #Date createdAt
  +updateId()
}
class Manifest {
  -boolean createdAt
  -Date code
  #int type
  +savePrice()
  +setDescription()
  +sendPrice()
}
abstract class Inventory {
  -double email
  #int price
  +float createdAt
  +processActive()
  +processLevel()
}
Manifest --o Depot
Inventory ..> Manifest : "*"
@enduml