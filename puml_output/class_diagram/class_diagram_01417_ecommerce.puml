@startuml
skinparam defaultFontSize 11
class Payment {
  #boolean amount
  #int note
  -long score
  +calculateEmail()
  +deleteDescription()
  +getUpdatedat()
  +calculateCode()
}
class Shipment {
  #double createdAt
  -Date code
  -double name
  +saveId()
  +createUpdatedat()
  +validateCreatedat()
  +updateLevel()
}
class Category {
  #long active
  -String name
  +long code
  -boolean score
  +validateDuration()
}
class Customer {
  +Date amount
  -int phone
  +createPrice()
  +cancelStatus()
  +createDescription()
}
Payment --* Shipment
Category --o Customer
Category --|> Payment
note right of Payment : Ecommerce domain
@enduml