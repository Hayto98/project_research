@startuml
skinparam defaultFontSize 11
class Payment {
  #boolean amount
  #int note
  -long score
  +setNote()
  +calculateScore()
  +validateQuantity()
  +findPhone()
}
class Shipment {
  #boolean price
  +int code
  +String address
  +sendName()
  +deleteStatus()
  +processAddress()
  +findCode()
}
abstract class Category {
  +float id
  #String quantity
  -boolean updatedAt
  #String phone
  +float createdAt
  +setCreatedat()
}
class Customer {
  -boolean id
  +float amount
  +int email
  -int note
  #long status
  +createUpdatedat()
  +deleteCode()
}
Customer --|> Category
Category ..|> Customer
Category --* Payment
@enduml