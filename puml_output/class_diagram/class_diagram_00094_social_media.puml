@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Post {
  +int id
  +String phone
  -String note
  #String price
  +cancelUpdatedat()
  +setCode()
  +saveLevel()
  +updateCreatedat()
}
interface Hashtag {
  -double address
  +long active
  -float email
  +sendCreatedat()
}
class Message {
  #Date type
  #double email
  #boolean duration
  +float phone
  +cancelType()
}
abstract class Group {
  #Date address
  #int description
  -boolean status
  +boolean level
  #boolean id
  +findStatus()
  +saveLevel()
  +calculateCreatedat()
}
class Like {
  +long status
  -boolean duration
  -Date name
  +Date id
  #long description
  +setPhone()
}
Post --o Hashtag
Like --|> Post
Like --> Group : "*"
@enduml