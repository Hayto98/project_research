@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Post {
  +int id
  +String phone
  -String note
  #String price
  +findScore()
  +deleteAddress()
  +sendEmail()
  +validateNote()
}
class Hashtag {
  -Date address
  -long code
  -long type
  #Date amount
  +sendScore()
  +deleteLevel()
  +sendName()
  +processTotal()
}
class Message {
  #String level
  #Date status
  #int description
  +sendStatus()
  +sendDuration()
  +sendAddress()
}
class Group {
  +String total
  +int status
  -long level
  +saveCreatedat()
  +saveEmail()
  +getDuration()
  +validateCode()
}
class Like {
  #Date duration
  -float id
  +float status
  +int active
  -Date total
  +cancelQuantity()
  +processScore()
  +savePrice()
  +cancelCreatedat()
}
Group --* Post
Post ..> Group : "1"
note right of Post : Social Media domain
@enduml