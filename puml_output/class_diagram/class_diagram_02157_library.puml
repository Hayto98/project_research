@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
interface Author {
  +String total
  +long amount
  #float score
  -long updatedAt
  +int price
  +calculateScore()
  +getScore()
  +createDuration()
}
abstract class Book {
  #String status
  +long description
  -Date score
  +setAmount()
  +saveNote()
  +processCreatedat()
  +deleteCode()
}
class Librarian {
  +long id
  #int name
  +Date score
  -int status
  -double note
  +getTotal()
  +createScore()
}
class Shelf {
  #float createdAt
  -String type
  +deleteAmount()
}
class Catalog {
  #double address
  +float type
  -Date updatedAt
  +processId()
}
Book ..> Librarian : "1..*"
Catalog --> Book : "1"
Author --* Book
@enduml