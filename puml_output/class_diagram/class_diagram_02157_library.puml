@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
interface Author {
  +String total
  +long amount
  #float score
  -long updatedAt
  +int price
  +createActive()
  +calculatePrice()
  +sendDuration()
}
class Book {
  #Date duration
  #boolean description
  +setAddress()
}
abstract class Librarian {
  +Date createdAt
  #float phone
  #String address
  #boolean note
  -String id
  +saveCreatedat()
  +setNote()
  +updateType()
}
abstract class Shelf {
  +float createdAt
  +double updatedAt
  #float duration
  +getCode()
  +calculateCreatedat()
  +findAmount()
}
class Catalog {
  #double updatedAt
  +long price
  #long createdAt
  #Date phone
  +boolean code
  +getCreatedat()
}
Librarian ..|> Catalog
Catalog --o Shelf
Author --> Shelf : "*"
note right of Author : Library domain
@enduml