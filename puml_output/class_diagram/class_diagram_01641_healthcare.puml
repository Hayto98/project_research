@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
abstract class LabTest {
  +Date name
  -String status
  +int amount
  +processEmail()
  +cancelQuantity()
  +setCreatedat()
}
class Treatment {
  -long active
  -double total
  #int phone
  -float status
  #boolean createdAt
  +createPhone()
  +setAddress()
  +deletePrice()
  +saveTotal()
}
class Billing {
  +int email
  +boolean total
  +deleteDescription()
  +getTotal()
  +setPhone()
  +cancelEmail()
}
class Patient {
  #double phone
  -String active
  #long address
  +double description
  +long name
  +findTotal()
  +findCode()
  +getEmail()
}
class Insurance {
  #boolean note
  #int amount
  -Date id
  +String name
  +findActive()
  +cancelTotal()
  +updateTotal()
}
abstract class Doctor {
  #boolean level
  +float note
  #Date createdAt
  +String amount
  +cancelCode()
  +validateAddress()
}
class Ward {
  -double type
  #float price
  #int code
  +Date duration
  +sendEmail()
  +findCreatedat()
}
Billing ..|> Ward
Ward --|> Treatment
Treatment --> Billing : "*"
@enduml