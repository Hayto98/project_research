@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
abstract class LabTest {
  +Date name
  -String status
  +int amount
  +cancelNote()
  +findPhone()
  +calculateActive()
}
abstract class Treatment {
  -double status
  #int createdAt
  -float note
  #boolean quantity
  +setScore()
  +processAmount()
  +setEmail()
  +saveTotal()
}
class Billing {
  #int status
  #String score
  +float type
  +validateActive()
  +saveAddress()
  +deleteName()
  +findPrice()
}
class Patient {
  -int address
  -long status
  +deleteUpdatedat()
  +createNote()
  +findAmount()
}
class Insurance {
  #int duration
  -Date level
  +getQuantity()
}
abstract class Doctor {
  #long phone
  #boolean total
  +saveCreatedat()
  +deleteDuration()
  +getDuration()
  +findAmount()
}
class Ward {
  #long type
  -Date email
  -Date name
  +cancelScore()
}
Patient --> Ward : "0..1"
Ward ..> LabTest : "0..1"
Treatment ..|> Billing
Billing ..|> Ward
Ward --|> Treatment
note right of LabTest : Healthcare domain
@enduml