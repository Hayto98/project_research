@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Housekeeping {
  -float address
  +double score
  +getAmount()
  +cancelAddress()
  +setDuration()
}
class Room {
  +String address
  -long score
  -Date type
  +int name
  +calculateAddress()
}
abstract class Amenity {
  +String total
  -boolean active
  +boolean description
  -String name
  +saveUpdatedat()
}
abstract class Booking {
  -long score
  #float duration
  +String phone
  +validatePhone()
  +processCreatedat()
  +getPhone()
  +calculateCode()
}
Amenity ..|> Housekeeping
Housekeeping --* Amenity
note right of Housekeeping : Hotel domain
@enduml