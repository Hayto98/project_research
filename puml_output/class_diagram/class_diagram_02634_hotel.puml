@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Housekeeping {
  -float address
  +double score
  +updateQuantity()
  +calculateId()
  +saveAddress()
}
interface Room {
  #boolean code
  -String duration
  +String phone
  -long address
  +cancelDuration()
  +sendTotal()
  +validateNote()
  +getLevel()
}
abstract class Amenity {
  #float total
  +float quantity
  +String duration
  +long active
  +sendQuantity()
  +deletePhone()
}
abstract class Booking {
  -boolean code
  +boolean updatedAt
  +createDuration()
  +processStatus()
  +validatePrice()
}
Housekeeping --* Room
Amenity ..|> Room
@enduml