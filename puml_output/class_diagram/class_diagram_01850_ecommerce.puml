@startuml
skinparam monochrome true
interface Review {
  +double id
  -long amount
  #boolean createdAt
  +cancelQuantity()
  +deleteStatus()
  +calculateActive()
  +createDescription()
}
interface Payment {
  #Date name
  -Date duration
  -long description
  +calculateAddress()
  +sendStatus()
}
class Category {
  -long duration
  +double note
  -float type
  -long active
  +sendName()
}
class Shipment {
  -float phone
  #int id
  +cancelType()
  +getName()
  +cancelQuantity()
  +processAddress()
}
abstract class Coupon {
  +double email
  #double address
  +setCreatedat()
  +cancelCreatedat()
  +saveTotal()
  +createPrice()
}
interface Customer {
  +double updatedAt
  #long createdAt
  -float phone
  #String price
  +calculatePrice()
  +processScore()
}
class Invoice {
  -Date status
  #int type
  +findLevel()
}
Customer --o Payment
Category --> Payment : "*"
Category --o Customer
Coupon ..|> Shipment
Payment ..> Shipment : "1..*"
@enduml