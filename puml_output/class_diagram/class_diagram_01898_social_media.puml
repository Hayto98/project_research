@startuml
skinparam ArrowColor #555555
abstract class Hashtag {
  #boolean type
  +String price
  -float email
  #int updatedAt
  +int active
  +deleteAddress()
  +processLevel()
  +getEmail()
}
interface Story {
  -float quantity
  #boolean type
  +boolean description
  +cancelTotal()
}
class Profile {
  +Date duration
  +double note
  +getPhone()
}
interface Like {
  -boolean quantity
  #int note
  -String createdAt
  +saveLevel()
  +setId()
  +sendDescription()
}
Hashtag --|> Story
Like ..> Profile : "1..*"
Profile ..|> Story
note right of Hashtag : Social Media domain
@enduml