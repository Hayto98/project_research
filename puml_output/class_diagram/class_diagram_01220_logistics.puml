@startuml
skinparam monochrome true
class DeliveryNote {
  #int amount
  #boolean total
  +float address
  +createPhone()
}
class Inventory {
  -String status
  #int quantity
  +sendActive()
  +validateCreatedat()
  +validateId()
}
class Driver {
  #float code
  -double active
  -boolean id
  #float level
  +calculateDuration()
  +calculatePhone()
  +saveUpdatedat()
}
abstract class Vehicle {
  +String duration
  #float score
  -boolean price
  +long phone
  #float name
  +updateCreatedat()
}
class Tracking {
  #Date score
  #int total
  +createEmail()
  +processEmail()
  +saveName()
  +updateId()
}
class Customer {
  +long total
  +float phone
  -boolean amount
  +long active
  #Date updatedAt
  +calculateCode()
  +createStatus()
  +findTotal()
}
Driver --o Inventory
Customer --o Tracking
Tracking ..> Customer : "*"
Vehicle --* Inventory
@enduml