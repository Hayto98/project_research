@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Exam {
  #int quantity
  #int price
  +boolean email
  #long id
  +deleteType()
  +deleteScore()
  +cancelCreatedat()
  +updateQuantity()
}
class Classroom {
  #float phone
  #long status
  +double description
  #boolean createdAt
  +float address
  +sendDuration()
}
class Attendance {
  #float price
  -double phone
  #float email
  #double score
  +findLevel()
  +findDuration()
  +sendAmount()
}
class Enrollment {
  #boolean phone
  -long note
  -String quantity
  +createPrice()
  +cancelAddress()
}
abstract class Student {
  #int createdAt
  +int quantity
  -int type
  #boolean status
  +updateUpdatedat()
  +calculateActive()
  +processPhone()
  +calculateScore()
}
Student ..|> Classroom
Exam ..|> Student
note right of Exam : Education domain
@enduml