@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Exam {
  #int quantity
  #int price
  +boolean email
  #long id
  +updateType()
  +validateUpdatedat()
  +findId()
  +createNote()
}
interface Classroom {
  -long createdAt
  +int quantity
  +boolean phone
  +saveActive()
  +deleteLevel()
  +sendType()
}
interface Attendance {
  #Date status
  +boolean note
  #long score
  #long duration
  +deleteCode()
  +sendAddress()
  +deleteName()
  +savePrice()
}
class Enrollment {
  #int note
  #long email
  -long score
  #boolean amount
  -long status
  +validatePhone()
  +updateType()
  +deleteCreatedat()
  +createTotal()
}
abstract class Student {
  -float price
  #float phone
  +boolean createdAt
  +String quantity
  +findCode()
  +getTotal()
}
Student ..|> Enrollment
Classroom ..> Enrollment : "*"
Attendance --> Enrollment : "0..1"
Student ..|> Classroom
@enduml