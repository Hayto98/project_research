@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
interface Payment {
  -Date description
  #Date id
  -Date createdAt
  -int updatedAt
  +savePrice()
  +deleteDuration()
}
interface Booking {
  -Date code
  #int id
  -double total
  +float description
  #boolean name
  +validatePhone()
}
abstract class Reservation {
  #int code
  +long description
  -String id
  +boolean active
  -long note
  +findDescription()
  +findCreatedat()
}
abstract class Guest {
  +long code
  -boolean active
  +validateTotal()
  +updateDescription()
  +calculateQuantity()
}
class Service {
  +float active
  +float phone
  +String createdAt
  #Date price
  +saveAddress()
}
abstract class CheckIn {
  -float address
  #double level
  +calculateId()
  +createTotal()
  +validateLevel()
  +sendStatus()
}
interface Amenity {
  +Date id
  #int quantity
  +double description
  +Date status
  +long amount
  +processNote()
  +deleteScore()
}
Payment ..> Booking : "0..1"
Guest --* CheckIn
CheckIn ..|> Payment
@enduml