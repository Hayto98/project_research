@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
interface Diagnosis {
  -int score
  #double description
  -long phone
  +String active
  +validateActive()
}
class Prescription {
  #boolean id
  -float updatedAt
  -Date level
  -String quantity
  +findId()
  +calculateName()
}
class Insurance {
  +boolean quantity
  #String active
  -float total
  +getAmount()
  +calculateLevel()
  +createTotal()
  +calculateAddress()
}
interface Doctor {
  -boolean name
  #boolean total
  #double score
  +double note
  -long description
  +getPrice()
  +cancelPrice()
}
Insurance --|> Doctor
Prescription --|> Diagnosis
Insurance ..> Prescription : "*"
@enduml