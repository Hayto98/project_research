@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Customer {
  #double email
  #String status
  +validateUpdatedat()
  +sendDescription()
}
abstract class Order {
  #boolean quantity
  -Date score
  #boolean status
  +setUpdatedat()
  +saveQuantity()
  +sendActive()
}
class Review {
  -boolean score
  #String phone
  +String total
  #float name
  +sendCode()
  +processType()
  +calculateId()
}
class Supplier {
  +double address
  -boolean id
  #float active
  #float description
  -String amount
  +getAmount()
  +getPrice()
  +processId()
}
Review --* Customer
Supplier --|> Customer
Customer --> Order : "1"
@enduml