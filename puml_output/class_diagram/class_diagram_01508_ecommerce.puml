@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Customer {
  #double email
  #String status
  +processPrice()
  +deleteQuantity()
}
interface Order {
  -Date level
  #boolean score
  +getDescription()
  +cancelAmount()
  +createScore()
}
class Review {
  #float name
  #float note
  -double status
  -String id
  +Date duration
  +validateId()
  +sendDescription()
  +deleteAmount()
  +calculatePhone()
}
interface Supplier {
  -double status
  +String phone
  +float total
  -boolean quantity
  +int description
  +deleteName()
  +validateDescription()
}
Supplier ..> Customer : "1..*"
Customer --o Supplier
Order --* Customer
note right of Customer : Ecommerce domain
@enduml