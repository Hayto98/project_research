@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
abstract class Follower {
  +boolean updatedAt
  -boolean type
  +boolean description
  +processLevel()
}
interface Story {
  #Date price
  +String score
  #boolean amount
  -String createdAt
  +findPrice()
  +validateType()
  +sendCode()
}
class Like {
  -Date createdAt
  +int score
  #String name
  +boolean price
  -String active
  +validateTotal()
}
class Comment {
  #long score
  #long name
  #long code
  #double address
  +deletePhone()
}
class Notification {
  #boolean status
  -double phone
  +updateLevel()
  +saveAddress()
}
class Album {
  +boolean active
  #String phone
  +float amount
  +saveLevel()
}
class Message {
  -float duration
  #float price
  -float phone
  +double description
  +updateAddress()
  +processNote()
  +calculatePhone()
  +cancelPrice()
}
Message --o Album
Comment --o Album
Follower ..> Like : "*"
note right of Follower : Social Media domain
@enduml