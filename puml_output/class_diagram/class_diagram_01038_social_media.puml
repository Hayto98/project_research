@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
abstract class Follower {
  +boolean updatedAt
  -boolean type
  +boolean description
  +calculateType()
}
abstract class Story {
  #Date price
  +String score
  #boolean amount
  -String createdAt
  +updateId()
  +createTotal()
  +processType()
}
class Like {
  #String score
  -Date code
  #float phone
  -long type
  #String createdAt
  +findStatus()
  +updateActive()
}
class Comment {
  #long code
  #boolean duration
  #String phone
  +long total
  #long name
  +createType()
  +processDescription()
  +sendQuantity()
}
abstract class Notification {
  -String description
  +long phone
  +saveName()
  +getTotal()
  +processPrice()
  +getCode()
}
class Album {
  +String active
  #Date createdAt
  +String duration
  #String phone
  +createTotal()
  +createDescription()
  +processStatus()
}
interface Message {
  -Date phone
  -int description
  -double email
  -double address
  -boolean createdAt
  +cancelNote()
  +processAddress()
  +updateAddress()
  +cancelCreatedat()
}
Message --o Album
Follower ..> Like : "*"
Follower ..|> Album
Story --> Like : "1..*"
Notification --> Story : "1"
@enduml