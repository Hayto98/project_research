@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Notification {
  #Date level
  #boolean quantity
  +double address
  #boolean total
  -double updatedAt
  +getStatus()
}
class Report {
  +int price
  -double code
  +double address
  +updateCreatedat()
  +processActive()
  +calculateCode()
  +createName()
}
class Story {
  #int price
  #long level
  #String amount
  +validateAddress()
  +cancelId()
  +cancelCreatedat()
}
abstract class Group {
  #int email
  -int level
  +calculateDuration()
  +deleteQuantity()
  +cancelActive()
}
class Post {
  +long score
  -float status
  -long address
  -long type
  +processNote()
  +validatePhone()
  +setTotal()
  +processName()
}
Notification ..|> Report
Post ..|> Group
Report --|> Story
Story ..|> Group
note right of Notification : Social Media domain
@enduml