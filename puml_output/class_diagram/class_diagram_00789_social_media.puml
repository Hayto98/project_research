@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Notification {
  #Date level
  #boolean quantity
  +double address
  #boolean total
  -double updatedAt
  +processQuantity()
}
class Report {
  +long amount
  +int price
  +createDuration()
  +updateType()
  +saveName()
}
abstract class Story {
  -Date createdAt
  +long type
  +float active
  +createCode()
  +createId()
}
abstract class Group {
  #String amount
  #boolean active
  -long quantity
  +getQuantity()
  +updateActive()
  +processId()
}
class Post {
  +long name
  -float email
  #int active
  -boolean updatedAt
  #Date note
  +saveCreatedat()
  +calculatePrice()
}
Notification ..> Story : "*"
Story --* Post
@enduml