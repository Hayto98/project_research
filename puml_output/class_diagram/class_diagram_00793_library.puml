@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
interface Renewal {
  #float code
  #int total
  -Date duration
  +deleteName()
  +deleteDescription()
}
class Reservation {
  -int email
  #int name
  -int note
  -boolean createdAt
  +saveScore()
}
abstract class Member {
  +long email
  -double type
  +Date name
  +cancelUpdatedat()
  +cancelTotal()
}
interface Publisher {
  -long level
  #boolean phone
  +long status
  +createAddress()
  +sendAmount()
}
class Catalog {
  -int note
  #String code
  #Date email
  #double score
  +saveActive()
}
Reservation --|> Member
Catalog --o Publisher
note right of Renewal : Library domain
@enduml