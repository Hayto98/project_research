@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
interface Renewal {
  #float code
  #int total
  -Date duration
  +deleteScore()
  +deleteNote()
}
class Reservation {
  +double description
  +float address
  -int email
  +createQuantity()
  +calculateAddress()
}
class Member {
  +long score
  -String total
  +sendPhone()
}
class Publisher {
  #long name
  +long createdAt
  -boolean updatedAt
  #String total
  -Date amount
  +deleteCreatedat()
  +saveCreatedat()
}
interface Catalog {
  #String email
  #long duration
  #boolean note
  +processScore()
  +processLevel()
  +validateNote()
}
Renewal --> Publisher : "1"
Catalog ..> Reservation : "0..1"
Member --> Renewal : "*"
Publisher ..> Member : "1..*"
@enduml