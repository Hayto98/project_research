@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
interface Tracking {
  #boolean duration
  +float address
  -double description
  +setNote()
  +findDescription()
}
class DeliveryNote {
  #int address
  +int quantity
  +calculateName()
}
interface Manifest {
  +String note
  +double amount
  -String createdAt
  +validateAmount()
  +updateNote()
  +calculateType()
}
abstract class Warehouse {
  -int updatedAt
  -int description
  -boolean quantity
  #double score
  +createDuration()
  +setDuration()
}
Manifest --* Warehouse
Manifest --|> DeliveryNote
@enduml