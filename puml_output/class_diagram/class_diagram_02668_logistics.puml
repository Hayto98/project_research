@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
interface Tracking {
  #boolean duration
  +float address
  -double description
  +calculateDuration()
  +getStatus()
}
class DeliveryNote {
  -boolean description
  #int id
  -Date createdAt
  +int name
  +getId()
  +calculateEmail()
}
class Manifest {
  +int email
  -float active
  -long price
  +long duration
  +calculateActive()
  +cancelTotal()
}
class Warehouse {
  +String updatedAt
  +int phone
  #long level
  -int score
  +String address
  +processAmount()
  +sendLevel()
}
DeliveryNote --> Manifest : "0..1"
Tracking --> DeliveryNote : "*"
note right of Tracking : Logistics domain
@enduml