@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
class Tracking {
  -Date id
  -String name
  -String quantity
  +float address
  +setTotal()
  +deleteAmount()
  +createAmount()
  +sendActive()
}
interface Shipment {
  #double status
  -float type
  #float active
  -float quantity
  #float price
  +validateEmail()
  +cancelType()
  +calculateNote()
  +calculateActive()
}
class FuelLog {
  +double price
  +double email
  -String address
  +setAmount()
}
class Inventory {
  +String id
  #int total
  #long phone
  -String updatedAt
  +String createdAt
  +setUpdatedat()
}
abstract class Manifest {
  #double level
  +long createdAt
  -float id
  +getType()
}
Manifest ..|> Shipment
Inventory --* FuelLog
FuelLog --o Shipment
Manifest --> FuelLog : "1..*"
@enduml