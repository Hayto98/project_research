@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Shelf {
  +float code
  +double id
  #boolean status
  #float name
  +processPhone()
  +deleteTotal()
}
class Loan {
  +String level
  #double name
  +int duration
  +float updatedAt
  +updateName()
}
abstract class Publisher {
  -int note
  #int status
  -Date level
  +validateAddress()
}
abstract class Branch {
  -float price
  +int duration
  #int address
  +String active
  +validateDescription()
  +getCode()
  +validateDuration()
  +saveEmail()
}
class Renewal {
  +int createdAt
  +float level
  +calculatePrice()
  +calculateAmount()
  +sendQuantity()
}
Shelf --|> Branch
Publisher --o Renewal
Loan --* Shelf
Renewal --o Loan
@enduml