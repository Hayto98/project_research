@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Shelf {
  +float code
  +double id
  #boolean status
  #float name
  +updatePhone()
  +cancelName()
}
class Loan {
  +int amount
  +float id
  +String note
  +updateNote()
  +findDuration()
  +setDuration()
  +setPhone()
}
class Publisher {
  -long email
  -float id
  #double duration
  +sendType()
  +getUpdatedat()
  +saveAmount()
}
class Branch {
  #long score
  +long note
  +updateLevel()
}
class Renewal {
  #double updatedAt
  #Date active
  +double phone
  +createAddress()
}
Loan --* Shelf
Renewal --o Loan
Shelf --* Renewal
note right of Shelf : Library domain
@enduml