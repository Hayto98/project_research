@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Library {
  +float note
  +Date id
  -boolean amount
  +processScore()
  +sendStatus()
  +updateCode()
  +findEmail()
}
class Classroom {
  #float score
  -String total
  #boolean duration
  +deleteCreatedat()
  +setAmount()
}
class Attendance {
  #float type
  -int description
  +long code
  +validateEmail()
  +setStatus()
  +setCode()
}
class Enrollment {
  +boolean score
  +String total
  -long id
  #double name
  #int active
  +findPrice()
  +updatePrice()
  +cancelStatus()
}
class Assignment {
  +String score
  +String quantity
  -float status
  -float email
  +Date name
  +calculateAddress()
  +saveEmail()
}
class Grade {
  +long description
  +double price
  +createCode()
  +updatePhone()
  +saveActive()
  +validateAddress()
}
interface Student {
  +boolean total
  -long level
  +Date amount
  +calculatePrice()
  +getNote()
  +getDescription()
}
Assignment --o Classroom
Library --> Student : "1..*"
Library --> Grade : "1"
Student ..|> Attendance
Library --* Assignment
@enduml