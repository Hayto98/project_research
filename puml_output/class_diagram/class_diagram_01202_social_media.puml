@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Hashtag {
  #long quantity
  +float note
  -boolean duration
  +processCode()
}
interface Like {
  +int total
  +float active
  -double status
  #String address
  +calculateActive()
  +createId()
}
class Album {
  #double updatedAt
  #int address
  +updateLevel()
}
class Comment {
  #boolean quantity
  +float updatedAt
  +setPrice()
  +createDescription()
  +cancelStatus()
  +getAddress()
}
class Group {
  +String total
  +double price
  +calculateQuantity()
}
class Profile {
  -Date description
  -float id
  +findUpdatedat()
  +deleteStatus()
}
interface Notification {
  -Date price
  -double description
  -double level
  -float code
  +sendEmail()
}
Like ..|> Notification
Hashtag --* Comment
@enduml