@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Hashtag {
  #long quantity
  +float note
  -boolean duration
  +getLevel()
}
class Like {
  +float active
  -double status
  #String address
  +boolean id
  -boolean createdAt
  +updateAddress()
}
interface Album {
  +float amount
  -Date active
  #boolean name
  +boolean quantity
  #String address
  +sendCode()
  +calculateAddress()
  +getTotal()
  +calculateDescription()
}
class Comment {
  -Date price
  +float level
  +int status
  +processEmail()
}
interface Group {
  +float duration
  +String email
  -Date price
  +calculateEmail()
  +processQuantity()
  +setCreatedat()
  +setCreatedat()
}
class Profile {
  -Date id
  -long type
  -Date quantity
  +getUpdatedat()
  +updatePhone()
  +saveLevel()
  +calculateAddress()
}
interface Notification {
  +int duration
  +Date note
  +sendUpdatedat()
  +cancelName()
}
Hashtag --o Album
Notification --o Like
Group ..|> Hashtag
note right of Hashtag : Social Media domain
@enduml