@startuml
skinparam monochrome true
skinparam defaultFontSize 11
interface Album {
  +Date quantity
  -long name
  +cancelDuration()
  +createAddress()
  +calculateDescription()
  +processNote()
}
interface Follower {
  #float active
  +Date type
  #int createdAt
  #float score
  +validateNote()
  +savePhone()
  +calculateQuantity()
}
class Profile {
  +long name
  -double price
  #float type
  #double status
  #boolean phone
  +sendName()
  +getCreatedat()
  +validatePhone()
}
class Like {
  +String code
  +double score
  #Date createdAt
  +createLevel()
  +setPhone()
  +cancelCreatedat()
}
interface Post {
  +long email
  -double id
  +double quantity
  -long note
  #boolean status
  +sendAddress()
  +setTotal()
}
class Report {
  #String name
  #float price
  +String active
  +updateAmount()
  +deleteScore()
}
class User {
  +Date active
  +Date email
  +float code
  -float address
  +calculateAmount()
  +saveUpdatedat()
}
Follower --* Album
User ..> Album : "1"
Report ..> Like : "1..*"
note right of Album : Social Media domain
@enduml