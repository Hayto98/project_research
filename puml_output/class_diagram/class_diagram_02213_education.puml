@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
interface Book {
  +long total
  -int id
  +setTotal()
  +saveUpdatedat()
  +deleteTotal()
}
class Grade {
  #float status
  #float duration
  -float phone
  -int score
  +String amount
  +sendTotal()
  +findCreatedat()
  +findScore()
}
class Department {
  #long level
  +Date phone
  +setPrice()
  +createPrice()
  +calculateTotal()
  +cancelPrice()
}
class Exam {
  -Date quantity
  -boolean level
  #double note
  #int total
  +updateDuration()
  +updateCode()
  +validateType()
}
class Student {
  +Date createdAt
  +String description
  +long code
  #long active
  +long type
  +sendName()
  +calculateTotal()
  +processPrice()
  +validateScore()
}
interface Teacher {
  +Date code
  -long phone
  +double address
  #long note
  +getStatus()
  +saveAmount()
  +findActive()
}
class Assignment {
  #long address
  #int name
  +Date email
  +int createdAt
  +calculateUpdatedat()
}
Student --|> Exam
Exam --> Student : "*"
Assignment --o Exam
Grade --|> Department
Exam ..> Teacher : "1"
Department --|> Exam
@enduml