@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
interface Book {
  +long total
  -int id
  +createEmail()
  +processStatus()
  +setPhone()
}
class Grade {
  +String level
  +long price
  +long email
  +createStatus()
  +cancelPhone()
  +cancelAddress()
}
class Department {
  #Date price
  -double phone
  -Date score
  -boolean quantity
  #double active
  +cancelQuantity()
  +getCode()
}
abstract class Exam {
  -String description
  #int code
  +String active
  +sendAddress()
  +updateQuantity()
  +sendDuration()
}
abstract class Student {
  -long updatedAt
  -int address
  #float active
  -long phone
  +double code
  +savePhone()
  +processType()
  +savePhone()
}
class Teacher {
  #long duration
  #int name
  +Date email
  +int createdAt
  +saveActive()
}
interface Assignment {
  -int id
  -String price
  -Date score
  #String note
  -double active
  +getPrice()
}
Exam --> Department : "*"
Teacher ..|> Student
Department ..> Teacher : "0..1"
note right of Book : Education domain
@enduml