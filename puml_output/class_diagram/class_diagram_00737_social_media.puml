@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Message {
  #boolean price
  +float phone
  -float quantity
  +findId()
}
abstract class Group {
  -float createdAt
  -Date active
  +long level
  #long score
  +processName()
  +sendName()
  +updateLevel()
  +processStatus()
}
class User {
  #boolean address
  #boolean level
  +createId()
  +processUpdatedat()
}
interface Follower {
  -int phone
  +Date price
  +int duration
  +int note
  -boolean type
  +deleteName()
  +processName()
  +validatePhone()
}
class Post {
  #String status
  +int quantity
  +Date updatedAt
  #float createdAt
  -long level
  +createCode()
  +saveEmail()
}
class Profile {
  -boolean type
  #double level
  +boolean email
  -boolean updatedAt
  -double description
  +setName()
  +findCode()
  +getPrice()
  +createDescription()
}
Post --o Follower
Profile ..> Group : "1"
User --> Profile : "1..*"
@enduml