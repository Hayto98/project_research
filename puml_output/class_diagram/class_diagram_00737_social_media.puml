@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
class Message {
  #boolean price
  +float phone
  -float quantity
  +deletePrice()
}
class Group {
  #double active
  -Date duration
  +long score
  +saveNote()
  +getType()
  +createPhone()
}
class User {
  #boolean address
  #boolean level
  +deleteScore()
  +calculatePhone()
}
abstract class Follower {
  +Date note
  +int type
  +int quantity
  -boolean updatedAt
  +createId()
  +setStatus()
  +calculateStatus()
}
class Post {
  +int createdAt
  +Date quantity
  #float status
  +validateCreatedat()
  +deleteName()
  +saveCode()
}
abstract class Profile {
  #boolean level
  -float email
  +boolean updatedAt
  -boolean description
  -double address
  +getPhone()
  +sendCreatedat()
  +cancelPrice()
  +calculateDescription()
}
User --> Profile : "1..*"
Group --o User
note right of Message : Social Media domain
@enduml