@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
interface Schedule {
  -boolean id
  #float address
  +int updatedAt
  #float phone
  +createDuration()
  +cancelPhone()
}
class Exam {
  #float active
  #int type
  -int level
  +float name
  +cancelNote()
  +calculateLevel()
  +updateName()
  +sendActive()
}
class Book {
  -String level
  #double duration
  -String description
  +calculateAmount()
  +findPhone()
  +findType()
}
abstract class Attendance {
  #Date score
  -String type
  -float price
  +Date address
  +int amount
  +processNote()
  +cancelDescription()
  +findAddress()
  +cancelPrice()
}
interface Grade {
  #boolean score
  #long amount
  #boolean phone
  +String name
  #int total
  +cancelCreatedat()
  +calculateActive()
  +sendActive()
}
class Enrollment {
  -double score
  +Date updatedAt
  -long note
  +float type
  +cancelEmail()
  +getPrice()
}
interface Student {
  +int code
  -float name
  -double description
  +setAddress()
  +setDuration()
  +findAddress()
}
Attendance --o Book
Exam --> Book : "1..*"
@enduml