@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
interface Schedule {
  -boolean id
  #float address
  +int updatedAt
  #float phone
  +calculateEmail()
  +updateQuantity()
}
interface Exam {
  +float type
  #Date name
  -int updatedAt
  +boolean quantity
  +int description
  +validateCode()
  +findPrice()
}
class Book {
  +float address
  -boolean note
  +sendType()
  +calculateAddress()
  +deleteScore()
  +saveQuantity()
}
class Attendance {
  #Date id
  +Date amount
  #float level
  #double note
  +cancelPhone()
  +getTotal()
}
interface Grade {
  #int duration
  -double score
  #boolean amount
  +long id
  +cancelDuration()
  +processType()
}
abstract class Enrollment {
  +float name
  #int price
  +float quantity
  +int duration
  +int createdAt
  +validateTotal()
  +createScore()
  +updateName()
}
abstract class Student {
  #boolean price
  +long createdAt
  #Date email
  #long quantity
  +createTotal()
  +setId()
  +setEmail()
}
Book ..> Exam : "*"
Grade ..> Exam : "*"
note right of Schedule : Education domain
@enduml