@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Amenity {
  -double duration
  #int total
  +double type
  -long updatedAt
  #float status
  +deleteQuantity()
  +validateStatus()
  +createDuration()
}
class Invoice {
  -boolean status
  +long updatedAt
  +validateAmount()
  +createId()
}
class Booking {
  #double score
  #double status
  #int type
  +float code
  #double id
  +updateName()
  +saveActive()
  +cancelQuantity()
  +createScore()
}
class Guest {
  #Date updatedAt
  #int level
  -long price
  -boolean code
  +boolean status
  +getQuantity()
  +setId()
}
Invoice --* Guest
Invoice --|> Amenity
note right of Amenity : Hotel domain
@enduml