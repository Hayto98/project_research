@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
class Amenity {
  -double duration
  #int total
  +double type
  -long updatedAt
  #float status
  +validateQuantity()
  +getAmount()
  +setCode()
}
class Invoice {
  #float status
  #String quantity
  +double createdAt
  #String code
  +cancelLevel()
  +updateNote()
  +findDescription()
}
class Booking {
  #Date amount
  #double quantity
  #float id
  +double duration
  +updateId()
}
interface Guest {
  #double level
  #int type
  +saveStatus()
  +calculateDuration()
}
Guest --|> Amenity
Booking --> Invoice : "0..1"
@enduml