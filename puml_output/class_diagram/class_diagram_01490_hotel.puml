@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
abstract class Housekeeping {
  +long type
  #float email
  #Date duration
  -int quantity
  -boolean status
  +setName()
  +processAmount()
  +setQuantity()
}
class Payment {
  #float score
  +int createdAt
  -boolean type
  +long id
  -Date address
  +saveNote()
  +calculateActive()
}
class Reservation {
  -String score
  -int createdAt
  #boolean updatedAt
  #boolean duration
  -boolean phone
  +updateStatus()
}
interface Booking {
  -float email
  -double total
  -long description
  +calculateId()
  +deleteLevel()
  +findLevel()
}
interface Restaurant {
  +int phone
  #String note
  #boolean name
  -float type
  #long description
  +calculateEmail()
  +getCode()
}
Booking ..> Reservation : "0..1"
Payment --o Reservation
@enduml