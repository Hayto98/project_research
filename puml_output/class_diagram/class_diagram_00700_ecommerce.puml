@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Customer {
  +String active
  +Date score
  +sendDescription()
  +getUpdatedat()
}
interface Warehouse {
  +int address
  +String description
  +savePrice()
  +calculateCode()
  +findPhone()
}
class Wishlist {
  -float score
  +long id
  +updateLevel()
  +updateNote()
  +sendQuantity()
}
interface Return {
  +float price
  +long address
  +calculateAmount()
}
abstract class Order {
  #float level
  -boolean note
  -String name
  +calculateScore()
}
class Supplier {
  +double score
  +double note
  #long price
  -long active
  +getStatus()
  +processPrice()
  +updateQuantity()
  +sendEmail()
}
class Coupon {
  -float description
  +String updatedAt
  #Date score
  -boolean quantity
  +processType()
  +updateScore()
}
Wishlist --* Warehouse
Return --|> Order
@enduml