@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
interface Renewal {
  #Date description
  +long address
  -String total
  #Date level
  -boolean code
  +setCode()
  +getAddress()
}
class Member {
  +double duration
  -boolean quantity
  +updateScore()
  +updateNote()
}
abstract class Shelf {
  -int note
  +Date total
  #int createdAt
  +calculateType()
  +validateEmail()
  +findPrice()
  +setPhone()
}
interface Loan {
  -long quantity
  +boolean type
  +setDescription()
  +createId()
  +sendCode()
}
abstract class Reservation {
  #float duration
  -double email
  #float id
  #boolean price
  +boolean phone
  +setUpdatedat()
  +createUpdatedat()
  +calculateNote()
  +updateScore()
}
Shelf ..> Loan : "1"
Loan --* Reservation
Renewal --> Loan : "*"
@enduml