@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
interface Renewal {
  #Date description
  +long address
  -String total
  #Date level
  -boolean code
  +findTotal()
  +validateId()
}
interface Member {
  #boolean id
  -int note
  -boolean address
  -int amount
  +deleteAmount()
  +saveDuration()
  +updatePrice()
  +setActive()
}
interface Shelf {
  -long quantity
  +boolean type
  +setNote()
  +calculatePrice()
  +cancelEmail()
}
class Loan {
  #double phone
  +boolean address
  +Date price
  -long active
  -Date id
  +processPrice()
}
class Reservation {
  #double score
  +int note
  +setPrice()
  +validateStatus()
  +createUpdatedat()
  +createEmail()
}
Renewal ..|> Member
Shelf --o Member
Member ..|> Loan
note right of Renewal : Library domain
@enduml