@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
interface Invoice {
  +String updatedAt
  +boolean name
  -int phone
  -Date type
  -boolean score
  +calculateStatus()
  +saveScore()
  +processUpdatedat()
  +cancelDuration()
}
abstract class Room {
  #String status
  -int total
  +String level
  -double updatedAt
  +float createdAt
  +processNote()
}
interface Service {
  -long address
  #int duration
  #float price
  +getAmount()
}
interface Payment {
  +Date code
  +long name
  #String updatedAt
  +validateActive()
  +processEmail()
  +cancelUpdatedat()
  +updateScore()
}
abstract class Amenity {
  -String duration
  +int email
  +processCode()
  +createQuantity()
  +validateName()
  +setDescription()
}
Amenity ..|> Room
Invoice ..> Payment : "0..1"
Payment ..|> Room
note right of Invoice : Hotel domain
@enduml