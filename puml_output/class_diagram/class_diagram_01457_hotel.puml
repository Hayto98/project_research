@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
interface Invoice {
  +String updatedAt
  +boolean name
  -int phone
  -Date type
  -boolean score
  +calculateQuantity()
  +processScore()
  +validateId()
  +createType()
}
interface Room {
  -boolean updatedAt
  #float level
  #double type
  #boolean price
  +boolean status
  +calculateDescription()
  +processName()
}
class Service {
  -int code
  #String duration
  -double type
  +calculateCreatedat()
  +setEmail()
}
abstract class Payment {
  +Date email
  #boolean createdAt
  +Date score
  +String name
  +int id
  +saveCreatedat()
  +cancelPrice()
}
class Amenity {
  +Date address
  #float active
  -String note
  #long email
  -String updatedAt
  +sendType()
  +validateNote()
}
Payment --* Invoice
Service --|> Amenity
Invoice --* Room
@enduml