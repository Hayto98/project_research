@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
abstract class DeliveryNote {
  #double id
  +boolean name
  +long createdAt
  +findDescription()
  +deleteCreatedat()
  +setQuantity()
  +calculateAddress()
}
abstract class Shipment {
  -Date note
  #float amount
  #long score
  +updateType()
  +saveCode()
}
class Warehouse {
  -String note
  #Date description
  +deleteAddress()
}
class FuelLog {
  #float price
  +Date email
  +setAmount()
  +updateCreatedat()
}
abstract class Tracking {
  #boolean address
  #float type
  #double email
  +processNote()
}
class Inventory {
  -boolean updatedAt
  -Date id
  #String level
  +validateAmount()
  +calculateDuration()
  +updateScore()
  +cancelActive()
}
interface Package {
  #boolean createdAt
  #float price
  #int status
  #int email
  +saveActive()
}
Package ..> DeliveryNote : "1"
Inventory --o Warehouse
Tracking --o Shipment
@enduml