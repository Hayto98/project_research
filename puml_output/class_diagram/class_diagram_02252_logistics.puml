@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
abstract class DeliveryNote {
  #double id
  +boolean name
  +long createdAt
  +cancelEmail()
  +deleteNote()
  +findCreatedat()
  +processAmount()
}
interface Shipment {
  -long score
  +double level
  #int quantity
  -String createdAt
  #Date amount
  +updateUpdatedat()
}
interface Warehouse {
  #float price
  +Date email
  +processAmount()
  +validateType()
}
class FuelLog {
  +double name
  #long amount
  #Date level
  +Date updatedAt
  -long id
  +updatePrice()
  +saveStatus()
  +createDuration()
}
class Tracking {
  +float status
  #float score
  +Date amount
  +calculateLevel()
  +updateType()
  +deleteStatus()
}
abstract class Inventory {
  +double amount
  #boolean type
  +savePrice()
  +deleteAmount()
  +sendTotal()
}
class Package {
  #Date level
  -Date code
  +int note
  +float phone
  +validateTotal()
}
FuelLog --o Inventory
DeliveryNote ..|> Package
Package --* DeliveryNote
Warehouse --|> DeliveryNote
note right of DeliveryNote : Logistics domain
@enduml