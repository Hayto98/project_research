@startuml
skinparam monochrome true
skinparam ArrowColor #555555
class Invoice {
  #long address
  -Date active
  -float id
  +updateScore()
  +deleteQuantity()
}
interface Housekeeping {
  +int score
  #double type
  #boolean id
  +sendQuantity()
}
class Staff {
  #String level
  #float updatedAt
  #String code
  +validateAmount()
  +calculateUpdatedat()
