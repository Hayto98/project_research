@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Cart {
  -float status
  +Date level
  +float quantity
  #Date code
  +updateQuantity()
}
class Supplier {
  -boolean address
  #double active
  +validateScore()
  +validateAddress()
}
class Payment {
  #int note
  #int email
  #double address
  +float total
  +Date quantity
  +getActive()
  +createQuantity()
}
interface Category {
  -double active
  -Date total
  +boolean type
  -String id
  +createStatus()
  +saveScore()
  +cancelDuration()
  +calculateLevel()
}
class Return {
  #double active
  -boolean score
  #int code
  +double total
  +calculatePhone()
  +setQuantity()
  +setEmail()
  +setQuantity()
}
class Shipment {
  +int name
  #float active
  #Date description
  -boolean createdAt
  +cancelActive()
  +setUpdatedat()
  +setDescription()
}
Category --o Shipment
Supplier --* Category
Shipment --o Payment
Supplier --o Payment
note right of Cart : Ecommerce domain
@enduml