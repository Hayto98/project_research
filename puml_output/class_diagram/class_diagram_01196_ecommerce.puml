@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
class Cart {
  -float status
  +Date level
  +float quantity
  #Date code
  +calculateNote()
}
class Supplier {
  #boolean id
  -int address
  -float active
  #long price
  +createAddress()
  +updateAmount()
  +getAddress()
}
abstract class Payment {
  #int level
  #int address
  #double total
  +float quantity
  +calculateUpdatedat()
  +findPhone()
}
class Category {
  #double quantity
  -String level
  -double active
  -Date duration
  +updateNote()
}
abstract class Return {
  -String level
  #float type
  +saveUpdatedat()
  +setQuantity()
  +deleteUpdatedat()
  +updateAmount()
}
class Shipment {
  #double active
  -boolean score
  #int code
  +double total
  +getPhone()
  +sendPhone()
  +processScore()
  +setStatus()
}
Cart --|> Payment
Payment --* Shipment
Shipment --> Cart : "0..1"
Supplier ..|> Cart
@enduml