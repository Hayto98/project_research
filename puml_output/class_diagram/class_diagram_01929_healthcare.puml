@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Nurse {
  -long createdAt
  #float code
  +processPrice()
}
class Insurance {
  #boolean phone
  +double email
  -float name
  #Date note
  +sendCode()
  +sendActive()
  +validateScore()
  +saveCreatedat()
}
class Doctor {
  +double amount
  -double updatedAt
  +int price
  +validateAddress()
  +processActive()
  +deleteUpdatedat()
  +cancelCode()
}
class Billing {
  -int id
  -double code
  -int note
  +processId()
}
abstract class Patient {
  #boolean name
  +int active
  #double status
  +cancelDescription()
  +getDuration()
  +setPhone()
}
Nurse --o Insurance
Patient ..> Billing : "*"
note right of Nurse : Healthcare domain
@enduml