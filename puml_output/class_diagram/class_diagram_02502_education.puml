@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Exam {
  #double phone
  +String createdAt
  -boolean name
  #int total
  -String updatedAt
  +saveActive()
  +processCreatedat()
}
class Student {
  #long id
  -String level
  -double duration
  +int type
  +setScore()
  +sendCode()
  +saveLevel()
}
class Book {
  +boolean duration
  #boolean note
  #long status
  #boolean name
  -int level
  +setScore()
  +processCode()
  +cancelCode()
  +createDuration()
}
class Attendance {
  -boolean type
  +int updatedAt
  +String code
  +long name
  +savePhone()
  +getPhone()
  +validateEmail()
}
class Enrollment {
  -double active
  #String code
  #long price
  +boolean phone
  #String id
  +getActive()
  +createDescription()
  +findEmail()
}
abstract class Teacher {
  +boolean status
  #String active
  #float email
  +setAddress()
  +cancelEmail()
}
interface Library {
  #String note
  #int score
  -long createdAt
  +deleteCreatedat()
  +saveType()
  +getCode()
  +validateTotal()
}
Attendance --o Book
Attendance ..|> Library
Teacher --* Student
Teacher --> Enrollment : "1..*"
Student --> Library : "*"
Library ..|> Attendance
@enduml