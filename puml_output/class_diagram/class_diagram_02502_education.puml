@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
class Exam {
  #double phone
  +String createdAt
  -boolean name
  #int total
  -String updatedAt
  +sendAmount()
  +findAddress()
}
class Student {
  #boolean score
  -boolean duration
  +createStatus()
  +calculateNote()
  +deleteDescription()
}
class Book {
  -String id
  #boolean price
  #Date note
  -boolean status
  #double name
  +saveActive()
  +calculateId()
}
abstract class Attendance {
  +double code
  #int email
  +String type
  +int updatedAt
  -long duration
  +calculateStatus()
}
class Enrollment {
  -double active
  #String code
  #long price
  +boolean phone
  #String id
  +findActive()
  +calculateLevel()
  +updateStatus()
}
interface Teacher {
  #float name
  +boolean score
  +boolean level
  +Date status
  +cancelScore()
  +updateDuration()
  +setDescription()
  +createQuantity()
}
interface Library {
  -double email
  -int level
  #int active
  -Date type
  #boolean address
  +updateCreatedat()
  +sendDuration()
  +processPrice()
}
Enrollment --* Exam
Exam --|> Book
Enrollment --* Library
note right of Exam : Education domain
@enduml