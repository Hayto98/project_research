@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
class Insurance {
  -long phone
  +double level
  +float note
  #String duration
  -boolean type
  +cancelPrice()
  +sendAddress()
  +getEmail()
}
interface LabTest {
  -Date status
  -double amount
  +createDuration()
}
interface Billing {
  #float total
  #Date updatedAt
  +int amount
  -double note
  +float score
  +deletePrice()
  +setDuration()
  +saveEmail()
}
class Patient {
  +double price
  +double quantity
  #boolean address
  -Date active
  +validateLevel()
}
interface Appointment {
  #int price
  -boolean phone
  +int updatedAt
  #double name
  +deleteDescription()
  +saveStatus()
  +validatePrice()
}
LabTest --|> Patient
Billing ..> Patient : "*"
Patient ..|> Insurance
@enduml