@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Hashtag {
  +int duration
  +double total
  #Date phone
  +updateAmount()
  +findPrice()
}
class Report {
  #boolean total
  #Date description
  -String duration
  +deleteCode()
}
class Follower {
  -int active
  -int createdAt
  +boolean note
  +sendName()
}
interface Profile {
  #long code
  #String total
  +int id
  +calculateScore()
  +sendScore()
  +validateAmount()
}
interface User {
  #float price
  -int id
  -String phone
  +sendTotal()
  +sendCode()
  +getQuantity()
  +saveLevel()
}
interface Like {
  #float createdAt
  +String status
  +deleteAmount()
}
class Album {
  +boolean active
  #boolean code
  -int status
  -Date score
  +setQuantity()
  +sendAddress()
}
Report --> Like : "1"
Report --o Follower
Like --* Album
Like --o Profile
@enduml