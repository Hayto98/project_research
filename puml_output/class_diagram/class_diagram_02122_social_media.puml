@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Hashtag {
  +int duration
  +double total
  #Date phone
  +sendId()
  +sendUpdatedat()
}
abstract class Report {
  #float total
  -String level
  +long active
  +saveUpdatedat()
  +saveActive()
}
class Follower {
  #String price
  -boolean description
  +float duration
  +boolean updatedAt
  -boolean id
  +saveQuantity()
}
interface Profile {
  -long amount
  -long duration
  +calculateId()
  +validateLevel()
}
abstract class User {
  +double note
  #float id
  #String price
  +setId()
  +getStatus()
}
abstract class Like {
  #float quantity
  +String active
  #boolean code
  #long status
  +createAmount()
  +createAddress()
}
class Album {
  -Date description
  #long quantity
  +processLevel()
  +createLevel()
  +calculateCreatedat()
  +findActive()
}
User --* Follower
Follower --|> Profile
Album ..|> Profile
note right of Hashtag : Social Media domain
@enduml