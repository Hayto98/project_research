@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Deposit {
  -int updatedAt
  +long address
  +String quantity
  +findId()
  +setLevel()
  +processActive()
  +processNote()
}
abstract class Account {
  #Date amount
  +float updatedAt
  +double email
  +validateDuration()
  +calculateAmount()
  +calculateEmail()
}
class Statement {
  +double status
  +float createdAt
  -double updatedAt
  +calculateLevel()
  +processDuration()
  +setEmail()
}
interface Teller {
  #float updatedAt
  -long note
  +boolean total
  #String email
  +saveStatus()
  +setName()
  +sendAddress()
}
class Card {
  #int description
  -boolean level
  -float amount
  -float createdAt
  +float total
  +cancelNote()
  +getNote()
  +createQuantity()
  +cancelDescription()
}
Deposit --* Account
Account --* Deposit
note right of Deposit : Banking domain
@enduml