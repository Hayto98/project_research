@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
class Deposit {
  -int updatedAt
  +long address
  +String quantity
  +calculateStatus()
  +setAmount()
  +updateDuration()
  +cancelEmail()
}
interface Account {
  +int active
  -Date type
  #String note
  +double score
  -long createdAt
  +processUpdatedat()
  +findAmount()
  +validateAddress()
  +createQuantity()
}
interface Statement {
  +double status
  +float createdAt
  -double updatedAt
  +calculateCode()
  +cancelActive()
  +createName()
}
interface Teller {
  #long email
  +Date score
  +getPrice()
  +cancelCreatedat()
  +getStatus()
  +validatePrice()
}
class Card {
  +float quantity
  +boolean description
  #long id
  +double email
  +boolean status
  +getTotal()
  +getAddress()
}
Account --> Teller : "*"
Statement --o Deposit
Card --|> Teller
Teller --* Statement
@enduml