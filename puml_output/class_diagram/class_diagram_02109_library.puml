@startuml
skinparam monochrome true
skinparam shadowing true
class Member {
  #double score
  +String type
  #double status
  +float phone
  +setStatus()
}
abstract class Librarian {
  #int amount
  -boolean total
  #boolean phone
  #Date note
  +Date quantity
  +setScore()
  +cancelUpdatedat()
  +processPrice()
  +cancelStatus()
}
interface Branch {
  #Date total
  #int type
  -int note
  -long createdAt
  +createId()
}
abstract class Book {
  -double updatedAt
  +double level
  +getPhone()
}
class Renewal {
  -String active
  -float name
  +setType()
  +deleteQuantity()
  +findDuration()
}
class Author {
  #long id
  -String updatedAt
  +String total
  +long name
  +validateLevel()
  +findStatus()
  +updateCreatedat()
  +deleteScore()
}
Member ..|> Librarian
Renewal ..|> Librarian
Renewal ..> Book : "1"
@enduml