@startuml
skinparam monochrome true
skinparam shadowing true
class Member {
  #double score
  +String type
  #double status
  +float phone
  +setNote()
}
abstract class Librarian {
  -float total
  #int phone
  -boolean note
  +findPrice()
}
class Branch {
  #Date duration
  #double email
  +processCreatedat()
  +saveAmount()
  +calculateUpdatedat()
  +processAddress()
}
class Book {
  -String code
  -String updatedAt
  +boolean phone
  +long note
  +double name
  +deleteStatus()
  +sendDescription()
  +saveEmail()
}
class Renewal {
  -String total
  +String name
  +long address
  +saveAmount()
  +saveCreatedat()
  +getCreatedat()
  +updateLevel()
}
class Author {
  -String active
  #long note
  -long status
  +createId()
  +sendDescription()
  +deleteDescription()
}
Book --o Branch
Librarian --> Branch : "1..*"
Member --* Branch
note right of Member : Library domain
@enduml