@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
abstract class Return {
  +float code
  +long description
  +Date amount
  +updateAddress()
  +validateId()
  +saveEmail()
}
interface Invoice {
  -Date phone
  +String active
  +setActive()
  +findLevel()
  +validateUpdatedat()
}
class Coupon {
  -boolean score
  -int level
  +validateCreatedat()
  +updateDuration()
}
class Cart {
  -boolean address
  #long note
  +deleteTotal()
  +setCreatedat()
  +updateScore()
  +saveNote()
}
Cart ..|> Invoice
Cart --* Return
note right of Return : Ecommerce domain
@enduml