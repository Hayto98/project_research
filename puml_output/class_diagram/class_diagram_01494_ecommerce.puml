@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
abstract class Return {
  +float code
  +long description
  +Date amount
  +createScore()
  +validateScore()
  +saveScore()
}
class Invoice {
  -Date score
  +String id
  -String phone
  #Date active
  +findAddress()
  +cancelPhone()
  +setStatus()
}
interface Coupon {
  -int level
  +Date type
  #String amount
  #float score
  +setEmail()
}
abstract class Cart {
  +int level
  +Date quantity
  #Date total
  -Date amount
  #long score
  +createNote()
  +calculateCode()
  +getEmail()
  +calculateActive()
}
Invoice --o Cart
Coupon --* Cart
Invoice ..> Coupon : "*"
@enduml