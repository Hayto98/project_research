@startuml

class Amenity {
  -int address
  +int status
  #boolean type
  +double code
  +updateCreatedat()
  +saveLevel()
}
interface Staff {
  -float description
  +int type
  +validateUpdatedat()
}
abstract class Booking {
  #double total
  -String phone
  #double id
  +deleteNote()
  +getUpdatedat()
  +getStatus()
  +getUpdatedat()
}
class Housekeeping {
  #double description
  #Date phone
  -double level
  +getPhone()
  +saveId()
  +setStatus()
}
class CheckIn {
  -boolean quantity
  #boolean total
  #int email
  #int duration
  +processType()
}
class Restaurant {
  #float total
  #boolean status
  #int address
  +findEmail()
}
Housekeeping ..|> CheckIn
Booking --|> Staff
Amenity --* Restaurant
Amenity --|> Housekeeping
CheckIn --|> Booking
note right of Amenity : Hotel domain
@enduml