@startuml

class Amenity {
  -int address
  +int status
  #boolean type
  +double code
  +updateDescription()
  +calculateNote()
}
interface Staff {
  -float description
  +int type
  +getPrice()
}
class Booking {
  -float price
  +boolean createdAt
  -double total
  +sendDescription()
}
abstract class Housekeeping {
  +String amount
  +float note
  +int name
  #int updatedAt
  -Date id
  +findPrice()
  +sendCreatedat()
  +validateType()
}
interface CheckIn {
  +Date total
  +Date email
  #long name
  -float phone
  -double id
  +saveActive()
  +getNote()
  +calculateAmount()
}
interface Restaurant {
  -Date level
  -int createdAt
  #float name
  +cancelCreatedat()
  +deleteEmail()
}
Booking --> CheckIn : "0..1"
Amenity --> Booking : "*"
@enduml