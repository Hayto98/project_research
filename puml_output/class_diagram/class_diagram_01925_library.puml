@startuml
skinparam ArrowColor #555555
interface Publisher {
  -long id
  -boolean name
  +double active
  +deletePrice()
  +findActive()
  +calculateCode()
  +createCreatedat()
}
class Author {
  -float type
  #String total
  +boolean level
  +validateActive()
  +sendType()
  +deleteStatus()
  +sendActive()
}
class Shelf {
  #Date address
  #String total
  -Date email
  +setNote()
  +processTotal()
  +calculateStatus()
  +processAddress()
}
class Renewal {
  -boolean phone
  #int duration
  #int email
  -Date active
  +updateAddress()
  +getPrice()
  +processLevel()
  +calculateQuantity()
}
interface Reservation {
  +double level
  -boolean active
  -String quantity
  -Date address
  #int amount
  +calculatePhone()
  +processTotal()
  +saveScore()
}
abstract class Loan {
  #double duration
  #long id
  -int code
  +saveCode()
}
class Book {
  #boolean duration
  +Date quantity
  +int total
  +createPrice()
}
Loan ..|> Author
Reservation ..> Shelf : "0..1"
Book --> Publisher : "1"
Publisher ..> Loan : "1..*"
Shelf --* Publisher
@enduml