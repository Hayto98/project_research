@startuml
skinparam ArrowColor #555555
interface Publisher {
  -long id
  -boolean name
  +double active
  +processType()
  +calculateDescription()
  +updateAmount()
  +processTotal()
}
abstract class Author {
  -boolean duration
  #boolean status
  -float description
  #int active
  +calculateEmail()
  +saveScore()
  +setEmail()
}
abstract class Shelf {
  -boolean note
  -boolean amount
  #int address
  #int phone
  -Date active
  +saveTotal()
  +calculateLevel()
  +findDuration()
  +findType()
}
interface Renewal {
  -double duration
  #double address
  +long amount
  #boolean description
  +createQuantity()
  +processPhone()
}
abstract class Reservation {
  #double duration
  #long id
  -int code
  +calculateQuantity()
}
interface Loan {
  #boolean duration
  +Date quantity
  +int total
  +calculateScore()
}
class Book {
  #int updatedAt
  +float active
  #String email
  +saveQuantity()
}
Publisher --o Shelf
Book --> Publisher : "1"
Shelf ..|> Author
note right of Publisher : Library domain
@enduml