@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
interface Reservation {
  #long address
  +int status
  +cancelUpdatedat()
  +processPrice()
  +findNote()
  +calculateLevel()
}
class CheckOut {
  -boolean active
  +String updatedAt
  #int id
  +double total
  -long duration
  +calculateType()
  +findName()
  +cancelUpdatedat()
  +calculateId()
}
class Amenity {
  +long price
  +boolean amount
  -double name
  +long score
  #long total
  +processId()
}
class CheckIn {
  #long active
  #double name
  #float note
  -String phone
  #boolean description
  +updateUpdatedat()
  +calculateEmail()
  +updateId()
  +findEmail()
}
interface Room {
  +int score
  +int name
  -double type
  #int active
  +processQuantity()
  +setActive()
  +sendTotal()
}
Reservation ..> CheckOut : "*"
Reservation ..|> Room
@enduml