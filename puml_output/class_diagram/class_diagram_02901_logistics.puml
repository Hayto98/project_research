@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class DeliveryNote {
  #Date status
  +double description
  #int updatedAt
  +int quantity
  #int price
  +createAddress()
  +processDescription()
  +setType()
  +findDescription()
}
class FuelLog {
  #boolean createdAt
  #int phone
  +createId()
}
abstract class Route {
  +String note
  +boolean id
  +boolean type
  -boolean createdAt
  +getCode()
}
abstract class Depot {
  #Date active
  +String type
  #int code
  #long description
  +Date score
  +cancelScore()
  +createTotal()
  +updateQuantity()
  +updateAddress()
}
class Customer {
  -String updatedAt
  +double phone
  +float note
  #int type
  #long level
  +cancelDuration()
  +sendPrice()
  +getQuantity()
  +validateCreatedat()
}
class Manifest {
  +int email
  +int updatedAt
  +getPrice()
}
class Driver {
  +String status
  -float level
  #double id
  #float email
  -float amount
  +setEmail()
}
Depot --* Route
Depot ..|> Manifest
FuelLog --* Manifest
@enduml