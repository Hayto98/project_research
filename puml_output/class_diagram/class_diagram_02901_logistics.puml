@startuml
skinparam monochrome true
skinparam defaultFontSize 13
class DeliveryNote {
  #Date status
  +double description
  #int updatedAt
  +int quantity
  #int price
  +setQuantity()
  +deleteDuration()
  +setStatus()
  +findCreatedat()
}
class FuelLog {
  #double name
  +double note
  +int email
  +deleteDuration()
}
class Route {
  +int level
  +boolean id
  #String price
  +Date total
  +boolean type
  +updateType()
  +saveName()
  +savePrice()
}
class Depot {
  +String note
  -int type
  #int phone
  #long quantity
  +saveDuration()
  +deleteEmail()
  +getEmail()
  +updateDescription()
}
class Customer {
  +boolean updatedAt
  -Date code
  +findLevel()
}
class Manifest {
  #double amount
  #float createdAt
  -float name
  +long type
  +calculateAddress()
  +validateTotal()
}
class Driver {
  -long quantity
  -float phone
  #int amount
  +findCode()
  +cancelPrice()
  +validateId()
  +processCode()
}
Manifest --* Depot
DeliveryNote ..> FuelLog : "1"
note right of DeliveryNote : Logistics domain
@enduml