@startuml
skinparam shadowing true
abstract class Grade {
  +double amount
  -double phone
  +float createdAt
  -long level
  +createLevel()
  +createId()
}
class Book {
  +String code
  -Date total
  +float level
  #boolean score
  +findNote()
}
class Enrollment {
  #double type
  #boolean status
  -boolean price
  +getDuration()
}
class Department {
  +String description
  +int note
  #boolean total
  #int code
  +boolean phone
  +processNote()
  +deleteNote()
  +getName()
}
class Student {
  -boolean type
  #Date duration
  -boolean score
  +getNote()
  +sendStatus()
  +getActive()
  +saveNote()
}
Grade --o Enrollment
Grade --> Book : "*"
note right of Grade : Education domain
@enduml