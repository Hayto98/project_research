@startuml
skinparam shadowing true
abstract class Grade {
  +double amount
  -double phone
  +float createdAt
  -long level
  +getNote()
  +findName()
}
class Book {
  +boolean id
  -double email
  +calculateLevel()
  +saveEmail()
  +cancelTotal()
  +createQuantity()
}
class Enrollment {
  #int note
  #double quantity
  +deleteAmount()
}
interface Department {
  #boolean level
  #long duration
  -float phone
  +double code
  -String name
  +validateCode()
  +savePhone()
  +calculateId()
}
class Student {
  -double id
  +double level
  +String address
  +sendNote()
}
Department --> Enrollment : "1..*"
Student --|> Department
Department --|> Grade
@enduml