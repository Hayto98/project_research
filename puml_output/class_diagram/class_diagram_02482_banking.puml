@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Card {
  +boolean amount
  -float createdAt
  -float address
  +Date type
  #float level
  +sendQuantity()
  +calculateName()
  +validateUpdatedat()
}
abstract class Transaction {
  +long id
  -boolean phone
  +updateEmail()
}
abstract class Beneficiary {
  #long status
  #String name
  -Date address
  +String quantity
  +updateDescription()
  +validateActive()
  +validateEmail()
  +calculatePhone()
}
class Loan {
  +Date active
  #String createdAt
  -int total
  -float duration
  -float address
  +updateCreatedat()
  +setDescription()
  +processPhone()
  +saveAddress()
}
abstract class Teller {
  +long total
  +Date email
  +float duration
  #boolean type
  +int description
  +deleteStatus()
}
abstract class Transfer {
  #Date duration
  #boolean createdAt
  +saveAmount()
  +updateType()
  +createLevel()
  +getEmail()
}
interface Customer {
  -boolean phone
  +double updatedAt
  +calculateLevel()
  +processEmail()
  +processId()
}
Customer --|> Card
Transaction --* Card
Loan --* Transfer
note right of Card : Banking domain
@enduml