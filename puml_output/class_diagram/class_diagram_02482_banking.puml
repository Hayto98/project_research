@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Card {
  +boolean amount
  -float createdAt
  -float address
  +Date type
  #float level
  +sendQuantity()
  +deletePhone()
  +saveType()
}
class Transaction {
  +long name
  +long phone
  -boolean updatedAt
  #String price
  +long code
  +findScore()
  +updateName()
  +calculateId()
  +findQuantity()
}
class Beneficiary {
  +boolean duration
  -int id
  #int phone
  -boolean updatedAt
  +calculateScore()
  +calculateCode()
  +deleteCode()
}
class Loan {
  +Date active
  #String createdAt
  -int total
  -float duration
  -float address
  +updateDescription()
  +sendId()
  +validatePhone()
  +processCreatedat()
}
class Teller {
  #Date phone
  -double address
  -int note
  +long score
  +Date total
  +updateQuantity()
  +sendType()
}
interface Transfer {
  +float createdAt
  -String code
  #int amount
  +setScore()
  +getName()
  +setCreatedat()
  +deleteScore()
}
class Customer {
  -Date quantity
  +long level
  #String name
  -long email
  -float code
  +validateAmount()
  +findActive()
  +updateActive()
  +findTotal()
}
Customer --|> Card
Transaction --* Card
Loan --* Transfer
@enduml