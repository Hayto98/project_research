@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
class Account {
  -long price
  +long quantity
  +boolean address
  -String code
  +calculateAmount()
  +sendCreatedat()
  +saveDescription()
}
abstract class Interest {
  #long amount
  +int price
  -long createdAt
  +int duration
  +updateAddress()
  +deleteCreatedat()
  +cancelEmail()
}
class Transaction {
  #double type
  +float code
  +boolean description
  #double amount
  +validateCreatedat()
}
abstract class Customer {
  -int id
  -boolean description
  +setScore()
  +getNote()
}
interface Withdrawal {
  #int email
  +String duration
  +createNote()
}
interface Statement {
  +long status
  +String updatedAt
  -String email
  #boolean quantity
  -String active
  +deleteTotal()
  +saveUpdatedat()
  +updateAmount()
}
class Beneficiary {
  #long phone
  -long type
  -int status
  -int active
  +deleteTotal()
}
Withdrawal --|> Interest
Transaction --|> Account
Customer ..|> Statement
Statement --|> Interest
Transaction --o Withdrawal
Statement --> Customer : "1..*"
@enduml