@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
class Housekeeping {
  -String amount
  -int description
  -String address
  +sendCode()
  +cancelActive()
  +getLevel()
  +getType()
}
abstract class Invoice {
  #boolean quantity
  #Date score
  #boolean type
  #double description
  +validateStatus()
  +sendType()
  +deleteScore()
}
class Staff {
  -int createdAt
  +String name
  +Date duration
  #String note
  +processUpdatedat()
  +sendAddress()
  +findCreatedat()
}
abstract class Amenity {
  +double active
  +boolean score
  +getCode()
  +deleteAddress()
}
Amenity --> Housekeeping : "0..1"
Housekeeping --> Staff : "1..*"
Housekeeping --* Invoice
note right of Housekeeping : Hotel domain
@enduml