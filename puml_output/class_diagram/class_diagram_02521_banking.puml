@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Transaction {
  +long duration
  -int phone
  #double score
  -int updatedAt
  +validateNote()
  +saveType()
  +sendActive()
}
class Branch {
  -boolean email
  +int code
  +deleteDuration()
  +deleteEmail()
  +findStatus()
  +sendCreatedat()
}
class Deposit {
  -long quantity
  #long price
  -float level
  -String address
  -boolean createdAt
  +validatePhone()
  +sendTotal()
  +getUpdatedat()
  +getNote()
}
class Beneficiary {
  +boolean id
  -int total
  -int amount
  +cancelStatus()
  +cancelAddress()
}
class Customer {
  +int total
  #int phone
  +float code
  #float address
  +float updatedAt
  +updatePrice()
  +validateName()
  +cancelEmail()
}
Branch --* Deposit
Deposit ..|> Beneficiary
@enduml