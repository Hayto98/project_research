@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
class Transaction {
  +long duration
  -int phone
  #double score
  -int updatedAt
  +updateDuration()
  +saveAmount()
  +getEmail()
}
class Branch {
  #double duration
  +float code
  #double description
  #Date note
  -float active
  +calculateAddress()
  +updateNote()
  +createQuantity()
  +calculatePrice()
}
class Deposit {
  +Date duration
  #boolean price
  +String code
  -boolean id
  #int quantity
  +sendNote()
  +updateType()
}
class Beneficiary {
  -float code
  -long quantity
  #String amount
  +updateUpdatedat()
  +updateCreatedat()
  +deleteDuration()
}
class Customer {
  +boolean id
  -long type
  #long status
  -int name
  +setScore()
}
Transaction --* Deposit
Beneficiary --|> Deposit
note right of Transaction : Banking domain
@enduml