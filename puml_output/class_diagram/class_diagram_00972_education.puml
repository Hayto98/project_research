@startuml

interface Grade {
  +int total
  #double name
  +boolean active
  #long type
  +setUpdatedat()
  +processDescription()
  +findCode()
  +findId()
}
interface Attendance {
  -String level
  +String type
  -long description
  #String duration
  +createTotal()
}
interface Department {
  -long address
  #boolean amount
  +validateDescription()
}
interface Library {
  #int code
  +long description
  -double amount
  #boolean duration
  -float active
  +setName()
  +cancelNote()
  +processAddress()
  +savePrice()
}
interface Exam {
  -String id
  -long createdAt
  +int address
  +cancelEmail()
  +calculateTotal()
}
class Student {
  +double duration
  -double description
  #double status
  +float code
  #double updatedAt
  +sendAmount()
}
Attendance ..|> Student
Exam ..> Attendance : "*"
@enduml