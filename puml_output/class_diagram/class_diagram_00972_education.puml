@startuml

interface Grade {
  +int total
  #double name
  +boolean active
  #long type
  +getQuantity()
  +validateAmount()
  +cancelQuantity()
  +cancelType()
}
class Attendance {
  -Date total
  +String status
  #boolean code
  +long id
  +float email
  +createActive()
  +getLevel()
  +saveType()
  +setDescription()
}
class Department {
  +int code
  -long score
  +findLevel()
  +calculatePrice()
  +getCreatedat()
  +cancelActive()
}
class Library {
  -String createdAt
  -long address
  +updateUpdatedat()
}
class Exam {
  +float score
  +String price
  -long description
  -boolean status
  +getLevel()
  +calculateName()
  +sendName()
  +updateCreatedat()
}
class Student {
  +int type
  +float quantity
  -Date duration
  +calculateTotal()
  +getNote()
}
Student --> Department : "1..*"
Attendance ..|> Department
Exam --* Grade
note right of Grade : Education domain
@enduml