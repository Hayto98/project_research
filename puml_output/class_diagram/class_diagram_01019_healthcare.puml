@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
abstract class LabTest {
  +double email
  -float duration
  +validateScore()
  +calculateAddress()
}
interface Hospital {
  -float description
  -int duration
  -int updatedAt
  +getLevel()
  +cancelTotal()
  +updateId()
}
class Prescription {
  +float note
  -Date type
  -boolean code
  +updateUpdatedat()
}
class Billing {
  -int address
  #int type
  #boolean status
  +float quantity
  +float level
  +getType()
  +savePrice()
  +saveQuantity()
}
interface Appointment {
  -long amount
  +String createdAt
  #String total
  #String description
  -long quantity
  +deleteDuration()
  +cancelActive()
}
class Ward {
  -int status
  -double updatedAt
  +long note
  +Date quantity
  #String address
  +updateQuantity()
}
abstract class Treatment {
  +double total
  -boolean score
  -long note
  #String code
  +deleteEmail()
  +setStatus()
  +validateStatus()
}
Prescription ..> Treatment : "1"
Appointment --|> Prescription
@enduml