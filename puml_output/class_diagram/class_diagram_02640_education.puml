@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Book {
  -String address
  -double price
  #boolean createdAt
  +String email
  +deleteType()
  +cancelScore()
  +findUpdatedat()
  +updateCode()
}
abstract class Library {
  +float createdAt
  #Date type
  +Date description
  -Date email
  #String id
  +createScore()
  +findCreatedat()
}
class Teacher {
  +double type
  -long score
  -float duration
  +Date createdAt
  #long email
  +saveCode()
  +cancelNote()
  +calculateScore()
}
abstract class Schedule {
  #long updatedAt
  #long address
  +calculateAmount()
}
interface Enrollment {
  -boolean name
  -double quantity
  -String address
  +Date total
  +saveLevel()
  +validateCode()
}
abstract class Student {
  #float email
  -double createdAt
  -int type
  +cancelScore()
}
Book --* Enrollment
Schedule ..|> Enrollment
Enrollment --* Schedule
note right of Book : Education domain
@enduml