@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Book {
  -String address
  -double price
  #boolean createdAt
  +String email
  +validateQuantity()
  +saveLevel()
  +getId()
  +savePrice()
}
interface Library {
  -int createdAt
  -int code
  #long type
  +processCreatedat()
}
class Teacher {
  -float type
  #Date code
  +float amount
  +cancelCreatedat()
}
abstract class Schedule {
  -long createdAt
  -float score
  +Date email
  #long name
  -Date type
  +findDescription()
}
abstract class Enrollment {
  #long score
  #long price
  +double status
  +boolean updatedAt
  -String address
  +findName()
  +createActive()
  +calculateQuantity()
}
abstract class Student {
  #Date price
  +Date phone
  #long code
  +double createdAt
  +getDescription()
  +setCode()
}
Student --o Library
Enrollment --o Teacher
Teacher --|> Library
Enrollment ..> Student : "0..1"
@enduml