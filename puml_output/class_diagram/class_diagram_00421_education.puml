@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Exam {
  +Date code
  -double note
  -float address
  +String phone
  -long quantity
  +setPhone()
}
abstract class Book {
  #long price
  +boolean active
  +Date description
  -double note
  +getEmail()
  +setDescription()
}
class Grade {
  #long status
  -long id
  +Date note
  +float quantity
  +updateCode()
  +validateScore()
  +setLevel()
}
interface Enrollment {
  -Date duration
  -boolean type
  +validateLevel()
}
class Teacher {
  #boolean active
  -boolean note
  -String description
  +cancelCreatedat()
}
Teacher --* Enrollment
Book --|> Enrollment
note right of Exam : Education domain
@enduml