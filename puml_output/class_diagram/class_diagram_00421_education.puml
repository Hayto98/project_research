@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Exam {
  +Date code
  -double note
  -float address
  +String phone
  -long quantity
  +setDescription()
}
class Book {
  #long address
  +boolean price
  +Date active
  -double description
  #int note
  +findCreatedat()
}
class Grade {
  #String phone
  -Date address
  #long status
  +processScore()
  +findScore()
  +setPrice()
}
class Enrollment {
  +long id
  #String quantity
  #float createdAt
  +getDuration()
}
interface Teacher {
  #float total
  #long address
  +boolean active
  -int id
  #boolean phone
  +createUpdatedat()
  +saveStatus()
  +saveName()
}
Exam --|> Book
Teacher --* Enrollment
@enduml