@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class User {
  #int total
  +String level
  +getAmount()
  +sendPhone()
  +validateActive()
  +calculateDescription()
}
abstract class Profile {
  -float price
  #boolean email
  -Date note
  -Date type
  +sendPrice()
  +createId()
  +sendUpdatedat()
  +updateAddress()
}
class Group {
  +long code
  -int description
  #float duration
  +Date total
  +findAddress()
  +createCreatedat()
  +findDescription()
}
interface Story {
  -String quantity
  #int description
  #int amount
  +updateUpdatedat()
  +setStatus()
  +createEmail()
}
class Post {
  -String code
  -String name
  +float address
  +int description
  +deleteNote()
}
Group ..> Profile : "0..1"
Profile --* Group
Story --* Profile
note right of User : Social Media domain
@enduml