@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class User {
  #int total
  +String level
  +saveStatus()
  +savePhone()
  +cancelScore()
  +processUpdatedat()
}
interface Profile {
  #double address
  -Date active
  #double total
  -double description
  +deletePrice()
  +setAmount()
  +validateTotal()
  +validateLevel()
}
interface Group {
  -String address
  #int total
  +long active
  +boolean price
  +createAddress()
  +setType()
  +cancelStatus()
}
abstract class Story {
  +Date phone
  +Date total
  +updateScore()
  +validateScore()
  +processDescription()
}
class Post {
  +int level
  -String updatedAt
  #int quantity
  +updateLevel()
  +deleteId()
}
Profile --|> User
Group --|> Post
@enduml