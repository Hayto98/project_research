@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Profile {
  +Date id
  -String note
  +int status
  +calculateEmail()
  +deleteNote()
  +findActive()
  +processDescription()
}
class Group {
  #String type
  +long note
  #double total
  #boolean duration
  +deleteUpdatedat()
}
interface Report {
  -double level
  -float note
  #double description
  +int createdAt
  +updateId()
  +calculateTotal()
}
interface Story {
  +boolean createdAt
  +long active
  -boolean amount
  +String quantity
  +cancelCode()
}
class Notification {
  +String status
  #float type
  +double updatedAt
  -String description
  +validateQuantity()
  +deleteName()
  +deletePrice()
}
Report --|> Notification
Story --o Notification
Profile --* Report
Report --> Group : "0..1"
note right of Profile : Social Media domain
@enduml