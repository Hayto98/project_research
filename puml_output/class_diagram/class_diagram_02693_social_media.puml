@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Profile {
  +Date id
  -String note
  +int status
  +calculateCode()
  +validateAddress()
  +findPhone()
  +deleteDuration()
}
interface Group {
  -boolean description
  -boolean email
  +String phone
  -Date type
  -boolean note
  +getEmail()
}
class Report {
  -double level
  -float note
  #double description
  +int createdAt
  +processActive()
  +sendTotal()
}
abstract class Story {
  -float level
  +boolean quantity
  +long createdAt
  -boolean active
  +String amount
  +processId()
}
class Notification {
  +int email
  +String status
  #float type
  +validateName()
  +validateScore()
}
Notification --* Report
Report --|> Group
@enduml