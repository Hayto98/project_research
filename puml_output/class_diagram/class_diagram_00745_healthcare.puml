@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
class Prescription {
  #float amount
  -String updatedAt
  +setTotal()
}
class Patient {
  +boolean level
  -long quantity
  +boolean score
  #long phone
  +deleteQuantity()
  +findStatus()
}
class Nurse {
  -Date id
  -double address
  -int active
  #int total
  #String name
  +sendCode()
  +validateTotal()
  +setUpdatedat()
}
class Appointment {
  #boolean amount
  +int duration
  #float level
  +long note
  +int id
  +processLevel()
  +calculateAddress()
  +getCode()
}
abstract class Treatment {
  +float createdAt
  +long updatedAt
  +updateScore()
  +calculateCreatedat()
  +createStatus()
  +calculateUpdatedat()
}
Prescription ..|> Appointment
Appointment ..|> Nurse
Prescription --o Nurse
Treatment --* Prescription
@enduml