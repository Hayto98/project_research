@startuml
skinparam monochrome true
abstract class LabTest {
  +long quantity
  #double createdAt
  #boolean duration
  #Date code
  +setScore()
  +findType()
  +processName()
  +createPrice()
}
interface Diagnosis {
  #Date status
  #Date score
  #int quantity
  +boolean name
  -boolean note
  +validateScore()
}
interface Prescription {
  +double description
  +boolean name
  -Date id
  #boolean amount
  +getDescription()
  +findTotal()
}
class Treatment {
  +String price
  +Date status
  +float address
  +double phone
  #int duration
  +cancelStatus()
  +cancelDescription()
  +createDescription()
}
class Billing {
  -double name
  #Date price
  -long quantity
  #boolean level
  #int total
  +findCode()
  +saveId()
}
abstract class Hospital {
  +int type
  +boolean amount
  +int updatedAt
  +float description
  +double total
  +updateEmail()
}
Hospital ..> Treatment : "0..1"
Treatment --* LabTest
@enduml