@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
interface Cart {
  #boolean score
  -long createdAt
  +sendScore()
}
interface Coupon {
  +boolean description
  -double address
  +Date duration
  +createStatus()
}
class Product {
  #long active
  +Date createdAt
  -boolean address
  +Date type
  +sendAmount()
  +createNote()
  +processName()
}
abstract class Invoice {
  #Date phone
  +double note
  -boolean createdAt
  +deleteAddress()
}
class Return {
  +int description
  #boolean score
  +int address
  +findActive()
  +calculateStatus()
}
class Customer {
  +double updatedAt
  -float note
  #boolean phone
  +float quantity
  -Date score
  +deleteActive()
  +findPhone()
  +calculateDuration()
}
Return --o Coupon
Invoice --|> Coupon
Customer --> Invoice : "0..1"
Invoice ..|> Cart
@enduml