@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
interface Cart {
  #boolean score
  -long createdAt
  +calculateScore()
}
interface Coupon {
  +boolean description
  -double address
  +Date duration
  +sendCode()
}
class Product {
  +Date address
  -boolean type
  +Date phone
  +sendId()
  +processUpdatedat()
  +validateNote()
}
class Invoice {
  +String note
  +int duration
  #long code
  +deleteDuration()
  +sendStatus()
}
class Return {
  +float type
  #double createdAt
  -Date note
  +validateName()
  +processType()
  +findDuration()
}
class Customer {
  #double duration
  #Date active
  #float address
  #int type
  -double description
  +setActive()
  +deleteType()
}
Invoice ..|> Cart
Return ..|> Cart
Invoice --* Customer
note right of Cart : Ecommerce domain
@enduml