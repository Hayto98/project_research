@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
class Invoice {
  +Date amount
  +boolean id
  +boolean score
  +updateDescription()
}
class Housekeeping {
  -Date duration
  +String note
  #boolean quantity
  +processCode()
}
interface Restaurant {
  #float email
  -Date code
  #Date updatedAt
  -float total
  -Date address
  +sendAmount()
  +createNote()
  +processTotal()
}
abstract class Payment {
  #int total
  -boolean address
  +cancelUpdatedat()
  +updateNote()
  +sendDuration()
}
Payment ..|> Housekeeping
Invoice ..> Housekeeping : "*"
Invoice --o Restaurant
@enduml