@startuml
skinparam monochrome true
skinparam shadowing true
class LabTest {
  #int updatedAt
  +long createdAt
  +int amount
  #int total
  -float price
  +deleteAmount()
  +calculateAmount()
}
class Doctor {
  +float amount
  #double quantity
  +float score
  #long price
  #boolean address
  +savePrice()
  +deleteCode()
}
interface Diagnosis {
  -int name
  #String active
  +sendPhone()
}
abstract class Insurance {
  -boolean name
  +String updatedAt
  -Date type
  #boolean email
  +int duration
  +updateStatus()
  +getCreatedat()
  +createQuantity()
}
LabTest ..|> Insurance
Insurance --|> Diagnosis
note right of LabTest : Healthcare domain
@enduml