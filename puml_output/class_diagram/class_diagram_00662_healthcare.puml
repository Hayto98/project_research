@startuml
skinparam monochrome true
skinparam shadowing true
class LabTest {
  #int updatedAt
  +long createdAt
  +int amount
  #int total
  -float price
  +createCreatedat()
  +calculateAddress()
}
abstract class Doctor {
  #long phone
  #double type
  #Date amount
  +saveNote()
  +setQuantity()
  +savePrice()
}
abstract class Diagnosis {
  #boolean active
  +Date quantity
  +validateCode()
  +createAddress()
  +getQuantity()
  +sendDuration()
}
class Insurance {
  +Date active
  +Date phone
  +sendQuantity()
}
Insurance --o Diagnosis
LabTest ..> Diagnosis : "0..1"
Insurance --|> Doctor
@enduml