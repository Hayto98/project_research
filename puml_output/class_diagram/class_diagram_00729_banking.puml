@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Transfer {
  -int phone
  -String code
  #float email
  +setDescription()
}
interface Deposit {
  +String amount
  +boolean name
  +long email
  +sendAmount()
  +sendNote()
  +createPhone()
}
class Branch {
  +Date note
  +Date level
  #boolean description
  #double price
  +getName()
  +setActive()
  +getLevel()
  +sendCreatedat()
}
interface Beneficiary {
  +boolean updatedAt
  #Date amount
  #long email
  +processDuration()
  +updateQuantity()
}
interface Account {
  +Date amount
  #double description
  +createTotal()
  +getUpdatedat()
  +findType()
  +updateNote()
}
Transfer ..|> Beneficiary
Deposit --> Beneficiary : "0..1"
note right of Transfer : Banking domain
@enduml