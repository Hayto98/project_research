@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Transfer {
  -int phone
  -String code
  #float email
  +findNote()
}
class Deposit {
  +String amount
  +boolean name
  +long email
  +cancelAmount()
  +createCode()
  +deleteLevel()
}
interface Branch {
  #Date email
  #int phone
  -String description
  #String duration
  #Date note
  +cancelType()
  +deleteActive()
  +processName()
  +deleteTotal()
}
class Beneficiary {
  #boolean active
  +boolean id
  +findAddress()
  +findId()
}
interface Account {
  -boolean code
  +long level
  #String phone
  +int amount
  +sendPrice()
}
Beneficiary --* Account
Beneficiary ..|> Transfer
Beneficiary ..> Deposit : "*"
Deposit --> Transfer : "*"
@enduml