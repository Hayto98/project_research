@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Customer {
  #double id
  -String address
  -Date total
  +findCreatedat()
}
abstract class Order {
  #boolean address
  #double price
  +validateName()
  +validateDescription()
}
abstract class Coupon {
  #boolean score
  #String level
  #int duration
  -Date code
  +processDescription()
  +calculateDuration()
}
class Category {
  +float description
  -Date code
  #String active
  -int name
  +double status
  +setActive()
  +deleteAmount()
  +findUpdatedat()
  +deleteQuantity()
}
abstract class Invoice {
  +String phone
  +boolean email
  +long name
  #Date active
  +findCreatedat()
  +saveDescription()
  +setEmail()
}
Category --o Order
Invoice ..> Order : "0..1"
Customer --o Category
Invoice --o Customer
@enduml