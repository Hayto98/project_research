@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Vehicle {
  -float status
  +long quantity
  +String phone
  -Date duration
  +String amount
  +deleteScore()
  +deleteCode()
  +cancelTotal()
}
class Route {
  #double name
  -String id
  +calculateNote()
}
class Manifest {
  +String status
  -float duration
  +calculateDuration()
  +calculateCreatedat()
  +savePrice()
}
class Driver {
  -int description
  #double name
  +deleteEmail()
  +saveAmount()
  +cancelScore()
}
abstract class Customer {
  +Date active
  +int price
  +cancelActive()
}
class Package {
  -float createdAt
  #int level
  +getStatus()
}
Vehicle --|> Package
Manifest --o Driver
note right of Vehicle : Logistics domain
@enduml