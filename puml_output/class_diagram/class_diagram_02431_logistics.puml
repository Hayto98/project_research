@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
class Vehicle {
  -float status
  +long quantity
  +String phone
  -Date duration
  +String amount
  +saveAddress()
  +setAmount()
  +createEmail()
}
interface Route {
  +boolean code
  +Date level
  +float total
  +cancelType()
}
abstract class Manifest {
  +String id
  +String name
  +String total
  -float note
  +cancelCreatedat()
  +setPhone()
  +calculateCode()
}
class Driver {
  +Date email
  -long code
  +Date description
  -Date name
  +boolean total
  +findLevel()
  +processAmount()
  +getScore()
  +processType()
}
class Customer {
  #boolean amount
  +boolean status
  +processActive()
}
interface Package {
  +String duration
  +float createdAt
  +long code
  -double id
  +Date status
  +sendCreatedat()
}
Route --* Manifest
Customer --* Package
Vehicle ..> Customer : "1..*"
@enduml