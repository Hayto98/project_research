@startuml
skinparam monochrome true
class Prescription {
  -double score
  +boolean amount
  -int status
  #boolean name
  +float createdAt
  +deleteQuantity()
  +findDuration()
  +updatePhone()
}
abstract class Patient {
  -double price
  -int score
  +updateEmail()
  +calculatePrice()
}
class Doctor {
  #int email
  #String phone
  #double duration
  +calculateNote()
  +saveType()
  +processUpdatedat()
}
class Insurance {
  -String price
  +float updatedAt
  +createStatus()
  +deleteEmail()
}
class Treatment {
  #Date code
  +long description
  #long note
  +deleteStatus()
}
class Billing {
  #double note
  +Date address
  +Date duration
  +createName()
  +saveStatus()
  +calculateNote()
  +getDuration()
}
class Hospital {
  #long quantity
  #boolean phone
  -long type
  +int price
  #Date code
  +validateType()
}
Prescription --> Patient : "1"
Hospital --|> Prescription
Doctor ..|> Treatment
@enduml