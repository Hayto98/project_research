@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Customer {
  -double phone
  #double type
  #long duration
  +validateActive()
  +getLevel()
  +setLevel()
}
interface Loan {
  #String description
  +int type
  #float active
  #long createdAt
  +int phone
  +cancelType()
  +createNote()
}
class Beneficiary {
  -double id
  #Date address
  +findTotal()
}
abstract class Transfer {
  #int id
  -float note
  +sendLevel()
  +processActive()
  +saveLevel()
  +updateId()
}
class Statement {
  -double total
  +double email
  +String score
  +cancelEmail()
  +cancelId()
}
class Interest {
  #float note
  +double description
  -int phone
  +updatePrice()
  +createPhone()
  +validateAddress()
  +saveStatus()
}
Statement ..|> Loan
Transfer --o Customer
Beneficiary --o Transfer
Customer --* Loan
Interest --|> Loan
@enduml