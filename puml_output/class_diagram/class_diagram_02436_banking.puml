@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
class Customer {
  -double phone
  #double type
  #long duration
  +cancelCode()
  +deleteLevel()
  +processDescription()
}
abstract class Loan {
  +float phone
  #float id
  #long createdAt
  +deleteDescription()
  +deleteActive()
}
class Beneficiary {
  -boolean address
  #String email
  +setId()
  +processAmount()
  +processNote()
  +updateId()
}
class Transfer {
  -int email
  +int score
  +long total
  +boolean price
  +double description
  +saveDuration()
  +validateActive()
}
class Statement {
  -float phone
  #float createdAt
  -boolean total
  +int id
  -String status
  +validateTotal()
  +processCode()
  +updatePhone()
  +saveCreatedat()
}
class Interest {
  #String name
  +String description
  +calculateTotal()
  +findPhone()
}
Interest ..|> Beneficiary
Beneficiary --|> Statement
note right of Customer : Banking domain
@enduml