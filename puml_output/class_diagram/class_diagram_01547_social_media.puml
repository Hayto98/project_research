@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Like {
  -Date code
  #String amount
  #Date status
  #double description
  +updatePhone()
  +cancelPrice()
  +processScore()
  +getLevel()
}
class Post {
  +Date code
  -boolean score
  #Date amount
  #double status
  +validateName()
  +processQuantity()
  +getDescription()
}
class Group {
  #boolean level
  -Date quantity
  +int updatedAt
  +saveTotal()
  +setStatus()
  +createStatus()
  +processAddress()
}
interface Follower {
  -double address
  +boolean note
  +boolean code
  +calculateDuration()
  +getDescription()
  +saveId()
  +sendPrice()
}
abstract class Hashtag {
  #int duration
  #float score
  -double createdAt
  +deleteActive()
  +deletePhone()
  +cancelTotal()
  +updateLevel()
}
Post --* Like
Post --* Hashtag
note right of Like : Social Media domain
@enduml