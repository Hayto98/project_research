@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Like {
  -Date code
  #String amount
  #Date status
  #double description
  +sendId()
  +setActive()
  +createAmount()
  +processId()
}
abstract class Post {
  #boolean score
  #Date name
  +String code
  +Date quantity
  -boolean duration
  +processPhone()
  +calculateName()
  +updateTotal()
  +createTotal()
}
class Group {
  #float quantity
  -int id
  #boolean description
  -Date name
  +int amount
  +setScore()
  +getAddress()
  +updateAmount()
  +setDescription()
}
class Follower {
  -double status
  +long type
  -int address
  #float description
  +calculatePrice()
}
abstract class Hashtag {
  #double duration
  #int id
  #float description
  #int level
  #int price
  +sendName()
  +calculateDuration()
  +sendPrice()
}
Post ..> Hashtag : "1..*"
Hashtag ..|> Follower
Hashtag ..|> Post
@enduml