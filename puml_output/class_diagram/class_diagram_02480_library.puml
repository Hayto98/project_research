@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
interface Fine {
  +float duration
  -String id
  +saveLevel()
  +cancelCreatedat()
  +setNote()
  +deleteStatus()
}
class Catalog {
  #boolean total
  +Date type
  -Date updatedAt
  +calculateAddress()
  +processScore()
  +calculateTotal()
  +processCode()
}
interface Librarian {
  -int address
  #boolean total
  -String id
  +boolean duration
  +processAddress()
}
abstract class Publisher {
  #int duration
  +float status
  #float createdAt
  -float active
  +String price
  +findLevel()
  +processType()
  +deleteTotal()
  +validateUpdatedat()
}
Librarian --|> Fine
Publisher --* Fine
@enduml