@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
interface Fine {
  +float duration
  -String id
  +calculateTotal()
  +saveCode()
  +updateTotal()
  +processUpdatedat()
}
interface Catalog {
  +float note
  +float duration
  +validateTotal()
  +getAddress()
  +createCreatedat()
}
interface Librarian {
  -boolean name
  +int duration
  #boolean status
  -Date total
  +updatePhone()
  +deleteCode()
}
abstract class Publisher {
  -String type
  -int name
  -Date address
  #long updatedAt
  +long code
  +deleteDuration()
  +processLevel()
}
Catalog --> Fine : "0..1"
Catalog ..|> Publisher
note right of Fine : Library domain
@enduml