@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Interest {
  +float level
  +int address
  -String price
  +Date id
  +updateType()
}
class Account {
  -int type
  #double price
  -boolean status
  +float level
  +int address
  +updateStatus()
  +deleteNote()
}
class Withdrawal {
  #double id
  -Date type
  +String duration
  -long address
  +updateAddress()
  +validateId()
  +updateActive()
}
interface Teller {
  #long quantity
  #Date phone
  +float note
  +processCreatedat()
}
Account --o Withdrawal
Interest --|> Account
note right of Interest : Banking domain
@enduml