@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
class Interest {
  +float level
  +int address
  -String price
  +Date id
  +calculateNote()
}
abstract class Account {
  -Date type
  #long duration
  -int price
  #double status
  +getScore()
  +validateQuantity()
  +deleteLevel()
}
class Withdrawal {
  +double amount
  +boolean updatedAt
  #long status
  +findType()
}
abstract class Teller {
  -Date address
  +String note
  +cancelPhone()
  +getDuration()
  +findAddress()
  +getUpdatedat()
}
Withdrawal ..|> Interest
Account --* Teller
Teller --* Withdrawal
@enduml