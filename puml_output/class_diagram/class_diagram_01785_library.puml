@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
interface Member {
  -boolean updatedAt
  +String phone
  +validateLevel()
}
abstract class Catalog {
  #Date code
  +float total
  +saveQuantity()
  +cancelQuantity()
  +updateCode()
}
class Fine {
  -int name
  -Date note
  +boolean score
  #String duration
  +updateAddress()
}
class Loan {
  +Date price
  -int score
  #Date active
  #boolean address
  +cancelCreatedat()
  +deletePrice()
  +calculatePrice()
}
abstract class Branch {
  #float email
  -String score
  #double type
  #int duration
  -float code
  +sendStatus()
  +findId()
  +validatePhone()
  +createName()
}
abstract class Shelf {
  +long code
  #boolean phone
  #String type
  -float duration
  #long id
  +setNote()
  +validateAddress()
  +validateCode()
  +deleteTotal()
}
abstract class Librarian {
  #double updatedAt
  +int amount
  #long status
  #Date type
  +long level
  +cancelEmail()
  +processCreatedat()
  +deleteCreatedat()
}
Branch --* Catalog
Branch --* Shelf
Catalog --> Branch : "*"
note right of Member : Library domain
@enduml