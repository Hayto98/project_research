@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
interface Member {
  -boolean updatedAt
  +String phone
  +updateQuantity()
}
class Catalog {
  #long name
  #long code
  +Date total
  +float duration
  -long address
  +deletePrice()
}
interface Fine {
  -Date price
  +boolean amount
  +validatePhone()
}
class Loan {
  -String address
  #long email
  +Date price
  #float active
  +deleteDescription()
  +cancelNote()
  +validateCreatedat()
}
abstract class Branch {
  -String price
  #float note
  -String level
  #double email
  #int type
  +processScore()
  +getName()
  +processNote()
  +cancelQuantity()
}
interface Shelf {
  #float id
  #long address
  +calculateEmail()
  +validateUpdatedat()
  +sendName()
}
class Librarian {
  -Date type
  #Date code
  +double id
  #long amount
  +getLevel()
  +createName()
  +calculateName()
  +createNote()
}
Fine ..|> Member
Shelf --o Loan
Librarian ..> Loan : "0..1"
Catalog --o Member
@enduml