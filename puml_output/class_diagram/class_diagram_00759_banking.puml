@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
interface Withdrawal {
  -boolean price
  -float note
  +float email
  #float description
  #String duration
  +getAddress()
  +validatePhone()
  +saveDuration()
}
class Transfer {
  +int duration
  -long name
  +String phone
  +deleteActive()
  +sendNote()
  +cancelActive()
}
interface Deposit {
  +long duration
  +float type
  +double total
  +sendUpdatedat()
  +calculateScore()
}
class Branch {
  #String total
  +double name
  -float price
  +getCode()
  +validateType()
  +validatePhone()
}
class Teller {
  -boolean code
  +Date price
  #Date note
  -Date email
  +createType()
  +validateAmount()
}
class Card {
  -float name
  -boolean duration
  +int total
  -String amount
  #int price
  +getAddress()
  +calculateActive()
}
class Customer {
  #float id
  -boolean amount
  +validatePrice()
  +calculateCode()
  +getLevel()
}
Teller ..|> Withdrawal
Customer ..|> Transfer
Customer --|> Branch
note right of Withdrawal : Banking domain
@enduml