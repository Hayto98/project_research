@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
interface Withdrawal {
  -boolean price
  -float note
  +float email
  #float description
  #String duration
  +processCode()
  +setEmail()
  +createActive()
}
class Transfer {
  +double updatedAt
  -int name
  +Date phone
  #float id
  +saveAddress()
  +saveLevel()
  +findPrice()
}
interface Deposit {
  -String level
  -int active
  +double duration
  #Date createdAt
  #int type
  +createPrice()
  +getActive()
}
interface Branch {
  #String updatedAt
  +double total
  -float name
  -String price
  +setEmail()
}
abstract class Teller {
  -double phone
  -long status
  #String quantity
  #Date code
  +createTotal()
  +getAmount()
  +sendNote()
}
class Card {
  +double phone
  +double amount
  -float createdAt
  -boolean note
  +int name
  +deleteNote()
  +getCode()
  +deleteAddress()
  +saveStatus()
}
class Customer {
  #long address
  +Date price
  +saveTotal()
}
Card --> Deposit : "1..*"
Deposit --o Branch
Withdrawal --> Customer : "0..1"
@enduml