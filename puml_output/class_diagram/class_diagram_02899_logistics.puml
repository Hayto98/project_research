@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
class Manifest {
  #double updatedAt
  #double description
  +createId()
  +cancelStatus()
  +calculateName()
  +setType()
}
class Route {
  #String updatedAt
  +float name
  #double note
  -Date score
  +findId()
  +updatePhone()
}
interface Vehicle {
  #boolean phone
  +int score
  +updateQuantity()
}
abstract class Inventory {
  +float score
  #double active
  +float id
  #double price
  +createCreatedat()
  +deletePhone()
  +validateNote()
}
class Shipment {
  #int type
  -Date amount
  +Date quantity
  #double updatedAt
  +String name
  +deletePrice()
  +createName()
}
interface Package {
  +Date duration
  +boolean address
  +float total
  +calculateScore()
  +saveLevel()
  +getAmount()
}
Package --* Vehicle
Manifest ..> Inventory : "0..1"
Package --* Inventory
Route ..|> Inventory
Route --o Vehicle
@enduml