@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
class Order {
  #Date description
  #int amount
  +sendCreatedat()
  +saveCreatedat()
  +saveTotal()
}
class Return {
  -long type
  -boolean price
  +deleteCreatedat()
  +setAmount()
  +updateType()
  +sendPrice()
}
abstract class Payment {
  -float name
  #boolean quantity
  -String address
  +boolean score
  +createStatus()
  +setCode()
  +saveScore()
  +deleteCreatedat()
}
class Supplier {
  +double total
  #String status
  +findDuration()
}
interface Customer {
  -double id
  +long code
  +cancelName()
  +setAddress()
  +validateQuantity()
}
Payment --|> Order
Customer ..|> Order
Customer ..> Supplier : "1"
Supplier --* Order
@enduml