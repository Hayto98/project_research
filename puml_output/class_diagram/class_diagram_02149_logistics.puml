@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
interface Inventory {
  +int updatedAt
  #Date note
  -int total
  #float description
  -int address
  +saveTotal()
  +getPhone()
}
class Tracking {
  +String quantity
  -float address
  +float id
  #float phone
  +saveId()
}
class Package {
  #long active
  -double name
  -long note
  -long status
  -long level
  +deleteAddress()
  +updateActive()
}
interface Shipment {
  #String status
  #long note
  +calculatePrice()
  +getLevel()
}
Shipment --> Inventory : "1"
Package --o Shipment
Inventory --> Package : "1..*"
@enduml