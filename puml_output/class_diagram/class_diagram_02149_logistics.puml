@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
interface Inventory {
  +int updatedAt
  #Date note
  -int total
  #float description
  -int address
  +calculateEmail()
  +createQuantity()
}
class Tracking {
  +double phone
  +float description
  +getId()
}
abstract class Package {
  #String note
  #long status
  +processAddress()
  +validateAddress()
  +validateAddress()
  +validateDescription()
}
class Shipment {
  #float duration
  #String score
  +processActive()
}
Package ..|> Shipment
Inventory --o Tracking
note right of Inventory : Logistics domain
@enduml