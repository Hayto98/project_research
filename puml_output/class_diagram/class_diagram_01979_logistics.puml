@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Depot {
  -boolean createdAt
  -int duration
  #float total
  -long status
  +calculateEmail()
  +setLevel()
}
abstract class Customer {
  #float code
  #int price
  +calculateEmail()
}
interface DeliveryNote {
  #int duration
  +boolean name
  -Date quantity
  +cancelCreatedat()
  +processDescription()
  +processNote()
}
class Vehicle {
  -int price
  -boolean total
  -long active
  -long address
  +updateCode()
  +createName()
}
DeliveryNote --> Vehicle : "1"
Customer --> DeliveryNote : "1"
Depot ..|> Vehicle
note right of Depot : Logistics domain
@enduml