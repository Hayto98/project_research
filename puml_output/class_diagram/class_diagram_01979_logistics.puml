@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
class Depot {
  -boolean createdAt
  -int duration
  #float total
  -long status
  +findAmount()
  +sendAddress()
}
class Customer {
  -Date status
  -Date code
  #int price
  #Date description
  #Date duration
  +processDescription()
}
interface DeliveryNote {
  #float name
  -boolean score
  +double quantity
  +sendStatus()
  +deleteActive()
}
abstract class Vehicle {
  -double quantity
  +long price
  #float total
  -long active
  +updateLevel()
  +findId()
  +deleteAddress()
}
DeliveryNote --* Depot
DeliveryNote --> Vehicle : "1"
@enduml