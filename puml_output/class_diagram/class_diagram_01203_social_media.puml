@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Comment {
  +double email
  -boolean phone
  -long price
  +boolean address
  +setUpdatedat()
  +validateDescription()
}
class Follower {
  +String updatedAt
  #double description
  +long id
  +validateCode()
  +processNote()
  +setType()
}
class Album {
  -boolean description
  #double total
  +saveDescription()
  +findNote()
  +setName()
}
class Like {
  #Date total
  #int score
  +calculateAddress()
  +sendCode()
  +processEmail()
  +calculateDescription()
}
class Hashtag {
  #int level
  #Date amount
  #float total
  -int phone
  +setTotal()
  +createLevel()
  +validatePhone()
}
class Group {
  #boolean price
  +Date address
  +findCreatedat()
  +updateCreatedat()
  +deleteName()
}
class Profile {
  +String id
  -Date email
  +long level
  -Date phone
  #double note
  +processName()
  +setType()
}
Like ..> Group : "1..*"
Group ..|> Follower
Profile --* Hashtag
Hashtag --* Like
Profile --o Group
Follower --o Comment
note right of Comment : Social Media domain
@enduml