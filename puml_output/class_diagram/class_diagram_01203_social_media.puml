@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
class Comment {
  +double email
  -boolean phone
  -long price
  +boolean address
  +updateUpdatedat()
  +sendNote()
}
class Follower {
  #int id
  +float score
  +Date level
  +validateEmail()
}
class Album {
  -double description
  +double phone
  +float email
  +float level
  +double code
  +createUpdatedat()
  +getAmount()
  +findAmount()
  +findStatus()
}
class Like {
  +boolean note
  #Date status
  #float name
  +processAddress()
}
abstract class Hashtag {
  -float score
  #String total
  -long level
  +findPhone()
  +validateCreatedat()
  +getCode()
  +sendActive()
}
class Group {
  #int duration
  #Date total
  #float phone
  +sendId()
  +validateActive()
  +validateStatus()
}
class Profile {
  #long total
  -long email
  +saveCode()
}
Profile --> Hashtag : "0..1"
Group ..> Album : "0..1"
Follower ..|> Profile
Comment --o Profile
@enduml