@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Vehicle {
  #boolean duration
  #float updatedAt
  -boolean email
  -boolean quantity
  -String level
  +calculateEmail()
}
class DeliveryNote {
  +long score
  +float type
  #double quantity
  +float createdAt
  +saveAmount()
  +createEmail()
}
class Route {
  +boolean phone
  -String createdAt
  +Date amount
  +findQuantity()
  +sendLevel()
}
interface Inventory {
  #String duration
  #int amount
  #float name
  -Date createdAt
  #long total
  +validateCode()
  +calculateEmail()
}
DeliveryNote --o Vehicle
Route --* Vehicle
@enduml