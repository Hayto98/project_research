@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
class Vehicle {
  #boolean duration
  #float updatedAt
  -boolean email
  -boolean quantity
  -String level
  +getDescription()
}
class DeliveryNote {
  #double quantity
  +float createdAt
  #Date amount
  +double phone
  -float level
  +validateCreatedat()
  +deleteId()
}
interface Route {
  #int code
  +float duration
  #boolean amount
  #int address
  -float price
  +saveCreatedat()
}
interface Inventory {
  +Date score
  +boolean address
  +String amount
  -Date description
  +getEmail()
  +validatePhone()
  +saveLevel()
}
DeliveryNote --|> Vehicle
Inventory ..|> DeliveryNote
note right of Vehicle : Logistics domain
@enduml