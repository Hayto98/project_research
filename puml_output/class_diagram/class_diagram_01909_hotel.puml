@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
interface Booking {
  -boolean total
  #double phone
  -boolean price
  +processTotal()
  +updatePhone()
  +calculateActive()
}
class Invoice {
  +long address
  -String quantity
  #String name
  +createName()
  +findAddress()
  +createAddress()
}
class Service {
  +String description
  -Date id
  -Date type
  +findDuration()
  +updateEmail()
  +processLevel()
  +saveName()
}
class Reservation {
  -Date createdAt
  -int id
  +double type
  -double price
  +savePrice()
  +findTotal()
  +calculateId()
}
class Guest {
  -String type
  +long address
  -boolean price
  +Date amount
  -int email
  +deleteAmount()
  +setPrice()
}
class Amenity {
  #Date email
  +float total
  +findName()
  +getEmail()
  +validateId()
  +saveDescription()
}
interface CheckIn {
  #double name
  #int phone
  +deleteDuration()
}
Service --* Amenity
Guest --|> Amenity
Invoice --|> Booking
Amenity --* Booking
Booking --> Guest : "*"
@enduml