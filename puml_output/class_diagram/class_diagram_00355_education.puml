@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
class Enrollment {
  -long score
  -long price
  #boolean level
  #String total
  +Date quantity
  +cancelUpdatedat()
}
interface Teacher {
  +double description
  +Date address
  +saveName()
  +processAddress()
}
class Assignment {
  #float total
  +boolean name
  -boolean address
  -float type
  +Date email
  +findPrice()
  +createId()
  +updateStatus()
}
class Book {
  -boolean status
  -Date type
  -double total
  +updateCreatedat()
  +sendDuration()
  +saveTotal()
  +updateNote()
}
interface Course {
  -int phone
  #String total
  +long updatedAt
  #boolean createdAt
  +createAmount()
}
interface Schedule {
  +long note
  #double active
  +getType()
}
Assignment --o Schedule
Book --* Teacher
Assignment --> Teacher : "1..*"
Enrollment --|> Assignment
@enduml