@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
class Appointment {
  #Date code
  #String duration
  -Date amount
  +processDescription()
}
class Diagnosis {
  +String duration
  +int note
  -String active
  #double email
  -boolean total
  +calculatePhone()
}
abstract class Treatment {
  #double total
  +String address
  +calculateType()
  +saveLevel()
}
abstract class Ward {
  +float total
  #float description
  #boolean createdAt
  -double score
  +processQuantity()
  +getLevel()
}
interface Prescription {
  #double id
  -boolean score
  +int level
  +processName()
  +saveScore()
  +findStatus()
  +getDescription()
}
class Nurse {
  #long address
  +Date email
  +cancelCode()
  +updateAmount()
}
Prescription --* Appointment
Appointment ..> Treatment : "0..1"
Treatment ..|> Prescription
Nurse --|> Ward
@enduml