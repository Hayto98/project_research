@startuml
skinparam defaultFontSize 13
class Course {
  +int id
  +String total
  +deleteTotal()
  +setCreatedat()
}
abstract class Book {
  #long code
  #long duration
  +calculateEmail()
  +findId()
  +createType()
}
abstract class Attendance {
  -String address
  #boolean note
  #boolean status
  +calculateActive()
}
interface Department {
  +float quantity
  -double amount
  +findTotal()
}
class Assignment {
  +double price
  -int code
  -double name
  #boolean updatedAt
  +float address
  +deleteCreatedat()
  +deleteEmail()
  +setDuration()
  +savePhone()
}
class Enrollment {
  -int phone
  #boolean description
  -double address
  +calculatePrice()
}
class Grade {
  +long price
  +boolean phone
  #int amount
  +createId()
  +calculateNote()
  +processId()
}
Course --|> Grade
Department --o Course
note right of Course : Education domain
@enduml