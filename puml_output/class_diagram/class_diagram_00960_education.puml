@startuml
skinparam defaultFontSize 13
class Course {
  +int id
  +String total
  +saveAddress()
  +getStatus()
}
abstract class Book {
  +String createdAt
  +float type
  +sendPrice()
  +updateTotal()
  +createDuration()
}
class Attendance {
  -boolean email
  #int type
  +calculateAmount()
  +cancelType()
  +deleteQuantity()
}
class Department {
  +double score
  #float level
  +setTotal()
}
class Assignment {
  #String price
  #double note
  +cancelCode()
  +sendLevel()
  +processType()
}
class Enrollment {
  #float score
  #int duration
  +updateStatus()
  +calculateCode()
  +sendCode()
}
class Grade {
  -int total
  +int score
  #float active
  -String description
  +updateType()
  +getScore()
  +setLevel()
}
Book --o Attendance
Book --> Enrollment : "*"
Department --o Course
Enrollment ..|> Department
@enduml