@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
abstract class Return {
  #double status
  +float address
  -boolean amount
  #double score
  +float price
  +saveTotal()
  +findUpdatedat()
}
class Customer {
  -Date score
  +String address
  +Date active
  #Date type
  #String total
  +saveQuantity()
  +getCode()
  +calculateDescription()
  +cancelName()
}
interface Invoice {
  +String name
  +String duration
  -Date phone
  -String updatedAt
  +int createdAt
  +saveTotal()
}
class Order {
  +long id
  +double level
  -String quantity
  -long type
  -Date name
  +saveTotal()
  +deleteType()
  +processType()
  +updateCode()
}
abstract class Payment {
  -double active
  -double status
  +boolean address
  +getNote()
  +deleteType()
}
class Supplier {
  -String name
  -double id
  +updateLevel()
  +saveUpdatedat()
  +calculateLevel()
  +setNote()
}
Order --> Customer : "0..1"
Invoice --> Payment : "1..*"
@enduml