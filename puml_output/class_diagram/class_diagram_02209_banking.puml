@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Withdrawal {
  +String phone
  -float total
  #long email
  +deleteLevel()
  +cancelTotal()
}
class Customer {
  +float address
  -Date code
  +sendAddress()
  +calculateAddress()
}
interface Interest {
  +int status
  -boolean updatedAt
  +createNote()
  +setTotal()
}
class Deposit {
  -boolean amount
  +int active
  -String id
  #long phone
  +calculatePrice()
  +getStatus()
  +cancelUpdatedat()
  +setNote()
}
class Account {
  +long createdAt
  +double description
  +setDuration()
}
Customer --o Deposit
Account --|> Interest
Interest --* Withdrawal
@enduml