@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
class Withdrawal {
  +String phone
  -float total
  #long email
  +getUpdatedat()
  +getAddress()
}
class Customer {
  -int address
  #boolean createdAt
  +setDuration()
}
class Interest {
  #int createdAt
  -String price
  +deleteActive()
  +getPhone()
  +calculateDuration()
}
class Deposit {
  -boolean note
  #double name
  -float address
  +updateDescription()
}
class Account {
  +float createdAt
  #double price
  -boolean status
  #long total
  +findQuantity()
}
Interest --|> Account
Customer --o Account
note right of Withdrawal : Banking domain
@enduml