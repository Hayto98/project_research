@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
interface Book {
  +float status
  #String address
  +updateName()
}
abstract class Author {
  -float note
  #Date quantity
  +saveId()
  +validateStatus()
}
interface Fine {
  -int price
  -String level
  #boolean updatedAt
  +getStatus()
}
class Publisher {
  +long email
  -boolean address
  -long price
  +float duration
  #int name
  +sendPrice()
  +calculatePrice()
  +findAddress()
  +validatePhone()
}
Book ..> Publisher : "0..1"
Author ..> Publisher : "*"
Publisher ..> Author : "1"
note right of Book : Library domain
@enduml