@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
interface Book {
  +float status
  #String address
  +saveTotal()
}
class Author {
  -long note
  -float id
  +cancelDuration()
  +processCode()
}
class Fine {
  -float duration
  #boolean amount
  +sendStatus()
  +deleteDuration()
}
class Publisher {
  +Date code
  +float score
  +boolean level
  -long name
  +sendStatus()
  +calculateCode()
  +sendLevel()
}
Book --* Publisher
Fine --o Publisher
Fine ..> Book : "0..1"
@enduml