@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
interface Return {
  #Date description
  #boolean updatedAt
  #long level
  -long amount
  #int total
  +getTotal()
  +getCode()
  +updateId()
}
class Product {
  #long amount
  +int address
  +sendQuantity()
  +saveTotal()
  +sendPrice()
  +cancelStatus()
}
abstract class Coupon {
  #String updatedAt
  +float name
  #int level
  +boolean duration
  #Date description
  +createStatus()
  +updatePrice()
  +deleteScore()
}
class Review {
  #float price
  +int duration
  #long email
  +Date address
  #double total
  +validatePrice()
  +cancelLevel()
  +cancelCreatedat()
  +deleteId()
}
abstract class Wishlist {
  +int code
  +Date amount
  +cancelAmount()
  +setCreatedat()
  +createDuration()
  +calculateId()
}
class Supplier {
  -int amount
  +Date name
  +getAmount()
  +createDuration()
  +cancelType()
}
Review ..> Product : "*"
Supplier --> Return : "1"
Wishlist --> Supplier : "*"
Review --o Return
@enduml