@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
component "Classroom Service" as C_ClassroomService
component "Department Service" as C_DepartmentService
component "Assignment Service" as C_AssignmentService
component "Grade Service" as C_GradeService
component "Attendance Service" as C_AttendanceService
component "Course Service" as C_CourseService
component "Library Service" as C_LibraryService
database "Education DB" as DB_education
C_ClassroomService --> DB_education
C_DepartmentService --> DB_education
C_AssignmentService --> DB_education
C_GradeService --> DB_education
C_AttendanceService --> DB_education
C_LibraryService --> DB_education
C_AssignmentService ..> C_DepartmentService : gRPC
C_ClassroomService ..> C_AttendanceService : gRPC
C_LibraryService ..> C_AssignmentService : REST
C_GradeService ..> C_LibraryService : gRPC
@enduml