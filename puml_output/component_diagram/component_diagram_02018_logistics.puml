@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
component "Inventory Service" as C_InventoryService
component "DeliveryNote Service" as C_DeliveryNoteService
component "Vehicle Service" as C_VehicleService
component "Depot Service" as C_DepotService
component "Shipment Service" as C_ShipmentService
database "Logistics DB" as DB_logistics
C_InventoryService --> DB_logistics
C_DeliveryNoteService --> DB_logistics
C_DepotService --> DB_logistics
C_ShipmentService --> DB_logistics
C_DeliveryNoteService ..> C_ShipmentService : gRPC
C_DepotService ..> C_InventoryService : REST
C_InventoryService ..> C_DeliveryNoteService : HTTP
C_DeliveryNoteService ..> C_InventoryService : REST
@enduml