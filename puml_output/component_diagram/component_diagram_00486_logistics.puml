@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
component "Warehouse Service" as C_WarehouseService
component "Driver Service" as C_DriverService
component "Vehicle Service" as C_VehicleService
component "Shipment Service" as C_ShipmentService
component "Customer Service" as C_CustomerService
component "Inventory Service" as C_InventoryService
component "Depot Service" as C_DepotService
database "Logistics DB" as DB_logistics
C_WarehouseService --> DB_logistics
C_DriverService --> DB_logistics
C_VehicleService --> DB_logistics
C_CustomerService --> DB_logistics
C_InventoryService --> DB_logistics
C_DepotService ..> C_WarehouseService : HTTP
C_InventoryService ..> C_ShipmentService : gRPC
C_DepotService ..> C_DriverService : REST
C_ShipmentService ..> C_DepotService : MQ
C_DepotService ..> C_CustomerService : REST
@enduml