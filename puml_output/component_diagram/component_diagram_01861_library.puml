@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
component "Loan Service" as C_LoanService
component "Reservation Service" as C_ReservationService
component "Shelf Service" as C_ShelfService
component "Renewal Service" as C_RenewalService
component "Book Service" as C_BookService
database "Library DB" as DB_library
C_LoanService --> DB_library
C_ReservationService --> DB_library
C_RenewalService --> DB_library
C_ReservationService ..> C_LoanService : REST
C_RenewalService ..> C_LoanService : REST
C_ShelfService ..> C_LoanService : HTTP
C_LoanService ..> C_RenewalService : gRPC
@enduml