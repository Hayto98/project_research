@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
component "Category Service" as C_CategoryService
component "Warehouse Service" as C_WarehouseService
component "Review Service" as C_ReviewService
component "Supplier Service" as C_SupplierService
component "Payment Service" as C_PaymentService
component "Wishlist Service" as C_WishlistService
database "Ecommerce DB" as DB_ecommerce
C_CategoryService --> DB_ecommerce
C_WarehouseService --> DB_ecommerce
C_PaymentService --> DB_ecommerce
C_WishlistService --> DB_ecommerce
C_CategoryService ..> C_WarehouseService : HTTP
C_CategoryService ..> C_ReviewService : gRPC
C_WarehouseService ..> C_PaymentService : REST
@enduml