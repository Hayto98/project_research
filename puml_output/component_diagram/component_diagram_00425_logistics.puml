@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
component "Depot Service" as C_DepotService
component "Route Service" as C_RouteService
component "Driver Service" as C_DriverService
component "Customer Service" as C_CustomerService
component "Tracking Service" as C_TrackingService
component "Shipment Service" as C_ShipmentService
database "Logistics DB" as DB_logistics
C_DepotService --> DB_logistics
C_RouteService --> DB_logistics
C_DriverService --> DB_logistics
C_CustomerService --> DB_logistics
C_TrackingService --> DB_logistics
C_ShipmentService --> DB_logistics
C_DepotService ..> C_TrackingService : gRPC
C_RouteService ..> C_DepotService : gRPC
C_DriverService ..> C_RouteService : HTTP
C_CustomerService ..> C_DepotService : HTTP
C_DepotService ..> C_RouteService : MQ
@enduml