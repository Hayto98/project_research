@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
component "Package Service" as C_PackageService
component "Depot Service" as C_DepotService
component "Warehouse Service" as C_WarehouseService
component "Tracking Service" as C_TrackingService
component "DeliveryNote Service" as C_DeliveryNoteService
database "Logistics DB" as DB_logistics
C_PackageService --> DB_logistics
C_WarehouseService --> DB_logistics
C_DeliveryNoteService --> DB_logistics
C_WarehouseService ..> C_PackageService : HTTP
C_DepotService ..> C_TrackingService : gRPC
C_DeliveryNoteService ..> C_TrackingService : REST
C_PackageService ..> C_DepotService : REST
@enduml