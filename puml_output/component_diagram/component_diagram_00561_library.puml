@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
component "Shelf Service" as C_ShelfService
component "Author Service" as C_AuthorService
component "Publisher Service" as C_PublisherService
component "Catalog Service" as C_CatalogService
component "Branch Service" as C_BranchService
database "Library DB" as DB_library
C_ShelfService --> DB_library
C_AuthorService --> DB_library
C_PublisherService --> DB_library
C_CatalogService --> DB_library
C_BranchService --> DB_library
C_PublisherService ..> C_AuthorService : REST
C_CatalogService ..> C_AuthorService : HTTP
C_BranchService ..> C_AuthorService : MQ
C_CatalogService ..> C_ShelfService : MQ
@enduml