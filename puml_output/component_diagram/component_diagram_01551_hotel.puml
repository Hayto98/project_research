@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
component "Amenity Service" as C_AmenityService
component "CheckOut Service" as C_CheckOutService
component "Service Service" as C_ServiceService
component "Reservation Service" as C_ReservationService
component "Booking Service" as C_BookingService
component "Staff Service" as C_StaffService
component "CheckIn Service" as C_CheckInService
database "Hotel DB" as DB_hotel
C_ServiceService --> DB_hotel
C_BookingService --> DB_hotel
C_StaffService --> DB_hotel
C_CheckInService --> DB_hotel
C_BookingService ..> C_ServiceService : MQ
C_CheckOutService ..> C_BookingService : gRPC
C_CheckInService ..> C_ServiceService : HTTP
@enduml