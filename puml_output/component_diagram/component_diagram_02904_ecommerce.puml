@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
component "Return Service" as C_ReturnService
component "Review Service" as C_ReviewService
component "Warehouse Service" as C_WarehouseService
component "Cart Service" as C_CartService
component "Order Service" as C_OrderService
component "Shipment Service" as C_ShipmentService
database "Ecommerce DB" as DB_ecommerce
C_ReturnService --> DB_ecommerce
C_WarehouseService --> DB_ecommerce
C_CartService --> DB_ecommerce
C_OrderService --> DB_ecommerce
C_ShipmentService --> DB_ecommerce
C_OrderService ..> C_ShipmentService : HTTP
C_CartService ..> C_ReturnService : MQ
C_OrderService ..> C_WarehouseService : HTTP
@enduml