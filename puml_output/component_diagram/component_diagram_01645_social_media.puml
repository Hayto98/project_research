@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
component "Report Service" as C_ReportService
component "Hashtag Service" as C_HashtagService
component "Message Service" as C_MessageService
component "Album Service" as C_AlbumService
component "Like Service" as C_LikeService
component "Follower Service" as C_FollowerService
database "Social Media DB" as DB_social_media
C_ReportService --> DB_social_media
C_MessageService --> DB_social_media
C_LikeService --> DB_social_media
C_FollowerService ..> C_LikeService : HTTP
C_MessageService ..> C_AlbumService : REST
C_HashtagService ..> C_FollowerService : REST
C_ReportService ..> C_HashtagService : gRPC
C_ReportService ..> C_LikeService : REST
@enduml