@startuml
skinparam monochrome true
skinparam shadowing true
component "Hospital Service" as C_HospitalService
component "Nurse Service" as C_NurseService
component "Patient Service" as C_PatientService
component "Insurance Service" as C_InsuranceService
component "Treatment Service" as C_TreatmentService
database "Healthcare DB" as DB_healthcare
C_PatientService --> DB_healthcare
C_InsuranceService --> DB_healthcare
C_TreatmentService --> DB_healthcare
C_PatientService ..> C_InsuranceService : gRPC
C_HospitalService ..> C_InsuranceService : HTTP
C_TreatmentService ..> C_InsuranceService : gRPC
C_InsuranceService ..> C_HospitalService : REST
@enduml