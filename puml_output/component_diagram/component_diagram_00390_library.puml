@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
component "Shelf Service" as C_ShelfService
component "Renewal Service" as C_RenewalService
component "Book Service" as C_BookService
component "Reservation Service" as C_ReservationService
component "Branch Service" as C_BranchService
component "Loan Service" as C_LoanService
database "Library DB" as DB_library
C_ShelfService --> DB_library
C_RenewalService --> DB_library
C_BookService --> DB_library
C_BranchService --> DB_library
C_BranchService ..> C_ShelfService : REST
C_BranchService ..> C_ShelfService : gRPC
C_BranchService ..> C_BookService : MQ
@enduml