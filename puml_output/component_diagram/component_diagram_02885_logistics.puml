@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
component "DeliveryNote Service" as C_DeliveryNoteService
component "Depot Service" as C_DepotService
component "Customer Service" as C_CustomerService
component "Route Service" as C_RouteService
component "Driver Service" as C_DriverService
component "Inventory Service" as C_InventoryService
component "Manifest Service" as C_ManifestService
database "Logistics DB" as DB_logistics
C_DepotService --> DB_logistics
C_CustomerService --> DB_logistics
C_RouteService --> DB_logistics
C_DriverService --> DB_logistics
C_InventoryService --> DB_logistics
C_InventoryService ..> C_DriverService : MQ
C_DepotService ..> C_ManifestService : REST
C_DepotService ..> C_DeliveryNoteService : HTTP
C_CustomerService ..> C_RouteService : gRPC
C_DriverService ..> C_DeliveryNoteService : HTTP
C_RouteService ..> C_CustomerService : REST
@enduml