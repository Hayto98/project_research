@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
component "Beneficiary Service" as C_BeneficiaryService
component "Interest Service" as C_InterestService
component "Transaction Service" as C_TransactionService
component "Loan Service" as C_LoanService
component "Transfer Service" as C_TransferService
database "Banking DB" as DB_banking
C_BeneficiaryService --> DB_banking
C_TransactionService --> DB_banking
C_TransferService --> DB_banking
C_TransactionService ..> C_BeneficiaryService : gRPC
C_BeneficiaryService ..> C_TransactionService : gRPC
C_InterestService ..> C_TransferService : gRPC
C_BeneficiaryService ..> C_TransactionService : HTTP
@enduml