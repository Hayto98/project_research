@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
component "Interest Service" as C_InterestService
component "Account Service" as C_AccountService
component "Teller Service" as C_TellerService
component "Beneficiary Service" as C_BeneficiaryService
component "Card Service" as C_CardService
database "Banking DB" as DB_banking
C_InterestService --> DB_banking
C_AccountService --> DB_banking
C_TellerService --> DB_banking
C_CardService --> DB_banking
C_CardService ..> C_InterestService : HTTP
C_AccountService ..> C_InterestService : HTTP
C_InterestService ..> C_TellerService : HTTP
@enduml