@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
component "Cart Service" as C_CartService
component "Product Service" as C_ProductService
component "Order Service" as C_OrderService
component "Payment Service" as C_PaymentService
component "Category Service" as C_CategoryService
component "Warehouse Service" as C_WarehouseService
component "Shipment Service" as C_ShipmentService
database "Ecommerce DB" as DB_ecommerce
C_PaymentService --> DB_ecommerce
C_CategoryService --> DB_ecommerce
C_WarehouseService --> DB_ecommerce
C_ShipmentService --> DB_ecommerce
C_OrderService ..> C_CategoryService : MQ
C_ShipmentService ..> C_OrderService : MQ
C_ShipmentService ..> C_ProductService : HTTP
C_WarehouseService ..> C_OrderService : HTTP
@enduml