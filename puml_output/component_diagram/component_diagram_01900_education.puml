@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
component "Student Service" as C_StudentService
component "Attendance Service" as C_AttendanceService
component "Book Service" as C_BookService
component "Department Service" as C_DepartmentService
component "Classroom Service" as C_ClassroomService
component "Exam Service" as C_ExamService
component "Course Service" as C_CourseService
database "Education DB" as DB_education
C_StudentService --> DB_education
C_AttendanceService --> DB_education
C_CourseService --> DB_education
C_DepartmentService ..> C_AttendanceService : REST
C_ExamService ..> C_AttendanceService : gRPC
C_ExamService ..> C_ClassroomService : HTTP
C_ClassroomService ..> C_DepartmentService : HTTP
C_CourseService ..> C_ClassroomService : MQ
C_BookService ..> C_StudentService : HTTP
@enduml