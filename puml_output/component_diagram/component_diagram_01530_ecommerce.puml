@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
component "Supplier Service" as C_SupplierService
component "Order Service" as C_OrderService
component "Payment Service" as C_PaymentService
component "Product Service" as C_ProductService
component "Customer Service" as C_CustomerService
component "Review Service" as C_ReviewService
component "Cart Service" as C_CartService
database "Ecommerce DB" as DB_ecommerce
C_OrderService --> DB_ecommerce
C_PaymentService --> DB_ecommerce
C_ProductService --> DB_ecommerce
C_ReviewService --> DB_ecommerce
C_SupplierService ..> C_ProductService : gRPC
C_CustomerService ..> C_CartService : gRPC
C_CartService ..> C_OrderService : MQ
C_PaymentService ..> C_SupplierService : MQ
C_ReviewService ..> C_SupplierService : gRPC
C_PaymentService ..> C_CustomerService : REST
@enduml