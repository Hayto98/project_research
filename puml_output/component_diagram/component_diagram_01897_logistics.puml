@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
component "Customer Service" as C_CustomerService
component "Package Service" as C_PackageService
component "Route Service" as C_RouteService
component "Shipment Service" as C_ShipmentService
component "Tracking Service" as C_TrackingService
component "Depot Service" as C_DepotService
component "Inventory Service" as C_InventoryService
database "Logistics DB" as DB_logistics
C_CustomerService --> DB_logistics
C_RouteService --> DB_logistics
C_ShipmentService --> DB_logistics
C_DepotService --> DB_logistics
C_InventoryService --> DB_logistics
C_PackageService ..> C_TrackingService : REST
C_PackageService ..> C_DepotService : gRPC
C_InventoryService ..> C_DepotService : REST
C_RouteService ..> C_CustomerService : REST
C_ShipmentService ..> C_TrackingService : MQ
C_CustomerService ..> C_PackageService : MQ
@enduml