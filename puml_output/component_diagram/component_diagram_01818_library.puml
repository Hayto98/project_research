@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
component "Renewal Service" as C_RenewalService
component "Reservation Service" as C_ReservationService
component "Loan Service" as C_LoanService
component "Fine Service" as C_FineService
component "Book Service" as C_BookService
component "Author Service" as C_AuthorService
database "Library DB" as DB_library
C_RenewalService --> DB_library
C_ReservationService --> DB_library
C_FineService --> DB_library
C_BookService --> DB_library
C_AuthorService --> DB_library
C_BookService ..> C_ReservationService : gRPC
C_ReservationService ..> C_AuthorService : MQ
C_AuthorService ..> C_ReservationService : MQ
C_ReservationService ..> C_RenewalService : HTTP
C_LoanService ..> C_ReservationService : REST
@enduml