@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
component "Guest Service" as C_GuestService
component "Amenity Service" as C_AmenityService
component "Housekeeping Service" as C_HousekeepingService
component "Reservation Service" as C_ReservationService
component "Booking Service" as C_BookingService
database "Hotel DB" as DB_hotel
C_AmenityService --> DB_hotel
C_HousekeepingService --> DB_hotel
C_ReservationService --> DB_hotel
C_AmenityService ..> C_BookingService : gRPC
C_HousekeepingService ..> C_BookingService : MQ
C_ReservationService ..> C_GuestService : HTTP
C_GuestService ..> C_BookingService : MQ
@enduml