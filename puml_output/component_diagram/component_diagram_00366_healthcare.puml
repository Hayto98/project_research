@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
component "Appointment Service" as C_AppointmentService
component "Nurse Service" as C_NurseService
component "Diagnosis Service" as C_DiagnosisService
component "Ward Service" as C_WardService
database "Healthcare DB" as DB_healthcare
C_AppointmentService --> DB_healthcare
C_NurseService --> DB_healthcare
C_WardService --> DB_healthcare
C_DiagnosisService ..> C_AppointmentService : MQ
C_WardService ..> C_NurseService : MQ
C_DiagnosisService ..> C_NurseService : gRPC
@enduml