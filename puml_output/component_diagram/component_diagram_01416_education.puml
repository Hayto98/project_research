@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
component "Department Service" as C_DepartmentService
component "Course Service" as C_CourseService
component "Grade Service" as C_GradeService
component "Exam Service" as C_ExamService
database "Education DB" as DB_education
C_CourseService --> DB_education
C_GradeService --> DB_education
C_ExamService --> DB_education
C_GradeService ..> C_DepartmentService : MQ
C_GradeService ..> C_DepartmentService : gRPC
@enduml