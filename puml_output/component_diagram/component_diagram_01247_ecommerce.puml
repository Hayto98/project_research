@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
component "Cart Service" as C_CartService
component "Review Service" as C_ReviewService
component "Category Service" as C_CategoryService
component "Return Service" as C_ReturnService
component "Customer Service" as C_CustomerService
component "Payment Service" as C_PaymentService
database "Ecommerce DB" as DB_ecommerce
C_CartService --> DB_ecommerce
C_ReviewService --> DB_ecommerce
C_PaymentService --> DB_ecommerce
C_ReturnService ..> C_CategoryService : REST
C_ReturnService ..> C_ReviewService : HTTP
C_CategoryService ..> C_CustomerService : MQ
C_CustomerService ..> C_ReviewService : gRPC
C_ReviewService ..> C_CustomerService : REST
@enduml