@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
component "Reservation Service" as C_ReservationService
component "Service Service" as C_ServiceService
component "Restaurant Service" as C_RestaurantService
component "Booking Service" as C_BookingService
component "CheckIn Service" as C_CheckInService
component "CheckOut Service" as C_CheckOutService
component "Payment Service" as C_PaymentService
database "Hotel DB" as DB_hotel
C_ReservationService --> DB_hotel
C_ServiceService --> DB_hotel
C_RestaurantService --> DB_hotel
C_CheckInService --> DB_hotel
C_CheckOutService --> DB_hotel
C_PaymentService --> DB_hotel
C_ServiceService ..> C_CheckInService : REST
C_BookingService ..> C_ReservationService : MQ
C_ServiceService ..> C_ReservationService : HTTP
C_CheckOutService ..> C_ReservationService : MQ
C_PaymentService ..> C_BookingService : HTTP
@enduml