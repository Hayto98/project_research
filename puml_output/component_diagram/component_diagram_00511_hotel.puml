@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
component "Reservation Service" as C_ReservationService
component "Amenity Service" as C_AmenityService
component "Booking Service" as C_BookingService
component "Housekeeping Service" as C_HousekeepingService
database "Hotel DB" as DB_hotel
C_ReservationService --> DB_hotel
C_BookingService --> DB_hotel
C_HousekeepingService --> DB_hotel
C_AmenityService ..> C_BookingService : HTTP
C_HousekeepingService ..> C_ReservationService : gRPC
C_BookingService ..> C_AmenityService : REST
@enduml