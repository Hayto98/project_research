@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
component "Amenity Service" as C_AmenityService
component "Payment Service" as C_PaymentService
component "Staff Service" as C_StaffService
component "Service Service" as C_ServiceService
component "Reservation Service" as C_ReservationService
component "Room Service" as C_RoomService
component "Housekeeping Service" as C_HousekeepingService
database "Hotel DB" as DB_hotel
C_AmenityService --> DB_hotel
C_StaffService --> DB_hotel
C_ServiceService --> DB_hotel
C_ReservationService --> DB_hotel
C_RoomService --> DB_hotel
C_HousekeepingService --> DB_hotel
C_ReservationService ..> C_StaffService : MQ
C_PaymentService ..> C_StaffService : MQ
C_AmenityService ..> C_ReservationService : gRPC
@enduml