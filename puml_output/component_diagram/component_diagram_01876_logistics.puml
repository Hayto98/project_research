@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
component "Driver Service" as C_DriverService
component "Package Service" as C_PackageService
component "DeliveryNote Service" as C_DeliveryNoteService
component "Vehicle Service" as C_VehicleService
component "Depot Service" as C_DepotService
component "Warehouse Service" as C_WarehouseService
database "Logistics DB" as DB_logistics
C_PackageService --> DB_logistics
C_DeliveryNoteService --> DB_logistics
C_VehicleService --> DB_logistics
C_WarehouseService --> DB_logistics
C_WarehouseService ..> C_DeliveryNoteService : MQ
C_DepotService ..> C_PackageService : HTTP
C_WarehouseService ..> C_DepotService : gRPC
C_PackageService ..> C_WarehouseService : HTTP
@enduml