@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
component "Shipment Service" as C_ShipmentService
component "Driver Service" as C_DriverService
component "Depot Service" as C_DepotService
component "Route Service" as C_RouteService
component "DeliveryNote Service" as C_DeliveryNoteService
component "Warehouse Service" as C_WarehouseService
component "Inventory Service" as C_InventoryService
database "Logistics DB" as DB_logistics
C_DriverService --> DB_logistics
C_InventoryService --> DB_logistics
C_DriverService ..> C_DepotService : REST
C_DriverService ..> C_InventoryService : MQ
C_ShipmentService ..> C_DriverService : HTTP
C_InventoryService ..> C_RouteService : gRPC
C_DepotService ..> C_DeliveryNoteService : REST
@enduml