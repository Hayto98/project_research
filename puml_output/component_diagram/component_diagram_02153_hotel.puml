@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
component "Reservation Service" as C_ReservationService
component "Booking Service" as C_BookingService
component "Housekeeping Service" as C_HousekeepingService
component "Invoice Service" as C_InvoiceService
component "Staff Service" as C_StaffService
database "Hotel DB" as DB_hotel
C_ReservationService --> DB_hotel
C_BookingService --> DB_hotel
C_InvoiceService --> DB_hotel
C_StaffService --> DB_hotel
C_StaffService ..> C_HousekeepingService : HTTP
C_ReservationService ..> C_StaffService : HTTP
C_StaffService ..> C_ReservationService : REST
@enduml