@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
component "Profile Service" as C_ProfileService
component "Comment Service" as C_CommentService
component "Album Service" as C_AlbumService
component "Post Service" as C_PostService
component "Follower Service" as C_FollowerService
component "Story Service" as C_StoryService
database "Social Media DB" as DB_social_media
C_ProfileService --> DB_social_media
C_FollowerService --> DB_social_media
C_StoryService --> DB_social_media
C_ProfileService ..> C_StoryService : MQ
C_CommentService ..> C_ProfileService : MQ
C_FollowerService ..> C_ProfileService : MQ
C_PostService ..> C_ProfileService : MQ
C_StoryService ..> C_PostService : HTTP
@enduml