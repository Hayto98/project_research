@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
component "Renewal Service" as C_RenewalService
component "Librarian Service" as C_LibrarianService
component "Loan Service" as C_LoanService
component "Book Service" as C_BookService
database "Library DB" as DB_library
C_LibrarianService --> DB_library
C_LoanService --> DB_library
C_BookService --> DB_library
C_RenewalService ..> C_LibrarianService : MQ
C_BookService ..> C_LibrarianService : MQ
C_LoanService ..> C_BookService : REST
@enduml