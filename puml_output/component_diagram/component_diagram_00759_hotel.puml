@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
component "Service Service" as C_ServiceService
component "Guest Service" as C_GuestService
component "Payment Service" as C_PaymentService
component "Housekeeping Service" as C_HousekeepingService
component "Invoice Service" as C_InvoiceService
component "Staff Service" as C_StaffService
component "Room Service" as C_RoomService
database "Hotel DB" as DB_hotel
C_ServiceService --> DB_hotel
C_GuestService --> DB_hotel
C_PaymentService --> DB_hotel
C_HousekeepingService --> DB_hotel
C_InvoiceService --> DB_hotel
C_RoomService --> DB_hotel
C_StaffService ..> C_HousekeepingService : gRPC
C_RoomService ..> C_HousekeepingService : REST
C_ServiceService ..> C_StaffService : MQ
C_StaffService ..> C_RoomService : MQ
C_PaymentService ..> C_GuestService : REST
C_PaymentService ..> C_HousekeepingService : gRPC
@enduml