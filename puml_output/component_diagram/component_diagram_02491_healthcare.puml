@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
component "Patient Service" as C_PatientService
component "Billing Service" as C_BillingService
component "LabTest Service" as C_LabTestService
component "Treatment Service" as C_TreatmentService
component "Doctor Service" as C_DoctorService
database "Healthcare DB" as DB_healthcare
C_PatientService --> DB_healthcare
C_BillingService --> DB_healthcare
C_TreatmentService --> DB_healthcare
C_DoctorService --> DB_healthcare
C_BillingService ..> C_DoctorService : MQ
C_LabTestService ..> C_PatientService : gRPC
C_TreatmentService ..> C_LabTestService : MQ
C_PatientService ..> C_LabTestService : MQ
@enduml