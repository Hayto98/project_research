@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
component "Shelf Service" as C_ShelfService
component "Branch Service" as C_BranchService
component "Publisher Service" as C_PublisherService
component "Catalog Service" as C_CatalogService
database "Library DB" as DB_library
C_ShelfService --> DB_library
C_PublisherService --> DB_library
C_CatalogService --> DB_library
C_CatalogService ..> C_BranchService : HTTP
C_CatalogService ..> C_ShelfService : gRPC
@enduml