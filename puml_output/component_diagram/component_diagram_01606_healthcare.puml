@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
component "Insurance Service" as C_InsuranceService
component "Billing Service" as C_BillingService
component "Treatment Service" as C_TreatmentService
component "Doctor Service" as C_DoctorService
component "Appointment Service" as C_AppointmentService
component "Diagnosis Service" as C_DiagnosisService
component "MedicalRecord Service" as C_MedicalRecordService
database "Healthcare DB" as DB_healthcare
C_BillingService --> DB_healthcare
C_TreatmentService --> DB_healthcare
C_DoctorService --> DB_healthcare
C_DiagnosisService --> DB_healthcare
C_DoctorService ..> C_TreatmentService : HTTP
C_InsuranceService ..> C_AppointmentService : REST
C_MedicalRecordService ..> C_AppointmentService : gRPC
C_InsuranceService ..> C_TreatmentService : HTTP
C_TreatmentService ..> C_BillingService : MQ
C_BillingService ..> C_DoctorService : gRPC
@enduml