@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
component "Category Service" as C_CategoryService
component "Warehouse Service" as C_WarehouseService
component "Invoice Service" as C_InvoiceService
component "Shipment Service" as C_ShipmentService
database "Ecommerce DB" as DB_ecommerce
C_CategoryService --> DB_ecommerce
C_WarehouseService --> DB_ecommerce
C_InvoiceService --> DB_ecommerce
C_ShipmentService --> DB_ecommerce
C_InvoiceService ..> C_WarehouseService : HTTP
C_CategoryService ..> C_WarehouseService : MQ
C_ShipmentService ..> C_CategoryService : REST
@enduml