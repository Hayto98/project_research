@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
component "Statement Service" as C_StatementService
component "Loan Service" as C_LoanService
component "Customer Service" as C_CustomerService
component "Card Service" as C_CardService
component "Transfer Service" as C_TransferService
component "Beneficiary Service" as C_BeneficiaryService
database "Banking DB" as DB_banking
C_StatementService --> DB_banking
C_LoanService --> DB_banking
C_CustomerService --> DB_banking
C_TransferService --> DB_banking
C_CustomerService ..> C_BeneficiaryService : HTTP
C_CardService ..> C_LoanService : REST
C_CardService ..> C_StatementService : HTTP
C_BeneficiaryService ..> C_TransferService : gRPC
@enduml