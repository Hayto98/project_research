@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
component "LabTest Service" as C_LabTestService
component "Nurse Service" as C_NurseService
component "Treatment Service" as C_TreatmentService
component "Hospital Service" as C_HospitalService
component "Prescription Service" as C_PrescriptionService
component "Ward Service" as C_WardService
component "Diagnosis Service" as C_DiagnosisService
database "Healthcare DB" as DB_healthcare
C_LabTestService --> DB_healthcare
C_HospitalService --> DB_healthcare
C_PrescriptionService --> DB_healthcare
C_WardService --> DB_healthcare
C_DiagnosisService --> DB_healthcare
C_TreatmentService ..> C_LabTestService : HTTP
C_TreatmentService ..> C_PrescriptionService : gRPC
C_NurseService ..> C_LabTestService : HTTP
C_PrescriptionService ..> C_LabTestService : MQ
@enduml