@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
component "Category Service" as C_CategoryService
component "Shipment Service" as C_ShipmentService
component "Order Service" as C_OrderService
component "Return Service" as C_ReturnService
component "Warehouse Service" as C_WarehouseService
component "Product Service" as C_ProductService
component "Invoice Service" as C_InvoiceService
database "Ecommerce DB" as DB_ecommerce
C_CategoryService --> DB_ecommerce
C_ShipmentService --> DB_ecommerce
C_OrderService --> DB_ecommerce
C_WarehouseService --> DB_ecommerce
C_CategoryService ..> C_WarehouseService : REST
C_OrderService ..> C_ShipmentService : MQ
C_WarehouseService ..> C_CategoryService : REST
C_ProductService ..> C_CategoryService : gRPC
C_WarehouseService ..> C_ReturnService : REST
@enduml