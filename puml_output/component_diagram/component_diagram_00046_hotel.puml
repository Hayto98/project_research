@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
component "Staff Service" as C_StaffService
component "Invoice Service" as C_InvoiceService
component "Reservation Service" as C_ReservationService
component "Service Service" as C_ServiceService
component "Payment Service" as C_PaymentService
database "Hotel DB" as DB_hotel
C_StaffService --> DB_hotel
C_InvoiceService --> DB_hotel
C_ReservationService --> DB_hotel
C_PaymentService --> DB_hotel
C_StaffService ..> C_PaymentService : gRPC
C_InvoiceService ..> C_StaffService : MQ
C_PaymentService ..> C_ReservationService : gRPC
C_ServiceService ..> C_PaymentService : gRPC
@enduml