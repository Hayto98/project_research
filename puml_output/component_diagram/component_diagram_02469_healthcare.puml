@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
component "Insurance Service" as C_InsuranceService
component "Doctor Service" as C_DoctorService
component "MedicalRecord Service" as C_MedicalRecordService
component "Hospital Service" as C_HospitalService
component "Appointment Service" as C_AppointmentService
component "Treatment Service" as C_TreatmentService
component "Prescription Service" as C_PrescriptionService
database "Healthcare DB" as DB_healthcare
C_DoctorService --> DB_healthcare
C_HospitalService --> DB_healthcare
C_AppointmentService --> DB_healthcare
C_TreatmentService --> DB_healthcare
C_HospitalService ..> C_InsuranceService : MQ
C_PrescriptionService ..> C_TreatmentService : MQ
C_TreatmentService ..> C_PrescriptionService : HTTP
C_DoctorService ..> C_TreatmentService : REST
C_AppointmentService ..> C_MedicalRecordService : gRPC
C_AppointmentService ..> C_TreatmentService : REST
@enduml