@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
component "Renewal Service" as C_RenewalService
component "Member Service" as C_MemberService
component "Shelf Service" as C_ShelfService
component "Librarian Service" as C_LibrarianService
component "Author Service" as C_AuthorService
component "Reservation Service" as C_ReservationService
database "Library DB" as DB_library
C_MemberService --> DB_library
C_ShelfService --> DB_library
C_LibrarianService --> DB_library
C_AuthorService --> DB_library
C_ReservationService --> DB_library
C_ShelfService ..> C_MemberService : REST
C_ReservationService ..> C_MemberService : REST
C_LibrarianService ..> C_ShelfService : REST
@enduml