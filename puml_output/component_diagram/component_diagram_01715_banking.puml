@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
component "Statement Service" as C_StatementService
component "Customer Service" as C_CustomerService
component "Branch Service" as C_BranchService
component "Interest Service" as C_InterestService
component "Withdrawal Service" as C_WithdrawalService
database "Banking DB" as DB_banking
C_StatementService --> DB_banking
C_BranchService --> DB_banking
C_WithdrawalService --> DB_banking
C_CustomerService ..> C_BranchService : REST
C_BranchService ..> C_WithdrawalService : MQ
C_WithdrawalService ..> C_InterestService : gRPC
C_WithdrawalService ..> C_InterestService : gRPC
@enduml