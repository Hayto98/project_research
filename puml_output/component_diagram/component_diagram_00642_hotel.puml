@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
component "CheckOut Service" as C_CheckOutService
component "Booking Service" as C_BookingService
component "Invoice Service" as C_InvoiceService
component "Room Service" as C_RoomService
component "Housekeeping Service" as C_HousekeepingService
component "Service Service" as C_ServiceService
database "Hotel DB" as DB_hotel
C_CheckOutService --> DB_hotel
C_BookingService --> DB_hotel
C_RoomService --> DB_hotel
C_HousekeepingService --> DB_hotel
C_ServiceService --> DB_hotel
C_ServiceService ..> C_BookingService : HTTP
C_BookingService ..> C_InvoiceService : REST
C_ServiceService ..> C_RoomService : HTTP
C_InvoiceService ..> C_HousekeepingService : gRPC
C_BookingService ..> C_InvoiceService : REST
@enduml