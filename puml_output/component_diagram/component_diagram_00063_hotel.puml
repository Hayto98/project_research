@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
component "Staff Service" as C_StaffService
component "Guest Service" as C_GuestService
component "CheckOut Service" as C_CheckOutService
component "Housekeeping Service" as C_HousekeepingService
component "Payment Service" as C_PaymentService
component "Booking Service" as C_BookingService
database "Hotel DB" as DB_hotel
C_GuestService --> DB_hotel
C_CheckOutService --> DB_hotel
C_PaymentService --> DB_hotel
C_BookingService ..> C_PaymentService : gRPC
C_HousekeepingService ..> C_PaymentService : REST
C_PaymentService ..> C_CheckOutService : HTTP
C_PaymentService ..> C_BookingService : gRPC
@enduml