@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
component "Teller Service" as C_TellerService
component "Branch Service" as C_BranchService
component "Beneficiary Service" as C_BeneficiaryService
component "Deposit Service" as C_DepositService
component "Statement Service" as C_StatementService
component "Withdrawal Service" as C_WithdrawalService
database "Banking DB" as DB_banking
C_BeneficiaryService --> DB_banking
C_DepositService --> DB_banking
C_BeneficiaryService ..> C_StatementService : HTTP
C_BeneficiaryService ..> C_BranchService : REST
C_DepositService ..> C_StatementService : REST
C_StatementService ..> C_DepositService : MQ
C_BranchService ..> C_BeneficiaryService : gRPC
@enduml