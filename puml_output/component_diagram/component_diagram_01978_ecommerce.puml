@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
component "Cart Service" as C_CartService
component "Invoice Service" as C_InvoiceService
component "Warehouse Service" as C_WarehouseService
component "Product Service" as C_ProductService
component "Wishlist Service" as C_WishlistService
database "Ecommerce DB" as DB_ecommerce
C_InvoiceService --> DB_ecommerce
C_ProductService --> DB_ecommerce
C_CartService ..> C_WarehouseService : MQ
C_ProductService ..> C_CartService : REST
C_CartService ..> C_WishlistService : REST
C_WishlistService ..> C_WarehouseService : MQ
@enduml