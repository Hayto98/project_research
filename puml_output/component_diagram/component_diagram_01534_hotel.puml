@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
component "Payment Service" as C_PaymentService
component "Staff Service" as C_StaffService
component "Restaurant Service" as C_RestaurantService
component "CheckOut Service" as C_CheckOutService
component "Room Service" as C_RoomService
component "CheckIn Service" as C_CheckInService
component "Booking Service" as C_BookingService
database "Hotel DB" as DB_hotel
C_RestaurantService --> DB_hotel
C_CheckOutService --> DB_hotel
C_CheckInService --> DB_hotel
C_BookingService --> DB_hotel
C_StaffService ..> C_RestaurantService : REST
C_PaymentService ..> C_CheckInService : HTTP
@enduml