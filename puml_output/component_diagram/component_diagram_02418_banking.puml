@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
component "Branch Service" as C_BranchService
component "Transaction Service" as C_TransactionService
component "Loan Service" as C_LoanService
component "Account Service" as C_AccountService
component "Statement Service" as C_StatementService
component "Customer Service" as C_CustomerService
database "Banking DB" as DB_banking
C_BranchService --> DB_banking
C_TransactionService --> DB_banking
C_LoanService --> DB_banking
C_StatementService --> DB_banking
C_CustomerService --> DB_banking
C_BranchService ..> C_TransactionService : REST
C_StatementService ..> C_BranchService : MQ
C_TransactionService ..> C_LoanService : gRPC
C_AccountService ..> C_CustomerService : MQ
C_CustomerService ..> C_AccountService : REST
@enduml