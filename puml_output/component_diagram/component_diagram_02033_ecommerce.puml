@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
component "Order Service" as C_OrderService
component "Coupon Service" as C_CouponService
component "Warehouse Service" as C_WarehouseService
component "Shipment Service" as C_ShipmentService
database "Ecommerce DB" as DB_ecommerce
C_OrderService --> DB_ecommerce
C_CouponService --> DB_ecommerce
C_ShipmentService ..> C_WarehouseService : MQ
C_CouponService ..> C_OrderService : MQ
C_CouponService ..> C_ShipmentService : REST
@enduml