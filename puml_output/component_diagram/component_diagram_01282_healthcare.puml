@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
component "Treatment Service" as C_TreatmentService
component "Nurse Service" as C_NurseService
component "Diagnosis Service" as C_DiagnosisService
component "Hospital Service" as C_HospitalService
component "MedicalRecord Service" as C_MedicalRecordService
component "Billing Service" as C_BillingService
database "Healthcare DB" as DB_healthcare
C_NurseService --> DB_healthcare
C_DiagnosisService --> DB_healthcare
C_MedicalRecordService --> DB_healthcare
C_BillingService --> DB_healthcare
C_TreatmentService ..> C_BillingService : REST
C_BillingService ..> C_MedicalRecordService : HTTP
C_BillingService ..> C_MedicalRecordService : REST
@enduml