@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
component "Nurse Service" as C_NurseService
component "LabTest Service" as C_LabTestService
component "Billing Service" as C_BillingService
component "Prescription Service" as C_PrescriptionService
component "Insurance Service" as C_InsuranceService
component "Ward Service" as C_WardService
database "Healthcare DB" as DB_healthcare
C_NurseService --> DB_healthcare
C_PrescriptionService --> DB_healthcare
C_WardService --> DB_healthcare
C_InsuranceService ..> C_NurseService : HTTP
C_InsuranceService ..> C_BillingService : REST
C_InsuranceService ..> C_PrescriptionService : REST
@enduml