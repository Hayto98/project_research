@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
component "Product Service" as C_ProductService
component "Customer Service" as C_CustomerService
component "Review Service" as C_ReviewService
component "Coupon Service" as C_CouponService
component "Shipment Service" as C_ShipmentService
component "Order Service" as C_OrderService
component "Category Service" as C_CategoryService
database "Ecommerce DB" as DB_ecommerce
C_CustomerService --> DB_ecommerce
C_ReviewService --> DB_ecommerce
C_CouponService --> DB_ecommerce
C_ShipmentService --> DB_ecommerce
C_CategoryService --> DB_ecommerce
C_ShipmentService ..> C_OrderService : MQ
C_ReviewService ..> C_CouponService : REST
C_ShipmentService ..> C_ProductService : gRPC
C_OrderService ..> C_CategoryService : gRPC
C_ReviewService ..> C_CustomerService : HTTP
@enduml