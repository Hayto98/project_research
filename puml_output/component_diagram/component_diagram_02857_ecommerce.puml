@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
component "Customer Service" as C_CustomerService
component "Return Service" as C_ReturnService
component "Warehouse Service" as C_WarehouseService
component "Order Service" as C_OrderService
component "Payment Service" as C_PaymentService
component "Product Service" as C_ProductService
component "Category Service" as C_CategoryService
database "Ecommerce DB" as DB_ecommerce
C_ReturnService --> DB_ecommerce
C_WarehouseService --> DB_ecommerce
C_OrderService --> DB_ecommerce
C_WarehouseService ..> C_CategoryService : REST
C_ReturnService ..> C_CustomerService : HTTP
C_CustomerService ..> C_ReturnService : MQ
C_PaymentService ..> C_WarehouseService : REST
C_PaymentService ..> C_OrderService : MQ
@enduml