@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
component "Vehicle Service" as C_VehicleService
component "Shipment Service" as C_ShipmentService
component "Tracking Service" as C_TrackingService
component "DeliveryNote Service" as C_DeliveryNoteService
component "Manifest Service" as C_ManifestService
component "Driver Service" as C_DriverService
component "Inventory Service" as C_InventoryService
database "Logistics DB" as DB_logistics
C_VehicleService --> DB_logistics
C_ShipmentService --> DB_logistics
C_TrackingService --> DB_logistics
C_DeliveryNoteService --> DB_logistics
C_ManifestService --> DB_logistics
C_DriverService --> DB_logistics
C_InventoryService --> DB_logistics
C_ManifestService ..> C_VehicleService : MQ
C_DriverService ..> C_ShipmentService : REST
C_InventoryService ..> C_TrackingService : MQ
@enduml