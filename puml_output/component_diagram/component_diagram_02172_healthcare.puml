@startuml
skinparam monochrome true
skinparam shadowing true
component "LabTest Service" as C_LabTestService
component "Treatment Service" as C_TreatmentService
component "Ward Service" as C_WardService
component "Doctor Service" as C_DoctorService
component "Hospital Service" as C_HospitalService
component "Appointment Service" as C_AppointmentService
database "Healthcare DB" as DB_healthcare
C_LabTestService --> DB_healthcare
C_TreatmentService --> DB_healthcare
C_WardService --> DB_healthcare
C_HospitalService --> DB_healthcare
C_HospitalService ..> C_LabTestService : REST
C_AppointmentService ..> C_TreatmentService : gRPC
C_DoctorService ..> C_AppointmentService : gRPC
C_HospitalService ..> C_AppointmentService : HTTP
C_LabTestService ..> C_WardService : REST
@enduml