@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
component "Insurance Service" as C_InsuranceService
component "Prescription Service" as C_PrescriptionService
component "Diagnosis Service" as C_DiagnosisService
component "Nurse Service" as C_NurseService
component "Doctor Service" as C_DoctorService
component "Treatment Service" as C_TreatmentService
component "LabTest Service" as C_LabTestService
database "Healthcare DB" as DB_healthcare
C_InsuranceService --> DB_healthcare
C_NurseService --> DB_healthcare
C_TreatmentService --> DB_healthcare
C_LabTestService --> DB_healthcare
C_NurseService ..> C_TreatmentService : MQ
C_NurseService ..> C_PrescriptionService : gRPC
C_InsuranceService ..> C_TreatmentService : gRPC
C_DoctorService ..> C_PrescriptionService : gRPC
@enduml