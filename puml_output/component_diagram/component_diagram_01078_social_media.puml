@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
component "Notification Service" as C_NotificationService
component "Album Service" as C_AlbumService
component "Follower Service" as C_FollowerService
component "Profile Service" as C_ProfileService
database "Social Media DB" as DB_social_media
C_NotificationService --> DB_social_media
C_AlbumService --> DB_social_media
C_FollowerService --> DB_social_media
C_ProfileService --> DB_social_media
C_FollowerService ..> C_AlbumService : MQ
C_FollowerService ..> C_ProfileService : gRPC
C_AlbumService ..> C_NotificationService : MQ
@enduml