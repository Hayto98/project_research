@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
component "Branch Service" as C_BranchService
component "Card Service" as C_CardService
component "Customer Service" as C_CustomerService
component "Transaction Service" as C_TransactionService
component "Beneficiary Service" as C_BeneficiaryService
database "Banking DB" as DB_banking
C_TransactionService --> DB_banking
C_BeneficiaryService --> DB_banking
C_BranchService ..> C_CustomerService : MQ
C_TransactionService ..> C_CustomerService : MQ
C_TransactionService ..> C_BeneficiaryService : REST
@enduml