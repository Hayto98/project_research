@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
component "User Service" as C_UserService
component "Post Service" as C_PostService
component "Like Service" as C_LikeService
component "Group Service" as C_GroupService
component "Comment Service" as C_CommentService
component "Notification Service" as C_NotificationService
component "Story Service" as C_StoryService
database "Social Media DB" as DB_social_media
C_LikeService --> DB_social_media
C_GroupService --> DB_social_media
C_CommentService --> DB_social_media
C_NotificationService --> DB_social_media
C_StoryService --> DB_social_media
C_PostService ..> C_CommentService : HTTP
C_StoryService ..> C_PostService : REST
C_PostService ..> C_StoryService : gRPC
@enduml