@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
component "Room Service" as C_RoomService
component "Housekeeping Service" as C_HousekeepingService
component "Invoice Service" as C_InvoiceService
component "Service Service" as C_ServiceService
component "Staff Service" as C_StaffService
component "CheckIn Service" as C_CheckInService
component "Payment Service" as C_PaymentService
database "Hotel DB" as DB_hotel
C_RoomService --> DB_hotel
C_InvoiceService --> DB_hotel
C_ServiceService --> DB_hotel
C_PaymentService --> DB_hotel
C_RoomService ..> C_CheckInService : MQ
C_InvoiceService ..> C_CheckInService : MQ
C_ServiceService ..> C_StaffService : HTTP
C_RoomService ..> C_CheckInService : MQ
C_StaffService ..> C_HousekeepingService : gRPC
@enduml