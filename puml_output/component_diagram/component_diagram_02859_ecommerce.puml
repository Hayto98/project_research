@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
component "Invoice Service" as C_InvoiceService
component "Warehouse Service" as C_WarehouseService
component "Category Service" as C_CategoryService
component "Shipment Service" as C_ShipmentService
component "Return Service" as C_ReturnService
component "Cart Service" as C_CartService
component "Customer Service" as C_CustomerService
database "Ecommerce DB" as DB_ecommerce
C_InvoiceService --> DB_ecommerce
C_WarehouseService --> DB_ecommerce
C_CategoryService --> DB_ecommerce
C_ReturnService --> DB_ecommerce
C_CartService --> DB_ecommerce
C_CustomerService --> DB_ecommerce
C_ShipmentService ..> C_WarehouseService : REST
C_CartService ..> C_CustomerService : gRPC
C_CustomerService ..> C_InvoiceService : REST
C_CustomerService ..> C_CategoryService : REST
@enduml