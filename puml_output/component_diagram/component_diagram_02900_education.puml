@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
component "Department Service" as C_DepartmentService
component "Student Service" as C_StudentService
component "Book Service" as C_BookService
component "Grade Service" as C_GradeService
component "Teacher Service" as C_TeacherService
component "Exam Service" as C_ExamService
component "Assignment Service" as C_AssignmentService
database "Education DB" as DB_education
C_StudentService --> DB_education
C_GradeService --> DB_education
C_ExamService --> DB_education
C_AssignmentService --> DB_education
C_AssignmentService ..> C_ExamService : REST
C_TeacherService ..> C_AssignmentService : MQ
C_ExamService ..> C_BookService : HTTP
C_StudentService ..> C_AssignmentService : gRPC
C_DepartmentService ..> C_BookService : REST
@enduml