@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
component "Amenity Service" as C_AmenityService
component "CheckOut Service" as C_CheckOutService
component "Restaurant Service" as C_RestaurantService
component "Payment Service" as C_PaymentService
database "Hotel DB" as DB_hotel
C_AmenityService --> DB_hotel
C_CheckOutService --> DB_hotel
C_CheckOutService ..> C_AmenityService : gRPC
C_PaymentService ..> C_RestaurantService : REST
C_RestaurantService ..> C_PaymentService : HTTP
@enduml