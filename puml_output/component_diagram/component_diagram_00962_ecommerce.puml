@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
component "Cart Service" as C_CartService
component "Supplier Service" as C_SupplierService
component "Shipment Service" as C_ShipmentService
component "Return Service" as C_ReturnService
component "Payment Service" as C_PaymentService
component "Wishlist Service" as C_WishlistService
component "Coupon Service" as C_CouponService
database "Ecommerce DB" as DB_ecommerce
C_CartService --> DB_ecommerce
C_WishlistService --> DB_ecommerce
C_CouponService --> DB_ecommerce
C_ReturnService ..> C_SupplierService : HTTP
C_CartService ..> C_PaymentService : gRPC
C_CartService ..> C_PaymentService : MQ
C_ShipmentService ..> C_SupplierService : REST
C_WishlistService ..> C_ShipmentService : HTTP
@enduml