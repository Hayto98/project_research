@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
component "Housekeeping Service" as C_HousekeepingService
component "CheckOut Service" as C_CheckOutService
component "Staff Service" as C_StaffService
component "Service Service" as C_ServiceService
component "Reservation Service" as C_ReservationService
component "Invoice Service" as C_InvoiceService
component "Amenity Service" as C_AmenityService
database "Hotel DB" as DB_hotel
C_CheckOutService --> DB_hotel
C_ServiceService --> DB_hotel
C_ReservationService --> DB_hotel
C_InvoiceService --> DB_hotel
C_HousekeepingService ..> C_InvoiceService : REST
C_AmenityService ..> C_CheckOutService : MQ
C_ServiceService ..> C_CheckOutService : REST
@enduml