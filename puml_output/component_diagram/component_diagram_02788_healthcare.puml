@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
component "Patient Service" as C_PatientService
component "MedicalRecord Service" as C_MedicalRecordService
component "Prescription Service" as C_PrescriptionService
component "Ward Service" as C_WardService
database "Healthcare DB" as DB_healthcare
C_PatientService --> DB_healthcare
C_MedicalRecordService --> DB_healthcare
C_PrescriptionService --> DB_healthcare
C_PrescriptionService ..> C_WardService : HTTP
C_WardService ..> C_PrescriptionService : REST
C_PrescriptionService ..> C_MedicalRecordService : MQ
@enduml