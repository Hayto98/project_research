@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
component "Teacher Service" as C_TeacherService
component "Schedule Service" as C_ScheduleService
component "Library Service" as C_LibraryService
component "Department Service" as C_DepartmentService
component "Attendance Service" as C_AttendanceService
component "Student Service" as C_StudentService
component "Book Service" as C_BookService
database "Education DB" as DB_education
C_ScheduleService --> DB_education
C_LibraryService --> DB_education
C_AttendanceService --> DB_education
C_StudentService --> DB_education
C_ScheduleService ..> C_LibraryService : gRPC
C_DepartmentService ..> C_ScheduleService : gRPC
C_LibraryService ..> C_BookService : HTTP
C_AttendanceService ..> C_StudentService : MQ
C_StudentService ..> C_TeacherService : MQ
C_TeacherService ..> C_DepartmentService : MQ
@enduml