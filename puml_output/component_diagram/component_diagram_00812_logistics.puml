@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
component "Route Service" as C_RouteService
component "DeliveryNote Service" as C_DeliveryNoteService
component "Driver Service" as C_DriverService
component "Warehouse Service" as C_WarehouseService
database "Logistics DB" as DB_logistics
C_RouteService --> DB_logistics
C_DeliveryNoteService --> DB_logistics
C_DriverService --> DB_logistics
C_WarehouseService --> DB_logistics
C_DriverService ..> C_DeliveryNoteService : REST
C_DeliveryNoteService ..> C_RouteService : gRPC
@enduml