@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
component "Hashtag Service" as C_HashtagService
component "Comment Service" as C_CommentService
component "Message Service" as C_MessageService
component "Album Service" as C_AlbumService
component "Group Service" as C_GroupService
component "Report Service" as C_ReportService
component "Post Service" as C_PostService
database "Social Media DB" as DB_social_media
C_CommentService --> DB_social_media
C_AlbumService --> DB_social_media
C_GroupService --> DB_social_media
C_ReportService --> DB_social_media
C_PostService --> DB_social_media
C_AlbumService ..> C_ReportService : HTTP
C_HashtagService ..> C_ReportService : gRPC
C_GroupService ..> C_PostService : HTTP
C_PostService ..> C_AlbumService : REST
C_PostService ..> C_GroupService : MQ
C_MessageService ..> C_ReportService : HTTP
@enduml