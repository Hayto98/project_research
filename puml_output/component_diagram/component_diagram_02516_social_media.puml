@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
component "Group Service" as C_GroupService
component "User Service" as C_UserService
component "Profile Service" as C_ProfileService
component "Report Service" as C_ReportService
component "Hashtag Service" as C_HashtagService
database "Social Media DB" as DB_social_media
C_UserService --> DB_social_media
C_ProfileService --> DB_social_media
C_HashtagService --> DB_social_media
C_ProfileService ..> C_UserService : REST
C_HashtagService ..> C_ProfileService : REST
C_HashtagService ..> C_GroupService : gRPC
@enduml