@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
component "Patient Service" as C_PatientService
component "Ward Service" as C_WardService
component "Treatment Service" as C_TreatmentService
component "Doctor Service" as C_DoctorService
component "Billing Service" as C_BillingService
component "Nurse Service" as C_NurseService
database "Healthcare DB" as DB_healthcare
C_PatientService --> DB_healthcare
C_DoctorService --> DB_healthcare
C_NurseService --> DB_healthcare
C_PatientService ..> C_NurseService : gRPC
C_TreatmentService ..> C_NurseService : REST
C_BillingService ..> C_DoctorService : MQ
@enduml