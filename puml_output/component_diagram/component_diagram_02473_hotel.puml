@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
component "CheckIn Service" as C_CheckInService
component "Room Service" as C_RoomService
component "Housekeeping Service" as C_HousekeepingService
component "Reservation Service" as C_ReservationService
component "CheckOut Service" as C_CheckOutService
component "Payment Service" as C_PaymentService
component "Guest Service" as C_GuestService
database "Hotel DB" as DB_hotel
C_RoomService --> DB_hotel
C_ReservationService --> DB_hotel
C_CheckOutService --> DB_hotel
C_GuestService --> DB_hotel
C_ReservationService ..> C_GuestService : REST
C_CheckInService ..> C_RoomService : MQ
@enduml