@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
component "Shelf Service" as C_ShelfService
component "Catalog Service" as C_CatalogService
component "Renewal Service" as C_RenewalService
component "Branch Service" as C_BranchService
component "Loan Service" as C_LoanService
component "Publisher Service" as C_PublisherService
database "Library DB" as DB_library
C_ShelfService --> DB_library
C_RenewalService --> DB_library
C_BranchService --> DB_library
C_LoanService --> DB_library
C_PublisherService --> DB_library
C_RenewalService ..> C_LoanService : gRPC
C_RenewalService ..> C_LoanService : MQ
C_ShelfService ..> C_PublisherService : REST
C_BranchService ..> C_LoanService : MQ
C_ShelfService ..> C_BranchService : HTTP
@enduml