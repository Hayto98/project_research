@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
component "Book Service" as C_BookService
component "Author Service" as C_AuthorService
component "Catalog Service" as C_CatalogService
component "Loan Service" as C_LoanService
component "Publisher Service" as C_PublisherService
component "Branch Service" as C_BranchService
database "Library DB" as DB_library
C_BookService --> DB_library
C_AuthorService --> DB_library
C_LoanService --> DB_library
C_BookService ..> C_AuthorService : HTTP
C_CatalogService ..> C_AuthorService : gRPC
C_CatalogService ..> C_PublisherService : HTTP
C_LoanService ..> C_PublisherService : REST
C_AuthorService ..> C_BranchService : HTTP
@enduml