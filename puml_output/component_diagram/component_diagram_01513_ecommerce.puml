@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
component "Supplier Service" as C_SupplierService
component "Return Service" as C_ReturnService
component "Customer Service" as C_CustomerService
component "Cart Service" as C_CartService
component "Invoice Service" as C_InvoiceService
component "Shipment Service" as C_ShipmentService
database "Ecommerce DB" as DB_ecommerce
C_ReturnService --> DB_ecommerce
C_CustomerService --> DB_ecommerce
C_InvoiceService --> DB_ecommerce
C_CartService ..> C_ShipmentService : gRPC
C_InvoiceService ..> C_SupplierService : HTTP
C_CustomerService ..> C_ShipmentService : REST
C_SupplierService ..> C_CustomerService : REST
C_ShipmentService ..> C_ReturnService : gRPC
@enduml