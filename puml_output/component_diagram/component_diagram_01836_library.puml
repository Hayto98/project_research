@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
component "Renewal Service" as C_RenewalService
component "Member Service" as C_MemberService
component "Author Service" as C_AuthorService
component "Catalog Service" as C_CatalogService
database "Library DB" as DB_library
C_RenewalService --> DB_library
C_MemberService --> DB_library
C_AuthorService --> DB_library
C_CatalogService --> DB_library
C_RenewalService ..> C_MemberService : HTTP
C_MemberService ..> C_AuthorService : REST
@enduml