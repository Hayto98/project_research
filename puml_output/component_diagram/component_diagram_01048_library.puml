@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
component "Reservation Service" as C_ReservationService
component "Member Service" as C_MemberService
component "Book Service" as C_BookService
component "Librarian Service" as C_LibrarianService
component "Fine Service" as C_FineService
component "Catalog Service" as C_CatalogService
database "Library DB" as DB_library
C_MemberService --> DB_library
C_LibrarianService --> DB_library
C_CatalogService --> DB_library
C_LibrarianService ..> C_MemberService : HTTP
C_FineService ..> C_ReservationService : HTTP
C_LibrarianService ..> C_FineService : MQ
C_FineService ..> C_MemberService : MQ
C_ReservationService ..> C_FineService : gRPC
@enduml