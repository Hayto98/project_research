@startuml
skinparam monochrome true
skinparam ArrowColor #555555
component "Nurse Service" as C_NurseService
component "Treatment Service" as C_TreatmentService
component "Insurance Service" as C_InsuranceService
component "Hospital Service" as C_HospitalService
component "Diagnosis Service" as C_DiagnosisService
component "Patient Service" as C_PatientService
component "Ward Service" as C_WardService
database "Healthcare DB" as DB_healthcare
C_NurseService --> DB_healthcare
C_InsuranceService --> DB_healthcare
C_HospitalService --> DB_healthcare
C_DiagnosisService --> DB_healthcare
C_WardService --> DB_healthcare
C_DiagnosisService ..> C_HospitalService : gRPC
C_PatientService ..> C_HospitalService : HTTP
C_HospitalService ..> C_PatientService : gRPC
C_TreatmentService ..> C_InsuranceService : MQ
C_InsuranceService ..> C_WardService : HTTP
C_PatientService ..> C_DiagnosisService : REST
@enduml