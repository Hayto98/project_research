@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
component "Nurse Service" as C_NurseService
component "Billing Service" as C_BillingService
component "LabTest Service" as C_LabTestService
component "Appointment Service" as C_AppointmentService
component "Insurance Service" as C_InsuranceService
component "Diagnosis Service" as C_DiagnosisService
component "Treatment Service" as C_TreatmentService
database "Healthcare DB" as DB_healthcare
C_BillingService --> DB_healthcare
C_LabTestService --> DB_healthcare
C_AppointmentService --> DB_healthcare
C_InsuranceService --> DB_healthcare
C_DiagnosisService --> DB_healthcare
C_LabTestService ..> C_AppointmentService : MQ
C_DiagnosisService ..> C_NurseService : MQ
C_DiagnosisService ..> C_TreatmentService : HTTP
C_NurseService ..> C_AppointmentService : gRPC
C_DiagnosisService ..> C_NurseService : REST
C_NurseService ..> C_AppointmentService : MQ
@enduml