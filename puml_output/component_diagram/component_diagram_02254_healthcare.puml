@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
component "Doctor Service" as C_DoctorService
component "Prescription Service" as C_PrescriptionService
component "MedicalRecord Service" as C_MedicalRecordService
component "Nurse Service" as C_NurseService
component "Diagnosis Service" as C_DiagnosisService
component "LabTest Service" as C_LabTestService
component "Insurance Service" as C_InsuranceService
database "Healthcare DB" as DB_healthcare
C_PrescriptionService --> DB_healthcare
C_MedicalRecordService --> DB_healthcare
C_NurseService --> DB_healthcare
C_DiagnosisService --> DB_healthcare
C_LabTestService --> DB_healthcare
C_MedicalRecordService ..> C_InsuranceService : gRPC
C_InsuranceService ..> C_DoctorService : MQ
C_InsuranceService ..> C_MedicalRecordService : MQ
C_LabTestService ..> C_InsuranceService : REST
@enduml