@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
component "Manifest Service" as C_ManifestService
component "DeliveryNote Service" as C_DeliveryNoteService
component "Tracking Service" as C_TrackingService
component "Customer Service" as C_CustomerService
component "Route Service" as C_RouteService
component "Vehicle Service" as C_VehicleService
component "Warehouse Service" as C_WarehouseService
database "Logistics DB" as DB_logistics
C_TrackingService --> DB_logistics
C_CustomerService --> DB_logistics
C_RouteService --> DB_logistics
C_VehicleService --> DB_logistics
C_DeliveryNoteService ..> C_TrackingService : HTTP
C_TrackingService ..> C_WarehouseService : HTTP
C_VehicleService ..> C_ManifestService : HTTP
C_CustomerService ..> C_VehicleService : MQ
C_WarehouseService ..> C_RouteService : HTTP
C_DeliveryNoteService ..> C_CustomerService : gRPC
@enduml