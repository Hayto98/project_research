@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
component "DeliveryNote Service" as C_DeliveryNoteService
component "Driver Service" as C_DriverService
component "FuelLog Service" as C_FuelLogService
component "Warehouse Service" as C_WarehouseService
component "Inventory Service" as C_InventoryService
component "Package Service" as C_PackageService
database "Logistics DB" as DB_logistics
C_DeliveryNoteService --> DB_logistics
C_DriverService --> DB_logistics
C_FuelLogService --> DB_logistics
C_WarehouseService --> DB_logistics
C_InventoryService --> DB_logistics
C_PackageService --> DB_logistics
C_InventoryService ..> C_DeliveryNoteService : REST
C_FuelLogService ..> C_PackageService : HTTP
C_DeliveryNoteService ..> C_DriverService : MQ
C_DriverService ..> C_WarehouseService : HTTP
C_InventoryService ..> C_WarehouseService : HTTP
@enduml