@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
component "Reservation Service" as C_ReservationService
component "Booking Service" as C_BookingService
component "Room Service" as C_RoomService
component "Invoice Service" as C_InvoiceService
component "Amenity Service" as C_AmenityService
component "Staff Service" as C_StaffService
component "Payment Service" as C_PaymentService
database "Hotel DB" as DB_hotel
C_InvoiceService --> DB_hotel
C_RoomService ..> C_ReservationService : REST
C_ReservationService ..> C_BookingService : gRPC
@enduml