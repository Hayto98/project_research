@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
component "Invoice Service" as C_InvoiceService
component "Housekeeping Service" as C_HousekeepingService
component "Staff Service" as C_StaffService
component "Room Service" as C_RoomService
database "Hotel DB" as DB_hotel
C_InvoiceService --> DB_hotel
C_HousekeepingService --> DB_hotel
C_StaffService --> DB_hotel
C_RoomService --> DB_hotel
C_InvoiceService ..> C_HousekeepingService : HTTP
C_RoomService ..> C_StaffService : REST
@enduml