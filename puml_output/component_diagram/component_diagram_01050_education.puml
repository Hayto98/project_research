@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
component "Assignment Service" as C_AssignmentService
component "Teacher Service" as C_TeacherService
component "Enrollment Service" as C_EnrollmentService
component "Grade Service" as C_GradeService
component "Student Service" as C_StudentService
component "Attendance Service" as C_AttendanceService
component "Book Service" as C_BookService
database "Education DB" as DB_education
C_AssignmentService --> DB_education
C_TeacherService --> DB_education
C_AssignmentService ..> C_StudentService : REST
C_StudentService ..> C_BookService : MQ
C_AssignmentService ..> C_EnrollmentService : HTTP
@enduml