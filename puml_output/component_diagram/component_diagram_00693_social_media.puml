@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
component "Like Service" as C_LikeService
component "Notification Service" as C_NotificationService
component "Report Service" as C_ReportService
component "Comment Service" as C_CommentService
component "Message Service" as C_MessageService
component "Group Service" as C_GroupService
database "Social Media DB" as DB_social_media
C_LikeService --> DB_social_media
C_NotificationService --> DB_social_media
C_CommentService --> DB_social_media
C_MessageService --> DB_social_media
C_NotificationService ..> C_CommentService : REST
C_GroupService ..> C_NotificationService : REST
C_GroupService ..> C_LikeService : HTTP
C_ReportService ..> C_NotificationService : MQ
@enduml