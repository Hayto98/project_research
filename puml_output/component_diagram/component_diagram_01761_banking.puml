@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
component "Statement Service" as C_StatementService
component "Teller Service" as C_TellerService
component "Deposit Service" as C_DepositService
component "Branch Service" as C_BranchService
component "Loan Service" as C_LoanService
component "Transaction Service" as C_TransactionService
database "Banking DB" as DB_banking
C_BranchService --> DB_banking
C_LoanService --> DB_banking
C_TransactionService --> DB_banking
C_TellerService ..> C_TransactionService : REST
C_DepositService ..> C_BranchService : gRPC
C_LoanService ..> C_TellerService : MQ
@enduml