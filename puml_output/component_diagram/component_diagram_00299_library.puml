@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
component "Fine Service" as C_FineService
component "Shelf Service" as C_ShelfService
component "Publisher Service" as C_PublisherService
component "Reservation Service" as C_ReservationService
component "Catalog Service" as C_CatalogService
component "Member Service" as C_MemberService
component "Branch Service" as C_BranchService
database "Library DB" as DB_library
C_ShelfService --> DB_library
C_PublisherService --> DB_library
C_CatalogService --> DB_library
C_MemberService --> DB_library
C_BranchService --> DB_library
C_BranchService ..> C_MemberService : gRPC
C_MemberService ..> C_ShelfService : REST
C_ReservationService ..> C_MemberService : HTTP
C_MemberService ..> C_ReservationService : MQ
C_PublisherService ..> C_CatalogService : MQ
C_FineService ..> C_CatalogService : HTTP
@enduml