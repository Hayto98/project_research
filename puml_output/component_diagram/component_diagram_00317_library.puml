@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
component "Shelf Service" as C_ShelfService
component "Renewal Service" as C_RenewalService
component "Loan Service" as C_LoanService
component "Author Service" as C_AuthorService
component "Catalog Service" as C_CatalogService
component "Reservation Service" as C_ReservationService
database "Library DB" as DB_library
C_RenewalService --> DB_library
C_LoanService --> DB_library
C_AuthorService --> DB_library
C_CatalogService --> DB_library
C_ReservationService --> DB_library
C_RenewalService ..> C_ShelfService : MQ
C_ShelfService ..> C_RenewalService : gRPC
C_ReservationService ..> C_LoanService : HTTP
@enduml