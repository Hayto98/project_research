@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
component "Member Service" as C_MemberService
component "Renewal Service" as C_RenewalService
component "Reservation Service" as C_ReservationService
component "Book Service" as C_BookService
component "Publisher Service" as C_PublisherService
component "Shelf Service" as C_ShelfService
component "Librarian Service" as C_LibrarianService
database "Library DB" as DB_library
C_MemberService --> DB_library
C_RenewalService --> DB_library
C_BookService --> DB_library
C_ShelfService --> DB_library
C_BookService ..> C_ReservationService : HTTP
C_LibrarianService ..> C_MemberService : REST
C_ShelfService ..> C_ReservationService : MQ
@enduml