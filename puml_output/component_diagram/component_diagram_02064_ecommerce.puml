@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
component "Return Service" as C_ReturnService
component "Invoice Service" as C_InvoiceService
component "Wishlist Service" as C_WishlistService
component "Customer Service" as C_CustomerService
component "Category Service" as C_CategoryService
component "Warehouse Service" as C_WarehouseService
component "Review Service" as C_ReviewService
database "Ecommerce DB" as DB_ecommerce
C_ReturnService --> DB_ecommerce
C_CategoryService --> DB_ecommerce
C_WarehouseService --> DB_ecommerce
C_ReviewService --> DB_ecommerce
C_WarehouseService ..> C_CategoryService : gRPC
C_WarehouseService ..> C_CustomerService : HTTP
C_ReturnService ..> C_InvoiceService : MQ
C_WishlistService ..> C_CategoryService : REST
C_ReviewService ..> C_CustomerService : gRPC
@enduml