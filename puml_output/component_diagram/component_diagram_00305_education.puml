@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
component "Book Service" as C_BookService
component "Exam Service" as C_ExamService
component "Classroom Service" as C_ClassroomService
component "Schedule Service" as C_ScheduleService
component "Course Service" as C_CourseService
database "Education DB" as DB_education
C_BookService --> DB_education
C_ExamService --> DB_education
C_ScheduleService --> DB_education
C_CourseService --> DB_education
C_BookService ..> C_CourseService : REST
C_ScheduleService ..> C_BookService : gRPC
C_BookService ..> C_ExamService : MQ
@enduml