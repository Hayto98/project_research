@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
component "Author Service" as C_AuthorService
component "Renewal Service" as C_RenewalService
component "Loan Service" as C_LoanService
component "Publisher Service" as C_PublisherService
database "Library DB" as DB_library
C_AuthorService --> DB_library
C_PublisherService --> DB_library
C_AuthorService ..> C_LoanService : REST
C_AuthorService ..> C_RenewalService : gRPC
@enduml