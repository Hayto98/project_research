@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
component "Album Service" as C_AlbumService
component "Report Service" as C_ReportService
component "Message Service" as C_MessageService
component "Story Service" as C_StoryService
component "Like Service" as C_LikeService
component "Post Service" as C_PostService
component "Notification Service" as C_NotificationService
database "Social Media DB" as DB_social_media
C_ReportService --> DB_social_media
C_MessageService --> DB_social_media
C_StoryService --> DB_social_media
C_LikeService --> DB_social_media
C_PostService --> DB_social_media
C_NotificationService --> DB_social_media
C_LikeService ..> C_ReportService : REST
C_AlbumService ..> C_StoryService : MQ
C_PostService ..> C_ReportService : gRPC
C_LikeService ..> C_PostService : gRPC
C_NotificationService ..> C_AlbumService : HTTP
C_ReportService ..> C_StoryService : MQ
@enduml