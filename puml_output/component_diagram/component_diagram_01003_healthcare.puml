@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
component "Treatment Service" as C_TreatmentService
component "Doctor Service" as C_DoctorService
component "Insurance Service" as C_InsuranceService
component "LabTest Service" as C_LabTestService
component "Prescription Service" as C_PrescriptionService
component "Nurse Service" as C_NurseService
component "MedicalRecord Service" as C_MedicalRecordService
database "Healthcare DB" as DB_healthcare
C_DoctorService --> DB_healthcare
C_InsuranceService --> DB_healthcare
C_LabTestService --> DB_healthcare
C_PrescriptionService --> DB_healthcare
C_NurseService ..> C_DoctorService : MQ
C_InsuranceService ..> C_TreatmentService : HTTP
C_NurseService ..> C_MedicalRecordService : REST
C_PrescriptionService ..> C_MedicalRecordService : MQ
C_DoctorService ..> C_NurseService : MQ
C_MedicalRecordService ..> C_DoctorService : REST
@enduml