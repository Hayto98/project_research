@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
component "Nurse Service" as C_NurseService
component "Treatment Service" as C_TreatmentService
component "Appointment Service" as C_AppointmentService
component "MedicalRecord Service" as C_MedicalRecordService
component "Prescription Service" as C_PrescriptionService
component "Insurance Service" as C_InsuranceService
component "Ward Service" as C_WardService
database "Healthcare DB" as DB_healthcare
C_TreatmentService --> DB_healthcare
C_PrescriptionService --> DB_healthcare
C_WardService --> DB_healthcare
C_TreatmentService ..> C_AppointmentService : gRPC
C_AppointmentService ..> C_NurseService : REST
C_WardService ..> C_MedicalRecordService : gRPC
C_AppointmentService ..> C_MedicalRecordService : gRPC
C_PrescriptionService ..> C_WardService : MQ
@enduml