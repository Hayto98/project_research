@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
component "Route Service" as C_RouteService
component "Tracking Service" as C_TrackingService
component "Vehicle Service" as C_VehicleService
component "Manifest Service" as C_ManifestService
component "Driver Service" as C_DriverService
component "Warehouse Service" as C_WarehouseService
component "FuelLog Service" as C_FuelLogService
database "Logistics DB" as DB_logistics
C_RouteService --> DB_logistics
C_TrackingService --> DB_logistics
C_VehicleService --> DB_logistics
C_ManifestService --> DB_logistics
C_DriverService --> DB_logistics
C_WarehouseService --> DB_logistics
C_FuelLogService --> DB_logistics
C_DriverService ..> C_VehicleService : MQ
C_WarehouseService ..> C_ManifestService : MQ
C_VehicleService ..> C_RouteService : MQ
C_TrackingService ..> C_VehicleService : gRPC
@enduml