@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
component "Treatment Service" as C_TreatmentService
component "Diagnosis Service" as C_DiagnosisService
component "Ward Service" as C_WardService
component "Appointment Service" as C_AppointmentService
component "Patient Service" as C_PatientService
component "Prescription Service" as C_PrescriptionService
component "Insurance Service" as C_InsuranceService
database "Healthcare DB" as DB_healthcare
C_TreatmentService --> DB_healthcare
C_DiagnosisService --> DB_healthcare
C_WardService --> DB_healthcare
C_PrescriptionService --> DB_healthcare
C_InsuranceService --> DB_healthcare
C_AppointmentService ..> C_TreatmentService : gRPC
C_AppointmentService ..> C_DiagnosisService : gRPC
C_PatientService ..> C_WardService : HTTP
C_PrescriptionService ..> C_AppointmentService : HTTP
C_DiagnosisService ..> C_InsuranceService : HTTP
@enduml