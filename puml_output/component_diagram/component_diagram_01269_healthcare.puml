@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
component "Insurance Service" as C_InsuranceService
component "Nurse Service" as C_NurseService
component "Hospital Service" as C_HospitalService
component "Prescription Service" as C_PrescriptionService
component "Appointment Service" as C_AppointmentService
component "Doctor Service" as C_DoctorService
database "Healthcare DB" as DB_healthcare
C_DoctorService --> DB_healthcare
C_InsuranceService ..> C_DoctorService : HTTP
C_DoctorService ..> C_AppointmentService : HTTP
C_DoctorService ..> C_AppointmentService : gRPC
C_InsuranceService ..> C_HospitalService : REST
C_DoctorService ..> C_InsuranceService : gRPC
@enduml