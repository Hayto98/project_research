@startuml
skinparam ArrowColor #555555
component "Housekeeping Service" as C_HousekeepingService
component "Restaurant Service" as C_RestaurantService
component "Invoice Service" as C_InvoiceService
component "Service Service" as C_ServiceService
component "CheckOut Service" as C_CheckOutService
database "Hotel DB" as DB_hotel
C_HousekeepingService --> DB_hotel
C_RestaurantService --> DB_hotel
C_InvoiceService --> DB_hotel
C_CheckOutService --> DB_hotel
C_InvoiceService ..> C_ServiceService : MQ
C_ServiceService ..> C_CheckOutService : gRPC
C_ServiceService ..> C_InvoiceService : HTTP
C_ServiceService ..> C_RestaurantService : REST
@enduml