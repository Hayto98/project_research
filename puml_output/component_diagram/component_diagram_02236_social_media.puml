@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
component "Notification Service" as C_NotificationService
component "Comment Service" as C_CommentService
component "Follower Service" as C_FollowerService
component "Group Service" as C_GroupService
component "Post Service" as C_PostService
component "Album Service" as C_AlbumService
component "Like Service" as C_LikeService
database "Social Media DB" as DB_social_media
C_NotificationService --> DB_social_media
C_CommentService --> DB_social_media
C_FollowerService --> DB_social_media
C_GroupService --> DB_social_media
C_PostService --> DB_social_media
C_AlbumService --> DB_social_media
C_LikeService --> DB_social_media
C_GroupService ..> C_LikeService : gRPC
C_GroupService ..> C_CommentService : REST
C_CommentService ..> C_NotificationService : MQ
C_FollowerService ..> C_CommentService : REST
C_NotificationService ..> C_AlbumService : gRPC
C_CommentService ..> C_AlbumService : REST
@enduml