@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
component "Notification Service" as C_NotificationService
component "Report Service" as C_ReportService
component "Comment Service" as C_CommentService
component "Hashtag Service" as C_HashtagService
component "Story Service" as C_StoryService
database "Social Media DB" as DB_social_media
C_NotificationService --> DB_social_media
C_ReportService --> DB_social_media
C_CommentService --> DB_social_media
C_HashtagService --> DB_social_media
C_StoryService --> DB_social_media
C_StoryService ..> C_CommentService : gRPC
C_CommentService ..> C_StoryService : gRPC
C_NotificationService ..> C_HashtagService : HTTP
@enduml