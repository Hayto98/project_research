@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
component "Warehouse Service" as C_WarehouseService
component "Route Service" as C_RouteService
component "Inventory Service" as C_InventoryService
component "FuelLog Service" as C_FuelLogService
component "Vehicle Service" as C_VehicleService
component "DeliveryNote Service" as C_DeliveryNoteService
database "Logistics DB" as DB_logistics
C_WarehouseService --> DB_logistics
C_RouteService --> DB_logistics
C_InventoryService --> DB_logistics
C_FuelLogService --> DB_logistics
C_VehicleService --> DB_logistics
C_DeliveryNoteService --> DB_logistics
C_WarehouseService ..> C_VehicleService : HTTP
C_WarehouseService ..> C_RouteService : gRPC
C_FuelLogService ..> C_InventoryService : gRPC
C_FuelLogService ..> C_RouteService : MQ
C_FuelLogService ..> C_WarehouseService : gRPC
@enduml