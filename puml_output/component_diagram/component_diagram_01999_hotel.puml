@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
component "Restaurant Service" as C_RestaurantService
component "CheckIn Service" as C_CheckInService
component "Staff Service" as C_StaffService
component "Amenity Service" as C_AmenityService
component "Booking Service" as C_BookingService
component "Housekeeping Service" as C_HousekeepingService
component "Service Service" as C_ServiceService
database "Hotel DB" as DB_hotel
C_RestaurantService --> DB_hotel
C_StaffService --> DB_hotel
C_AmenityService --> DB_hotel
C_BookingService --> DB_hotel
C_HousekeepingService --> DB_hotel
C_ServiceService ..> C_CheckInService : gRPC
C_AmenityService ..> C_CheckInService : gRPC
C_StaffService ..> C_BookingService : gRPC
C_BookingService ..> C_ServiceService : HTTP
@enduml