@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
component "Appointment Service" as C_AppointmentService
component "Patient Service" as C_PatientService
component "Doctor Service" as C_DoctorService
component "Diagnosis Service" as C_DiagnosisService
component "Nurse Service" as C_NurseService
component "Hospital Service" as C_HospitalService
component "MedicalRecord Service" as C_MedicalRecordService
database "Healthcare DB" as DB_healthcare
C_DoctorService --> DB_healthcare
C_NurseService --> DB_healthcare
C_HospitalService --> DB_healthcare
C_MedicalRecordService --> DB_healthcare
C_HospitalService ..> C_DoctorService : REST
C_DoctorService ..> C_NurseService : gRPC
C_AppointmentService ..> C_NurseService : MQ
@enduml