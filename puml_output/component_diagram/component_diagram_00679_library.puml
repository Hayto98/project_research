@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
component "Catalog Service" as C_CatalogService
component "Fine Service" as C_FineService
component "Member Service" as C_MemberService
component "Reservation Service" as C_ReservationService
component "Librarian Service" as C_LibrarianService
component "Author Service" as C_AuthorService
database "Library DB" as DB_library
C_FineService --> DB_library
C_MemberService --> DB_library
C_LibrarianService --> DB_library
C_AuthorService --> DB_library
C_MemberService ..> C_FineService : MQ
C_ReservationService ..> C_LibrarianService : HTTP
C_MemberService ..> C_AuthorService : MQ
C_AuthorService ..> C_LibrarianService : REST
@enduml