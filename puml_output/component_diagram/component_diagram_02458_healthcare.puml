@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
component "Nurse Service" as C_NurseService
component "Ward Service" as C_WardService
component "Diagnosis Service" as C_DiagnosisService
component "Doctor Service" as C_DoctorService
component "Insurance Service" as C_InsuranceService
database "Healthcare DB" as DB_healthcare
C_WardService --> DB_healthcare
C_DiagnosisService --> DB_healthcare
C_DoctorService --> DB_healthcare
C_NurseService ..> C_InsuranceService : MQ
C_NurseService ..> C_DiagnosisService : gRPC
C_InsuranceService ..> C_DiagnosisService : HTTP
C_InsuranceService ..> C_WardService : gRPC
@enduml