@startuml
skinparam monochrome true
skinparam defaultFontSize 11
component "Member Service" as C_MemberService
component "Librarian Service" as C_LibrarianService
component "Branch Service" as C_BranchService
component "Publisher Service" as C_PublisherService
component "Loan Service" as C_LoanService
component "Renewal Service" as C_RenewalService
component "Fine Service" as C_FineService
database "Library DB" as DB_library
C_MemberService --> DB_library
C_LibrarianService --> DB_library
C_LoanService --> DB_library
C_RenewalService --> DB_library
C_FineService --> DB_library
C_LibrarianService ..> C_LoanService : gRPC
C_MemberService ..> C_BranchService : HTTP
C_FineService ..> C_BranchService : REST
C_FineService ..> C_PublisherService : REST
C_LoanService ..> C_BranchService : REST
@enduml