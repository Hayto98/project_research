@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
component "Librarian Service" as C_LibrarianService
component "Author Service" as C_AuthorService
component "Book Service" as C_BookService
component "Catalog Service" as C_CatalogService
component "Publisher Service" as C_PublisherService
component "Member Service" as C_MemberService
database "Library DB" as DB_library
C_AuthorService --> DB_library
C_BookService --> DB_library
C_PublisherService --> DB_library
C_MemberService --> DB_library
C_CatalogService ..> C_LibrarianService : gRPC
C_PublisherService ..> C_MemberService : MQ
C_PublisherService ..> C_CatalogService : REST
C_BookService ..> C_PublisherService : HTTP
@enduml