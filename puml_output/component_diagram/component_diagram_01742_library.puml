@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
component "Fine Service" as C_FineService
component "Book Service" as C_BookService
component "Librarian Service" as C_LibrarianService
component "Loan Service" as C_LoanService
component "Author Service" as C_AuthorService
component "Catalog Service" as C_CatalogService
database "Library DB" as DB_library
C_BookService --> DB_library
C_LibrarianService --> DB_library
C_AuthorService --> DB_library
C_CatalogService --> DB_library
C_CatalogService ..> C_LoanService : HTTP
C_BookService ..> C_FineService : HTTP
C_FineService ..> C_LoanService : REST
C_LoanService ..> C_LibrarianService : gRPC
C_BookService ..> C_CatalogService : REST
@enduml