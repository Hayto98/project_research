@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
component "Invoice Service" as C_InvoiceService
component "Coupon Service" as C_CouponService
component "Shipment Service" as C_ShipmentService
component "Order Service" as C_OrderService
database "Ecommerce DB" as DB_ecommerce
C_InvoiceService --> DB_ecommerce
C_ShipmentService --> DB_ecommerce
C_CouponService ..> C_OrderService : HTTP
C_OrderService ..> C_InvoiceService : gRPC
C_CouponService ..> C_InvoiceService : gRPC
@enduml