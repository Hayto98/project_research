@startuml
skinparam monochrome true
skinparam ArrowColor #555555
component "Album Service" as C_AlbumService
component "Post Service" as C_PostService
component "Story Service" as C_StoryService
component "Report Service" as C_ReportService
component "Follower Service" as C_FollowerService
database "Social Media DB" as DB_social_media
C_AlbumService --> DB_social_media
C_StoryService --> DB_social_media
C_ReportService --> DB_social_media
C_FollowerService --> DB_social_media
C_ReportService ..> C_StoryService : gRPC
C_PostService ..> C_StoryService : MQ
C_StoryService ..> C_AlbumService : HTTP
C_StoryService ..> C_AlbumService : MQ
@enduml