@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
component "Order Service" as C_OrderService
component "Customer Service" as C_CustomerService
component "Shipment Service" as C_ShipmentService
component "Payment Service" as C_PaymentService
component "Cart Service" as C_CartService
component "Return Service" as C_ReturnService
component "Coupon Service" as C_CouponService
database "Ecommerce DB" as DB_ecommerce
C_CustomerService --> DB_ecommerce
C_ShipmentService --> DB_ecommerce
C_PaymentService --> DB_ecommerce
C_CartService --> DB_ecommerce
C_CouponService --> DB_ecommerce
C_PaymentService ..> C_CouponService : REST
C_CouponService ..> C_ShipmentService : HTTP
C_PaymentService ..> C_OrderService : HTTP
C_ReturnService ..> C_CustomerService : gRPC
C_CouponService ..> C_ShipmentService : gRPC
@enduml