@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam shadowing true
component "Prescription Service" as C_PrescriptionService
component "Ward Service" as C_WardService
component "Treatment Service" as C_TreatmentService
component "Appointment Service" as C_AppointmentService
component "Nurse Service" as C_NurseService
component "Billing Service" as C_BillingService
database "Healthcare DB" as DB_healthcare
C_WardService --> DB_healthcare
C_TreatmentService --> DB_healthcare
C_AppointmentService --> DB_healthcare
C_NurseService --> DB_healthcare
C_BillingService --> DB_healthcare
C_BillingService ..> C_PrescriptionService : gRPC
C_AppointmentService ..> C_NurseService : REST
C_TreatmentService ..> C_BillingService : REST
@enduml