@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
component "Invoice Service" as C_InvoiceService
component "Amenity Service" as C_AmenityService
component "Booking Service" as C_BookingService
component "Service Service" as C_ServiceService
component "CheckIn Service" as C_CheckInService
database "Hotel DB" as DB_hotel
C_InvoiceService --> DB_hotel
C_BookingService --> DB_hotel
C_ServiceService --> DB_hotel
C_InvoiceService ..> C_AmenityService : MQ
C_CheckInService ..> C_AmenityService : HTTP
C_BookingService ..> C_CheckInService : gRPC
@enduml