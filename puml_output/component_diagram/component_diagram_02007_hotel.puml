@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
component "Payment Service" as C_PaymentService
component "Booking Service" as C_BookingService
component "Guest Service" as C_GuestService
component "Staff Service" as C_StaffService
component "Service Service" as C_ServiceService
component "Housekeeping Service" as C_HousekeepingService
component "Room Service" as C_RoomService
database "Hotel DB" as DB_hotel
C_PaymentService --> DB_hotel
C_BookingService --> DB_hotel
C_GuestService --> DB_hotel
C_StaffService --> DB_hotel
C_HousekeepingService --> DB_hotel
C_RoomService ..> C_StaffService : gRPC
C_BookingService ..> C_ServiceService : HTTP
@enduml