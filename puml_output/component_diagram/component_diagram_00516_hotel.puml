@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
component "Amenity Service" as C_AmenityService
component "Invoice Service" as C_InvoiceService
component "Room Service" as C_RoomService
component "CheckOut Service" as C_CheckOutService
component "Restaurant Service" as C_RestaurantService
component "Booking Service" as C_BookingService
component "Guest Service" as C_GuestService
database "Hotel DB" as DB_hotel
C_AmenityService --> DB_hotel
C_InvoiceService --> DB_hotel
C_RoomService --> DB_hotel
C_CheckOutService --> DB_hotel
C_RestaurantService --> DB_hotel
C_BookingService --> DB_hotel
C_GuestService --> DB_hotel
C_BookingService ..> C_AmenityService : gRPC
C_InvoiceService ..> C_RoomService : MQ
C_InvoiceService ..> C_CheckOutService : REST
C_RoomService ..> C_InvoiceService : HTTP
C_RestaurantService ..> C_BookingService : MQ
@enduml