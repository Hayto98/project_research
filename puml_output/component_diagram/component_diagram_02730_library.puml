@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
component "Renewal Service" as C_RenewalService
component "Author Service" as C_AuthorService
component "Branch Service" as C_BranchService
component "Catalog Service" as C_CatalogService
component "Publisher Service" as C_PublisherService
component "Librarian Service" as C_LibrarianService
database "Library DB" as DB_library
C_RenewalService --> DB_library
C_BranchService --> DB_library
C_CatalogService --> DB_library
C_PublisherService ..> C_RenewalService : HTTP
C_CatalogService ..> C_AuthorService : HTTP
C_LibrarianService ..> C_CatalogService : MQ
C_CatalogService ..> C_BranchService : REST
@enduml