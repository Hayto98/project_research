@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam ArrowColor #555555
component "Prescription Service" as C_PrescriptionService
component "LabTest Service" as C_LabTestService
component "Ward Service" as C_WardService
component "Billing Service" as C_BillingService
component "Treatment Service" as C_TreatmentService
component "Nurse Service" as C_NurseService
database "Healthcare DB" as DB_healthcare
C_LabTestService --> DB_healthcare
C_WardService --> DB_healthcare
C_BillingService --> DB_healthcare
C_NurseService --> DB_healthcare
C_NurseService ..> C_BillingService : gRPC
C_PrescriptionService ..> C_BillingService : REST
C_LabTestService ..> C_TreatmentService : REST
C_PrescriptionService ..> C_WardService : REST
@enduml