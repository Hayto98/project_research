@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
component "Fine Service" as C_FineService
component "Member Service" as C_MemberService
component "Renewal Service" as C_RenewalService
component "Catalog Service" as C_CatalogService
component "Publisher Service" as C_PublisherService
component "Loan Service" as C_LoanService
component "Shelf Service" as C_ShelfService
database "Library DB" as DB_library
C_FineService --> DB_library
C_MemberService --> DB_library
C_RenewalService --> DB_library
C_CatalogService --> DB_library
C_PublisherService --> DB_library
C_LoanService ..> C_FineService : HTTP
C_LoanService ..> C_MemberService : HTTP
C_ShelfService ..> C_MemberService : MQ
C_CatalogService ..> C_ShelfService : MQ
C_ShelfService ..> C_RenewalService : gRPC
@enduml