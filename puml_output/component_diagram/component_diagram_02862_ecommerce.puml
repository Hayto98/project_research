@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
component "Shipment Service" as C_ShipmentService
component "Invoice Service" as C_InvoiceService
component "Category Service" as C_CategoryService
component "Order Service" as C_OrderService
database "Ecommerce DB" as DB_ecommerce
C_InvoiceService --> DB_ecommerce
C_OrderService ..> C_InvoiceService : REST
C_ShipmentService ..> C_CategoryService : REST
@enduml