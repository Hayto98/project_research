@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
component "Ward Service" as C_WardService
component "Nurse Service" as C_NurseService
component "Billing Service" as C_BillingService
component "MedicalRecord Service" as C_MedicalRecordService
component "LabTest Service" as C_LabTestService
database "Healthcare DB" as DB_healthcare
C_NurseService --> DB_healthcare
C_BillingService --> DB_healthcare
C_MedicalRecordService --> DB_healthcare
C_LabTestService --> DB_healthcare
C_MedicalRecordService ..> C_WardService : HTTP
C_BillingService ..> C_NurseService : gRPC
@enduml