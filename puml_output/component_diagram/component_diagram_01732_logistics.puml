@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
component "Depot Service" as C_DepotService
component "Package Service" as C_PackageService
component "Customer Service" as C_CustomerService
component "DeliveryNote Service" as C_DeliveryNoteService
component "Inventory Service" as C_InventoryService
component "Driver Service" as C_DriverService
component "Manifest Service" as C_ManifestService
database "Logistics DB" as DB_logistics
C_PackageService --> DB_logistics
C_CustomerService --> DB_logistics
C_DeliveryNoteService --> DB_logistics
C_DriverService --> DB_logistics
C_ManifestService --> DB_logistics
C_DepotService ..> C_ManifestService : gRPC
C_PackageService ..> C_DepotService : REST
C_InventoryService ..> C_DriverService : gRPC
C_ManifestService ..> C_CustomerService : REST
C_DriverService ..> C_DepotService : gRPC
C_DriverService ..> C_CustomerService : gRPC
@enduml