@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
component "Transfer Service" as C_TransferService
component "Account Service" as C_AccountService
component "Interest Service" as C_InterestService
component "Deposit Service" as C_DepositService
component "Branch Service" as C_BranchService
component "Statement Service" as C_StatementService
database "Banking DB" as DB_banking
C_TransferService --> DB_banking
C_InterestService --> DB_banking
C_DepositService --> DB_banking
C_BranchService --> DB_banking
C_InterestService ..> C_AccountService : MQ
C_BranchService ..> C_AccountService : HTTP
C_DepositService ..> C_StatementService : HTTP
C_StatementService ..> C_BranchService : MQ
C_TransferService ..> C_StatementService : gRPC
@enduml