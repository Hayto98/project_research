@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
component "Loan Service" as C_LoanService
component "Branch Service" as C_BranchService
component "Publisher Service" as C_PublisherService
component "Catalog Service" as C_CatalogService
component "Librarian Service" as C_LibrarianService
database "Library DB" as DB_library
C_BranchService --> DB_library
C_PublisherService --> DB_library
C_CatalogService --> DB_library
C_LoanService ..> C_PublisherService : REST
C_CatalogService ..> C_LibrarianService : gRPC
C_BranchService ..> C_LoanService : gRPC
C_LoanService ..> C_LibrarianService : REST
@enduml