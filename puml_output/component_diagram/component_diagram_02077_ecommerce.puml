@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
component "Return Service" as C_ReturnService
component "Payment Service" as C_PaymentService
component "Supplier Service" as C_SupplierService
component "Invoice Service" as C_InvoiceService
database "Ecommerce DB" as DB_ecommerce
C_ReturnService --> DB_ecommerce
C_SupplierService --> DB_ecommerce
C_SupplierService ..> C_ReturnService : MQ
C_InvoiceService ..> C_ReturnService : gRPC
@enduml