@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
component "FuelLog Service" as C_FuelLogService
component "Driver Service" as C_DriverService
component "Package Service" as C_PackageService
component "Tracking Service" as C_TrackingService
component "Route Service" as C_RouteService
component "Manifest Service" as C_ManifestService
database "Logistics DB" as DB_logistics
C_DriverService --> DB_logistics
C_PackageService --> DB_logistics
C_TrackingService --> DB_logistics
C_RouteService --> DB_logistics
C_ManifestService --> DB_logistics
C_PackageService ..> C_DriverService : HTTP
C_TrackingService ..> C_FuelLogService : HTTP
C_DriverService ..> C_RouteService : gRPC
@enduml