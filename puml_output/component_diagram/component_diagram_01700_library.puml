@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
component "Book Service" as C_BookService
component "Publisher Service" as C_PublisherService
component "Reservation Service" as C_ReservationService
component "Renewal Service" as C_RenewalService
component "Fine Service" as C_FineService
component "Member Service" as C_MemberService
database "Library DB" as DB_library
C_BookService --> DB_library
C_RenewalService --> DB_library
C_FineService --> DB_library
C_MemberService --> DB_library
C_MemberService ..> C_BookService : HTTP
C_MemberService ..> C_RenewalService : gRPC
C_ReservationService ..> C_BookService : MQ
C_ReservationService ..> C_FineService : gRPC
C_PublisherService ..> C_MemberService : REST
@enduml