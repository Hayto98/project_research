@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
component "Prescription Service" as C_PrescriptionService
component "Nurse Service" as C_NurseService
component "Diagnosis Service" as C_DiagnosisService
component "Hospital Service" as C_HospitalService
component "Billing Service" as C_BillingService
component "Treatment Service" as C_TreatmentService
component "Patient Service" as C_PatientService
database "Healthcare DB" as DB_healthcare
C_DiagnosisService --> DB_healthcare
C_PatientService --> DB_healthcare
C_TreatmentService ..> C_PatientService : HTTP
C_NurseService ..> C_PatientService : HTTP
C_PrescriptionService ..> C_HospitalService : gRPC
C_NurseService ..> C_PrescriptionService : gRPC
C_DiagnosisService ..> C_PatientService : REST
@enduml