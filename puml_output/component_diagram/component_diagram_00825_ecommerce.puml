@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
component "Warehouse Service" as C_WarehouseService
component "Return Service" as C_ReturnService
component "Wishlist Service" as C_WishlistService
component "Supplier Service" as C_SupplierService
component "Invoice Service" as C_InvoiceService
database "Ecommerce DB" as DB_ecommerce
C_SupplierService --> DB_ecommerce
C_InvoiceService --> DB_ecommerce
C_InvoiceService ..> C_WarehouseService : gRPC
C_SupplierService ..> C_ReturnService : HTTP
C_SupplierService ..> C_WishlistService : MQ
@enduml