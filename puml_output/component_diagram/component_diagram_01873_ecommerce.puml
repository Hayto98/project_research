@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
component "Order Service" as C_OrderService
component "Invoice Service" as C_InvoiceService
component "Return Service" as C_ReturnService
component "Payment Service" as C_PaymentService
component "Shipment Service" as C_ShipmentService
component "Cart Service" as C_CartService
component "Product Service" as C_ProductService
database "Ecommerce DB" as DB_ecommerce
C_OrderService --> DB_ecommerce
C_InvoiceService --> DB_ecommerce
C_ReturnService --> DB_ecommerce
C_ShipmentService --> DB_ecommerce
C_CartService --> DB_ecommerce
C_OrderService ..> C_CartService : MQ
C_CartService ..> C_PaymentService : HTTP
C_CartService ..> C_OrderService : HTTP
C_InvoiceService ..> C_ReturnService : MQ
@enduml