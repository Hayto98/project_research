@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
component "Warehouse Service" as C_WarehouseService
component "Cart Service" as C_CartService
component "Payment Service" as C_PaymentService
component "Return Service" as C_ReturnService
database "Ecommerce DB" as DB_ecommerce
C_WarehouseService --> DB_ecommerce
C_ReturnService --> DB_ecommerce
C_CartService ..> C_ReturnService : HTTP
C_ReturnService ..> C_WarehouseService : gRPC
@enduml