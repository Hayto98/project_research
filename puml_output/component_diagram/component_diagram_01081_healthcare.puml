@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
component "Billing Service" as C_BillingService
component "Insurance Service" as C_InsuranceService
component "LabTest Service" as C_LabTestService
component "Doctor Service" as C_DoctorService
component "Nurse Service" as C_NurseService
component "Appointment Service" as C_AppointmentService
component "Hospital Service" as C_HospitalService
database "Healthcare DB" as DB_healthcare
C_BillingService --> DB_healthcare
C_InsuranceService --> DB_healthcare
C_LabTestService --> DB_healthcare
C_DoctorService --> DB_healthcare
C_NurseService --> DB_healthcare
C_AppointmentService --> DB_healthcare
C_HospitalService --> DB_healthcare
C_InsuranceService ..> C_BillingService : MQ
C_HospitalService ..> C_LabTestService : gRPC
C_HospitalService ..> C_InsuranceService : gRPC
C_HospitalService ..> C_AppointmentService : HTTP
C_NurseService ..> C_HospitalService : gRPC
C_DoctorService ..> C_HospitalService : REST
@enduml