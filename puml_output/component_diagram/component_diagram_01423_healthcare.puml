@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
component "Doctor Service" as C_DoctorService
component "Nurse Service" as C_NurseService
component "Treatment Service" as C_TreatmentService
component "Hospital Service" as C_HospitalService
database "Healthcare DB" as DB_healthcare
C_TreatmentService --> DB_healthcare
C_HospitalService --> DB_healthcare
C_NurseService ..> C_TreatmentService : HTTP
C_TreatmentService ..> C_DoctorService : REST
C_HospitalService ..> C_DoctorService : HTTP
@enduml