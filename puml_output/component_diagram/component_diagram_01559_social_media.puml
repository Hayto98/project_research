@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
component "Post Service" as C_PostService
component "Story Service" as C_StoryService
component "User Service" as C_UserService
component "Notification Service" as C_NotificationService
component "Profile Service" as C_ProfileService
component "Album Service" as C_AlbumService
component "Report Service" as C_ReportService
database "Social Media DB" as DB_social_media
C_PostService --> DB_social_media
C_UserService --> DB_social_media
C_NotificationService --> DB_social_media
C_ProfileService --> DB_social_media
C_AlbumService --> DB_social_media
C_StoryService ..> C_AlbumService : HTTP
C_NotificationService ..> C_AlbumService : REST
C_UserService ..> C_NotificationService : REST
C_PostService ..> C_StoryService : HTTP
C_ReportService ..> C_ProfileService : REST
@enduml