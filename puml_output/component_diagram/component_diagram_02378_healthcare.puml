@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
component "Doctor Service" as C_DoctorService
component "Diagnosis Service" as C_DiagnosisService
component "Billing Service" as C_BillingService
component "Insurance Service" as C_InsuranceService
component "Ward Service" as C_WardService
component "Prescription Service" as C_PrescriptionService
component "Treatment Service" as C_TreatmentService
database "Healthcare DB" as DB_healthcare
C_DiagnosisService --> DB_healthcare
C_BillingService --> DB_healthcare
C_WardService --> DB_healthcare
C_TreatmentService --> DB_healthcare
C_DiagnosisService ..> C_InsuranceService : gRPC
C_DoctorService ..> C_BillingService : gRPC
C_PrescriptionService ..> C_WardService : gRPC
C_WardService ..> C_PrescriptionService : MQ
C_BillingService ..> C_InsuranceService : MQ
C_BillingService ..> C_PrescriptionService : HTTP
@enduml