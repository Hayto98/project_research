@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
component "Album Service" as C_AlbumService
component "User Service" as C_UserService
component "Report Service" as C_ReportService
component "Profile Service" as C_ProfileService
component "Group Service" as C_GroupService
component "Comment Service" as C_CommentService
component "Notification Service" as C_NotificationService
database "Social Media DB" as DB_social_media
C_AlbumService --> DB_social_media
C_UserService --> DB_social_media
C_ReportService --> DB_social_media
C_ProfileService --> DB_social_media
C_UserService ..> C_ProfileService : HTTP
C_AlbumService ..> C_UserService : MQ
C_ProfileService ..> C_UserService : MQ
C_ReportService ..> C_CommentService : MQ
C_CommentService ..> C_ReportService : MQ
C_NotificationService ..> C_AlbumService : gRPC
@enduml