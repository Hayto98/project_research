@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
component "Attendance Service" as C_AttendanceService
component "Department Service" as C_DepartmentService
component "Teacher Service" as C_TeacherService
component "Schedule Service" as C_ScheduleService
component "Assignment Service" as C_AssignmentService
database "Education DB" as DB_education
C_AttendanceService --> DB_education
C_DepartmentService --> DB_education
C_TeacherService --> DB_education
C_ScheduleService --> DB_education
C_AssignmentService --> DB_education
C_AttendanceService ..> C_DepartmentService : MQ
C_TeacherService ..> C_DepartmentService : MQ
C_DepartmentService ..> C_AssignmentService : REST
C_DepartmentService ..> C_ScheduleService : MQ
@enduml