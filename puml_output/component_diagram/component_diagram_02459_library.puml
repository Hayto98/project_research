@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
component "Publisher Service" as C_PublisherService
component "Fine Service" as C_FineService
component "Librarian Service" as C_LibrarianService
component "Branch Service" as C_BranchService
component "Loan Service" as C_LoanService
component "Book Service" as C_BookService
component "Reservation Service" as C_ReservationService
database "Library DB" as DB_library
C_PublisherService --> DB_library
C_FineService --> DB_library
C_LoanService --> DB_library
C_BookService --> DB_library
C_ReservationService ..> C_FineService : gRPC
C_BookService ..> C_ReservationService : REST
C_LoanService ..> C_PublisherService : MQ
C_BookService ..> C_BranchService : REST
C_ReservationService ..> C_PublisherService : HTTP
@enduml