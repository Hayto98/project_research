@startuml
skinparam monochrome true
skinparam ArrowColor #555555
component "Product Service" as C_ProductService
component "Invoice Service" as C_InvoiceService
component "Cart Service" as C_CartService
component "Shipment Service" as C_ShipmentService
component "Customer Service" as C_CustomerService
component "Wishlist Service" as C_WishlistService
component "Supplier Service" as C_SupplierService
database "Ecommerce DB" as DB_ecommerce
C_CartService --> DB_ecommerce
C_ShipmentService --> DB_ecommerce
C_CustomerService --> DB_ecommerce
C_WishlistService --> DB_ecommerce
C_SupplierService --> DB_ecommerce
C_CustomerService ..> C_ProductService : gRPC
C_InvoiceService ..> C_SupplierService : gRPC
C_CustomerService ..> C_InvoiceService : REST
C_InvoiceService ..> C_ProductService : REST
@enduml