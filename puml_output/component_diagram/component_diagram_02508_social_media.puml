@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
component "Message Service" as C_MessageService
component "Story Service" as C_StoryService
component "Album Service" as C_AlbumService
component "Group Service" as C_GroupService
component "Hashtag Service" as C_HashtagService
component "Follower Service" as C_FollowerService
database "Social Media DB" as DB_social_media
C_MessageService --> DB_social_media
C_StoryService --> DB_social_media
C_GroupService --> DB_social_media
C_HashtagService --> DB_social_media
C_FollowerService --> DB_social_media
C_AlbumService ..> C_GroupService : gRPC
C_FollowerService ..> C_GroupService : HTTP
C_AlbumService ..> C_FollowerService : gRPC
C_FollowerService ..> C_StoryService : HTTP
C_StoryService ..> C_FollowerService : MQ
@enduml