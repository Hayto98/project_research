@startuml
skinparam monochrome true
skinparam shadowing true
component "Group Service" as C_GroupService
component "Profile Service" as C_ProfileService
component "Post Service" as C_PostService
component "Album Service" as C_AlbumService
component "Like Service" as C_LikeService
component "Report Service" as C_ReportService
component "Message Service" as C_MessageService
database "Social Media DB" as DB_social_media
C_GroupService --> DB_social_media
C_ProfileService --> DB_social_media
C_AlbumService --> DB_social_media
C_LikeService --> DB_social_media
C_ReportService ..> C_LikeService : MQ
C_MessageService ..> C_PostService : HTTP
C_MessageService ..> C_ProfileService : HTTP
C_PostService ..> C_ReportService : gRPC
C_ReportService ..> C_PostService : MQ
@enduml