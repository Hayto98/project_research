@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
component "User Service" as C_UserService
component "Story Service" as C_StoryService
component "Album Service" as C_AlbumService
component "Report Service" as C_ReportService
component "Post Service" as C_PostService
component "Group Service" as C_GroupService
database "Social Media DB" as DB_social_media
C_UserService --> DB_social_media
C_StoryService --> DB_social_media
C_PostService --> DB_social_media
C_GroupService --> DB_social_media
C_PostService ..> C_UserService : gRPC
C_AlbumService ..> C_PostService : MQ
C_StoryService ..> C_UserService : MQ
C_UserService ..> C_PostService : gRPC
@enduml