@startuml
skinparam monochrome true
skinparam ArrowColor #555555
component "Treatment Service" as C_TreatmentService
component "Insurance Service" as C_InsuranceService
component "Doctor Service" as C_DoctorService
component "Appointment Service" as C_AppointmentService
component "Ward Service" as C_WardService
component "LabTest Service" as C_LabTestService
database "Healthcare DB" as DB_healthcare
C_DoctorService --> DB_healthcare
