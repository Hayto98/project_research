@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
component "Warehouse Service" as C_WarehouseService
component "Depot Service" as C_DepotService
component "Package Service" as C_PackageService
component "FuelLog Service" as C_FuelLogService
component "DeliveryNote Service" as C_DeliveryNoteService
database "Logistics DB" as DB_logistics
C_DepotService --> DB_logistics
C_PackageService --> DB_logistics
C_FuelLogService --> DB_logistics
C_DeliveryNoteService --> DB_logistics
C_PackageService ..> C_DeliveryNoteService : MQ
C_FuelLogService ..> C_WarehouseService : MQ
C_DeliveryNoteService ..> C_FuelLogService : REST
C_DeliveryNoteService ..> C_FuelLogService : MQ
@enduml