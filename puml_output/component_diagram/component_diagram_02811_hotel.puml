@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
component "CheckIn Service" as C_CheckInService
component "Restaurant Service" as C_RestaurantService
component "Guest Service" as C_GuestService
component "Staff Service" as C_StaffService
component "Reservation Service" as C_ReservationService
database "Hotel DB" as DB_hotel
C_RestaurantService --> DB_hotel
C_GuestService --> DB_hotel
C_StaffService --> DB_hotel
C_ReservationService --> DB_hotel
C_StaffService ..> C_RestaurantService : MQ
C_RestaurantService ..> C_CheckInService : REST
C_CheckInService ..> C_StaffService : MQ
@enduml