@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
component "Booking Service" as C_BookingService
component "Invoice Service" as C_InvoiceService
component "Room Service" as C_RoomService
component "Guest Service" as C_GuestService
component "Service Service" as C_ServiceService
database "Hotel DB" as DB_hotel
C_BookingService --> DB_hotel
C_InvoiceService --> DB_hotel
C_RoomService --> DB_hotel
C_GuestService --> DB_hotel
C_ServiceService --> DB_hotel
C_BookingService ..> C_GuestService : MQ
C_InvoiceService ..> C_GuestService : HTTP
C_RoomService ..> C_BookingService : HTTP
@enduml