@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
component "Customer Service" as C_CustomerService
component "Invoice Service" as C_InvoiceService
component "Review Service" as C_ReviewService
component "Category Service" as C_CategoryService
component "Product Service" as C_ProductService
component "Supplier Service" as C_SupplierService
component "Order Service" as C_OrderService
database "Ecommerce DB" as DB_ecommerce
C_CustomerService --> DB_ecommerce
C_InvoiceService --> DB_ecommerce
C_ReviewService --> DB_ecommerce
C_CategoryService --> DB_ecommerce
C_ProductService --> DB_ecommerce
C_SupplierService --> DB_ecommerce
C_CategoryService ..> C_OrderService : gRPC
C_SupplierService ..> C_OrderService : MQ
C_CustomerService ..> C_CategoryService : HTTP
C_InvoiceService ..> C_CategoryService : HTTP
C_CustomerService ..> C_InvoiceService : MQ
C_CustomerService ..> C_ProductService : REST
@enduml