@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
component "Driver Service" as C_DriverService
component "Package Service" as C_PackageService
component "Depot Service" as C_DepotService
