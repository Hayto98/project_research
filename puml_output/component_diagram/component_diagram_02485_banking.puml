@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
component "Interest Service" as C_InterestService
component "Customer Service" as C_CustomerService
component "Loan Service" as C_LoanService
component "Deposit Service" as C_DepositService
component "Card Service" as C_CardService
component "Account Service" as C_AccountService
database "Banking DB" as DB_banking
C_CustomerService --> DB_banking
C_LoanService --> DB_banking
C_CardService --> DB_banking
C_AccountService --> DB_banking
C_DepositService ..> C_InterestService : MQ
C_InterestService ..> C_AccountService : gRPC
C_LoanService ..> C_InterestService : MQ
C_InterestService ..> C_DepositService : gRPC
C_AccountService ..> C_DepositService : REST
@enduml