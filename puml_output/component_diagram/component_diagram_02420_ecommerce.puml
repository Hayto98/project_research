@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
component "Customer Service" as C_CustomerService
component "Coupon Service" as C_CouponService
component "Order Service" as C_OrderService
component "Invoice Service" as C_InvoiceService
component "Product Service" as C_ProductService
component "Cart Service" as C_CartService
database "Ecommerce DB" as DB_ecommerce
C_CustomerService --> DB_ecommerce
C_CouponService --> DB_ecommerce
C_OrderService --> DB_ecommerce
C_InvoiceService --> DB_ecommerce
C_CartService --> DB_ecommerce
C_CustomerService ..> C_OrderService : MQ
C_CouponService ..> C_ProductService : gRPC
C_CartService ..> C_InvoiceService : gRPC
C_CustomerService ..> C_InvoiceService : gRPC
C_CustomerService ..> C_InvoiceService : MQ
@enduml