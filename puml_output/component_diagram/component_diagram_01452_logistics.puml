@startuml
skinparam monochrome true
skinparam ArrowColor #555555
component "Manifest Service" as C_ManifestService
component "Route Service" as C_RouteService
component "Vehicle Service" as C_VehicleService
component "Depot Service" as C_DepotService
component "Customer Service" as C_CustomerService
component "FuelLog Service" as C_FuelLogService
component "Package Service" as C_PackageService
database "Logistics DB" as DB_logistics
C_RouteService --> DB_logistics
C_VehicleService --> DB_logistics
C_DepotService --> DB_logistics
C_FuelLogService --> DB_logistics
C_PackageService --> DB_logistics
C_DepotService ..> C_FuelLogService : gRPC
C_CustomerService ..> C_DepotService : gRPC
C_VehicleService ..> C_DepotService : REST
C_CustomerService ..> C_PackageService : MQ
C_VehicleService ..> C_RouteService : HTTP
C_CustomerService ..> C_RouteService : MQ
@enduml