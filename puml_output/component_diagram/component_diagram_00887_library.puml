@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
component "Book Service" as C_BookService
component "Reservation Service" as C_ReservationService
component "Publisher Service" as C_PublisherService
component "Fine Service" as C_FineService
component "Librarian Service" as C_LibrarianService
component "Shelf Service" as C_ShelfService
database "Library DB" as DB_library
C_BookService --> DB_library
C_ReservationService --> DB_library
C_PublisherService --> DB_library
C_FineService --> DB_library
C_LibrarianService --> DB_library
C_ShelfService --> DB_library
C_FineService ..> C_PublisherService : REST
C_ReservationService ..> C_PublisherService : REST
C_BookService ..> C_FineService : gRPC
@enduml