@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
component "Beneficiary Service" as C_BeneficiaryService
component "Withdrawal Service" as C_WithdrawalService
component "Transfer Service" as C_TransferService
component "Interest Service" as C_InterestService
component "Branch Service" as C_BranchService
database "Banking DB" as DB_banking
C_BeneficiaryService --> DB_banking
C_WithdrawalService --> DB_banking
C_TransferService --> DB_banking
C_InterestService --> DB_banking
C_BranchService --> DB_banking
C_InterestService ..> C_TransferService : REST
C_BranchService ..> C_BeneficiaryService : gRPC
C_BranchService ..> C_WithdrawalService : MQ
C_InterestService ..> C_TransferService : MQ
@enduml