@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
component "Book Service" as C_BookService
component "Renewal Service" as C_RenewalService
component "Loan Service" as C_LoanService
component "Catalog Service" as C_CatalogService
component "Publisher Service" as C_PublisherService
component "Author Service" as C_AuthorService
component "Shelf Service" as C_ShelfService
database "Library DB" as DB_library
C_RenewalService --> DB_library
C_CatalogService --> DB_library
C_PublisherService --> DB_library
C_AuthorService --> DB_library
C_BookService ..> C_LoanService : MQ
C_RenewalService ..> C_AuthorService : REST
C_PublisherService ..> C_ShelfService : MQ
@enduml