@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
component "Prescription Service" as C_PrescriptionService
component "Insurance Service" as C_InsuranceService
component "Treatment Service" as C_TreatmentService
component "Appointment Service" as C_AppointmentService
component "Billing Service" as C_BillingService
database "Healthcare DB" as DB_healthcare
C_PrescriptionService --> DB_healthcare
C_TreatmentService --> DB_healthcare
C_BillingService --> DB_healthcare
C_TreatmentService ..> C_AppointmentService : HTTP
C_BillingService ..> C_TreatmentService : HTTP
C_InsuranceService ..> C_BillingService : REST
C_AppointmentService ..> C_PrescriptionService : HTTP
@enduml