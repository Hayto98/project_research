@startuml
skinparam monochrome true
skinparam ArrowColor #555555
component "Billing Service" as C_BillingService
component "Prescription Service" as C_PrescriptionService
component "Insurance Service" as C_InsuranceService
component "Diagnosis Service" as C_DiagnosisService
component "Treatment Service" as C_TreatmentService
component "MedicalRecord Service" as C_MedicalRecordService
database "Healthcare DB" as DB_healthcare
C_BillingService --> DB_healthcare
C_PrescriptionService --> DB_healthcare
C_InsuranceService --> DB_healthcare
C_TreatmentService --> DB_healthcare
C_MedicalRecordService --> DB_healthcare
C_InsuranceService ..> C_DiagnosisService : gRPC
C_BillingService ..> C_MedicalRecordService : MQ
C_TreatmentService ..> C_PrescriptionService : REST
C_MedicalRecordService ..> C_DiagnosisService : REST
@enduml