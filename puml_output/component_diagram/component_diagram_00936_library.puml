@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
component "Reservation Service" as C_ReservationService
component "Branch Service" as C_BranchService
component "Author Service" as C_AuthorService
component "Book Service" as C_BookService
component "Member Service" as C_MemberService
database "Library DB" as DB_library
C_ReservationService --> DB_library
C_BranchService --> DB_library
C_AuthorService --> DB_library
C_BookService --> DB_library
C_AuthorService ..> C_ReservationService : HTTP
C_BookService ..> C_MemberService : HTTP
C_BookService ..> C_BranchService : REST
C_BranchService ..> C_MemberService : REST
@enduml