@startuml
skinparam monochrome true
skinparam defaultFontSize 13
component "Author Service" as C_AuthorService
component "Publisher Service" as C_PublisherService
component "Reservation Service" as C_ReservationService
component "Loan Service" as C_LoanService
component "Catalog Service" as C_CatalogService
component "Branch Service" as C_BranchService
component "Fine Service" as C_FineService
database "Library DB" as DB_library
C_AuthorService --> DB_library
C_PublisherService --> DB_library
C_CatalogService --> DB_library
C_FineService --> DB_library
C_CatalogService ..> C_LoanService : HTTP
C_PublisherService ..> C_FineService : gRPC
C_BranchService ..> C_ReservationService : gRPC
C_AuthorService ..> C_CatalogService : HTTP
C_CatalogService ..> C_ReservationService : REST
C_FineService ..> C_CatalogService : MQ
@enduml