@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
component "Member Service" as C_MemberService
component "Branch Service" as C_BranchService
component "Publisher Service" as C_PublisherService
component "Reservation Service" as C_ReservationService
component "Renewal Service" as C_RenewalService
component "Author Service" as C_AuthorService
database "Library DB" as DB_library
C_MemberService --> DB_library
C_BranchService --> DB_library
C_PublisherService --> DB_library
C_ReservationService --> DB_library
C_RenewalService --> DB_library
C_AuthorService --> DB_library
C_MemberService ..> C_RenewalService : HTTP
C_RenewalService ..> C_ReservationService : REST
C_ReservationService ..> C_PublisherService : REST
@enduml