@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
component "Housekeeping Service" as C_HousekeepingService
component "CheckIn Service" as C_CheckInService
component "Service Service" as C_ServiceService
component "Reservation Service" as C_ReservationService
component "Amenity Service" as C_AmenityService
database "Hotel DB" as DB_hotel
C_HousekeepingService --> DB_hotel
C_CheckInService --> DB_hotel
C_ServiceService --> DB_hotel
C_ReservationService --> DB_hotel
C_AmenityService --> DB_hotel
C_AmenityService ..> C_HousekeepingService : MQ
C_ServiceService ..> C_ReservationService : MQ
C_HousekeepingService ..> C_ServiceService : HTTP
@enduml