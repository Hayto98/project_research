@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
component "Housekeeping Service" as C_HousekeepingService
component "Room Service" as C_RoomService
component "CheckIn Service" as C_CheckInService
component "Invoice Service" as C_InvoiceService
component "Reservation Service" as C_ReservationService
component "Guest Service" as C_GuestService
component "Booking Service" as C_BookingService
database "Hotel DB" as DB_hotel
C_HousekeepingService --> DB_hotel
C_RoomService --> DB_hotel
C_CheckInService --> DB_hotel
C_ReservationService --> DB_hotel
C_GuestService --> DB_hotel
C_BookingService --> DB_hotel
C_ReservationService ..> C_RoomService : REST
C_CheckInService ..> C_BookingService : MQ
C_ReservationService ..> C_BookingService : gRPC
C_GuestService ..> C_RoomService : gRPC
C_HousekeepingService ..> C_GuestService : REST
C_BookingService ..> C_RoomService : gRPC
@enduml