@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
component "Billing Service" as C_BillingService
component "LabTest Service" as C_LabTestService
component "MedicalRecord Service" as C_MedicalRecordService
component "Doctor Service" as C_DoctorService
component "Diagnosis Service" as C_DiagnosisService
component "Ward Service" as C_WardService
component "Prescription Service" as C_PrescriptionService
database "Healthcare DB" as DB_healthcare
C_DiagnosisService --> DB_healthcare
C_PrescriptionService --> DB_healthcare
C_WardService ..> C_BillingService : REST
C_PrescriptionService ..> C_WardService : gRPC
C_MedicalRecordService ..> C_DoctorService : HTTP
C_MedicalRecordService ..> C_WardService : MQ
C_PrescriptionService ..> C_LabTestService : HTTP
C_PrescriptionService ..> C_DoctorService : MQ
@enduml