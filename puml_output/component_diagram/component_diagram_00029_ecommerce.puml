@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
component "Supplier Service" as C_SupplierService
component "Shipment Service" as C_ShipmentService
component "Cart Service" as C_CartService
component "Warehouse Service" as C_WarehouseService
component "Customer Service" as C_CustomerService
component "Payment Service" as C_PaymentService
database "Ecommerce DB" as DB_ecommerce
C_SupplierService --> DB_ecommerce
C_ShipmentService --> DB_ecommerce
C_CartService --> DB_ecommerce
C_CustomerService --> DB_ecommerce
C_CartService ..> C_ShipmentService : REST
C_CustomerService ..> C_WarehouseService : gRPC
C_PaymentService ..> C_WarehouseService : HTTP
C_WarehouseService ..> C_PaymentService : REST
C_WarehouseService ..> C_SupplierService : gRPC
@enduml