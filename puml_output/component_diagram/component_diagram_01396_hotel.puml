@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
component "Booking Service" as C_BookingService
component "Service Service" as C_ServiceService
component "CheckIn Service" as C_CheckInService
component "Reservation Service" as C_ReservationService
component "Payment Service" as C_PaymentService
component "CheckOut Service" as C_CheckOutService
component "Housekeeping Service" as C_HousekeepingService
database "Hotel DB" as DB_hotel
C_BookingService --> DB_hotel
C_ServiceService --> DB_hotel
C_CheckInService --> DB_hotel
C_PaymentService --> DB_hotel
C_CheckOutService --> DB_hotel
C_HousekeepingService --> DB_hotel
C_ReservationService ..> C_CheckInService : MQ
C_ReservationService ..> C_HousekeepingService : REST
C_ReservationService ..> C_CheckInService : MQ
C_CheckOutService ..> C_BookingService : gRPC
C_ReservationService ..> C_BookingService : MQ
@enduml