@startuml
skinparam monochrome true
skinparam defaultFontSize 11
component "Nurse Service" as C_NurseService
component "Ward Service" as C_WardService
component "Treatment Service" as C_TreatmentService
component "Prescription Service" as C_PrescriptionService
component "Hospital Service" as C_HospitalService
component "Billing Service" as C_BillingService
component "Insurance Service" as C_InsuranceService
database "Healthcare DB" as DB_healthcare
C_NurseService --> DB_healthcare
C_WardService --> DB_healthcare
C_TreatmentService --> DB_healthcare
C_BillingService --> DB_healthcare
C_InsuranceService --> DB_healthcare
C_TreatmentService ..> C_InsuranceService : gRPC
C_PrescriptionService ..> C_HospitalService : REST
C_PrescriptionService ..> C_NurseService : HTTP
C_WardService ..> C_InsuranceService : REST
C_HospitalService ..> C_PrescriptionService : HTTP
C_NurseService ..> C_TreatmentService : gRPC
@enduml