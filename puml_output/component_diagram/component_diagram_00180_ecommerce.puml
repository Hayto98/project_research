@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
component "Warehouse Service" as C_WarehouseService
component "Supplier Service" as C_SupplierService
component "Invoice Service" as C_InvoiceService
component "Wishlist Service" as C_WishlistService
database "Ecommerce DB" as DB_ecommerce
C_WarehouseService --> DB_ecommerce
C_SupplierService --> DB_ecommerce
C_InvoiceService --> DB_ecommerce
C_WishlistService --> DB_ecommerce
C_WarehouseService ..> C_InvoiceService : gRPC
C_WarehouseService ..> C_SupplierService : HTTP
C_WishlistService ..> C_InvoiceService : REST
@enduml