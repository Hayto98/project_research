@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
component "Reservation Service" as C_ReservationService
component "Member Service" as C_MemberService
component "Publisher Service" as C_PublisherService
component "Fine Service" as C_FineService
component "Author Service" as C_AuthorService
database "Library DB" as DB_library
C_ReservationService --> DB_library
C_MemberService --> DB_library
C_FineService --> DB_library
C_AuthorService --> DB_library
C_PublisherService ..> C_AuthorService : REST
C_PublisherService ..> C_MemberService : HTTP
C_PublisherService ..> C_FineService : gRPC
@enduml