@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
component "Customer Service" as C_CustomerService
component "Warehouse Service" as C_WarehouseService
component "Shipment Service" as C_ShipmentService
component "Route Service" as C_RouteService
component "Tracking Service" as C_TrackingService
component "Package Service" as C_PackageService
database "Logistics DB" as DB_logistics
C_CustomerService --> DB_logistics
C_WarehouseService --> DB_logistics
C_ShipmentService --> DB_logistics
C_RouteService --> DB_logistics
C_TrackingService --> DB_logistics
C_PackageService --> DB_logistics
C_CustomerService ..> C_PackageService : gRPC
C_RouteService ..> C_ShipmentService : HTTP
C_TrackingService ..> C_WarehouseService : HTTP
C_CustomerService ..> C_RouteService : gRPC
C_TrackingService ..> C_RouteService : HTTP
@enduml