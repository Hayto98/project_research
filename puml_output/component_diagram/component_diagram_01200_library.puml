@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
component "Branch Service" as C_BranchService
component "Shelf Service" as C_ShelfService
component "Loan Service" as C_LoanService
component "Member Service" as C_MemberService
component "Publisher Service" as C_PublisherService
database "Library DB" as DB_library
C_MemberService --> DB_library
C_PublisherService --> DB_library
C_MemberService ..> C_ShelfService : gRPC
C_MemberService ..> C_BranchService : MQ
C_MemberService ..> C_PublisherService : gRPC
C_ShelfService ..> C_PublisherService : gRPC
@enduml