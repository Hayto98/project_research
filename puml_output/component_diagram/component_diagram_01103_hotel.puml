@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
component "Staff Service" as C_StaffService
component "Restaurant Service" as C_RestaurantService
component "Invoice Service" as C_InvoiceService
component "Reservation Service" as C_ReservationService
component "Housekeeping Service" as C_HousekeepingService
component "CheckIn Service" as C_CheckInService
database "Hotel DB" as DB_hotel
C_StaffService --> DB_hotel
C_ReservationService --> DB_hotel
C_HousekeepingService --> DB_hotel
C_ReservationService ..> C_RestaurantService : HTTP
C_RestaurantService ..> C_StaffService : HTTP
C_ReservationService ..> C_InvoiceService : gRPC
C_StaffService ..> C_ReservationService : MQ
@enduml