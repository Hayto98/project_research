@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
component "Service Service" as C_ServiceService
component "Restaurant Service" as C_RestaurantService
component "Housekeeping Service" as C_HousekeepingService
component "CheckIn Service" as C_CheckInService
component "Invoice Service" as C_InvoiceService
component "Booking Service" as C_BookingService
component "Payment Service" as C_PaymentService
database "Hotel DB" as DB_hotel
C_HousekeepingService --> DB_hotel
C_BookingService --> DB_hotel
C_RestaurantService ..> C_InvoiceService : HTTP
C_ServiceService ..> C_InvoiceService : HTTP
C_CheckInService ..> C_PaymentService : HTTP
@enduml