@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
component "Branch Service" as C_BranchService
component "Book Service" as C_BookService
component "Member Service" as C_MemberService
component "Loan Service" as C_LoanService
component "Fine Service" as C_FineService
component "Catalog Service" as C_CatalogService
component "Publisher Service" as C_PublisherService
database "Library DB" as DB_library
C_BookService --> DB_library
C_MemberService --> DB_library
C_LoanService --> DB_library
C_PublisherService --> DB_library
C_CatalogService ..> C_PublisherService : gRPC
C_BookService ..> C_LoanService : HTTP
C_PublisherService ..> C_BranchService : HTTP
@enduml