@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
component "Inventory Service" as C_InventoryService
component "Warehouse Service" as C_WarehouseService
component "Driver Service" as C_DriverService
component "DeliveryNote Service" as C_DeliveryNoteService
component "Route Service" as C_RouteService
component "Manifest Service" as C_ManifestService
component "Tracking Service" as C_TrackingService
database "Logistics DB" as DB_logistics
C_DriverService --> DB_logistics
C_DeliveryNoteService --> DB_logistics
C_RouteService --> DB_logistics
C_ManifestService --> DB_logistics
C_TrackingService --> DB_logistics
C_WarehouseService ..> C_DriverService : gRPC
C_InventoryService ..> C_DeliveryNoteService : HTTP
C_DriverService ..> C_WarehouseService : REST
C_InventoryService ..> C_TrackingService : MQ
C_ManifestService ..> C_TrackingService : REST
C_WarehouseService ..> C_InventoryService : MQ
@enduml