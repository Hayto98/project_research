@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
component "Report Service" as C_ReportService
component "Album Service" as C_AlbumService
component "Like Service" as C_LikeService
component "Follower Service" as C_FollowerService
component "Group Service" as C_GroupService
component "User Service" as C_UserService
component "Comment Service" as C_CommentService
database "Social Media DB" as DB_social_media
C_ReportService --> DB_social_media
C_LikeService --> DB_social_media
C_FollowerService --> DB_social_media
C_GroupService --> DB_social_media
C_CommentService --> DB_social_media
C_CommentService ..> C_GroupService : REST
C_AlbumService ..> C_UserService : HTTP
C_FollowerService ..> C_AlbumService : HTTP
@enduml