@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
component "Billing Service" as C_BillingService
component "Treatment Service" as C_TreatmentService
component "Appointment Service" as C_AppointmentService
component "Patient Service" as C_PatientService
component "Prescription Service" as C_PrescriptionService
component "Hospital Service" as C_HospitalService
database "Healthcare DB" as DB_healthcare
C_BillingService --> DB_healthcare
C_AppointmentService --> DB_healthcare
C_PatientService --> DB_healthcare
C_PrescriptionService --> DB_healthcare
C_HospitalService --> DB_healthcare
C_TreatmentService ..> C_PatientService : REST
C_TreatmentService ..> C_BillingService : REST
C_TreatmentService ..> C_HospitalService : HTTP
C_HospitalService ..> C_PrescriptionService : gRPC
C_PrescriptionService ..> C_HospitalService : REST
@enduml