@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
component "Product Service" as C_ProductService
component "Review Service" as C_ReviewService
component "Payment Service" as C_PaymentService
component "Cart Service" as C_CartService
component "Supplier Service" as C_SupplierService
database "Ecommerce DB" as DB_ecommerce
C_ProductService --> DB_ecommerce
C_PaymentService ..> C_CartService : REST
C_ReviewService ..> C_CartService : HTTP
C_SupplierService ..> C_ProductService : gRPC
C_ReviewService ..> C_SupplierService : gRPC
@enduml