@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
component "Nurse Service" as C_NurseService
component "Ward Service" as C_WardService
component "Hospital Service" as C_HospitalService
component "Doctor Service" as C_DoctorService
component "Billing Service" as C_BillingService
component "Patient Service" as C_PatientService
database "Healthcare DB" as DB_healthcare
C_WardService --> DB_healthcare
C_HospitalService --> DB_healthcare
C_DoctorService --> DB_healthcare
C_BillingService --> DB_healthcare
C_PatientService --> DB_healthcare
C_HospitalService ..> C_PatientService : REST
C_PatientService ..> C_HospitalService : gRPC
C_PatientService ..> C_DoctorService : gRPC
C_NurseService ..> C_WardService : MQ
@enduml