@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
component "Restaurant Service" as C_RestaurantService
component "Guest Service" as C_GuestService
component "Room Service" as C_RoomService
component "CheckIn Service" as C_CheckInService
component "Reservation Service" as C_ReservationService
component "Invoice Service" as C_InvoiceService
component "Booking Service" as C_BookingService
database "Hotel DB" as DB_hotel
C_RestaurantService --> DB_hotel
C_GuestService --> DB_hotel
C_RoomService --> DB_hotel
C_CheckInService --> DB_hotel
C_ReservationService --> DB_hotel
C_CheckInService ..> C_BookingService : gRPC
C_ReservationService ..> C_RoomService : MQ
C_InvoiceService ..> C_GuestService : HTTP
C_BookingService ..> C_InvoiceService : REST
C_InvoiceService ..> C_ReservationService : HTTP
@enduml