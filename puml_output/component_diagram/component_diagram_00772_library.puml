@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
component "Renewal Service" as C_RenewalService
component "Fine Service" as C_FineService
component "Librarian Service" as C_LibrarianService
component "Author Service" as C_AuthorService
component "Shelf Service" as C_ShelfService
component "Member Service" as C_MemberService
database "Library DB" as DB_library
C_RenewalService --> DB_library
C_FineService --> DB_library
C_LibrarianService --> DB_library
C_AuthorService --> DB_library
C_ShelfService --> DB_library
C_MemberService --> DB_library
C_LibrarianService ..> C_MemberService : HTTP
C_ShelfService ..> C_LibrarianService : REST
C_LibrarianService ..> C_AuthorService : HTTP
C_LibrarianService ..> C_ShelfService : gRPC
C_LibrarianService ..> C_FineService : REST
@enduml