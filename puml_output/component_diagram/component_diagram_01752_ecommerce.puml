@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
component "Payment Service" as C_PaymentService
component "Category Service" as C_CategoryService
component "Order Service" as C_OrderService
component "Supplier Service" as C_SupplierService
component "Return Service" as C_ReturnService
component "Product Service" as C_ProductService
database "Ecommerce DB" as DB_ecommerce
C_PaymentService --> DB_ecommerce
C_CategoryService --> DB_ecommerce
C_OrderService --> DB_ecommerce
C_SupplierService --> DB_ecommerce
C_ReturnService --> DB_ecommerce
C_ProductService --> DB_ecommerce
C_SupplierService ..> C_ProductService : HTTP
C_ProductService ..> C_PaymentService : REST
C_ReturnService ..> C_CategoryService : MQ
C_ProductService ..> C_SupplierService : MQ
@enduml