@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
component "Coupon Service" as C_CouponService
component "Payment Service" as C_PaymentService
component "Return Service" as C_ReturnService
component "Wishlist Service" as C_WishlistService
database "Ecommerce DB" as DB_ecommerce
C_CouponService --> DB_ecommerce
C_PaymentService --> DB_ecommerce
C_ReturnService --> DB_ecommerce
C_WishlistService --> DB_ecommerce
C_CouponService ..> C_ReturnService : gRPC
C_PaymentService ..> C_ReturnService : MQ
C_ReturnService ..> C_CouponService : HTTP
@enduml