@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
component "Driver Service" as C_DriverService
component "Package Service" as C_PackageService
component "Route Service" as C_RouteService
component "Depot Service" as C_DepotService
component "Customer Service" as C_CustomerService
component "Manifest Service" as C_ManifestService
database "Logistics DB" as DB_logistics
C_DriverService --> DB_logistics
C_PackageService --> DB_logistics
C_CustomerService --> DB_logistics
C_RouteService ..> C_ManifestService : REST
C_DriverService ..> C_PackageService : MQ
C_DriverService ..> C_RouteService : gRPC
C_PackageService ..> C_DepotService : REST
@enduml