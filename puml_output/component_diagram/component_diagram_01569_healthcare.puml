@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
component "Prescription Service" as C_PrescriptionService
component "LabTest Service" as C_LabTestService
component "Doctor Service" as C_DoctorService
component "Insurance Service" as C_InsuranceService
component "MedicalRecord Service" as C_MedicalRecordService
component "Ward Service" as C_WardService
database "Healthcare DB" as DB_healthcare
C_DoctorService --> DB_healthcare
C_MedicalRecordService --> DB_healthcare
C_WardService --> DB_healthcare
C_LabTestService ..> C_InsuranceService : MQ
C_PrescriptionService ..> C_InsuranceService : HTTP
C_PrescriptionService ..> C_WardService : REST
C_MedicalRecordService ..> C_DoctorService : gRPC
@enduml