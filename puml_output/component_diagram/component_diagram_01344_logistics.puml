@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
component "Inventory Service" as C_InventoryService
component "Manifest Service" as C_ManifestService
component "Driver Service" as C_DriverService
component "DeliveryNote Service" as C_DeliveryNoteService
component "Vehicle Service" as C_VehicleService
component "Customer Service" as C_CustomerService
component "Warehouse Service" as C_WarehouseService
database "Logistics DB" as DB_logistics
C_ManifestService --> DB_logistics
C_DriverService --> DB_logistics
C_DeliveryNoteService --> DB_logistics
C_CustomerService --> DB_logistics
C_WarehouseService --> DB_logistics
C_CustomerService ..> C_InventoryService : REST
C_WarehouseService ..> C_CustomerService : HTTP
C_DeliveryNoteService ..> C_InventoryService : MQ
C_CustomerService ..> C_DeliveryNoteService : REST
C_DriverService ..> C_WarehouseService : MQ
@enduml