@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam shadowing true
component "Shipment Service" as C_ShipmentService
component "Customer Service" as C_CustomerService
component "Package Service" as C_PackageService
component "Driver Service" as C_DriverService
component "Manifest Service" as C_ManifestService
component "Vehicle Service" as C_VehicleService
database "Logistics DB" as DB_logistics
C_ShipmentService --> DB_logistics
C_CustomerService --> DB_logistics
C_PackageService --> DB_logistics
C_DriverService --> DB_logistics
C_VehicleService --> DB_logistics
C_VehicleService ..> C_ShipmentService : MQ
C_VehicleService ..> C_ManifestService : REST
C_CustomerService ..> C_PackageService : REST
C_PackageService ..> C_CustomerService : MQ
C_DriverService ..> C_PackageService : MQ
@enduml