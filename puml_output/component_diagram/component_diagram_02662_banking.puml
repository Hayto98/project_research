@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
component "Withdrawal Service" as C_WithdrawalService
component "Beneficiary Service" as C_BeneficiaryService
component "Interest Service" as C_InterestService
component "Transaction Service" as C_TransactionService
database "Banking DB" as DB_banking
C_WithdrawalService --> DB_banking
C_BeneficiaryService --> DB_banking
C_InterestService --> DB_banking
C_TransactionService --> DB_banking
C_InterestService ..> C_WithdrawalService : MQ
C_WithdrawalService ..> C_TransactionService : HTTP
C_InterestService ..> C_TransactionService : MQ
@enduml