@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
component "Message Service" as C_MessageService
component "Notification Service" as C_NotificationService
component "Post Service" as C_PostService
component "Album Service" as C_AlbumService
component "Story Service" as C_StoryService
component "User Service" as C_UserService
database "Social Media DB" as DB_social_media
C_NotificationService --> DB_social_media
C_PostService --> DB_social_media
C_AlbumService --> DB_social_media
C_StoryService --> DB_social_media
C_AlbumService ..> C_UserService : MQ
C_NotificationService ..> C_AlbumService : REST
C_UserService ..> C_MessageService : MQ
C_UserService ..> C_NotificationService : HTTP
C_NotificationService ..> C_PostService : gRPC
@enduml