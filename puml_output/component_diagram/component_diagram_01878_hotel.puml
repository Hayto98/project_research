@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
component "Booking Service" as C_BookingService
component "Restaurant Service" as C_RestaurantService
component "Amenity Service" as C_AmenityService
component "Housekeeping Service" as C_HousekeepingService
component "Payment Service" as C_PaymentService
component "Reservation Service" as C_ReservationService
component "CheckIn Service" as C_CheckInService
database "Hotel DB" as DB_hotel
C_BookingService --> DB_hotel
C_RestaurantService --> DB_hotel
C_AmenityService --> DB_hotel
C_HousekeepingService --> DB_hotel
C_ReservationService --> DB_hotel
C_CheckInService --> DB_hotel
C_PaymentService ..> C_HousekeepingService : HTTP
C_AmenityService ..> C_PaymentService : REST
C_BookingService ..> C_CheckInService : REST
C_RestaurantService ..> C_HousekeepingService : gRPC
C_AmenityService ..> C_CheckInService : REST
C_HousekeepingService ..> C_RestaurantService : MQ
@enduml