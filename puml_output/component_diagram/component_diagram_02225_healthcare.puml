@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
component "Insurance Service" as C_InsuranceService
component "Appointment Service" as C_AppointmentService
component "Patient Service" as C_PatientService
component "Treatment Service" as C_TreatmentService
component "Billing Service" as C_BillingService
component "Ward Service" as C_WardService
database "Healthcare DB" as DB_healthcare
C_InsuranceService --> DB_healthcare
C_PatientService --> DB_healthcare
C_TreatmentService --> DB_healthcare
C_BillingService --> DB_healthcare
C_WardService --> DB_healthcare
C_WardService ..> C_AppointmentService : gRPC
C_PatientService ..> C_TreatmentService : gRPC
C_TreatmentService ..> C_InsuranceService : MQ
C_TreatmentService ..> C_BillingService : MQ
@enduml