@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
component "Cart Service" as C_CartService
component "Return Service" as C_ReturnService
component "Invoice Service" as C_InvoiceService
component "Supplier Service" as C_SupplierService
component "Warehouse Service" as C_WarehouseService
component "Shipment Service" as C_ShipmentService
component "Review Service" as C_ReviewService
database "Ecommerce DB" as DB_ecommerce
C_CartService --> DB_ecommerce
C_ReturnService --> DB_ecommerce
C_InvoiceService --> DB_ecommerce
C_SupplierService --> DB_ecommerce
C_ShipmentService --> DB_ecommerce
C_SupplierService ..> C_WarehouseService : REST
C_WarehouseService ..> C_ReturnService : REST
@enduml