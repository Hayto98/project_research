@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
component "Customer Service" as C_CustomerService
component "Cart Service" as C_CartService
component "Supplier Service" as C_SupplierService
component "Wishlist Service" as C_WishlistService
component "Order Service" as C_OrderService
component "Payment Service" as C_PaymentService
component "Return Service" as C_ReturnService
database "Ecommerce DB" as DB_ecommerce
C_CustomerService --> DB_ecommerce
C_CartService --> DB_ecommerce
C_WishlistService --> DB_ecommerce
C_OrderService --> DB_ecommerce
C_PaymentService --> DB_ecommerce
C_ReturnService --> DB_ecommerce
C_SupplierService ..> C_WishlistService : HTTP
C_OrderService ..> C_WishlistService : HTTP
C_WishlistService ..> C_OrderService : MQ
@enduml