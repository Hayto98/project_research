@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
component "Package Service" as C_PackageService
component "Vehicle Service" as C_VehicleService
component "Warehouse Service" as C_WarehouseService
component "Tracking Service" as C_TrackingService
component "Depot Service" as C_DepotService
component "Inventory Service" as C_InventoryService
database "Logistics DB" as DB_logistics
C_PackageService --> DB_logistics
C_VehicleService --> DB_logistics
C_WarehouseService --> DB_logistics
C_TrackingService --> DB_logistics
C_DepotService --> DB_logistics
C_InventoryService --> DB_logistics
C_DepotService ..> C_WarehouseService : HTTP
C_DepotService ..> C_PackageService : gRPC
C_TrackingService ..> C_VehicleService : HTTP
C_InventoryService ..> C_PackageService : MQ
@enduml