@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
component "Branch Service" as C_BranchService
component "Loan Service" as C_LoanService
component "Beneficiary Service" as C_BeneficiaryService
component "Teller Service" as C_TellerService
component "Account Service" as C_AccountService
component "Transfer Service" as C_TransferService
database "Banking DB" as DB_banking
C_BranchService --> DB_banking
C_BeneficiaryService --> DB_banking
C_TellerService --> DB_banking
C_TransferService --> DB_banking
C_TransferService ..> C_BranchService : REST
C_TellerService ..> C_LoanService : gRPC
C_LoanService ..> C_TransferService : REST
C_TransferService ..> C_TellerService : MQ
@enduml