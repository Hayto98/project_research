@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
component "Transaction Service" as C_TransactionService
component "Statement Service" as C_StatementService
component "Transfer Service" as C_TransferService
component "Teller Service" as C_TellerService
component "Card Service" as C_CardService
database "Banking DB" as DB_banking
C_StatementService --> DB_banking
C_TellerService --> DB_banking
C_CardService --> DB_banking
C_TellerService ..> C_StatementService : MQ
C_TransactionService ..> C_TransferService : gRPC
C_StatementService ..> C_TellerService : gRPC
C_StatementService ..> C_TransactionService : HTTP
@enduml