@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
component "Warehouse Service" as C_WarehouseService
component "Invoice Service" as C_InvoiceService
component "Cart Service" as C_CartService
component "Shipment Service" as C_ShipmentService
component "Customer Service" as C_CustomerService
component "Wishlist Service" as C_WishlistService
component "Review Service" as C_ReviewService
database "Ecommerce DB" as DB_ecommerce
C_InvoiceService --> DB_ecommerce
C_CustomerService --> DB_ecommerce
C_WishlistService --> DB_ecommerce
C_ReviewService ..> C_InvoiceService : REST
C_InvoiceService ..> C_WarehouseService : MQ
C_ReviewService ..> C_ShipmentService : HTTP
C_InvoiceService ..> C_ReviewService : gRPC
C_CustomerService ..> C_ShipmentService : gRPC
C_WarehouseService ..> C_WishlistService : REST
@enduml