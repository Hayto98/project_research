@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
component "Department Service" as C_DepartmentService
component "Book Service" as C_BookService
component "Classroom Service" as C_ClassroomService
component "Grade Service" as C_GradeService
component "Assignment Service" as C_AssignmentService
component "Course Service" as C_CourseService
database "Education DB" as DB_education
C_DepartmentService --> DB_education
C_BookService --> DB_education
C_ClassroomService --> DB_education
C_AssignmentService --> DB_education
C_CourseService --> DB_education
C_CourseService ..> C_DepartmentService : MQ
C_CourseService ..> C_AssignmentService : REST
@enduml