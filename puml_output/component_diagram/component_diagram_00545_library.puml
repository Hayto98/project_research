@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
component "Renewal Service" as C_RenewalService
component "Librarian Service" as C_LibrarianService
component "Book Service" as C_BookService
component "Catalog Service" as C_CatalogService
component "Author Service" as C_AuthorService
component "Fine Service" as C_FineService
component "Branch Service" as C_BranchService
database "Library DB" as DB_library
C_LibrarianService --> DB_library
C_BookService --> DB_library
C_CatalogService --> DB_library
C_AuthorService --> DB_library
C_FineService --> DB_library
C_BranchService --> DB_library
C_AuthorService ..> C_BranchService : gRPC
C_LibrarianService ..> C_RenewalService : REST
C_FineService ..> C_CatalogService : HTTP
C_RenewalService ..> C_BookService : MQ
C_FineService ..> C_BranchService : REST
@enduml