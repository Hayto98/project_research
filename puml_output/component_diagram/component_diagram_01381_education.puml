@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
component "Schedule Service" as C_ScheduleService
component "Department Service" as C_DepartmentService
component "Enrollment Service" as C_EnrollmentService
component "Teacher Service" as C_TeacherService
component "Grade Service" as C_GradeService
component "Exam Service" as C_ExamService
component "Book Service" as C_BookService
database "Education DB" as DB_education
C_ScheduleService --> DB_education
C_DepartmentService --> DB_education
C_TeacherService --> DB_education
C_GradeService --> DB_education
C_ExamService --> DB_education
C_BookService --> DB_education
C_ScheduleService ..> C_DepartmentService : HTTP
C_GradeService ..> C_ScheduleService : REST
C_DepartmentService ..> C_ExamService : gRPC
@enduml