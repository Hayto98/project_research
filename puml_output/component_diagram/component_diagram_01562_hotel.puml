@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
component "Reservation Service" as C_ReservationService
component "CheckIn Service" as C_CheckInService
component "Booking Service" as C_BookingService
component "Restaurant Service" as C_RestaurantService
database "Hotel DB" as DB_hotel
C_ReservationService --> DB_hotel
C_BookingService --> DB_hotel
C_RestaurantService ..> C_CheckInService : MQ
C_BookingService ..> C_RestaurantService : HTTP
C_ReservationService ..> C_BookingService : REST
@enduml