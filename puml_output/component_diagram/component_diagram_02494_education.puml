@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
component "Enrollment Service" as C_EnrollmentService
component "Library Service" as C_LibraryService
component "Course Service" as C_CourseService
component "Book Service" as C_BookService
component "Teacher Service" as C_TeacherService
component "Exam Service" as C_ExamService
component "Classroom Service" as C_ClassroomService
database "Education DB" as DB_education
C_LibraryService --> DB_education
C_CourseService --> DB_education
C_TeacherService --> DB_education
C_ExamService --> DB_education
C_ClassroomService --> DB_education
C_BookService ..> C_CourseService : MQ
C_LibraryService ..> C_ExamService : REST
C_EnrollmentService ..> C_LibraryService : REST
C_ClassroomService ..> C_BookService : HTTP
C_CourseService ..> C_TeacherService : MQ
C_LibraryService ..> C_CourseService : REST
@enduml