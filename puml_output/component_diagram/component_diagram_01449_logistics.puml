@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
component "Inventory Service" as C_InventoryService
component "Route Service" as C_RouteService
component "Vehicle Service" as C_VehicleService
component "Manifest Service" as C_ManifestService
component "Depot Service" as C_DepotService
component "Package Service" as C_PackageService
database "Logistics DB" as DB_logistics
C_InventoryService --> DB_logistics
C_RouteService --> DB_logistics
C_VehicleService --> DB_logistics
C_ManifestService --> DB_logistics
C_DepotService --> DB_logistics
C_PackageService --> DB_logistics
C_DepotService ..> C_PackageService : REST
C_VehicleService ..> C_DepotService : gRPC
C_PackageService ..> C_VehicleService : HTTP
C_InventoryService ..> C_ManifestService : gRPC
C_RouteService ..> C_DepotService : gRPC
@enduml