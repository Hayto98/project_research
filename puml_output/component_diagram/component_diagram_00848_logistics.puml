@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
component "Route Service" as C_RouteService
component "Warehouse Service" as C_WarehouseService
component "DeliveryNote Service" as C_DeliveryNoteService
component "Inventory Service" as C_InventoryService
database "Logistics DB" as DB_logistics
C_RouteService --> DB_logistics
C_WarehouseService --> DB_logistics
C_DeliveryNoteService --> DB_logistics
C_InventoryService --> DB_logistics
C_RouteService ..> C_DeliveryNoteService : REST
C_InventoryService ..> C_DeliveryNoteService : gRPC
C_WarehouseService ..> C_InventoryService : HTTP
@enduml