@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
component "MedicalRecord Service" as C_MedicalRecordService
component "Diagnosis Service" as C_DiagnosisService
component "Billing Service" as C_BillingService
component "Hospital Service" as C_HospitalService
component "Patient Service" as C_PatientService
database "Healthcare DB" as DB_healthcare
C_MedicalRecordService --> DB_healthcare
C_DiagnosisService --> DB_healthcare
C_BillingService --> DB_healthcare
C_HospitalService --> DB_healthcare
C_PatientService --> DB_healthcare
C_MedicalRecordService ..> C_BillingService : gRPC
C_BillingService ..> C_PatientService : gRPC
C_DiagnosisService ..> C_BillingService : MQ
C_HospitalService ..> C_MedicalRecordService : gRPC
@enduml