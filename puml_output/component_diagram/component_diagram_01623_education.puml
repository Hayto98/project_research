@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
component "Classroom Service" as C_ClassroomService
component "Exam Service" as C_ExamService
component "Student Service" as C_StudentService
component "Teacher Service" as C_TeacherService
component "Attendance Service" as C_AttendanceService
component "Department Service" as C_DepartmentService
component "Book Service" as C_BookService
database "Education DB" as DB_education
C_ClassroomService --> DB_education
C_StudentService --> DB_education
C_TeacherService --> DB_education
C_AttendanceService --> DB_education
C_DepartmentService --> DB_education
C_ExamService ..> C_BookService : HTTP
C_StudentService ..> C_TeacherService : gRPC
C_BookService ..> C_ExamService : HTTP
C_ExamService ..> C_ClassroomService : REST
C_TeacherService ..> C_ExamService : HTTP
@enduml