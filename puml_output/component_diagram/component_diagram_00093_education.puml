@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
component "Attendance Service" as C_AttendanceService
component "Exam Service" as C_ExamService
component "Assignment Service" as C_AssignmentService
component "Book Service" as C_BookService
component "Classroom Service" as C_ClassroomService
component "Teacher Service" as C_TeacherService
component "Schedule Service" as C_ScheduleService
database "Education DB" as DB_education
C_AttendanceService --> DB_education
C_ExamService --> DB_education
C_AssignmentService --> DB_education
C_TeacherService --> DB_education
C_ScheduleService --> DB_education
C_AssignmentService ..> C_BookService : HTTP
C_AttendanceService ..> C_TeacherService : HTTP
C_ScheduleService ..> C_TeacherService : gRPC
C_BookService ..> C_AssignmentService : gRPC
C_ScheduleService ..> C_ClassroomService : gRPC
C_AttendanceService ..> C_BookService : gRPC
@enduml