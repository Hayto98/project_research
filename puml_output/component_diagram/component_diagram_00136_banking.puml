@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
component "Teller Service" as C_TellerService
component "Beneficiary Service" as C_BeneficiaryService
component "Account Service" as C_AccountService
component "Customer Service" as C_CustomerService
component "Transaction Service" as C_TransactionService
database "Banking DB" as DB_banking
C_BeneficiaryService --> DB_banking
C_AccountService --> DB_banking
C_CustomerService --> DB_banking
C_TellerService ..> C_AccountService : HTTP
C_CustomerService ..> C_TellerService : HTTP
C_TellerService ..> C_CustomerService : HTTP
@enduml