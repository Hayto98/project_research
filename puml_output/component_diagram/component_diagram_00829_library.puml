@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
component "Renewal Service" as C_RenewalService
component "Branch Service" as C_BranchService
component "Author Service" as C_AuthorService
component "Publisher Service" as C_PublisherService
component "Reservation Service" as C_ReservationService
component "Fine Service" as C_FineService
component "Shelf Service" as C_ShelfService
database "Library DB" as DB_library
C_RenewalService --> DB_library
C_BranchService --> DB_library
C_AuthorService --> DB_library
C_ReservationService --> DB_library
C_FineService --> DB_library
C_ShelfService --> DB_library
C_ShelfService ..> C_FineService : gRPC
C_ShelfService ..> C_AuthorService : gRPC
C_ReservationService ..> C_ShelfService : REST
C_BranchService ..> C_ReservationService : gRPC
@enduml