@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam ArrowColor #555555
component "LabTest Service" as C_LabTestService
component "Appointment Service" as C_AppointmentService
component "Doctor Service" as C_DoctorService
component "Nurse Service" as C_NurseService
component "Patient Service" as C_PatientService
component "Treatment Service" as C_TreatmentService
database "Healthcare DB" as DB_healthcare
C_LabTestService --> DB_healthcare
C_DoctorService --> DB_healthcare
C_NurseService --> DB_healthcare
C_PatientService --> DB_healthcare
C_TreatmentService --> DB_healthcare
C_NurseService ..> C_TreatmentService : REST
C_PatientService ..> C_NurseService : HTTP
C_DoctorService ..> C_AppointmentService : gRPC
C_PatientService ..> C_AppointmentService : REST
@enduml