@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
component "FuelLog Service" as C_FuelLogService
component "Route Service" as C_RouteService
component "Customer Service" as C_CustomerService
component "Warehouse Service" as C_WarehouseService
component "Vehicle Service" as C_VehicleService
component "Manifest Service" as C_ManifestService
database "Logistics DB" as DB_logistics
C_FuelLogService --> DB_logistics
C_CustomerService --> DB_logistics
C_WarehouseService --> DB_logistics
C_RouteService ..> C_VehicleService : MQ
C_FuelLogService ..> C_CustomerService : REST
C_VehicleService ..> C_FuelLogService : REST
C_FuelLogService ..> C_CustomerService : REST
C_FuelLogService ..> C_CustomerService : gRPC
@enduml