@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
component "Amenity Service" as C_AmenityService
component "Payment Service" as C_PaymentService
component "CheckIn Service" as C_CheckInService
component "Restaurant Service" as C_RestaurantService
component "Staff Service" as C_StaffService
database "Hotel DB" as DB_hotel
C_AmenityService --> DB_hotel
C_CheckInService --> DB_hotel
C_StaffService --> DB_hotel
C_StaffService ..> C_CheckInService : HTTP
C_CheckInService ..> C_PaymentService : REST
C_CheckInService ..> C_StaffService : MQ
@enduml