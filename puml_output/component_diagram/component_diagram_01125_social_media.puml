@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
component "Notification Service" as C_NotificationService
component "Story Service" as C_StoryService
component "Like Service" as C_LikeService
component "Profile Service" as C_ProfileService
component "Album Service" as C_AlbumService
component "Comment Service" as C_CommentService
database "Social Media DB" as DB_social_media
C_ProfileService --> DB_social_media
C_AlbumService --> DB_social_media
C_LikeService ..> C_CommentService : REST
C_NotificationService ..> C_AlbumService : gRPC
C_CommentService ..> C_StoryService : gRPC
C_StoryService ..> C_AlbumService : REST
C_AlbumService ..> C_LikeService : MQ
@enduml