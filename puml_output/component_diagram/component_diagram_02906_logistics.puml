@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
component "Shipment Service" as C_ShipmentService
component "Package Service" as C_PackageService
component "FuelLog Service" as C_FuelLogService
component "Driver Service" as C_DriverService
component "Customer Service" as C_CustomerService
component "DeliveryNote Service" as C_DeliveryNoteService
database "Logistics DB" as DB_logistics
C_ShipmentService --> DB_logistics
C_DriverService --> DB_logistics
C_CustomerService --> DB_logistics
C_DeliveryNoteService --> DB_logistics
C_DriverService ..> C_DeliveryNoteService : HTTP
C_FuelLogService ..> C_DriverService : gRPC
C_FuelLogService ..> C_CustomerService : gRPC
C_CustomerService ..> C_DriverService : REST
C_DeliveryNoteService ..> C_ShipmentService : MQ
@enduml