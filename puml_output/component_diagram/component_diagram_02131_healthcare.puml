@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam shadowing true
component "Treatment Service" as C_TreatmentService
component "Prescription Service" as C_PrescriptionService
component "Nurse Service" as C_NurseService
component "MedicalRecord Service" as C_MedicalRecordService
component "Patient Service" as C_PatientService
database "Healthcare DB" as DB_healthcare
C_TreatmentService --> DB_healthcare
C_PrescriptionService --> DB_healthcare
C_PrescriptionService ..> C_TreatmentService : REST
C_PatientService ..> C_NurseService : REST
C_NurseService ..> C_TreatmentService : MQ
C_NurseService ..> C_PatientService : REST
@enduml