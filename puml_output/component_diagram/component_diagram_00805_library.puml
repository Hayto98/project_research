@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
component "Author Service" as C_AuthorService
component "Fine Service" as C_FineService
component "Branch Service" as C_BranchService
component "Renewal Service" as C_RenewalService
component "Shelf Service" as C_ShelfService
component "Catalog Service" as C_CatalogService
component "Librarian Service" as C_LibrarianService
database "Library DB" as DB_library
C_FineService --> DB_library
C_BranchService --> DB_library
C_RenewalService --> DB_library
C_CatalogService --> DB_library
C_CatalogService ..> C_ShelfService : HTTP
C_AuthorService ..> C_ShelfService : gRPC
C_LibrarianService ..> C_RenewalService : HTTP
C_LibrarianService ..> C_BranchService : MQ
@enduml