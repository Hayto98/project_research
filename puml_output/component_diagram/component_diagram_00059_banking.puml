@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
component "Transfer Service" as C_TransferService
component "Interest Service" as C_InterestService
component "Card Service" as C_CardService
component "Teller Service" as C_TellerService
component "Deposit Service" as C_DepositService
database "Banking DB" as DB_banking
C_TransferService --> DB_banking
C_InterestService --> DB_banking
C_CardService --> DB_banking
C_TellerService --> DB_banking
C_TransferService ..> C_DepositService : HTTP
C_TellerService ..> C_DepositService : gRPC
C_TransferService ..> C_CardService : gRPC
@enduml