@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
component "Report Service" as C_ReportService
component "Hashtag Service" as C_HashtagService
component "User Service" as C_UserService
component "Follower Service" as C_FollowerService
component "Album Service" as C_AlbumService
component "Group Service" as C_GroupService
database "Social Media DB" as DB_social_media
C_ReportService --> DB_social_media
C_UserService --> DB_social_media
C_GroupService --> DB_social_media
C_ReportService ..> C_UserService : REST
C_HashtagService ..> C_UserService : REST
C_AlbumService ..> C_FollowerService : gRPC
C_GroupService ..> C_UserService : REST
C_FollowerService ..> C_UserService : REST
@enduml