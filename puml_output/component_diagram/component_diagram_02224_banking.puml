@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
component "Customer Service" as C_CustomerService
component "Teller Service" as C_TellerService
component "Branch Service" as C_BranchService
component "Interest Service" as C_InterestService
component "Transfer Service" as C_TransferService
component "Statement Service" as C_StatementService
component "Deposit Service" as C_DepositService
database "Banking DB" as DB_banking
C_CustomerService --> DB_banking
C_TellerService --> DB_banking
C_InterestService --> DB_banking
C_TransferService --> DB_banking
C_StatementService --> DB_banking
C_DepositService --> DB_banking
C_DepositService ..> C_CustomerService : HTTP
C_InterestService ..> C_CustomerService : gRPC
C_TransferService ..> C_TellerService : gRPC
C_DepositService ..> C_StatementService : HTTP
@enduml