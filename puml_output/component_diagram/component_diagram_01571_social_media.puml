@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
component "Like Service" as C_LikeService
component "Message Service" as C_MessageService
component "Follower Service" as C_FollowerService
component "Post Service" as C_PostService
component "Hashtag Service" as C_HashtagService
component "Comment Service" as C_CommentService
component "User Service" as C_UserService
database "Social Media DB" as DB_social_media
C_LikeService --> DB_social_media
C_MessageService --> DB_social_media
C_FollowerService --> DB_social_media
C_PostService --> DB_social_media
C_HashtagService --> DB_social_media
C_CommentService --> DB_social_media
C_UserService --> DB_social_media
C_FollowerService ..> C_LikeService : gRPC
C_LikeService ..> C_FollowerService : HTTP
C_CommentService ..> C_HashtagService : MQ
C_PostService ..> C_FollowerService : REST
C_FollowerService ..> C_MessageService : MQ
@enduml