@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
component "Attendance Service" as C_AttendanceService
component "Enrollment Service" as C_EnrollmentService
component "Grade Service" as C_GradeService
component "Library Service" as C_LibraryService
component "Student Service" as C_StudentService
component "Teacher Service" as C_TeacherService
component "Classroom Service" as C_ClassroomService
database "Education DB" as DB_education
C_AttendanceService --> DB_education
C_EnrollmentService --> DB_education
C_GradeService --> DB_education
C_LibraryService --> DB_education
C_StudentService --> DB_education
C_TeacherService --> DB_education
C_GradeService ..> C_ClassroomService : MQ
C_EnrollmentService ..> C_StudentService : REST
C_AttendanceService ..> C_TeacherService : gRPC
C_TeacherService ..> C_LibraryService : gRPC
C_StudentService ..> C_TeacherService : gRPC
C_StudentService ..> C_LibraryService : MQ
@enduml