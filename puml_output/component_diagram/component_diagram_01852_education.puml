@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
component "Grade Service" as C_GradeService
component "Student Service" as C_StudentService
component "Book Service" as C_BookService
component "Classroom Service" as C_ClassroomService
component "Exam Service" as C_ExamService
component "Department Service" as C_DepartmentService
database "Education DB" as DB_education
C_GradeService --> DB_education
C_BookService --> DB_education
C_ClassroomService --> DB_education
C_ExamService --> DB_education
C_DepartmentService --> DB_education
C_DepartmentService ..> C_BookService : MQ
C_ExamService ..> C_StudentService : gRPC
C_BookService ..> C_ClassroomService : HTTP
C_ExamService ..> C_ClassroomService : REST
C_ClassroomService ..> C_DepartmentService : gRPC
@enduml