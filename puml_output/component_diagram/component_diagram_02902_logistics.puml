@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
component "DeliveryNote Service" as C_DeliveryNoteService
component "Depot Service" as C_DepotService
component "Warehouse Service" as C_WarehouseService
component "Shipment Service" as C_ShipmentService
component "Manifest Service" as C_ManifestService
component "Customer Service" as C_CustomerService
component "FuelLog Service" as C_FuelLogService
database "Logistics DB" as DB_logistics
C_DepotService --> DB_logistics
C_WarehouseService --> DB_logistics
C_ShipmentService --> DB_logistics
C_ManifestService --> DB_logistics
C_CustomerService --> DB_logistics
C_FuelLogService --> DB_logistics
C_DeliveryNoteService ..> C_FuelLogService : MQ
C_ManifestService ..> C_WarehouseService : MQ
C_ShipmentService ..> C_DeliveryNoteService : REST
C_WarehouseService ..> C_ShipmentService : gRPC
C_DeliveryNoteService ..> C_CustomerService : gRPC
C_CustomerService ..> C_DeliveryNoteService : gRPC
@enduml