@startuml
skinparam monochrome true
skinparam defaultFontSize 11
component "Account Service" as C_AccountService
component "Statement Service" as C_StatementService
component "Branch Service" as C_BranchService
component "Withdrawal Service" as C_WithdrawalService
component "Card Service" as C_CardService
component "Transaction Service" as C_TransactionService
component "Loan Service" as C_LoanService
database "Banking DB" as DB_banking
C_AccountService --> DB_banking
C_StatementService --> DB_banking
C_WithdrawalService --> DB_banking
C_CardService --> DB_banking
C_TransactionService --> DB_banking
C_LoanService --> DB_banking
C_TransactionService ..> C_StatementService : HTTP
C_BranchService ..> C_CardService : HTTP
C_CardService ..> C_AccountService : MQ
C_WithdrawalService ..> C_AccountService : MQ
C_StatementService ..> C_AccountService : HTTP
C_CardService ..> C_TransactionService : HTTP
@enduml