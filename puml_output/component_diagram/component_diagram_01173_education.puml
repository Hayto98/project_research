@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
component "Enrollment Service" as C_EnrollmentService
component "Attendance Service" as C_AttendanceService
component "Book Service" as C_BookService
component "Assignment Service" as C_AssignmentService
component "Grade Service" as C_GradeService
database "Education DB" as DB_education
C_EnrollmentService --> DB_education
C_AttendanceService --> DB_education
C_BookService --> DB_education
C_GradeService --> DB_education
C_EnrollmentService ..> C_GradeService : HTTP
C_EnrollmentService ..> C_AssignmentService : REST
C_AttendanceService ..> C_EnrollmentService : MQ
C_EnrollmentService ..> C_BookService : REST
@enduml