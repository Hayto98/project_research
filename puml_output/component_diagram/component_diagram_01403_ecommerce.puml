@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
component "Warehouse Service" as C_WarehouseService
component "Supplier Service" as C_SupplierService
component "Review Service" as C_ReviewService
component "Coupon Service" as C_CouponService
component "Invoice Service" as C_InvoiceService
component "Cart Service" as C_CartService
component "Order Service" as C_OrderService
database "Ecommerce DB" as DB_ecommerce
C_WarehouseService --> DB_ecommerce
C_CouponService --> DB_ecommerce
C_InvoiceService --> DB_ecommerce
C_CartService --> DB_ecommerce
C_OrderService --> DB_ecommerce
C_ReviewService ..> C_SupplierService : gRPC
C_OrderService ..> C_ReviewService : gRPC
C_OrderService ..> C_InvoiceService : REST
C_InvoiceService ..> C_CartService : gRPC
C_OrderService ..> C_CouponService : MQ
C_CartService ..> C_SupplierService : gRPC
@enduml