@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
component "DeliveryNote Service" as C_DeliveryNoteService
component "Package Service" as C_PackageService
component "Vehicle Service" as C_VehicleService
component "FuelLog Service" as C_FuelLogService
component "Tracking Service" as C_TrackingService
database "Logistics DB" as DB_logistics
C_DeliveryNoteService --> DB_logistics
C_VehicleService --> DB_logistics
C_FuelLogService --> DB_logistics
C_TrackingService --> DB_logistics
C_FuelLogService ..> C_PackageService : gRPC
C_VehicleService ..> C_DeliveryNoteService : MQ
C_FuelLogService ..> C_TrackingService : gRPC
@enduml