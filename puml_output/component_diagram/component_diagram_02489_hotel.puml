@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
component "Reservation Service" as C_ReservationService
component "Housekeeping Service" as C_HousekeepingService
component "CheckOut Service" as C_CheckOutService
component "CheckIn Service" as C_CheckInService
component "Payment Service" as C_PaymentService
component "Amenity Service" as C_AmenityService
database "Hotel DB" as DB_hotel
C_ReservationService --> DB_hotel
C_HousekeepingService --> DB_hotel
C_CheckOutService --> DB_hotel
C_CheckInService --> DB_hotel
C_AmenityService --> DB_hotel
C_CheckInService ..> C_HousekeepingService : HTTP
C_CheckOutService ..> C_CheckInService : HTTP
C_ReservationService ..> C_CheckOutService : HTTP
C_PaymentService ..> C_CheckOutService : gRPC
@enduml