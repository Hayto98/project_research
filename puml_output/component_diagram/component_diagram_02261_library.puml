@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 13
component "Publisher Service" as C_PublisherService
component "Shelf Service" as C_ShelfService
component "Fine Service" as C_FineService
component "Loan Service" as C_LoanService
component "Renewal Service" as C_RenewalService
component "Reservation Service" as C_ReservationService
component "Catalog Service" as C_CatalogService
database "Library DB" as DB_library
C_PublisherService --> DB_library
C_ShelfService --> DB_library
C_FineService --> DB_library
C_LoanService --> DB_library
C_RenewalService --> DB_library
C_ReservationService --> DB_library
C_PublisherService ..> C_ReservationService : MQ
C_RenewalService ..> C_ShelfService : gRPC
C_FineService ..> C_PublisherService : HTTP
C_ReservationService ..> C_ShelfService : MQ
C_FineService ..> C_ShelfService : MQ
C_PublisherService ..> C_CatalogService : MQ
@enduml