@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
component "Patient Service" as C_PatientService
component "Billing Service" as C_BillingService
component "Hospital Service" as C_HospitalService
component "MedicalRecord Service" as C_MedicalRecordService
component "LabTest Service" as C_LabTestService
component "Ward Service" as C_WardService
database "Healthcare DB" as DB_healthcare
C_PatientService --> DB_healthcare
C_BillingService --> DB_healthcare
C_HospitalService --> DB_healthcare
C_MedicalRecordService --> DB_healthcare
C_LabTestService --> DB_healthcare
C_WardService --> DB_healthcare
C_LabTestService ..> C_BillingService : HTTP
C_PatientService ..> C_HospitalService : REST
C_LabTestService ..> C_MedicalRecordService : HTTP
C_MedicalRecordService ..> C_WardService : MQ
C_WardService ..> C_BillingService : MQ
@enduml