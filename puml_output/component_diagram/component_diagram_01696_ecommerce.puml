@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
component "Payment Service" as C_PaymentService
component "Supplier Service" as C_SupplierService
component "Shipment Service" as C_ShipmentService
component "Product Service" as C_ProductService
component "Review Service" as C_ReviewService
component "Category Service" as C_CategoryService
component "Coupon Service" as C_CouponService
database "Ecommerce DB" as DB_ecommerce
C_PaymentService --> DB_ecommerce
C_SupplierService --> DB_ecommerce
C_ShipmentService --> DB_ecommerce
C_ProductService --> DB_ecommerce
C_ReviewService --> DB_ecommerce
C_CategoryService --> DB_ecommerce
C_CouponService --> DB_ecommerce
C_CategoryService ..> C_CouponService : MQ
C_ReviewService ..> C_ShipmentService : gRPC
C_ProductService ..> C_CouponService : HTTP
@enduml