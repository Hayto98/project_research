@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 13
component "Loan Service" as C_LoanService
component "Shelf Service" as C_ShelfService
component "Branch Service" as C_BranchService
component "Member Service" as C_MemberService
component "Reservation Service" as C_ReservationService
database "Library DB" as DB_library
C_LoanService --> DB_library
C_ShelfService --> DB_library
C_BranchService --> DB_library
C_ReservationService --> DB_library
C_MemberService ..> C_LoanService : HTTP
C_BranchService ..> C_LoanService : gRPC
C_BranchService ..> C_ReservationService : gRPC
C_ReservationService ..> C_LoanService : REST
@enduml