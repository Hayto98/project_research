@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
component "Payment Service" as C_PaymentService
component "Booking Service" as C_BookingService
component "Room Service" as C_RoomService
component "Reservation Service" as C_ReservationService
database "Hotel DB" as DB_hotel
C_PaymentService --> DB_hotel
C_BookingService --> DB_hotel
C_RoomService --> DB_hotel
C_ReservationService --> DB_hotel
C_RoomService ..> C_PaymentService : HTTP
C_ReservationService ..> C_BookingService : HTTP
C_ReservationService ..> C_PaymentService : REST
@enduml