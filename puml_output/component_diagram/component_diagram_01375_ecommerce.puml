@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
component "Shipment Service" as C_ShipmentService
component "Warehouse Service" as C_WarehouseService
component "Coupon Service" as C_CouponService
component "Category Service" as C_CategoryService
component "Payment Service" as C_PaymentService
component "Cart Service" as C_CartService
database "Ecommerce DB" as DB_ecommerce
C_ShipmentService --> DB_ecommerce
C_WarehouseService --> DB_ecommerce
C_CouponService --> DB_ecommerce
C_CouponService ..> C_WarehouseService : REST
C_CouponService ..> C_CategoryService : gRPC
C_CartService ..> C_WarehouseService : REST
C_ShipmentService ..> C_PaymentService : gRPC
C_CouponService ..> C_CartService : REST
@enduml