@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
component "Category Service" as C_CategoryService
component "Product Service" as C_ProductService
component "Review Service" as C_ReviewService
component "Cart Service" as C_CartService
component "Supplier Service" as C_SupplierService
component "Coupon Service" as C_CouponService
component "Payment Service" as C_PaymentService
database "Ecommerce DB" as DB_ecommerce
C_CategoryService --> DB_ecommerce
C_ProductService --> DB_ecommerce
C_CartService --> DB_ecommerce
C_SupplierService --> DB_ecommerce
C_PaymentService ..> C_ProductService : MQ
C_SupplierService ..> C_ProductService : gRPC
C_CartService ..> C_CategoryService : MQ
C_CouponService ..> C_SupplierService : MQ
C_ReviewService ..> C_SupplierService : MQ
C_CategoryService ..> C_ProductService : HTTP
@enduml