@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
component "Review Service" as C_ReviewService
component "Supplier Service" as C_SupplierService
component "Shipment Service" as C_ShipmentService
component "Payment Service" as C_PaymentService
component "Wishlist Service" as C_WishlistService
component "Order Service" as C_OrderService
database "Ecommerce DB" as DB_ecommerce
C_ReviewService --> DB_ecommerce
C_SupplierService --> DB_ecommerce
C_ShipmentService --> DB_ecommerce
C_PaymentService --> DB_ecommerce
C_WishlistService --> DB_ecommerce
C_OrderService --> DB_ecommerce
C_OrderService ..> C_PaymentService : HTTP
C_ShipmentService ..> C_WishlistService : HTTP
C_ShipmentService ..> C_ReviewService : MQ
C_OrderService ..> C_ReviewService : MQ
C_ShipmentService ..> C_WishlistService : gRPC
@enduml