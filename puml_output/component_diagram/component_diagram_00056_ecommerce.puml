@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
component "Coupon Service" as C_CouponService
component "Shipment Service" as C_ShipmentService
component "Product Service" as C_ProductService
component "Invoice Service" as C_InvoiceService
component "Return Service" as C_ReturnService
component "Supplier Service" as C_SupplierService
component "Review Service" as C_ReviewService
database "Ecommerce DB" as DB_ecommerce
C_CouponService --> DB_ecommerce
C_ShipmentService --> DB_ecommerce
C_ProductService --> DB_ecommerce
C_ReturnService --> DB_ecommerce
C_ReviewService --> DB_ecommerce
C_InvoiceService ..> C_ReturnService : REST
C_ReviewService ..> C_ProductService : HTTP
C_InvoiceService ..> C_SupplierService : HTTP
C_SupplierService ..> C_CouponService : gRPC
C_ReviewService ..> C_InvoiceService : HTTP
@enduml