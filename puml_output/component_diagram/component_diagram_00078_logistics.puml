@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
component "Customer Service" as C_CustomerService
component "Inventory Service" as C_InventoryService
component "FuelLog Service" as C_FuelLogService
component "Route Service" as C_RouteService
component "Vehicle Service" as C_VehicleService
component "Shipment Service" as C_ShipmentService
database "Logistics DB" as DB_logistics
C_CustomerService --> DB_logistics
C_InventoryService --> DB_logistics
C_RouteService --> DB_logistics
C_ShipmentService --> DB_logistics
C_ShipmentService ..> C_VehicleService : MQ
C_CustomerService ..> C_RouteService : REST
C_InventoryService ..> C_FuelLogService : gRPC
C_RouteService ..> C_ShipmentService : REST
C_FuelLogService ..> C_ShipmentService : REST
@enduml