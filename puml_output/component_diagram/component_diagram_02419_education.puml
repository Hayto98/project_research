@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
component "Schedule Service" as C_ScheduleService
component "Course Service" as C_CourseService
component "Grade Service" as C_GradeService
component "Library Service" as C_LibraryService
component "Student Service" as C_StudentService
component "Enrollment Service" as C_EnrollmentService
component "Teacher Service" as C_TeacherService
database "Education DB" as DB_education
C_CourseService --> DB_education
C_GradeService --> DB_education
C_LibraryService --> DB_education
C_StudentService --> DB_education
C_TeacherService --> DB_education
C_LibraryService ..> C_GradeService : HTTP
C_CourseService ..> C_ScheduleService : gRPC
C_LibraryService ..> C_GradeService : HTTP
C_TeacherService ..> C_ScheduleService : HTTP
@enduml