@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam ArrowColor #555555
component "Publisher Service" as C_PublisherService
component "Author Service" as C_AuthorService
component "Shelf Service" as C_ShelfService
component "Fine Service" as C_FineService
component "Branch Service" as C_BranchService
component "Reservation Service" as C_ReservationService
component "Librarian Service" as C_LibrarianService
database "Library DB" as DB_library
C_AuthorService --> DB_library
C_BranchService --> DB_library
C_LibrarianService --> DB_library
C_AuthorService ..> C_ShelfService : gRPC
C_AuthorService ..> C_ShelfService : REST
C_AuthorService ..> C_ReservationService : HTTP
C_FineService ..> C_BranchService : gRPC
C_LibrarianService ..> C_AuthorService : HTTP
C_PublisherService ..> C_FineService : HTTP
@enduml