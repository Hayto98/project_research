@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
component "Room Service" as C_RoomService
component "Invoice Service" as C_InvoiceService
component "Payment Service" as C_PaymentService
component "Guest Service" as C_GuestService
component "Amenity Service" as C_AmenityService
component "Housekeeping Service" as C_HousekeepingService
component "Booking Service" as C_BookingService
database "Hotel DB" as DB_hotel
C_RoomService --> DB_hotel
C_PaymentService --> DB_hotel
C_GuestService --> DB_hotel
C_AmenityService --> DB_hotel
C_HousekeepingService --> DB_hotel
C_GuestService ..> C_RoomService : MQ
C_HousekeepingService ..> C_AmenityService : REST
C_GuestService ..> C_AmenityService : REST
C_AmenityService ..> C_RoomService : HTTP
@enduml