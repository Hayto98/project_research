@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
component "Teller Service" as C_TellerService
component "Interest Service" as C_InterestService
component "Transaction Service" as C_TransactionService
component "Account Service" as C_AccountService
component "Card Service" as C_CardService
component "Statement Service" as C_StatementService
component "Transfer Service" as C_TransferService
database "Banking DB" as DB_banking
C_InterestService --> DB_banking
C_CardService --> DB_banking
C_StatementService --> DB_banking
C_TransferService ..> C_InterestService : MQ
C_TransactionService ..> C_StatementService : gRPC
C_CardService ..> C_TransactionService : REST
@enduml