@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
component "MedicalRecord Service" as C_MedicalRecordService
component "Diagnosis Service" as C_DiagnosisService
component "Prescription Service" as C_PrescriptionService
component "Billing Service" as C_BillingService
component "Hospital Service" as C_HospitalService
component "Appointment Service" as C_AppointmentService
component "Nurse Service" as C_NurseService
database "Healthcare DB" as DB_healthcare
C_MedicalRecordService --> DB_healthcare
C_DiagnosisService --> DB_healthcare
C_PrescriptionService --> DB_healthcare
C_AppointmentService --> DB_healthcare
C_NurseService --> DB_healthcare
C_BillingService ..> C_NurseService : gRPC
C_DiagnosisService ..> C_MedicalRecordService : MQ
C_BillingService ..> C_AppointmentService : gRPC
C_NurseService ..> C_HospitalService : REST
C_AppointmentService ..> C_HospitalService : HTTP
@enduml