@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
component "Book Service" as C_BookService
component "Member Service" as C_MemberService
component "Reservation Service" as C_ReservationService
component "Librarian Service" as C_LibrarianService
component "Branch Service" as C_BranchService
component "Catalog Service" as C_CatalogService
database "Library DB" as DB_library
C_BookService --> DB_library
C_MemberService --> DB_library
C_ReservationService --> DB_library
C_LibrarianService --> DB_library
C_BranchService --> DB_library
C_CatalogService --> DB_library
C_LibrarianService ..> C_MemberService : MQ
C_BranchService ..> C_BookService : REST
C_BookService ..> C_MemberService : gRPC
C_LibrarianService ..> C_BookService : HTTP
C_BranchService ..> C_CatalogService : gRPC
@enduml