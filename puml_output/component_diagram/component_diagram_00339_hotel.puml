@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
component "CheckIn Service" as C_CheckInService
component "Amenity Service" as C_AmenityService
component "Room Service" as C_RoomService
component "Payment Service" as C_PaymentService
component "Service Service" as C_ServiceService
database "Hotel DB" as DB_hotel
C_CheckInService --> DB_hotel
C_AmenityService --> DB_hotel
C_RoomService --> DB_hotel
C_ServiceService ..> C_PaymentService : MQ
C_PaymentService ..> C_CheckInService : MQ
@enduml