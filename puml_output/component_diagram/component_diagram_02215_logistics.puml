@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
component "Tracking Service" as C_TrackingService
component "DeliveryNote Service" as C_DeliveryNoteService
component "Customer Service" as C_CustomerService
component "Shipment Service" as C_ShipmentService
database "Logistics DB" as DB_logistics
C_TrackingService --> DB_logistics
C_CustomerService --> DB_logistics
C_ShipmentService --> DB_logistics
C_DeliveryNoteService ..> C_CustomerService : REST
C_ShipmentService ..> C_DeliveryNoteService : REST
@enduml