@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
component "Library Service" as C_LibraryService
component "Grade Service" as C_GradeService
component "Teacher Service" as C_TeacherService
component "Enrollment Service" as C_EnrollmentService
component "Attendance Service" as C_AttendanceService
database "Education DB" as DB_education
C_LibraryService --> DB_education
C_GradeService --> DB_education
C_EnrollmentService --> DB_education
C_AttendanceService --> DB_education
C_TeacherService ..> C_GradeService : HTTP
C_AttendanceService ..> C_LibraryService : REST
C_AttendanceService ..> C_TeacherService : HTTP
C_TeacherService ..> C_EnrollmentService : HTTP
@enduml