@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
component "Depot Service" as C_DepotService
component "Inventory Service" as C_InventoryService
component "Package Service" as C_PackageService
component "Customer Service" as C_CustomerService
component "Manifest Service" as C_ManifestService
component "DeliveryNote Service" as C_DeliveryNoteService
component "Vehicle Service" as C_VehicleService
database "Logistics DB" as DB_logistics
C_DepotService --> DB_logistics
C_PackageService --> DB_logistics
C_CustomerService --> DB_logistics
C_ManifestService --> DB_logistics
C_DeliveryNoteService --> DB_logistics
C_VehicleService --> DB_logistics
C_CustomerService ..> C_VehicleService : REST
C_InventoryService ..> C_ManifestService : REST
C_InventoryService ..> C_VehicleService : REST
C_DeliveryNoteService ..> C_ManifestService : gRPC
C_VehicleService ..> C_InventoryService : REST
@enduml