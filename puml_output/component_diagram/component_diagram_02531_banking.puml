@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
component "Loan Service" as C_LoanService
component "Teller Service" as C_TellerService
component "Deposit Service" as C_DepositService
component "Withdrawal Service" as C_WithdrawalService
component "Transaction Service" as C_TransactionService
component "Card Service" as C_CardService
component "Account Service" as C_AccountService
database "Banking DB" as DB_banking
C_LoanService --> DB_banking
C_TellerService --> DB_banking
C_DepositService --> DB_banking
C_AccountService --> DB_banking
C_WithdrawalService ..> C_CardService : MQ
C_TransactionService ..> C_TellerService : REST
C_LoanService ..> C_TellerService : HTTP
C_DepositService ..> C_TransactionService : HTTP
@enduml