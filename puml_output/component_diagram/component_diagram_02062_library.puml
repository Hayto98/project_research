@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
component "Catalog Service" as C_CatalogService
component "Book Service" as C_BookService
component "Publisher Service" as C_PublisherService
component "Shelf Service" as C_ShelfService
database "Library DB" as DB_library
C_CatalogService --> DB_library
C_BookService --> DB_library
C_PublisherService --> DB_library
C_ShelfService --> DB_library
C_CatalogService ..> C_BookService : HTTP
C_PublisherService ..> C_BookService : MQ
C_BookService ..> C_ShelfService : gRPC
@enduml