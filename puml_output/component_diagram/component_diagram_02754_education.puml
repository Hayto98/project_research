@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
component "Schedule Service" as C_ScheduleService
component "Classroom Service" as C_ClassroomService
component "Enrollment Service" as C_EnrollmentService
component "Course Service" as C_CourseService
component "Library Service" as C_LibraryService
component "Assignment Service" as C_AssignmentService
component "Exam Service" as C_ExamService
database "Education DB" as DB_education
C_ScheduleService --> DB_education
C_EnrollmentService --> DB_education
C_CourseService --> DB_education
C_AssignmentService --> DB_education
C_ExamService --> DB_education
C_EnrollmentService ..> C_ScheduleService : MQ
C_ClassroomService ..> C_EnrollmentService : gRPC
C_ExamService ..> C_AssignmentService : gRPC
C_ExamService ..> C_LibraryService : gRPC
C_ScheduleService ..> C_CourseService : MQ
C_ExamService ..> C_ScheduleService : gRPC
@enduml