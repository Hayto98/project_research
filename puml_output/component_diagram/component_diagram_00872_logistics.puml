@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
component "FuelLog Service" as C_FuelLogService
component "Manifest Service" as C_ManifestService
component "Inventory Service" as C_InventoryService
component "Route Service" as C_RouteService
component "Vehicle Service" as C_VehicleService
component "Warehouse Service" as C_WarehouseService
component "DeliveryNote Service" as C_DeliveryNoteService
database "Logistics DB" as DB_logistics
C_FuelLogService --> DB_logistics
C_InventoryService --> DB_logistics
C_WarehouseService --> DB_logistics
C_WarehouseService ..> C_VehicleService : MQ
C_InventoryService ..> C_RouteService : MQ
C_VehicleService ..> C_FuelLogService : MQ
C_DeliveryNoteService ..> C_InventoryService : REST
@enduml