@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
component "Renewal Service" as C_RenewalService
component "Librarian Service" as C_LibrarianService
component "Fine Service" as C_FineService
component "Catalog Service" as C_CatalogService
component "Shelf Service" as C_ShelfService
component "Loan Service" as C_LoanService
database "Library DB" as DB_library
C_RenewalService --> DB_library
C_LibrarianService --> DB_library
C_CatalogService --> DB_library
C_ShelfService --> DB_library
C_LoanService --> DB_library
C_FineService ..> C_RenewalService : HTTP
C_ShelfService ..> C_LoanService : MQ
C_RenewalService ..> C_LoanService : MQ
C_LibrarianService ..> C_LoanService : HTTP
C_ShelfService ..> C_LoanService : REST
@enduml