@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 11
component "Branch Service" as C_BranchService
component "Book Service" as C_BookService
component "Reservation Service" as C_ReservationService
component "Publisher Service" as C_PublisherService
component "Member Service" as C_MemberService
component "Loan Service" as C_LoanService
component "Shelf Service" as C_ShelfService
database "Library DB" as DB_library
C_BranchService --> DB_library
C_BookService --> DB_library
C_MemberService --> DB_library
C_BranchService ..> C_PublisherService : MQ
C_BranchService ..> C_BookService : HTTP
C_PublisherService ..> C_MemberService : HTTP
C_MemberService ..> C_BookService : MQ
C_BranchService ..> C_LoanService : MQ
@enduml