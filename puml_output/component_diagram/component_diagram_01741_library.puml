@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
component "Renewal Service" as C_RenewalService
component "Loan Service" as C_LoanService
component "Book Service" as C_BookService
component "Reservation Service" as C_ReservationService
component "Member Service" as C_MemberService
component "Author Service" as C_AuthorService
component "Librarian Service" as C_LibrarianService
database "Library DB" as DB_library
C_LoanService --> DB_library
C_ReservationService --> DB_library
C_MemberService --> DB_library
C_AuthorService --> DB_library
C_MemberService ..> C_RenewalService : HTTP
C_RenewalService ..> C_AuthorService : REST
C_AuthorService ..> C_ReservationService : HTTP
C_AuthorService ..> C_RenewalService : HTTP
@enduml