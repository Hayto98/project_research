@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
component "Shelf Service" as C_ShelfService
component "Catalog Service" as C_CatalogService
component "Member Service" as C_MemberService
component "Loan Service" as C_LoanService
component "Reservation Service" as C_ReservationService
component "Publisher Service" as C_PublisherService
database "Library DB" as DB_library
C_ShelfService --> DB_library
C_CatalogService --> DB_library
C_MemberService --> DB_library
C_LoanService --> DB_library
C_ShelfService ..> C_MemberService : gRPC
C_LoanService ..> C_ShelfService : MQ
C_CatalogService ..> C_PublisherService : REST
C_CatalogService ..> C_MemberService : REST
@enduml