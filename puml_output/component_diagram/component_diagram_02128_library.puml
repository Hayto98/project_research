@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
component "Branch Service" as C_BranchService
component "Book Service" as C_BookService
component "Catalog Service" as C_CatalogService
component "Renewal Service" as C_RenewalService
database "Library DB" as DB_library
C_BranchService --> DB_library
C_BookService --> DB_library
C_CatalogService --> DB_library
C_RenewalService --> DB_library
C_RenewalService ..> C_BranchService : REST
C_BookService ..> C_BranchService : REST
@enduml