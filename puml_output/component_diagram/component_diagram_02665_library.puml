@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
component "Catalog Service" as C_CatalogService
component "Publisher Service" as C_PublisherService
component "Fine Service" as C_FineService
component "Member Service" as C_MemberService
component "Librarian Service" as C_LibrarianService
component "Loan Service" as C_LoanService
component "Author Service" as C_AuthorService
database "Library DB" as DB_library
C_MemberService --> DB_library
C_LibrarianService --> DB_library
C_LoanService --> DB_library
C_FineService ..> C_AuthorService : gRPC
C_LibrarianService ..> C_MemberService : REST
C_MemberService ..> C_FineService : REST
C_PublisherService ..> C_FineService : REST
@enduml