@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
component "Patient Service" as C_PatientService
component "Hospital Service" as C_HospitalService
component "Appointment Service" as C_AppointmentService
component "Treatment Service" as C_TreatmentService
component "Doctor Service" as C_DoctorService
component "Nurse Service" as C_NurseService
component "Prescription Service" as C_PrescriptionService
database "Healthcare DB" as DB_healthcare
C_TreatmentService --> DB_healthcare
C_DoctorService --> DB_healthcare
C_PrescriptionService --> DB_healthcare
C_HospitalService ..> C_PrescriptionService : HTTP
C_DoctorService ..> C_AppointmentService : gRPC
C_HospitalService ..> C_DoctorService : MQ
C_PrescriptionService ..> C_PatientService : MQ
C_NurseService ..> C_HospitalService : MQ
@enduml