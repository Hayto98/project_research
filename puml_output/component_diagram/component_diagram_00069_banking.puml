@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 11
component "Teller Service" as C_TellerService
component "Customer Service" as C_CustomerService
component "Account Service" as C_AccountService
component "Loan Service" as C_LoanService
component "Withdrawal Service" as C_WithdrawalService
component "Statement Service" as C_StatementService
component "Interest Service" as C_InterestService
database "Banking DB" as DB_banking
C_TellerService --> DB_banking
C_CustomerService --> DB_banking
C_AccountService --> DB_banking
C_LoanService --> DB_banking
C_StatementService --> DB_banking
C_InterestService --> DB_banking
C_WithdrawalService ..> C_AccountService : MQ
C_StatementService ..> C_AccountService : MQ
@enduml