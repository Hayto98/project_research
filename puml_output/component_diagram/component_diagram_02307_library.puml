@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
component "Reservation Service" as C_ReservationService
component "Loan Service" as C_LoanService
component "Renewal Service" as C_RenewalService
component "Librarian Service" as C_LibrarianService
database "Library DB" as DB_library
C_LoanService --> DB_library
C_RenewalService --> DB_library
C_LibrarianService ..> C_ReservationService : REST
C_LibrarianService ..> C_LoanService : MQ
C_ReservationService ..> C_LibrarianService : gRPC
@enduml