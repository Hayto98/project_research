@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
component "Review Service" as C_ReviewService
component "Warehouse Service" as C_WarehouseService
component "Coupon Service" as C_CouponService
component "Cart Service" as C_CartService
database "Ecommerce DB" as DB_ecommerce
C_ReviewService --> DB_ecommerce
C_CartService --> DB_ecommerce
C_WarehouseService ..> C_ReviewService : HTTP
C_CouponService ..> C_WarehouseService : HTTP
C_WarehouseService ..> C_CartService : REST
@enduml