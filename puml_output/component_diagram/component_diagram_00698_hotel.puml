@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 11
component "CheckIn Service" as C_CheckInService
component "CheckOut Service" as C_CheckOutService
component "Restaurant Service" as C_RestaurantService
component "Service Service" as C_ServiceService
database "Hotel DB" as DB_hotel
C_CheckInService --> DB_hotel
C_CheckOutService --> DB_hotel
C_ServiceService --> DB_hotel
C_RestaurantService ..> C_ServiceService : HTTP
C_CheckInService ..> C_CheckOutService : gRPC
C_CheckOutService ..> C_ServiceService : HTTP
@enduml