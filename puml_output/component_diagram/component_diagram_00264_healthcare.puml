@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 13
component "Ward Service" as C_WardService
component "Prescription Service" as C_PrescriptionService
component "Insurance Service" as C_InsuranceService
component "Hospital Service" as C_HospitalService
component "Nurse Service" as C_NurseService
component "Appointment Service" as C_AppointmentService
component "Treatment Service" as C_TreatmentService
database "Healthcare DB" as DB_healthcare
C_WardService --> DB_healthcare
C_InsuranceService --> DB_healthcare
C_HospitalService --> DB_healthcare
C_TreatmentService --> DB_healthcare
C_TreatmentService ..> C_WardService : REST
C_HospitalService ..> C_AppointmentService : REST
C_PrescriptionService ..> C_InsuranceService : REST
C_InsuranceService ..> C_TreatmentService : REST
C_AppointmentService ..> C_TreatmentService : MQ
C_NurseService ..> C_PrescriptionService : REST
@enduml