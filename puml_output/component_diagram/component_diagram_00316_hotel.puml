@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
component "CheckIn Service" as C_CheckInService
component "Service Service" as C_ServiceService
component "Invoice Service" as C_InvoiceService
component "Payment Service" as C_PaymentService
component "CheckOut Service" as C_CheckOutService
component "Room Service" as C_RoomService
database "Hotel DB" as DB_hotel
C_PaymentService --> DB_hotel
C_CheckOutService --> DB_hotel
C_RoomService --> DB_hotel
C_InvoiceService ..> C_CheckOutService : REST
C_ServiceService ..> C_PaymentService : HTTP
C_ServiceService ..> C_CheckOutService : HTTP
C_RoomService ..> C_InvoiceService : HTTP
C_CheckOutService ..> C_PaymentService : HTTP
@enduml