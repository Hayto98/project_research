@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam defaultFontSize 11
component "Renewal Service" as C_RenewalService
component "Branch Service" as C_BranchService
component "Shelf Service" as C_ShelfService
component "Loan Service" as C_LoanService
component "Librarian Service" as C_LibrarianService
component "Member Service" as C_MemberService
database "Library DB" as DB_library
C_BranchService --> DB_library
C_ShelfService --> DB_library
C_LoanService --> DB_library
C_MemberService --> DB_library
C_BranchService ..> C_LibrarianService : REST
C_BranchService ..> C_RenewalService : HTTP
C_RenewalService ..> C_ShelfService : gRPC
C_RenewalService ..> C_BranchService : HTTP
C_MemberService ..> C_ShelfService : MQ
@enduml