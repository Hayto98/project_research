@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 13
component "Vehicle Service" as C_VehicleService
component "Driver Service" as C_DriverService
component "Depot Service" as C_DepotService
component "FuelLog Service" as C_FuelLogService
component "Inventory Service" as C_InventoryService
component "Warehouse Service" as C_WarehouseService
component "DeliveryNote Service" as C_DeliveryNoteService
database "Logistics DB" as DB_logistics
C_DriverService --> DB_logistics
C_DepotService --> DB_logistics
C_FuelLogService --> DB_logistics
C_WarehouseService --> DB_logistics
C_DeliveryNoteService --> DB_logistics
C_DepotService ..> C_WarehouseService : MQ
C_DeliveryNoteService ..> C_InventoryService : HTTP
C_DriverService ..> C_DeliveryNoteService : HTTP
C_VehicleService ..> C_WarehouseService : HTTP
C_WarehouseService ..> C_VehicleService : HTTP
@enduml