@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam shadowing true
component "Vehicle Service" as C_VehicleService
component "Driver Service" as C_DriverService
component "Depot Service" as C_DepotService
component "Route Service" as C_RouteService
component "DeliveryNote Service" as C_DeliveryNoteService
component "Inventory Service" as C_InventoryService
database "Logistics DB" as DB_logistics
C_VehicleService --> DB_logistics
C_DriverService --> DB_logistics
C_DepotService --> DB_logistics
C_RouteService --> DB_logistics
C_DeliveryNoteService --> DB_logistics
C_InventoryService --> DB_logistics
C_DeliveryNoteService ..> C_DepotService : HTTP
C_DepotService ..> C_VehicleService : HTTP
C_DepotService ..> C_InventoryService : gRPC
C_DriverService ..> C_DepotService : REST
@enduml