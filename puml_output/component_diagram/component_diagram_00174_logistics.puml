@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
component "DeliveryNote Service" as C_DeliveryNoteService
component "Inventory Service" as C_InventoryService
component "Customer Service" as C_CustomerService
component "Tracking Service" as C_TrackingService
component "Route Service" as C_RouteService
component "Depot Service" as C_DepotService
database "Logistics DB" as DB_logistics
C_DeliveryNoteService --> DB_logistics
C_InventoryService --> DB_logistics
C_CustomerService --> DB_logistics
C_TrackingService --> DB_logistics
C_DepotService --> DB_logistics
C_InventoryService ..> C_TrackingService : REST
C_CustomerService ..> C_RouteService : HTTP
C_CustomerService ..> C_TrackingService : HTTP
C_DeliveryNoteService ..> C_CustomerService : gRPC
C_DeliveryNoteService ..> C_RouteService : HTTP
@enduml