@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam shadowing true
component "Coupon Service" as C_CouponService
component "Supplier Service" as C_SupplierService
component "Payment Service" as C_PaymentService
component "Shipment Service" as C_ShipmentService
component "Invoice Service" as C_InvoiceService
component "Customer Service" as C_CustomerService
component "Cart Service" as C_CartService
database "Ecommerce DB" as DB_ecommerce
C_CouponService --> DB_ecommerce
C_PaymentService --> DB_ecommerce
C_ShipmentService --> DB_ecommerce
C_InvoiceService --> DB_ecommerce
C_CartService --> DB_ecommerce
C_PaymentService ..> C_ShipmentService : HTTP
C_ShipmentService ..> C_InvoiceService : HTTP
C_PaymentService ..> C_CouponService : gRPC
C_InvoiceService ..> C_CustomerService : REST
C_InvoiceService ..> C_ShipmentService : MQ
C_SupplierService ..> C_ShipmentService : HTTP
@enduml