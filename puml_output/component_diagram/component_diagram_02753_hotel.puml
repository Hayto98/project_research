@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
component "Amenity Service" as C_AmenityService
component "CheckIn Service" as C_CheckInService
component "Payment Service" as C_PaymentService
component "Restaurant Service" as C_RestaurantService
component "Invoice Service" as C_InvoiceService
component "Reservation Service" as C_ReservationService
database "Hotel DB" as DB_hotel
C_AmenityService --> DB_hotel
C_RestaurantService --> DB_hotel
C_InvoiceService --> DB_hotel
C_ReservationService --> DB_hotel
C_PaymentService ..> C_AmenityService : HTTP
C_RestaurantService ..> C_InvoiceService : gRPC
C_AmenityService ..> C_ReservationService : HTTP
@enduml