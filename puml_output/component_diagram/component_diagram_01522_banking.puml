@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
component "Transaction Service" as C_TransactionService
component "Customer Service" as C_CustomerService
component "Withdrawal Service" as C_WithdrawalService
component "Teller Service" as C_TellerService
component "Beneficiary Service" as C_BeneficiaryService
database "Banking DB" as DB_banking
C_TransactionService --> DB_banking
C_CustomerService --> DB_banking
C_WithdrawalService --> DB_banking
C_TransactionService ..> C_BeneficiaryService : gRPC
C_CustomerService ..> C_TransactionService : gRPC
@enduml