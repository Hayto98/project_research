@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam defaultFontSize 13
component "Branch Service" as C_BranchService
component "Author Service" as C_AuthorService
component "Publisher Service" as C_PublisherService
component "Book Service" as C_BookService
component "Fine Service" as C_FineService
component "Catalog Service" as C_CatalogService
component "Reservation Service" as C_ReservationService
database "Library DB" as DB_library
C_AuthorService --> DB_library
C_PublisherService --> DB_library
C_BookService --> DB_library
C_FineService --> DB_library
C_PublisherService ..> C_BookService : gRPC
C_AuthorService ..> C_BookService : HTTP
C_BranchService ..> C_ReservationService : HTTP
C_CatalogService ..> C_BookService : REST
C_BranchService ..> C_FineService : gRPC
C_CatalogService ..> C_PublisherService : HTTP
@enduml