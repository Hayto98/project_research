@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
component "Fine Service" as C_FineService
component "Member Service" as C_MemberService
component "Shelf Service" as C_ShelfService
component "Loan Service" as C_LoanService
component "Reservation Service" as C_ReservationService
component "Author Service" as C_AuthorService
component "Book Service" as C_BookService
