@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
component "Return Service" as C_ReturnService
component "Category Service" as C_CategoryService
component "Coupon Service" as C_CouponService
component "Invoice Service" as C_InvoiceService
component "Shipment Service" as C_ShipmentService
database "Ecommerce DB" as DB_ecommerce
C_ReturnService --> DB_ecommerce
C_CategoryService --> DB_ecommerce
C_CouponService --> DB_ecommerce
C_InvoiceService --> DB_ecommerce
C_InvoiceService ..> C_ShipmentService : gRPC
C_CategoryService ..> C_InvoiceService : gRPC
C_ShipmentService ..> C_CategoryService : HTTP
C_InvoiceService ..> C_ReturnService : REST
@enduml