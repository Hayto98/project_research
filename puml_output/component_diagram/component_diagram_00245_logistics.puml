@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
component "Manifest Service" as C_ManifestService
component "Depot Service" as C_DepotService
component "Package Service" as C_PackageService
component "DeliveryNote Service" as C_DeliveryNoteService
component "Tracking Service" as C_TrackingService
component "Shipment Service" as C_ShipmentService
database "Logistics DB" as DB_logistics
C_DepotService --> DB_logistics
C_PackageService --> DB_logistics
C_DeliveryNoteService --> DB_logistics
C_TrackingService --> DB_logistics
C_ShipmentService --> DB_logistics
C_DeliveryNoteService ..> C_DepotService : REST
C_ManifestService ..> C_TrackingService : HTTP
C_PackageService ..> C_ManifestService : MQ
C_DepotService ..> C_ShipmentService : gRPC
C_ShipmentService ..> C_ManifestService : MQ
@enduml