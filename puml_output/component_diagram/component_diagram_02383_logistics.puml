@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
component "Warehouse Service" as C_WarehouseService
component "Manifest Service" as C_ManifestService
component "Package Service" as C_PackageService
component "Depot Service" as C_DepotService
component "Shipment Service" as C_ShipmentService
component "Vehicle Service" as C_VehicleService
database "Logistics DB" as DB_logistics
C_ManifestService --> DB_logistics
C_PackageService --> DB_logistics
C_DepotService --> DB_logistics
C_VehicleService --> DB_logistics
C_ManifestService ..> C_WarehouseService : HTTP
C_ManifestService ..> C_ShipmentService : gRPC
C_WarehouseService ..> C_ShipmentService : gRPC
@enduml