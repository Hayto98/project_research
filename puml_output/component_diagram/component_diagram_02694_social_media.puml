@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
component "Album Service" as C_AlbumService
component "Post Service" as C_PostService
component "Follower Service" as C_FollowerService
component "Like Service" as C_LikeService
component "Profile Service" as C_ProfileService
component "Message Service" as C_MessageService
component "Report Service" as C_ReportService
database "Social Media DB" as DB_social_media
C_AlbumService --> DB_social_media
C_PostService --> DB_social_media
C_FollowerService --> DB_social_media
C_LikeService --> DB_social_media
C_ProfileService --> DB_social_media
C_ReportService --> DB_social_media
C_LikeService ..> C_ReportService : gRPC
C_FollowerService ..> C_AlbumService : MQ
C_MessageService ..> C_ReportService : REST
C_ReportService ..> C_ProfileService : REST
C_ReportService ..> C_AlbumService : REST
C_LikeService ..> C_PostService : gRPC
@enduml