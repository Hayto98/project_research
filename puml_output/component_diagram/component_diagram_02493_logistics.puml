@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
skinparam ArrowColor #555555
component "Customer Service" as C_CustomerService
component "Manifest Service" as C_ManifestService
component "Vehicle Service" as C_VehicleService
component "Depot Service" as C_DepotService
component "Tracking Service" as C_TrackingService
database "Logistics DB" as DB_logistics
C_CustomerService --> DB_logistics
C_ManifestService --> DB_logistics
C_VehicleService --> DB_logistics
C_DepotService --> DB_logistics
C_CustomerService ..> C_ManifestService : MQ
C_DepotService ..> C_TrackingService : REST
@enduml