@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam defaultFontSize 13
component "Nurse Service" as C_NurseService
component "Billing Service" as C_BillingService
component "Patient Service" as C_PatientService
component "Prescription Service" as C_PrescriptionService
component "Insurance Service" as C_InsuranceService
component "Doctor Service" as C_DoctorService
component "Appointment Service" as C_AppointmentService
database "Healthcare DB" as DB_healthcare
C_NurseService --> DB_healthcare
C_BillingService --> DB_healthcare
C_PatientService --> DB_healthcare
C_PrescriptionService --> DB_healthcare
C_InsuranceService --> DB_healthcare
C_PatientService ..> C_BillingService : REST
C_PatientService ..> C_NurseService : REST
C_PatientService ..> C_InsuranceService : REST
@enduml