@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
component "Story Service" as C_StoryService
component "Report Service" as C_ReportService
component "Album Service" as C_AlbumService
component "Message Service" as C_MessageService
component "Profile Service" as C_ProfileService
database "Social Media DB" as DB_social_media
C_StoryService --> DB_social_media
C_ReportService --> DB_social_media
C_MessageService --> DB_social_media
C_ProfileService --> DB_social_media
C_ProfileService ..> C_MessageService : MQ
C_StoryService ..> C_MessageService : REST
C_MessageService ..> C_AlbumService : HTTP
@enduml