@startuml
skinparam backgroundColor #FFFFFF
skinparam roundCorner 15
skinparam defaultFontSize 11
component "Ward Service" as C_WardService
component "Hospital Service" as C_HospitalService
component "Treatment Service" as C_TreatmentService
component "Patient Service" as C_PatientService
component "Diagnosis Service" as C_DiagnosisService
component "Nurse Service" as C_NurseService
database "Healthcare DB" as DB_healthcare
C_WardService --> DB_healthcare
C_TreatmentService --> DB_healthcare
C_PatientService --> DB_healthcare
C_NurseService --> DB_healthcare
C_HospitalService ..> C_TreatmentService : gRPC
C_PatientService ..> C_NurseService : HTTP
C_DiagnosisService ..> C_TreatmentService : gRPC
C_NurseService ..> C_DiagnosisService : MQ
@enduml