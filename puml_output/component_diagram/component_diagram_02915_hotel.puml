@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
component "Reservation Service" as C_ReservationService
component "Service Service" as C_ServiceService
component "Booking Service" as C_BookingService
component "Invoice Service" as C_InvoiceService
component "CheckIn Service" as C_CheckInService
component "Payment Service" as C_PaymentService
database "Hotel DB" as DB_hotel
C_ReservationService --> DB_hotel
C_CheckInService --> DB_hotel
C_PaymentService --> DB_hotel
C_BookingService ..> C_ReservationService : REST
C_ServiceService ..> C_CheckInService : gRPC
C_PaymentService ..> C_CheckInService : REST
C_BookingService ..> C_InvoiceService : REST
C_PaymentService ..> C_ServiceService : gRPC
@enduml