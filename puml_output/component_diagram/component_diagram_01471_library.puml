@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam ArrowColor #555555
component "Branch Service" as C_BranchService
component "Publisher Service" as C_PublisherService
component "Book Service" as C_BookService
component "Renewal Service" as C_RenewalService
component "Member Service" as C_MemberService
database "Library DB" as DB_library
C_BranchService --> DB_library
C_PublisherService --> DB_library
C_BookService --> DB_library
C_MemberService --> DB_library
C_MemberService ..> C_BookService : HTTP
C_BranchService ..> C_RenewalService : gRPC
C_RenewalService ..> C_MemberService : REST
@enduml