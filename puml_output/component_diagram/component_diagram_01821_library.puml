@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam ArrowColor #555555
component "Publisher Service" as C_PublisherService
component "Book Service" as C_BookService
component "Member Service" as C_MemberService
component "Fine Service" as C_FineService
component "Catalog Service" as C_CatalogService
database "Library DB" as DB_library
C_BookService --> DB_library
C_FineService --> DB_library
C_CatalogService --> DB_library
C_PublisherService ..> C_MemberService : HTTP
C_PublisherService ..> C_CatalogService : gRPC
C_MemberService ..> C_BookService : HTTP
@enduml