@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
component "Nurse Service" as C_NurseService
component "Diagnosis Service" as C_DiagnosisService
component "Billing Service" as C_BillingService
component "Hospital Service" as C_HospitalService
component "LabTest Service" as C_LabTestService
component "MedicalRecord Service" as C_MedicalRecordService
database "Healthcare DB" as DB_healthcare
C_DiagnosisService --> DB_healthcare
C_BillingService --> DB_healthcare
C_HospitalService --> DB_healthcare
C_MedicalRecordService --> DB_healthcare
C_MedicalRecordService ..> C_HospitalService : REST
C_MedicalRecordService ..> C_DiagnosisService : HTTP
C_LabTestService ..> C_BillingService : gRPC
C_BillingService ..> C_HospitalService : gRPC
C_DiagnosisService ..> C_MedicalRecordService : gRPC
@enduml