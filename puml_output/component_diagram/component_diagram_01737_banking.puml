@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
component "Interest Service" as C_InterestService
component "Beneficiary Service" as C_BeneficiaryService
component "Transaction Service" as C_TransactionService
component "Deposit Service" as C_DepositService
component "Customer Service" as C_CustomerService
component "Card Service" as C_CardService
database "Banking DB" as DB_banking
C_BeneficiaryService --> DB_banking
C_TransactionService --> DB_banking
C_DepositService --> DB_banking
C_TransactionService ..> C_InterestService : HTTP
C_InterestService ..> C_CustomerService : gRPC
C_InterestService ..> C_CardService : HTTP
C_CardService ..> C_CustomerService : REST
C_CustomerService ..> C_CardService : gRPC
@enduml