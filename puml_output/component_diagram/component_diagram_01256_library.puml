@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
component "Member Service" as C_MemberService
component "Librarian Service" as C_LibrarianService
component "Catalog Service" as C_CatalogService
component "Shelf Service" as C_ShelfService
component "Book Service" as C_BookService
component "Loan Service" as C_LoanService
component "Renewal Service" as C_RenewalService
database "Library DB" as DB_library
C_MemberService --> DB_library
C_LibrarianService --> DB_library
C_ShelfService --> DB_library
C_BookService --> DB_library
C_LoanService --> DB_library
C_LoanService ..> C_BookService : REST
C_LoanService ..> C_RenewalService : REST
C_CatalogService ..> C_ShelfService : MQ
C_CatalogService ..> C_BookService : MQ
C_BookService ..> C_LoanService : HTTP
@enduml