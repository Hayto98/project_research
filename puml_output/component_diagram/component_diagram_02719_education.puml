@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
component "Library Service" as C_LibraryService
component "Classroom Service" as C_ClassroomService
component "Student Service" as C_StudentService
component "Schedule Service" as C_ScheduleService
component "Grade Service" as C_GradeService
component "Assignment Service" as C_AssignmentService
database "Education DB" as DB_education
C_LibraryService --> DB_education
C_ClassroomService --> DB_education
C_StudentService --> DB_education
C_ScheduleService --> DB_education
C_GradeService --> DB_education
C_AssignmentService --> DB_education
C_LibraryService ..> C_StudentService : REST
C_AssignmentService ..> C_ScheduleService : MQ
C_StudentService ..> C_ClassroomService : MQ
C_LibraryService ..> C_ScheduleService : MQ
C_ClassroomService ..> C_AssignmentService : gRPC
@enduml