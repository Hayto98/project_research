@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
component "Category Service" as C_CategoryService
component "Coupon Service" as C_CouponService
component "Review Service" as C_ReviewService
component "Order Service" as C_OrderService
component "Supplier Service" as C_SupplierService
component "Return Service" as C_ReturnService
component "Shipment Service" as C_ShipmentService
database "Ecommerce DB" as DB_ecommerce
C_CategoryService --> DB_ecommerce
C_CouponService --> DB_ecommerce
C_OrderService --> DB_ecommerce
C_SupplierService --> DB_ecommerce
C_ReturnService --> DB_ecommerce
C_ShipmentService --> DB_ecommerce
C_SupplierService ..> C_ReturnService : HTTP
C_ReviewService ..> C_SupplierService : HTTP
C_OrderService ..> C_ReturnService : REST
C_CouponService ..> C_SupplierService : REST
C_OrderService ..> C_ReviewService : gRPC
C_ShipmentService ..> C_ReturnService : MQ
@enduml