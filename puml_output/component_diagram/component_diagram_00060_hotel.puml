@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
component "Staff Service" as C_StaffService
component "Payment Service" as C_PaymentService
component "Room Service" as C_RoomService
component "Housekeeping Service" as C_HousekeepingService
component "CheckIn Service" as C_CheckInService
component "Booking Service" as C_BookingService
component "Guest Service" as C_GuestService
database "Hotel DB" as DB_hotel
C_StaffService --> DB_hotel
C_PaymentService --> DB_hotel
C_RoomService --> DB_hotel
C_CheckInService --> DB_hotel
C_BookingService --> DB_hotel
C_GuestService --> DB_hotel
C_PaymentService ..> C_HousekeepingService : REST
C_CheckInService ..> C_StaffService : MQ
C_StaffService ..> C_PaymentService : MQ
C_GuestService ..> C_RoomService : gRPC
C_GuestService ..> C_PaymentService : HTTP
C_CheckInService ..> C_HousekeepingService : HTTP
@enduml