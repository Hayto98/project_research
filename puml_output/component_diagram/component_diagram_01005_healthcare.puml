@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 13
component "Prescription Service" as C_PrescriptionService
component "Doctor Service" as C_DoctorService
component "Hospital Service" as C_HospitalService
component "Billing Service" as C_BillingService
database "Healthcare DB" as DB_healthcare
C_PrescriptionService --> DB_healthcare
C_DoctorService --> DB_healthcare
C_BillingService --> DB_healthcare
C_BillingService ..> C_DoctorService : REST
C_PrescriptionService ..> C_HospitalService : HTTP
C_BillingService ..> C_HospitalService : gRPC
@enduml