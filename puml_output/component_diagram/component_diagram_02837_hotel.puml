@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam ArrowColor #555555
component "Service Service" as C_ServiceService
component "CheckOut Service" as C_CheckOutService
component "Guest Service" as C_GuestService
component "Amenity Service" as C_AmenityService
component "Housekeeping Service" as C_HousekeepingService
database "Hotel DB" as DB_hotel
C_ServiceService --> DB_hotel
C_CheckOutService --> DB_hotel
C_GuestService --> DB_hotel
C_HousekeepingService --> DB_hotel
C_AmenityService ..> C_GuestService : HTTP
C_GuestService ..> C_HousekeepingService : REST
@enduml