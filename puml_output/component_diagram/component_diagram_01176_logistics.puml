@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam ArrowColor #555555
component "Warehouse Service" as C_WarehouseService
component "Package Service" as C_PackageService
component "Vehicle Service" as C_VehicleService
component "Tracking Service" as C_TrackingService
component "Shipment Service" as C_ShipmentService
component "Inventory Service" as C_InventoryService
component "Customer Service" as C_CustomerService
database "Logistics DB" as DB_logistics
C_PackageService --> DB_logistics
C_VehicleService --> DB_logistics
C_TrackingService --> DB_logistics
C_ShipmentService --> DB_logistics
C_InventoryService --> DB_logistics
C_CustomerService --> DB_logistics
C_VehicleService ..> C_InventoryService : gRPC
C_WarehouseService ..> C_TrackingService : gRPC
C_CustomerService ..> C_WarehouseService : HTTP
C_PackageService ..> C_VehicleService : HTTP
C_CustomerService ..> C_ShipmentService : REST
C_CustomerService ..> C_PackageService : HTTP
@enduml