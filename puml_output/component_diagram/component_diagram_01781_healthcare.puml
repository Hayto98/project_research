@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #E8F4FA
skinparam classBorderColor #2C7DA0
component "Nurse Service" as C_NurseService
component "Appointment Service" as C_AppointmentService
component "Hospital Service" as C_HospitalService
component "Treatment Service" as C_TreatmentService
database "Healthcare DB" as DB_healthcare
C_NurseService --> DB_healthcare
C_AppointmentService --> DB_healthcare
C_HospitalService --> DB_healthcare
C_AppointmentService ..> C_HospitalService : gRPC
C_NurseService ..> C_HospitalService : HTTP
C_NurseService ..> C_AppointmentService : MQ
@enduml