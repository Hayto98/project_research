@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F1F8E9
skinparam classBorderColor #33691E
skinparam defaultFontSize 11
component "Transaction Service" as C_TransactionService
component "Loan Service" as C_LoanService
component "Account Service" as C_AccountService
component "Beneficiary Service" as C_BeneficiaryService
component "Withdrawal Service" as C_WithdrawalService
component "Branch Service" as C_BranchService
component "Transfer Service" as C_TransferService
database "Banking DB" as DB_banking
C_AccountService --> DB_banking
C_BeneficiaryService --> DB_banking
C_BranchService --> DB_banking
C_TransferService --> DB_banking
C_BeneficiaryService ..> C_TransactionService : gRPC
C_BranchService ..> C_TransactionService : gRPC
C_WithdrawalService ..> C_TransferService : MQ
C_TransferService ..> C_LoanService : REST
@enduml