@startuml
skinparam backgroundColor #FFFDE7
skinparam classBackgroundColor #FFF9C4
skinparam classBorderColor #F57F17
skinparam shadowing true
component "Patient Service" as C_PatientService
component "Nurse Service" as C_NurseService
component "Ward Service" as C_WardService
component "Appointment Service" as C_AppointmentService
component "Prescription Service" as C_PrescriptionService
database "Healthcare DB" as DB_healthcare
C_PatientService --> DB_healthcare
C_NurseService --> DB_healthcare
C_AppointmentService --> DB_healthcare
C_PrescriptionService --> DB_healthcare
C_AppointmentService ..> C_PrescriptionService : gRPC
C_WardService ..> C_PatientService : HTTP
C_PatientService ..> C_NurseService : HTTP
C_AppointmentService ..> C_WardService : MQ
@enduml