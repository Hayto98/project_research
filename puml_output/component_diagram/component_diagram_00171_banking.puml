@startuml
skinparam shadowing false
skinparam backgroundColor #F5F5F5
skinparam defaultFontSize 11
component "Customer Service" as C_CustomerService
component "Card Service" as C_CardService
component "Transfer Service" as C_TransferService
component "Teller Service" as C_TellerService
component "Branch Service" as C_BranchService
database "Banking DB" as DB_banking
C_CustomerService --> DB_banking
C_CardService --> DB_banking
C_BranchService --> DB_banking
C_BranchService ..> C_CustomerService : gRPC
C_BranchService ..> C_TellerService : REST
C_BranchService ..> C_CardService : MQ
C_CustomerService ..> C_TransferService : REST
@enduml