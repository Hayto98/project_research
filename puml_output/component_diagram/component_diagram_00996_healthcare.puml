@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
component "MedicalRecord Service" as C_MedicalRecordService
component "Prescription Service" as C_PrescriptionService
component "Billing Service" as C_BillingService
component "Nurse Service" as C_NurseService
component "Appointment Service" as C_AppointmentService
component "Insurance Service" as C_InsuranceService
component "Doctor Service" as C_DoctorService
database "Healthcare DB" as DB_healthcare
C_MedicalRecordService --> DB_healthcare
C_PrescriptionService --> DB_healthcare
C_BillingService --> DB_healthcare
C_NurseService --> DB_healthcare
C_AppointmentService --> DB_healthcare
C_InsuranceService --> DB_healthcare
C_DoctorService --> DB_healthcare
C_NurseService ..> C_MedicalRecordService : REST
C_PrescriptionService ..> C_InsuranceService : REST
C_MedicalRecordService ..> C_NurseService : gRPC
C_PrescriptionService ..> C_MedicalRecordService : REST
C_DoctorService ..> C_BillingService : REST
