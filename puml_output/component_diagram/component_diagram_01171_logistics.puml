@startuml
skinparam backgroundColor #ECEFF1
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #455A64
skinparam defaultFontSize 13
component "DeliveryNote Service" as C_DeliveryNoteService
component "Vehicle Service" as C_VehicleService
component "FuelLog Service" as C_FuelLogService
component "Customer Service" as C_CustomerService
component "Depot Service" as C_DepotService
database "Logistics DB" as DB_logistics
C_DeliveryNoteService --> DB_logistics
C_VehicleService --> DB_logistics
C_CustomerService --> DB_logistics
C_DepotService --> DB_logistics
C_DepotService ..> C_CustomerService : MQ
C_FuelLogService ..> C_CustomerService : MQ
C_DepotService ..> C_FuelLogService : gRPC
C_CustomerService ..> C_DepotService : gRPC
@enduml