@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam defaultFontSize 11
component "Comment Service" as C_CommentService
component "Report Service" as C_ReportService
component "Post Service" as C_PostService
component "Follower Service" as C_FollowerService
component "Group Service" as C_GroupService
component "Album Service" as C_AlbumService
database "Social Media DB" as DB_social_media
C_CommentService --> DB_social_media
C_ReportService --> DB_social_media
C_FollowerService --> DB_social_media
C_GroupService --> DB_social_media
C_AlbumService --> DB_social_media
C_AlbumService ..> C_CommentService : gRPC
C_CommentService ..> C_ReportService : HTTP
C_GroupService ..> C_CommentService : HTTP
C_FollowerService ..> C_PostService : HTTP
C_FollowerService ..> C_ReportService : gRPC
@enduml