@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #FFF3E0
skinparam classBorderColor #E65100
skinparam shadowing true
component "Appointment Service" as C_AppointmentService
component "MedicalRecord Service" as C_MedicalRecordService
component "Hospital Service" as C_HospitalService
component "Patient Service" as C_PatientService
component "LabTest Service" as C_LabTestService
component "Nurse Service" as C_NurseService
component "Insurance Service" as C_InsuranceService
database "Healthcare DB" as DB_healthcare
C_AppointmentService --> DB_healthcare
C_HospitalService --> DB_healthcare
C_PatientService --> DB_healthcare
C_NurseService --> DB_healthcare
C_InsuranceService --> DB_healthcare
C_NurseService ..> C_PatientService : gRPC
C_InsuranceService ..> C_LabTestService : MQ
C_PatientService ..> C_NurseService : MQ
C_MedicalRecordService ..> C_InsuranceService : MQ
C_HospitalService ..> C_PatientService : REST
@enduml