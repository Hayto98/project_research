@startuml
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #6A1B9A
skinparam shadowing true
component "MedicalRecord Service" as C_MedicalRecordService
component "Ward Service" as C_WardService
component "Nurse Service" as C_NurseService
component "Patient Service" as C_PatientService
component "Hospital Service" as C_HospitalService
component "Treatment Service" as C_TreatmentService
component "Prescription Service" as C_PrescriptionService
database "Healthcare DB" as DB_healthcare
C_MedicalRecordService --> DB_healthcare
C_WardService --> DB_healthcare
C_NurseService --> DB_healthcare
C_TreatmentService --> DB_healthcare
C_PrescriptionService --> DB_healthcare
C_HospitalService ..> C_NurseService : HTTP
C_WardService ..> C_HospitalService : HTTP
C_NurseService ..> C_PrescriptionService : MQ
C_WardService ..> C_MedicalRecordService : HTTP
C_PatientService ..> C_NurseService : gRPC
@enduml